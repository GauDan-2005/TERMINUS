[163.838937, "i", "cat > /app/scripts/run-matrix.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\nAPP_ROOT=\"${APP_ROOT:-/app}\"\nOUT=\"${APP_ROOT}/output\"\nmkdir -p \"${OUT}\"\n\n# Do not wipe the entire output directory; only replace the matrix audit.\nrm -f \"${OUT}/solver-audit.json\"\n\nSOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\nif [ ! -x \"${SOLVERCTL}\" ]; then\n  SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\nfi\n\n\"${SOLVERCTL}\" matrix\nEOF\nchmod +x /app/scripts/run-matrix.sh\n"]
[163.841717, "o", "cat > /app/scripts/run-matrix.sh <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #!/bin/bash\r\n\u001b[?2004l\r\u001b[?2004h> set -euo pipefail\r\n\u001b[?2004l\r\u001b[?2004h> APP_ROOT=\"${APP_ROOT:-/app}\"\r\n\u001b[?2004l\r\u001b[?2004h> OUT=\"${APP_ROOT}/output\"\r\n\u001b[?2004l\r\u001b[?2004h> mkdir -p \"${OUT}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Do not wipe the entire output directory; only replace the matrix audit.\r\n\u001b[?2004l\r\u001b[?2004h> rm -f \"${OUT}/solver-audit.json\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\r\n\u001b[?2004l\r\u001b[?2004h> if [ ! -x \"${SOLVERCTL}\" ]; then\r\n\u001b[?2004l\r\u001b[?2004h>   SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\r\n\u001b[?2004l\r\u001b[?2004h> fi\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \"${SOLVERCTL}\" matrix\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
