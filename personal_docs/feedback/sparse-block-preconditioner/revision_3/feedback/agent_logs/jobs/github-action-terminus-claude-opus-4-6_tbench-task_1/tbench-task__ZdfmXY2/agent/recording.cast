[108.656321, "o", ">     int nblocks = c / d;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int bi = 0; bi < nblocks; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h>         for (int r = 0; r < d; r++) {\r\n\u001b[?2004l\r\u001b[?2004h>             e[bi * d + r] = a[b[bi] * d + r];\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[108.657259, "o", "\u001b[?2004hroot@fdca5a4b6410:/app# "]
[108.781686, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        int blk = i / a->bs;\n        int loc = i % a->bs;\n        c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\n    }\n}\nEOF\n"]
[108.782219, "o", "cat > /app/prec_r/apply.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
