[12.26729, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n\"${APP_ROOT}/bin/solverctl\" matrix\r\n"]
[12.267557, "o", "\u001b[?2004hroot@ef972ec32819:/app# "]
[12.37712, "i", "cat /app/scripts/run-one.sh\n"]
