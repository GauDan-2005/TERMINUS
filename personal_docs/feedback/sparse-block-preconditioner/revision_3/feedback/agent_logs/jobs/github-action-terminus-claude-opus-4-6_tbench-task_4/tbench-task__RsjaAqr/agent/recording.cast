[208.004925, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int nblocks = c / d;\n    for (int bi = 0; bi < nblocks; bi++) {\n        int src = b[bi];\n        for (int r = 0; r < d; r++) {\n            e[bi * d + r] = a[src * d + r];\n        }\n    }\n}\nEOF\n"]
[208.00707, "o", "cat > /app/perm_p/order.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void map_p(const double *a, const int *b, int c, int d, double *e) {\r\n\u001b[?2004l\r\u001b[?2004h>     int nblocks = c / d;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int bi = 0; bi < nblocks; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int src = b[bi];\r\n\u001b[?2004l\r\u001b[?2004h>         for (int r = 0; r < d; r++) {\r\n\u001b[?2004l\r\u001b[?2004h>             e[bi * d + r] = a[src * d + r];\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[208.0073, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h"]
