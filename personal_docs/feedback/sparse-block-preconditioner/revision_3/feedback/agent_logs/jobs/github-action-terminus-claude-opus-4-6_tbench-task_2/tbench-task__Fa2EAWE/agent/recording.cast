[200.289452, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[200.289634, "o", "void map_p(const double *a, const int *b, int c, int d, double *e) {\r\n\u001b[?2004l\r"]
[200.289736, "o", "\u001b[?2004h> "]
[200.289771, "o", "    int nblocks = c / d;"]
[200.290606, "o", "\r\n\u001b[?2004l\r"]
[200.290664, "o", "\u001b[?2004h> "]
[200.29079, "o", "    for (int bi = 0; bi < nblocks; bi++) {\r\n\u001b[?2004l\r"]
[200.29082, "o", "\u001b[?2004h> "]
