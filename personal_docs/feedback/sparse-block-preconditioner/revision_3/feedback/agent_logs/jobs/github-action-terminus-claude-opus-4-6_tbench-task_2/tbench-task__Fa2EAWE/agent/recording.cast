[200.290994, "o", "\u001b[?2004h> "]
[200.291162, "o", "            e[bi * d + r] = a[b[bi] * d + r];\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.291316, "o", ">         }\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.29135, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
