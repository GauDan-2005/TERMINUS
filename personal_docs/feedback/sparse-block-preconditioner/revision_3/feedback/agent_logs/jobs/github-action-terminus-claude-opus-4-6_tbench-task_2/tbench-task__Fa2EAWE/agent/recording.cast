[179.939063, "o", "\u001b[?2004h> "]
[179.93934, "o", "        c->row_ptr[bi] = ptr;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[179.939451, "o", "        for (int bj = 0; bj < nb; bj++) {\r\n\u001b[?2004l\r"]
[179.939512, "o", "\u001b[?2004h> "]
[179.93973, "o", "            int col_blk = reorder ? a->perm[bj] : bj;\r\n\u001b[?2004l\r"]
[179.93976, "o", "\u001b[?2004h> "]
[179.939882, "o", "            int has = 0;\r\n\u001b[?2004l\r"]
[179.93991, "o", "\u001b[?2004h> "]
[179.940094, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[179.940209, "o", "> "]
[179.94029, "o", "                for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[179.940317, "o", "\u001b[?2004h> "]
[179.940489, "o", "                    int gr = row_blk * bs + r;\r\n\u001b[?2004l\r"]
[179.940517, "o", "\u001b[?2004h> "]
[179.940667, "o", "                    int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[179.94082, "o", "\u001b[?2004h> "]
[179.940909, "o", "                    double v = a->a[gr * dim + gc];\r\n\u001b[?2004l\r"]
[179.940999, "o", "\u001b[?2004h> "]
[179.941113, "o", "                    if (fabs(v) > 0.0) {\r\n\u001b[?2004l\r"]
[179.94118, "o", "\u001b[?2004h> "]
[179.941268, "o", "                        has = 1;\r\n\u001b[?2004l\r"]
[179.941297, "o", "\u001b[?2004h> "]
[179.941401, "o", "                    }"]
[179.941478, "o", "\r\n\u001b[?2004l\r"]
[179.94154, "o", "\u001b[?2004h"]
[179.941567, "o", "> "]
[179.941672, "o", "                }\r\n\u001b[?2004l\r"]
[179.941828, "o", "\u001b[?2004h"]
[179.944058, "o", ">             }\r\n\u001b[?2004l\r\u001b[?2004h>             if (has) {\r\n\u001b[?2004l\r\u001b[?2004h>                 c->col_idx[ptr] = bj;\r\n\u001b[?2004l\r\u001b[?2004h>                 for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r\u001b[?2004h>                     for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r\u001b[?2004h>                         int gr = row_blk * bs + r;\r\n\u001b[?2004l\r\u001b[?2004h>                         int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r\u001b[?2004h>                         c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n\u001b[?2004l\r\u001b[?2004h>                     }\r\n\u001b[?2004l\r\u001b[?2004h>                 }\r\n\u001b[?2004l\r\u001b[?2004h>                 ptr++;\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[179.944168, "o", "> "]
[179.944389, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[179.944499, "o", "\u001b[?2004h> "]
[179.94467, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r"]
[179.94478, "o", "\u001b[?2004h> "]
[179.944926, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[179.945006, "o", "\u001b[?2004h> "]
[179.945213, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[179.945299, "o", "\u001b[?2004h"]
[179.945405, "o", "> "]
[179.945562, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[179.945648, "o", "\u001b[?2004h> "]
[179.945887, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[179.945923, "o", "\u001b[?2004h> "]
[179.946129, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[179.946163, "o", "\u001b[?2004h"]
[179.946187, "o", "> "]
[179.946342, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r"]
[179.94637, "o", "\u001b[?2004h> "]
[179.94661, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r\u001b[?2004h"]
[179.946662, "o", "> "]
[179.946684, "o", "                    }\r\n\u001b[?2004l\r"]
[179.946702, "o", "\u001b[?2004h"]
[179.946727, "o", "> "]
[179.947022, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n"]
[179.947072, "o", "\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[179.947113, "o", "\u001b[?2004h"]
[179.947149, "o", "> \r\n\u001b[?2004l\r"]
[179.947171, "o", "\u001b[?2004h"]
[179.947194, "o", "> "]
[179.947538, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[179.947599, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[179.947741, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[179.947858, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r"]
[179.947887, "o", "\u001b[?2004h"]
[179.94798, "o", "> "]
[179.948104, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[179.948148, "o", "\u001b[?2004h"]
[179.948169, "o", "> "]
[179.948284, "o", "        y[i] = 0.0;"]
[179.948383, "o", "\r\n\u001b[?2004l\r"]
[179.948493, "o", "\u001b[?2004h> "]
[179.948614, "o", "    }\r\n"]
[179.948734, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[179.948863, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[179.94894, "o", "\u001b[?2004h> "]
[179.949027, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[179.949164, "o", "\u001b[?2004h> "]
[179.949204, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[179.949226, "o", "\u001b[?2004h"]
[179.94925, "o", "> "]
[179.949387, "o", "        for (int k = start; k < end; k++) {"]
[179.949504, "o", "\r\n\u001b[?2004l\r"]
[179.949534, "o", "\u001b[?2004h> "]
[179.94969, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[179.949834, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[179.94996, "o", "\u001b[?2004h> "]
[179.950082, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[179.950181, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[179.950327, "o", "\u001b[?2004h> "]
[179.950422, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[179.950652, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[179.950681, "o", "\u001b[?2004h> "]
[179.950867, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n"]
[179.951001, "o", "\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[179.95113, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[179.952236, "o", "\u001b[?2004hroot@5d2fadd567bd:/app# "]
[200.286489, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int nblocks = c / d;\n    for (int bi = 0; bi < nblocks; bi++) {\n        for (int r = 0; r < d; r++) {\n            e[bi * d + r] = a[b[bi] * d + r];\n        }\n    }\n}\nEOF\n"]
[200.286817, "o", "cat > /app/perm_p/order.cpp << 'EOF'"]
[200.286955, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.28724, "o", "> "]
[200.287337, "o", "#include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.287457, "o", "> "]
