[133.564059, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int nblocks = c / d;\n    for (int bi = 0; bi < nblocks; bi++) {\n        int src = b[bi];\n        for (int r = 0; r < d; r++) {\n            e[bi * d + r] = a[src * d + r];\n        }\n    }\n}\nEOF\n"]
