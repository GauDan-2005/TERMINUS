[133.232322, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[133.232403, "o", "\u001b[?2004h> "]
[133.232569, "o", "                    for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[133.232676, "o", "\u001b[?2004h> "]
[133.232783, "o", "                        int gr = row_blk * bs + r;\r\n\u001b[?2004l\r"]
[133.232807, "o", "\u001b[?2004h"]
[133.232868, "o", "> "]
[133.232997, "o", "                        int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[133.233022, "o", "\u001b[?2004h"]
[133.233039, "o", "> "]
[133.233279, "o", "                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n\u001b[?2004l\r"]
[133.233304, "o", "\u001b[?2004h"]
[133.233322, "o", "> "]
[133.233419, "o", "                    }\r\n\u001b[?2004l\r"]
[133.233461, "o", "\u001b[?2004h> "]
[133.233586, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.233998, "o", "                ptr++;\r\n\u001b[?2004l\r"]
[133.234583, "o", "\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[133.234763, "o", ">     c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.234908, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.235045, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.235192, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[133.235324, "o", "\u001b[?2004h> "]
[133.235458, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.235593, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.235745, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[133.235853, "o", "\u001b[?2004h> "]
[133.236013, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[133.236121, "o", "\u001b[?2004h> "]
[133.236259, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r"]
[133.236363, "o", "\u001b[?2004h> "]
[133.236494, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r\u001b[?2004h"]
[133.236644, "o", ">                     }\r\n\u001b[?2004l\r"]
[133.236797, "o", "\u001b[?2004h>                 }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.236966, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.237129, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[133.237235, "o", "> "]
[133.237368, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.237495, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r"]
[133.23765, "o", "\u001b[?2004h> "]
[133.237684, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.237787, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r"]
[133.237907, "o", "\u001b[?2004h> "]
[133.238046, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.238193, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[133.238325, "o", "\u001b[?2004h> "]
[133.238446, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.238578, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.238653, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[133.238739, "o", "\u001b[?2004h> "]
[133.2389, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[133.238981, "o", "\u001b[?2004h> "]
[133.239149, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.239318, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[133.239428, "o", "\u001b[?2004h> "]
[133.239561, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.239717, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[133.23983, "o", "\u001b[?2004h> "]
[133.239959, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[133.240065, "o", "\u001b[?2004h> "]
[133.240218, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[133.240341, "o", "\u001b[?2004h> "]
[133.24049, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r"]
[133.240657, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[133.24077, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[133.241666, "o", "\u001b[?2004hroot@f4664844cd46:/app# "]
[133.339943, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        c[i] = a->diag_inv[i] * b[i];\n    }\n}\nEOF\n"]
