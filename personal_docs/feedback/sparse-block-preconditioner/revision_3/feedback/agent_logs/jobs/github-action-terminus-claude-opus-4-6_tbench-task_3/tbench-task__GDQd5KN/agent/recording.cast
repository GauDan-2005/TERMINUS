[133.453829, "i", "cat > /app/scale_q/metric.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <math.h>\n\ndouble norm_q(const double *a, int b) {\n    double s = 0.0;\n    for (int i = 0; i < b; i++) {\n        s += a[i] * a[i];\n    }\n    return sqrt(s);\n}\nEOF\n"]
