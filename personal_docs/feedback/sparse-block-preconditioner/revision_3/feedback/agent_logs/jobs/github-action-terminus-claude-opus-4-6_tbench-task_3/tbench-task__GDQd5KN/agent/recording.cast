[133.456522, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> double norm_q(const double *a, int b) {\r\n\u001b[?2004l\r\u001b[?2004h>     double s = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < b; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         s += a[i] * a[i];\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     return sqrt(s);\r\n\u001b[?2004l\r\u001b[?2004h> "]
