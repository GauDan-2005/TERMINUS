[379.512318, "i", "cp /app/output/solver-audit.json /tmp/a1.json; bash /app/scripts/run-matrix.sh; cp /app/output/solver-audit.json /tmp/a2.json; diff -u /tmp/a1.json /tmp/a2.json || true\n"]
[379.513044, "o", "cp /app/output/solver-audit.json /tmp/a1.json; bash /app/scripts/run-matrix.sh; cp /app/output/solver-audit.json /tmp/a2.json; diff -u /tmp/a1.json /tmp/a2.json || true\r\n\u001b[?2004l\r"]
