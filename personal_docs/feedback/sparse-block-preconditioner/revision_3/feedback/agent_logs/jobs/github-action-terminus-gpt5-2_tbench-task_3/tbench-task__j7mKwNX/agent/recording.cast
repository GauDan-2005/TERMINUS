[379.397932, "o", "{\r\n  \"cases\": [\r\n    {\r\n      \"name\": \"basalt\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"flint\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"shale\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"garnet\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"mica\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"opal\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    }\r\n  ]\r\n}\r\n"]
