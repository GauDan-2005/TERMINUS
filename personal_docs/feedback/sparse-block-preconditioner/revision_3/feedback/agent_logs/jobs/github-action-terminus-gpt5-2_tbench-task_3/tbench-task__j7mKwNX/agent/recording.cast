[399.540411, "i", "python3 - <<'PY'\nimport json, subprocess\ncases = ['basalt','flint','shale','garnet','mica','opal']\nsubprocess.run(['bash','/app/scripts/run-matrix.sh'], check=True)\nwith open('/app/output/solver-audit.json') as f:\n    mat = json.load(f)['cases']\nmat_by = {c['name']: c for c in mat}\nfor name in cases:\n    subprocess.run(['bash','/app/scripts/run-one.sh', name], check=True)\n    with open(f'/app/output/{name}-audit.json') as f:\n        one = json.load(f)['cases'][0]\n    same = (one == mat_by[name])\n    print(name, 'MATCH' if same else 'DIFF')\n    if not same:\n        print('matrix:', mat_by[name])\n        print('one   :', one)\nPY\n"]
[399.540689, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
[399.541029, "o", "\u001b[?2004h"]
[399.542231, "o", "> import json, subprocess\r\n\u001b[?2004l\r\u001b[?2004h> "]
[399.542443, "o", "cases = ['basalt','flint','shale','garnet','mica','opal']\r\n\u001b[?2004l\r\u001b[?2004h> subprocess.run(['bash','/app/scripts/run-matrix.sh'], check=True)\r\n\u001b[?2004l\r\u001b[?2004h> with open('/app/output/solver-audit.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[399.543813, "o", "    mat = json.load(f)['cases']\r\n\u001b[?2004l\r"]
[399.543941, "o", "\u001b[?2004h> "]
[399.543972, "o", "mat_by = {c['name']: c for c in mat}\r\n\u001b[?2004l\r"]
[399.543991, "o", "\u001b[?2004h"]
[399.544011, "o", "> "]
[399.544211, "o", "for name in cases:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[399.544382, "o", "    subprocess.run(['bash','/app/scripts/run-one.sh', name], check=True)\r\n\u001b[?2004l\r"]
[399.54449, "o", "\u001b[?2004h> "]
[399.544634, "o", "    with open(f'/app/output/{name}-audit.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.544746, "o", "> "]
[399.544827, "o", "        one = json.load(f)['cases'][0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.545001, "o", "> "]
[399.545048, "o", "    same = (one == mat_by[name])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[399.545502, "o", "    print(name, 'MATCH' if same else 'DIFF')\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.545618, "o", ">     if not same:\r\n\u001b[?2004l\r\u001b[?2004h>         print('matrix:', mat_by[name])\r\n\u001b[?2004l\r\u001b[?2004h>         print('one   :', one)\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.545699, "o", "> PY\r\n\u001b[?2004l\r"]
[399.581945, "o", "basalt MATCH\r\n"]
[399.587654, "o", "flint MATCH\r\n"]
[399.593362, "o", "shale MATCH\r\n"]
[399.598948, "o", "garnet MATCH\r\n"]
[399.604666, "o", "mica MATCH\r\n"]
[399.610233, "o", "opal MATCH\r\n"]
