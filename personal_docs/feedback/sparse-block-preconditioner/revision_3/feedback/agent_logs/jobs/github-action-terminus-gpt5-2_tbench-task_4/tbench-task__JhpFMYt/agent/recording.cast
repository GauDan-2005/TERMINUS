[495.73365, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n\r\ndouble norm_q(const double *a, int b) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < b; i++) {\r\n        s += a[i] * a[i];\r\n    }\r\n    return sqrt(s);\r\n}\r\n"]
[495.733842, "o", "\u001b[?2004h"]
