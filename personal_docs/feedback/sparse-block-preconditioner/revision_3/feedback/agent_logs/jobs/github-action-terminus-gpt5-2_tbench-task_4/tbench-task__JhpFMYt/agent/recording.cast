[302.652802, "o", "\r\n\u001b[?2004l\r"]
[302.653707, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n\r\ndouble norm_q(const double *a, int b) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < b; i++) {\r\n        s += a[i] * a[i];\r\n    }\r\n    return sqrt(s) + 1.0e-4;\r\n}\r\n"]
[302.65391, "o", "\u001b[?2004hroot@924dc32e4576:/app# "]
[302.775908, "i", "sed -n '1,320p' /app/solve_s/driver.cpp\n"]
[302.776436, "o", "sed -n '1,320p' /app/solve_s/driver.cpp\r\n\u001b[?2004l\r"]
[302.777995, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n#include <string.h>\r\n\r\nstatic double l2_norm(const double *v, int n) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < n; i++) {\r\n        s += v[i] * v[i];\r\n    }\r\n    return sqrt(s);\r\n}\r\n\r\nvoid step_r(const BsrPack *a, const double *b, double *c);\r\n\r\nint pcg_solve(const BsrPack *pack, const double *rhs, double *x, int *iters, double *final_res) {\r\n    const int n = pack->n;\r\n"]
[302.778037, "o", "    const int max_iter = 200;\r\n    const double tol = 1e-9;\r\n    double r[MAX_DIM];\r\n    double z[MAX_DIM];\r\n    double p[MAX_DIM];\r\n    double ap[MAX_DIM];\r\n    double rz_old;\r\n    double alpha;\r\n    double beta;\r\n    double rs;\r\n    int k;\r\n\r\n    for (int i = 0; i < n; i++) {\r\n        x[i] = 0.0;\r\n    }\r\n    bsr_matvec(pack, x, r);\r\n    for (int i = 0; i < n; i++) {\r\n        r[i] = rhs[i] - r[i];\r\n    }\r\n    rs = l2_norm(r, n);\r\n    if (rs < tol) {\r\n        *iters = 0;\r\n        *final_res = rs;\r\n        return 0;\r\n    }\r\n    step_r(pack, r, z);\r\n    memcpy(p, z, (size_t)n * sizeof(double));\r\n"]
[302.778061, "o", "    rz_old = 0.0;\r\n    for (int i = 0; i < n; i++) {\r\n        rz_old += r[i] * z[i];\r\n    }\r\n    for (k = 1; k <= max_iter; k++) {\r\n        bsr_matvec(pack, p, ap);\r\n        alpha = rz_old;\r\n"]
[302.77808, "o", "        double denom = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n            denom += p[i] * ap[i];\r\n        }\r\n        if (fabs(denom) < 1e-30) {\r\n            break;\r\n        }\r\n"]
[302.778102, "o", "        alpha /= denom;\r\n        for (int i = 0; i < n; i++) {\r\n            x[i] += alpha * p[i];\r\n"]
[302.778124, "o", "            r[i] -= alpha * ap[i];\r\n        }\r\n        rs = l2_norm(r, n);\r\n        if (rs < tol) {\r\n            *iters = k;\r\n            *final_res = rs;\r\n            return 0;\r\n        }\r\n        step_r(pack, r, z);\r\n        beta = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n            beta += r[i] * z[i];\r\n        }\r\n"]
[302.778142, "o", "        beta /= rz_old;\r\n        for (int i = 0; i < n; i++) {\r\n            p[i] = z[i] + beta * p[i];\r\n        }\r\n        rz_old = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n"]
[302.778158, "o", "            rz_old += r[i] * z[i];\r\n        }\r\n    }\r\n    *iters = max_iter;\r\n    *final_res = rs;\r\n    return 1;\r\n"]
[302.778179, "o", "}\r\n"]
