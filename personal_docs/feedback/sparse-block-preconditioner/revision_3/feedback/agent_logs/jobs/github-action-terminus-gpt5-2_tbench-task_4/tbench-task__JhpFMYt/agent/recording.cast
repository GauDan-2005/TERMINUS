[303.900925, "o", "/app/config/limits.toml:1:max_iterations = 200\r\n/app/docs/layout.md:5:The matrix audit at `/app/output/solver-audit.json` contains a top-level `cases` array. Each element carries name, ok, iterations, final_residual, reported_residual, residual_agrees, and hit_limit as defined below.\r\n/app/docs/layout.md:9:- `iterations` — PCG iteration count\r\n/app/docs/layout.md:10:- `final_residual` — measured L2 residual after the solve\r\n/app/docs/layout.md:11:- `reported_residual` — value emitted through the metric helper\r\n/app/docs/layout.md:12:- `residual_agrees` — whether the two residual fields match within tolerance\r\n/app/docs/layout.md:13:- `hit_limit` — whether the iteration cap was reached\r\n/app/drive_u/run.cpp:45:    out->iterations = iters;\r\n/app/drive_u/run.cpp:46:    out->final_residual = true_res;\r\n/app/drive_u/run.cpp:47:    out->reported_residual = rep_res;\r\n/app/drive_u/run.cpp:48:    out->hit_limit = hit;\r\n/app/drive_u/run.cpp:49:    out->residual_agrees = fabs(rep_res - true_res) <= 1e-6 * (1.0 + true_res);\r\n/app/drive_u/run.cpp:50:    out->ok = (!hit) && (true_res < 1e-8) && out->residual_agrees;\r\n/app/flow_t/report.cpp:20:    fprintf(fp, \"      \\\"iterations\\\": %d,\\n\", res->iterations);\r\n/app/flow_t/report.cpp:21:    fprintf(fp, \"      \\\"final_residual\\\": %.17g,\\n\", res->final_residual);\r\n/app/flow_t/report.cpp:22:    fprintf(fp, \"      \\\"reported_residual\\\": %.17g,\\n\", res->reported_residual);\r\n/app/flow_t/report.cpp:23:    fprintf(fp, \"      \\\"residual_agrees\\\": %s,\\n\", res->residual_agrees ? \"true\" : \"false\");\r\n/app/flow_t/report.cpp:24:    fprintf(fp, \"      \\\"hit_limit\\\": %s\\n    }\", res->hit_limit ? \"true\" : \"false\");\r\n/app/include/solver_report.h:8:    int iterations;\r\n/app/include/solver_report.h:9:    double final_residual;\r\n/app/include/solver_report.h:10:    double reported_residual;\r\n/app/include/solver_report.h:11:    int residual_agrees;\r\n/app/include/solver_report.h:12:    int hit_limit;\r\n/app/output/solver-audit.json:5:      \"ok\": false,\r\n/app/output/solver-audit.json:6:      \"iterations\": 1,\r\n/app/output/solver-audit.json:7:      \"final_residual\": 0,\r\n/app/output/solver-audit.json:8:      \"reported_residual\": 0.0001,\r\n/app/output/solver-audit.json:9:      \"residual_agrees\": false,\r\n/app/output/solver-audit.json:10:      \"hit_limit\": false\r\n/app/output/solver-audit.json:14:      \"ok\": false,\r\n/app/output/solver-audit.json:15:      \"iterations\": 1,\r\n/app/output/solver-audit.json:16:      \"final_residual\": 0,\r\n/app/output/solver-audit.json:17:      \"reported_residual\": 0.0001,\r\n/app/output/solver-audit.json:18:      \"residual_agrees\": false,\r\n/app/output/solver-audit.json:19:      \"hit_limit\": false\r\n/app/output/solver-audit.json:23:      \"ok\": false,\r\n/app/output/solver-audit.json:24:      \"iterations\": 1,\r\n/app/output/solver-audit.json:25:      \"final_residual\": 0,\r\n/app/output/solver-audit.json:26:      \"reported_residual\": 0.0001,\r\n/app/output/solver-audit.json:27:      \"residual_agrees\": false,\r\n/app/output/solver-audit.json:28:      \"hit_limit\": false\r\n/app/output/solver-audit.json:32:      \"ok\": false,\r\n/app/output/solver-audit.json:33:      \"iterations\": 1,\r\n"]
