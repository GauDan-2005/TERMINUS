[13.919279, "o", "cat /app/config/limits.toml\r\n\u001b[?2004l\r"]
[13.920294, "o", "max_iterations = 200\r\nresidual_tol = 1.0e-9\r\nagreement_tol = 1.0e-6\r\n"]
