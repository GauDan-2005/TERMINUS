[200.047964, "o", "\u001b[?2004h> "]
[200.048069, "o", "        s += a[i] * a[i];\r\n\u001b[?2004l\r"]
[200.048182, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[200.04831, "o", "    return sqrt(s);\r\n\u001b[?2004l\r\u001b[?2004h> "]
