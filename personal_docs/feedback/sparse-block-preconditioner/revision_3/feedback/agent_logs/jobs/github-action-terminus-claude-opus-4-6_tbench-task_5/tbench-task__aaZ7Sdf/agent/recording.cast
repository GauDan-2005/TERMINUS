[13.675611, "o", "\u001b[?2004l\r"]
[13.676378, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nNAME=\"${1:?case name required}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n\"${APP_ROOT}/bin/solverctl\" one \"${NAME}\"\r\n"]
[13.676648, "o", "\u001b[?2004h"]
[13.67678, "o", "root@a4818f8ff802:/app# "]
[13.799122, "i", "cat /app/CMakeLists.txt\n"]
[13.799683, "o", "cat /app/CMakeLists.txt\r\n\u001b[?2004l\r"]
[13.800278, "o", "cmake_minimum_required(VERSION 3.16)\r\nproject(solverctl LANGUAGES CXX)\r\n\r\nset(CMAKE_CXX_STANDARD 17)\r\nset(CMAKE_CXX_STANDARD_REQUIRED ON)\r\n\r\nadd_executable(solverctl\r\n    src/main.cpp\r\n    src/case_io.cpp\r\n    csr_m/assemble.cpp\r\n    bsr_n/layout.cpp\r\n    perm_p/order.cpp\r\n    prec_r/apply.cpp\r\n    scale_q/metric.cpp\r\n    solve_s/driver.cpp\r\n    flow_t/report.cpp\r\n    drive_u/run.cpp\r\n    spill_v/bucket.cpp\r\n    mirror_w/trace.cpp\r\n)\r\n\r\ntarget_include_directories(solverctl PRIVATE include)\r\n\r\nset_target_properties(solverctl PROPERTIES\r\n    RUNTIME_OUTPUT_DIRECTORY \"${CMAKE_BINARY_DIR}/bin\"\r\n)\r\n"]
[13.800605, "o", "\u001b[?2004hroot@a4818f8ff802:/app# "]
