[200.16869, "o", "#include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[200.168801, "o", "void fn_n(const MatrixView *a, int reorder, BsrPack *c) {"]
[200.168849, "o", "\r\n"]
[200.168888, "o", "\u001b[?2004l\r"]
[200.169111, "o", "\u001b[?2004h>     int nb = a->nblocks;\r\n\u001b[?2004l\r"]
[200.169188, "o", "\u001b[?2004h> "]
[200.169341, "o", "    int bs = a->bs;"]
[200.169428, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.169534, "o", ">     int dim = a->n;\r\n"]
[200.1698, "o", "\u001b[?2004l\r\u001b[?2004h>     int ptr = 0;\r\n\u001b[?2004l\r\u001b[?2004h>     memset(c, 0, sizeof(*c));\r\n\u001b[?2004l\r\u001b[?2004h> "]
[200.169883, "o", "    c->n = dim;\r\n\u001b[?2004l\r"]
[200.169948, "o", "\u001b[?2004h"]
[200.170066, "o", "> "]
[200.170255, "o", "    c->bs = bs;\r\n\u001b[?2004l\r\u001b[?2004h>     c->nblocks = nb;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[200.170289, "o", "    c->reorder = reorder;\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.170313, "o", "> "]
[200.170486, "o", "    for (int i = 0; i < nb; i++) {\r\n\u001b[?2004l\r"]
[200.170569, "o", "\u001b[?2004h> "]
[200.170717, "o", "        c->perm[i] = a->perm[i];\r\n\u001b[?2004l\r"]
[200.170794, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[200.171036, "o", "\u001b[?2004h> "]
[200.171248, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[200.171281, "o", "\u001b[?2004h> "]
[200.171515, "o", "        int row_blk = reorder ? a->perm[bi] : bi;"]
[200.171652, "o", "\r\n"]
[200.171966, "o", "\u001b[?2004l\r\u001b[?2004h>         c->row_ptr[bi] = ptr;"]
[200.172063, "o", "\r\n"]
[200.172213, "o", "\u001b[?2004l\r"]
[200.172301, "o", "\u001b[?2004h"]
[200.172443, "o", "> "]
[200.172631, "o", "        for (int bj = 0; bj < nb; bj++) {\r\n"]
[200.172712, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[200.173008, "o", "            int col_blk = reorder ? a->perm[bj] : bj;\r\n\u001b[?2004l\r"]
[200.173046, "o", "\u001b[?2004h"]
[200.173138, "o", "> "]
[200.173257, "o", "            int has = 0;\r\n\u001b[?2004l\r"]
[200.17334, "o", "\u001b[?2004h> "]
[200.173546, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[200.173573, "o", "\u001b[?2004h"]
[200.173599, "o", "> "]
[200.173824, "o", "                for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[200.173852, "o", "\u001b[?2004h> "]
[200.174045, "o", "                    int gr = row_blk * bs + r;\r\n\u001b[?2004l\r"]
[200.174072, "o", "\u001b[?2004h"]
[200.174097, "o", "> "]
[200.174347, "o", "                    int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[200.174415, "o", "\u001b[?2004h> "]
[200.174592, "o", "                    double v = a->a[gr * dim + gc];\r\n\u001b[?2004l\r"]
[200.174625, "o", "\u001b[?2004h> "]
[200.174835, "o", "                    if (fabs(v) > 0.0) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.174866, "o", "> "]
[200.174998, "o", "                        has = 1;\r\n\u001b[?2004l\r"]
[200.17509, "o", "\u001b[?2004h> "]
[200.175238, "o", "                    }\r\n\u001b[?2004l\r"]
[200.175317, "o", "\u001b[?2004h> "]
[200.175411, "o", "                }"]
[200.175505, "o", "\r\n"]
[200.175565, "o", "\u001b[?2004l\r"]
[200.175727, "o", "\u001b[?2004h> "]
[200.175854, "o", "            }\r\n\u001b[?2004l\r"]
[200.175972, "o", "\u001b[?2004h"]
[200.176055, "o", "> "]
[200.176158, "o", "            if (has) {\r\n\u001b[?2004l\r"]
[200.17625, "o", "\u001b[?2004h"]
[200.176315, "o", "> "]
[200.176512, "o", "                c->col_idx[ptr] = bj;\r\n\u001b[?2004l\r"]
[200.176586, "o", "\u001b[?2004h"]
[200.176619, "o", "> "]
[200.176867, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[200.176972, "o", "\u001b[?2004h"]
[200.177004, "o", "> "]
[200.177232, "o", "                    for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[200.177261, "o", "\u001b[?2004h"]
[200.177386, "o", "> "]
[200.177565, "o", "                        int gr = row_blk * bs + r;\r\n\u001b[?2004l\r"]
[200.177593, "o", "\u001b[?2004h> "]
[200.17781, "o", "                        int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[200.177838, "o", "\u001b[?2004h"]
[200.177926, "o", "> "]
[200.17826, "o", "                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n\u001b[?2004l\r"]
[200.178354, "o", "\u001b[?2004h> "]
[200.178383, "o", "                    }\r\n\u001b[?2004l\r"]
[200.178452, "o", "\u001b[?2004h> "]
[200.178579, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[200.178671, "o", "                ptr++;\r\n\u001b[?2004l\r"]
[200.178768, "o", "\u001b[?2004h>             }\r\n"]
[200.178803, "o", "\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[200.178858, "o", "\u001b[?2004h> "]
[200.178952, "o", "    }\r\n\u001b[?2004l\r"]
[200.17899, "o", "\u001b[?2004h> "]
[200.179046, "o", "    c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[200.179181, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[200.17924, "o", "\u001b[?2004h> "]
[200.179307, "o", "        c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r"]
[200.179385, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[200.179472, "o", "\u001b[?2004h> "]
[200.17955, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[200.179622, "o", "\u001b[?2004h> "]
[200.179851, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.179937, "o", ">         int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[200.179967, "o", "\u001b[?2004h> "]
[200.180133, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[200.180158, "o", "\u001b[?2004h"]
[200.180177, "o", "> "]
[200.180328, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[200.180363, "o", "\u001b[?2004h> "]
[200.180519, "o", "                for (int r = 0; r < bs; r++) {\r\n"]
[200.180602, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[200.180787, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[200.180908, "o", "\u001b[?2004h> "]
[200.181003, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.181034, "o", "> "]
[200.181231, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[200.18127, "o", "\u001b[?2004h> "]
[200.181381, "o", "                    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[200.181491, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.181537, "o", "> "]
[200.181586, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.181732, "o", "> "]
[200.181765, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[200.181785, "o", "\u001b[?2004h"]
[200.181809, "o", "> \r\n\u001b[?2004l\r"]
[200.181948, "o", "\u001b[?2004h> "]
[200.182119, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[200.182156, "o", "\u001b[?2004h> "]
[200.182267, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r"]
[200.182337, "o", "\u001b[?2004h> "]
[200.182403, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.182432, "o", "> "]
[200.182518, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r"]
[200.182547, "o", "\u001b[?2004h> "]
[200.182685, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[200.182731, "o", "\u001b[?2004h> "]
[200.18282, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r"]
[200.182863, "o", "\u001b[?2004h> "]
[200.182885, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.182917, "o", "> "]
[200.183089, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.183114, "o", "> "]
[200.183239, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[200.183264, "o", "\u001b[?2004h> "]
[200.183408, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[200.18351, "o", "\u001b[?2004h> "]
[200.183714, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[200.183741, "o", "\u001b[?2004h> "]
[200.183862, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[200.183956, "o", "\u001b[?2004h> "]
[200.184121, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[200.184314, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[200.18434, "o", "\u001b[?2004h"]
[200.18438, "o", "> "]
[200.18453, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[200.184554, "o", "\u001b[?2004h"]
[200.184581, "o", "> "]
[200.184742, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[200.184787, "o", "\u001b[?2004h"]
[200.184819, "o", "> "]
[200.185081, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[200.185127, "o", "\u001b[?2004h"]
[200.185161, "o", "> "]
[200.185216, "o", "                }\r\n\u001b[?2004l\r"]
[200.185247, "o", "\u001b[?2004h"]
[200.185283, "o", "> "]
[200.185331, "o", "            }\r\n\u001b[?2004l\r"]
[200.185374, "o", "\u001b[?2004h> "]
[200.185426, "o", "        }\r\n\u001b[?2004l\r"]
[200.185467, "o", "\u001b[?2004h> "]
[200.185531, "o", "    }"]
[200.185581, "o", "\r\n"]
[200.185979, "o", "\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[200.187006, "o", "\u001b[?2004hroot@a4818f8ff802:/app# "]
[200.302745, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        int blk = i / a->bs;\n        int loc = i % a->bs;\n        c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\n    }\n}\nEOF\n"]
[200.30315, "o", "cat > /app/prec_r/apply.cpp << 'EOF'\r\n\u001b[?2004l\r"]
[200.303348, "o", "\u001b[?2004h> "]
[200.304146, "o", "#include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r"]
[200.304387, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void step_r(const BsrPack *a, const double *b, double *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     int dim = a->n;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int blk = i / a->bs;\r\n\u001b[?2004l\r\u001b[?2004h>         int loc = i % a->bs;\r\n\u001b[?2004l\r\u001b[?2004h"]
[200.30483, "o", ">         c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
