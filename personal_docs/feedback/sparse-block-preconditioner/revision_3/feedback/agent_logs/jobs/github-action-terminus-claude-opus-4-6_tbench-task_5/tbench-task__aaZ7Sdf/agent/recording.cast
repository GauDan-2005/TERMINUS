[200.047638, "o", "double norm_q(const double *a, int b) {\r\n\u001b[?2004l\r"]
[200.047789, "o", "\u001b[?2004h>     double s = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
