Sending keys: ['cat > /app/bsr_n/layout.cpp <<\'EOF\'\n#include "../include/matrix_view.h"\n\n#include <math.h>\n#include <string.h>\n\nvoid fn_n(const MatrixView *a, int reorder, BsrPack *c) {\n    int nb = a->nblocks;\n    int bs = a->bs;\n    int dim = a->n;\n    int ptr = 0;\n    memset(c, 0, sizeof(*c));\n    c->n = dim;\n    c->bs = bs;\n    c->nblocks = nb;\n    c->reorder = reorder;\n    for (int i = 0; i < nb; i++) {\n        c->perm[i] = a->perm[i];\n    }\n\n    // Build BSR in the packed block order.\n    // If reorder is enabled, packed block index bi corresponds to original block perm[bi].\n    for (int bi = 0; bi < nb; bi++) {\n        int row_blk = reorder ? a->perm[bi] : bi;\n        c->row_ptr[bi] = ptr;\n        for (int bj = 0; bj < nb; bj++) {\n            int col_blk = reorder ? a->perm[bj] : bj;\n            int has = 0;\n            for (int r = 0; r < bs; r++) {\n                for (int cc = 0; cc < bs; cc++) {\n                    int gr = row_blk * bs + r;\n                    int gc = col_blk * bs + cc;\n                    double v = a->a[gr * dim + gc];\n                    if (fabs(v) > 0.0) {\n                        has = 1;\n                    }\n                }\n            }\n            if (has) {\n                // Store the column using packed index bj so matvec works in packed space.\n                c->col_idx[ptr] = bj;\n                for (int r = 0; r < bs; r++) {\n                    for (int cc = 0; cc < bs; cc++) {\n                        int gr = row_blk * bs + r;\n                        int gc = col_blk * bs + cc;\n                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\n                    }\n                }\n                ptr++;\n            }\n        }\n    }\n    c->row_ptr[nb] = ptr;\n\n    // Diagonal preconditioner in packed indexing.\n    for (int i = 0; i < dim; i++) {\n        c->diag_inv[i] = 1.0;\n    }\n    for (int bi = 0; bi < nb; bi++) {\n        int start = c->row_ptr[bi];\n        int end = c->row_ptr[bi + 1];\n        for (int k = start; k < end; k++) {\n            if (c->col_idx[k] == bi) {\n                for (int r = 0; r < bs; r++) {\n                    double d = c->data[k * bs * bs + r * bs + r];\n                    if (fabs(d) > 1e-14) {\n                        c->diag_inv[bi * bs + r] = 1.0 / d;\n                    }\n                }\n            }\n        }\n    }\n}\n\nvoid bsr_matvec(const BsrPack *pack, const double *x, double *y) {\n    int nb = pack->nblocks;\n    int bs = pack->bs;\n    int dim = pack->n;\n    for (int i = 0; i < dim; i++) {\n        y[i] = 0.0;\n    }\n    for (int bi = 0; bi < nb; bi++) {\n        int start = pack->row_ptr[bi];\n        int end = pack->row_ptr[bi + 1];\n        for (int k = start; k < end; k++) {\n            int bj = pack->col_idx[k];\n            for (int r = 0; r < bs; r++) {\n                for (int ccc = 0; ccc < bs; ccc++) {\n                    int gi = bi * bs + r;\n                    int gj = bj * bs + ccc;\n                    y[gi] += pack->data[k * bs * bs + r * bs + ccc] * x[gj];\n                }\n            }\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > /app/perm_p/order.cpp <<\'EOF\'\n#include "../include/matrix_view.h"\n\n#include <string.h>\n\n// Map a vector from original ordering to packed ordering.\n// When reorder is enabled, packed block index bi corresponds to original block perm[bi].\nvoid map_p(const double *in, const int *perm, int n, int bs, double *out) {\n    int nb = n / bs;\n    // Default: identity mapping.\n    for (int i = 0; i < n; i++) {\n        out[i] = in[i];\n    }\n\n    // If perm is present and differs, map by blocks.\n    // out[bi] = in[perm[bi]] (block-wise)\n    // This matches fn_n building rows in packed order.\n    if (perm) {\n        for (int bi = 0; bi < nb; bi++) {\n            int src_blk = perm[bi];\n            memcpy(out + bi * bs, in + src_blk * bs, (size_t)bs * sizeof(double));\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
