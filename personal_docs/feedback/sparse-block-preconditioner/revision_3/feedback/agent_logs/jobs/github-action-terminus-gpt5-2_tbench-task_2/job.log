Sending keys: ["python3 - <<'PY'\nimport math, re\nfrom pathlib import Path\n\ndef load_case(path):\n    name=None; nblocks=0; bs=0; reorder=0; perm=[]; blocks=[]; rhs=[]\n    for line in Path(path).read_text().splitlines():\n        line=line.strip()\n        if not line or line.startswith('#'): continue\n        parts=line.split()\n        if parts[0]=='name': name=parts[1]\n        elif parts[0]=='nblocks': nblocks=int(parts[1])\n        elif parts[0]=='bs': bs=int(parts[1])\n        elif parts[0]=='reorder': reorder=int(parts[1])\n        elif parts[0]=='perm': perm=list(map(int, parts[1:]))\n        elif parts[0]=='block':\n            rb=int(parts[1]); cb=int(parts[2]); vals=list(map(float, parts[3:]))\n            blocks.append((rb,cb,vals))\n        elif parts[0]=='rhs': rhs=list(map(float, parts[1:]))\n    n=nblocks*bs\n    A=[[0.0]*n for _ in range(n)]\n    for rb,cb,vals in blocks:\n        for r in range(bs):\n            for c in range(bs):\n                gr=rb*bs+r; gc=cb*bs+c\n                A[gr][gc]=vals[r*bs+c]\n    b=rhs[:n]\n    return name,A,b\n\ndef solve_gauss(A,b):\n    n=len(b)\n    M=[row[:] + [b[i]] for i,row in enumerate(A)]\n    for col in range(n):\n        piv=max(range(col,n), key=lambda r: abs(M[r][col]))\n        M[col],M[piv]=M[piv],M[col]\n        p=M[col][col]\n        if abs(p)<1e-15: raise ValueError('singular')\n        for j in range(col,n+1): M[col][j]/=p\n        for r in range(n):\n            if r==col: continue\n            f=M[r][col]\n            if f==0: continue\n            for j in range(col,n+1):\n                M[r][j]-=f*M[col][j]\n    return [M[i][n] for i in range(n)]\n\ndef residual_norm(A,x,b):\n    n=len(b)\n    r=[]\n    for i in range(n):\n        ax=sum(A[i][j]*x[j] for j in range(n))\n        r.append(b[i]-ax)\n    return math.sqrt(sum(v*v for v in r))\n\nfor case in ['basalt','flint','shale','garnet','mica','opal']:\n    name,A,b=load_case(f'/app/data/cases/{case}.case')\n    x=solve_gauss(A,b)\n    rn=residual_norm(A,x,b)\n    print(case,'direct_residual',rn,'x0',x[0])\nPY\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
