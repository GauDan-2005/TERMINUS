[?2004l[?2004h>             for c in range(bs):
[?2004l[?2004h>                 gr=rb*bs+r; gc=cb*bs+c
[?2004l[?2004h>                 A[gr][gc]=vals[r*bs+c]
[?2004l[?2004h>     b=rhs[:n]
[?2004l[?2004h>     return name,A,b
