[?2004l[?2004h>         if not line or line.startswith('#'): continue
[?2004l[?2004h>         parts=line.split()
[?2004l[?2004h>         if parts[0]=='name': name=parts[1]
[?2004l[?2004h>         elif parts[0]=='nblocks': nblocks=int(parts[1])
[?2004l[?2004h>         elif parts[0]=='bs': bs=int(parts[1])
[?2004l[?2004h>         elif parts[0]=='reorder': reorder=int(parts[1])
[?2004l[?2004h>         elif parts[0]=='perm': perm=list(map(int, parts[1:]))
[?2004l[?2004h>         elif parts[0]=='block':
[?2004l[?2004h>             rb=int(parts[1]); cb=int(parts[2]); vals=list(map(float, parts[3:]))
[?2004l[?2004h>             blocks.append((rb,cb,vals))
