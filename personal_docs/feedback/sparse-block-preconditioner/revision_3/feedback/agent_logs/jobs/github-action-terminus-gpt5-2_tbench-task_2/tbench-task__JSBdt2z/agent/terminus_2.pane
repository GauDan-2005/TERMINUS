[?2004l[?2004h> def solve_gauss(A,b):
[?2004l[?2004h>     n=len(b)
[?2004l[?2004h>     M=[row[:] + [b[i]] for i,row in enumerate(A)]
[?2004l[?2004h>     for col in range(n):
[?2004l[?2004h>         piv=max(range(col,n), key=lambda r: abs(M[r][col]))
[?2004l[?2004h>         M[col],M[piv]=M[piv],M[col]
[?2004l[?2004h>         p=M[col][col]
[?2004l[?2004h>         if abs(p)<1e-15: raise ValueError('singular')
[?2004l[?2004h>         for j in range(col,n+1): M[col][j]/=p
[?2004l[?2004h>         for r in range(n):
