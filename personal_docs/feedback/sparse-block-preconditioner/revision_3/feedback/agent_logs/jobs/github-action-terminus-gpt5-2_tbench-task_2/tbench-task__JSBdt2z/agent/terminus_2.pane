[?2004l[?2004h>             f=M[r][col]
[?2004l[?2004h>             if f==0: continue
[?2004l[?2004h>             for j in range(col,n+1):
[?2004l[?2004h>                 M[r][j]-=f*M[col][j]
[?2004l[?2004h>     return [M[i][n] for i in range(n)]
[?2004l[?2004h> 
[?2004l[?2004h> def residual_norm(A,x,b):
[?2004l[?2004h>     n=len(b)
[?2004l[?2004h>     r=[]
