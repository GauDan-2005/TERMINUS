[251.178847, "i", "cat > /app/perm_p/order.cpp <<'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\n// Map a vector from original ordering to packed ordering.\n// When reorder is enabled, packed block index bi corresponds to original block perm[bi].\nvoid map_p(const double *in, const int *perm, int n, int bs, double *out) {\n    int nb = n / bs;\n    // Default: identity mapping.\n    for (int i = 0; i < n; i++) {\n        out[i] = in[i];\n    }\n\n    // If perm is present and differs, map by blocks.\n    // out[bi] = in[perm[bi]] (block-wise)\n    // This matches fn_n building rows in packed order.\n    if (perm) {\n        for (int bi = 0; bi < nb; bi++) {\n            int src_blk = perm[bi];\n            memcpy(out + bi * bs, in + src_blk * bs, (size_t)bs * sizeof(double));\n        }\n    }\n}\nEOF\n"]
