[250.070643, "i", "for f in /app/data/cases/*.case; do echo \"--- $f\"; sed -n '1,120p' \"$f\"; done\n"]
[250.071151, "o", "for f in /app/data/cases/*.case; do echo \"--- $f\"; sed -n '1,120p' \"$f\"; done"]
[250.071435, "o", "\r\n\u001b[?2004l\r--- /app/data/cases/basalt.case\r\n"]
[250.072929, "o", "# basalt — identity layout, diagonal blocks\r\n"]
[250.073139, "o", "name basalt\r\nnblocks 2\r\nbs 2\r\nreorder 0\r\nperm 0 1\r\nblock 0 0 4 0 0 4\r\nblock 1 1 4 0 0 4\r\nrhs 1 0 1 0\r\n"]
[250.07325, "o", "--- /app/data/cases/flint.case\r\n"]
[250.074901, "o", "# flint — identity layout with off-diagonal coupling\r\nname flint\r\nnblocks 2\r\nbs 2\r\nreorder 0\r\nperm 0 1\r\nblock 0 0 4 0 0 4\r\nblock 1 1 4 0 0 4\r\n"]
[250.074942, "o", "block 0 1 0 0.5 0 0\r\nblock 1 0 0 0.5 0 0\r\nrhs 1 0 1 0\r\n"]
[250.075134, "o", "--- /app/data/cases/garnet.case\r\n"]
[250.076077, "o", "# garnet — three blocks with reorder\r\nname garnet\r\nnblocks 3\r\nbs 2\r\nreorder 1\r\nperm 2 0 1\r\nblock 0 0 5 0 0 5\r\n"]
[250.076109, "o", "block 1 1 5 0 0 5\r\nblock 2 2 5 0 0 5\r\nblock 0 1 0 0.4 0 0\r\nblock 1 0 0 0.4 0 0\r\nblock 1 2 0 0.4 0 0\r\nblock 2 1 0 0.4 0 0\r\nrhs 1 0 1 0 1 0\r\n"]
[250.076247, "o", "--- /app/data/cases/mica.case\r\n"]
[250.077242, "o", "# mica — three blocks with reorder (garnet-class conditioning)\r\nname mica\r\nnblocks 3\r\nbs 2\r\nreorder 1\r\nperm 1 2 0\r\nblock 0 0 5 0 0 5\r\nblock 1 1 5 0 0 5\r\nblock 2 2 5 0 0 5\r\nblock 0 1 0 0.4 0 0\r\nblock 1 0 0 0.4 0 0\r\nblock 1 2 0 0.4 0 0\r\n"]
[250.077343, "o", "block 2 1 0 0.4 0 0\r\nrhs 1 0 1 0 1 0\r\n"]
[250.077454, "o", "--- /app/data/cases/opal.case\r\n"]
[250.078415, "o", "# opal — three blocks with reorder (garnet-class conditioning)\r\nname opal\r\nnblocks 3\r\nbs 2\r\nreorder 1\r\nperm 1 2 0\r\nblock 0 0 5 0 0 5\r\nblock 1 1 5 0 0 5\r\n"]
[250.078563, "o", "block 2 2 5 0 0 5\r\nblock 0 1 0 0.4 0 0\r\nblock 1 0 0 0.4 0 0\r\nblock 1 2 0 0.4 0 0\r\nblock 2 1 0 0.4 0 0\r\nrhs 1 0 1 0 1 0\r\n"]
[250.078815, "o", "--- /app/data/cases/shale.case\r\n"]
[250.079763, "o", "# shale — reordered flint-equivalent system\r\nname shale\r\nnblocks 2\r\nbs 2\r\nreorder 1\r\nperm 1 0\r\nblock 0 0 4 0 0 4\r\nblock 1 1 4 0 0 4\r\nblock 0 1 0 0.5 0 0\r\n"]
[250.07986, "o", "block 1 0 0 0.5 0 0\r\nrhs 1 0 1 0\r\n"]
[250.079978, "o", "\u001b[?2004h"]
[250.080048, "o", "root@3ddcf2b2b165:/app# "]
[251.059619, "i", "cat > /app/bsr_n/layout.cpp <<'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <math.h>\n#include <string.h>\n\nvoid fn_n(const MatrixView *a, int reorder, BsrPack *c) {\n    int nb = a->nblocks;\n    int bs = a->bs;\n    int dim = a->n;\n    int ptr = 0;\n    memset(c, 0, sizeof(*c));\n    c->n = dim;\n    c->bs = bs;\n    c->nblocks = nb;\n    c->reorder = reorder;\n    for (int i = 0; i < nb; i++) {\n        c->perm[i] = a->perm[i];\n    }\n\n    // Build BSR in the packed block order.\n    // If reorder is enabled, packed block index bi corresponds to original block perm[bi].\n    for (int bi = 0; bi < nb; bi++) {\n        int row_blk = reorder ? a->perm[bi] : bi;\n        c->row_ptr[bi] = ptr;\n        for (int bj = 0; bj < nb; bj++) {\n            int col_blk = reorder ? a->perm[bj] : bj;\n            int has = 0;\n            for (int r = 0; r < bs; r++) {\n                for (int cc = 0; cc < bs; cc++) {\n                    int gr = row_blk * bs + r;\n                    int gc = col_blk * bs + cc;\n                    double v = a->a[gr * dim + gc];\n                    if (fabs(v) > 0.0) {\n                        has = 1;\n                    }\n                }\n            }\n            if (has) {\n                // Store the column using packed index bj so matvec works in packed space.\n                c->col_idx[ptr] = bj;\n                for (int r = 0; r < bs; r++) {\n                    for (int cc = 0; cc < bs; cc++) {\n                        int gr = row_blk * bs + r;\n                        int gc = col_blk * bs + cc;\n                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\n                    }\n                }\n                ptr++;\n            }\n        }\n    }\n    c->row_ptr[nb] = ptr;\n\n    // Diagonal preconditioner in packed indexing.\n    for (int i = 0; i < dim; i++) {\n        c->diag_inv[i] = 1.0;\n    }\n    for (int bi = 0; bi < nb; bi++) {\n        int start = c->row_ptr[bi];\n        int end = c->row_ptr[bi + 1];\n        for (int k = start; k < end; k++) {\n            if (c->col_idx[k] == bi) {\n                for (int r = 0; r < bs; r++) {\n                    double d = c->data[k * bs * bs + r * bs + r];\n                    if (fabs(d) > 1e-14) {\n                        c->diag_inv[bi * bs + r] = 1.0 / d;\n                    }\n                }\n            }\n        }\n    }\n}\n\nvoid bsr_matvec(const BsrPack *pack, const double *x, double *y) {\n    int nb = pack->nblocks;\n    int bs = pack->bs;\n    int dim = pack->n;\n    for (int i = 0; i < dim; i++) {\n        y[i] = 0.0;\n    }\n    for (int bi = 0; bi < nb; bi++) {\n        int start = pack->row_ptr[bi];\n        int end = pack->row_ptr[bi + 1];\n        for (int k = start; k < end; k++) {\n            int bj = pack->col_idx[k];\n            for (int r = 0; r < bs; r++) {\n                for (int ccc = 0; ccc < bs; ccc++) {\n                    int gi = bi * bs + r;\n                    int gj = bj * bs + ccc;\n                    y[gi] += pack->data[k * bs * bs + r * bs + ccc] * x[gj];\n                }\n            }\n        }\n    }\n}\nEOF\n"]
