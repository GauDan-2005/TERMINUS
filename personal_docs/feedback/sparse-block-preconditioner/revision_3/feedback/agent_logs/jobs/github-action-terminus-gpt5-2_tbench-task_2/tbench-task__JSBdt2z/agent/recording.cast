[179.587263, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\nm = json.loads(Path('/app/output/solver-audit.json').read_text())\none = json.loads(Path('/app/output/basalt-audit.json').read_text())\nmslice = {'cases':[c for c in m.get('cases',[]) if c.get('name')=='basalt']}\nprint(mslice==one)\nPY\n"]
[179.589029, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> from pathlib import Path\r\n\u001b[?2004l\r\u001b[?2004h> m = json.loads(Path('/app/output/solver-audit.json').read_text())\r\n\u001b[?2004l\r\u001b[?2004h> one = json.loads(Path('/app/output/basalt-audit.json').read_text())\r\n\u001b[?2004l\r\u001b[?2004h> mslice = {'cases':[c for c in m.get('cases',[]) if c.get('name')=='basalt']}\r\n\u001b[?2004l\r\u001b[?2004h> print(mslice==one)\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
