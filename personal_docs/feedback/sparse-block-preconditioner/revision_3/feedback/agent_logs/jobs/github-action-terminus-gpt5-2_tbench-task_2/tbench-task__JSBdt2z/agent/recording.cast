[191.368815, "o", "# Operations\r\n"]
[191.368999, "o", "\r\nThe control binary lives at `/app/bin/solverctl`. Scenario specifications are under `/app/data/cases`.\r\n\r\nCMake build trees may be created under `/app/build`. Outputs land in `/app/output`.\r\n"]
