[157.963702, "i", "cat > /app/scripts/run-matrix.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\nAPP_ROOT=\"${APP_ROOT:-/app}\"\nOUT=\"${APP_ROOT}/output\"\nmkdir -p \"${OUT}\"\n\n# Prefer the CMake build tree binary, fall back to a staged install under /app/bin,\n# then PATH.\nif [[ -x \"${APP_ROOT}/build/bin/solverctl\" ]]; then\n  SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\nelif [[ -x \"${APP_ROOT}/bin/solverctl\" ]]; then\n  SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\nelse\n  SOLVERCTL=\"$(command -v solverctl || true)\"\nfi\n\nif [[ -z \"${SOLVERCTL}\" ]]; then\n  echo \"error: solverctl not found (expected ${APP_ROOT}/build/bin/solverctl)\" >&2\n  exit 127\nfi\n\n\"${SOLVERCTL}\" matrix\n\n# Canonicalize JSON to make repeated runs byte-for-byte comparable.\npython3 - <<'PY'\nimport json\nfrom pathlib import Path\n\np = Path('/app/output/solver-audit.json')\ndata = json.loads(p.read_text())\ncases = data.get('cases', [])\ndata['cases'] = sorted(cases, key=lambda c: c.get('name',''))\np.write_text(json.dumps(data, sort_keys=True, separators=(',',':')) + \"\\n\")\nPY\nEOF\n"]
