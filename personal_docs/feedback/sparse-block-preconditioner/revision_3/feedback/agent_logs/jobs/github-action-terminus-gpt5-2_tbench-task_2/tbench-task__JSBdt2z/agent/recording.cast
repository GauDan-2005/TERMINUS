[204.131552, "o", "grep -RIn \"matrix_from_case\\|map_p\\|fn_n\\|bsr_matvec\\|step_r\" /app | head -n 50\r\n\u001b[?2004l\r"]
[204.135454, "o", "/app/bsr_n/layout.cpp:6:void fn_n(const MatrixView *a, int reorder, BsrPack *c) {\r\n/app/bsr_n/layout.cpp:68:void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n/app/csr_m/assemble.cpp:5:void matrix_from_case(const CaseSpec *spec, MatrixView *view) {\r\n/app/drive_u/run.cpp:8:void fn_n(const MatrixView *a, int reorder, BsrPack *c);\r\n/app/drive_u/run.cpp:9:void map_p(const double *a, const int *b, int c, int d, double *e);\r\n/app/drive_u/run.cpp:11:void matrix_from_case(const CaseSpec *spec, MatrixView *view);\r\n/app/drive_u/run.cpp:34:    matrix_from_case(spec, &view);\r\n/app/drive_u/run.cpp:35:    fn_n(&view, view.reorder, &pack);\r\n/app/drive_u/run.cpp:36:    map_p(view.b, view.perm, view.n, view.bs, rhs);\r\n/app/drive_u/run.cpp:38:    bsr_matvec(&pack, x, r);\r\n/app/include/matrix_view.h:29:void matrix_from_case(const CaseSpec *spec, MatrixView *view);\r\n/app/include/matrix_view.h:30:void bsr_matvec(const BsrPack *pack, const double *x, double *y);\r\n/app/perm_p/order.cpp:5:void map_p(const double *a, const int *b, int c, int d, double *e) {\r\n"]
[204.135707, "o", "/app/prec_r/apply.cpp:3:void step_r(const BsrPack *a, const double *b, double *c) {\r\n/app/solve_s/driver.cpp:14:void step_r(const BsrPack *a, const double *b, double *c);\r\n/app/solve_s/driver.cpp:33:    bsr_matvec(pack, x, r);\r\n/app/solve_s/driver.cpp:43:    step_r(pack, r, z);\r\n/app/solve_s/driver.cpp:50:        bsr_matvec(pack, p, ap);\r\n/app/solve_s/driver.cpp:70:        step_r(pack, r, z);\r\n"]
[204.135858, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[205.130864, "i", "sed -n '1,260p' /app/csr_m/assemble.cpp\n"]
[205.131249, "o", "sed -n '1,260p' /app/csr_m/assemble.cpp"]
[205.132025, "o", "\r\n\u001b[?2004l\r"]
[205.13275, "o", "#include \"../include/matrix_view.h\"\r\n"]
[205.132867, "o", "\r\n"]
[205.132936, "o", "#include <string.h>\r\n"]
[205.132999, "o", "\r\n"]
[205.133062, "o", "void matrix_from_case(const CaseSpec *spec, MatrixView *view) {\r\n"]
[205.133121, "o", "    int dim = spec->nblocks * spec->bs;\r\n"]
[205.133176, "o", "    int i;\r\n"]
[205.133233, "o", "    memset(view, 0, sizeof(*view));\r\n"]
[205.133293, "o", "    view->n = dim;\r\n"]
[205.133357, "o", "    view->bs = spec->bs;\r\n"]
[205.133427, "o", "    view->nblocks = spec->nblocks;\r\n"]
[205.13349, "o", "    view->reorder = spec->reorder;\r\n"]
[205.133583, "o", "    for (i = 0; i < spec->nblocks; i++) {\r\n        view->perm[i] = spec->perm[i];\r\n    }\r\n    for (i = 0; i < dim * dim; i++) {\r\n        view->a[i] = 0.0;\r\n    }\r\n    for (i = 0; i < spec->block_count; i++) {\r\n        const BlockEntry *be = &spec->blocks[i];\r\n        int rb = be->rb;"]
[205.133671, "o", "\r\n        int cb = be->cb;\r\n        int r;\r\n        int c;\r\n        for (r = 0; r < spec->bs; r++) {\r\n            for (c = 0; c < spec->bs; c++) {\r\n                int gr = rb * spec->bs + r;\r\n                int gc = cb * spec->bs + c;\r\n                view->a[gr * dim + gc] = be->vals[r * spec->bs + c];\r\n            }\r\n        }\r\n    }\r\n    for (i = 0; i < dim; i++) {\r\n"]
[205.133763, "o", "        view->b[i] = spec->rhs[i];\r\n    }\r\n}\r\n"]
[205.134037, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[205.242985, "i", "sed -n '1,260p' /app/bsr_n/layout.cpp\n"]
[205.243312, "o", "sed -n '1,260p' /app/bsr_n/layout.cpp\r\n\u001b[?2004l\r"]
[205.244828, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n#include <string.h>\r\n\r\nvoid fn_n(const MatrixView *a, int reorder, BsrPack *c) {\r\n    int nb = a->nblocks;\r\n    int bs = a->bs;\r\n"]
[205.244972, "o", "    int dim = a->n;\r\n    int ptr = 0;\r\n    memset(c, 0, sizeof(*c));\r\n    c->n = dim;\r\n    c->bs = bs;\r\n    c->nblocks = nb;\r\n    c->reorder = reorder;\r\n    for (int i = 0; i < nb; i++) {\r\n        c->perm[i] = a->perm[i];\r\n    }\r\n    for (int bi = 0; bi < nb; bi++) {\r\n        int row_blk = reorder ? a->perm[bi] : bi;\r\n        c->row_ptr[bi] = ptr;\r\n        for (int bj = 0; bj < nb; bj++) {\r\n            int col_blk = reorder ? ((bj + 1) % nb) : bj;\r\n            int has = 0;\r\n            for (int r = 0; r < bs; r++) {\r\n                for (int cc = 0; cc < bs; cc++) {\r\n"]
[205.245007, "o", "                    int gr = row_blk * bs + r;\r\n                    int gc = col_blk * bs + cc;\r\n                    double v = a->a[gr * dim + gc];\r\n                    if (fabs(v) > 0.0) {\r\n                        has = 1;\r\n                    }\r\n                }\r\n            }\r\n            if (has) {\r\n                c->col_idx[ptr] = col_blk;\r\n                for (int r = 0; r < bs; r++) {\r\n                    for (int cc = 0; cc < bs; cc++) {\r\n                        int gr = row_blk * bs + r;\r\n                        int gc = col_blk * bs + cc;\r\n"]
[205.245214, "o", "                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n                    }\r\n                }\r\n                ptr++;\r\n            }\r\n        }\r\n    }\r\n"]
[205.245478, "o", "    c->row_ptr[nb] = ptr;\r\n    for (int i = 0; i < dim; i++) {\r\n        c->diag_inv[i] = 1.0;\r\n    }\r\n    for (int bi = 0; bi < nb; bi++) {\r\n        int start = c->row_ptr[bi];\r\n        int end = c->row_ptr[bi + 1];\r\n        for (int k = start; k < end; k++) {\r\n            if (c->col_idx[k] == bi) {\r\n                for (int r = 0; r < bs; r++) {\r\n                    double d = c->data[k * bs * bs + r * bs + r];\r\n                    if (fabs(d) > 1e-14) {\r\n                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n"]
[205.2458, "o", "                    }\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\nvoid bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n    int nb = pack->nblocks;\r\n    int bs = pack->bs;\r\n    int dim = pack->n;\r\n    for (int i = 0; i < dim; i++) {\r\n        y[i] = 0.0;\r\n    }\r\n    for (int bi = 0; bi < nb; bi++) {\r\n        int start = pack->row_ptr[bi];\r\n        int end = pack->row_ptr[bi + 1];\r\n        for (int k = start; k < end; k++) {\r\n            int bj = pack->col_idx[k];\r\n            for (int r = 0; r < bs; r++) {\r\n                for (int c = 0; c < bs; c++) {\r\n                    int gi = bi * bs + r;\r\n                    int gj = bj * bs + c;\r\n                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[205.358792, "i", "sed -n '1,260p' /app/perm_p/order.cpp\n"]
[205.359291, "o", "sed -n '1,260p' /app/perm_p/order.cpp\r\n\u001b[?2004l\r"]
[205.360987, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\r\n    (void)b;\r\n    (void)c;\r\n    (void)d;\r\n    memcpy(e, a, (size_t)c * sizeof(double));\r\n}\r\n"]
[205.361196, "o", "\u001b[?2004h"]
[205.361334, "o", "root@3ddcf2b2b165:/app# "]
[205.483295, "i", "sed -n '1,260p' /app/prec_r/apply.cpp\n"]
[205.483654, "o", "sed -n '1,260p' /app/prec_r/apply.cpp\r\n\u001b[?2004l\r"]
[205.485383, "o", "#include \"../include/matrix_view.h\"\r\n\r\nvoid step_r(const BsrPack *a, const double *b, double *c) {\r\n    int dim = a->n;\r\n    for (int i = 0; i < dim; i++) {\r\n        int blk = i / a->bs;\r\n        int loc = i % a->bs;\r\n        int src_blk = blk;\r\n        if (a->reorder) {\r\n            src_blk = (blk + 1) % a->nblocks;\r\n        }\r\n        c[i] = a->diag_inv[src_blk * a->bs + loc] * b[i];\r\n    }\r\n}\r\n"]
[205.485461, "o", "\u001b[?2004h"]
[205.485487, "o", "root@3ddcf2b2b165:/app# "]
[205.602871, "i", "grep -RIn \"double norm_q\" -n /app/scale_q/metric.cpp\n"]
[205.603337, "o", "grep -RIn \"double norm_q\" -n /app/scale_q/metric.cpp\r\n\u001b[?2004l\r"]
[205.604793, "o", "5:double norm_q(const double *a, int b) {\r\n"]
[205.605197, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[205.723222, "i", "cat > /app/scale_q/metric.cpp <<'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <math.h>\n\n// Reported residual should match the independently computed L2 residual.\n// (Previously this added a constant bias, making audits fail.)\ndouble norm_q(const double *a, int b) {\n    double s = 0.0;\n    for (int i = 0; i < b; i++) {\n        s += a[i] * a[i];\n    }\n    return sqrt(s);\n}\nEOF\n"]
