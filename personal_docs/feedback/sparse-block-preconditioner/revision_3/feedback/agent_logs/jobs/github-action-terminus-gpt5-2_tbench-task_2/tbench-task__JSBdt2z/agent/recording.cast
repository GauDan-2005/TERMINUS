[310.176596, "o", "{\r\n  \"cases\": [\r\n    {\r\n      \"name\": \"basalt\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"flint\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"shale\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"garnet\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n"]
[310.177072, "o", "      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"mica\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"opal\",\r\n      \"ok\": true,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0,\r\n      \"residual_agrees\": true,\r\n      \"hit_limit\": false\r\n    }\r\n  ]\r\n}\r\n\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[310.291644, "i", "python3 - <<'PY'\nimport math, re\nfrom pathlib import Path\n\ndef load_case(path):\n    name=None; nblocks=0; bs=0; reorder=0; perm=[]; blocks=[]; rhs=[]\n    for line in Path(path).read_text().splitlines():\n        line=line.strip()\n        if not line or line.startswith('#'): continue\n        parts=line.split()\n        if parts[0]=='name': name=parts[1]\n        elif parts[0]=='nblocks': nblocks=int(parts[1])\n        elif parts[0]=='bs': bs=int(parts[1])\n        elif parts[0]=='reorder': reorder=int(parts[1])\n        elif parts[0]=='perm': perm=list(map(int, parts[1:]))\n        elif parts[0]=='block':\n            rb=int(parts[1]); cb=int(parts[2]); vals=list(map(float, parts[3:]))\n            blocks.append((rb,cb,vals))\n        elif parts[0]=='rhs': rhs=list(map(float, parts[1:]))\n    n=nblocks*bs\n    A=[[0.0]*n for _ in range(n)]\n    for rb,cb,vals in blocks:\n        for r in range(bs):\n            for c in range(bs):\n                gr=rb*bs+r; gc=cb*bs+c\n                A[gr][gc]=vals[r*bs+c]\n    b=rhs[:n]\n    return name,A,b\n\ndef solve_gauss(A,b):\n    n=len(b)\n    M=[row[:] + [b[i]] for i,row in enumerate(A)]\n    for col in range(n):\n        piv=max(range(col,n), key=lambda r: abs(M[r][col]))\n        M[col],M[piv]=M[piv],M[col]\n        p=M[col][col]\n        if abs(p)<1e-15: raise ValueError('singular')\n        for j in range(col,n+1): M[col][j]/=p\n        for r in range(n):\n            if r==col: continue\n            f=M[r][col]\n            if f==0: continue\n            for j in range(col,n+1):\n                M[r][j]-=f*M[col][j]\n    return [M[i][n] for i in range(n)]\n\ndef residual_norm(A,x,b):\n    n=len(b)\n    r=[]\n    for i in range(n):\n        ax=sum(A[i][j]*x[j] for j in range(n))\n        r.append(b[i]-ax)\n    return math.sqrt(sum(v*v for v in r))\n\nfor case in ['basalt','flint','shale','garnet','mica','opal']:\n    name,A,b=load_case(f'/app/data/cases/{case}.case')\n    x=solve_gauss(A,b)\n    rn=residual_norm(A,x,b)\n    print(case,'direct_residual',rn,'x0',x[0])\nPY\n"]
[310.292172, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import math, re\r\n"]
[310.292405, "o", "\u001b[?2004l\r\u001b[?2004h> from pathlib import Path\r\n\u001b[?2004l\r"]
[310.294606, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def load_case(path):\r\n\u001b[?2004l\r"]
[310.294874, "o", "\u001b[?2004h>     name=None; nblocks=0; bs=0; reorder=0; perm=[]; blocks=[]; rhs=[]\r\n\u001b[?2004l\r\u001b[?2004h>     for line in Path(path).read_text().splitlines():\r\n\u001b[?2004l\r\u001b[?2004h>         line=line.strip()\r\n\u001b[?2004l\r\u001b[?2004h>         if not line or line.startswith('#'): continue\r\n\u001b[?2004l\r\u001b[?2004h>         parts=line.split()\r\n\u001b[?2004l\r\u001b[?2004h>         if parts[0]=='name': name=parts[1]\r\n\u001b[?2004l\r\u001b[?2004h>         elif parts[0]=='nblocks': nblocks=int(parts[1])\r\n\u001b[?2004l\r\u001b[?2004h>         elif parts[0]=='bs': bs=int(parts[1])\r\n\u001b[?2004l\r\u001b[?2004h>         elif parts[0]=='reorder': reorder=int(parts[1])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[310.295002, "o", "        elif parts[0]=='perm': perm=list(map(int, parts[1:]))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[310.295327, "o", "        elif parts[0]=='block':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[310.295459, "o", "            rb=int(parts[1]); cb=int(parts[2]); vals=list(map(float, parts[3:]))\r\n\u001b[?2004l\r"]
[310.295487, "o", "\u001b[?2004h"]
[310.295508, "o", "> "]
[310.295659, "o", "            blocks.append((rb,cb,vals))\r\n\u001b[?2004l\r"]
[310.295688, "o", "\u001b[?2004h"]
[310.295708, "o", "> "]
[310.296036, "o", "        elif parts[0]=='rhs': rhs=list(map(float, parts[1:]))\r\n"]
[310.296075, "o", "\u001b[?2004l\r"]
[310.296284, "o", "\u001b[?2004h> "]
[310.296409, "o", "    n=nblocks*bs\r\n\u001b[?2004l\r"]
[310.29652, "o", "\u001b[?2004h> "]
[310.296629, "o", "    A=[[0.0]*n for _ in range(n)]\r\n\u001b[?2004l\r"]
[310.296656, "o", "\u001b[?2004h"]
[310.296675, "o", "> "]
[310.296787, "o", "    for rb,cb,vals in blocks:\r\n\u001b[?2004l\r"]
[310.296819, "o", "\u001b[?2004h> "]
[310.296937, "o", "        for r in range(bs):\r\n\u001b[?2004l\r"]
[310.296967, "o", "\u001b[?2004h> "]
[310.297084, "o", "            for c in range(bs):\r\n\u001b[?2004l\r"]
[310.29711, "o", "\u001b[?2004h"]
[310.29713, "o", "> "]
[310.297255, "o", "                gr=rb*bs+r; gc=cb*bs+c\r\n\u001b[?2004l\r"]
[310.297281, "o", "\u001b[?2004h"]
[310.297298, "o", "> "]
[310.297442, "o", "                A[gr][gc]=vals[r*bs+c]\r\n\u001b[?2004l\r"]
[310.297549, "o", "\u001b[?2004h"]
[310.297686, "o", ">     b=rhs[:n]\r\n\u001b[?2004l\r"]
[310.297843, "o", "\u001b[?2004h> "]
[310.297959, "o", "    return name,A,b\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[310.298053, "o", "def solve_gauss(A,b):"]
[310.298174, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[310.298283, "o", "> "]
[310.298373, "o", "    n=len(b)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[310.298547, "o", "    M=[row[:] + [b[i]] for i,row in enumerate(A)]\r\n\u001b[?2004l\r"]
[310.298578, "o", "\u001b[?2004h> "]
[310.298687, "o", "    for col in range(n):\r\n\u001b[?2004l\r"]
[310.298718, "o", "\u001b[?2004h> "]
[310.298923, "o", "        piv=max(range(col,n), key=lambda r: abs(M[r][col]))\r\n\u001b[?2004l\r"]
[310.298955, "o", "\u001b[?2004h> "]
[310.299095, "o", "        M[col],M[piv]=M[piv],M[col]\r\n\u001b[?2004l\r"]
[310.299134, "o", "\u001b[?2004h> "]
[310.299239, "o", "        p=M[col][col]\r\n\u001b[?2004l\r"]
[310.299271, "o", "\u001b[?2004h> "]
[310.299459, "o", "        if abs(p)<1e-15: raise ValueError('singular')\r\n\u001b[?2004l\r"]
[310.29949, "o", "\u001b[?2004h> "]
[310.29966, "o", "        for j in range(col,n+1): M[col][j]/=p\r\n\u001b[?2004l\r"]
[310.299691, "o", "\u001b[?2004h> "]
[310.299804, "o", "        for r in range(n):\r\n\u001b[?2004l\r"]
[310.299889, "o", "\u001b[?2004h> "]
[310.299959, "o", "            if r==col: continue\r\n\u001b[?2004l\r"]
[310.300069, "o", "\u001b[?2004h> "]
[310.300163, "o", "            f=M[r][col]\r\n\u001b[?2004l\r"]
[310.300252, "o", "\u001b[?2004h> "]
[310.300319, "o", "            if f==0: continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[310.30045, "o", "            for j in range(col,n+1):\r\n\u001b[?2004l\r"]
[310.300562, "o", "\u001b[?2004h> "]
[310.30063, "o", "                M[r][j]-=f*M[col][j]\r\n\u001b[?2004l\r"]
[310.300759, "o", "\u001b[?2004h"]
[310.300848, "o", "> "]
[310.300937, "o", "    return [M[i][n] for i in range(n)]\r\n\u001b[?2004l\r"]
[310.301032, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[310.301106, "o", "def residual_norm(A,x,b):\r\n\u001b[?2004l\r"]
[310.30122, "o", "\u001b[?2004h> "]
[310.301366, "o", "    n=len(b)\r\n\u001b[?2004l\r\u001b[?2004h>     r=[]\r\n\u001b[?2004l\r"]
[310.301468, "o", "\u001b[?2004h>     for i in range(n):\r\n\u001b[?2004l\r"]
[310.301542, "o", "\u001b[?2004h> "]
[310.301656, "o", "        ax=sum(A[i][j]*x[j] for j in range(n))\r\n\u001b[?2004l\r"]
[310.301725, "o", "\u001b[?2004h> "]
[310.301895, "o", "        r.append(b[i]-ax)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[310.302016, "o", "    return math.sqrt(sum(v*v for v in r))\r\n\u001b[?2004l\r"]
[310.302107, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[310.302182, "o", "> "]
[310.302386, "o", "for case in ['basalt','flint','shale','garnet','mica','opal']:\r\n\u001b[?2004l\r"]
[310.302441, "o", "\u001b[?2004h"]
[310.302468, "o", "> "]
[310.30266, "o", "    name,A,b=load_case(f'/app/data/cases/{case}.case')\r\n\u001b[?2004l\r"]
[310.302721, "o", "\u001b[?2004h> "]
[310.302835, "o", "    x=solve_gauss(A,b)\r\n\u001b[?2004l\r\u001b[?2004h"]
[310.302917, "o", "> "]
[310.302981, "o", "    rn=residual_norm(A,x,b)\r\n\u001b[?2004l\r\u001b[?2004h"]
[310.303081, "o", "> "]
[310.303184, "o", "    print(case,'direct_residual',rn,'x0',x[0])\r\n\u001b[?2004l\r"]
[310.30326, "o", "\u001b[?2004h> "]
[310.303333, "o", "PY\r\n\u001b[?2004l\r"]
[310.325716, "o", "basalt direct_residual 0.0 x0 0.25\r\n"]
[310.325848, "o", "flint direct_residual 0.0 x0 0.25\r\n"]
[310.325969, "o", "shale direct_residual 0.0 x0 0.25\r\n"]
[310.326135, "o", "garnet direct_residual 0.0 x0 0.2\r\n"]
[310.326301, "o", "mica direct_residual 0.0 x0 0.2\r\n"]
[310.326459, "o", "opal direct_residual 0.0 x0 0.2\r\n"]
[310.330075, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
