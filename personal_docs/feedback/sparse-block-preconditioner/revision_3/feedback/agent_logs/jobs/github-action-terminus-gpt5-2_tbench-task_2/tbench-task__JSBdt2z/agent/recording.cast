[333.881027, "o", "total 8\r\n"]
[333.881067, "o", "drwxr-xr-x  2 root root  56 May 29 00:26 .\r\ndrwxr-xr-x 20 root root 278 May 29 00:26 ..\r\n-rw-r--r--  1 root root 137 May 29 00:26 garnet-audit.json\r\n-rw-r--r--  1 root root 756 May 29 00:26 solver-audit.json\r\n"]
[333.881232, "o", "\u001b[?2004h"]
