[343.814569, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\nm=json.loads(Path('/app/output/solver-audit.json').read_text())\none=json.loads(Path('/app/output/garnet-audit.json').read_text())\nmslice={'cases':[c for c in m['cases'] if c.get('name')=='garnet']}\nprint('match', mslice==one)\nPY\n"]
[343.816005, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> from pathlib import Path\r\n\u001b[?2004l\r\u001b[?2004h> m=json.loads(Path('/app/output/solver-audit.json').read_text())\r\n"]
[343.817131, "o", "\u001b[?2004l\r\u001b[?2004h> one=json.loads(Path('/app/output/garnet-audit.json').read_text())\r\n\u001b[?2004l\r\u001b[?2004h> mslice={'cases':[c for c in m['cases'] if c.get('name')=='garnet']}\r\n\u001b[?2004l\r\u001b[?2004h> print('match', mslice==one)\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
[343.840646, "o", "match True\r\n"]
[343.844415, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[344.817851, "i", "sed -n '1,200p' /app/scripts/run-matrix.sh\nsed -n '1,220p' /app/scripts/run-one.sh\n"]
[344.819059, "o", "sed -n '1,200p' /app/scripts/run-matrix.sh"]
[344.819163, "o", "\r\n"]
[344.819193, "o", "\u001b[?2004l\r"]
[344.820572, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\n\r\n# Prefer the CMake build tree binary, fall back to a staged install under /app/bin,\r\n# then PATH.\r\nif [[ -x \"${APP_ROOT}/build/bin/solverctl\" ]]; then\r\n  SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\r\nelif [[ -x \"${APP_ROOT}/bin/solverctl\" ]]; then\r\n  SOLVERCTL=\"${APP_ROOT}/bin/solverctl\""]
[344.820615, "o", "\r\nelse\r\n  SOLVERCTL=\"$(command -v solverctl || true)\"\r\nfi\r\n\r\nif [[ -z \"${SOLVERCTL}\" ]]; then\r\n  echo \"error: solverctl not found (expected ${APP_ROOT}/build/bin/solverctl)\" >&2\r\n  exit 127\r\nfi\r\n\r\n\"${SOLVERCTL}\" matrix\r\n"]
[344.82066, "o", "\r\n# Canonicalize JSON to make repeated runs byte-for-byte comparable.\r\npython3 - <<'PY'\r\nimport json\r\nfrom pathlib import Path\r\n\r\np = Path('/app/output/solver-audit.json')\r\ndata = json.loads(p.read_text())\r\ncases = data.get('cases', [])\r\ndata['cases'] = sorted(cases, key=lambda c: c.get('name',''))\r\np.write_text(json.dumps(data, sort_keys=True, separators=(',',':')) + \"\\n\")\r\nPY\r\n"]
[344.821049, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[344.821096, "o", "sed -n '1,220p' /app/scripts/run-one.sh"]
[344.821144, "o", "\r\n"]
[344.821189, "o", "\u001b[?2004l\r"]
[344.822658, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nNAME=\"${1:?case name required}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\n\r\nif [[ -x \"${APP_ROOT}/build/bin/solverctl\" ]]; then\r\n  SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\r\nelif [[ -x \"${APP_ROOT}/bin/solverctl\" ]]; then\r\n"]
[344.822712, "o", "  SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\r\nelse\r\n  SOLVERCTL=\"$(command -v solverctl || true)\"\r\nfi\r\n\r\nif [[ -z \"${SOLVERCTL}\" ]]; then\r\n  echo \"error: solverctl not found (expected ${APP_ROOT}/build/bin/solverctl)\" >&2\r\n  exit 127\r\nfi\r\n\r\n\"${SOLVERCTL}\" one \"${NAME}\"\r\n\r\npython3 - <<PY\r\nimport json\r\nfrom pathlib import Path\r\n\r\nname = ${NAME@Q}\r\n# ${NAME@Q} produces a shell-quoted string; strip quotes in python by letting it be a literal.\r\n# Bash will expand it like 'basalt', which is valid python.\r\n"]
[344.82274, "o", "\r\np = Path(f\"/app/output/{name.strip(\"'\\\"\")}-audit.json\")\r\n# Safer: compute again from argv-like literal\r\ncase_name = name.strip(\"'\\\"\")\r\np = Path(f\"/app/output/{case_name}-audit.json\")\r\n\r\ndata = json.loads(p.read_text())\r\ncases = data.get('cases', [])\r\n"]
[344.822978, "o", "data['cases'] = sorted(cases, key=lambda c: c.get('name',''))\r\np.write_text(json.dumps(data, sort_keys=True, separators=(',',':')) + \"\\n\")\r\nPY\r\n"]
[344.823134, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[344.935193, "i", "cmake --build /app/build -j\"$(nproc)\"\n"]
[344.935594, "o", "cmake --build /app/build -j\"$(nproc)\"\r\n\u001b[?2004l\r"]
[344.991359, "o", "[100%] Built target solverctl\r\n"]
[345.001426, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[354.946364, "i", "bash /app/scripts/run-matrix.sh\npython3 -c 'import json; j=json.load(open(\"/app/output/solver-audit.json\")); import sys; sys.exit(0 if all(c[\"ok\"] and c[\"residual_agrees\"] for c in j[\"cases\"]) else 1)'\n"]
[354.947027, "o", "bash /app/scripts/run-matrix.sh"]
[354.948623, "o", "\r\n\u001b[?2004l\r"]
[354.977948, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
[354.978487, "o", "python3 -c 'import json; j=json.load(open(\"/app/output/solver-audit.json\")); import sys; sys.exit(0 if all(c[\"ok\"] and c[\"residual_agrees\"] for c in j[\"cases\"]) else 1)'\r\n\u001b[?2004l\r"]
[354.999854, "o", "\u001b[?2004hroot@3ddcf2b2b165:/app# "]
