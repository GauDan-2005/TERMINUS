[251.077588, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r\u001b[?2004h>     int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h>     int bs = pack->bs;\r\n\u001b[?2004l\r\u001b[?2004h>     int dim = pack->n;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         y[i] = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r\u001b[?2004h>         int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r\u001b[?2004h>         for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r\u001b[?2004h>             int bj = pack->col_idx[k];\r\n\u001b[?2004l\r\u001b[?2004h>             for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[251.077969, "o", "                for (int ccc = 0; ccc < bs; ccc++) {"]
[251.078137, "o", "\r\n\u001b[?2004l\r"]
[251.078208, "o", "\u001b[?2004h"]
[251.078398, "o", "> "]
[251.078602, "o", "                    int gi = bi * bs + r;"]
[251.078779, "o", "\r\n\u001b[?2004l\r"]
[251.078908, "o", "\u001b[?2004h> "]
[251.079064, "o", "                    int gj = bj * bs + ccc;\r\n\u001b[?2004l\r"]
[251.079196, "o", "\u001b[?2004h> "]
[251.079486, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + ccc] * x[gj];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[251.079636, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
