[251.298908, "i", "cat > /app/prec_r/apply.cpp <<'EOF'\n#include \"../include/matrix_view.h\"\n\n// Apply diagonal preconditioner in packed ordering.\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        c[i] = a->diag_inv[i] * b[i];\n    }\n}\nEOF\n"]
