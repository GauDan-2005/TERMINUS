[251.072628, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[251.07267, "o", "> "]
[251.072789, "o", "        int start = c->row_ptr[bi];"]
[251.072884, "o", "\r\n\u001b[?2004l\r"]
[251.073049, "o", "\u001b[?2004h> "]
[251.073218, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[251.073345, "o", "        for (int k = start; k < end; k++) {"]
