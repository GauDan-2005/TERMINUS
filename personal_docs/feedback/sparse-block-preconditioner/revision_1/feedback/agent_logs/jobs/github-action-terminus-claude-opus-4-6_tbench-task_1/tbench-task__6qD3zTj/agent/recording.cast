[93.038509, "o", "\u001b[?2004h> "]
[93.038668, "o", "                    int gr = row_blk * bs + r;\r\n\u001b[?2004l\r"]
[93.03875, "o", "\u001b[?2004h> "]
[93.03887, "o", "                    int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[93.03894, "o", "\u001b[?2004h> "]
[93.039093, "o", "                    double v = a->a[gr * dim + gc];\r\n\u001b[?2004l\r"]
[93.039204, "o", "\u001b[?2004h> "]
[93.03932, "o", "                    if (fabs(v) > 0.0) {\r\n\u001b[?2004l\r"]
[93.039389, "o", "\u001b[?2004h> "]
[93.039468, "o", "                        has = 1;\r\n\u001b[?2004l\r"]
[93.039543, "o", "\u001b[?2004h> "]
[93.039656, "o", "                    }\r\n\u001b[?2004l\r"]
[93.039764, "o", "\u001b[?2004h> "]
[93.039814, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[93.039943, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[93.039975, "o", ">             if (has) {"]
[93.040002, "o", "\r\n\u001b[?2004l\r"]
[93.04003, "o", "\u001b[?2004h"]
[93.040055, "o", "> "]
[93.040194, "o", "                c->col_idx[ptr] = bj;\r\n\u001b[?2004l\r"]
[93.040226, "o", "\u001b[?2004h> "]
[93.040392, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[93.040422, "o", "\u001b[?2004h> "]
[93.040607, "o", "                    for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[93.040679, "o", "\u001b[?2004h"]
[93.040707, "o", "> "]
[93.040833, "o", "                        int gr = row_blk * bs + r;\r\n\u001b[?2004l\r"]
[93.040903, "o", "\u001b[?2004h> "]
[93.041062, "o", "                        int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[93.04115, "o", "\u001b[?2004h> "]
[93.041398, "o", "                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n\u001b[?2004l\r"]
[93.041432, "o", "\u001b[?2004h> "]
[93.041536, "o", "                    }\r\n\u001b[?2004l\r"]
[93.041569, "o", "\u001b[?2004h> "]
[93.041674, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[93.041772, "o", "                ptr++;\r\n\u001b[?2004l\r"]
[93.041835, "o", "\u001b[?2004h> "]
[93.041899, "o", "            }\r\n\u001b[?2004l\r"]
[93.041926, "o", "\u001b[?2004h> "]
[93.042011, "o", "        }\r\n\u001b[?2004l\r"]
[93.042042, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[93.042065, "o", "> "]
[93.042184, "o", "    c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r"]
[93.042256, "o", "\u001b[?2004h> "]
[93.04236, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[93.042427, "o", "\u001b[?2004h> "]
[93.042547, "o", "        c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[93.042656, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[93.042731, "o", "> "]
[93.042794, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[93.042931, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r"]
[93.042999, "o", "\u001b[?2004h> "]
[93.043135, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[93.043238, "o", "\u001b[?2004h> "]
[93.043325, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[93.043406, "o", "\u001b[?2004h> "]
[93.043497, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[93.043588, "o", "\u001b[?2004h> "]
[93.043709, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[93.04378, "o", "\u001b[?2004h> "]
[93.043962, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[93.044033, "o", "\u001b[?2004h> "]
[93.044152, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r"]
[93.044182, "o", "\u001b[?2004h> "]
[93.044385, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[93.044416, "o", "\u001b[?2004h> "]
[93.044528, "o", "                    }\r\n\u001b[?2004l\r"]
[93.044654, "o", "\u001b[?2004h>                 }\r\n"]
[93.044699, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[93.04482, "o", "            }\r\n\u001b[?2004l\r"]
[93.044856, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[93.044961, "o", "    }\r\n\u001b[?2004l\r"]
[93.044993, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[93.045139, "o", "\u001b[?2004h> "]
[93.045298, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[93.045396, "o", "\u001b[?2004h> "]
[93.045447, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r"]
[93.045489, "o", "\u001b[?2004h> "]
[93.045657, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r\u001b[?2004h"]
[93.045754, "o", ">     int dim = pack->n;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[93.045869, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[93.045903, "o", "\u001b[?2004h> "]
[93.045987, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r"]
[93.046017, "o", "\u001b[?2004h> "]
[93.046092, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[93.046219, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[93.04625, "o", "\u001b[?2004h> "]
[93.04638, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[93.046409, "o", "\u001b[?2004h> "]
[93.046538, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[93.04657, "o", "\u001b[?2004h> "]
[93.046713, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[93.046742, "o", "\u001b[?2004h> "]
[93.046876, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[93.046906, "o", "\u001b[?2004h> "]
[93.047047, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[93.047075, "o", "\u001b[?2004h> "]
[93.047227, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[93.047256, "o", "\u001b[?2004h> "]
[93.047399, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[93.047427, "o", "\u001b[?2004h> "]
[93.047584, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[93.047701, "o", "\u001b[?2004h> "]
[93.047843, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[93.047952, "o", "\u001b[?2004h> "]
[93.04802, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h"]
[93.04813, "o", ">             }\r\n\u001b[?2004l\r"]
[93.048218, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[93.04832, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[93.048392, "o", "> EOF\r\n\u001b[?2004l\r"]
[93.049542, "o", "\u001b[?2004hroot@b89b76998eda:/app# "]
[93.536875, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *perm, int n, int bs, double *e) {\n    int nb = n / bs;\n    for (int bi = 0; bi < nb; bi++) {\n        int old_blk = perm[bi];\n        for (int r = 0; r < bs; r++) {\n            e[bi * bs + r] = a[old_blk * bs + r];\n        }\n    }\n}\nEOF\n"]
[93.537344, "o", "cat > /app/perm_p/order.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[93.537545, "o", "#include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
