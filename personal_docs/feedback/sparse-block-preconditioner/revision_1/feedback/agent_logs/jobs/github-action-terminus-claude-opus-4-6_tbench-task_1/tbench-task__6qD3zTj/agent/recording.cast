[93.538675, "o", "\u001b[?2004h> "]
[93.538849, "o", "            e[bi * bs + r] = a[old_blk * bs + r];\r\n\u001b[?2004l\r"]
[93.538889, "o", "\u001b[?2004h> "]
[93.538917, "o", "        }\r\n\u001b[?2004l\r"]
[93.539041, "o", "\u001b[?2004h"]
