[93.537657, "o", "> \r\n\u001b[?2004l\r"]
[93.537859, "o", "\u001b[?2004h> "]
[93.537968, "o", "void map_p(const double *a, const int *perm, int n, int bs, double *e) {\r\n\u001b[?2004l\r"]
[93.538059, "o", "\u001b[?2004h> "]
[93.538103, "o", "    int nb = n / bs;\r\n\u001b[?2004l\r\u001b[?2004h"]
[93.538218, "o", "> "]
