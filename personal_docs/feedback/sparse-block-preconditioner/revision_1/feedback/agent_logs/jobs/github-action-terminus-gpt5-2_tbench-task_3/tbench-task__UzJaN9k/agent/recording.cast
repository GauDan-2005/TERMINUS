[53.043956, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: scripts/run-matrix.sh\n@@\n APP_ROOT=\"${APP_ROOT:-/app}\"\n OUT=\"${APP_ROOT}/output\"\n mkdir -p \"${OUT}\"\n bash \"${APP_ROOT}/scripts/clean-room.sh\"\n-\"${APP_ROOT}/bin/solverctl\" matrix\n+\n+# Prefer the CMake build tree binary; fall back to an installed location.\n+SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\n+if [[ ! -x \"${SOLVERCTL}\" ]]; then\n+  SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\n+fi\n+\n+\"${SOLVERCTL}\" matrix\n*** End Patch\nPATCH\n"]
