[158.128265, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        int blk = i / a->bs;\n        int loc = i % a->bs;\n        c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\n    }\n}\nEOF\n"]
