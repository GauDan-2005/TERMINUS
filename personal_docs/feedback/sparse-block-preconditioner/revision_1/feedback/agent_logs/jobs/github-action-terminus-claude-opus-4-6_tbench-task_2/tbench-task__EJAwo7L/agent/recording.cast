[157.134241, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[157.134329, "o", "\u001b[?2004h> "]
[157.134451, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r"]
[157.134526, "o", "\u001b[?2004h> "]
[157.134648, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[157.134688, "o", "\u001b[?2004h> "]
[157.134824, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[157.134929, "o", "\u001b[?2004h> "]
[157.135016, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[157.135049, "o", "\u001b[?2004h> "]
[157.135209, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[157.135238, "o", "\u001b[?2004h> "]
[157.135455, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[157.135485, "o", "\u001b[?2004h> "]
[157.135638, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r"]
[157.135666, "o", "\u001b[?2004h> "]
[157.135867, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[157.135894, "o", "\u001b[?2004h> "]
[157.135991, "o", "                    }\r\n\u001b[?2004l\r"]
[157.136014, "o", "\u001b[?2004h"]
[157.136031, "o", "> "]
[157.136108, "o", "                }\r\n\u001b[?2004l\r"]
[157.136181, "o", "\u001b[?2004h"]
[157.136255, "o", ">             }\r\n\u001b[?2004l\r"]
[157.136314, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[157.136333, "o", "\u001b[?2004h"]
[157.136354, "o", "> "]
[157.136396, "o", "    }\r\n\u001b[?2004l\r"]
[157.136428, "o", "\u001b[?2004h"]
[157.136496, "o", "> }\r\n\u001b[?2004l\r"]
[157.13658, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[157.136683, "o", "\u001b[?2004h"]
[157.136756, "o", "> "]
[157.136937, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[157.13709, "o", "\u001b[?2004h> "]
[157.137225, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.137307, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.13742, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.137591, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.137624, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r"]
[157.13764, "o", "\u001b[?2004h"]
[157.137661, "o", "> "]
[157.137704, "o", "    }\r\n\u001b[?2004l\r"]
[157.137743, "o", "\u001b[?2004h> "]
[157.137953, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[157.138065, "o", "\u001b[?2004h> "]
[157.138109, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.138248, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[157.138292, "o", "\u001b[?2004h> "]
[157.138426, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[157.138468, "o", "\u001b[?2004h> "]
[157.138594, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[157.138636, "o", "\u001b[?2004h> "]
[157.138772, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[157.138866, "o", "\u001b[?2004h> "]
[157.138983, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[157.139013, "o", "\u001b[?2004h> "]
[157.139166, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[157.139196, "o", "\u001b[?2004h> "]
[157.139345, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[157.139379, "o", "\u001b[?2004h> "]
[157.139615, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[157.139646, "o", "\u001b[?2004h> "]
[157.139749, "o", "                }\r\n\u001b[?2004l\r"]
[157.139779, "o", "\u001b[?2004h> "]
[157.139895, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.139916, "o", "        }\r\n\u001b[?2004l\r"]
[157.139953, "o", "\u001b[?2004h"]
[157.139981, "o", "> "]
[157.139998, "o", "    }\r\n\u001b[?2004l\r"]
[157.140022, "o", "\u001b[?2004h"]
[157.140041, "o", "> "]
[157.140058, "o", "}\r\n\u001b[?2004l\r"]
[157.140129, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[157.14107, "o", "\u001b[?2004hroot@e82a056b0afe:/app# "]
[157.623665, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int nblocks = c / d;\n    for (int i = 0; i < nblocks; i++) {\n        int src = b[i];\n        for (int r = 0; r < d; r++) {\n            e[i * d + r] = a[src * d + r];\n        }\n    }\n}\nEOF\n"]
[157.624076, "o", "cat > /app/perm_p/order.cpp << 'EOF'"]
[157.624436, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> #include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.625592, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[157.625737, "o", "> "]
