[157.627785, "o", "    for (int i = 0; i < nblocks; i++) {\r\n\u001b[?2004l\r"]
[157.627856, "o", "\u001b[?2004h>         int src = b[i];"]
[157.627996, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.6281, "o", "        for (int r = 0; r < d; r++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.628231, "o", "            e[i * d + r] = a[src * d + r];\r\n\u001b[?2004l\r"]
[157.62827, "o", "\u001b[?2004h> "]
[157.628296, "o", "        }\r\n\u001b[?2004l\r"]
[157.628321, "o", "\u001b[?2004h"]
[157.62834, "o", "> "]
[157.628363, "o", "    }\r\n\u001b[?2004l\r"]
[157.628577, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
