[128.057566, "o", "\u001b[?2004h> "]
[128.057739, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[128.057772, "o", "\u001b[?2004h> "]
[128.057887, "o", "                    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[128.058004, "o", ">                 }\r\n\u001b[?2004l\r\u001b[?2004h"]
[128.058099, "o", "> "]
[128.058184, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h"]
[128.058359, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n"]
[128.058467, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[128.058599, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[128.058635, "o", "\u001b[?2004h> "]
[128.05878, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h"]
[128.058811, "o", "> "]
[128.058933, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r"]
[128.059071, "o", "\u001b[?2004h> "]
[128.059186, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[128.059341, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[128.059448, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[128.059544, "o", "> "]
[128.059635, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[128.059726, "o", "\u001b[?2004h> "]
[128.059771, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[128.059802, "o", "\u001b[?2004h> "]
[128.059952, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[128.059986, "o", "\u001b[?2004h> "]
[128.060114, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[128.060143, "o", "\u001b[?2004h> "]
[128.060273, "o", "            int cj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[128.060297, "o", "\u001b[?2004h> "]
[128.060443, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[128.060471, "o", "\u001b[?2004h> "]
[128.060697, "o", "                for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[128.060775, "o", "\u001b[?2004h> "]
[128.061037, "o", "                    y[bi * bs + r] += pack->data[k * bs * bs + r * bs + cc] * x[cj * bs + cc];\r\n\u001b[?2004l\r"]
[128.061116, "o", "\u001b[?2004h> "]
[128.061179, "o", "                }\r\n\u001b[?2004l\r"]
[128.061208, "o", "\u001b[?2004h"]
[128.061226, "o", "> "]
[128.061286, "o", "            }\r\n\u001b[?2004l\r"]
[128.061306, "o", "\u001b[?2004h"]
[128.061327, "o", "> "]
[128.061401, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[128.061428, "o", "> "]
[128.06145, "o", "    }\r\n\u001b[?2004l\r"]
[128.061473, "o", "\u001b[?2004h"]
[128.061495, "o", "> }\r\n\u001b[?2004l\r"]
[128.061517, "o", "\u001b[?2004h"]
[128.06154, "o", "> EOF\r\n\u001b[?2004l\r"]
[128.062648, "o", "\u001b[?2004hroot@f33eabfe7919:/app# "]
[128.548989, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int nblocks = c / d;\n    for (int i = 0; i < nblocks; i++) {\n        int src = b[i];\n        for (int k = 0; k < d; k++) {\n            e[i * d + k] = a[src * d + k];\n        }\n    }\n}\nEOF\n"]
[128.549422, "o", "cat > /app/perm_p/order.cpp << 'EOF'\r\n\u001b[?2004l\r"]
[128.553163, "o", "\u001b[?2004h"]
[128.553491, "o", "> #include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void map_p(const double *a, const int *b, int c, int d, double *e) {\r\n\u001b[?2004l\r\u001b[?2004h>     int nblocks = c / d;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < nblocks; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int src = b[i];\r\n\u001b[?2004l\r\u001b[?2004h>         for (int k = 0; k < d; k++) {\r\n\u001b[?2004l\r\u001b[?2004h>             e[i * d + k] = a[src * d + k];\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@f33eabfe7919:/app# "]
[129.056844, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        c[i] = a->diag_inv[i] * b[i];\n    }\n}\nEOF\n"]
[129.057825, "o", "cat > /app/prec_r/apply.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void step_r(const BsrPack *a, const double *b, double *c) {\r\n"]
[129.057969, "o", "\u001b[?2004l\r\u001b[?2004h"]
[129.058077, "o", "> "]
[129.058118, "o", "    int dim = a->n;"]
