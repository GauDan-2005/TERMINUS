[145.220885, "o", "# garnet — three blocks with reorder\r\nname garnet\r\nnblocks 3\r\nbs 2\r\nreorder 1\r\nperm 2 0 1\r\nblock 0 0 5 0 0 5\r\nblock 1 1 5 0 0 5\r\nblock 2 2 5 0 0 5\r\nblock 0 1 0 0.4 0 0\r\nblock 1 0 0 0.4 0 0\r\nblock 1 2 0 0.4 0 0\r\nblock 2 1 0 0.4 0 0\r\nrhs 1 0 1 0 1 0\r\n"]
