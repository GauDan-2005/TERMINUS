[144.867711, "o", "\r\n\u001b[?2004l\r"]
[144.869187, "o", "==> /app/data/cases/basalt.case <==\r\n# basalt — identity layout, diagonal blocks\r\nname basalt\r\nnblocks 2\r\nbs 2\r\nreorder 0\r\n\r\n==> /app/data/cases/flint.case <==\r\n"]
[144.869359, "o", "# flint — identity layout with off-diagonal coupling\r\nname flint\r\nnblocks 2\r\nbs 2\r\nreorder 0\r\n\r\n==> /app/data/cases/garnet.case <==\r\n# garnet — three blocks with reorder\r\nname garnet\r\nnblocks 3\r\nbs 2\r\nreorder 1\r\n\r\n==> /app/data/cases/mica.case <==\r\n# mica — three blocks with reorder (garnet-class conditioning)\r\nname mica\r\nnblocks 3\r\nbs 2\r\nreorder 1\r\n\r\n==> /app/data/cases/opal.case <==\r\n"]
[144.869464, "o", "# opal — three blocks with reorder (garnet-class conditioning)\r\nname opal\r\nnblocks 3\r\nbs 2\r\nreorder 1\r\n\r\n==> /app/data/cases/shale.case <==\r\n# shale — reordered flint-equivalent system\r\nname shale\r\nnblocks 2\r\nbs 2\r\nreorder 1\r\n\u001b[?2004hroot@cb92047aa9e0:/app# "]
[144.982579, "i", "cat /app/data/cases/basalt.case\n"]
[144.982934, "o", "cat /app/data/cases/basalt.case\r\n\u001b[?2004l\r"]
[144.983749, "o", "# basalt — identity layout, diagonal blocks\r\nname basalt\r\nnblocks 2\r\nbs 2\r\nreorder 0\r\nperm 0 1\r\nblock 0 0 4 0 0 4\r\nblock 1 1 4 0 0 4\r\nrhs 1 0 1 0\r\n"]
