[211.840123, "o", "\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>             if (has) {\r\n\u001b[?2004l\r\u001b[?2004h>                 c->col_idx[ptr] = bj;\r\n\u001b[?2004l\r\u001b[?2004h>                 for (int r = 0; r < bs; r++) {"]
[211.840235, "o", "\r\n"]
[211.844026, "o", "\u001b[?2004l\r\u001b[?2004h>                     for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r\u001b[?2004h>                         int gr = row_blk * bs + r;\r\n\u001b[?2004l\r\u001b[?2004h>                         int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r\u001b[?2004h>                         c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n\u001b[?2004l\r\u001b[?2004h>                     }\r\n\u001b[?2004l\r\u001b[?2004h>                 }\r\n\u001b[?2004l\r\u001b[?2004h>                 ptr++;\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int start = c->row_ptr[bi];\r\n\u001b[?2004l\r\u001b[?2004h>         int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r\u001b[?2004h>         for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r\u001b[?2004h>             if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[211.844164, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[211.844238, "o", "> "]
[211.844392, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[211.84454, "o", "\u001b[?2004h> "]
[211.844676, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[211.844813, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[211.844891, "o", "\u001b[?2004h> "]
[211.844919, "o", "                    }\r\n\u001b[?2004l\r"]
[211.844995, "o", "\u001b[?2004h"]
[211.845035, "o", ">                 }\r\n\u001b[?2004l\r\u001b[?2004h"]
[211.845112, "o", "> "]
[211.845146, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[211.845296, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[211.845367, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[211.845392, "o", "\u001b[?2004h> "]
[211.845616, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[211.845639, "o", "\u001b[?2004h"]
[211.845656, "o", "> "]
[211.845755, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r"]
[211.84578, "o", "\u001b[?2004h> "]
[211.845875, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r"]
[211.8459, "o", "\u001b[?2004h> "]
[211.845992, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r"]
[211.846017, "o", "\u001b[?2004h"]
[211.846033, "o", "> "]
[211.846149, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[211.84617, "o", "\u001b[?2004h"]
[211.846186, "o", "> "]
[211.846318, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r"]
[211.846349, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[211.846482, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[211.846508, "o", "\u001b[?2004h> "]
[211.846646, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[211.846669, "o", "\u001b[?2004h"]
[211.846688, "o", "> "]
[211.84682, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[211.846842, "o", "\u001b[?2004h"]
[211.846858, "o", "> "]
[211.847001, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[211.847026, "o", "\u001b[?2004h"]
[211.847042, "o", "> "]
[211.847166, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[211.847189, "o", "\u001b[?2004h"]
[211.847205, "o", "> "]
[211.847344, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[211.847368, "o", "\u001b[?2004h"]
[211.847384, "o", "> "]
[211.847534, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[211.847558, "o", "\u001b[?2004h"]
[211.847573, "o", "> "]
[211.847707, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[211.847731, "o", "\u001b[?2004h"]
[211.847747, "o", "> "]
[211.847881, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[211.847904, "o", "\u001b[?2004h"]
[211.847928, "o", "> "]
[211.848182, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[211.848292, "o", "\u001b[?2004h> "]
[211.848382, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[211.848502, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[211.848572, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[211.848642, "o", "\u001b[?2004h"]
[211.848704, "o", "> EOF\r\n\u001b[?2004l\r"]
[211.849652, "o", "\u001b[?2004h"]
[211.849734, "o", "root@cb92047aa9e0:/app# "]
[211.96756, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *perm, int n, int bs, double *e) {\n    int nb = n / bs;\n    for (int bi = 0; bi < nb; bi++) {\n        int src_blk = perm[bi];\n        for (int j = 0; j < bs; j++) {\n            e[bi * bs + j] = a[src_blk * bs + j];\n        }\n    }\n}\nEOF\n"]
[211.970251, "o", "cat > /app/perm_p/order.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void map_p(const double *a, const int *perm, int n, int bs, double *e) {\r\n\u001b[?2004l\r\u001b[?2004h>     int nb = n / bs;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int src_blk = perm[bi];\r\n\u001b[?2004l\r\u001b[?2004h>         for (int j = 0; j < bs; j++) {\r\n\u001b[?2004l\r\u001b[?2004h>             e[bi * bs + j] = a[src_blk * bs + j];\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[211.971178, "o", "\u001b[?2004hroot@cb92047aa9e0:/app# "]
[212.083778, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        c[i] = a->diag_inv[i] * b[i];\n    }\n}\nEOF\n"]
[212.084283, "o", "cat > /app/prec_r/apply.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.085353, "o", "#include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void step_r(const BsrPack *a, const double *b, double *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     int dim = a->n;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.085538, "o", "        c[i] = a->diag_inv[i] * b[i];\r\n\u001b[?2004l\r"]
