[21.269002, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\r\n    (void)b;\r\n    (void)c;\r\n    (void)d;\r\n    memcpy(e, a, (size_t)c * sizeof(double));\r\n}\r\n"]
