[107.674236, "o", "        for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[107.674263, "o", "\u001b[?2004h> "]
[107.674432, "o", "            e[bi * bs + r] = a[src * bs + r];\r\n\u001b[?2004l\r"]
[107.674457, "o", "\u001b[?2004h"]
[107.674479, "o", "> "]
[107.674614, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[107.674688, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n"]
[107.674757, "o", "\u001b[?2004l\r"]
[107.675926, "o", "\u001b[?2004hroot@f3f0333370d8:/app# "]
[108.175382, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        c[i] = a->diag_inv[i] * b[i];\n    }\n}\nEOF\n"]
