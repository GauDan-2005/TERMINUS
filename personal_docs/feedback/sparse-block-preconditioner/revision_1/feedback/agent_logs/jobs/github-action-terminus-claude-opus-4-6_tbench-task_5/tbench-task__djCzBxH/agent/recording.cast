[21.391266, "i", "cat /app/prec_r/apply.cpp\n"]
[21.391517, "o", "cat /app/prec_r/apply.cpp\r\n\u001b[?2004l\r"]
[21.393433, "o", "#include \"../include/matrix_view.h\"\r\n\r\nvoid step_r(const BsrPack *a, const double *b, double *c) {\r\n    int dim = a->n;\r\n    for (int i = 0; i < dim; i++) {\r\n        int blk = i / a->bs;\r\n        int loc = i % a->bs;\r\n        int src_blk = blk;\r\n        if (a->reorder) {\r\n            src_blk = (blk + 1) % a->nblocks;\r\n        }\r\n        c[i] = a->diag_inv[src_blk * a->bs + loc] * b[i];\r\n    }\r\n}\r\n"]
[21.393608, "o", "\u001b[?2004h"]
[21.393644, "o", "root@f3f0333370d8:/app# "]
