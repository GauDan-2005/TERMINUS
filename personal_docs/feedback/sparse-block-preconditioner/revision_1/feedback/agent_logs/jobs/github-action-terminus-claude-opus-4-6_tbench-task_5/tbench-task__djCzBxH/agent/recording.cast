[107.673083, "o", "> \r\n\u001b[?2004l\r"]
[107.673107, "o", "\u001b[?2004h"]
[107.673149, "o", "> "]
[107.673476, "o", "void map_p(const double *a, const int *perm, int n, int bs, double *e) {\r\n\u001b[?2004l\r"]
[107.673632, "o", "\u001b[?2004h> "]
[107.673721, "o", "    int nb = n / bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
