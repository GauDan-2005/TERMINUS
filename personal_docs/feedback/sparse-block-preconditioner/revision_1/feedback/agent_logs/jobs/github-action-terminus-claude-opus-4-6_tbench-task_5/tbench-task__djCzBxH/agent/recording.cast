[107.179436, "o", "    int ptr = 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[107.17953, "o", "    memset(c, 0, sizeof(*c));\r\n\u001b[?2004l\r"]
[107.179783, "o", "\u001b[?2004h>     c->n = dim;\r\n\u001b[?2004l\r\u001b[?2004h"]
[107.179811, "o", "> "]
[107.179876, "o", "    c->bs = bs;\r\n\u001b[?2004l\r"]
[107.179901, "o", "\u001b[?2004h> "]
[107.179991, "o", "    c->nblocks = nb;\r\n\u001b[?2004l\r"]
[107.180012, "o", "\u001b[?2004h"]
[107.180032, "o", "> "]
[107.180131, "o", "    c->reorder = reorder;\r\n\u001b[?2004l\r"]
[107.180154, "o", "\u001b[?2004h"]
[107.180173, "o", "> "]
[107.180338, "o", "    for (int i = 0; i < nb; i++) {\r\n\u001b[?2004l\r"]
[107.180394, "o", "\u001b[?2004h> "]
[107.18051, "o", "        c->perm[i] = a->perm[i];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[107.180537, "o", "    }\r\n\u001b[?2004l\r"]
[107.180559, "o", "\u001b[?2004h"]
[107.180664, "o", "> "]
[107.180774, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[107.180905, "o", "\u001b[?2004h> "]
[107.180997, "o", "        int row_blk = reorder ? a->perm[bi] : bi;\r\n\u001b[?2004l\r"]
[107.181027, "o", "\u001b[?2004h> "]
[107.181149, "o", "        c->row_ptr[bi] = ptr;\r\n\u001b[?2004l\r"]
[107.181177, "o", "\u001b[?2004h> "]
[107.181333, "o", "        for (int bj = 0; bj < nb; bj++) {\r\n\u001b[?2004l\r"]
[107.181365, "o", "\u001b[?2004h> "]
[107.181527, "o", "            int col_blk = reorder ? a->perm[bj] : bj;\r\n\u001b[?2004l\r"]
[107.181559, "o", "\u001b[?2004h> "]
[107.181665, "o", "            int has = 0;\r\n\u001b[?2004l\r"]
[107.181694, "o", "\u001b[?2004h> "]
[107.181839, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[107.181866, "o", "\u001b[?2004h> "]
[107.182027, "o", "                for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[107.182053, "o", "\u001b[?2004h"]
[107.18207, "o", "> "]
[107.182231, "o", "                    int gr = row_blk * bs + r;\r\n\u001b[?2004l\r"]
[107.182325, "o", "\u001b[?2004h> "]
[107.182453, "o", "                    int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[107.182528, "o", "\u001b[?2004h> "]
[107.182662, "o", "                    double v = a->a[gr * dim + gc];\r\n\u001b[?2004l\r"]
[107.182741, "o", "\u001b[?2004h> "]
[107.182921, "o", "                    if (fabs(v) > 0.0) {\r\n\u001b[?2004l\r"]
[107.183027, "o", "\u001b[?2004h> "]
[107.183078, "o", "                        has = 1;\r\n\u001b[?2004l\r"]
[107.183113, "o", "\u001b[?2004h> "]
[107.183242, "o", "                    }\r\n\u001b[?2004l\r"]
[107.183338, "o", "\u001b[?2004h>                 }\r\n\u001b[?2004l\r"]
[107.183418, "o", "\u001b[?2004h>             }\r\n\u001b[?2004l\r"]
[107.183454, "o", "\u001b[?2004h> "]
[107.183567, "o", "            if (has) {\r\n\u001b[?2004l\r"]
[107.18366, "o", "\u001b[?2004h> "]
[107.183733, "o", "                c->col_idx[ptr] = bj;\r\n\u001b[?2004l\r"]
[107.183799, "o", "\u001b[?2004h> "]
[107.183945, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[107.183972, "o", "\u001b[?2004h"]
[107.18399, "o", "> "]
[107.184151, "o", "                    for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[107.184175, "o", "\u001b[?2004h"]
[107.184192, "o", "> "]
[107.184365, "o", "                        int gr = row_blk * bs + r;\r\n\u001b[?2004l\r"]
[107.184389, "o", "\u001b[?2004h"]
[107.184406, "o", "> "]
[107.184562, "o", "                        int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[107.184587, "o", "\u001b[?2004h"]
[107.184603, "o", "> "]
[107.184871, "o", "                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n\u001b[?2004l\r"]
[107.184896, "o", "\u001b[?2004h"]
[107.184915, "o", "> "]
[107.184992, "o", "                    }\r\n\u001b[?2004l\r"]
[107.185013, "o", "\u001b[?2004h"]
[107.185034, "o", "> "]
[107.185125, "o", "                }\r\n\u001b[?2004l\r"]
[107.185177, "o", "\u001b[?2004h> "]
[107.185259, "o", "                ptr++;\r\n\u001b[?2004l\r"]
[107.185364, "o", "\u001b[?2004h> "]
[107.185393, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[107.185474, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[107.185548, "o", "    }\r\n\u001b[?2004l\r"]
[107.185574, "o", "\u001b[?2004h> "]
[107.18566, "o", "    c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r"]
[107.18569, "o", "\u001b[?2004h> "]
[107.185849, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[107.18594, "o", "\u001b[?2004h> "]
[107.186009, "o", "        c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r"]
[107.186038, "o", "\u001b[?2004h> "]
[107.186113, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[107.186175, "o", "> "]
[107.186276, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[107.186359, "o", "\u001b[?2004h> "]
[107.18644, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r"]
[107.186531, "o", "\u001b[?2004h> "]
[107.186713, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[107.186833, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[107.186864, "o", "\u001b[?2004h> "]
[107.186991, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[107.187096, "o", "\u001b[?2004h> "]
[107.187225, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[107.187375, "o", "\u001b[?2004h> "]
[107.187493, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[107.187528, "o", "\u001b[?2004h> "]
[107.187688, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r"]
[107.187725, "o", "\u001b[?2004h> "]
[107.187931, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[107.188042, "o", "\u001b[?2004h>                     }\r\n"]
[107.188175, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[107.188257, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r"]
[107.188322, "o", "\u001b[?2004h> "]
[107.188493, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[107.188601, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[107.188762, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[107.188831, "o", "\u001b[?2004h> "]
[107.188908, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r"]
[107.188929, "o", "\u001b[?2004h"]
[107.188947, "o", "> "]
[107.18904, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r"]
[107.189086, "o", "\u001b[?2004h> "]
[107.189171, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r"]
[107.189194, "o", "\u001b[?2004h"]
[107.189215, "o", "> "]
[107.189335, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[107.18936, "o", "\u001b[?2004h"]
[107.189381, "o", "> "]
[107.189459, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r"]
[107.189483, "o", "\u001b[?2004h> "]
[107.18963, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[107.189755, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[107.189895, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[107.18997, "o", "\u001b[?2004h> "]
[107.190079, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[107.190145, "o", "\u001b[?2004h> "]
[107.190301, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[107.190446, "o", "\u001b[?2004h> "]
[107.1905, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r\u001b[?2004h"]
[107.190601, "o", "> "]
[107.190668, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[107.190703, "o", "\u001b[?2004h> "]
[107.190875, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[107.190905, "o", "\u001b[?2004h> "]
[107.191055, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[107.191085, "o", "\u001b[?2004h> "]
[107.191234, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[107.191264, "o", "\u001b[?2004h> "]
[107.191503, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[107.191532, "o", "\u001b[?2004h> "]
[107.191623, "o", "                }\r\n\u001b[?2004l\r"]
[107.191696, "o", "\u001b[?2004h> "]
[107.191724, "o", "            }\r\n\u001b[?2004l\r"]
[107.191749, "o", "\u001b[?2004h"]
[107.19185, "o", "> "]
[107.191882, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n"]
[107.191906, "o", "\u001b[?2004l\r\u001b[?2004h"]
[107.191925, "o", "> "]
[107.19195, "o", "}\r\n\u001b[?2004l\r"]
[107.191976, "o", "\u001b[?2004h"]
[107.192101, "o", "> EOF\r\n"]
[107.19213, "o", "\u001b[?2004l\r"]
[107.193099, "o", "\u001b[?2004hroot@f3f0333370d8:/app# "]
[107.671973, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *perm, int n, int bs, double *e) {\n    int nb = n / bs;\n    for (int bi = 0; bi < nb; bi++) {\n        int src = perm[bi];\n        for (int r = 0; r < bs; r++) {\n            e[bi * bs + r] = a[src * bs + r];\n        }\n    }\n}\nEOF\n"]
[107.672388, "o", "cat > /app/perm_p/order.cpp << 'EOF'"]
[107.672537, "o", "\r\n"]
