[167.652048, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\n\nnames=['basalt','flint','shale','garnet','mica','opal']\n\n# Generate per-case audits and preserve them outside /app/output (since clean-room wipes it)\ncase_objs={}\nfor n in names:\n    import subprocess\n    subprocess.check_call(['bash','/app/scripts/run-one.sh',n])\n    data=json.loads(Path(f'/app/output/{n}-audit.json').read_text())\n    assert len(data['cases'])==1\n    case_objs[n]=data['cases'][0]\n\n# Now run matrix once and compare slices\nimport subprocess\nsubprocess.check_call(['bash','/app/scripts/run-matrix.sh'])\nm=json.loads(Path('/app/output/solver-audit.json').read_text())\nm_by={c['name']:c for c in m['cases']}\n\nok=True\nfor n in names:\n    a=case_objs[n]\n    b=m_by.get(n)\n    if a!=b:\n        ok=False\n        print('MISMATCH', n)\n        for k in sorted(set(a)|set(b)):\n            if a.get(k)!=b.get(k):\n                print(' ',k, a.get(k), '!=', b.get(k))\n\nprint('all_slices_match', ok)\nPY\n"]
