[187.513936, "o", "\u001b[?2004h> "]
[187.514177, "o", "for p in [Path('/tmp/solver-audit.1.json'), Path('/tmp/solver-audit.2.json')]:\r\n\u001b[?2004l\r"]
[187.514281, "o", "\u001b[?2004h> "]
[187.514334, "o", "    b=p.read_bytes()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[187.514583, "o", "    print(p.name, 'sha256', hashlib.sha256(b).hexdigest(), 'bytes', len(b))\r\n\u001b[?2004l\r"]
[187.514617, "o", "\u001b[?2004h> "]
[187.514644, "o", "PY\r\n\u001b[?2004l\r"]
