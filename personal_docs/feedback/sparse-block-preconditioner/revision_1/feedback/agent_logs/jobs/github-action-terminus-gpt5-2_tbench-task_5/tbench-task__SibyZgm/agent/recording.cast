[137.521146, "o", "\u001b[?2004hroot@78b1d39f5e77:/app# "]
[142.52189, "i", "sed -n '1,120p' /app/src/main.cpp\n"]
[142.522522, "o", "sed -n '1,120p' /app/src/main.cpp\r\n\u001b[?2004l\r"]
[142.523699, "o", "#include \"../include/case_spec.h\"\r\n#include \"../include/solver_report.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <sys/stat.h>\r\n\r\nint run_u(const CaseSpec *spec, const char *out_dir, SolveResult *out);\r\n\r\n"]
[142.523846, "o", "static const char *CASES[] = {\"basalt\", \"flint\", \"shale\", \"garnet\", \"mica\", \"opal\", NULL};\r\n\r\nstatic int run_named(const char *name, const char *out_dir, SolveResult *res) {\r\n    char path[512];\r\n    CaseSpec spec;\r\n    snprintf(path, sizeof(path), \"/app/data/cases/%s.case\", name);\r\n    if (case_load(path, &spec) != 0) {\r\n        return -1;\r\n    }\r\n    return run_u(&spec, out_dir, res);\r\n}\r\n\r\nint main(int argc, char **argv) {\r\n"]
[142.523957, "o", "    const char *out_dir = \"/app/output\";\r\n    mkdir(out_dir, 0755);\r\n"]
[142.524104, "o", "    if (argc >= 2 && strcmp(argv[1], \"matrix\") == 0) {\r\n        SolveResult cases[6];\r\n        int n = 0;\r\n        for (int i = 0; CASES[i]; i++) {\r\n            if (run_named(CASES[i], out_dir, &cases[n]) != 0) {\r\n                return 1;\r\n            }\r\n            n++;\r\n        }\r\n        if (emit_matrix(cases, n, \"/app/output/solver-audit.json\") != 0) {\r\n            return 1;\r\n        }\r\n        return 0;\r\n    }\r\n    if (argc >= 3 && strcmp(argv[1], \"one\") == 0) {\r\n        SolveResult res;\r\n        char audit[512];\r\n        if (run_named(argv[2], out_dir, &res) != 0) {\r\n            return 1;\r\n        }\r\n        snprintf(audit, sizeof(audit), \"/app/output/%s-audit.json\", argv[2]);\r\n        return emit_t(&res, audit) != 0;\r\n    }\r\n    fprintf(stderr, \"usage: solverctl matrix | solverctl one <case>\\n\");\r\n    return 1;\r\n}\r\n"]
[142.524303, "o", "\u001b[?2004h"]
[142.524429, "o", "root@78b1d39f5e77:/app# "]
[142.644269, "i", "cat > /app/scripts/run-matrix.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\nAPP_ROOT=\"${APP_ROOT:-/app}\"\nOUT=\"${APP_ROOT}/output\"\n\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\n# clean-room may remove output; recreate after cleanup\nmkdir -p \"${OUT}\"\n\n# Prefer the CMake build tree binary, but allow an installed /app/bin/solverctl or PATH.\nSOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\nif [[ ! -x \"${SOLVERCTL}\" ]]; then\n  SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\nfi\nif [[ ! -x \"${SOLVERCTL}\" ]]; then\n  SOLVERCTL=\"$(command -v solverctl || true)\"\nfi\nif [[ -z \"${SOLVERCTL}\" || ! -x \"${SOLVERCTL}\" ]]; then\n  echo \"solverctl not found (expected ${APP_ROOT}/build/bin/solverctl)\" >&2\n  exit 127\nfi\n\n\"${SOLVERCTL}\" matrix\nEOF\nchmod +x /app/scripts/run-matrix.sh\n"]
[142.644788, "o", "cat > /app/scripts/run-matrix.sh <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.646549, "o", "#!/bin/bash\r\n\u001b[?2004l\r\u001b[?2004h> set -euo pipefail\r\n\u001b[?2004l\r\u001b[?2004h> APP_ROOT=\"${APP_ROOT:-/app}\"\r\n\u001b[?2004l\r\u001b[?2004h> OUT=\"${APP_ROOT}/output\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> bash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n\u001b[?2004l\r\u001b[?2004h> # clean-room may remove output; recreate after cleanup\r\n\u001b[?2004l\r\u001b[?2004h> mkdir -p \"${OUT}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Prefer the CMake build tree binary, but allow an installed /app/bin/solverctl or PATH."]
