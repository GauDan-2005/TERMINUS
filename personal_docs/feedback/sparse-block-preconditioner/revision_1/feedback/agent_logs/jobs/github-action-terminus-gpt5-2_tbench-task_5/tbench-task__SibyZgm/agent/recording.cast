[143.644708, "i", "cat > /app/scripts/run-one.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\nAPP_ROOT=\"${APP_ROOT:-/app}\"\nNAME=\"${1:?case name required}\"\nOUT=\"${APP_ROOT}/output\"\n\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\n# clean-room may remove output; recreate after cleanup\nmkdir -p \"${OUT}\"\n\n# Prefer the CMake build tree binary, but allow an installed /app/bin/solverctl or PATH.\nSOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\nif [[ ! -x \"${SOLVERCTL}\" ]]; then\n  SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\nfi\nif [[ ! -x \"${SOLVERCTL}\" ]]; then\n  SOLVERCTL=\"$(command -v solverctl || true)\"\nfi\nif [[ -z \"${SOLVERCTL}\" || ! -x \"${SOLVERCTL}\" ]]; then\n  echo \"solverctl not found (expected ${APP_ROOT}/build/bin/solverctl)\" >&2\n  exit 127\nfi\n\n\"${SOLVERCTL}\" one \"${NAME}\"\nEOF\nchmod +x /app/scripts/run-one.sh\n"]
[143.645237, "o", "cat > /app/scripts/run-one.sh <<'EOF'\r\n\u001b[?2004l\r"]
