[52.00095, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\nm=Path('/app/output/solver-audit.json')\none=Path('/app/output/basalt-audit.json')\nif m.exists():\n  M=json.loads(m.read_text())\n  cases={c['name']:c for c in M.get('cases',[])}\n  print('matrix cases:', sorted(cases)[:20], '... total', len(cases))\n  if one.exists():\n    O=json.loads(one.read_text())\n    # allow either {case:...} or {cases:[...]}\n    if 'cases' in O:\n      ocase = {c['name']:c for c in O['cases']}.get('basalt')\n    else:\n      ocase = O\n    print('slice equals per-case:', ocase==cases.get('basalt'))\n    if ocase!=cases.get('basalt'):\n      print('matrix basalt:', cases.get('basalt'))\n      print('one basalt  :', ocase)\nelse:\n  print('missing /app/output/solver-audit.json')\nPY\n"]
