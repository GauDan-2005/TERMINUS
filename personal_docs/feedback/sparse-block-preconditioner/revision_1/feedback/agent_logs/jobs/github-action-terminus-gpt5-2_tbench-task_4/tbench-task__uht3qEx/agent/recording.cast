[16.170985, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n\"${APP_ROOT}/bin/solverctl\" matrix\r\n\u001b[?2004hroot@4cc4b56ff70c:/app# "]
