[128.338301, "i", "cat > /app/scripts/run-matrix.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\n\nAPP_ROOT=\"${APP_ROOT:-/app}\"\nOUT=\"${APP_ROOT}/output\"\nmkdir -p \"${OUT}\"\n\n# Prefer the CMake build tree binary. Allow an override via SOLVERCTL.\nSOLVERCTL=\"${SOLVERCTL:-}\"\nif [[ -z \"${SOLVERCTL}\" ]]; then\n  if [[ -x \"${APP_ROOT}/build/bin/solverctl\" ]]; then\n    SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\n  else\n    SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\n  fi\nfi\n\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\n\"${SOLVERCTL}\" matrix\nEOF\n"]
