[128.461675, "o", "\u001b[?2004l\r\u001b[?2004h> OUT=\"${APP_ROOT}/output\"\r\n\u001b[?2004l\r\u001b[?2004h> mkdir -p \"${OUT}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Prefer the CMake build tree binary. Allow an override via SOLVERCTL.\r\n\u001b[?2004l\r\u001b[?2004h> SOLVERCTL=\"${SOLVERCTL:-}\"\r\n\u001b[?2004l\r\u001b[?2004h> if [[ -z \"${SOLVERCTL}\" ]]; then\r\n\u001b[?2004l\r\u001b[?2004h>   if [[ -x \"${APP_ROOT}/build/bin/solverctl\" ]]; then\r\n\u001b[?2004l\r\u001b[?2004h>     SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\r\n\u001b[?2004l\r\u001b[?2004h>   else\r\n\u001b[?2004l\r\u001b[?2004h>     SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\r\n\u001b[?2004l\r\u001b[?2004h>   fi\r\n\u001b[?2004l\r\u001b[?2004h> fi\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> bash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n\u001b[?2004l\r\u001b[?2004h> \"${SOLVERCTL}\" one \"${NAME}\"\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
