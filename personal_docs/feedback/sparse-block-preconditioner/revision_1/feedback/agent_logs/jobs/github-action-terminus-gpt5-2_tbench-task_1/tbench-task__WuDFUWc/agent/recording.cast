[126.176048, "o", "#!/bin/bash\r\n"]
[126.1763, "o", "set -euo pipefail\r\n\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nNAME=\"${1:?case name required}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\n\r\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n\r\n# Prefer the CMake build-tree binary, but allow alternate locations.\r\nSOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\r\nif [[ ! -x \"${SOLVERCTL}\" ]]; then\r\n  SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\r\nfi\r\nif [[ ! -x \"${SOLVERCTL}\" ]]; then\r\n  SOLVERCTL=\"solverctl\"\r\nfi\r\n\r\n\"${SOLVERCTL}\" one \"${NAME}\"\r\n"]
