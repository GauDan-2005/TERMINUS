[41.307703, "o", "#include \"../include/case_spec.h\"\r\n#include \"../include/solver_report.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <sys/stat.h>\r\n\r\n"]
[41.307867, "o", "int run_u(const CaseSpec *spec, const char *out_dir, SolveResult *out);\r\n\r\nstatic const char *CASES[] = {\"basalt\", \"flint\", \"shale\", \"garnet\", \"mica\", \"opal\", NULL};\r\n\r\nstatic int run_named(const char *name, const char *out_dir, SolveResult *res) {\r\n    char path[512];\r\n    CaseSpec spec;\r\n    snprintf(path, sizeof(path), \"/app/data/cases/%s.case\", name);\r\n    if (case_load(path, &spec) != 0) {\r\n        return -1;\r\n    }\r\n    return run_u(&spec, out_dir, res);\r\n}\r\n\r\nint main(int argc, char **argv) {\r\n    const char *out_dir = \"/app/output\";\r\n    mkdir(out_dir, 0755);\r\n    if (argc >= 2 && strcmp(argv[1], \"matrix\") == 0) {\r\n        SolveResult cases[6];\r\n        int n = 0;\r\n        for (int i = 0; CASES[i]; i++) {\r\n            if (run_named(CASES[i], out_dir, &cases[n]) != 0) {\r\n                return 1;\r\n            }\r\n            n++;\r\n        }\r\n        if (emit_matrix(cases, n, \"/app/output/solver-audit.json\") != 0) {\r\n            return 1;\r\n        }\r\n        return 0;\r\n    }\r\n    if (argc >= 3 && strcmp(argv[1], \"one\") == 0) {\r\n        SolveResult res;\r\n        char audit[512];\r\n        if (run_named(argv[2], out_dir, &res) != 0) {\r\n            return 1;\r\n        }\r\n        snprintf(audit, sizeof(audit), \"/app/output/%s-audit.json\", argv[2]);\r\n        return emit_t(&res, audit) != 0;\r\n    }\r\n    fprintf(stderr, \"usage: solverctl matrix | solverctl one <case>\\n\");\r\n    return 1;\r\n}\r\n\u001b[?2004hroot@f0090f19629f:/app# "]
[41.415218, "i", "grep -RIn --line-number 'iterations\\|residual\\|metric\\|report' /app/src /app/include /app/flow_t /app/scale_q /app/solve_s /app/drive_u | head -n 120\n"]
[41.415943, "o", "grep -RIn --line-number 'iterations\\|residual\\|metric\\|report' /app/src /app/include /app/flow_t /app/scale_q /app/solve_s /app/drive_u | head -n 120\r\n\u001b[?2004l\r"]
[41.417636, "o", "/app/src/main.cpp:2:#include \"../include/solver_report.h\"\r\n/app/include/solver_report.h:8:    int iterations;\r\n/app/include/solver_report.h:9:    double final_residual;\r\n/app/include/solver_report.h:10:    double reported_residual;\r\n/app/include/solver_report.h:11:    int residual_agrees;\r\n/app/flow_t/report.cpp:1:#include \"../include/solver_report.h\"\r\n/app/flow_t/report.cpp:20:    fprintf(fp, \"      \\\"iterations\\\": %d,\\n\", res->iterations);\r\n/app/flow_t/report.cpp:21:    fprintf(fp, \"      \\\"final_residual\\\": %.17g,\\n\", res->final_residual);\r\n/app/flow_t/report.cpp:22:    fprintf(fp, \"      \\\"reported_residual\\\": %.17g,\\n\", res->reported_residual);\r\n/app/flow_t/report.cpp:23:    fprintf(fp, \"      \\\"residual_agrees\\\": %s,\\n\", res->residual_agrees ? \"true\" : \"false\");\r\n/app/drive_u/run.cpp:3:#include \"../include/solver_report.h\"\r\n/app/drive_u/run.cpp:45:    out->iterations = iters;\r\n/app/drive_u/run.cpp:46:    out->final_residual = true_res;\r\n/app/drive_u/run.cpp:47:    out->reported_residual = rep_res;\r\n/app/drive_u/run.cpp:49:    out->residual_agrees = fabs(rep_res - true_res) <= 1e-6 * (1.0 + true_res);\r\n/app/drive_u/run.cpp:50:    out->ok = (!hit) && (true_res < 1e-8) && out->residual_agrees;\r\n"]
[41.417973, "o", "\u001b[?2004hroot@f0090f19629f:/app# "]
