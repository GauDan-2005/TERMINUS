[10.129577, "o", "\u001b[?2004l\r"]
[10.130506, "o", "#!/bin/bash\r\n"]
[10.130635, "o", "set -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n\"${APP_ROOT}/bin/solverctl\" matrix\r\n"]
