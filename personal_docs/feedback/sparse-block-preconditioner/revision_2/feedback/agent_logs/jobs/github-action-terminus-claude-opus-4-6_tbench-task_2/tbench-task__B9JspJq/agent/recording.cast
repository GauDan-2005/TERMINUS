[157.776019, "o", "\u001b[?2004h> "]
[157.777699, "o", "        c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.778437, "o", "root@4e1bf0d6759c:/app# "]
[157.885954, "i", "cat > /app/scale_q/metric.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <math.h>\n\ndouble norm_q(const double *a, int b) {\n    double s = 0.0;\n    for (int i = 0; i < b; i++) {\n        s += a[i] * a[i];\n    }\n    return sqrt(s);\n}\nEOF\n"]
[157.886702, "o", "cat > /app/scale_q/metric.cpp << 'EOF'"]
