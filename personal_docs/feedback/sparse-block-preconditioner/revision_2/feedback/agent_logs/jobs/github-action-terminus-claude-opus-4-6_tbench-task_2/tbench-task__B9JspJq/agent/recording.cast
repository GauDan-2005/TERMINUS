[157.553892, "o", "            }\r\n\u001b[?2004l\r"]
[157.55392, "o", "\u001b[?2004h"]
[157.553991, "o", "> "]
[157.554121, "o", "            if (has) {\r\n\u001b[?2004l\r"]
[157.554252, "o", "\u001b[?2004h> "]
[157.554442, "o", "                c->col_idx[ptr] = bj;\r\n\u001b[?2004l\r"]
[157.554474, "o", "\u001b[?2004h"]
[157.554609, "o", "> "]
[157.554723, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[157.554751, "o", "\u001b[?2004h"]
[157.554827, "o", "> "]
[157.555079, "o", "                    for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[157.555171, "o", "\u001b[?2004h> "]
[157.555362, "o", "                        int gr = row_blk * bs + r;\r\n\u001b[?2004l\r"]
[157.555389, "o", "\u001b[?2004h"]
[157.555502, "o", "> "]
[157.555653, "o", "                        int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[157.555679, "o", "\u001b[?2004h"]
[157.555791, "o", "> "]
[157.556086, "o", "                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n\u001b[?2004l\r"]
[157.556116, "o", "\u001b[?2004h"]
[157.556206, "o", "> "]
[157.556339, "o", "                    }\r\n\u001b[?2004l\r"]
[157.556366, "o", "\u001b[?2004h"]
[157.556482, "o", ">                 }\r\n"]
[157.55651, "o", "\u001b[?2004l\r\u001b[?2004h"]
[157.55661, "o", "> "]
[157.556713, "o", "                ptr++;\r\n\u001b[?2004l\r"]
[157.556741, "o", "\u001b[?2004h"]
[157.556837, "o", "> "]
[157.556927, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.557024, "o", "> "]
[157.55709, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[157.557113, "o", "\u001b[?2004h"]
[157.557201, "o", "> "]
[157.557326, "o", "    c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r"]
[157.557355, "o", "\u001b[?2004h"]
[157.557431, "o", "> "]
[157.557609, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[157.557701, "o", "\u001b[?2004h> "]
[157.557811, "o", "        c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r"]
[157.557906, "o", "\u001b[?2004h"]
[157.558037, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.558118, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.558156, "o", "> "]
[157.558326, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r"]
[157.558438, "o", "\u001b[?2004h> "]
[157.558524, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.558634, "o", "> "]
[157.558714, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.558825, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[157.558858, "o", "\u001b[?2004h> "]
[157.559011, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[157.559039, "o", "\u001b[?2004h> "]
[157.559256, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[157.559281, "o", "\u001b[?2004h"]
[157.559298, "o", "> "]
[157.559435, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r"]
[157.559459, "o", "\u001b[?2004h"]
[157.559475, "o", "> "]
[157.559661, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[157.559742, "o", "\u001b[?2004h> "]
[157.559854, "o", "                    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.56001, "o", ">                 }\r\n\u001b[?2004l\r"]
[157.560118, "o", "\u001b[?2004h> "]
[157.560227, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n"]
[157.560326, "o", "\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.560428, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[157.560514, "o", "> "]
[157.560656, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[157.560708, "o", "\u001b[?2004h> "]
[157.560829, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.560919, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r"]
[157.560978, "o", "\u001b[?2004h> "]
[157.561047, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r"]
[157.561107, "o", "\u001b[?2004h> "]
[157.561234, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[157.561305, "o", "\u001b[?2004h> "]
[157.561378, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.561513, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.561617, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[157.561653, "o", "\u001b[?2004h> "]
[157.5618, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[157.561903, "o", "\u001b[?2004h> "]
[157.561972, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[157.561999, "o", "\u001b[?2004h> "]
[157.562154, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[157.562177, "o", "\u001b[?2004h"]
[157.562244, "o", "> "]
[157.562334, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[157.562361, "o", "\u001b[?2004h"]
[157.562383, "o", "> "]
[157.562526, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[157.56256, "o", "\u001b[?2004h> "]
[157.562712, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[157.562746, "o", "\u001b[?2004h> "]
[157.562893, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.562984, "o", "> "]
[157.563044, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[157.56318, "o", "\u001b[?2004h> "]
[157.563439, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[157.563468, "o", "\u001b[?2004h> "]
[157.563551, "o", "                }\r\n\u001b[?2004l\r"]
[157.563573, "o", "\u001b[?2004h> "]
[157.563641, "o", "            }\r\n\u001b[?2004l\r"]
[157.563711, "o", "\u001b[?2004h> "]
[157.563735, "o", "        }\r\n\u001b[?2004l\r"]
[157.563849, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.564027, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.564136, "o", "> EOF\r\n\u001b[?2004l\r"]
[157.564907, "o", "\u001b[?2004hroot@4e1bf0d6759c:/app# "]
[157.662337, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int nblocks = c / d;\n    for (int bi = 0; bi < nblocks; bi++) {\n        for (int r = 0; r < d; r++) {\n            e[bi * d + r] = a[b[bi] * d + r];\n        }\n    }\n}\nEOF\n"]
[157.662688, "o", "cat > /app/perm_p/order.cpp << 'EOF'"]
[157.662832, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.662867, "o", "> "]
[157.664766, "o", "#include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void map_p(const double *a, const int *b, int c, int d, double *e) {\r\n\u001b[?2004l\r\u001b[?2004h>     int nblocks = c / d;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int bi = 0; bi < nblocks; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h>         for (int r = 0; r < d; r++) {\r\n\u001b[?2004l\r\u001b[?2004h>             e[bi * d + r] = a[b[bi] * d + r];\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[157.66666, "o", "\u001b[?2004hroot@4e1bf0d6759c:/app# "]
[157.774242, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        int blk = i / a->bs;\n        int loc = i % a->bs;\n        c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\n    }\n}\nEOF\n"]
[157.774604, "o", "cat > /app/prec_r/apply.cpp << 'EOF'"]
[157.774823, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.77495, "o", "#include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r"]
[157.775094, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[157.775174, "o", "> "]
[157.775294, "o", "void step_r(const BsrPack *a, const double *b, double *c) {\r\n\u001b[?2004l\r"]
[157.77532, "o", "\u001b[?2004h"]
[157.775522, "o", "> "]
[157.775604, "o", "    int dim = a->n;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.775688, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[157.775768, "o", "\u001b[?2004h> "]
[157.775843, "o", "        int blk = i / a->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
