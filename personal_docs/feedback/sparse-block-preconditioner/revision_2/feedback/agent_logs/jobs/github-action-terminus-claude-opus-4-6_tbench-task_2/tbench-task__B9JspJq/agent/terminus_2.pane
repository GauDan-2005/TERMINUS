void map_p(const double *a, const int *b, int c, int d, double *e) {
    (void)b;
    (void)c;
    (void)d;
    memcpy(e, a, (size_t)c * sizeof(double));
}
[?2004hroot@4e1bf0d6759c:/app# cat /app/prec_r/apply.cpp
[?2004l#include "../include/matrix_view.h"

void step_r(const BsrPack *a, const double *b, double *c) {
    int dim = a->n;
    for (int i = 0; i < dim; i++) {
        int blk = i / a->bs;
        int loc = i % a->bs;
        int src_blk = blk;
        if (a->reorder) {
            src_blk = (blk + 1) % a->nblocks;
        }
        c[i] = a->diag_inv[src_blk * a->bs + loc] * b[i];
    }
}
[?2004hroot@4e1bf0d6759c:/app# cat /app/scale_q/metric.cpp
