[35.839965, "i", "cat /app/csr_m/assemble.cpp\n"]
[35.840346, "o", "cat /app/csr_m/assemble.cpp\r\n\u001b[?2004l\r"]
[35.841425, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid matrix_from_case(const CaseSpec *spec, MatrixView *view) {\r\n    int dim = spec->nblocks * spec->bs;\r\n    int i;\r\n    memset(view, 0, sizeof(*view));\r\n    view->n = dim;\r\n    view->bs = spec->bs;\r\n    view->nblocks = spec->nblocks;\r\n    view->reorder = spec->reorder;\r\n    for (i = 0; i < spec->nblocks; i++) {\r\n        view->perm[i] = spec->perm[i];\r\n    }\r\n    for (i = 0; i < dim * dim; i++) {\r\n        view->a[i] = 0.0;\r\n    }\r\n    for (i = 0; i < spec->block_count; i++) {\r\n        const BlockEntry *be = &spec->blocks[i];\r\n        int rb = be->rb;\r\n        int cb = be->cb;\r\n        int r;\r\n        int c;\r\n        for (r = 0; r < spec->bs; r++) {\r\n            for (c = 0; c < spec->bs; c++) {\r\n                int gr = rb * spec->bs + r;\r\n                int gc = cb * spec->bs + c;\r\n                view->a[gr * dim + gc] = be->vals[r * spec->bs + c];\r\n            }\r\n        }\r\n    }\r\n    for (i = 0; i < dim; i++) {\r\n        view->b[i] = spec->rhs[i];\r\n    }\r\n}\r\n"]
[35.841523, "o", "\u001b[?2004hroot@448fd82dff43:/app# "]
