[109.61488, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     int nblocks = c / d;\r\n\u001b[?2004l\r\u001b[?2004h"]
[109.615952, "o", ">     for (int bi = 0; bi < nblocks; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int src = b[bi];\r\n\u001b[?2004l\r\u001b[?2004h>         for (int r = 0; r < d; r++) {\r\n\u001b[?2004l\r\u001b[?2004h>             e[bi * d + r] = a[src * d + r];\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
