[108.611692, "o", "    c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r"]
[108.611767, "o", "\u001b[?2004h> "]
[108.611859, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[108.61199, "o", "\u001b[?2004h> "]
[108.612091, "o", "        c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.612128, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.612279, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[108.612372, "o", "\u001b[?2004h> "]
[108.612469, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r"]
[108.612498, "o", "\u001b[?2004h> "]
[108.612645, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[108.612711, "o", "\u001b[?2004h> "]
[108.612844, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[108.612872, "o", "\u001b[?2004h> "]
[108.613026, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[108.613056, "o", "\u001b[?2004h> "]
[108.613246, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[108.613318, "o", "\u001b[?2004h> "]
[108.613519, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[108.613555, "o", "\u001b[?2004h> "]
[108.613719, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r"]
[108.613753, "o", "\u001b[?2004h> "]
[108.613964, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[108.61404, "o", "\u001b[?2004h> "]
[108.614157, "o", "                    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.614188, "o", "> "]
[108.614209, "o", "                }\r\n\u001b[?2004l\r"]
[108.614228, "o", "\u001b[?2004h"]
[108.614246, "o", "> "]
[108.614381, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.614406, "o", "        }\r\n\u001b[?2004l\r"]
[108.61446, "o", "\u001b[?2004h"]
[108.614492, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.614552, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.614613, "o", "> \r\n\u001b[?2004l\r"]
[108.614708, "o", "\u001b[?2004h> "]
[108.614848, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[108.614874, "o", "\u001b[?2004h"]
[108.614892, "o", "> "]
[108.615024, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.615113, "o", "> "]
[108.615197, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.615275, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r"]
[108.615309, "o", "\u001b[?2004h"]
[108.615335, "o", "> "]
[108.615469, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[108.615501, "o", "\u001b[?2004h> "]
[108.615598, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r"]
[108.615627, "o", "\u001b[?2004h"]
[108.61565, "o", "> "]
[108.615674, "o", "    }\r\n\u001b[?2004l\r"]
[108.615787, "o", "\u001b[?2004h> "]
[108.615883, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[108.615966, "o", "\u001b[?2004h> "]
[108.616064, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[108.616153, "o", "\u001b[?2004h> "]
[108.61625, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[108.616279, "o", "\u001b[?2004h> "]
[108.616442, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[108.616468, "o", "\u001b[?2004h"]
[108.616484, "o", "> "]
[108.616642, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[108.61674, "o", "\u001b[?2004h> "]
[108.616852, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[108.616971, "o", "\u001b[?2004h> "]
[108.617059, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[108.617093, "o", "\u001b[?2004h> "]
[108.617296, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[108.617381, "o", "\u001b[?2004h> "]
[108.617491, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.617573, "o", "> "]
[108.617766, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[108.617872, "o", "\u001b[?2004h>                 }\r\n\u001b[?2004l\r"]
[108.617977, "o", "\u001b[?2004h> "]
[108.618073, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[108.61814, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.61824, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.618358, "o", "EOF\r\n\u001b[?2004l\r"]
[108.619138, "o", "\u001b[?2004hroot@448fd82dff43:/app# "]
[109.112882, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        int blk = i / a->bs;\n        int loc = i % a->bs;\n        c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\n    }\n}\nEOF\n"]
[109.1133, "o", "cat > /app/prec_r/apply.cpp << 'EOF'\r\n\u001b[?2004l\r"]
[109.113515, "o", "\u001b[?2004h> "]
[109.11361, "o", "#include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[109.114469, "o", "> void step_r(const BsrPack *a, const double *b, double *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     int dim = a->n;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int blk = i / a->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[109.114806, "o", "        int loc = i % a->bs;\r\n\u001b[?2004l\r"]
[109.114935, "o", "\u001b[?2004h>         c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[109.115016, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[109.11505, "o", "> "]
[109.115144, "o", "}"]
[109.115211, "o", "\r\n\u001b[?2004l\r"]
[109.11529, "o", "\u001b[?2004h> "]
[109.115319, "o", "EOF\r\n"]
[109.115361, "o", "\u001b[?2004l\r"]
[109.116353, "o", "\u001b[?2004hroot@448fd82dff43:/app# "]
[109.612539, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int nblocks = c / d;\n    for (int bi = 0; bi < nblocks; bi++) {\n        int src = b[bi];\n        for (int r = 0; r < d; r++) {\n            e[bi * d + r] = a[src * d + r];\n        }\n    }\n}\nEOF\n"]
[109.613012, "o", "cat > /app/perm_p/order.cpp << 'EOF'"]
[109.613346, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> #include \"../include/matrix_view.h\""]
