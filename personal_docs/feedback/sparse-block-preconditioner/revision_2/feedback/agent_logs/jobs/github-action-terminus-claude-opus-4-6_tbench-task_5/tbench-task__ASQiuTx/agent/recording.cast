[112.311162, "o", "\u001b[?2004h>                 for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r\u001b[?2004h>                     for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r\u001b[?2004h>                         int gr = row_blk * bs + r;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[112.311358, "o", "                        int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[112.311699, "o", "                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n\u001b[?2004l\r\u001b[?2004h>                     }\r\n\u001b[?2004l\r\u001b[?2004h>                 }\r\n\u001b[?2004l\r\u001b[?2004h>                 ptr++;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[112.311817, "o", "            }"]
[112.311918, "o", "\r\n\u001b[?2004l\r"]
[112.312003, "o", "\u001b[?2004h> "]
[112.312067, "o", "        }\r\n\u001b[?2004l\r"]
[112.312092, "o", "\u001b[?2004h> "]
[112.312117, "o", "    }\r\n\u001b[?2004l\r"]
[112.312244, "o", "\u001b[?2004h"]
[112.312317, "o", ">     c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r\u001b[?2004h"]
[112.312352, "o", "> "]
[112.312442, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[112.312523, "o", "\u001b[?2004h> "]
[112.312635, "o", "        c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[112.312705, "o", ">     }\r\n\u001b[?2004l\r"]
[112.312741, "o", "\u001b[?2004h> "]
[112.31399, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[112.31403, "o", "\u001b[?2004h> "]
[112.314295, "o", "        int row_blk = reorder ? c->perm[bi] : bi;\r\n\u001b[?2004l\r"]
[112.314328, "o", "\u001b[?2004h"]
[112.314352, "o", "> "]
[112.314545, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r"]
[112.314635, "o", "\u001b[?2004h"]
[112.314696, "o", "> "]
[112.314798, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[112.314823, "o", "\u001b[?2004h"]
[112.314844, "o", "> "]
[112.315004, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[112.31503, "o", "\u001b[?2004h"]
[112.315052, "o", "> "]
[112.315195, "o", "            if (c->col_idx[k] == row_blk) {\r\n\u001b[?2004l\r"]
[112.315227, "o", "\u001b[?2004h> "]
[112.315392, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[112.31546, "o", "\u001b[?2004h> "]
[112.315631, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[112.315669, "o", "\u001b[?2004h> "]
[112.31581, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r"]
[112.315899, "o", "\u001b[?2004h> "]
[112.316055, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[112.316081, "o", "\u001b[?2004h> "]
[112.316176, "o", "                    }\r\n\u001b[?2004l\r"]
[112.316203, "o", "\u001b[?2004h> "]
[112.316292, "o", "                }\r\n\u001b[?2004l\r"]
[112.316318, "o", "\u001b[?2004h> "]
[112.3164, "o", "            }\r\n\u001b[?2004l\r"]
[112.316525, "o", "\u001b[?2004h> "]
[112.31661, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[112.316638, "o", "> }\r\n\u001b[?2004l\r"]
[112.31666, "o", "\u001b[?2004h> "]
[112.316686, "o", "\r\n\u001b[?2004l\r"]
[112.316829, "o", "\u001b[?2004h> "]
[112.316982, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[112.317052, "o", "\u001b[?2004h> "]
[112.317147, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r"]
[112.317257, "o", "\u001b[?2004h"]
[112.317344, "o", ">     int bs = pack->bs;\r\n\u001b[?2004l\r"]
[112.317418, "o", "\u001b[?2004h> "]
[112.317468, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r"]
[112.317522, "o", "\u001b[?2004h"]
[112.31758, "o", "> "]
[112.317716, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[112.317861, "o", ">         y[i] = 0.0;\r\n"]
[112.317985, "o", "\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[112.318105, "o", "\u001b[?2004h> "]
[112.318217, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[112.318296, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[112.318395, "o", "\u001b[?2004h> "]
[112.318509, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[112.318604, "o", "\u001b[?2004h> "]
[112.318675, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[112.318716, "o", "\u001b[?2004h> "]
[112.318837, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[112.318922, "o", "\u001b[?2004h> "]
[112.318999, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[112.319028, "o", "\u001b[?2004h> "]
[112.319169, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[112.319199, "o", "\u001b[?2004h> "]
[112.319339, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[112.31937, "o", "\u001b[?2004h> "]
[112.319515, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[112.319542, "o", "\u001b[?2004h> "]
[112.319784, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[112.319814, "o", "\u001b[?2004h> "]
[112.319908, "o", "                }\r\n\u001b[?2004l\r"]
[112.319991, "o", "\u001b[?2004h> "]
[112.320027, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[112.320097, "o", "        }\r\n\u001b[?2004l\r"]
[112.320122, "o", "\u001b[?2004h> "]
[112.320147, "o", "    }\r\n"]
[112.32017, "o", "\u001b[?2004l\r"]
[112.32019, "o", "\u001b[?2004h"]
[112.320298, "o", "> }\r\n"]
[112.32033, "o", "\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[112.321559, "o", "\u001b[?2004hroot@4c9dcbb4b369:/app# "]
[112.794712, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        c[i] = a->diag_inv[i] * b[i];\n    }\n}\nEOF\n"]
[112.79521, "o", "cat > /app/prec_r/apply.cpp << 'EOF'\r\n\u001b[?2004l\r"]
[112.795255, "o", "\u001b[?2004h"]
[112.795592, "o", "> "]
[112.795714, "o", "#include \"../include/matrix_view.h\"\r\n"]
[112.795956, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[112.796288, "o", "void step_r(const BsrPack *a, const double *b, double *c) {\r\n\u001b[?2004l\r"]
[112.796411, "o", "\u001b[?2004h> "]
[112.797632, "o", "    int dim = a->n;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         c[i] = a->diag_inv[i] * b[i];\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[112.798632, "o", "\u001b[?2004hroot@4c9dcbb4b369:/app# "]
[113.306295, "i", "cat > /app/scale_q/metric.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <math.h>\n\ndouble norm_q(const double *a, int b) {\n    double s = 0.0;\n    for (int i = 0; i < b; i++) {\n        s += a[i] * a[i];\n    }\n    return sqrt(s);\n}\nEOF\n"]
[113.307061, "o", "cat > /app/scale_q/metric.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[113.307217, "o", "#include <math.h>"]
[113.309583, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> double norm_q(const double *a, int b) {\r\n\u001b[?2004l\r\u001b[?2004h>     double s = 0.0;\r\n"]
[113.310865, "o", "\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < b; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         s += a[i] * a[i];\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     return sqrt(s);\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[113.311856, "o", "\u001b[?2004hroot@4c9dcbb4b369:/app# "]
[113.810593, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *perm, int n, int bs, double *e) {\n    int nblocks = n / bs;\n    for (int bi = 0; bi < nblocks; bi++) {\n        int src_blk = perm[bi];\n        for (int r = 0; r < bs; r++) {\n            e[bi * bs + r] = a[src_blk * bs + r];\n        }\n    }\n}\nEOF\n"]
[113.811572, "o", "cat > /app/perm_p/order.cpp << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n"]
