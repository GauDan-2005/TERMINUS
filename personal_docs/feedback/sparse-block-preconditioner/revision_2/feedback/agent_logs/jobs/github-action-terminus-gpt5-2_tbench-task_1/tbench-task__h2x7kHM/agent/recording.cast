[124.20363, "i", "python3 - <<'PY'\nimport json\np='/app/output/solver-audit.json'\nwith open(p) as f: data=json.load(f)\ncases=data.get('cases',[])\nprint('cases',len(cases))\nfail=[c for c in cases if not c.get('ok',False)]\nra=[c for c in cases if not c.get('residual_agrees',False)]\nhl=[c for c in cases if c.get('hit_limit',False)]\nprint('ok_false',len(fail))\nprint('residual_disagree',len(ra))\nprint('hit_limit',len(hl))\nfor title,arr in [('OK_FALSE',fail),('RESIDUAL_DISAGREE',ra),('HIT_LIMIT',hl)]:\n    if arr:\n        print('\\n'+title)\n        for c in arr:\n            print(c.get('name'), 'it',c.get('iterations'), 'final',c.get('final_residual'), 'reported',c.get('reported_residual'), 'agree',c.get('residual_agrees'), 'hit',c.get('hit_limit'))\nPY\n"]
