[12.181627, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nNAME=\"${1:?case name required}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n"]
[12.181671, "o", "\"${APP_ROOT}/bin/solverctl\" one \"${NAME}\"\r\n"]
