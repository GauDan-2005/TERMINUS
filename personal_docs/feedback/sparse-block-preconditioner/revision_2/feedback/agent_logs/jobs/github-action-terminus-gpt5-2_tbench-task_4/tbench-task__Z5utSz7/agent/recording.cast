[255.959505, "o", "#include \"../include/matrix_view.h\"\r\n"]
[255.959607, "o", "\r\n#include <math.h>\r\n#include <string.h>\r\n\r\nstatic double l2_norm(const double *v, int n) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < n; i++) {\r\n        s += v[i] * v[i];\r\n    }\r\n    return sqrt(s);\r\n}\r\n"]
[255.959639, "o", "\r\nvoid step_r(const BsrPack *a, const double *b, double *c);\r\n\r\nint pcg_solve(const BsrPack *pack, const double *rhs, double *x, int *iters, double *final_res) {\r\n    const int n = pack->n;\r\n    const int max_iter = 200;\r\n    const double tol = 1e-9;\r\n    double r[MAX_DIM];\r\n    double z[MAX_DIM];\r\n    double p[MAX_DIM];\r\n    double ap[MAX_DIM];\r\n    double rz_old;\r\n"]
[255.959663, "o", "    double alpha;\r\n    double beta;\r\n    double rs;\r\n    int k;\r\n\r\n    for (int i = 0; i < n; i++) {\r\n        x[i] = 0.0;\r\n"]
[255.959683, "o", "    }\r\n    bsr_matvec(pack, x, r);\r\n    for (int i = 0; i < n; i++) {\r\n        r[i] = rhs[i] - r[i];\r\n    }\r\n    rs = l2_norm(r, n);\r\n    if (rs < tol) {\r\n"]
[255.959702, "o", "        *iters = 0;\r\n        *final_res = rs;\r\n        return 0;\r\n    }\r\n    step_r(pack, r, z);\r\n    memcpy(p, z, (size_t)n * sizeof(double));\r\n"]
[255.959723, "o", "    rz_old = 0.0;\r\n    for (int i = 0; i < n; i++) {\r\n        rz_old += r[i] * z[i];\r\n    }\r\n    for (k = 1; k <= max_iter; k++) {\r\n"]
[255.95974, "o", "        bsr_matvec(pack, p, ap);\r\n        alpha = rz_old;\r\n        double denom = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n            denom += p[i] * ap[i];\r\n        }\r\n"]
[255.959756, "o", "        if (fabs(denom) < 1e-30) {\r\n            break;\r\n        }\r\n        alpha /= denom;\r\n        for (int i = 0; i < n; i++) {\r\n"]
[255.959776, "o", "            x[i] += alpha * p[i];\r\n            r[i] -= alpha * ap[i];\r\n        }\r\n        rs = l2_norm(r, n);\r\n        if (rs < tol) {\r\n            *iters = k;\r\n"]
[255.959793, "o", "            *final_res = rs;\r\n            return 0;\r\n        }\r\n        step_r(pack, r, z);\r\n        beta = 0.0;"]
[255.959814, "o", "\r\n        for (int i = 0; i < n; i++) {\r\n            beta += r[i] * z[i];\r\n        }\r\n        beta /= rz_old;\r\n"]
[255.959833, "o", "        for (int i = 0; i < n; i++) {\r\n            p[i] = z[i] + beta * p[i];\r\n        }\r\n        rz_old = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n            rz_old += r[i] * z[i];\r\n"]
[255.959851, "o", "        }\r\n    }\r\n    *iters = max_iter;\r\n    *final_res = rs;\r\n    return 1;\r\n"]
[255.959875, "o", "}\r\n"]
[255.960109, "o", "\u001b[?2004h"]
[255.960133, "o", "root@60c46bae9fb1:/app# "]
