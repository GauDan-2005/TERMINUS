[156.485819, "o", "APP_ROOT=\"${APP_ROOT:-/app}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.485929, "o", "OUT=\"${APP_ROOT}/output\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.486026, "o", "mkdir -p \"${OUT}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[156.486917, "o", "> # Clean transient solver byproducts but preserve audit JSON artifacts.\r\n\u001b[?2004l\r\u001b[?2004h> # The audit scripts and solverctl are responsible for (over)writing audit JSON.\r\n\u001b[?2004l\r\u001b[?2004h> shopt -s nullglob\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.486968, "o", "for f in \"${OUT}\"/*; do\r\n\u001b[?2004l\r"]
[156.486996, "o", "\u001b[?2004h> "]
[156.487138, "o", "  base=\"$(basename \"$f\")\""]
[156.487758, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>   case \"$base\" in\r\n\u001b[?2004l\r\u001b[?2004h>     solver-audit.json|*-audit.json)\r\n\u001b[?2004l\r\u001b[?2004h>       ;;\r\n\u001b[?2004l\r\u001b[?2004h>     *)\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.487874, "o", ">       rm -rf -- \"$f\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.487962, "o", "      ;;\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.487997, "o", ">   esac\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.488061, "o", "> done\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.48813, "o", "> "]
[156.488197, "o", "EOF\r\n\u001b[?2004l\r"]
[156.489363, "o", "\u001b[?2004hroot@60c46bae9fb1:/app# "]
