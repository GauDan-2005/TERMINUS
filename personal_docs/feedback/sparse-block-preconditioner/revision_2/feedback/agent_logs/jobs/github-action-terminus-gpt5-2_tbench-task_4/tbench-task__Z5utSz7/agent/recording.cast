[255.84696, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n\r\ndouble norm_q(const double *a, int b) {\r\n    double s = 0.0;\r\n"]
[255.847133, "o", "    for (int i = 0; i < b; i++) {\r\n        s += a[i] * a[i];\r\n    }\r\n    return sqrt(s) + 1.0e-4;\r\n}\r\n"]
[255.847424, "o", "\u001b[?2004hroot@60c46bae9fb1:/app# "]
