[78.838997, "i", "sed -n '1,200p' /app/src/main.cpp\n"]
[78.83938, "o", "sed -n '1,200p' /app/src/main.cpp\r\n\u001b[?2004l\r"]
[78.84141, "o", "#include \"../include/case_spec.h\"\r\n#include \"../include/solver_report.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <sys/stat.h>\r\n\r\nint run_u(const CaseSpec *spec, const char *out_dir, SolveResult *out);\r\n\r\nstatic const char *CASES[] = {\"basalt\", \"flint\", \"shale\", \"garnet\", \"mica\", \"opal\", NULL};\r\n"]
[78.841651, "o", "\r\nstatic int run_named(const char *name, const char *out_dir, SolveResult *res) {\r\n    char path[512];\r\n    CaseSpec spec;\r\n    snprintf(path, sizeof(path), \"/app/data/cases/%s.case\", name);\r\n    if (case_load(path, &spec) != 0) {\r\n        return -1;\r\n    }\r\n    return run_u(&spec, out_dir, res);\r\n}\r\n\r\nint main(int argc, char **argv) {\r\n    const char *out_dir = \"/app/output\";\r\n    mkdir(out_dir, 0755);\r\n    if (argc >= 2 && strcmp(argv[1], \"matrix\") == 0) {\r\n        SolveResult cases[6];\r\n        int n = 0;\r\n        for (int i = 0; CASES[i]; i++) {\r\n            if (run_named(CASES[i], out_dir, &cases[n]) != 0) {\r\n                return 1;\r\n            }\r\n            n++;\r\n        }\r\n        if (emit_matrix(cases, n, \"/app/output/solver-audit.json\") != 0) {\r\n            return 1;\r\n        }\r\n        return 0;\r\n    }\r\n    if (argc >= 3 && strcmp(argv[1], \"one\") == 0) {\r\n"]
[78.841773, "o", "        SolveResult res;\r\n        char audit[512];\r\n        if (run_named(argv[2], out_dir, &res) != 0) {\r\n            return 1;\r\n        }\r\n        snprintf(audit, sizeof(audit), \"/app/output/%s-audit.json\", argv[2]);\r\n        return emit_t(&res, audit) != 0;\r\n    }\r\n    fprintf(stderr, \"usage: solverctl matrix | solverctl one <case>\\n\");\r\n    return 1;\r\n}\r\n"]
[78.841932, "o", "\u001b[?2004hroot@60c46bae9fb1:/app# "]
[78.955546, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: scripts/run-matrix.sh\n@@\n APP_ROOT=\"${APP_ROOT:-/app}\"\n OUT=\"${APP_ROOT}/output\"\n mkdir -p \"${OUT}\"\n bash \"${APP_ROOT}/scripts/clean-room.sh\"\n-\"${APP_ROOT}/bin/solverctl\" matrix\n+SOLVERCTL=\"${SOLVERCTL:-}\"\n+if [[ -z \"${SOLVERCTL}\" ]]; then\n+  if [[ -x \"${APP_ROOT}/bin/solverctl\" ]]; then\n+    SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\n+  elif [[ -x \"${APP_ROOT}/build/bin/solverctl\" ]]; then\n+    SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\n+  else\n+    echo \"solverctl not found (looked in ${APP_ROOT}/bin and ${APP_ROOT}/build/bin); set SOLVERCTL=...\" >&2\n+    exit 127\n+  fi\n+fi\n+\n+\"${SOLVERCTL}\" matrix > \"${OUT}/solver-audit.json\"\n*** End Patch\nPATCH\n"]
[78.956022, "o", "apply_patch<<'PATCH'\r\n\u001b[?2004l\r"]
