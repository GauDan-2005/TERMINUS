[362.607726, "i", "cat > /app/scripts/clean-room.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\nAPP_ROOT=\"${APP_ROOT:-/app}\"\nOUT=\"${APP_ROOT}/output\"\nmkdir -p \"${OUT}\"\n\n# Clean transient solver byproducts but preserve audit JSON artifacts.\n# Keep the canonical solver-audit.json, any solver-audit*.json copies, and per-case *-audit.json.\nshopt -s nullglob\nfor f in \"${OUT}\"/*; do\n  base=\"$(basename \"$f\")\"\n  case \"$base\" in\n    solver-audit.json|solver-audit*.json|*-audit.json)\n      ;;\n    *)\n      rm -rf -- \"$f\"\n      ;;\n  esac\ndone\nEOF\nchmod +x /app/scripts/clean-room.sh\n"]
