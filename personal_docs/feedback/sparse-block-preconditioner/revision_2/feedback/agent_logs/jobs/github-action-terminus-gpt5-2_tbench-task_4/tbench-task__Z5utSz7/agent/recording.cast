[257.093772, "o", "/app/include/solver_report.h:10:    double reported_residual;\r\n/app/flow_t/report.cpp:22:    fprintf(fp, \"      \\\"reported_residual\\\": %.17g,\\n\", res->reported_residual);\r\n"]
