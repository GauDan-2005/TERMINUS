[419.82513, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nNAME=\"${1:?case name required}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\n\r\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n"]
[419.82517, "o", "\r\nSOLVERCTL=\"${SOLVERCTL:-}\"\r\nif [[ -z \"${SOLVERCTL}\" ]]; then\r\n  if [[ -x \"${APP_ROOT}/bin/solverctl\" ]]; then\r\n    SOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\r\n  elif [[ -x \"${APP_ROOT}/build/bin/solverctl\" ]]; then\r\n    SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\r\n  else\r\n    echo \"solverctl not found (looked in ${APP_ROOT}/bin and ${APP_ROOT}/build/bin); set SOLVERCTL=...\" >&2\r\n"]
[419.825194, "o", "    exit 127\r\n  fi\r\nfi\r\n\r\n"]
[419.825215, "o", "\"${SOLVERCTL}\" one \"${NAME}\"\r\n"]
