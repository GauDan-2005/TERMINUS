[153.575745, "o", "sed -n '1,200p' /app/src/main.cpp\r\n\u001b[?2004l\r"]
[153.577442, "o", "#include \"../include/case_spec.h\"\r\n#include \"../include/solver_report.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <sys/stat.h>\r\n\r\nint run_u(const CaseSpec *spec, const char *out_dir, SolveResult *out);\r\n"]
[153.57749, "o", "\r\nstatic const char *CASES[] = {\"basalt\", \"flint\", \"shale\", \"garnet\", \"mica\", \"opal\", NULL};\r\n\r\nstatic int run_named(const char *name, const char *out_dir, SolveResult *res) {\r\n    char path[512];\r\n"]
[153.577612, "o", "    CaseSpec spec;\r\n    snprintf(path, sizeof(path), \"/app/data/cases/%s.case\", name);\r\n    if (case_load(path, &spec) != 0) {\r\n"]
[153.577653, "o", "        return -1;\r\n    }\r\n"]
[153.578252, "o", "    return run_u(&spec, out_dir, res);\r\n}\r\n\r\nint main(int argc, char **argv) {\r\n    const char *out_dir = \"/app/output\";\r\n    mkdir(out_dir, 0755);\r\n    if (argc >= 2 && strcmp(argv[1], \"matrix\") == 0) {\r\n        SolveResult cases[6];\r\n        int n = 0;\r\n        for (int i = 0; CASES[i]; i++) {\r\n            if (run_named(CASES[i], out_dir, &cases[n]) != 0) {\r\n                return 1;\r\n            }\r\n            n++;\r\n        }\r\n        if (emit_matrix(cases, n, \"/app/output/solver-audit.json\") != 0) {\r\n            return 1;\r\n        }\r\n        return 0;\r\n    }\r\n    if (argc >= 3 && strcmp(argv[1], \"one\") == 0) {\r\n        SolveResult res;\r\n        char audit[512];\r\n        if (run_named(argv[2], out_dir, &res) != 0) {\r\n            return 1;\r\n        }\r\n        snprintf(audit, sizeof(audit), \"/app/output/%s-audit.json\", argv[2]);\r\n        return emit_t(&res, audit) != 0;\r\n    }\r\n    fprintf(stderr, \"usage: solverctl matrix | solverctl one <case>\\n\");\r\n    return 1;\r\n}\r\n\u001b[?2004hroot@8d4b11936542:/app# "]
[153.698937, "i", "sed -n '1,220p' /app/solve_s/driver.cpp\n"]
[153.699496, "o", "sed -n '1,220p' /app/solve_s/driver.cpp\r\n\u001b[?2004l\r"]
[153.700948, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n#include <string.h>\r\n\r\nstatic double l2_norm(const double *v, int n) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < n; i++) {\r\n        s += v[i] * v[i];\r\n    }\r\n    return sqrt(s);\r\n}\r\n\r\nvoid step_r(const BsrPack *a, const double *b, double *c);\r\n\r\nint pcg_solve(const BsrPack *pack, const double *rhs, double *x, int *iters, double *final_res) {\r\n    const int n = pack->n;\r\n    const int max_iter = 200;\r\n    const double tol = 1e-9;\r\n    double r[MAX_DIM];\r\n    double z[MAX_DIM];\r\n    double p[MAX_DIM];\r\n    double ap[MAX_DIM];\r\n    double rz_old;\r\n    double alpha;\r\n"]
[153.700987, "o", "    double beta;\r\n    double rs;\r\n    int k;\r\n\r\n    for (int i = 0; i < n; i++) {\r\n        x[i] = 0.0;\r\n    }\r\n    bsr_matvec(pack, x, r);\r\n    for (int i = 0; i < n; i++) {\r\n        r[i] = rhs[i] - r[i];\r\n    }\r\n    rs = l2_norm(r, n);\r\n    if (rs < tol) {\r\n        *iters = 0;\r\n        *final_res = rs;\r\n        return 0;\r\n    }\r\n    step_r(pack, r, z);\r\n    memcpy(p, z, (size_t)n * sizeof(double));\r\n"]
[153.701015, "o", "    rz_old = 0.0;\r\n    for (int i = 0; i < n; i++) {\r\n        rz_old += r[i] * z[i];\r\n    }\r\n    for (k = 1; k <= max_iter; k++) {\r\n        bsr_matvec(pack, p, ap);\r\n        alpha = rz_old;\r\n        double denom = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n            denom += p[i] * ap[i];\r\n"]
[153.701039, "o", "        }\r\n        if (fabs(denom) < 1e-30) {\r\n            break;\r\n        }\r\n        alpha /= denom;\r\n        for (int i = 0; i < n; i++) {\r\n            x[i] += alpha * p[i];\r\n            r[i] -= alpha * ap[i];\r\n        }\r\n"]
[153.701066, "o", "        rs = l2_norm(r, n);\r\n        if (rs < tol) {\r\n            *iters = k;\r\n            *final_res = rs;\r\n            return 0;\r\n        }\r\n        step_r(pack, r, z);\r\n        beta = 0.0;\r\n"]
[153.70109, "o", "        for (int i = 0; i < n; i++) {\r\n            beta += r[i] * z[i];\r\n        }\r\n        beta /= rz_old;\r\n        for (int i = 0; i < n; i++) {\r\n            p[i] = z[i] + beta * p[i];\r\n        }\r\n"]
[153.701114, "o", "        rz_old = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n            rz_old += r[i] * z[i];\r\n        }\r\n    }\r\n    *iters = max_iter;\r\n    *final_res = rs;\r\n    return 1;\r\n}\r\n"]
[153.701371, "o", "\u001b[?2004hroot@8d4b11936542:/app# "]
[153.842779, "i", "sed -n '1,220p' /app/scale_q/metric.cpp\n"]
[153.843178, "o", "sed -n '1,220p' /app/scale_q/metric.cpp\r\n\u001b[?2004l\r"]
[153.844697, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n\r\ndouble norm_q(const double *a, int b) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < b; i++) {\r\n        s += a[i] * a[i];\r\n"]
[153.844927, "o", "    }\r\n    return sqrt(s) + 1.0e-4;\r\n}\r\n"]
[153.844968, "o", "\u001b[?2004hroot@8d4b11936542:/app# "]
[153.967269, "i", "sed -n '1,260p' /app/flow_t/report.cpp\n"]
