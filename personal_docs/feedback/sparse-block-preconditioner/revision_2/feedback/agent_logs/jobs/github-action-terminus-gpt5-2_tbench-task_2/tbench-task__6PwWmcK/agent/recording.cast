[335.78738, "i", "cat > /app/scripts/run-matrix.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\n\nAPP_ROOT=\"${APP_ROOT:-/app}\"\nOUT=\"${APP_ROOT}/output\"\nmkdir -p \"${OUT}\"\n\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\n\nSOLVERCTL=\"${APP_ROOT}/bin/solverctl\"\nif [[ ! -x \"${SOLVERCTL}\" ]]; then\n  SOLVERCTL=\"${APP_ROOT}/build/bin/solverctl\"\nfi\nif [[ ! -x \"${SOLVERCTL}\" ]]; then\n  if command -v solverctl >/dev/null 2>&1; then\n    SOLVERCTL=\"$(command -v solverctl)\"\n  fi\nfi\nif [[ ! -x \"${SOLVERCTL}\" ]]; then\n  echo \"error: solverctl not found; build with CMake (e.g. /app/build/bin/solverctl)\" >&2\n  exit 127\nfi\n\n\"${SOLVERCTL}\" matrix\nEOF\nchmod +x /app/scripts/run-matrix.sh\n"]
