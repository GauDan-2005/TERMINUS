Sending keys: ['cat > /app/perm_p/order.cpp <<\'EOF\'\n#include "../include/matrix_view.h"\n\n#include <string.h>\n\n// Apply a block permutation to a scalar vector.\n//\n// b[] is a block permutation of length nb such that:\n//   packed block i corresponds to global block b[i].\n//\n// c is the scalar length n, d is the block size bs.\n//\n// If d > 0:\n//   this function maps global -> packed (used for RHS before solve)\n// If d < 0:\n//   this function maps packed -> global\n//\n// (The sign trick keeps the original signature while allowing both directions.)\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int bs = d < 0 ? -d : d;\n    if (!b || bs <= 0) {\n        memcpy(e, a, (size_t)c * sizeof(double));\n        return;\n    }\n    int nb = c / bs;\n\n    if (d > 0) {\n        // global -> packed\n        for (int bi = 0; bi < nb; bi++) {\n            int gbi = b[bi];\n            for (int r = 0; r < bs; r++) {\n                e[bi * bs + r] = a[gbi * bs + r];\n            }\n        }\n    } else {\n        // packed -> global\n        for (int bi = 0; bi < nb; bi++) {\n            int gbi = b[bi];\n            for (int r = 0; r < bs; r++) {\n                e[gbi * bs + r] = a[bi * bs + r];\n            }\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > /app/bsr_n/layout.cpp <<\'EOF\'\n#include "../include/matrix_view.h"\n\n#include <math.h>\n#include <string.h>\n\nvoid fn_n(const MatrixView *a, int reorder, BsrPack *c) {\n    int nb = a->nblocks;\n    int bs = a->bs;\n    int dim = a->n;\n    int ptr = 0;\n\n    memset(c, 0, sizeof(*c));\n    c->n = dim;\n    c->bs = bs;\n    c->nblocks = nb;\n    c->reorder = reorder;\n    for (int i = 0; i < nb; i++) {\n        c->perm[i] = a->perm[i];\n    }\n\n    // Pack in *packed block coordinates* (bi,bj). When reordered, packed block\n    // index i maps to global block index perm[i]. We store col_idx as packed bj.\n    for (int bi = 0; bi < nb; bi++) {\n        int row_blk = reorder ? a->perm[bi] : bi; // global block for this packed row\n        c->row_ptr[bi] = ptr;\n\n        for (int bj = 0; bj < nb; bj++) {\n            int col_blk = reorder ? a->perm[bj] : bj; // global block for this packed col\n            int has = 0;\n\n            for (int r = 0; r < bs; r++) {\n                for (int cc = 0; cc < bs; cc++) {\n                    int gr = row_blk * bs + r;\n                    int gc = col_blk * bs + cc;\n                    double v = a->a[gr * dim + gc];\n                    if (fabs(v) > 0.0) {\n                        has = 1;\n                    }\n                }\n            }\n\n            if (has) {\n                c->col_idx[ptr] = bj; // packed column index\n                for (int r = 0; r < bs; r++) {\n                    for (int cc = 0; cc < bs; cc++) {\n                        int gr = row_blk * bs + r;\n                        int gc = col_blk * bs + cc;\n                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\n                    }\n                }\n                ptr++;\n            }\n        }\n    }\n\n    c->row_ptr[nb] = ptr;\n\n    // Jacobi preconditioner diagonal inverse in *packed scalar coordinates*.\n    for (int i = 0; i < dim; i++) {\n        c->diag_inv[i] = 1.0;\n    }\n    for (int bi = 0; bi < nb; bi++) {\n        int start = c->row_ptr[bi];\n        int end = c->row_ptr[bi + 1];\n        for (int k = start; k < end; k++) {\n            if (c->col_idx[k] == bi) {\n                for (int r = 0; r < bs; r++) {\n                    double d = c->data[k * bs * bs + r * bs + r];\n                    if (fabs(d) > 1e-14) {\n                        c->diag_inv[bi * bs + r] = 1.0 / d;\n                    }\n                }\n            }\n        }\n    }\n}\n\nvoid bsr_matvec(const BsrPack *pack, const double *x, double *y) {\n    int nb = pack->nblocks;\n    int bs = pack->bs;\n    int dim = pack->n;\n\n    for (int i = 0; i < dim; i++) {\n        y[i] = 0.0;\n    }\n\n    for (int bi = 0; bi < nb; bi++) {\n        int start = pack->row_ptr[bi];\n        int end = pack->row_ptr[bi + 1];\n        int row_blk = pack->reorder ? pack->perm[bi] : bi; // global block\n\n        for (int k = start; k < end; k++) {\n            int bj = pack->col_idx[k];\n            int col_blk = pack->reorder ? pack->perm[bj] : bj; // global block\n\n            for (int r = 0; r < bs; r++) {\n                for (int c = 0; c < bs; c++) {\n                    int gi = row_blk * bs + r;\n                    int gj = col_blk * bs + c;\n                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\n                }\n            }\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
