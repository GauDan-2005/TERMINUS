Sending keys: ['cat > /app/bsr_n/layout.cpp <<\'EOF\'\n#include "../include/matrix_view.h"\n\n#include <math.h>\n#include <string.h>\n\nvoid fn_n(const MatrixView *a, int reorder, BsrPack *c) {\n    int nb = a->nblocks;\n    int bs = a->bs;\n    int dim = a->n;\n    int ptr = 0;\n\n    memset(c, 0, sizeof(*c));\n    c->n = dim;\n    c->bs = bs;\n    c->nblocks = nb;\n    c->reorder = reorder;\n    for (int i = 0; i < nb; i++) {\n        c->perm[i] = a->perm[i];\n    }\n\n    // Pack in packed coordinates. For reorder==1, packed block index i maps to\n    // global block index perm[i] when reading from dense a->a.\n    for (int bi = 0; bi < nb; bi++) {\n        int grow = reorder ? a->perm[bi] : bi;\n        c->row_ptr[bi] = ptr;\n\n        for (int bj = 0; bj < nb; bj++) {\n            int gcol = reorder ? a->perm[bj] : bj;\n\n            int has = 0;\n            for (int r = 0; r < bs; r++) {\n                for (int cc = 0; cc < bs; cc++) {\n                    int gr = grow * bs + r;\n                    int gc = gcol * bs + cc;\n                    double v = a->a[gr * dim + gc];\n                    if (fabs(v) > 0.0) has = 1;\n                }\n            }\n\n            if (has) {\n                c->col_idx[ptr] = bj; // packed col index\n                for (int r = 0; r < bs; r++) {\n                    for (int cc = 0; cc < bs; cc++) {\n                        int gr = grow * bs + r;\n                        int gc = gcol * bs + cc;\n                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\n                    }\n                }\n                ptr++;\n            }\n        }\n    }\n\n    c->row_ptr[nb] = ptr;\n\n    // Diagonal inverse in packed scalar coordinates.\n    for (int i = 0; i < dim; i++) c->diag_inv[i] = 1.0;\n    for (int bi = 0; bi < nb; bi++) {\n        int start = c->row_ptr[bi];\n        int end = c->row_ptr[bi + 1];\n        for (int k = start; k < end; k++) {\n            if (c->col_idx[k] == bi) {\n                for (int r = 0; r < bs; r++) {\n                    double d = c->data[k * bs * bs + r * bs + r];\n                    if (fabs(d) > 1e-14) c->diag_inv[bi * bs + r] = 1.0 / d;\n                }\n            }\n        }\n    }\n}\n\nvoid bsr_matvec(const BsrPack *pack, const double *x, double *y) {\n    int nb = pack->nblocks;\n    int bs = pack->bs;\n    int dim = pack->n;\n\n    for (int i = 0; i < dim; i++) y[i] = 0.0;\n\n    // Matvec is performed in packed coordinates; reorder affects only how the\n    // pack was assembled (which global rows/cols were read into each packed block).\n    for (int bi = 0; bi < nb; bi++) {\n        int start = pack->row_ptr[bi];\n        int end = pack->row_ptr[bi + 1];\n        for (int k = start; k < end; k++) {\n            int bj = pack->col_idx[k];\n            for (int r = 0; r < bs; r++) {\n                for (int c = 0; c < bs; c++) {\n                    int gi = bi * bs + r;\n                    int gj = bj * bs + c;\n                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\n                }\n            }\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
