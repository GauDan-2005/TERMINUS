[296.613227, "o", "\u001b[?2004l\r"]
[296.613308, "o", "\u001b[?2004h"]
[296.613421, "o", "> \r\n\u001b[?2004l\r"]
[296.613499, "o", "\u001b[?2004h"]
[296.613624, "o", "> "]
[296.61384, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[296.614006, "o", "\u001b[?2004h> "]
[296.61404, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.614186, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r"]
[296.614304, "o", "\u001b[?2004h> "]
[296.614332, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[296.61441, "o", "\u001b[?2004h"]
[296.614513, "o", "> "]
[296.614553, "o", "    for (int i = 0; i < dim; i++) y[i] = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[296.614645, "o", "> \r\n\u001b[?2004l\r"]
[296.614746, "o", "\u001b[?2004h> "]
[296.614937, "o", "    // Matvec is performed in packed coordinates; reorder affects only how the\r\n\u001b[?2004l\r"]
[296.615052, "o", "\u001b[?2004h> "]
[296.615317, "o", "    // pack was assembled (which global rows/cols were read into each packed block).\r\n\u001b[?2004l\r"]
[296.615347, "o", "\u001b[?2004h"]
[296.61537, "o", "> "]
[296.615523, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[296.615563, "o", "\u001b[?2004h> "]
[296.615733, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[296.615766, "o", "\u001b[?2004h> "]
[296.615932, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[296.615967, "o", "\u001b[?2004h> "]
[296.61615, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[296.616183, "o", "\u001b[?2004h> "]
[296.616352, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[296.616402, "o", "\u001b[?2004h> "]
[296.616568, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[296.616604, "o", "\u001b[?2004h> "]
[296.6168, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[296.616833, "o", "\u001b[?2004h> "]
[296.617013, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[296.617047, "o", "\u001b[?2004h> "]
[296.617233, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[296.617268, "o", "\u001b[?2004h> "]
[296.617671, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[296.617707, "o", "\u001b[?2004h> "]
[296.617908, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h"]
[296.617942, "o", ">             }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.618033, "o", "        }\r\n\u001b[?2004l\r"]
[296.618067, "o", "\u001b[?2004h"]
[296.618208, "o", ">     }\r\n\u001b[?2004l\r"]
[296.618339, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[296.619507, "o", "\u001b[?2004hroot@608af32c58d9:/app# "]
[296.730493, "i", "cat > /app/scale_q/metric.cpp <<'EOF'\n#include <math.h>\n\n// Independent residual metric helper used by the audit.\n// Must match the L2 norm used by the driver.\ndouble norm_q(const double *a, int b) {\n    double s = 0.0;\n    for (int i = 0; i < b; i++) {\n        s += a[i] * a[i];\n    }\n    return sqrt(s);\n}\nEOF\n"]
[296.730947, "o", "cat > /app/scale_q/metric.cpp <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
[296.731127, "o", "> "]
[296.731232, "o", "#include <math.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
