[441.755438, "i", "python3 - <<'PY'\nimport json,glob,os\nm=json.load(open('/tmp/solver-audit.json.run1'))\nby={c['name']:c for c in m['cases']}\nall_ok=True\nfiles=[f for f in glob.glob('/app/output/*-audit.json') if not f.endswith('/solver-audit.json')]\nprint('case_files', len(files))\nfor f in sorted(files):\n    name=os.path.basename(f).replace('-audit.json','')\n    one=json.load(open(f))['cases'][0]\n    if one!=by.get(name):\n        all_ok=False\n        print('DIFF', name)\n        print(' one :', one)\n        print(' mat :', by.get(name))\nprint('per-case match:', all_ok)\nPY\n"]
