[253.443406, "o", "\u001b[?2004h> "]
[253.443443, "o", "//\r\n\u001b[?2004l\r"]
[253.447613, "o", "\u001b[?2004h> // (The sign trick keeps the original signature while allowing both directions.)\r\n\u001b[?2004l\r\u001b[?2004h> void map_p(const double *a, const int *b, int c, int d, double *e) {\r\n\u001b[?2004l\r\u001b[?2004h>     int bs = d < 0 ? -d : d;\r\n\u001b[?2004l\r\u001b[?2004h>     if (!b || bs <= 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         memcpy(e, a, (size_t)c * sizeof(double));\r\n\u001b[?2004l\r\u001b[?2004h>         return;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     int nb = c / bs;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if (d > 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         // global -> packed\r\n\u001b[?2004l\r\u001b[?2004h>         for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h>             int gbi = b[bi];\r\n\u001b[?2004l\r\u001b[?2004h>             for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r\u001b[?2004h>                 e[bi * bs + r] = a[gbi * bs + r];\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     } else {\r\n\u001b[?2004l\r\u001b[?2004h>         // packed -> global\r\n\u001b[?2004l\r\u001b[?2004h>         for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h>             int gbi = b[bi];\r\n\u001b[?2004l\r\u001b[?2004h>             for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r\u001b[?2004h>                 e[gbi * bs + r] = a[bi * bs + r];\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[253.448661, "o", "\u001b[?2004hroot@608af32c58d9:/app# "]
[253.559127, "i", "cat > /app/bsr_n/layout.cpp <<'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <math.h>\n#include <string.h>\n\nvoid fn_n(const MatrixView *a, int reorder, BsrPack *c) {\n    int nb = a->nblocks;\n    int bs = a->bs;\n    int dim = a->n;\n    int ptr = 0;\n\n    memset(c, 0, sizeof(*c));\n    c->n = dim;\n    c->bs = bs;\n    c->nblocks = nb;\n    c->reorder = reorder;\n    for (int i = 0; i < nb; i++) {\n        c->perm[i] = a->perm[i];\n    }\n\n    // Pack in *packed block coordinates* (bi,bj). When reordered, packed block\n    // index i maps to global block index perm[i]. We store col_idx as packed bj.\n    for (int bi = 0; bi < nb; bi++) {\n        int row_blk = reorder ? a->perm[bi] : bi; // global block for this packed row\n        c->row_ptr[bi] = ptr;\n\n        for (int bj = 0; bj < nb; bj++) {\n            int col_blk = reorder ? a->perm[bj] : bj; // global block for this packed col\n            int has = 0;\n\n            for (int r = 0; r < bs; r++) {\n                for (int cc = 0; cc < bs; cc++) {\n                    int gr = row_blk * bs + r;\n                    int gc = col_blk * bs + cc;\n                    double v = a->a[gr * dim + gc];\n                    if (fabs(v) > 0.0) {\n                        has = 1;\n                    }\n                }\n            }\n\n            if (has) {\n                c->col_idx[ptr] = bj; // packed column index\n                for (int r = 0; r < bs; r++) {\n                    for (int cc = 0; cc < bs; cc++) {\n                        int gr = row_blk * bs + r;\n                        int gc = col_blk * bs + cc;\n                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\n                    }\n                }\n                ptr++;\n            }\n        }\n    }\n\n    c->row_ptr[nb] = ptr;\n\n    // Jacobi preconditioner diagonal inverse in *packed scalar coordinates*.\n    for (int i = 0; i < dim; i++) {\n        c->diag_inv[i] = 1.0;\n    }\n    for (int bi = 0; bi < nb; bi++) {\n        int start = c->row_ptr[bi];\n        int end = c->row_ptr[bi + 1];\n        for (int k = start; k < end; k++) {\n            if (c->col_idx[k] == bi) {\n                for (int r = 0; r < bs; r++) {\n                    double d = c->data[k * bs * bs + r * bs + r];\n                    if (fabs(d) > 1e-14) {\n                        c->diag_inv[bi * bs + r] = 1.0 / d;\n                    }\n                }\n            }\n        }\n    }\n}\n\nvoid bsr_matvec(const BsrPack *pack, const double *x, double *y) {\n    int nb = pack->nblocks;\n    int bs = pack->bs;\n    int dim = pack->n;\n\n    for (int i = 0; i < dim; i++) {\n        y[i] = 0.0;\n    }\n\n    for (int bi = 0; bi < nb; bi++) {\n        int start = pack->row_ptr[bi];\n        int end = pack->row_ptr[bi + 1];\n        int row_blk = pack->reorder ? pack->perm[bi] : bi; // global block\n\n        for (int k = start; k < end; k++) {\n            int bj = pack->col_idx[k];\n            int col_blk = pack->reorder ? pack->perm[bj] : bj; // global block\n\n            for (int r = 0; r < bs; r++) {\n                for (int c = 0; c < bs; c++) {\n                    int gi = row_blk * bs + r;\n                    int gj = col_blk * bs + c;\n                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\n                }\n            }\n        }\n    }\n}\nEOF\n"]
[253.559565, "o", "cat > /app/bsr_n/layout.cpp <<'EOF'\r\n\u001b[?2004l\r"]
[253.559742, "o", "\u001b[?2004h> #include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r"]
[253.559768, "o", "\u001b[?2004h> "]
[253.55979, "o", "\r\n\u001b[?2004l\r"]
[253.55981, "o", "\u001b[?2004h"]
[253.559834, "o", "> "]
[253.562304, "o", "#include <math.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void fn_n(const MatrixView *a, int reorder, BsrPack *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     int nb = a->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h>     int bs = a->bs;\r\n\u001b[?2004l\r\u001b[?2004h>     int dim = a->n;\r\n\u001b[?2004l\r\u001b[?2004h>     int ptr = 0;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     memset(c, 0, sizeof(*c));\r\n\u001b[?2004l\r\u001b[?2004h>     c->n = dim;\r\n\u001b[?2004l\r\u001b[?2004h>     c->bs = bs;\r\n\u001b[?2004l\r\u001b[?2004h>     c->nblocks = nb;\r\n\u001b[?2004l\r\u001b[?2004h>     c->reorder = reorder;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < nb; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         c->perm[i] = a->perm[i];\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.562779, "o", "    // Pack in *packed block coordinates* (bi,bj). When reordered, packed block\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.562999, "o", "    // index i maps to global block index perm[i]. We store col_idx as packed bj.\r\n\u001b[?2004l\r"]
[253.563068, "o", "\u001b[?2004h"]
[253.563094, "o", "> "]
[253.563251, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[253.563281, "o", "\u001b[?2004h"]
[253.563307, "o", "> "]
[253.563611, "o", "        int row_blk = reorder ? a->perm[bi] : bi; // global block for this packed row\r\n\u001b[?2004l\r"]
[253.563653, "o", "\u001b[?2004h"]
[253.563678, "o", "> "]
[253.563808, "o", "        c->row_ptr[bi] = ptr;\r\n\u001b[?2004l\r"]
[253.56383, "o", "\u001b[?2004h"]
[253.563855, "o", "> \r\n\u001b[?2004l\r"]
[253.563891, "o", "\u001b[?2004h"]
[253.56392, "o", "> "]
[253.564066, "o", "        for (int bj = 0; bj < nb; bj++) {\r\n\u001b[?2004l\r"]
[253.564103, "o", "\u001b[?2004h"]
[253.564129, "o", "> "]
[253.564454, "o", "            int col_blk = reorder ? a->perm[bj] : bj; // global block for this packed col\r\n\u001b[?2004l\r"]
[253.564489, "o", "\u001b[?2004h"]
[253.564515, "o", "> "]
[253.564601, "o", "            int has = 0;\r\n\u001b[?2004l\r"]
[253.564633, "o", "\u001b[?2004h"]
[253.564658, "o", "> \r\n\u001b[?2004l\r"]
[253.564683, "o", "\u001b[?2004h"]
[253.564708, "o", "> "]
[253.564869, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[253.564895, "o", "\u001b[?2004h"]
[253.564921, "o", "> "]
[253.565183, "o", "                for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r"]
[253.565216, "o", "\u001b[?2004h> "]
[253.565596, "o", "                    int gr = row_blk * bs + r;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.565689, "o", "                    int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r"]
[253.566383, "o", "\u001b[?2004h> "]
[253.566449, "o", "                    double v = a->a[gr * dim + gc];\r\n\u001b[?2004l\r\u001b[?2004h>                     if (fabs(v) > 0.0) {\r\n\u001b[?2004l\r\u001b[?2004h>                         has = 1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.56649, "o", "                    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[253.566518, "o", "> "]
[253.566598, "o", "                }\r\n\u001b[?2004l\r"]
[253.566632, "o", "\u001b[?2004h> "]
[253.566699, "o", "            }\r\n\u001b[?2004l\r"]
[253.566775, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[253.566873, "o", "> "]
[253.566965, "o", "            if (has) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.567574, "o", "                c->col_idx[ptr] = bj; // packed column index\r\n\u001b[?2004l\r\u001b[?2004h>                 for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.567758, "o", "                    for (int cc = 0; cc < bs; cc++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.567873, "o", "                        int gr = row_blk * bs + r;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.568124, "o", "                        int gc = col_blk * bs + cc;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.568329, "o", "                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n\u001b[?2004l\r\u001b[?2004h"]
[253.568602, "o", ">                     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.568881, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h>                 ptr++;\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[253.569083, "o", "\u001b[?2004h>     c->row_ptr[nb] = ptr;\r\n\u001b[?2004l\r"]
[253.569409, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.569703, "o", "    // Jacobi preconditioner diagonal inverse in *packed scalar coordinates*.\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.569747, "o", "        c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.569775, "o", "    }"]
[253.569954, "o", "\r\n\u001b[?2004l\r"]
[253.570092, "o", "\u001b[?2004h> "]
[253.570176, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[253.570258, "o", "\u001b[?2004h> "]
[253.57043, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r"]
[253.570545, "o", "\u001b[?2004h> "]
[253.570713, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[253.570898, "o", "\u001b[?2004h> "]
[253.571016, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[253.571063, "o", "> "]
[253.571172, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[253.571205, "o", "\u001b[?2004h"]
[253.571309, "o", "> "]
[253.57152, "o", "                for (int r = 0; r < bs; r++) {\r\n"]
[253.571607, "o", "\u001b[?2004l\r"]
[253.57171, "o", "\u001b[?2004h"]
[253.571802, "o", "> "]
[253.572081, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n"]
[253.572223, "o", "\u001b[?2004l\r"]
[253.572318, "o", "\u001b[?2004h"]
[253.572392, "o", "> "]
[253.572594, "o", "                    if (fabs(d) > 1e-14) {\r\n"]
[253.572693, "o", "\u001b[?2004l\r"]
[253.5728, "o", "\u001b[?2004h"]
[253.57289, "o", "> "]
[253.573136, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n"]
[253.573255, "o", "\u001b[?2004l\r"]
[253.573329, "o", "\u001b[?2004h> "]
[253.573495, "o", "                    }\r\n\u001b[?2004l\r"]
[253.573611, "o", "\u001b[?2004h"]
[253.573676, "o", "> "]
[253.573832, "o", "                }\r\n\u001b[?2004l\r"]
[253.573973, "o", "\u001b[?2004h>             }\r\n\u001b[?2004l\r"]
[253.574048, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.574074, "o", "    }\r\n\u001b[?2004l\r"]
[253.574102, "o", "\u001b[?2004h"]
[253.574126, "o", "> "]
[253.574151, "o", "}\r\n"]
[253.574346, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.574562, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[253.574638, "o", "\u001b[?2004h> "]
[253.574835, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.574954, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r"]
[253.575054, "o", "\u001b[?2004h> "]
[253.575148, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r"]
[253.575217, "o", "\u001b[?2004h> "]
[253.575293, "o", "\r\n\u001b[?2004l\r"]
[253.575388, "o", "\u001b[?2004h"]
[253.575481, "o", "> "]
[253.575567, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[253.575693, "o", "\u001b[?2004h"]
[253.575746, "o", ">         y[i] = 0.0;\r\n\u001b[?2004l\r"]
[253.575915, "o", "\u001b[?2004h"]
[253.575955, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.576082, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
