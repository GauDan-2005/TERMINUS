[215.941913, "o", "sed -n '1,260p' /app/include/case_spec.h"]
[215.943252, "o", "\r\n"]
[215.943545, "o", "\u001b[?2004l\r"]
[215.945716, "o", "#pragma once\r\n\r\n#include <stddef.h>\r\n\r\n#define MAX_BLOCKS 8\r\n#define MAX_BS 4\r\n"]
[215.945777, "o", "#define MAX_NNZ_BLOCKS 64\r\n#define CASE_NAME_LEN 32\r\n\r\ntypedef struct {\r\n    int rb;\r\n    int cb;\r\n    double vals[MAX_BS * MAX_BS];\r\n} BlockEntry;\r\n\r\ntypedef struct {\r\n    char name[CASE_NAME_LEN];\r\n"]
[215.945803, "o", "    int nblocks;\r\n    int bs;\r\n    int reorder;\r\n    int perm[MAX_BLOCKS];\r\n    int block_count;\r\n    BlockEntry blocks[MAX_NNZ_BLOCKS];\r\n    double rhs[MAX_BLOCKS * MAX_BS];\r\n} CaseSpec;\r\n\r\n"]
[215.945826, "o", "int case_load(const char *path, CaseSpec *spec);\r\n"]
