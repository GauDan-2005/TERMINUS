[253.198335, "o", "\r\n\u001b[?2004l\r"]
[253.199732, "o", "#include \"../include/matrix_view.h\"\r\n"]
[253.19989, "o", "\r\n"]
[253.200054, "o", "#include <string.h>\r\n\r\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\r\n    (void)b;\r\n    (void)c;\r\n    (void)d;\r\n    memcpy(e, a, (size_t)c * sizeof(double));\r\n}\r\n"]
[253.200227, "o", "\u001b[?2004h"]
[253.200316, "o", "root@608af32c58d9:/app# "]
[253.313232, "i", "sed -n '1,260p' /app/bsr_n/layout.cpp\n"]
[253.3139, "o", "sed -n '1,260p' /app/bsr_n/layout.cpp\r\n\u001b[?2004l\r"]
[253.315176, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n#include <string.h>\r\n\r\nvoid fn_n(const MatrixView *a, int reorder, BsrPack *c) {\r\n    int nb = a->nblocks;\r\n    int bs = a->bs;\r\n    int dim = a->n;\r\n    int ptr = 0;\r\n    memset(c, 0, sizeof(*c));\r\n    c->n = dim;\r\n    c->bs = bs;\r\n    c->nblocks = nb;\r\n    c->reorder = reorder;\r\n    for (int i = 0; i < nb; i++) {\r\n        c->perm[i] = a->perm[i];\r\n    }\r\n    for (int bi = 0; bi < nb; bi++) {\r\n        int row_blk = reorder ? a->perm[bi] : bi;\r\n        c->row_ptr[bi] = ptr;\r\n        for (int bj = 0; bj < nb; bj++) {\r\n            int col_blk = reorder ? ((bj + 1) % nb) : bj;\r\n            int has = 0;\r\n            for (int r = 0; r < bs; r++) {\r\n                for (int cc = 0; cc < bs; cc++) {\r\n                    int gr = row_blk * bs + r;\r\n                    int gc = col_blk * bs + cc;\r\n                    double v = a->a[gr * dim + gc];\r\n                    if (fabs(v) > 0.0) {\r\n                        has = 1;\r\n                    }\r\n                }\r\n            }\r\n            if (has) {\r\n                c->col_idx[ptr] = col_blk;\r\n                for (int r = 0; r < bs; r++) {\r\n                    for (int cc = 0; cc < bs; cc++) {\r\n                        int gr = row_blk * bs + r;\r\n                        int gc = col_blk * bs + cc;\r\n                        c->data[ptr * bs * bs + r * bs + cc] = a->a[gr * dim + gc];\r\n                    }\r\n                }\r\n                ptr++;\r\n            }\r\n        }\r\n    }\r\n    c->row_ptr[nb] = ptr;\r\n    for (int i = 0; i < dim; i++) {\r\n        c->diag_inv[i] = 1.0;\r\n    }\r\n    for (int bi = 0; bi < nb; bi++) {\r\n"]
[253.315506, "o", "        int start = c->row_ptr[bi];\r\n        int end = c->row_ptr[bi + 1];\r\n        for (int k = start; k < end; k++) {\r\n            if (c->col_idx[k] == bi) {\r\n                for (int r = 0; r < bs; r++) {\r\n                    double d = c->data[k * bs * bs + r * bs + r];\r\n                    if (fabs(d) > 1e-14) {\r\n                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n                    }\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\nvoid bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n    int nb = pack->nblocks;\r\n    int bs = pack->bs;\r\n    int dim = pack->n;\r\n    for (int i = 0; i < dim; i++) {\r\n        y[i] = 0.0;\r\n    }\r\n    for (int bi = 0; bi < nb; bi++) {\r\n        int start = pack->row_ptr[bi];\r\n        int end = pack->row_ptr[bi + 1];\r\n        for (int k = start; k < end; k++) {\r\n            int bj = pack->col_idx[k];\r\n            for (int r = 0; r < bs; r++) {\r\n                for (int c = 0; c < bs; c++) {\r\n                    int gi = bi * bs + r;\r\n                    int gj = bj * bs + c;\r\n                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n"]
[253.315768, "o", "\u001b[?2004hroot@608af32c58d9:/app# "]
[253.437633, "i", "cat > /app/perm_p/order.cpp <<'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\n// Apply a block permutation to a scalar vector.\n//\n// b[] is a block permutation of length nb such that:\n//   packed block i corresponds to global block b[i].\n//\n// c is the scalar length n, d is the block size bs.\n//\n// If d > 0:\n//   this function maps global -> packed (used for RHS before solve)\n// If d < 0:\n//   this function maps packed -> global\n//\n// (The sign trick keeps the original signature while allowing both directions.)\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int bs = d < 0 ? -d : d;\n    if (!b || bs <= 0) {\n        memcpy(e, a, (size_t)c * sizeof(double));\n        return;\n    }\n    int nb = c / bs;\n\n    if (d > 0) {\n        // global -> packed\n        for (int bi = 0; bi < nb; bi++) {\n            int gbi = b[bi];\n            for (int r = 0; r < bs; r++) {\n                e[bi * bs + r] = a[gbi * bs + r];\n            }\n        }\n    } else {\n        // packed -> global\n        for (int bi = 0; bi < nb; bi++) {\n            int gbi = b[bi];\n            for (int r = 0; r < bs; r++) {\n                e[gbi * bs + r] = a[bi * bs + r];\n            }\n        }\n    }\n}\nEOF\n"]
[253.439653, "o", "cat > /app/perm_p/order.cpp <<'EOF'"]
