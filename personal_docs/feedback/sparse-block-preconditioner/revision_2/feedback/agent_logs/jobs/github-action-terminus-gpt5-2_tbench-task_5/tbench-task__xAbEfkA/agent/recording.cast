[189.392406, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n\r\ndouble norm_q(const double *a, int b) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < b; i++) {\r\n        s += a[i] * a[i];\r\n    }\r\n    return sqrt(s) + 1.0e-4;\r\n}\r\n"]
[189.392627, "o", "\u001b[?2004hroot@608af32c58d9:/app# "]
[189.519012, "i", "sed -n '1,320p' /app/solve_s/driver.cpp\n"]
