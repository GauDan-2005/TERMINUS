[292.559882, "o", "\u001b[?2004l\r"]
[292.561308, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n\r\ndouble norm_q(const double *a, int b) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < b; i++) {\r\n        s += a[i] * a[i];\r\n    }\r\n    return sqrt(s) + 1.0e-4;\r\n"]
[292.561401, "o", "}\r\n"]
[292.561603, "o", "\u001b[?2004hroot@608af32c58d9:/app# "]
[292.689941, "i", "sed -n '1,260p' /app/csr_m/assemble.cpp\n"]
[292.690312, "o", "sed -n '1,260p' /app/csr_m/assemble.cpp\r\n\u001b[?2004l\r"]
[292.691831, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid matrix_from_case(const CaseSpec *spec, MatrixView *view) {\r\n    int dim = spec->nblocks * spec->bs;\r\n    int i;\r\n    memset(view, 0, sizeof(*view));\r\n    view->n = dim;\r\n    view->bs = spec->bs;\r\n    view->nblocks = spec->nblocks;\r\n    view->reorder = spec->reorder;\r\n    for (i = 0; i < spec->nblocks; i++) {\r\n        view->perm[i] = spec->perm[i];\r\n    }\r\n"]
[292.691894, "o", "    for (i = 0; i < dim * dim; i++) {\r\n        view->a[i] = 0.0;\r\n    }\r\n    for (i = 0; i < spec->block_count; i++) {\r\n        const BlockEntry *be = &spec->blocks[i];\r\n        int rb = be->rb;\r\n        int cb = be->cb;\r\n        int r;\r\n        int c;\r\n        for (r = 0; r < spec->bs; r++) {\r\n            for (c = 0; c < spec->bs; c++) {\r\n                int gr = rb * spec->bs + r;\r\n                int gc = cb * spec->bs + c;\r\n                view->a[gr * dim + gc] = be->vals[r * spec->bs + c];\r\n            }\r\n        }\r\n    }\r\n    for (i = 0; i < dim; i++) {\r\n        view->b[i] = spec->rhs[i];\r\n    }\r\n}\r\n"]
[292.692136, "o", "\u001b[?2004hroot@608af32c58d9:/app# "]
[292.813736, "i", "grep -RIn \"void matrix_from_case\" -n /app | head\n"]
[292.814246, "o", "grep -RIn \"void matrix_from_case\" -n /app | head\r\n"]
[292.816259, "o", "\u001b[?2004l\r"]
[292.817415, "o", "/app/csr_m/assemble.cpp:5:void matrix_from_case(const CaseSpec *spec, MatrixView *view) {\r\n/app/drive_u/run.cpp:11:void matrix_from_case(const CaseSpec *spec, MatrixView *view);\r\n/app/include/matrix_view.h:29:void matrix_from_case(const CaseSpec *spec, MatrixView *view);\r\n"]
[292.817603, "o", "\u001b[?2004hroot@608af32c58d9:/app# "]
[293.814576, "i", "sed -n '1,260p' /app/src/case_io.cpp\n"]
[293.815138, "o", "sed -n '1,260p' /app/src/case_io.cpp\r\n\u001b[?2004l\r"]
[293.816771, "o", "#include \"../include/case_spec.h\"\r\n\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n\r\nstatic void trim(char *s) {\r\n    size_t n = strlen(s);\r\n    while (n > 0 && (s[n - 1] == '\\n' || s[n - 1] == '\\r' || s[n - 1] == ' ')) {\r\n        s[--n] = '\\0';\r\n"]
[293.816812, "o", "    }\r\n}\r\n\r\nint case_load(const char *path, CaseSpec *spec) {\r\n    FILE *fp = fopen(path, \"r\");\r\n    char line[512];\r\n    if (!fp) {\r\n        return -1;\r\n    }\r\n    memset(spec, 0, sizeof(*spec));\r\n    for (int i = 0; i < MAX_BLOCKS; i++) {\r\n        spec->perm[i] = i;\r\n"]
[293.816837, "o", "    }\r\n    while (fgets(line, sizeof(line), fp)) {\r\n        trim(line);\r\n        if (line[0] == '#' || line[0] == '\\0') {\r\n            continue;\r\n        }\r\n        if (strncmp(line, \"name \", 5) == 0) {\r\n"]
[293.816862, "o", "            strncpy(spec->name, line + 5, CASE_NAME_LEN - 1);\r\n        } else if (strncmp(line, \"nblocks \", 8) == 0) {\r\n            spec->nblocks = atoi(line + 8);\r\n        } else if (strncmp(line, \"bs \", 3) == 0) {\r\n            spec->bs = atoi(line + 3);\r\n        } else if (strncmp(line, \"reorder \", 8) == 0) {\r\n"]
