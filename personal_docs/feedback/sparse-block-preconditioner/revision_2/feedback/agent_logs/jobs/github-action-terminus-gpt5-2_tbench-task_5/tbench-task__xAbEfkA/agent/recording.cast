[253.576831, "o", "\r\n"]
[253.576871, "o", "\u001b[?2004l\r"]
[253.576933, "o", "\u001b[?2004h"]
[253.576983, "o", "> "]
[253.577019, "o", "\r\n"]
[253.577054, "o", "\u001b[?2004l\r"]
[253.577112, "o", "\u001b[?2004h"]
[253.577163, "o", "> "]
[253.577851, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r\u001b[?2004h>             int bj = pack->col_idx[k];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.577994, "o", "            int col_blk = pack->reorder ? pack->perm[bj] : bj; // global block\r\n\u001b[?2004l\r\u001b[?2004h"]
[253.578097, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.578273, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[253.578403, "o", "\u001b[?2004h> "]
[253.57861, "o", "                for (int c = 0; c < bs; c++) {"]
