[296.732, "o", "\u001b[?2004h> "]
[296.732058, "o", "double norm_q(const double *a, int b) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.732213, "o", "    double s = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.732343, "o", "    for (int i = 0; i < b; i++) {\r\n\u001b[?2004l\r"]
[296.732456, "o", "\u001b[?2004h> "]
[296.732592, "o", "        s += a[i] * a[i];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.732692, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.732889, "o", "    return sqrt(s);\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
