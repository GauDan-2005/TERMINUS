[253.578938, "o", "\u001b[?2004h> "]
[253.579173, "o", "                    int gi = row_blk * bs + r;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[253.579331, "o", "                    int gj = col_blk * bs + c;\r\n\u001b[?2004l\r"]
[253.579466, "o", "\u001b[?2004h> "]
[253.579632, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[253.579664, "o", "\u001b[?2004h> "]
[253.579751, "o", "                }"]
