[10.010851, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nNAME=\"${1:?case name required}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n\"${APP_ROOT}/bin/solverctl\" one \"${NAME}\"\r\n"]
[10.011131, "o", "\u001b[?2004hroot@71b188f79b25:/app# "]
[16.975018, "i", "cat /app/CMakeLists.txt\n"]
[16.9761, "o", "cat /app/CMakeLists.txt\r\n\u001b[?2004l\r"]
[16.976502, "o", "cmake_minimum_required(VERSION 3.16)\r\nproject(solverctl LANGUAGES CXX)\r\n\r\nset(CMAKE_CXX_STANDARD 17)\r\nset(CMAKE_CXX_STANDARD_REQUIRED ON)\r\n\r\nadd_executable(solverctl\r\n    src/main.cpp\r\n    src/case_io.cpp\r\n    csr_m/assemble.cpp\r\n    bsr_n/layout.cpp\r\n    perm_p/order.cpp\r\n    prec_r/apply.cpp\r\n    scale_q/metric.cpp\r\n    solve_s/driver.cpp\r\n    flow_t/report.cpp\r\n    drive_u/run.cpp\r\n    spill_v/bucket.cpp\r\n    mirror_w/trace.cpp\r\n)\r\n\r\ntarget_include_directories(solverctl PRIVATE include)\r\n\r\nset_target_properties(solverctl PROPERTIES\r\n    RUNTIME_OUTPUT_DIRECTORY \"${CMAKE_BINARY_DIR}/bin\"\r\n)\r\n"]
[16.977022, "o", "\u001b[?2004hroot@71b188f79b25:/app# "]
[17.106189, "i", "cat /app/include/case_spec.h\n"]
[17.106596, "o", "cat /app/include/case_spec.h\r\n\u001b[?2004l\r"]
[17.109783, "o", "#pragma once\r\n\r\n#include <stddef.h>\r\n\r\n#define MAX_BLOCKS 8\r\n#define MAX_BS 4\r\n#define MAX_NNZ_BLOCKS 64\r\n#define CASE_NAME_LEN 32\r\n\r\ntypedef struct {\r\n    int rb;\r\n    int cb;\r\n    double vals[MAX_BS * MAX_BS];\r\n} BlockEntry;\r\n\r\ntypedef struct {\r\n    char name[CASE_NAME_LEN];\r\n    int nblocks;\r\n    int bs;\r\n    int reorder;\r\n    int perm[MAX_BLOCKS];\r\n    int block_count;\r\n    BlockEntry blocks[MAX_NNZ_BLOCKS];\r\n    double rhs[MAX_BLOCKS * MAX_BS];\r\n} CaseSpec;\r\n\r\nint case_load(const char *path, CaseSpec *spec);\r\n\u001b[?2004hroot@71b188f79b25:/app# "]
[17.245998, "i", "cat /app/include/matrix_view.h\n"]
[17.246542, "o", "cat /app/include/matrix_view.h\r\n\u001b[?2004l\r"]
[17.247922, "o", "#pragma once\r\n\r\n#include \"case_spec.h\"\r\n\r\n#define MAX_DIM 32\r\n\r\ntypedef struct {\r\n    int n;\r\n    int bs;\r\n    int nblocks;\r\n    int reorder;\r\n    int perm[MAX_BLOCKS];\r\n    double a[MAX_DIM * MAX_DIM];\r\n    double b[MAX_DIM];\r\n} MatrixView;\r\n\r\ntypedef struct {\r\n    int n;\r\n    int bs;\r\n    int nblocks;\r\n    int reorder;\r\n    int perm[MAX_BLOCKS];\r\n    int row_ptr[MAX_BLOCKS + 1];\r\n    int col_idx[MAX_NNZ_BLOCKS];\r\n    double data[MAX_NNZ_BLOCKS * MAX_BS * MAX_BS];\r\n    double diag_inv[MAX_DIM];\r\n} BsrPack;\r\n\r\nvoid matrix_from_case(const CaseSpec *spec, MatrixView *view);\r\nvoid bsr_matvec(const BsrPack *pack, const double *x, double *y);\r\n"]
[17.248347, "o", "\u001b[?2004hroot@71b188f79b25:/app# "]
[17.377314, "i", "cat /app/include/solver_report.h\n"]
[17.377867, "o", "cat /app/include/solver_report.h"]
[17.378066, "o", "\r\n\u001b[?2004l\r"]
[17.379096, "o", "#pragma once\r\n\r\n#define MAX_CASES 8\r\n\r\ntypedef struct {\r\n    char name[32];\r\n    int ok;\r\n    int iterations;\r\n    double final_residual;\r\n    double reported_residual;\r\n    int residual_agrees;\r\n    int hit_limit;\r\n} SolveResult;\r\n\r\nint emit_t(const SolveResult *res, const char *audit_path);\r\nint emit_matrix(const SolveResult *cases, int count, const char *audit_path);\r\n\u001b[?2004hroot@71b188f79b25:/app# "]
[17.501994, "i", "cat /app/src/main.cpp\n"]
[17.502683, "o", "cat /app/src/main.cpp\r\n\u001b[?2004l\r"]
[17.505159, "o", "#include \"../include/case_spec.h\"\r\n#include \"../include/solver_report.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <sys/stat.h>\r\n\r\nint run_u(const CaseSpec *spec, const char *out_dir, SolveResult *out);\r\n\r\nstatic const char *CASES[] = {\"basalt\", \"flint\", \"shale\", \"garnet\", \"mica\", \"opal\", NULL};\r\n\r\nstatic int run_named(const char *name, const char *out_dir, SolveResult *res) {\r\n    char path[512];\r\n    CaseSpec spec;\r\n    snprintf(path, sizeof(path), \"/app/data/cases/%s.case\", name);\r\n    if (case_load(path, &spec) != 0) {\r\n        return -1;\r\n    }\r\n    return run_u(&spec, out_dir, res);\r\n}\r\n\r\nint main(int argc, char **argv) {\r\n    const char *out_dir = \"/app/output\";\r\n    mkdir(out_dir, 0755);\r\n    if (argc >= 2 && strcmp(argv[1], \"matrix\") == 0) {\r\n        SolveResult cases[6];\r\n        int n = 0;\r\n        for (int i = 0; CASES[i]; i++) {\r\n            if (run_named(CASES[i], out_dir, &cases[n]) != 0) {\r\n                return 1;\r\n            }\r\n            n++;\r\n        }\r\n        if (emit_matrix(cases, n, \"/app/output/solver-audit.json\") != 0) {\r\n            return 1;\r\n        }\r\n        return 0;\r\n    }\r\n    if (argc >= 3 && strcmp(argv[1], \"one\") == 0) {\r\n        SolveResult res;\r\n        char audit[512];\r\n"]
[17.50521, "o", "        if (run_named(argv[2], out_dir, &res) != 0) {\r\n            return 1;\r\n        }\r\n        snprintf(audit, sizeof(audit), \"/app/output/%s-audit.json\", argv[2]);\r\n        return emit_t(&res, audit) != 0;\r\n    }\r\n    fprintf(stderr, \"usage: solverctl matrix | solverctl one <case>\\n\");\r\n    return 1;\r\n}\r\n"]
[17.505488, "o", "\u001b[?2004h"]
