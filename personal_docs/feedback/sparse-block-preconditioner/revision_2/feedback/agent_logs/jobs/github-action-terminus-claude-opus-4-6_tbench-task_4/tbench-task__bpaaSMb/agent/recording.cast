[124.24819, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[124.24834, "o", "\u001b[?2004h> "]
[124.248386, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.248528, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[124.248575, "o", "\u001b[?2004h> "]
[124.248736, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[124.248773, "o", "\u001b[?2004h> "]
[124.248921, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[124.249008, "o", "\u001b[?2004h> "]
[124.249141, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[124.249178, "o", "\u001b[?2004h> "]
[124.24938, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[124.249414, "o", "\u001b[?2004h> "]
[124.249559, "o", "                    if (fabs(d) > 1e-14) {\r\n\u001b[?2004l\r"]
[124.249593, "o", "\u001b[?2004h> "]
[124.249816, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[124.24985, "o", "\u001b[?2004h> "]
[124.249946, "o", "                    }\r\n\u001b[?2004l\r"]
[124.249974, "o", "\u001b[?2004h"]
[124.249999, "o", "> "]
[124.250095, "o", "                }\r\n\u001b[?2004l\r"]
[124.250122, "o", "\u001b[?2004h"]
[124.250271, "o", ">             }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.250302, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.250399, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.250471, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.250578, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.250766, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[124.250856, "o", "\u001b[?2004h> "]
[124.250951, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.25106, "o", "> "]
[124.25119, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.251316, "o", "    int dim = pack->n;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.251405, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[124.251516, "o", "\u001b[?2004h> "]
[124.251569, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.251655, "o", "> "]
[124.251773, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.251857, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.251945, "o", "> "]
[124.252028, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[124.252139, "o", "\u001b[?2004h> "]
[124.252287, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r\u001b[?2004h"]
[124.252387, "o", "> "]
[124.252529, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.252678, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[124.252801, "o", "\u001b[?2004h> "]
[124.252878, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[124.252915, "o", "\u001b[?2004h> "]
[124.253096, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[124.253131, "o", "\u001b[?2004h> "]
[124.253303, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[124.253335, "o", "\u001b[?2004h> "]
[124.253509, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[124.253538, "o", "\u001b[?2004h> "]
[124.253792, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[124.253826, "o", "\u001b[?2004h> "]
[124.253925, "o", "                }"]
[124.25453, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[124.255518, "o", "\u001b[?2004hroot@71b188f79b25:/app# "]
[124.740842, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int nb = c / d;\n    for (int i = 0; i < nb; i++) {\n        for (int r = 0; r < d; r++) {\n            e[i * d + r] = a[b[i] * d + r];\n        }\n    }\n}\nEOF\n"]
[124.741547, "o", "cat > /app/perm_p/order.cpp << 'EOF'\r\n"]
[124.741674, "o", "\u001b[?2004l\r\u001b[?2004h> #include \"../include/matrix_view.h\""]
[124.742383, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void map_p(const double *a, const int *b, int c, int d, double *e) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[124.745228, "o", "    int nb = c / d;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < nb; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         for (int r = 0; r < d; r++) {\r\n\u001b[?2004l\r\u001b[?2004h>             e[i * d + r] = a[b[i] * d + r];\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@71b188f79b25:/app# "]
[125.249028, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        int blk = i / a->bs;\n        int loc = i % a->bs;\n        c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\n    }\n}\nEOF\n"]
[125.249453, "o", "cat > /app/prec_r/apply.cpp << 'EOF'"]
[125.250143, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.250484, "o", "#include \"../include/matrix_view.h\""]
[125.251972, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void step_r(const BsrPack *a, const double *b, double *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     int dim = a->n;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int blk = i / a->bs;\r\n\u001b[?2004l\r\u001b[?2004h>         int loc = i % a->bs;\r\n\u001b[?2004l\r\u001b[?2004h>         c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\r\n\u001b[?2004l\r"]
[125.252071, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.252235, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[125.253371, "o", "\u001b[?2004hroot@71b188f79b25:/app# "]
[125.744781, "i", "cat > /app/scale_q/metric.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <math.h>\n\ndouble norm_q(const double *a, int b) {\n    double s = 0.0;\n    for (int i = 0; i < b; i++) {\n        s += a[i] * a[i];\n    }\n    return sqrt(s);\n}\nEOF\n"]
