[137.176669, "o", "> "]
[137.176781, "o", "    for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.176873, "o", "        c->diag_inv[i] = 1.0;\r\n\u001b[?2004l\r"]
[137.176982, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.177098, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[137.177128, "o", "\u001b[?2004h> "]
[137.177242, "o", "        int start = c->row_ptr[bi];\r\n\u001b[?2004l\r"]
[137.177297, "o", "\u001b[?2004h> "]
[137.177443, "o", "        int end = c->row_ptr[bi + 1];\r\n\u001b[?2004l\r"]
[137.177486, "o", "\u001b[?2004h> "]
[137.177626, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[137.17771, "o", "\u001b[?2004h> "]
[137.177806, "o", "            if (c->col_idx[k] == bi) {\r\n\u001b[?2004l\r"]
[137.177886, "o", "\u001b[?2004h> "]
[137.17804, "o", "                for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[137.178067, "o", "\u001b[?2004h> "]
[137.178282, "o", "                    double d = c->data[k * bs * bs + r * bs + r];\r\n\u001b[?2004l\r"]
[137.178311, "o", "\u001b[?2004h"]
[137.178335, "o", "> "]
[137.178474, "o", "                    if (fabs(d) > 1e-15) {\r\n\u001b[?2004l\r"]
[137.178503, "o", "\u001b[?2004h> "]
[137.1787, "o", "                        c->diag_inv[bi * bs + r] = 1.0 / d;\r\n\u001b[?2004l\r"]
[137.178729, "o", "\u001b[?2004h> "]
[137.178837, "o", "                    }\r\n\u001b[?2004l\r"]
[137.178869, "o", "\u001b[?2004h> "]
[137.178939, "o", "                }\r\n\u001b[?2004l\r"]
[137.179033, "o", "\u001b[?2004h> "]
[137.179174, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.179255, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n"]
[137.179292, "o", "\u001b[?2004l\r\u001b[?2004h"]
[137.179399, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.179569, "o", "void bsr_matvec(const BsrPack *pack, const double *x, double *y) {\r\n\u001b[?2004l\r"]
[137.179679, "o", "\u001b[?2004h> "]
[137.179787, "o", "    int nb = pack->nblocks;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.179903, "o", "    int bs = pack->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.180004, "o", "    for (int i = 0; i < pack->n; i++) {\r\n\u001b[?2004l\r"]
[137.180113, "o", "\u001b[?2004h> "]
[137.180192, "o", "        y[i] = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[137.180265, "o", "\u001b[?2004h> "]
[137.180381, "o", "    for (int bi = 0; bi < nb; bi++) {\r\n\u001b[?2004l\r"]
[137.180465, "o", "\u001b[?2004h> "]
[137.180579, "o", "        int start = pack->row_ptr[bi];\r\n\u001b[?2004l\r"]
[137.180605, "o", "\u001b[?2004h> "]
[137.180782, "o", "        int end = pack->row_ptr[bi + 1];\r\n\u001b[?2004l\r\u001b[?2004h"]
[137.180805, "o", "> "]
[137.180952, "o", "        for (int k = start; k < end; k++) {\r\n\u001b[?2004l\r"]
[137.18098, "o", "\u001b[?2004h> "]
[137.18116, "o", "            int bj = pack->col_idx[k];\r\n\u001b[?2004l\r"]
[137.18119, "o", "\u001b[?2004h> "]
[137.18134, "o", "            for (int r = 0; r < bs; r++) {\r\n\u001b[?2004l\r"]
[137.181368, "o", "\u001b[?2004h> "]
[137.181539, "o", "                for (int c = 0; c < bs; c++) {\r\n\u001b[?2004l\r"]
[137.181563, "o", "\u001b[?2004h> "]
[137.18172, "o", "                    int gi = bi * bs + r;\r\n\u001b[?2004l\r"]
[137.181744, "o", "\u001b[?2004h> "]
[137.181902, "o", "                    int gj = bj * bs + c;\r\n\u001b[?2004l\r"]
[137.181926, "o", "\u001b[?2004h"]
[137.181942, "o", "> "]
[137.18218, "o", "                    y[gi] += pack->data[k * bs * bs + r * bs + c] * x[gj];\r\n\u001b[?2004l\r"]
[137.182204, "o", "\u001b[?2004h> "]
[137.182304, "o", "                }\r\n\u001b[?2004l\r"]
[137.182423, "o", "\u001b[?2004h> "]
[137.182512, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.182625, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[137.182744, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[137.183569, "o", "\u001b[?2004hroot@fa90d47eedde:/app# "]
[137.467018, "i", "cat > /app/prec_r/apply.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\nvoid step_r(const BsrPack *a, const double *b, double *c) {\n    int dim = a->n;\n    for (int i = 0; i < dim; i++) {\n        int blk = i / a->bs;\n        int loc = i % a->bs;\n        c[i] = a->diag_inv[blk * a->bs + loc] * b[i];\n    }\n}\nEOF\n"]
[137.46745, "o", "cat > /app/prec_r/apply.cpp << 'EOF'\r\n\u001b[?2004l\r"]
[137.467505, "o", "\u001b[?2004h> "]
[137.467655, "o", "#include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r"]
[137.468007, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[137.468084, "o", "\u001b[?2004h> "]
[137.468606, "o", "void step_r(const BsrPack *a, const double *b, double *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     int dim = a->n;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < dim; i++) {\r\n\u001b[?2004l\r"]
[137.468771, "o", "\u001b[?2004h> "]
[137.468836, "o", "        int blk = i / a->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.468948, "o", "        int loc = i % a->bs;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.469293, "o", "        c[i] = a->diag_inv[blk * a->bs + loc] * b[i];"]
[137.470332, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.470384, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[137.470771, "o", "\u001b[?2004hroot@fa90d47eedde:/app# "]
[137.775754, "i", "cat > /app/scale_q/metric.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <math.h>\n\ndouble norm_q(const double *a, int b) {\n    double s = 0.0;\n    for (int i = 0; i < b; i++) {\n        s += a[i] * a[i];\n    }\n    return sqrt(s);\n}\nEOF\n"]
[137.776096, "o", "cat > /app/scale_q/metric.cpp << 'EOF'\r\n\u001b[?2004l\r"]
[137.776198, "o", "\u001b[?2004h"]
[137.776362, "o", "> "]
[137.776944, "o", "#include \"../include/matrix_view.h\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[137.777107, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> #include <math.h>\r\n\u001b[?2004l\r"]
[137.777294, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.777412, "o", "double norm_q(const double *a, int b) {\r\n\u001b[?2004l\r\u001b[?2004h>     double s = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[137.777498, "o", "> "]
[137.77758, "o", "    for (int i = 0; i < b; i++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.777673, "o", "        s += a[i] * a[i];\r\n\u001b[?2004l\r"]
[137.777794, "o", "\u001b[?2004h> "]
[137.777895, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>     return sqrt(s);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[137.777993, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[137.779502, "o", "\u001b[?2004hroot@fa90d47eedde:/app# "]
[138.075224, "i", "cat > /app/perm_p/order.cpp << 'EOF'\n#include \"../include/matrix_view.h\"\n\n#include <string.h>\n\nvoid map_p(const double *a, const int *b, int c, int d, double *e) {\n    int nblocks = c / d;\n    for (int bi = 0; bi < nblocks; bi++) {\n        int orig_blk = b[bi];\n        for (int r = 0; r < d; r++) {\n            e[bi * d + r] = a[orig_blk * d + r];\n        }\n    }\n}\nEOF\n"]
