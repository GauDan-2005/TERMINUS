[166.4341, "o", "{\r\n  \"cases\": [\r\n    {\r\n      \"name\": \"basalt\",\r\n      \"ok\": false,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0.0001,\r\n      \"residual_agrees\": false,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"flint\",\r\n      \"ok\": false,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0.0001,\r\n      \"residual_agrees\": false,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"shale\",\r\n      \"ok\": false,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0.0001,\r\n      \"residual_agrees\": false,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"garnet\",\r\n      \"ok\": false,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0.0001,\r\n      \"residual_agrees\": false,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"mica\",\r\n      \"ok\": false,\r\n      \"iterations\": 1,\r\n      \"final_residual\": 0,\r\n      \"reported_residual\": 0.0001,\r\n      \"residual_agrees\": false,\r\n      \"hit_limit\": false\r\n    },\r\n    {\r\n      \"name\": \"opal\",\r\n      \"ok\": false,\r\n"]
[166.434238, "o", "\u001b[?2004hroot@dcbc4436cd95:/app# "]
[166.552291, "i", "sed -n '1,200p' /app/src/main.cpp\n"]
[166.552668, "o", "sed -n '1,200p' /app/src/main.cpp\r\n"]
[166.552708, "o", "\u001b[?2004l\r"]
[166.554317, "o", "#include \"../include/case_spec.h\"\r\n#include \"../include/solver_report.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n#include <sys/stat.h>\r\n\r\nint run_u(const CaseSpec *spec, const char *out_dir, SolveResult *out);\r\n\r\nstatic const char *CASES[] = {\"basalt\", \"flint\", \"shale\", \"garnet\", \"mica\", \"opal\", NULL};\r\n\r\nstatic int run_named(const char *name, const char *out_dir, SolveResult *res) {\r\n    char path[512];\r\n    CaseSpec spec;\r\n    snprintf(path, sizeof(path), \"/app/data/cases/%s.case\", name);\r\n    if (case_load(path, &spec) != 0) {\r\n        return -1;\r\n    }\r\n    return run_u(&spec, out_dir, res);\r\n}\r\n\r\nint main(int argc, char **argv) {\r\n    const char *out_dir = \"/app/output\";\r\n    mkdir(out_dir, 0755);\r\n    if (argc >= 2 && strcmp(argv[1], \"matrix\") == 0) {\r\n        SolveResult cases[6];\r\n        int n = 0;\r\n        for (int i = 0; CASES[i]; i++) {\r\n            if (run_named(CASES[i], out_dir, &cases[n]) != 0) {\r\n                return 1;\r\n            }\r\n            n++;\r\n        }\r\n        if (emit_matrix(cases, n, \"/app/output/solver-audit.json\") != 0) {\r\n            return 1;\r\n        }\r\n        return 0;\r\n    }\r\n    if (argc >= 3 && strcmp(argv[1], \"one\") == 0) {\r\n        SolveResult res;\r\n        char audit[512];\r\n        if (run_named(argv[2], out_dir, &res) != 0) {\r\n            return 1;\r\n        }\r\n        snprintf(audit, sizeof(audit), \"/app/output/%s-audit.json\", argv[2]);\r\n        return emit_t(&res, audit) != 0;\r\n    }\r\n    fprintf(stderr, \"usage: solverctl matrix | solverctl one <case>\\n\");\r\n    return 1;\r\n}\r\n\u001b[?2004h"]
[166.554358, "o", "root@dcbc4436cd95:/app# "]
[166.66794, "i", "sed -n '1,240p' /app/flow_t/report.cpp\n"]
[166.668234, "o", "sed -n '1,240p' /app/flow_t/report.cpp"]
[166.668548, "o", "\r\n\u001b[?2004l\r"]
[166.670124, "o", "#include \"../include/solver_report.h\"\r\n"]
[166.67029, "o", "\r\n"]
[166.670421, "o", "#include <stdio.h>\r\n"]
[166.670629, "o", "\r\n"]
[166.670814, "o", "static void esc(FILE *fp, const char *s) {\r\n    fputc('\"', fp);\r\n    for (const char *p = s; *p; p++) {\r\n        if (*p == '\"' || *p == '\\\\') {\r\n            fputc('\\\\', fp);\r\n        }\r\n        fputc(*p, fp);\r\n    }\r\n    fputc('\"', fp);\r\n}\r\n"]
[166.670851, "o", "\r\nstatic void write_case(FILE *fp, const SolveResult *res, int last) {\r\n    fprintf(fp, \"    {\\n      \\\"name\\\": \");\r\n    esc(fp, res->name);\r\n    fprintf(fp, \",\\n      \\\"ok\\\": %s,\\n\", res->ok ? \"true\" : \"false\");\r\n    fprintf(fp, \"      \\\"iterations\\\": %d,\\n\", res->iterations);\r\n    fprintf(fp, \"      \\\"final_residual\\\": %.17g,\\n\", res->final_residual);\r\n    fprintf(fp, \"      \\\"reported_residual\\\": %.17g,\\n\", res->reported_residual);\r\n    fprintf(fp, \"      \\\"residual_agrees\\\": %s,\\n\", res->residual_agrees ? \"true\" : \"false\");\r\n    fprintf(fp, \"      \\\"hit_limit\\\": %s\\n    }\", res->hit_limit ? \"true\" : \"false\");\r\n    if (!last) {\r\n"]
[166.67087, "o", "        fprintf(fp, \",\");\r\n    }\r\n    fprintf(fp, \"\\n\");\r\n}\r\n\r\nint emit_t(const SolveResult *res, const char *audit_path) {\r\n    FILE *fp = fopen(audit_path, \"w\");\r\n"]
[166.670889, "o", "    if (!fp) {\r\n        return -1;\r\n    }\r\n    fprintf(fp, \"{\\n  \\\"cases\\\": [\\n\");\r\n    write_case(fp, res, 1);\r\n    fprintf(fp, \"  ]\\n}\\n\");\r\n"]
[166.670908, "o", "    fclose(fp);\r\n    return 0;\r\n}\r\n\r\nint emit_matrix(const SolveResult *cases, int count, const char *audit_path) {\r\n    FILE *fp = fopen(audit_path, \"w\");\r\n"]
[166.670929, "o", "    if (!fp) {\r\n        return -1;\r\n    }\r\n    fprintf(fp, \"{\\n  \\\"cases\\\": [\\n\");\r\n    for (int i = 0; i < count; i++) {\r\n        write_case(fp, &cases[i], i + 1 == count);\r\n"]
[166.670958, "o", "    }\r\n    fprintf(fp, \"  ]\\n}\\n\");\r\n    fclose(fp);\r\n    return 0;\r\n}\r\n"]
[166.671203, "o", "\u001b[?2004hroot@dcbc4436cd95:/app# "]
[166.787632, "i", "python3 - <<'PY'\nimport json,sys,os\np='/app/output/solver-audit.json'\nif not os.path.exists(p):\n    print('missing',p); sys.exit(0)\ntry:\n    data=json.load(open(p))\nexcept Exception as e:\n    print('json parse error',e); sys.exit(0)\nprint('keys',sorted(data.keys()))\ncases=data.get('cases',[])\nprint('cases',len(cases))\nfor c in cases:\n    print(c.get('name'),c.get('ok'),c.get('iterations'),c.get('final_residual'),c.get('reported_residual'),c.get('residual_agrees'),c.get('hit_limit'))\nPY\n"]
