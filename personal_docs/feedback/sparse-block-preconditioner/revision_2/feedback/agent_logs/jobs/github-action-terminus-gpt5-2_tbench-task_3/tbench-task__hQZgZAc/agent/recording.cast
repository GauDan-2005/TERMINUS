[175.630136, "o", "sed -n '1,220p' /app/include/solver_report.h\r\n\u001b[?2004l\r"]
[175.630777, "o", "#pragma once\r\n\r\n#define MAX_CASES 8\r\n\r\ntypedef struct {\r\n    char name[32];\r\n    int ok;\r\n    int iterations;\r\n    double final_residual;\r\n    double reported_residual;\r\n    int residual_agrees;\r\n    int hit_limit;\r\n} SolveResult;\r\n\r\nint emit_t(const SolveResult *res, const char *audit_path);\r\nint emit_matrix(const SolveResult *cases, int count, const char *audit_path);\r\n"]
[175.630972, "o", "\u001b[?2004hroot@dcbc4436cd95:/app# "]
[175.744168, "i", "sed -n '1,260p' /app/drive_u/run.cpp\n"]
[175.744786, "o", "sed -n '1,260p' /app/drive_u/run.cpp"]
[175.74492, "o", "\r\n\u001b[?2004l\r"]
[175.745945, "o", "#include \"../include/case_spec.h\"\r\n#include \"../include/matrix_view.h\"\r\n#include \"../include/solver_report.h\"\r\n\r\n#include <math.h>\r\n#include <string.h>\r\n\r\nvoid fn_n(const MatrixView *a, int reorder, BsrPack *c);\r\nvoid map_p(const double *a, const int *b, int c, int d, double *e);\r\ndouble norm_q(const double *a, int b);\r\n"]
[175.746123, "o", "void matrix_from_case(const CaseSpec *spec, MatrixView *view);\r\nint pcg_solve(const BsrPack *pack, const double *rhs, double *x, int *iters, double *final_res);\r\n\r\nstatic double l2_norm(const double *v, int n) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < n; i++) {\r\n        s += v[i] * v[i];\r\n    }\r\n    return sqrt(s);\r\n}\r\n\r\nint run_u(const CaseSpec *spec, const char *out_dir, SolveResult *out) {\r\n    MatrixView view;\r\n    BsrPack pack;\r\n    double rhs[MAX_DIM];\r\n    double x[MAX_DIM];\r\n"]
[175.746284, "o", "    double r[MAX_DIM];\r\n    double true_res;\r\n    double rep_res;\r\n    int hit;\r\n    int iters;\r\n\r\n    (void)out_dir;\r\n    matrix_from_case(spec, &view);\r\n    fn_n(&view, view.reorder, &pack);\r\n    map_p(view.b, view.perm, view.n, view.bs, rhs);\r\n    hit = pcg_solve(&pack, rhs, x, &iters, &true_res);\r\n    bsr_matvec(&pack, x, r);\r\n    for (int i = 0; i < view.n; i++) {\r\n        r[i] = rhs[i] - r[i];\r\n    }\r\n    true_res = l2_norm(r, view.n);\r\n    rep_res = norm_q(r, view.n);\r\n    strncpy(out->name, spec->name, sizeof(out->name) - 1);\r\n    out->iterations = iters;\r\n    out->final_residual = true_res;\r\n    out->reported_residual = rep_res;\r\n    out->hit_limit = hit;\r\n    out->residual_agrees = fabs(rep_res - true_res) <= 1e-6 * (1.0 + true_res);\r\n    out->ok = (!hit) && (true_res < 1e-8) && out->residual_agrees;\r\n    return 0;\r\n}\r\n"]
[175.746319, "o", "\u001b[?2004hroot@dcbc4436cd95:/app# "]
[175.868233, "i", "sed -n '1,320p' /app/solve_s/driver.cpp\n"]
[175.868805, "o", "sed -n '1,320p' /app/solve_s/driver.cpp\r\n\u001b[?2004l\r"]
[175.870653, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n#include <string.h>\r\n\r\nstatic double l2_norm(const double *v, int n) {\r\n    double s = 0.0;\r\n"]
[175.871029, "o", "    for (int i = 0; i < n; i++) {\r\n        s += v[i] * v[i];\r\n    }\r\n    return sqrt(s);\r\n}\r\n\r\nvoid step_r(const BsrPack *a, const double *b, double *c);\r\n\r\nint pcg_solve(const BsrPack *pack, const double *rhs, double *x, int *iters, double *final_res) {\r\n    const int n = pack->n;\r\n    const int max_iter = 200;\r\n    const double tol = 1e-9;\r\n    double r[MAX_DIM];\r\n    double z[MAX_DIM];\r\n    double p[MAX_DIM];\r\n    double ap[MAX_DIM];\r\n    double rz_old;\r\n    double alpha;\r\n    double beta;\r\n    double rs;\r\n    int k;\r\n\r\n    for (int i = 0; i < n; i++) {\r\n        x[i] = 0.0;\r\n    }\r\n    bsr_matvec(pack, x, r);\r\n    for (int i = 0; i < n; i++) {\r\n        r[i] = rhs[i] - r[i];\r\n    }\r\n    rs = l2_norm(r, n);\r\n    if (rs < tol) {\r\n        *iters = 0;\r\n        *final_res = rs;\r\n        return 0;\r\n    }\r\n    step_r(pack, r, z);\r\n    memcpy(p, z, (size_t)n * sizeof(double));\r\n    rz_old = 0.0;\r\n    for (int i = 0; i < n; i++) {\r\n        rz_old += r[i] * z[i];\r\n    }\r\n    for (k = 1; k <= max_iter; k++) {\r\n        bsr_matvec(pack, p, ap);\r\n        alpha = rz_old;\r\n        double denom = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n            denom += p[i] * ap[i];\r\n        }\r\n        if (fabs(denom) < 1e-30) {\r\n            break;\r\n        }\r\n        alpha /= denom;\r\n        for (int i = 0; i < n; i++) {\r\n            x[i] += alpha * p[i];\r\n            r[i] -= alpha * ap[i];\r\n        }\r\n        rs = l2_norm(r, n);\r\n        if (rs < tol) {\r\n            *iters = k;\r\n            *final_res = rs;\r\n            return 0;\r\n        }\r\n        step_r(pack, r, z);\r\n        beta = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n            beta += r[i] * z[i];\r\n        }\r\n        beta /= rz_old;\r\n        for (int i = 0; i < n; i++) {\r\n            p[i] = z[i] + beta * p[i];\r\n        }\r\n        rz_old = 0.0;\r\n        for (int i = 0; i < n; i++) {\r\n            rz_old += r[i] * z[i];\r\n        }\r\n    }\r\n    *iters = max_iter;\r\n    *final_res = rs;\r\n    return 1;\r\n}\r\n"]
[175.871171, "o", "\u001b[?2004hroot@dcbc4436cd95:/app# "]
[175.987814, "i", "sed -n '1,260p' /app/scale_q/metric.cpp\n"]
[175.988466, "o", "sed -n '1,260p' /app/scale_q/metric.cpp\r\n\u001b[?2004l\r"]
[175.991591, "o", "#include \"../include/matrix_view.h\"\r\n\r\n#include <math.h>\r\n\r\ndouble norm_q(const double *a, int b) {\r\n    double s = 0.0;\r\n    for (int i = 0; i < b; i++) {\r\n        s += a[i] * a[i];\r\n    }\r\n    return sqrt(s) + 1.0e-4;\r\n"]
[175.991632, "o", "}\r\n"]
[175.99182, "o", "\u001b[?2004h"]
