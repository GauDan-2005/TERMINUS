[149.821041, "o", "#include <stdio.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[149.821071, "o", "\u001b[?2004h> "]
[149.821224, "o", "int emit_p(const SimState *a, const char *b) {\r\n\u001b[?2004l\r"]
[149.821291, "o", "\u001b[?2004h> "]
[149.821434, "o", "    if (!a || !b) return -1;\r\n\u001b[?2004l\r"]
[149.821485, "o", "\u001b[?2004h> "]
[149.82166, "o", "    FILE *fp = fopen(b, \"wb\");\r\n\u001b[?2004l\r"]
[149.821696, "o", "\u001b[?2004h> "]
[149.821822, "o", "    if (!fp) return -2;\r\n\u001b[?2004l\r"]
[149.821842, "o", "\u001b[?2004h> "]
[149.821958, "o", "    VaultHeader hdr;\r\n\u001b[?2004l\r"]
[149.821982, "o", "\u001b[?2004h"]
[149.822003, "o", "> "]
[149.82213, "o", "    hdr.magic = VAULT_MAGIC;\r\n\u001b[?2004l\r"]
[149.822151, "o", "\u001b[?2004h"]
[149.822169, "o", "> "]
[149.822334, "o", "    hdr.version = VAULT_VERSION;\r\n\u001b[?2004l\r\u001b[?2004h"]
[149.822375, "o", "> "]
[149.822508, "o", "    hdr.fingerprint = a->fingerprint_payload;\r\n\u001b[?2004l\r"]
[149.822534, "o", "\u001b[?2004h> "]
[149.822698, "o", "    hdr.build_stamp = (uint64_t)BUILD_STAMP;\r\n\u001b[?2004l\r"]
[149.82273, "o", "\u001b[?2004h"]
[149.822753, "o", "> "]
[149.822886, "o", "    fwrite(&hdr, sizeof(hdr), 1, fp);\r\n\u001b[?2004l\r"]
[149.822909, "o", "\u001b[?2004h> "]
[149.82303, "o", "    int n_cells = a->grid.n;\r\n\u001b[?2004l\r"]
[149.823054, "o", "\u001b[?2004h"]
[149.823295, "o", "> "]
[149.82594, "o", "    fwrite(&n_cells, sizeof(int), 1, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     fwrite(a->grid.cells, sizeof(CellView), n_cells, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     /* Save FluxBank state */\r\n\u001b[?2004l\r\u001b[?2004h>     fwrite(&a->bank.n_pending, sizeof(int), 1, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     if (a->bank.n_pending > 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         fwrite(a->bank.leaf, sizeof(int), a->bank.n_pending, fp);\r\n\u001b[?2004l\r\u001b[?2004h>         fwrite(a->bank.flux, sizeof(double), a->bank.n_pending * NVAR, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     fclose(fp);\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@87f509269b26:/app# "]
[149.928606, "i", "cat > /app/rsm_k/resume.cpp << 'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n#include <string.h>\n\nint load_k(const char *a, SimState *b, VaultAudit *c) {\n    if (!a || !b || !c) return -1;\n    memset(c, 0, sizeof(*c));\n    FILE *in = fopen(a, \"rb\");\n    if (!in) {\n        c->reason = REASON_MISSING;\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\n        return -2;\n    }\n    VaultHeader hdr;\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\n        return -3;\n    }\n    if (hdr.magic != VAULT_MAGIC) {\n        fclose(in);\n        c->reason = REASON_MAGIC;\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\n        return -4;\n    }\n    if (hdr.fingerprint != b->fingerprint_payload) {\n        fclose(in);\n        c->reason = REASON_FINGERPRINT;\n        snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\n        return -5;\n    }\n    int n_cells = 0;\n    fread(&n_cells, sizeof(int), 1, in);\n    b->grid.n = n_cells;\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\n    /* Restore FluxBank state */\n    int np = 0;\n    if (fread(&np, sizeof(int), 1, in) == 1 && np > 0 && np <= MAX_FACES) {\n        b->bank.n_pending = np;\n        fread(b->bank.leaf, sizeof(int), np, in);\n        fread(b->bank.flux, sizeof(double), np * NVAR, in);\n    } else {\n        b->bank.n_pending = 0;\n    }\n    memset(&b->topo, 0, sizeof(b->topo));\n    fclose(in);\n    c->reason = REASON_OK;\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\n    return 0;\n}\nEOF\n"]
