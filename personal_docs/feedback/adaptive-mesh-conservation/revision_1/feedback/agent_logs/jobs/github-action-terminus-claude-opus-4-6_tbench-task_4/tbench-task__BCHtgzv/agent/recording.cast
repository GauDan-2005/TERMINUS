[76.347839, "i", "cat /app/srl_p/serial.cpp\n"]
[76.348074, "o", "cat /app/srl_p/serial.cpp\r\n\u001b[?2004l\r"]
[76.348979, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdio.h>\r\n\r\nint emit_p(const SimState *a, const char *b) {\r\n    if (!a || !b) return -1;\r\n    FILE *fp = fopen(b, \"wb\");\r\n    if (!fp) return -2;\r\n    VaultHeader hdr;\r\n    hdr.magic = VAULT_MAGIC;\r\n    hdr.version = VAULT_VERSION;\r\n    hdr.fingerprint = a->fingerprint_payload;\r\n    hdr.build_stamp = (uint64_t)BUILD_STAMP;\r\n    fwrite(&hdr, sizeof(hdr), 1, fp);\r\n    int n_cells = a->grid.n;\r\n    fwrite(&n_cells, sizeof(int), 1, fp);\r\n    fwrite(a->grid.cells, sizeof(CellView), n_cells, fp);\r\n    fclose(fp);\r\n    return 0;\r\n}\r\n"]
[76.349325, "o", "\u001b[?2004h"]
[76.349466, "o", "root@87f509269b26:/app# "]
[76.468904, "i", "cat /app/rsm_k/resume.cpp\n"]
[76.469329, "o", "cat /app/rsm_k/resume.cpp\r\n\u001b[?2004l\r"]
[76.470144, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\nint load_k(const char *a, SimState *b, VaultAudit *c) {\r\n    if (!a || !b || !c) return -1;\r\n    memset(c, 0, sizeof(*c));\r\n    FILE *in = fopen(a, \"rb\");\r\n    if (!in) {\r\n        c->reason = REASON_MISSING;\r\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\r\n        return -2;\r\n    }\r\n    VaultHeader hdr;\r\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\r\n        fclose(in);\r\n        c->reason = REASON_SHORT;\r\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\r\n        return -3;\r\n    }\r\n    if (hdr.magic != VAULT_MAGIC) {\r\n        fclose(in);\r\n        c->reason = REASON_MAGIC;\r\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\r\n        return -4;\r\n    }\r\n    int n_cells = 0;\r\n    fread(&n_cells, sizeof(int), 1, in);\r\n    b->grid.n = n_cells;\r\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\r\n    memset(&b->topo, 0, sizeof(b->topo));\r\n    b->bank.n_pending = 0;\r\n    fclose(in);\r\n    c->reason = REASON_OK;\r\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\r\n    return 0;\r\n}\r\n"]
[76.470354, "o", "\u001b[?2004hroot@87f509269b26:/app# "]
[76.592446, "i", "cat /app/lnk_n/relate.cpp\n"]
[76.592812, "o", "cat /app/lnk_n/relate.cpp\r\n\u001b[?2004l\r"]
[76.593996, "o", "#include \"../include/cell_view.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d) {\r\n    if (!a || !d) return -1;\r\n    int n = a->n;\r\n    for (int i = 0; i < n; i++) {\r\n        d->parent[i] = a->cells[i].parent;\r\n    }\r\n    if (b && c > 0) {\r\n        for (int i = 0; i < c && i < n; i++) {\r\n            int idx = b[i];\r\n            if (idx >= 0 && idx < n) {\r\n                d->parent[idx] = a->cells[idx].parent;\r\n            }\r\n        }\r\n    }\r\n    return 0;\r\n}\r\n"]
[76.594224, "o", "\u001b[?2004h"]
[76.594496, "o", "root@87f509269b26:/app# "]
[76.707782, "i", "cat /app/sync_b/halo.cpp\n"]
[76.708352, "o", "cat /app/sync_b/halo.cpp\r\n\u001b[?2004l\r"]
[76.709051, "o", "#include \"../include/cell_view.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\nvoid op_b(CellPatch *a, const CellPatch *b, int c, int d) {\r\n    if (!a || !b) return;\r\n    int width = (b->n < 8) ? b->n : 8;\r\n    a->n = width;\r\n    for (int i = 0; i < width; i++) {\r\n        int src = i + d;\r\n        if (src < 0) src = 0;\r\n        if (src >= b->n) src = b->n - 1;\r\n        a->vol[i] = b->vol[src];\r\n        for (int v = 0; v < NVAR; v++) {\r\n            a->q[i * NVAR + v] = b->q[src * NVAR + v];\r\n        }\r\n    }\r\n    (void)c;\r\n}\r\n"]
[76.709167, "o", "\u001b[?2004h"]
[76.70925, "o", "root@87f509269b26:/app# "]
[76.824271, "i", "cat /app/include/case_spec.h\n"]
[76.825202, "o", "cat /app/include/case_spec.h\r\n\u001b[?2004l\r"]
[76.826358, "o", "#ifndef CASE_SPEC_H\r\n#define CASE_SPEC_H\r\n\r\n#include \"cell_view.h\"\r\n#include \"audit_emit.h\"\r\n\r\n#define MAX_COARSE 64\r\n\r\nstruct ScenarioSpec {\r\n    char name[32];\r\n    int profile;\r\n    int n_coarse;\r\n    int do_flux;\r\n    int do_collapse;\r\n    int do_restart;\r\n    int leaf_count[MAX_COARSE];\r\n    int leaf_weight[MAX_COARSE][MAX_LEAVES];\r\n};\r\n\r\nconst char *app_root(void);\r\n\r\nint load_case(const char *path, const char *section, ScenarioSpec *out);\r\n\r\nint run_u(const ScenarioSpec *a, const char *b, ScenarioOutcome *c);\r\n\r\n#endif\r\n"]
[76.826631, "o", "\u001b[?2004hroot@87f509269b26:/app# "]
[76.94388, "i", "cat /app/include/ic_loader.h\n"]
[76.945087, "o", "cat /app/include/ic_loader.h\r\n\u001b[?2004l\r#ifndef IC_LOADER_H\r\n#define IC_LOADER_H\r\n\r\n#include \"cell_view.h\"\r\n\r\nint load_init(int profile_id, int n_coarse, CellGrid *out);\r\n\r\n#endif\r\n\u001b[?2004h"]
[76.945132, "o", "root@87f509269b26:/app# "]
[149.600186, "i", "cat > /app/agg_q/blend.cpp << 'EOF'\n#include \"../include/cell_view.h\"\n\nvoid fold_q(const CellPatch *a, int b, CellPatch *c) {\n    if (!a || !c) return;\n    int n = (a->n < b) ? a->n : b;\n    if (n <= 0) {\n        c->n = 0;\n        return;\n    }\n    double sum_vol = 0.0;\n    double sum_q[NVAR] = {0.0, 0.0, 0.0};\n    for (int i = 0; i < n; i++) {\n        sum_vol += a->vol[i];\n        for (int v = 0; v < NVAR; v++) {\n            sum_q[v] += a->vol[i] * a->q[i * NVAR + v];\n        }\n    }\n    c->n = 1;\n    c->vol[0] = sum_vol;\n    for (int v = 0; v < NVAR; v++) {\n        c->q[v] = (sum_vol > 0.0) ? sum_q[v] / sum_vol : 0.0;\n    }\n}\nEOF\n"]
