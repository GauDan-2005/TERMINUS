[292.336293, "i", "cat > /app/lnk_n/relate.cpp << 'EOF'\n#include \"../include/cell_view.h\"\n#include \"../include/topo_link.h\"\n\n#include <string.h>\n\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d) {\n    if (!a || !d) return -1;\n    int n = a->n;\n    /* Clear child info */\n    memset(d->child0, 0, sizeof(d->child0));\n    memset(d->child_count, 0, sizeof(d->child_count));\n    for (int i = 0; i < n; i++) {\n        d->parent[i] = a->cells[i].parent;\n    }\n    /* Build child0 and child_count from parent info */\n    for (int i = 0; i < n; i++) {\n        int p = d->parent[i];\n        if (p < 0) continue;\n        if (d->child_count[p] == 0) {\n            d->child0[p] = i;\n        }\n        d->child_count[p]++;\n    }\n    (void)b;\n    (void)c;\n    return 0;\n}\nEOF\n"]
[292.33664, "o", "cat > /app/lnk_n/relate.cpp << 'EOF'\r\n\u001b[?2004l\r"]
