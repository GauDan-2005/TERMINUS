[?2004l#include "../include/cell_view.h"
#include "../include/topo_link.h"

int step_n(CellGrid *a, const int *b, int c, TopoLink *d) {
    if (!a || !d) return -1;
    int n = a->n;
    for (int i = 0; i < n; i++) {
        d->parent[i] = a->cells[i].parent;
    }
    if (b && c > 0) {
        for (int i = 0; i < c && i < n; i++) {
            int idx = b[i];
            if (idx >= 0 && idx < n) {
                d->parent[idx] = a->cells[idx].parent;
            }
        }
    }
    return 0;
}
[?2004hroot@5d46ad38ee8d:/app# sed -n '1,240p' /app/drv_u/run_refine.cpp
[?2004l#include "phases.h"
#include "../include/flow_record.h"
#include "../include/topo_link.h"

#include <string.h>

void phase_grow(SimState *st, const ScenarioSpec *spec) {
    CellGrid coarse = st->grid;
    CellGrid leaves;
    leaves.n = 0;
    st->n_coarse = spec->n_coarse;
    for (int c = 0; c < spec->n_coarse; c++) {
        int k = spec->leaf_count[c];
        if (k < 1) k = 1;
        int sumw = 0;
        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];
        if (sumw <= 0) sumw = 1;
        st->coarse_start[c] = leaves.n;
        st->coarse_len[c] = k;
        double vj[MAX_LEAVES];
        double vtot = 0.0;
        double jw = 0.0;
        for (int j = 0; j < k; j++) {
            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;
            vtot += vj[j];
            jw += vj[j] * (double)j;
        }
        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;
        for (int j = 0; j < k; j++) {
            int gi = leaves.n++;
            leaves.cells[gi].idx = gi;
            leaves.cells[gi].vol = vj[j];
            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;
            for (int v = 0; v < NVAR; v++) {
                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;
            }
            leaves.cells[gi].tier = (k > 1) ? 1 : 0;
            leaves.cells[gi].parent = (k > 1) ? c : -1;
        }
    }
    st->grid = leaves;

    int changed[MAX_CELLS];
    int nch = 0;
    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;
    step_n(&st->grid, changed, nch, &st->topo);

    st->bank.n_pending = 0;
    if (!spec->do_flux) return;
    for (int c = 0; c < spec->n_coarse; c++) {
        int k = st->coarse_len[c];
        if (k < 2) continue;
        int start = st->coarse_start[c];
        double vsum = 0.0;
        double wq[NVAR] = {0.0, 0.0, 0.0};
        for (int j = 0; j < k; j++) {
            const CellView *cell = &st->grid.cells[start + j];
            vsum += cell->vol;
            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];
        }
        double qbar[NVAR];
        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;
        EdgePulse ep;
        ep.base_idx = start;
        ep.subfaces = k;
        for (int j = 0; j < k; j++) {
            const CellView *cell = &st->grid.cells[start + j];
            for (int v = 0; v < NVAR; v++) {
                ep.flux_vals[j * NVAR + v] =
                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);
            }
        }
        op_m(&ep, &st->bank);
    }
}
[?2004hroot@5d46ad38ee8d:/app# sed -n '1,260p' /app/agg_q/blend.cpp
[?2004l#include "../include/cell_view.h"

void fold_q(const CellPatch *a, int b, CellPatch *c) {
    if (!a || !c) return;
    int n = (a->n < b) ? a->n : b;
    if (n <= 0) {
        c->n = 0;
        return;
    }
    double sum_vol = 0.0;
    double sum_q[NVAR] = {0.0, 0.0, 0.0};
    for (int i = 0; i < n; i++) {
        sum_vol += a->vol[i];
        for (int v = 0; v < NVAR; v++) {
            sum_q[v] += a->q[i * NVAR + v];
        }
    }
    c->n = 1;
    c->vol[0] = sum_vol;
    double inv_n = 1.0 / (double)n;
    for (int v = 0; v < NVAR; v++) {
        c->q[v] = sum_q[v] * inv_n;
    }
}
[?2004hroot@5d46ad38ee8d:/app# sed -n '1,260p' /app/swp_t/sweep.cpp
[?2004l#include "../include/cell_view.h"

typedef void (*cell_fn)(CellView *, void *);

void traverse_t(CellGrid *a, cell_fn fn, void *ctx) {
    if (!a || !fn) return;
    for (int i = 0; i < a->n; i++) {
        fn(&a->cells[i], ctx);
    }
}

double span_t(const CellGrid *a) {
    if (!a || a->n == 0) return 0.0;
    double lo = a->cells[0].vol;
    double hi = a->cells[0].vol;
    for (int i = 1; i < a->n; i++) {
        double v = a->cells[i].vol;
        if (v < lo) lo = v;
        if (v > hi) hi = v;
    }
    return hi - lo;
}
[?2004hroot@5d46ad38ee8d:/app# sed -n '1,240p' /app/src/vault_io.cpp
[?2004l#include "../include/vault_layout.h"

#include <stdint.h>

uint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed) {
    const uint8_t *p = (const uint8_t *)data;
    uint64_t h = 0xcbf29ce484222325ull ^ seed;
    for (int i = 0; i < n_bytes; i++) {
        h ^= (uint64_t)p[i];
        h *= 0x100000001b3ull;
    }
    return h;
}
[?2004hroot@5d46ad38ee8d:/app# sed -n '1,260p' /app/rsm_k/resume.cpp
[?2004l#include "../include/vault_layout.h"

#include <stdio.h>
#include <string.h>

int load_k(const char *a, SimState *b, VaultAudit *c) {
    if (!a || !b || !c) return -1;
    memset(c, 0, sizeof(*c));
    FILE *in = fopen(a, "rb");
    if (!in) {
        c->reason = REASON_MISSING;
        snprintf(c->msg, sizeof(c->msg), "open failed");
        return -2;
    }
    VaultHeader hdr;
    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {
        fclose(in);
        c->reason = REASON_SHORT;
        snprintf(c->msg, sizeof(c->msg), "header short");
        return -3;
    }
    if (hdr.magic != VAULT_MAGIC) {
        fclose(in);
        c->reason = REASON_MAGIC;
        snprintf(c->msg, sizeof(c->msg), "bad magic 0x%x", hdr.magic);
        return -4;
    }
    int n_cells = 0;
    fread(&n_cells, sizeof(int), 1, in);
    b->grid.n = n_cells;
    fread(b->grid.cells, sizeof(CellView), n_cells, in);
    memset(&b->topo, 0, sizeof(b->topo));
    b->bank.n_pending = 0;
    fclose(in);
    c->reason = REASON_OK;
    snprintf(c->msg, sizeof(c->msg), "ok");
    return 0;
}
