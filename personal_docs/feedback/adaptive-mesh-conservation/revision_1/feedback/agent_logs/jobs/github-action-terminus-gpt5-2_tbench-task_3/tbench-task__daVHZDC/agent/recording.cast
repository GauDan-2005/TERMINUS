[314.336706, "o", "\u001b[?2004h> a = json.loads(Path('/tmp/conservation_audit.first.json').read_text())\r\n\u001b[?2004l\r\u001b[?2004h> b = json.loads(Path('/app/output/conservation_audit.json').read_text())\r\n\u001b[?2004l\r\u001b[?2004h> print('equal:', a==b)\r\n\u001b[?2004l\r\u001b[?2004h> if a!=b:\r\n\u001b[?2004l\r\u001b[?2004h>     # canonical dump to help see whether it's only float repr/order\r\n\u001b[?2004l\r\u001b[?2004h>     print('cases:', len(a.get('cases',[])), len(b.get('cases',[])))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
