[97.360947, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: drv_u/run_refine.cpp\n@@\n void phase_grow(SimState *st, const ScenarioSpec *spec) {\n     CellGrid coarse = st->grid;\n     CellGrid leaves;\n     leaves.n = 0;\n@@\n-        double vj[MAX_LEAVES];\n-        double vtot = 0.0;\n-        double jw = 0.0;\n+        double vj[MAX_LEAVES];\n+        double fj[MAX_LEAVES];\n+        double vtot = 0.0;\n+        double jw = 0.0;\n         for (int j = 0; j < k; j++) {\n             vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\n             vtot += vj[j];\n             jw += vj[j] * (double)j;\n         }\n         double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\n+\n+        // Compute shape factors and renormalize so that splitting preserves\n+        // volume-weighted totals: sum_j vj * qj == coarse.vol * coarse.q.\n+        double denom[NVAR] = {0.0, 0.0, 0.0};\n+        for (int j = 0; j < k; j++) {\n+            fj[j] = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\n+            for (int v = 0; v < NVAR; v++) denom[v] += vj[j] * fj[j];\n+        }\n+        double scale[NVAR];\n+        for (int v = 0; v < NVAR; v++) {\n+            scale[v] = (denom[v] != 0.0) ? (coarse.cells[c].vol / denom[v]) : 1.0;\n+        }\n+\n         for (int j = 0; j < k; j++) {\n             int gi = leaves.n++;\n             leaves.cells[gi].idx = gi;\n             leaves.cells[gi].vol = vj[j];\n-            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\n             for (int v = 0; v < NVAR; v++) {\n-                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\n+                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * fj[j] * scale[v];\n             }\n             leaves.cells[gi].tier = (k > 1) ? 1 : 0;\n             leaves.cells[gi].parent = (k > 1) ? c : -1;\n         }\n     }\n*** End Patch\nPATCH\n"]
