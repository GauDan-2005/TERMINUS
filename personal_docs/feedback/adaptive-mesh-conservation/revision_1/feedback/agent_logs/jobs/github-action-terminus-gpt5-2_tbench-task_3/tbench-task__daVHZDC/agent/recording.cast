[98.364084, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: agg_q/blend.cpp\n@@\n void fold_q(const CellPatch *a, int b, CellPatch *c) {\n     if (!a || !c) return;\n     int n = (a->n < b) ? a->n : b;\n@@\n-    double sum_vol = 0.0;\n-    double sum_q[NVAR] = {0.0, 0.0, 0.0};\n+    double sum_vol = 0.0;\n+    double sum_vq[NVAR] = {0.0, 0.0, 0.0};\n     for (int i = 0; i < n; i++) {\n         sum_vol += a->vol[i];\n         for (int v = 0; v < NVAR; v++) {\n-            sum_q[v] += a->q[i * NVAR + v];\n+            sum_vq[v] += a->vol[i] * a->q[i * NVAR + v];\n         }\n     }\n     c->n = 1;\n     c->vol[0] = sum_vol;\n-    double inv_n = 1.0 / (double)n;\n     for (int v = 0; v < NVAR; v++) {\n-        c->q[v] = sum_q[v] * inv_n;\n+        c->q[v] = (sum_vol > 0.0) ? (sum_vq[v] / sum_vol) : 0.0;\n     }\n }\n*** End Patch\nPATCH\n"]
