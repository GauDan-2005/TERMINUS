[167.295144, "o", "\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[168.268844, "i", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\np = Path('/app/drv_u/run_refine.cpp')\ns = p.read_text()\n# We patch inside phase_grow: introduce fj[], denom/scale, and use renormalized q.\n# Do a targeted replacement of the block that computes vj/vtot/jw..jbar and then writes leaves.\nold_block_pat = re.compile(r\"double vj\\[MAX_LEAVES\\];\\n\\s*double vtot = 0\\.0;\\n\\s*double jw = 0\\.0;\\n\\s*for \\(int j = 0; j < k; j\\+\\+\\) \\{\\n\\s*vj\\[j\\] = coarse\\.cells\\[c\\]\\.vol \\* \\(double\\)spec->leaf_weight\\[c\\]\\[j\\] / \\(double\\)sumw;\\n\\s*vtot \\+= vj\\[j\\];\\n\\s*jw \\+= vj\\[j\\] \\* \\(double\\)j;\\n\\s*\\}\\n\\s*double jbar = \\(vtot > 0\\.0\\) \\? jw / vtot : 0\\.0;\\n\\s*for \\(int j = 0; j < k; j\\+\\+\\) \\{\\n\\s*int gi = leaves\\.n\\+\\+;\\n\\s*leaves\\.cells\\[gi\\]\\.idx = gi;\\n\\s*leaves\\.cells\\[gi\\]\\.vol = vj\\[j\\];\\n\\s*double f = \\(k > 1\\) \\? \\(1\\.0 \\+ LEAF_SPREAD \\* \\(\\(double\\)j - jbar\\)\\) : 1\\.0;\\n\\s*for \\(int v = 0; v < NVAR; v\\+\\+\\) \\{\\n\\s*leaves\\.cells\\[gi\\]\\.q\\[v\\] = coarse\\.cells\\[c\\]\\.q\\[v\\] \\* f;\\n\\s*\\}\\n\\s*leaves\\.cells\\[gi\\]\\.tier = \\(k > 1\\) \\? 1 : 0;\\n\\s*leaves\\.cells\\[gi\\]\\.parent = \\(k > 1\\) \\? c : -1;\\n\\s*\\}\\n\")\nnew_block = \"\"\"double vj[MAX_LEAVES];\n        double fj[MAX_LEAVES];\n        double vtot = 0.0;\n        double jw = 0.0;\n        for (int j = 0; j < k; j++) {\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\n            vtot += vj[j];\n            jw += vj[j] * (double)j;\n        }\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\n\n        // Renormalize the shaped split so totals are conserved:\n        //   sum_j vj * qj == coarse.vol * coarse.q   (per variable).\n        double denom[NVAR] = {0.0, 0.0, 0.0};\n        for (int j = 0; j < k; j++) {\n            fj[j] = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\n            for (int v = 0; v < NVAR; v++) denom[v] += vj[j] * fj[j];\n        }\n        double scale[NVAR];\n        for (int v = 0; v < NVAR; v++) {\n            scale[v] = (denom[v] != 0.0) ? (coarse.cells[c].vol / denom[v]) : 1.0;\n        }\n\n        for (int j = 0; j < k; j++) {\n            int gi = leaves.n++;\n            leaves.cells[gi].idx = gi;\n            leaves.cells[gi].vol = vj[j];\n            for (int v = 0; v < NVAR; v++) {\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * fj[j] * scale[v];\n            }\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\n        }\n\"\"\"\nns, n = old_block_pat.subn(new_block, s)\nif n != 1:\n    raise SystemExit(f'Expected to replace 1 split block, replaced {n}')\np.write_text(ns)\nprint('patched', p)\nPY\n"]
