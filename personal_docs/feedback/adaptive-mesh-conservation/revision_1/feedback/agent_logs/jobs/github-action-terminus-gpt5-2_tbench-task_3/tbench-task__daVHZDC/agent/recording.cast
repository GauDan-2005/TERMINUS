[199.294033, "o", "{\r\n  \"cases\": [\r\n    {\r\n      \"name\": \"storm\",\r\n      \"base_total\": [1.98, 1.75, 1.7429999999999999],\r\n      \"after_total\": [1.9838624999999999, 1.7568531250000001, 1.7449218750000002],\r\n      \"resumed_total\": [8.7781874999999996, 6.5723593749999996, 7.783765625],\r\n      \"drift_ratio\": 0.0039160714285715005,\r\n      \"balanced\": false,\r\n      \"base_match\": false,\r\n      \"adjacency\": 0,\r\n      \"halo_q\": [0.42229999999999995, 0.74927499999999991, 0.21012499999999998]\r\n    },\r\n    {\r\n      \"name\": \"canyon\",\r\n      \"base_total\": [2.0019999999999998, 1.7449999999999999, 1.7310000000000001],\r\n      \"after_total\": [2.0101312499999997, 1.7511281249999999, 1.7394281249999999],\r\n      \"resumed_total\": [9.6342749999999988, 8.9240281249999995, 7.3328218750000014],\r\n      \"drift_ratio\": 0.0048689341421142614,\r\n      \"balanced\": false,\r\n      \"base_match\": false,\r\n      \"adjacency\": 0,\r\n      \"halo_q\": [0.56579999999999997, 0.24702499999999997, 0.704175]\r\n    },\r\n    {\r\n      \"name\": \"plume\",\r\n      \"base_total\": [2.29, 1.6689999999999998, 1.7520000000000002],\r\n      \"after_total\": [2.29, 1.669, 1.7520000000000002],\r\n      \"resumed_total\": [5.7809999999999997, 3.9450000000000003, 4.5250000000000004],\r\n      \"drift_ratio\": 1.3304050624627401e-16,\r\n      \"balanced\": true,\r\n      \"base_match\": true,\r\n      \"adjacency\": 0,\r\n      \"halo_q\": [0.68053333333333343, 0.50346666666666673, 0.29973333333333341]\r\n    },\r\n    {\r\n      \"name\": \"spire\",\r\n      \"base_total\": [1.98, 1.75, 1.7429999999999999],\r\n      \"after_total\": [1.98, 1.75, 1.7429999999999999],\r\n      \"resumed_total\": [5.3010000000000002, 3.9290000000000003, 4.5380000000000003],\r\n      \"drift_ratio\": 0,\r\n      \"balanced\": true,\r\n      \"base_match\": true,\r\n"]
