[248.77009, "o", "{\r\n  \"cases\": [\r\n    {\r\n      \"name\": \"storm\",\r\n      \"base_total\": [1.98, 1.75, 1.7429999999999999],\r\n      \"after_total\": [1.98, 1.75, 1.7429999999999999],\r\n      \"resumed_total\": [8.7672437499999987, 6.5529421875000002, 7.7783203125],\r\n      \"drift_ratio\": 0,\r\n      \"balanced\": true,\r\n      \"base_match\": true,\r\n      \"adjacency\": 0,\r\n      \"halo_q\": [0.41972499999999996, 0.7447062499999999, 0.20884374999999999]\r\n    },\r\n    {\r\n      \"name\": \"canyon\",\r\n      \"base_total\": [2.0019999999999998, 1.7449999999999999, 1.7310000000000001],\r\n      \"after_total\": [2.0019999999999998, 1.7449999999999999, 1.7309999999999999],\r\n      \"resumed_total\": [9.6048312500000002, 8.8982828124999997, 7.3046359375000005],\r\n      \"drift_ratio\": 1.2827533502312611e-16,\r\n      \"balanced\": true,\r\n      \"base_match\": true,\r\n      \"adjacency\": 0,\r\n      \"halo_q\": [0.56235000000000002, 0.24551874999999998, 0.69988125000000001]\r\n    },\r\n    {\r\n      \"name\": \"plume\",\r\n      \"base_total\": [2.29, 1.6689999999999998, 1.7520000000000002],\r\n      \"after_total\": [2.29, 1.669, 1.7520000000000002],\r\n      \"resumed_total\": [5.7809999999999997, 3.9450000000000003, 4.5250000000000004],\r\n      \"drift_ratio\": 1.3304050624627401e-16,\r\n      \"balanced\": true,\r\n      \"base_match\": true,\r\n      \"adjacency\": 0,\r\n      \"halo_q\": [0.68053333333333343, 0.50346666666666673, 0.29973333333333341]\r\n    },\r\n    {\r\n      \"name\": \"spire\",\r\n      \"base_total\": [1.98, 1.75, 1.7429999999999999],\r\n      \"after_total\": [1.98, 1.75, 1.7429999999999999],\r\n      \"resumed_total\": [5.3010000000000002, 3.9290000000000003, 4.5380000000000003],\r\n      \"drift_ratio\": 0,\r\n      \"balanced\": true,\r\n      \"base_match\": true,\r\n      \"adjacency\": 0,\r\n      \"halo_q\": [0.44289999999999996, 0.785825, 0.22037499999999999]\r\n    },\r\n    {\r\n      \"name\": \"