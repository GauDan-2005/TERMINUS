[166.921277, "o", "\r\n\u001b[?2004l\r\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[167.039622, "i", "sed -n '1,220p' /app/drv_u/run_refine.cpp\n"]
[167.040038, "o", "sed -n '1,220p' /app/drv_u/run_refine.cpp\r\n"]
[167.040396, "o", "\u001b[?2004l\r"]
[167.041498, "o", "#include \"phases.h\"\r\n#include \"../include/flow_record.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\r\n    CellGrid coarse = st->grid;\r\n    CellGrid leaves;\r\n    leaves.n = 0;\r\n    st->n_coarse = spec->n_coarse;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = spec->leaf_count[c];\r\n"]
[167.041564, "o", "        if (k < 1) k = 1;\r\n        int sumw = 0;\r\n        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\r\n        if (sumw <= 0) sumw = 1;\r\n        st->coarse_start[c] = leaves.n;\r\n        st->coarse_len[c] = k;\r\n        double vj[MAX_LEAVES];\r\n        double vtot = 0.0;\r\n        double jw = 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\r\n            vtot += vj[j];\r\n            jw += vj[j] * (double)j;\r\n        }\r\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            int gi = leaves.n++;\r\n            leaves.cells[gi].idx = gi;\r\n            leaves.cells[gi].vol = vj[j];\r\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\r\n            }\r\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\r\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\r\n        }\r\n    }\r\n    st->grid = leaves;\r\n\r\n    int changed[MAX_CELLS];\r\n    int nch = 0;\r\n    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\r\n    step_n(&st->grid, changed, nch, &st->topo);\r\n\r\n    st->bank.n_pending = 0;\r\n    if (!spec->do_flux) return;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = st->coarse_len[c];\r\n        if (k < 2) continue;\r\n        int start = st->coarse_start[c];\r\n        double vsum = 0.0;\r\n        double wq[NVAR] = {0.0, 0.0, 0.0};\r\n        for (int j = 0; j < k; j++) {\r\n"]
[167.041585, "o", "            const CellView *cell = &st->grid.cells[start + j];\r\n            vsum += cell->vol;\r\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\r\n"]
[167.041631, "o", "        }\r\n        double qbar[NVAR];\r\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\r\n        EdgePulse ep;\r\n        ep.base_idx = start;\r\n        ep.subfaces = k;\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            for (int v = 0; v < NVAR; v++) {\r\n"]
[167.04174, "o", "                ep.flux_vals[j * NVAR + v] =\r\n                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\r\n            }\r\n        }\r\n        op_m(&ep, &st->bank);\r\n    }\r\n}\r\n"]
[167.042403, "o", "\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[167.148084, "i", "sed -n '1,140p' /app/agg_q/blend.cpp\n"]
[167.148299, "o", "sed -n '1,140p' /app/agg_q/blend.cpp\r\n\u001b[?2004l\r"]
[167.149717, "o", "#include \"../include/cell_view.h\"\r\n\r\nvoid fold_q(const CellPatch *a, int b, CellPatch *c) {\r\n    if (!a || !c) return;\r\n    int n = (a->n < b) ? a->n : b;\r\n    if (n <= 0) {\r\n        c->n = 0;\r\n        return;\r\n    }\r\n    double sum_vol = 0.0;\r\n"]
[167.149775, "o", "    double sum_q[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int i = 0; i < n; i++) {\r\n        sum_vol += a->vol[i];\r\n        for (int v = 0; v < NVAR; v++) {\r\n"]
[167.149873, "o", "            sum_q[v] += a->q[i * NVAR + v];\r\n        }\r\n    }\r\n    c->n = 1;\r\n"]
[167.149898, "o", "    c->vol[0] = sum_vol;\r\n    double inv_n = 1.0 / (double)n;\r\n    for (int v = 0; v < NVAR; v++) {\r\n"]
[167.149992, "o", "        c->q[v] = sum_q[v] * inv_n;\r\n    }\r\n}\r\n"]
[167.150249, "o", "\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[167.263943, "i", "python3 - <<'PY'\nfrom pathlib import Path\np = Path('/app/agg_q/blend.cpp')\ns = p.read_text()\nold = s\n# Replace fold_q implementation with volume-weighted version.\nimport re\npat = re.compile(r\"void fold_q\\(const CellPatch \\*a, int b, CellPatch \\*c\\) \\{.*?\\n\\}\", re.S)\nrep = r'''void fold_q(const CellPatch *a, int b, CellPatch *c) {\n    if (!a || !c) return;\n    int n = (a->n < b) ? a->n : b;\n    if (n <= 0) {\n        c->n = 0;\n        return;\n    }\n    double sum_vol = 0.0;\n    double sum_vq[NVAR] = {0.0, 0.0, 0.0};\n    for (int i = 0; i < n; i++) {\n        sum_vol += a->vol[i];\n        for (int v = 0; v < NVAR; v++) {\n            sum_vq[v] += a->vol[i] * a->q[i * NVAR + v];\n        }\n    }\n    c->n = 1;\n    c->vol[0] = sum_vol;\n    for (int v = 0; v < NVAR; v++) {\n        c->q[v] = (sum_vol > 0.0) ? (sum_vq[v] / sum_vol) : 0.0;\n    }\n}'''\nns, n = pat.subn(rep, s)\nif n != 1:\n    raise SystemExit(f'Expected to replace 1 fold_q, replaced {n}')\np.write_text(ns)\nprint('patched', p)\nPY\n"]
[167.26423, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
[167.264662, "o", "\u001b[?2004h> from pathlib import Path\r\n\u001b[?2004l\r\u001b[?2004h> p = Path('/app/agg_q/blend.cpp')\r\n\u001b[?2004l\r"]
[167.264869, "o", "\u001b[?2004h> s = p.read_text()\r\n\u001b[?2004l\r"]
[167.264908, "o", "\u001b[?2004h> old = s\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.265084, "o", "# Replace fold_q implementation with volume-weighted version.\r\n\u001b[?2004l\r"]
[167.265116, "o", "\u001b[?2004h> "]
[167.265166, "o", "import re\r\n\u001b[?2004l\r"]
[167.265193, "o", "\u001b[?2004h> "]
[167.268039, "o", "pat = re.compile(r\"void fold_q\\(const CellPatch \\*a, int b, CellPatch \\*c\\) \\{.*?\\n\\}\", re.S)\r\n\u001b[?2004l\r\u001b[?2004h> rep = r'''void fold_q(const CellPatch *a, int b, CellPatch *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     if (!a || !c) return;\r\n\u001b[?2004l\r\u001b[?2004h>     int n = (a->n < b) ? a->n : b;\r\n\u001b[?2004l\r\u001b[?2004h>     if (n <= 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         c->n = 0;\r\n\u001b[?2004l\r\u001b[?2004h>         return;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     double sum_vol = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h>     double sum_vq[NVAR] = {0.0, 0.0, 0.0};\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < n; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         sum_vol += a->vol[i];\r\n\u001b[?2004l\r\u001b[?2004h>         for (int v = 0; v < NVAR; v++) {\r\n\u001b[?2004l\r\u001b[?2004h>             sum_vq[v] += a->vol[i] * a->q[i * NVAR + v];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.268104, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.268165, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.268537, "o", "    c->n = 1;\r\n\u001b[?2004l\r"]
[167.26858, "o", "\u001b[?2004h>     c->vol[0] = sum_vol;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int v = 0; v < NVAR; v++) {\r\n\u001b[?2004l\r"]
[167.268607, "o", "\u001b[?2004h"]
[167.26863, "o", "> "]
[167.268885, "o", "        c->q[v] = (sum_vol > 0.0) ? (sum_vq[v] / sum_vol) : 0.0;\r\n\u001b[?2004l\r"]
[167.268923, "o", "\u001b[?2004h> "]
[167.269051, "o", "    }\r\n\u001b[?2004l\r"]
[167.269095, "o", "\u001b[?2004h> "]
[167.269122, "o", "}'''\r\n\u001b[?2004l\r"]
[167.269239, "o", "\u001b[?2004h> "]
