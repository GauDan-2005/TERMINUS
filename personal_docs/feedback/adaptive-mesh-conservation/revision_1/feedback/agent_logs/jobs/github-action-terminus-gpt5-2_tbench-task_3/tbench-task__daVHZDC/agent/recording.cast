[76.69583, "i", "sed -n '1,200p' /app/lnk_n/relate.cpp\n"]
[76.696132, "o", "sed -n '1,200p' /app/lnk_n/relate.cpp\r\n\u001b[?2004l\r"]
[76.697277, "o", "#include \"../include/cell_view.h\"\r\n#include \"../include/topo_link.h\"\r\n"]
[76.700063, "o", "\r\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d) {\r\n    if (!a || !d) return -1;\r\n    int n = a->n;\r\n    for (int i = 0; i < n; i++) {\r\n        d->parent[i] = a->cells[i].parent;\r\n    }\r\n    if (b && c > 0) {\r\n        for (int i = 0; i < c && i < n; i++) {\r\n            int idx = b[i];\r\n            if (idx >= 0 && idx < n) {\r\n                d->parent[idx] = a->cells[idx].parent;\r\n            }\r\n        }\r\n    }\r\n    return 0;\r\n}\r\n\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[76.811689, "i", "sed -n '1,240p' /app/drv_u/run_refine.cpp\n"]
[76.812303, "o", "sed -n '1,240p' /app/drv_u/run_refine.cpp\r\n\u001b[?2004l\r"]
[76.813706, "o", "#include \"phases.h\"\r\n"]
[76.81377, "o", "#include \"../include/flow_record.h\"\r\n"]
[76.814288, "o", "#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\r\n    CellGrid coarse = st->grid;\r\n    CellGrid leaves;\r\n    leaves.n = 0;\r\n    st->n_coarse = spec->n_coarse;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = spec->leaf_count[c];\r\n        if (k < 1) k = 1;\r\n        int sumw = 0;\r\n        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\r\n        if (sumw <= 0) sumw = 1;\r\n        st->coarse_start[c] = leaves.n;\r\n        st->coarse_len[c] = k;\r\n        double vj[MAX_LEAVES];\r\n        double vtot = 0.0;\r\n        double jw = 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\r\n            vtot += vj[j];\r\n            jw += vj[j] * (double)j;\r\n        }\r\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            int gi = leaves.n++;\r\n            leaves.cells[gi].idx = gi;\r\n            leaves.cells[gi].vol = vj[j];\r\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\r\n            }\r\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\r\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\r\n        }\r\n    }\r\n    st->grid = leaves;\r\n\r\n    int changed[MAX_CELLS];\r\n    int nch = 0;\r\n    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\r\n    step_n(&st->grid, changed, nch, &st->topo);\r\n\r\n    st->bank.n_pending = 0;\r\n    if (!spec->do_flux) return;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = st->coarse_len[c];\r\n        if (k < 2) continue;\r\n        int start = st->coarse_start[c];\r\n        double vsum = 0.0;\r\n        double wq[NVAR] = {0.0, 0.0, 0.0};\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            vsum += cell->vol;\r\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\r\n        }\r\n        double qbar[NVAR];\r\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\r\n        EdgePulse ep;\r\n        ep.base_idx = start;\r\n        ep.subfaces = k;\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            for (int v = 0; v < NVAR; v++) {\r\n                ep.flux_vals[j * NVAR + v] =\r\n                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\r\n            }\r\n        }\r\n        op_m(&ep, &st->bank);\r\n    }\r\n}\r\n"]
[76.81454, "o", "\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[76.936243, "i", "sed -n '1,260p' /app/agg_q/blend.cpp\n"]
[76.936605, "o", "sed -n '1,260p' /app/agg_q/blend.cpp"]
[76.936886, "o", "\r\n\u001b[?2004l\r"]
[76.941711, "o", "#include \"../include/cell_view.h\"\r\n\r\nvoid fold_q(const CellPatch *a, int b, CellPatch *c) {\r\n    if (!a || !c) return;\r\n    int n = (a->n < b) ? a->n : b;\r\n    if (n <= 0) {\r\n        c->n = 0;\r\n        return;\r\n    }\r\n    double sum_vol = 0.0;\r\n    double sum_q[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int i = 0; i < n; i++) {\r\n        sum_vol += a->vol[i];\r\n        for (int v = 0; v < NVAR; v++) {\r\n            sum_q[v] += a->q[i * NVAR + v];\r\n        }\r\n    }\r\n    c->n = 1;\r\n    c->vol[0] = sum_vol;\r\n    double inv_n = 1.0 / (double)n;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        c->q[v] = sum_q[v] * inv_n;\r\n    }\r\n}\r\n\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[77.048126, "i", "sed -n '1,260p' /app/swp_t/sweep.cpp\n"]
[77.048734, "o", "sed -n '1,260p' /app/swp_t/sweep.cpp\r\n\u001b[?2004l\r"]
[77.05122, "o", "#include \"../include/cell_view.h\"\r\n\r\ntypedef void (*cell_fn)(CellView *, void *);\r\n\r\nvoid traverse_t(CellGrid *a, cell_fn fn, void *ctx) {\r\n    if (!a || !fn) return;\r\n    for (int i = 0; i < a->n; i++) {\r\n        fn(&a->cells[i], ctx);\r\n    }\r\n}\r\n\r\ndouble span_t(const CellGrid *a) {\r\n    if (!a || a->n == 0) return 0.0;\r\n    double lo = a->cells[0].vol;\r\n    double hi = a->cells[0].vol;\r\n    for (int i = 1; i < a->n; i++) {\r\n        double v = a->cells[i].vol;\r\n        if (v < lo) lo = v;\r\n        if (v > hi) hi = v;\r\n    }\r\n    return hi - lo;\r\n}\r\n\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[77.163942, "i", "sed -n '1,240p' /app/src/vault_io.cpp\n"]
[77.16425, "o", "sed -n '1,240p' /app/src/vault_io.cpp"]
[77.164643, "o", "\r\n\u001b[?2004l\r"]
[77.166072, "o", "#include \"../include/vault_layout.h\"\r\n"]
[77.166201, "o", "\r\n"]
[77.166496, "o", "#include <stdint.h>\r\n\r\nuint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed) {\r\n    const uint8_t *p = (const uint8_t *)data;\r\n    uint64_t h = 0xcbf29ce484222325ull ^ seed;\r\n    for (int i = 0; i < n_bytes; i++) {\r\n        h ^= (uint64_t)p[i];\r\n        h *= 0x100000001b3ull;\r\n    }\r\n    return h;\r\n}\r\n"]
[77.16655, "o", "\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[77.275683, "i", "sed -n '1,260p' /app/rsm_k/resume.cpp\n"]
[77.276065, "o", "sed -n '1,260p' /app/rsm_k/resume.cpp\r\n\u001b[?2004l\r"]
[77.277485, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\nint load_k(const char *a, SimState *b, VaultAudit *c) {\r\n    if (!a || !b || !c) return -1;\r\n    memset(c, 0, sizeof(*c));\r\n    FILE *in = fopen(a, \"rb\");\r\n    if (!in) {\r\n"]
[77.277593, "o", "        c->reason = REASON_MISSING;\r\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\r\n        return -2;\r\n    }\r\n    VaultHeader hdr;\r\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\r\n        fclose(in);\r\n        c->reason = REASON_SHORT;\r\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\r\n        return -3;\r\n    }\r\n    if (hdr.magic != VAULT_MAGIC) {\r\n        fclose(in);\r\n        c->reason = REASON_MAGIC;\r\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\r\n        return -4;\r\n    }\r\n    int n_cells = 0;\r\n    fread(&n_cells, sizeof(int), 1, in);\r\n    b->grid.n = n_cells;\r\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\r\n    memset(&b->topo, 0, sizeof(b->topo));\r\n    b->bank.n_pending = 0;\r\n    fclose(in);\r\n    c->reason = REASON_OK;\r\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\r\n    return 0;\r\n}\r\n"]
