[60.080967, "o", "sed -n '1,200p' /app/config/cases.toml\r\n\u001b[?2004l\r"]
[60.082586, "o", "# Per-scenario schedules for the bundled sweep.\r\n# profile selects the initial-condition table under /app/data/init.\r\n# leaves is a '|'-separated list (one entry per base cell); each entry is a\r\n# comma-separated list of integer sub-cell weights for that base cell.\r\n# do_flux / do_collapse / do_restart toggle the structural phases.\r\n\r\n[storm]\r\nprofile = 0\r\nn_coarse = 4\r\ndo_flux = 1\r\ndo_collapse = 0\r\ndo_restart = 0\r\nleaves = 2,1,1|1|1|1\r\n\r\n[canyon]\r\nprofile = 1\r\nn_coarse = 4\r\ndo_flux = 1\r\ndo_collapse = 0\r\ndo_restart = 0\r\nleaves = 2,1,1|2,2|1|1\r\n\r\n[plume]\r\nprofile = 2\r\nn_coarse = 4\r\ndo_flux = 0\r\ndo_collapse = 1\r\ndo_restart = 0\r\nleaves = 2,1|3,1|1|1\r\n\r\n[spire]\r\nprofile = 0\r\nn_coarse = 4\r\ndo_flux = 0\r\ndo_collapse = 1\r\ndo_restart = 0\r\nleaves = 3,1|1|1|1\r\n\r\n[basin]\r\nprofile = 1\r\nn_coarse = 4\r\ndo_flux = 1\r\ndo_collapse = 0\r\ndo_restart = 1\r\nleaves = 2,1,1|1|1|1\r\n\r\n[dune]\r\nprofile = 2\r\nn_coarse = 4\r\ndo_flux = 1\r\ndo_collapse = 0\r\ndo_restart = 1\r\nleaves = 2,1,1|2,2|1|1\r\n"]
[60.082797, "o", "\u001b[?2004h"]
