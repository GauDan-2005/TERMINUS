[207.02366, "i", "sed -n '1,220p' /app/acc_m/edge_corr.cpp\n"]
[207.024084, "o", "sed -n '1,220p' /app/acc_m/edge_corr.cpp\r\n\u001b[?2004l\r"]
[207.025388, "o", "#include \"../include/flow_record.h\"\r\n"]
[207.025627, "o", "\r\nvoid op_m(const EdgePulse *a, FluxBank *b) {\r\n    if (!a || !b) return;\r\n    if (b->n_pending >= MAX_FACES) return;\r\n    int slot = b->n_pending++;\r\n    b->leaf[slot] = a->base_idx;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        b->flux[slot * NVAR + v] = a->flux_vals[v];\r\n    }\r\n}\r\n"]
[207.025768, "o", "\u001b[?2004hroot@5d46ad38ee8d:/app# "]
[207.147697, "i", "sed -n '1,220p' /app/include/flow_record.h\n"]
[207.148209, "o", "sed -n '1,220p' /app/include/flow_record.h"]
[207.148526, "o", "\r\n\u001b[?2004l\r"]
[207.149723, "o", "#ifndef FLOW_RECORD_H\r\n#define FLOW_RECORD_H\r\n\r\n#include \"cell_view.h\"\r\n\r\nstruct EdgePulse {\r\n    int base_idx;\r\n    int subfaces;\r\n    double flux_vals[MAX_LEAVES * NVAR];\r\n};\r\n\r\nstruct FluxBank {\r\n    int n_pending;\r\n    int leaf[MAX_FACES];\r\n"]
[207.149874, "o", "    double flux[MAX_FACES * NVAR];\r\n};\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b);\r\n\r\n#endif\r\n"]
[207.149997, "o", "\u001b[?2004hroot@5d46ad38ee8d:/app# "]
