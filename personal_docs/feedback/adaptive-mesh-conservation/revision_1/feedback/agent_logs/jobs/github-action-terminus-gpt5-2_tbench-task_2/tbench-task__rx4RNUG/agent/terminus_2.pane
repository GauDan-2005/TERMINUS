void op_m(const EdgePulse *a, FluxBank *b) {
    if (!a || !b) return;
    if (b->n_pending >= MAX_FACES) return;
    int slot = b->n_pending++;
    b->leaf[slot] = a->base_idx;
    for (int v = 0; v < NVAR; v++) {
        b->flux[slot * NVAR + v] = a->flux_vals[v];
    }
}
