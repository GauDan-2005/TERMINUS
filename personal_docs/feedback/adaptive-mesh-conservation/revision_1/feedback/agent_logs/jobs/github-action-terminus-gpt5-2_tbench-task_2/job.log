Sending keys: ['cat > /app/agg_q/blend.cpp <<\'EOF\'\n#include "../include/cell_view.h"\n\n#include <string.h>\n\n// Conservative merge (collapse): fold fine leaves into a parent.\n// The invariant is that integrated quantities are preserved:\n//   parent.vol = sum(child.vol)\n//   parent.vol * parent.q[v] = sum(child.vol * child.q[v])\nvoid fold_q(const CellPatch *a, int n, CellPatch *out) {\n    if (!a || !out) return;\n    if (n < 1) {\n        memset(out, 0, sizeof(*out));\n        return;\n    }\n\n    double vtot = 0.0;\n    double mass[NVAR];\n    for (int v = 0; v < NVAR; v++) mass[v] = 0.0;\n\n    for (int i = 0; i < n && i < MAX_LEAVES; i++) {\n        double vol = a->vol[i];\n        if (vol <= 0.0) continue;\n        vtot += vol;\n        for (int v = 0; v < NVAR; v++) {\n            mass[v] += vol * a->q[i * NVAR + v];\n        }\n    }\n\n    memset(out, 0, sizeof(*out));\n    out->n = 1;\n    out->vol[0] = vtot;\n    for (int v = 0; v < NVAR; v++) {\n        out->q[v] = (vtot > 0.0) ? (mass[v] / vtot) : 0.0;\n    }\n}\n\n// A simple ghost-band sampler used by the audit (not a conservation-critical operation).\nvoid op_b(CellPatch *dst, const CellPatch *src, int n, int side) {\n    if (!dst || !src) return;\n    (void)side;\n    memset(dst, 0, sizeof(*dst));\n    if (n < 1) return;\n\n    // Sample the first entry.\n    dst->n = 1;\n    dst->vol[0] = src->vol[0];\n    for (int v = 0; v < NVAR; v++) dst->q[v] = src->q[v];\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
