j] * f) / fsum_vol;\n                leaves.cells[gi].q[v] = (vj[j] > 0.0) ? (m_child / vj[j]) : 0.0;\n            }\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\n        }\n    }\n\n    st->grid = leaves;\n\n    int changed[MAX_CELLS];\n    int nch = 0;\n    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\n    step_n(&st->grid, changed, nch, &st->topo);\n\n    st->bank.n_pending = 0;\n    if (!spec->do_flux) return;\n\n    for (int c = 0; c < spec->n_coarse; c++) {\n        int k = st->coarse_len[c];\n        if (k < 2) continue;\n        int start = st->coarse_start[c];\n\n        double vsum = 0.0;\n        double wq[NVAR] = {0.0, 0.0, 0.0};\n        for (int j = 0; j < k; j++) {\n            const CellView *cell = &st->grid.cells[start + j];\n            vsum += cell->vol;\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\n        }\n        double qbar[NVAR];\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\n\n        // Enqueue one correction per leaf (FluxBank is leaf-indexed).\n        for (int j = 0; j < k; j++) {\n            const CellView *cell = &st->grid.cells[start + j];\n            EdgePulse ep;\n            memset(&ep, 0, sizeof(ep));\n            ep.base_idx = start + j;\n            ep.subfaces = 1;\n            for (int v = 0; v < NVAR; v++) {\n                ep.flux_vals[v] = REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\n            }\n            op_m(&ep, &st->bank);\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ['cat > /app/lnk_n/relate.cpp <<\'EOF\'\n#include "../include/cell_view.h"\n#include "../include/topo_link.h"\n\n#include <string.h>\n\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d) {\n    (void)b;\n    (void)c;\n    if (!a || !d) return -1;\n\n    int n = a->n;\n\n    // Initialize.\n    d->n_faces = 0;\n    for (int i = 0; i < n; i++) {\n        d->parent[i] = a->cells[i].parent;\n        d->child0[i] = -1;\n        d->child_count[i] = 0;\n    }\n\n    // Count children per parent.\n    for (int i = 0; i < n; i++) {\n        int p = d->parent[i];\n        if (p >= 0 && p < n) d->child_count[p]++;\n    }\n\n    // Assign contiguous child ranges in index order.\n    // For this toy driver the children of a parent are created consecutively,\n    // so we can use the first occurrence as child0.\n    for (int i = 0; i < n; i++) {\n        int p = d->parent[i];\n        if (p >= 0 && p < n) {\n            if (d->child0[p] < 0) d->child0[p] = i;\n        }\n    }\n\n    return 0;\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
