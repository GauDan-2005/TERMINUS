[112.211291, "o", "\r\n\u001b[?2004l\r"]
[112.212453, "o", "#include \"phases.h\"\r\n"]
[112.212585, "o", "#include \"../include/ic_loader.h\"\r\n\r\n#include <math.h>\r\n#include <string.h>\r\n#include <stdio.h>\r\n\r\nstatic int compute_adjacency(const SimState *st) {\r\n    int count = 0;\r\n    for (int i = 0; i < st->grid.n; i++) {\r\n"]
[112.212775, "o", "        int p = st->topo.parent[i];\r\n        if (p < 0) continue;\r\n        int c0 = st->topo.child0[p];\r\n        int cn = st->topo.child_count[p];\r\n"]
[112.212895, "o", "        if (cn > 0 && i >= c0 && i < c0 + cn) count++;\r\n    }\r\n    return count;\r\n}\r\n\r\nstatic void apply_reflux(SimState *st) {\r\n    for (int i = 0; i < st->bank.n_pending; i++) {\r\n        int leaf = st->bank.leaf[i];\r\n        if (leaf < 0 || leaf >= st->grid.n) continue;\r\n        double vol = st->grid.cells[leaf].vol;\r\n"]
[112.213034, "o", "        if (vol <= 0.0) continue;\r\n        for (int v = 0; v < NVAR; v++) {\r\n            st->grid.cells[leaf].q[v] += st->bank.flux[i * NVAR + v] / vol;\r\n        }\r\n    }\r\n}\r\n\r\nint run_u(const ScenarioSpec *spec, const char *mode, ScenarioOutcome *out) {\r\n    (void)mode;\r\n    memset(out, 0, sizeof(*out));\r\n    snprintf(out->name, sizeof(out->name), \"%s\", spec->name);\r\n\r\n    SimState st;\r\n    memset(&st, 0, sizeof(st));\r\n\r\n    CellGrid coarse;\r\n"]
[112.213072, "o", "    if (load_init(spec->profile, spec->n_coarse, &coarse) != 0) return -1;\r\n\r\n    double base[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        for (int v = 0; v < NVAR; v++) base[v] += coarse.cells[c].vol * coarse.cells[c].q[v];\r\n    }\r\n"]
[112.213219, "o", "\r\n    st.grid = coarse;\r\n    uint64_t fp = vault_fnv1a(spec->name, (int)strlen(spec->name), 0ull);\r\n    fp = vault_fnv1a(&spec->profile, (int)sizeof(int), fp);\r\n    fp = vault_fnv1a(&spec->n_coarse, (int)sizeof(int), fp);\r\n"]
[112.213279, "o", "    st.fingerprint_payload = fp;\r\n\r\n    phase_grow(&st, spec);\r\n\r\n    if (spec->do_restart) {\r\n"]
[112.213303, "o", "        VaultAudit aud;\r\n        memset(&aud, 0, sizeof(aud));\r\n        char vault[256];\r\n        char probe[256];\r\n        char logp[256];\r\n        snprintf(vault, sizeof(vault), \"%s/work/vault.bin\", app_root());\r\n        snprintf(probe, sizeof(probe), \"%s/work/vault_probe.bin\", app_root());\r\n"]
[112.213355, "o", "        snprintf(logp, sizeof(logp), \"%s/output/persistence_audit.log\", app_root());\r\n        phase_persist(&st, vault, probe, logp, &aud);\r\n    }\r\n\r\n    out->adjacency = compute_adjacency(&st);\r\n\r\n    apply_reflux(&st);\r\n\r\n    phase_fold(&st, spec);\r\n\r\n"]
[112.213383, "o", "    double after[NVAR] = {0.0, 0.0, 0.0};\r\n    double moment[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int i = 0; i < st.grid.n; i++) {\r\n        double vol = st.grid.cells[i].vol;\r\n        for (int v = 0; v < NVAR; v++) {\r\n"]
[112.21343, "o", "            double m = vol * st.grid.cells[i].q[v];\r\n            after[v] += m;\r\n            moment[v] += (double)(i + 1) * m;\r\n        }\r\n    }\r\n\r\n    int expected = 0;\r\n    if (spec->do_flux) {\r\n        for (int c = 0; c < spec->n_coarse; c++) {\r\n            if (spec->leaf_count[c] > 1) expected += spec->leaf_count[c];\r\n"]
[112.213458, "o", "        }\r\n    }\r\n"]
[112.21388, "o", "\r\n    double drift = 0.0;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        double denom = fabs(base[v]);\r\n        if (denom < 1e-12) denom = 1e-12;\r\n        double d = fabs(after[v] - base[v]) / denom;\r\n        if (d > drift) drift = d;\r\n    }\r\n\r\n    for (int v = 0; v < NVAR; v++) {\r\n        out->base_total[v] = base[v];\r\n        out->after_total[v] = after[v];\r\n        out->resumed_total[v] = moment[v];\r\n        out->halo_q[v] = st.halo_q[v];\r\n    }\r\n    out->drift_ratio = drift;\r\n    out->balanced = (st.bank.n_pending == expected) ? 1 : 0;\r\n    out->base_match = (drift < 1e-9) ? 1 : 0;\r\n    return 0;\r\n}\r\n"]
[112.213996, "o", "\u001b[?2004h"]
[112.21407, "o", "root@fb196c8d4778:/app# "]
[112.326837, "i", "sed -n '1,320p' /app/drv_u/run_refine.cpp\n"]
[112.327242, "o", "sed -n '1,320p' /app/drv_u/run_refine.cpp"]
[112.327366, "o", "\r\n\u001b[?2004l\r"]
[112.328817, "o", "#include \"phases.h\"\r\n#include \"../include/flow_record.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\r\n    CellGrid coarse = st->grid;\r\n    CellGrid leaves;\r\n    leaves.n = 0;\r\n    st->n_coarse = spec->n_coarse;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = spec->leaf_count[c];\r\n        if (k < 1) k = 1;\r\n        int sumw = 0;\r\n"]
[112.328897, "o", "        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\r\n        if (sumw <= 0) sumw = 1;\r\n        st->coarse_start[c] = leaves.n;\r\n        st->coarse_len[c] = k;\r\n        double vj[MAX_LEAVES];\r\n"]
[112.329143, "o", "        double vtot = 0.0;\r\n"]
[112.329235, "o", "        double jw = 0.0;\r\n"]
[112.329346, "o", "        for (int j = 0; j < k; j++) {\r\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\r\n            vtot += vj[j];\r\n            jw += vj[j] * (double)j;\r\n        }\r\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\r\n"]
[112.329554, "o", "        for (int j = 0; j < k; j++) {\r\n            int gi = leaves.n++;\r\n            leaves.cells[gi].idx = gi;\r\n            leaves.cells[gi].vol = vj[j];\r\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\r\n            }\r\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\r\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\r\n        }\r\n    }\r\n    st->grid = leaves;\r\n"]
[112.329772, "o", "\r\n    int changed[MAX_CELLS];\r\n    int nch = 0;\r\n    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\r\n    step_n(&st->grid, changed, nch, &st->topo);\r\n\r\n    st->bank.n_pending = 0;\r\n    if (!spec->do_flux) return;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = st->coarse_len[c];\r\n        if (k < 2) continue;\r\n        int start = st->coarse_start[c];\r\n        double vsum = 0.0;\r\n        double wq[NVAR] = {0.0, 0.0, 0.0};\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            vsum += cell->vol;\r\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\r\n        }\r\n        double qbar[NVAR];\r\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\r\n        EdgePulse ep;\r\n        ep.base_idx = start;\r\n        ep.subfaces = k;\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            for (int v = 0; v < NVAR; v++) {\r\n                ep.flux_vals[j * NVAR + v] =\r\n                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\r\n            }\r\n        }\r\n        op_m(&ep, &st->bank);\r\n    }\r\n}\r\n"]
[112.329916, "o", "\u001b[?2004hroot@fb196c8d4778:/app# "]
[112.445656, "i", "sed -n '1,320p' /app/drv_u/run_blend.cpp\n"]
[112.446861, "o", "sed -n '1,320p' /app/drv_u/run_blend.cpp\r\n\u001b[?2004l\r"]
[112.448134, "o", "#include \"phases.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_fold(SimState *st, const ScenarioSpec *spec) {\r\n    for (int v = 0; v < NVAR; v++) st->halo_q[v] = 0.0;\r\n\r\n    int seam = -1;\r\n    for (int c = 0; c < st->n_coarse; c++) {\r\n        if (st->coarse_len[c] > 1) { seam = c; break; }\r\n    }\r\n    if (seam >= 0) {\r\n        int start = st->coarse_start[seam];\r\n        int k = st->coarse_len[seam];\r\n        CellPatch src;\r\n        src.n = k;\r\n"]
[112.448201, "o", "        for (int j = 0; j < k && j < MAX_LEAVES; j++) {\r\n            src.vol[j] = st->grid.cells[start + j].vol;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                src.q[j * NVAR + v] = st->grid.cells[start + j].q[v];\r\n            }\r\n        }\r\n        CellPatch ghost;\r\n        memset(&ghost, 0, sizeof(ghost));\r\n        op_b(&ghost, &src, k, 1);\r\n        for (int v = 0; v < NVAR; v++) st->halo_q[v] = ghost.q[v];\r\n    }\r\n\r\n    if (!spec->do_collapse) return;"]
[112.448229, "o", "\r\n\r\n    CellGrid folded;\r\n    folded.n = 0;\r\n    for (int c = 0; c < st->n_coarse; c++) {\r\n        int start = st->coarse_start[c];"]
[112.44827, "o", "\r\n        int k = st->coarse_len[c];\r\n        int gi = folded.n++;\r\n        if (k < 2) {\r\n            folded.cells[gi] = st->grid.cells[start];\r\n            folded.cells[gi].idx = gi;\r\n            folded.cells[gi].tier = 0;\r\n            folded.cells[gi].parent = -1;\r\n            continue;"]
[112.448294, "o", "\r\n        }\r\n        CellPatch children;\r\n        children.n = k;\r\n        for (int j = 0; j < k && j < MAX_LEAVES; j++) {\r\n            children.vol[j] = st->grid.cells[start + j].vol;\r\n"]
[112.448319, "o", "            for (int v = 0; v < NVAR; v++) {\r\n                children.q[j * NVAR + v] = st->grid.cells[start + j].q[v];\r\n            }\r\n        }\r\n        CellPatch parent;\r\n        memset(&parent, 0, sizeof(parent));\r\n"]
[112.448373, "o", "        fold_q(&children, k, &parent);\r\n        folded.cells[gi].idx = gi;\r\n        folded.cells[gi].tier = 0;\r\n        folded.cells[gi].parent = -1;\r\n        folded.cells[gi].vol = parent.vol[0];\r\n        for (int v = 0; v < NVAR; v++) folded.cells[gi].q[v] = parent.q[v];\r\n    }\r\n    for (int c = 0; c < st->n_coarse; c++) {\r\n        st->coarse_start[c] = c;\r\n        st->coarse_len[c] = 1;\r\n    }\r\n    st->grid = folded;\r\n}\r\n"]
[112.448658, "o", "\u001b[?2004hroot@fb196c8d4778:/app# "]
[112.558672, "i", "sed -n '1,320p' /app/drv_u/run_sync.cpp\n"]
[112.559054, "o", "sed -n '1,320p' /app/drv_u/run_sync.cpp\r\n\u001b[?2004l\r"]
[112.560258, "o", "#include \"phases.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\nstatic int copy_with_flip(const char *src_path, const char *dst_path) {\r\n    FILE *in = fopen(src_path, \"rb\");\r\n    if (!in) return -1;\r\n    FILE *out = fopen(dst_path, \"wb\");\r\n    if (!out) { fclose(in); return -2; }\r\n    unsigned char buf[8192];\r\n"]
[112.562133, "o", "    size_t total = 0;\r\n    size_t r;\r\n    while ((r = fread(buf, 1, sizeof(buf), in)) > 0) {\r\n        if (total == 0 && r > 8) {\r\n            buf[8] ^= 0xFFu;\r\n        }\r\n        fwrite(buf, 1, r, out);\r\n        total += r;\r\n    }\r\n    fclose(in);\r\n    fclose(out);\r\n    return 0;\r\n}\r\n\r\nint phase_persist(SimState *st, const char *vault_path, const char *tamper_path,\r\n                  const char *log_path, VaultAudit *resume_aud) {\r\n    if (emit_p(st, vault_path) != 0) return -1;\r\n\r\n    FILE *log = fopen(log_path, \"a\");\r\n    if (copy_with_flip(vault_path, tamper_path) == 0) {\r\n        SimState probe = *st;\r\n        VaultAudit taud;\r\n        memset(&taud, 0, sizeof(taud));\r\n        load_k(tamper_path, &probe, &taud);\r\n        if (log) {\r\n            if (taud.reason == REASON_FINGERPRINT) {\r\n                fprintf(log, \"REJECTED reason=SIGNATURE_MISMATCH path=%s\\n\", tamper_path);\r\n            } else {\r\n                fprintf(log, \"ACCEPTED reason=%d path=%s\\n\", taud.reason, tamper_path);\r\n            }\r\n        }\r\n    }\r\n\r\n    int rc = load_k(vault_path, st, resume_aud);\r\n    if (log) {\r\n        if (resume_aud->reason == REASON_OK) {\r\n            fprintf(log, \"ACCEPTED reason=OK path=%s\\n\", vault_path);\r\n        } else {\r\n            fprintf(log, \"REJECTED reason=%d path=%s\\n\", resume_aud->reason, vault_path);\r\n        }\r\n        fclose(log);\r\n    }\r\n    return rc;\r\n}\r\n\u001b[?2004hroot@fb196c8d4778:/app# "]
[112.674625, "i", "sed -n '1,360p' /app/swp_t/sweep.cpp\n"]
[112.675129, "o", "sed -n '1,360p' /app/swp_t/sweep.cpp\r\n\u001b[?2004l\r"]
[112.677869, "o", "#include \"../include/cell_view.h\"\r\n\r\ntypedef void (*cell_fn)(CellView *, void *);\r\n\r\nvoid traverse_t(CellGrid *a, cell_fn fn, void *ctx) {\r\n    if (!a || !fn) return;\r\n    for (int i = 0; i < a->n; i++) {\r\n        fn(&a->cells[i], ctx);\r\n    }\r\n}\r\n\r\ndouble span_t(const CellGrid *a) {\r\n    if (!a || a->n == 0) return 0.0;\r\n    double lo = a->cells[0].vol;\r\n    double hi = a->cells[0].vol;\r\n    for (int i = 1; i < a->n; i++) {\r\n        double v = a->cells[i].vol;\r\n        if (v < lo) lo = v;\r\n        if (v > hi) hi = v;\r\n    }\r\n    return hi - lo;\r\n}\r\n\u001b[?2004hroot@fb196c8d4778:/app# "]
[112.794188, "i", "sed -n '1,260p' /app/lnk_n/relate.cpp\n"]
[112.794769, "o", "sed -n '1,260p' /app/lnk_n/relate.cpp\r\n\u001b[?2004l\r"]
[112.796298, "o", "#include \"../include/cell_view.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d) {\r\n    if (!a || !d) return -1;\r\n    int n = a->n;\r\n    for (int i = 0; i < n; i++) {\r\n        d->parent[i] = a->cells[i].parent;\r\n    }\r\n    if (b && c > 0) {\r\n        for (int i = 0; i < c && i < n; i++) {\r\n            int idx = b[i];\r\n            if (idx >= 0 && idx < n) {\r\n                d->parent[idx] = a->cells[idx].parent;\r\n            }\r\n        }\r\n    }\r\n    return 0;\r\n}\r\n\u001b[?2004hroot@fb196c8d4778:/app# "]
[112.910372, "i", "sed -n '1,260p' /app/acc_m/edge_corr.cpp\n"]
[112.910728, "o", "sed -n '1,260p' /app/acc_m/edge_corr.cpp\r\n"]
[112.910987, "o", "\u001b[?2004l\r"]
[112.912749, "o", "#include \"../include/flow_record.h\"\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b) {\r\n    if (!a || !b) return;\r\n    if (b->n_pending >= MAX_FACES) return;\r\n    int slot = b->n_pending++;\r\n    b->leaf[slot] = a->base_idx;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        b->flux[slot * NVAR + v] = a->flux_vals[v];\r\n    }\r\n}\r\n"]
[112.912957, "o", "\u001b[?2004hroot@fb196c8d4778:/app# "]
[113.026385, "i", "sed -n '1,260p' /app/rsm_k/resume.cpp\n"]
[113.026855, "o", "sed -n '1,260p' /app/rsm_k/resume.cpp\r\n\u001b[?2004l\r"]
[113.028548, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\nint load_k(const char *a, SimState *b, VaultAudit *c) {\r\n    if (!a || !b || !c) return -1;\r\n    memset(c, 0, sizeof(*c));\r\n    FILE *in = fopen(a, \"rb\");\r\n"]
[113.028589, "o", "    if (!in) {\r\n        c->reason = REASON_MISSING;\r\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\r\n        return -2;\r\n    }\r\n    VaultHeader hdr;\r\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\r\n        fclose(in);\r\n        c->reason = REASON_SHORT;\r\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\r\n        return -3;\r\n    }\r\n    if (hdr.magic != VAULT_MAGIC) {\r\n"]
[113.02875, "o", "        fclose(in);\r\n        c->reason = REASON_MAGIC;\r\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\r\n"]
[113.028839, "o", "        return -4;\r\n    }\r\n    int n_cells = 0;\r\n    fread(&n_cells, sizeof(int), 1, in);\r\n    b->grid.n = n_cells;\r\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\r\n    memset(&b->topo, 0, sizeof(b->topo));\r\n    b->bank.n_pending = 0;\r\n    fclose(in);\r\n    c->reason = REASON_OK;\r\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\r\n    return 0;\r\n}\r\n"]
