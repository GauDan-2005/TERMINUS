[113.140235, "o", "\r\n\u001b[?2004l\r"]
[113.141989, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdint.h>\r\n\r\nuint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed) {\r\n    const uint8_t *p = (const uint8_t *)data;\r\n    uint64_t h = 0xcbf29ce484222325ull ^ seed;\r\n    for (int i = 0; i < n_bytes; i++) {\r\n        h ^= (uint64_t)p[i];\r\n        h *= 0x100000001b3ull;\r\n    }\r\n    return h;\r\n}\r\n"]
[113.142207, "o", "\u001b[?2004hroot@fb196c8d4778:/app# "]
[113.254355, "i", "sed -n '1,260p' /app/srl_p/serial.cpp\n"]
