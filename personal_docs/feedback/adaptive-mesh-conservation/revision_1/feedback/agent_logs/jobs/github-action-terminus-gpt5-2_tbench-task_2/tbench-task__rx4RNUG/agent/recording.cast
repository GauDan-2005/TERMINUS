[281.171676, "i", "cat > /app/lnk_n/relate.cpp <<'EOF'\n#include \"../include/cell_view.h\"\n#include \"../include/topo_link.h\"\n\n#include <string.h>\n\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d) {\n    (void)b;\n    (void)c;\n    if (!a || !d) return -1;\n\n    int n = a->n;\n\n    // Initialize.\n    d->n_faces = 0;\n    for (int i = 0; i < n; i++) {\n        d->parent[i] = a->cells[i].parent;\n        d->child0[i] = -1;\n        d->child_count[i] = 0;\n    }\n\n    // Count children per parent.\n    for (int i = 0; i < n; i++) {\n        int p = d->parent[i];\n        if (p >= 0 && p < n) d->child_count[p]++;\n    }\n\n    // Assign contiguous child ranges in index order.\n    // For this toy driver the children of a parent are created consecutively,\n    // so we can use the first occurrence as child0.\n    for (int i = 0; i < n; i++) {\n        int p = d->parent[i];\n        if (p >= 0 && p < n) {\n            if (d->child0[p] < 0) d->child0[p] = i;\n        }\n    }\n\n    return 0;\n}\nEOF\n"]
[281.17198, "o", "cat > /app/lnk_n/relate.cpp <<'EOF'"]
