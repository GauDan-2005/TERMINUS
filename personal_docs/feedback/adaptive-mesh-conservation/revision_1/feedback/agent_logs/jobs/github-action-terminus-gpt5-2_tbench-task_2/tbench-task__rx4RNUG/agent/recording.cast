[280.174658, "o", "\u001b[?2004l\r"]
[280.174685, "o", "\u001b[?2004h> "]
[280.174833, "o", "print(p.read_text()[:2000])\r\n\u001b[?2004l\r"]
[280.174997, "o", "\u001b[?2004h> "]
[280.175076, "o", "PY\r\n\u001b[?2004l\r"]
[280.198725, "o", "#include \"phases.h\"\r\n#include \"../include/flow_record.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\r\n    CellGrid coarse = st->grid;\r\n    CellGrid leaves;\r\n    leaves.n = 0;\r\n    st->n_coarse = spec->n_coarse;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = spec->leaf_count[c];\r\n        if (k < 1) k = 1;\r\n        int sumw = 0;\r\n        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\r\n        if (sumw <= 0) sumw = 1;\r\n        st->coarse_start[c] = leaves.n;\r\n        st->coarse_len[c] = k;\r\n        double vj[MAX_LEAVES];\r\n        double vtot = 0.0;\r\n        double jw = 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\r\n            vtot += vj[j];\r\n            jw += vj[j] * (double)j;\r\n        }\r\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            int gi = leaves.n++;\r\n            leaves.cells[gi].idx = gi;\r\n            leaves.cells[gi].vol = vj[j];\r\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\r\n            }\r\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\r\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\r\n        }\r\n    }\r\n    st->grid = leaves;\r\n\r\n    int changed[MAX_CELLS];\r\n    int nch = 0;\r\n"]
[280.19891, "o", "    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\r\n    step_n(&st->grid, changed, nch, &st->topo);\r\n\r\n    st->bank.n_pending = 0;\r\n    if (!spec->do_flux) return;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = st->coarse_len[c];\r\n        if (k < 2) continue;\r\n        int start = st->coarse_start[c];\r\n        double vsum = 0.0;\r\n        double wq[NVAR] = {0.0, 0.0, 0.0};\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            vsum += cell->vol;\r\n      \r\n"]
[280.202915, "o", "\u001b[?2004hroot@fb196c8d4778:/app# "]
[280.667598, "i", "cat > /app/drv_u/run_refine.cpp <<'EOF'\n#include \"phases.h\"\n#include \"../include/flow_record.h\"\n#include \"../include/topo_link.h\"\n\n#include <string.h>\n\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\n    CellGrid coarse = st->grid;\n    CellGrid leaves;\n    leaves.n = 0;\n    st->n_coarse = spec->n_coarse;\n\n    for (int c = 0; c < spec->n_coarse; c++) {\n        int k = spec->leaf_count[c];\n        if (k < 1) k = 1;\n\n        int sumw = 0;\n        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\n        if (sumw <= 0) sumw = 1;\n\n        st->coarse_start[c] = leaves.n;\n        st->coarse_len[c] = k;\n\n        double vj[MAX_LEAVES];\n        double vtot = 0.0;\n        double jw = 0.0;\n        for (int j = 0; j < k; j++) {\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\n            vtot += vj[j];\n            jw += vj[j] * (double)j;\n        }\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\n\n        // Conservative split: distribute parent masses (vol*q) to children.\n        double parent_mass[NVAR];\n        for (int v = 0; v < NVAR; v++) parent_mass[v] = coarse.cells[c].vol * coarse.cells[c].q[v];\n\n        // Optional shape factor f, renormalized by volume so totals are preserved.\n        double fsum_vol = 0.0;\n        for (int j = 0; j < k; j++) {\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\n            if (f < 0.0) f = 0.0;\n            fsum_vol += vj[j] * f;\n        }\n        if (fsum_vol <= 0.0) fsum_vol = (vtot > 0.0) ? vtot : 1.0;\n\n        for (int j = 0; j < k; j++) {\n            int gi = leaves.n++;\n            leaves.cells[gi].idx = gi;\n            leaves.cells[gi].vol = vj[j];\n\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\n            if (f < 0.0) f = 0.0;\n\n            for (int v = 0; v < NVAR; v++) {\n                double m_child = parent_mass[v] * (vj[j] * f) / fsum_vol;\n                leaves.cells[gi].q[v] = (vj[j] > 0.0) ? (m_child / vj[j]) : 0.0;\n            }\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\n        }\n    }\n\n    st->grid = leaves;\n\n    int changed[MAX_CELLS];\n    int nch = 0;\n    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\n    step_n(&st->grid, changed, nch, &st->topo);\n\n    st->bank.n_pending = 0;\n    if (!spec->do_flux) return;\n\n    for (int c = 0; c < spec->n_coarse; c++) {\n        int k = st->coarse_len[c];\n        if (k < 2) continue;\n        int start = st->coarse_start[c];\n\n        double vsum = 0.0;\n        double wq[NVAR] = {0.0, 0.0, 0.0};\n        for (int j = 0; j < k; j++) {\n            const CellView *cell = &st->grid.cells[start + j];\n            vsum += cell->vol;\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\n        }\n        double qbar[NVAR];\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\n\n        // Enqueue one correction per leaf (FluxBank is leaf-indexed).\n        for (int j = 0; j < k; j++) {\n            const CellView *cell = &st->grid.cells[start + j];\n            EdgePulse ep;\n            memset(&ep, 0, sizeof(ep));\n            ep.base_idx = start + j;\n            ep.subfaces = 1;\n            for (int v = 0; v < NVAR; v++) {\n                ep.flux_vals[v] = REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\n            }\n            op_m(&ep, &st->bank);\n        }\n    }\n}\nEOF\n"]
[280.668007, "o", "cat > /app/drv_u/run_refine.cpp <<'EOF'\r\n\u001b[?2004l\r"]
