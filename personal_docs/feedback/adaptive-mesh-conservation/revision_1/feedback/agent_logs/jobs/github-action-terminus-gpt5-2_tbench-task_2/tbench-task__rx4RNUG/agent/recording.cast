[464.659655, "o", "\u001b[?2004l\r"]
[464.661384, "o", "#include \"../include/cell_view.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\nvoid op_b(CellPatch *a, const CellPatch *b, int c, int d) {\r\n    if (!a || !b) return;\r\n    int width = (b->n < 8) ? b->n : 8;\r\n    a->n = width;\r\n    for (int i = 0; i < width; i++) {\r\n        int src = i + d;\r\n        if (src < 0) src = 0;\r\n        if (src >= b->n) src = b->n - 1;\r\n        a->vol[i] = b->vol[src];\r\n        for (int v = 0; v < NVAR; v++) {\r\n            a->q[i * NVAR + v] = b->q[src * NVAR + v];\r\n        }\r\n    }\r\n    (void)c;\r\n}\r\n\u001b[?2004hroot@fb196c8d4778:/app# "]
[464.778955, "i", "cat > /app/agg_q/blend.cpp <<'EOF'\n#include \"../include/cell_view.h\"\n\n#include <string.h>\n\n// Conservative merge (collapse): fold fine leaves into a parent.\n// Preserve integrated quantities for each tracked variable.\nvoid fold_q(const CellPatch *a, int n, CellPatch *out) {\n    if (!a || !out) return;\n\n    int k = n;\n    if (k > a->n) k = a->n;\n    if (k > MAX_LEAVES) k = MAX_LEAVES;\n\n    if (k <= 0) {\n        memset(out, 0, sizeof(*out));\n        return;\n    }\n\n    double vtot = 0.0;\n    double mass[NVAR];\n    for (int v = 0; v < NVAR; v++) mass[v] = 0.0;\n\n    for (int i = 0; i < k; i++) {\n        double vol = a->vol[i];\n        if (vol <= 0.0) continue;\n        vtot += vol;\n        for (int v = 0; v < NVAR; v++) {\n            mass[v] += vol * a->q[i * NVAR + v];\n        }\n    }\n\n    memset(out, 0, sizeof(*out));\n    out->n = 1;\n    out->vol[0] = vtot;\n    for (int v = 0; v < NVAR; v++) {\n        out->q[v] = (vtot > 0.0) ? (mass[v] / vtot) : 0.0;\n    }\n}\nEOF\n"]
