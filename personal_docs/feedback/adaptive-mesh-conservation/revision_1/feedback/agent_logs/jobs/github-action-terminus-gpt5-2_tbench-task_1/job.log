Sending keys: ['cat > /app/drv_u/run_refine.cpp <<\'EOF\'\n#include "phases.h"\n#include "../include/flow_record.h"\n#include "../include/topo_link.h"\n\n#include <math.h>\n#include <string.h>\n\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\n    CellGrid coarse = st->grid;\n    CellGrid leaves;\n    leaves.n = 0;\n    st->n_coarse = spec->n_coarse;\n\n    for (int c = 0; c < spec->n_coarse; c++) {\n        int k = spec->leaf_count[c];\n        if (k < 1) k = 1;\n\n        int sumw = 0;\n        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\n        if (sumw <= 0) sumw = 1;\n\n        st->coarse_start[c] = leaves.n;\n        st->coarse_len[c] = k;\n\n        double vj[MAX_LEAVES];\n        double vtot = 0.0;\n        double jw = 0.0;\n        for (int j = 0; j < k; j++) {\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\n            vtot += vj[j];\n            jw += vj[j] * (double)j;\n        }\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\n\n        // Conservative prolongation: after shaping q across leaves, renormalize so\n        // sum_j vol_j * q_j == coarse.vol * coarse.q for each variable.\n        double want_m[NVAR] = {0.0, 0.0, 0.0};\n        for (int v = 0; v < NVAR; v++) want_m[v] = coarse.cells[c].vol * coarse.cells[c].q[v];\n\n        double got_m[NVAR] = {0.0, 0.0, 0.0};\n\n        for (int j = 0; j < k; j++) {\n            int gi = leaves.n++;\n            leaves.cells[gi].idx = gi;\n            leaves.cells[gi].vol = vj[j];\n\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\n            for (int v = 0; v < NVAR; v++) {\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\n                got_m[v] += vj[j] * leaves.cells[gi].q[v];\n            }\n\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\n        }\n\n        int start = st->coarse_start[c];\n        for (int v = 0; v < NVAR; v++) {\n            double scale = 1.0;\n            if (fabs(got_m[v]) > 1e-30) {\n                scale = want_m[v] / got_m[v];\n                for (int j = 0; j < k; j++) {\n                    leaves.cells[start + j].q[v] *= scale;\n                }\n            } else {\n                // Degenerate: ensure exact conservation by setting all leaves to coarse value.\n                for (int j = 0; j < k; j++) {\n                    leaves.cells[start + j].q[v] = coarse.cells[c].q[v];\n                }\n            }\n        }\n    }\n\n    st->grid = leaves;\n\n    int changed[MAX_CELLS];\n    int nch = 0;\n    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\n    step_n(&st->grid, changed, nch, &st->topo);\n\n    st->bank.n_pending = 0;\n    if (!spec->do_flux) return;\n\n    for (int c = 0; c < spec->n_coarse; c++) {\n        int k = st->coarse_len[c];\n        if (k < 2) continue;\n        int start = st->coarse_start[c];\n\n        double vsum = 0.0;\n        double wq[NVAR] = {0.0, 0.0, 0.0};\n        for (int j = 0; j < k; j++) {\n            const CellView *cell = &st->grid.cells[start + j];\n            vsum += cell->vol;\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\n        }\n        double qbar[NVAR];\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\n\n        EdgePulse ep;\n        ep.base_idx = start;\n        ep.subfaces = k;\n        for (int j = 0; j < k; j++) {\n            const CellView *cell = &st->grid.cells[start + j];\n            for (int v = 0; v < NVAR; v++) {\n                ep.flux_vals[j * NVAR + v] =\n                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\n            }\n        }\n        op_m(&ep, &st->bank);\n    }\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ['cat > /app/srl_p/serial.cpp <<\'EOF\'\n#include "../include/vault_layout.h"\n\n#include <stdio.h>\n\nint emit_p(const SimState *a, const char *b) {\n    if (!a || !b) return -1;\n    FILE *fp = fopen(b, "wb");\n    if (!fp) return -2;\n\n    VaultHeader hdr;\n    hdr.magic = VAULT_MAGIC;\n    hdr.version = VAULT_VERSION;\n    hdr.fingerprint = a->fingerprint_payload;\n    hdr.build_stamp = (uint64_t)BUILD_STAMP;\n\n    if (fwrite(&hdr, sizeof(hdr), 1, fp) != 1) { fclose(fp); return -3; }\n\n    int n_cells = a->grid.n;\n    if (fwrite(&n_cells, sizeof(int), 1, fp) != 1) { fclose(fp); return -4; }\n    if (fwrite(a->grid.cells, sizeof(CellView), n_cells, fp) != (size_t)n_cells) { fclose(fp); return -5; }\n\n    if (fwrite(&a->topo, sizeof(a->topo), 1, fp) != 1) { fclose(fp); return -6; }\n    if (fwrite(&a->bank, sizeof(a->bank), 1, fp) != 1) { fclose(fp); return -7; }\n\n    if (fwrite(&a->n_coarse, sizeof(int), 1, fp) != 1) { fclose(fp); return -8; }\n    if (fwrite(a->coarse_start, sizeof(int), MAX_CELLS, fp) != MAX_CELLS) { fclose(fp); return -9; }\n    if (fwrite(a->coarse_len, sizeof(int), MAX_CELLS, fp) != MAX_CELLS) { fclose(fp); return -10; }\n\n    if (fwrite(&a->step_idx, sizeof(int), 1, fp) != 1) { fclose(fp); return -11; }\n    if (fwrite(&a->dt_carry, sizeof(double), 1, fp) != 1) { fclose(fp); return -12; }\n\n    if (fwrite(&a->fingerprint_payload, sizeof(uint64_t), 1, fp) != 1) { fclose(fp); return -13; }\n    if (fwrite(&a->adjacency, sizeof(int), 1, fp) != 1) { fclose(fp); return -14; }\n    if (fwrite(a->halo_q, sizeof(double), NVAR, fp) != NVAR) { fclose(fp); return -15; }\n\n    fclose(fp);\n    return 0;\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ['cat > /app/rsm_k/resume.cpp <<\'EOF\'\n#include "../include/vault_layout.h"\n\n#include <stdio.h>\n#include <string.h>\n\nstatic int short_read(FILE *in, VaultAudit *c, const char *what, int rc) {\n    if (in) fclose(in);\n    c->reason = REASON_SHORT;\n    snprintf(c->msg, sizeof(c->msg), "%s short", what);\n    return rc;\n}\n\nint load_k(const char *a, SimState *b, VaultAudit *c) {\n    if (!a || !b || !c) return -1;\n    memset(c, 0, sizeof(*c));\n\n    FILE *in = fopen(a, "rb");\n    if (!in) {\n        c->reason = REASON_MISSING;\n        snprintf(c->msg, sizeof(c->msg), "open failed");\n        return -2;\n    }\n\n    VaultHeader hdr;\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\n        return short_read(in, c, "header", -3);\n    }\n    if (hdr.magic != VAULT_MAGIC) {\n        fclose(in);\n        c->reason = REASON_MAGIC;\n        snprintf(c->msg, sizeof(c->msg), "bad magic 0x%x", hdr.magic);\n        return -4;\n    }\n    if (hdr.version != VAULT_VERSION) {\n        fclose(in);\n        c->reason = REASON_VERSION;\n        snprintf(c->msg, sizeof(c->msg), "bad version %u", hdr.version);\n        return -5;\n    }\n\n    // Fingerprint check: expected fingerprint is provided by current run inputs.\n    if (hdr.fingerprint != b->fingerprint_payload) {\n        fclose(in);\n        c->reason = REASON_FINGERPRINT;\n        snprintf(c->msg, sizeof(c->msg), "fingerprint mismatch");\n        return -6;\n    }\n\n    int n_cells = 0;\n    if (fread(&n_cells, sizeof(int), 1, in) != 1) {\n        return short_read(in, c, "n_cells", -7);\n    }\n    if (n_cells < 0 || n_cells > MAX_CELLS) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), "n_cells out of range");\n        return -8;\n    }\n\n    b->grid.n = n_cells;\n    if (fread(b->grid.cells, sizeof(CellView), n_cells, in) != (size_t)n_cells) {\n        return short_read(in, c, "cells", -9);\n    }\n    if (fread(&b->topo, sizeof(b->topo), 1, in) != 1) {\n        return short_read(in, c, "topo", -10);\n    }\n    if (fread(&b->bank, sizeof(b->bank), 1, in) != 1) {\n        return short_read(in, c, "bank", -11);\n    }\n\n    if (fread(&b->n_coarse, sizeof(int), 1, in) != 1) {\n        return short_read(in, c, "n_coarse", -12);\n    }\n    if (fread(b->coarse_start, sizeof(int), MAX_CELLS, in) != MAX_CELLS) {\n        return short_read(in, c, "coarse_start", -13);\n    }\n    if (fread(b->coarse_len, sizeof(int), MAX_CELLS, in) != MAX_CELLS) {\n        return short_read(in, c, "coarse_len", -14);\n    }\n\n    if (fread(&b->step_idx, sizeof(int), 1, in) != 1) {\n        return short_read(in, c, "step_idx", -15);\n    }\n    if (fread(&b->dt_carry, sizeof(double), 1, in) != 1) {\n        return short_read(in, c, "dt_carry", -16);\n    }\n\n    uint64_t fp_payload = 0;\n    if (fread(&fp_payload, sizeof(uint64_t), 1, in) != 1) {\n        return short_read(in, c, "payload_fingerprint", -17);\n    }\n    if (fp_payload != b->fingerprint_payload) {\n        fclose(in);\n        c->reason = REASON_FINGERPRINT;\n        snprintf(c->msg, sizeof(c->msg), "payload fingerprint mismatch");\n        return -18;\n    }\n\n    if (fread(&b->adjacency, sizeof(int), 1, in) != 1) {\n        return short_read(in, c, "adjacency", -19);\n    }\n    if (fread(b->halo_q, sizeof(double), NVAR, in) != NVAR) {\n        return short_read(in, c, "halo_q", -20);\n    }\n\n    fclose(in);\n    c->reason = REASON_OK;\n    snprintf(c->msg, sizeof(c->msg), "ok");\n    return 0;\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
