[?2004l[?2004h> void fold_q(const CellPatch *a, int b, CellPatch *c) {
[?2004l[?2004h>     if (!a || !c) return;
[?2004l[?2004h>     int n = (a->n < b) ? a->n : b;
[?2004l[?2004h>     if (n <= 0) {
[?2004l[?2004h>         c->n = 0;
[?2004l[?2004h>         return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     // Conservative restriction: preserve volume-integrated quantities.
[?2004l[?2004h>     // a->q stores per-volume state; conserved totals are vol*q.
[?2004l[?2004h>     double sum_vol = 0.0;
[?2004l[?2004h>     double sum_m[NVAR] = {0.0, 0.0, 0.0};
[?2004l[?2004h>     for (int i = 0; i < n; i++) {
