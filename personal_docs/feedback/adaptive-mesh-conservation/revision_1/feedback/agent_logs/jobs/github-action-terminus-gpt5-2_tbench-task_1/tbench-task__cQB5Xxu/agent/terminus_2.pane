[?2004l[?2004h>         for (int v = 0; v < NVAR; v++) {
[?2004l[?2004h>             sum_m[v] += a->vol[i] * a->q[i * NVAR + v];
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     c->n = 1;
[?2004l[?2004h>     c->vol[0] = sum_vol;
[?2004l[?2004h>     for (int v = 0; v < NVAR; v++) {
[?2004l[?2004h>         c->q[v] = (sum_vol > 0.0) ? (sum_m[v] / sum_vol) : 0.0;
[?2004l[?2004h>     }
[?2004l[?2004h> }
