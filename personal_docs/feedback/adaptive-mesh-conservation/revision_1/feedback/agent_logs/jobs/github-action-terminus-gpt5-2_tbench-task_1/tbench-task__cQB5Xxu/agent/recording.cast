[176.718272, "i", "sed -n '1,260p' /app/include/flow_record.h\n"]
[176.718758, "o", "sed -n '1,260p' /app/include/flow_record.h\r\n\u001b[?2004l\r"]
[176.721372, "o", "#ifndef FLOW_RECORD_H\r\n#define FLOW_RECORD_H\r\n\r\n#include \"cell_view.h\"\r\n\r\nstruct EdgePulse {\r\n    int base_idx;\r\n    int subfaces;\r\n    double flux_vals[MAX_LEAVES * NVAR];\r\n};\r\n"]
[176.721533, "o", "\r\nstruct FluxBank {\r\n    int n_pending;\r\n    int leaf[MAX_FACES];\r\n    double flux[MAX_FACES * NVAR];\r\n};\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b);\r\n\r\n#endif\r\n"]
[176.721673, "o", "\u001b[?2004hroot@6362f560e0ae:/app# "]
[177.218518, "i", "sed -n '1,260p' /app/acc_m/edge_corr.cpp\n"]
[177.218879, "o", "sed -n '1,260p' /app/acc_m/edge_corr.cpp"]
[177.219224, "o", "\r\n\u001b[?2004l\r"]
[177.220419, "o", "#include \"../include/flow_record.h\"\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b) {\r\n    if (!a || !b) return;\r\n    if (b->n_pending >= MAX_FACES) return;\r\n    int slot = b->n_pending++;\r\n"]
[177.220515, "o", "    b->leaf[slot] = a->base_idx;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        b->flux[slot * NVAR + v] = a->flux_vals[v];\r\n    }\r\n}\r\n"]
[177.220671, "o", "\u001b[?2004h"]
[177.220701, "o", "root@6362f560e0ae:/app# "]
[177.705587, "i", "sed -n '1,260p' /app/include/cell_view.h\n"]
[177.706575, "o", "sed -n '1,260p' /app/include/cell_view.h"]
[177.706734, "o", "\r\n\u001b[?2004l\r"]
[177.708976, "o", "#ifndef CELL_VIEW_H\r\n#define CELL_VIEW_H\r\n\r\n#include <stdint.h>\r\n\r\n#define NVAR 3\r\n#define MAX_CELLS 384\r\n#define MAX_FACES 768\r\n#define MAX_LEAVES 8\r\n#define REFLUX_RATE 0.25\r\n"]
[177.709023, "o", "#define LEAF_SPREAD 0.1\r\n\r\nstruct CellView {\r\n    int idx;\r\n    int tier;\r\n    int parent;\r\n    double vol;\r\n    double q[NVAR];\r\n};\r\n\r\nstruct CellGrid {\r\n    CellView cells[MAX_CELLS];\r\n    int n;\r\n};\r\n\r\nstruct CellPatch {\r\n    int n;\r\n    double vol[MAX_LEAVES];\r\n    double q[MAX_LEAVES * NVAR];\r\n};\r\n"]
[177.709049, "o", "\r\nvoid fold_q(const CellPatch *a, int b, CellPatch *c);\r\n\r\n#endif\r\n"]
[177.709299, "o", "\u001b[?2004hroot@6362f560e0ae:/app# "]
[178.205512, "i", "sed -n '1,260p' /app/include/topo_link.h\n"]
[178.206698, "o", "sed -n '1,260p' /app/include/topo_link.h\r\n\u001b[?2004l\r"]
[178.207577, "o", "#ifndef TOPO_LINK_H\r\n#define TOPO_LINK_H\r\n\r\n#include \"cell_view.h\"\r\n\r\nstruct TopoLink {\r\n    int n_faces;\r\n    int face_left[MAX_FACES];\r\n    int face_right[MAX_FACES];\r\n    int face_level[MAX_FACES];\r\n    int parent[MAX_CELLS];\r\n    int child0[MAX_CELLS];\r\n    int child_count[MAX_CELLS];\r\n};\r\n"]
[178.207682, "o", "\r\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d);\r\nvoid op_b(CellPatch *a, const CellPatch *b, int c, int d);\r\n\r\n#endif\r\n"]
[178.208607, "o", "\u001b[?2004hroot@6362f560e0ae:/app# "]
[178.714545, "i", "sed -n '1,220p' /app/drv_u/run.cpp\n"]
[178.715168, "o", "sed -n '1,220p' /app/drv_u/run.cpp\r\n\u001b[?2004l\r"]
[178.716912, "o", "#include \"phases.h\"\r\n#include \"../include/ic_loader.h\"\r\n\r\n#include <math.h>\r\n#include <string.h>\r\n#include <stdio.h>\r\n\r\nstatic int compute_adjacency(const SimState *st) {\r\n    int count = 0;\r\n    for (int i = 0; i < st->grid.n; i++) {\r\n        int p = st->topo.parent[i];\r\n"]
[178.716964, "o", "        if (p < 0) continue;\r\n        int c0 = st->topo.child0[p];\r\n        int cn = st->topo.child_count[p];\r\n        if (cn > 0 && i >= c0 && i < c0 + cn) count++;\r\n    }\r\n    return count;\r\n}\r\n\r\nstatic void apply_reflux(SimState *st) {\r\n    for (int i = 0; i < st->bank.n_pending; i++) {\r\n        int leaf = st->bank.leaf[i];\r\n        if (leaf < 0 || leaf >= st->grid.n) continue;\r\n        double vol = st->grid.cells[leaf].vol;\r\n        if (vol <= 0.0) continue;\r\n        for (int v = 0; v < NVAR; v++) {\r\n            st->grid.cells[leaf].q[v] += st->bank.flux[i * NVAR + v] / vol;\r\n"]
[178.71707, "o", "        }\r\n    }\r\n}\r\n\r\nint run_u(const ScenarioSpec *spec, const char *mode, ScenarioOutcome *out) {\r\n    (void)mode;\r\n    memset(out, 0, sizeof(*out));\r\n    snprintf(out->name, sizeof(out->name), \"%s\", spec->name);\r\n\r\n    SimState st;\r\n    memset(&st, 0, sizeof(st));\r\n\r\n    CellGrid coarse;\r\n    if (load_init(spec->profile, spec->n_coarse, &coarse) != 0) return -1;\r\n\r\n    double base[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        for (int v = 0; v < NVAR; v++) base[v] += coarse.cells[c].vol * coarse.cells[c].q[v];\r\n    }\r\n\r\n    st.grid = coarse;\r\n    uint64_t fp = vault_fnv1a(spec->name, (int)strlen(spec->name), 0ull);\r\n    fp = vault_fnv1a(&spec->profile, (int)sizeof(int), fp);\r\n    fp = vault_fnv1a(&spec->n_coarse, (int)sizeof(int), fp);\r\n    st.fingerprint_payload = fp;\r\n"]
[178.71723, "o", "\r\n    phase_grow(&st, spec);\r\n\r\n    if (spec->do_restart) {\r\n        VaultAudit aud;\r\n        memset(&aud, 0, sizeof(aud));\r\n        char vault[256];\r\n        char probe[256];\r\n        char logp[256];\r\n        snprintf(vault, sizeof(vault), \"%s/work/vault.bin\", app_root());\r\n        snprintf(probe, sizeof(probe), \"%s/work/vault_probe.bin\", app_root());\r\n        snprintf(logp, sizeof(logp), \"%s/output/persistence_audit.log\", app_root());\r\n        phase_persist(&st, vault, probe, logp, &aud);\r\n    }\r\n\r\n    out->adjacency = compute_adjacency(&st);\r\n\r\n    apply_reflux(&st);\r\n\r\n    phase_fold(&st, spec);\r\n\r\n    double after[NVAR] = {0.0, 0.0, 0.0};\r\n    double moment[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int i = 0; i < st.grid.n; i++) {\r\n        double vol = st.grid.cells[i].vol;\r\n        for (int v = 0; v < NVAR; v++) {\r\n            double m = vol * st.grid.cells[i].q[v];\r\n            after[v] += m;\r\n            moment[v] += (double)(i + 1) * m;\r\n        }\r\n"]
[178.717261, "o", "    }\r\n\r\n    int expected = 0;\r\n    if (spec->do_flux) {\r\n        for (int c = 0; c < spec->n_coarse; c++) {\r\n            if (spec->leaf_count[c] > 1) expected += spec->leaf_count[c];\r\n        }\r\n    }\r\n\r\n    double drift = 0.0;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        double denom = fabs(base[v]);\r\n        if (denom < 1e-12) denom = 1e-12;\r\n        double d = fabs(after[v] - base[v]) / denom;\r\n        if (d > drift) drift = d;\r\n    }\r\n\r\n    for (int v = 0; v < NVAR; v++) {\r\n        out->base_total[v] = base[v];\r\n        out->after_total[v] = after[v];\r\n        out->resumed_total[v] = moment[v];\r\n        out->halo_q[v] = st.halo_q[v];\r\n    }\r\n    out->drift_ratio = drift;\r\n    out->balanced = (st.bank.n_pending == expected) ? 1 : 0;\r\n    out->base_match = (drift < 1e-9) ? 1 : 0;\r\n    return 0;\r\n}\r\n"]
[178.717698, "o", "\u001b[?2004hroot@6362f560e0ae:/app# "]
[187.506631, "i", "cat > /app/acc_m/edge_corr.cpp <<'EOF'\n#include \"../include/flow_record.h\"\n\nvoid op_m(const EdgePulse *a, FluxBank *b) {\n    if (!a || !b) return;\n    if (a->subfaces <= 0) return;\n\n    // Store one correction per subface (leaf). Each stored flux is a conserved\n    // delta (e.g., vol * delta_q), applied later as q += flux/vol.\n    for (int j = 0; j < a->subfaces; j++) {\n        if (b->n_pending >= MAX_FACES) return;\n        int slot = b->n_pending++;\n        b->leaf[slot] = a->base_idx + j;\n        for (int v = 0; v < NVAR; v++) {\n            b->flux[slot * NVAR + v] = a->flux_vals[j * NVAR + v];\n        }\n    }\n}\nEOF\n"]
[187.506973, "o", "cat > /app/acc_m/edge_corr.cpp <<'EOF'"]
