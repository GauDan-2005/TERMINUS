[30.314695, "o", "\r\n#include <stdint.h>\r\n\r\nuint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed) {\r\n    const uint8_t *p = (const uint8_t *)data;\r\n    uint64_t h = 0xcbf29ce484222325ull ^ seed;\r\n    for (int i = 0; i < n_bytes; i++) {\r\n        h ^= (uint64_t)p[i];\r\n        h *= 0x100000001b3ull;\r\n    }\r\n    return h;\r\n}\r\n\u001b[?2004hroot@6362f560e0ae:/app# "]
