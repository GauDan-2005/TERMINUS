[109.873568, "o", "> "]
[109.874153, "o", "     if (!a || !b) return -1;\r\n\u001b[?2004l\r\u001b[?2004h>      FILE *fp = fopen(b, \"wb\");\r\n\u001b[?2004l\r\u001b[?2004h>      if (!fp) return -2;\r\n\u001b[?2004l\r\u001b[?2004h> @@\r\n\u001b[?2004l\r\u001b[?2004h> "]
[109.874271, "o", "-    fwrite(&hdr, sizeof(hdr), 1, fp);\r\n\u001b[?2004l\r\u001b[?2004h"]
[109.874348, "o", "> "]
[109.874436, "o", "-    int n_cells = a->grid.n;\r\n\u001b[?2004l\r\u001b[?2004h"]
[109.874503, "o", "> "]
[109.874624, "o", "-    fwrite(&n_cells, sizeof(int), 1, fp);\r\n\u001b[?2004l\r"]
[109.874716, "o", "\u001b[?2004h> "]
[109.874884, "o", "-    fwrite(a->grid.cells, sizeof(CellView), n_cells, fp);\r\n\u001b[?2004l\r"]
[109.874923, "o", "\u001b[?2004h> "]
[109.875221, "o", "+    if (fwrite(&hdr, sizeof(hdr), 1, fp) != 1) { fclose(fp); return -3; }\r\n\u001b[?2004l\r"]
[109.875258, "o", "\u001b[?2004h> +\r\n"]
[109.875294, "o", "\u001b[?2004l\r"]
[109.875318, "o", "\u001b[?2004h> "]
[109.875754, "o", "+    // Persist enough state to make a restart equivalent to an uninterrupted run."]
[109.875893, "o", "\r\n\u001b[?2004l\r"]
[109.876195, "o", "\u001b[?2004h> "]
[109.876382, "o", "+    // Keep the layout explicit to avoid padding surprises.\r\n\u001b[?2004l\r"]
[109.87649, "o", "\u001b[?2004h"]
[109.876619, "o", "> "]
[109.876757, "o", "+    int n_cells = a->grid.n;\r\n\u001b[?2004l\r"]
[109.876927, "o", "\u001b[?2004h> "]
[109.877186, "o", "+    if (fwrite(&n_cells, sizeof(int), 1, fp) != 1) { fclose(fp); return -4; }\r\n\u001b[?2004l\r"]
[109.877353, "o", "\u001b[?2004h> "]
[109.877687, "o", "+    if (fwrite(a->grid.cells, sizeof(CellView), n_cells, fp) != (size_t)n_cells) { fclose(fp); return -5; }\r\n\u001b[?2004l\r"]
[109.877806, "o", "\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[109.878102, "o", "+    if (fwrite(&a->topo, sizeof(a->topo), 1, fp) != 1) { fclose(fp); return -6; }\r\n\u001b[?2004l\r"]
[109.878202, "o", "\u001b[?2004h> "]
[109.878436, "o", "+    if (fwrite(&a->bank, sizeof(a->bank), 1, fp) != 1) { fclose(fp); return -7; }\r\n\u001b[?2004l\r"]
[109.878468, "o", "\u001b[?2004h> "]
[109.878493, "o", "+\r\n\u001b[?2004l\r"]
[109.878519, "o", "\u001b[?2004h"]
[109.878545, "o", "> "]
[109.87881, "o", "+    if (fwrite(&a->n_coarse, sizeof(int), 1, fp) != 1) { fclose(fp); return -8; }\r\n\u001b[?2004l\r"]
[109.878847, "o", "\u001b[?2004h> "]
[109.879161, "o", "+    if (fwrite(a->coarse_start, sizeof(int), MAX_CELLS, fp) != MAX_CELLS) { fclose(fp); return -9; }\r\n\u001b[?2004l\r"]
[109.8792, "o", "\u001b[?2004h> "]
[109.879509, "o", "+    if (fwrite(a->coarse_len, sizeof(int), MAX_CELLS, fp) != MAX_CELLS) { fclose(fp); return -10; }\r\n\u001b[?2004l\r"]
[109.879543, "o", "\u001b[?2004h> "]
[109.879568, "o", "+\r\n\u001b[?2004l\r"]
[109.879593, "o", "\u001b[?2004h"]
[109.879617, "o", "> "]
[109.879892, "o", "+    if (fwrite(&a->step_idx, sizeof(int), 1, fp) != 1) { fclose(fp); return -11; }\r\n\u001b[?2004l\r"]
[109.879977, "o", "\u001b[?2004h> "]
[109.880243, "o", "+    if (fwrite(&a->dt_carry, sizeof(double), 1, fp) != 1) { fclose(fp); return -12; }\r\n\u001b[?2004l\r"]
[109.880279, "o", "\u001b[?2004h> "]
[109.880544, "o", "+    if (fwrite(&a->adjacency, sizeof(int), 1, fp) != 1) { fclose(fp); return -13; }\r\n\u001b[?2004l\r"]
[109.88066, "o", "\u001b[?2004h> "]
[109.880875, "o", "+    if (fwrite(a->halo_q, sizeof(double), NVAR, fp) != NVAR) { fclose(fp); return -14; }\r\n\u001b[?2004l\r"]
[109.880963, "o", "\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h"]
[109.881043, "o", "> "]
[109.881315, "o", "+    if (fwrite(&a->fingerprint_payload, sizeof(uint64_t), 1, fp) != 1) { fclose(fp); return -15; }\r\n\u001b[?2004l\r"]
[109.881346, "o", "\u001b[?2004h> "]
[109.88143, "o", "     fclose(fp);"]
[109.881497, "o", "\r\n"]
[109.881618, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[109.881715, "o", "     return 0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[109.8818, "o", ">  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[109.881881, "o", "*** End Patch"]
[109.881929, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[109.882006, "o", "PATCH\r\n\u001b[?2004l\r"]
[109.882323, "o", "bash: apply_patch: command not found\r\n"]
[109.88255, "o", "\u001b[?2004hroot@6362f560e0ae:/app# "]
[110.887779, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: rsm_k/resume.cpp\n@@\n int load_k(const char *a, SimState *b, VaultAudit *c) {\n@@\n     VaultHeader hdr;\n     if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\n@@\n     }\n     if (hdr.magic != VAULT_MAGIC) {\n@@\n     }\n+    if (hdr.version != VAULT_VERSION) {\n+        fclose(in);\n+        c->reason = REASON_VERSION;\n+        snprintf(c->msg, sizeof(c->msg), \"bad version %u\", hdr.version);\n+        return -5;\n+    }\n+\n+    // Fingerprint check: caller pre-populates b->fingerprint_payload based on inputs.\n+    if (hdr.fingerprint != b->fingerprint_payload) {\n+        fclose(in);\n+        c->reason = REASON_FINGERPRINT;\n+        snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\n+        return -6;\n+    }\n@@\n     int n_cells = 0;\n-    fread(&n_cells, sizeof(int), 1, in);\n+    if (fread(&n_cells, sizeof(int), 1, in) != 1) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"n_cells short\");\n+        return -7;\n+    }\n     b->grid.n = n_cells;\n-    fread(b->grid.cells, sizeof(CellView), n_cells, in);\n-    memset(&b->topo, 0, sizeof(b->topo));\n-    b->bank.n_pending = 0;\n+    if (n_cells < 0 || n_cells > MAX_CELLS) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"n_cells out of range\");\n+        return -8;\n+    }\n+    if (fread(b->grid.cells, sizeof(CellView), n_cells, in) != (size_t)n_cells) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"cells short\");\n+        return -9;\n+    }\n+\n+    if (fread(&b->topo, sizeof(b->topo), 1, in) != 1) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"topo short\");\n+        return -10;\n+    }\n+    if (fread(&b->bank, sizeof(b->bank), 1, in) != 1) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"bank short\");\n+        return -11;\n+    }\n+\n+    if (fread(&b->n_coarse, sizeof(int), 1, in) != 1) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"n_coarse short\");\n+        return -12;\n+    }\n+    if (fread(b->coarse_start, sizeof(int), MAX_CELLS, in) != MAX_CELLS) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"coarse_start short\");\n+        return -13;\n+    }\n+    if (fread(b->coarse_len, sizeof(int), MAX_CELLS, in) != MAX_CELLS) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"coarse_len short\");\n+        return -14;\n+    }\n+    if (fread(&b->step_idx, sizeof(int), 1, in) != 1) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"step_idx short\");\n+        return -15;\n+    }\n+    if (fread(&b->dt_carry, sizeof(double), 1, in) != 1) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"dt_carry short\");\n+        return -16;\n+    }\n+    if (fread(&b->adjacency, sizeof(int), 1, in) != 1) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"adjacency short\");\n+        return -17;\n+    }\n+    if (fread(b->halo_q, sizeof(double), NVAR, in) != NVAR) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"halo_q short\");\n+        return -18;\n+    }\n+    uint64_t fp_payload = 0;\n+    if (fread(&fp_payload, sizeof(uint64_t), 1, in) != 1) {\n+        fclose(in);\n+        c->reason = REASON_SHORT;\n+        snprintf(c->msg, sizeof(c->msg), \"payload fp short\");\n+        return -19;\n+    }\n+    // Stored payload fingerprint should match as well.\n+    if (fp_payload != b->fingerprint_payload) {\n+        fclose(in);\n+        c->reason = REASON_FINGERPRINT;\n+        snprintf(c->msg, sizeof(c->msg), \"payload fingerprint mismatch\");\n+        return -20;\n+    }\n     fclose(in);\n     c->reason = REASON_OK;\n     snprintf(c->msg, sizeof(c->msg), \"ok\");\n     return 0;\n }\n*** End Patc"]
