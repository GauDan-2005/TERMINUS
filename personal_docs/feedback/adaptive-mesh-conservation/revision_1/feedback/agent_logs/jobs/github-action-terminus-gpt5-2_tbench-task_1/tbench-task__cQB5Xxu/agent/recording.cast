[156.952334, "o", "> "]
[156.952516, "o", "#include \"phases.h\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.952558, "o", "#include \"../include/flow_record.h\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.952702, "o", "#include \"../include/topo_link.h\""]
[156.952831, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.952862, "o", "> \r\n\u001b[?2004l\r"]
[156.95288, "o", "\u001b[?2004h"]
[156.952899, "o", "> "]
[156.952972, "o", "#include <math.h>\r\n\u001b[?2004l\r"]
[156.953, "o", "\u001b[?2004h"]
[156.953021, "o", "> "]
[156.95309, "o", "#include <string.h>\r\n\u001b[?2004l\r"]
[156.953289, "o", "\u001b[?2004h> "]
[156.953353, "o", "\r\n"]
[156.953423, "o", "\u001b[?2004l\r"]
[156.953515, "o", "\u001b[?2004h"]
[156.953948, "o", "> void phase_grow(SimState *st, const ScenarioSpec *spec) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.953982, "o", "    CellGrid coarse = st->grid;\r\n\u001b[?2004l\r"]
[156.954002, "o", "\u001b[?2004h> "]
[156.954113, "o", "    CellGrid leaves;\r\n\u001b[?2004l\r"]
[156.954145, "o", "\u001b[?2004h> "]
[156.954363, "o", "    leaves.n = 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.954767, "o", "    st->n_coarse = spec->n_coarse;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for (int c = 0; c < spec->n_coarse; c++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.954982, "o", ">         int k = spec->leaf_count[c];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.955103, "o", "        if (k < 1) k = 1;\r\n\u001b[?2004l\r"]
[156.955137, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.955227, "o", "        int sumw = 0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.955257, "o", "> "]
[156.955466, "o", "        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\r\n\u001b[?2004l\r"]
[156.955531, "o", "\u001b[?2004h> "]
[156.955624, "o", "        if (sumw <= 0) sumw = 1;\r\n\u001b[?2004l\r"]
[156.955683, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.955716, "o", "\u001b[?2004h> "]
[156.95589, "o", "        st->coarse_start[c] = leaves.n;\r\n\u001b[?2004l\r"]
[156.955989, "o", "\u001b[?2004h> "]
[156.956095, "o", "        st->coarse_len[c] = k;\r\n\u001b[?2004l\r"]
[156.956171, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.956322, "o", "        double vj[MAX_LEAVES];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.956408, "o", "        double vtot = 0.0;\r\n\u001b[?2004l\r"]
[156.956456, "o", "\u001b[?2004h> "]
[156.956563, "o", "        double jw = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.956693, "o", "        for (int j = 0; j < k; j++) {\r\n\u001b[?2004l\r"]
[156.956798, "o", "\u001b[?2004h> "]
[156.957019, "o", "            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\r\n\u001b[?2004l\r"]
[156.957049, "o", "\u001b[?2004h> "]
[156.95716, "o", "            vtot += vj[j];\r\n\u001b[?2004l\r"]
[156.957282, "o", "\u001b[?2004h> "]
[156.957357, "o", "            jw += vj[j] * (double)j;\r\n\u001b[?2004l\r"]
[156.957468, "o", "\u001b[?2004h> "]
[156.957515, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.957662, "o", "        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\r\n\u001b[?2004l\r"]
[156.957698, "o", "\u001b[?2004h> "]
[156.957725, "o", "\r\n\u001b[?2004l\r"]
[156.95775, "o", "\u001b[?2004h> "]
[156.958025, "o", "        // Conservative prolongation: after shaping q across leaves, renormalize so\r\n\u001b[?2004l\r"]
[156.958108, "o", "\u001b[?2004h> "]
[156.95834, "o", "        // sum_j vol_j * q_j == coarse.vol * coarse.q for each variable.\r\n\u001b[?2004l\r"]
[156.958475, "o", "\u001b[?2004h> "]
[156.958578, "o", "        double want_m[NVAR] = {0.0, 0.0, 0.0};\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.958937, "o", "        for (int v = 0; v < NVAR; v++) want_m[v] = coarse.cells[c].vol * coarse.cells[c].q[v];\r\n\u001b[?2004l\r"]
[156.959005, "o", "\u001b[?2004h> "]
[156.959116, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.959199, "o", "        double got_m[NVAR] = {0.0, 0.0, 0.0};\r\n\u001b[?2004l\r"]
[156.959278, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.959391, "o", "\u001b[?2004h> "]
[156.959503, "o", "        for (int j = 0; j < k; j++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.959598, "o", "            int gi = leaves.n++;\r\n\u001b[?2004l\r"]
[156.959694, "o", "\u001b[?2004h> "]
[156.959824, "o", "            leaves.cells[gi].idx = gi;\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.959945, "o", "> "]
[156.960048, "o", "            leaves.cells[gi].vol = vj[j];\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.960202, "o", "\u001b[?2004h> "]
[156.960374, "o", "            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.960524, "o", "            for (int v = 0; v < NVAR; v++) {\r\n\u001b[?2004l\r"]
[156.960554, "o", "\u001b[?2004h> "]
[156.960759, "o", "                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\r\n\u001b[?2004l\r"]
[156.960785, "o", "\u001b[?2004h> "]
[156.96098, "o", "                got_m[v] += vj[j] * leaves.cells[gi].q[v];\r\n\u001b[?2004l\r"]
[156.961007, "o", "\u001b[?2004h> "]
[156.961101, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.961192, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[156.961236, "o", "> "]
[156.961386, "o", "            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\r\n\u001b[?2004l\r"]
[156.96141, "o", "\u001b[?2004h"]
[156.961442, "o", "> "]
[156.961655, "o", "            leaves.cells[gi].parent = (k > 1) ? c : -1;"]
[156.96177, "o", "\r\n\u001b[?2004l\r"]
[156.961848, "o", "\u001b[?2004h"]
[156.961966, "o", "> "]
[156.962087, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.962186, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.962318, "o", "        int start = st->coarse_start[c];\r\n\u001b[?2004l\r"]
[156.962423, "o", "\u001b[?2004h> "]
[156.96252, "o", "        for (int v = 0; v < NVAR; v++) {\r\n\u001b[?2004l\r"]
[156.962627, "o", "\u001b[?2004h> "]
[156.962703, "o", "            double scale = 1.0;\r\n\u001b[?2004l\r"]
[156.96281, "o", "\u001b[?2004h> "]
[156.962879, "o", "            if (fabs(got_m[v]) > 1e-30) {\r\n\u001b[?2004l\r"]
[156.962986, "o", "\u001b[?2004h> "]
[156.963083, "o", "                scale = want_m[v] / got_m[v];\r\n\u001b[?2004l\r"]
[156.963183, "o", "\u001b[?2004h> "]
[156.963287, "o", "                for (int j = 0; j < k; j++) {\r\n\u001b[?2004l\r"]
[156.963368, "o", "\u001b[?2004h> "]
[156.963518, "o", "                    leaves.cells[start + j].q[v] *= scale;\r\n\u001b[?2004l\r"]
[156.963609, "o", "\u001b[?2004h> "]
[156.963703, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.963806, "o", "            } else {\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.963909, "o", "> "]
[156.964125, "o", "                // Degenerate: ensure exact conservation by setting all leaves to coarse value.\r\n\u001b[?2004l\r"]
[156.96423, "o", "\u001b[?2004h> "]
[156.964327, "o", "                for (int j = 0; j < k; j++) {\r\n\u001b[?2004l\r"]
[156.964432, "o", "\u001b[?2004h> "]
[156.964598, "o", "                    leaves.cells[start + j].q[v] = coarse.cells[c].q[v];\r\n\u001b[?2004l\r"]
[156.964686, "o", "\u001b[?2004h> "]
[156.964777, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.964883, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.964966, "o", ">         }\r\n\u001b[?2004l\r"]
[156.965059, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[156.965141, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.965183, "o", "    st->grid = leaves;\r\n\u001b[?2004l\r"]
[156.965259, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.965378, "o", "\u001b[?2004h> "]
[156.965416, "o", "    int changed[MAX_CELLS];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.965552, "o", "    int nch = 0;\r\n\u001b[?2004l\r"]
[156.965665, "o", "\u001b[?2004h> "]
[156.965768, "o", "    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\r\n\u001b[?2004l\r"]
[156.965807, "o", "\u001b[?2004h> "]
[156.965962, "o", "    step_n(&st->grid, changed, nch, &st->topo);\r\n\u001b[?2004l\r"]
[156.966078, "o", "\u001b[?2004h> "]
[156.96624, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     st->bank.n_pending = 0;\r\n\u001b[?2004l\r"]
[156.966411, "o", "\u001b[?2004h>     if (!spec->do_flux) return;\r\n\u001b[?2004l\r"]
[156.966553, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.966691, "o", "    for (int c = 0; c < spec->n_coarse; c++) {\r\n\u001b[?2004l\r"]
[156.966779, "o", "\u001b[?2004h> "]
[156.966816, "o", "        int k = st->coarse_len[c];\r\n\u001b[?2004l\r"]
[156.966841, "o", "\u001b[?2004h> "]
[156.966982, "o", "        if (k < 2) continue;\r\n\u001b[?2004l\r"]
[156.967068, "o", "\u001b[?2004h> "]
[156.967163, "o", "        int start = st->coarse_start[c];\r\n\u001b[?2004l\r"]
[156.967252, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.967364, "o", "        double vsum = 0.0;\r\n\u001b[?2004l\r"]
[156.9674, "o", "\u001b[?2004h> "]
[156.967559, "o", "        double wq[NVAR] = {0.0, 0.0, 0.0};\r\n\u001b[?2004l\r"]
[156.967598, "o", "\u001b[?2004h> "]
[156.967735, "o", "        for (int j = 0; j < k; j++) {\r\n\u001b[?2004l\r"]
[156.967772, "o", "\u001b[?2004h> "]
[156.967987, "o", "            const CellView *cell = &st->grid.cells[start + j];\r\n\u001b[?2004l\r"]
[156.968022, "o", "\u001b[?2004h> "]
[156.968144, "o", "            vsum += cell->vol;\r\n\u001b[?2004l\r"]
[156.968182, "o", "\u001b[?2004h> "]
[156.968423, "o", "            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\r\n\u001b[?2004l\r"]
[156.968457, "o", "\u001b[?2004h> "]
[156.968605, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.968694, "o", "        double qbar[NVAR];\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.968722, "o", "> "]
[156.968973, "o", "        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\r\n\u001b[?2004l\r"]
[156.969008, "o", "\u001b[?2004h> "]
[156.96909, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.96918, "o", "        EdgePulse ep;\r\n\u001b[?2004l\r"]
[156.969217, "o", "\u001b[?2004h> "]
[156.969348, "o", "        ep.base_idx = start;\r\n\u001b[?2004l\r"]
[156.969432, "o", "\u001b[?2004h> "]
[156.969466, "o", "        ep.subfaces = k;\r\n\u001b[?2004l\r"]
[156.969496, "o", "\u001b[?2004h> "]
[156.969659, "o", "        for (int j = 0; j < k; j++) {\r\n\u001b[?2004l\r"]
[156.969695, "o", "\u001b[?2004h> "]
[156.969905, "o", "            const CellView *cell = &st->grid.cells[start + j];\r\n\u001b[?2004l\r"]
[156.969943, "o", "\u001b[?2004h> "]
[156.970101, "o", "            for (int v = 0; v < NVAR; v++) {\r\n\u001b[?2004l\r"]
[156.970135, "o", "\u001b[?2004h> "]
[156.970337, "o", "                ep.flux_vals[j * NVAR + v] =\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.970375, "o", "> "]
[156.970595, "o", "                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\r\n\u001b[?2004l\r"]
[156.970633, "o", "\u001b[?2004h> "]
[156.970723, "o", "            }\r\n\u001b[?2004l\r"]
[156.97081, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.97095, "o", "> "]
[156.971061, "o", "        op_m(&ep, &st->bank);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[156.971194, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.971271, "o", "> EOF\r\n\u001b[?2004l\r"]
[156.972304, "o", "\u001b[?2004hroot@6362f560e0ae:/app# "]
[157.459161, "i", "cat > /app/srl_p/serial.cpp <<'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n\nint emit_p(const SimState *a, const char *b) {\n    if (!a || !b) return -1;\n    FILE *fp = fopen(b, \"wb\");\n    if (!fp) return -2;\n\n    VaultHeader hdr;\n    hdr.magic = VAULT_MAGIC;\n    hdr.version = VAULT_VERSION;\n    hdr.fingerprint = a->fingerprint_payload;\n    hdr.build_stamp = (uint64_t)BUILD_STAMP;\n\n    if (fwrite(&hdr, sizeof(hdr), 1, fp) != 1) { fclose(fp); return -3; }\n\n    int n_cells = a->grid.n;\n    if (fwrite(&n_cells, sizeof(int), 1, fp) != 1) { fclose(fp); return -4; }\n    if (fwrite(a->grid.cells, sizeof(CellView), n_cells, fp) != (size_t)n_cells) { fclose(fp); return -5; }\n\n    if (fwrite(&a->topo, sizeof(a->topo), 1, fp) != 1) { fclose(fp); return -6; }\n    if (fwrite(&a->bank, sizeof(a->bank), 1, fp) != 1) { fclose(fp); return -7; }\n\n    if (fwrite(&a->n_coarse, sizeof(int), 1, fp) != 1) { fclose(fp); return -8; }\n    if (fwrite(a->coarse_start, sizeof(int), MAX_CELLS, fp) != MAX_CELLS) { fclose(fp); return -9; }\n    if (fwrite(a->coarse_len, sizeof(int), MAX_CELLS, fp) != MAX_CELLS) { fclose(fp); return -10; }\n\n    if (fwrite(&a->step_idx, sizeof(int), 1, fp) != 1) { fclose(fp); return -11; }\n    if (fwrite(&a->dt_carry, sizeof(double), 1, fp) != 1) { fclose(fp); return -12; }\n\n    if (fwrite(&a->fingerprint_payload, sizeof(uint64_t), 1, fp) != 1) { fclose(fp); return -13; }\n    if (fwrite(&a->adjacency, sizeof(int), 1, fp) != 1) { fclose(fp); return -14; }\n    if (fwrite(a->halo_q, sizeof(double), NVAR, fp) != NVAR) { fclose(fp); return -15; }\n\n    fclose(fp);\n    return 0;\n}\nEOF\n"]
[157.459562, "o", "cat > /app/srl_p/serial.cpp <<'EOF'\r\n\u001b[?2004l\r"]
[157.459717, "o", "\u001b[?2004h> #include \"../include/vault_layout.h\"\r\n\u001b[?2004l\r"]
[157.459805, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.462261, "o", "#include <stdio.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> int emit_p(const SimState *a, const char *b) {\r\n\u001b[?2004l\r\u001b[?2004h>     if (!a || !b) return -1;\r\n\u001b[?2004l\r\u001b[?2004h>     FILE *fp = fopen(b, \"wb\");\r\n\u001b[?2004l\r\u001b[?2004h>     if (!fp) return -2;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     VaultHeader hdr;\r\n\u001b[?2004l\r\u001b[?2004h>     hdr.magic = VAULT_MAGIC;\r\n\u001b[?2004l\r\u001b[?2004h>     hdr.version = VAULT_VERSION;\r\n\u001b[?2004l\r\u001b[?2004h>     hdr.fingerprint = a->fingerprint_payload;\r\n\u001b[?2004l\r\u001b[?2004h>     hdr.build_stamp = (uint64_t)BUILD_STAMP;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if (fwrite(&hdr, sizeof(hdr), 1, fp) != 1) { fclose(fp); return -3; }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     int n_cells = a->grid.n;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.4625, "o", "    if (fwrite(&n_cells, sizeof(int), 1, fp) != 1) { fclose(fp); return -4; }\r\n\u001b[?2004l\r"]
[157.462581, "o", "\u001b[?2004h> "]
[157.462923, "o", "    if (fwrite(a->grid.cells, sizeof(CellView), n_cells, fp) != (size_t)n_cells) { fclose(fp); return -5; }\r\n\u001b[?2004l\r"]
[157.46302, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[157.463085, "o", "> "]
[157.463329, "o", "    if (fwrite(&a->topo, sizeof(a->topo), 1, fp) != 1) { fclose(fp); return -6; }\r\n"]
[157.463355, "o", "\u001b[?2004l\r"]
[157.463377, "o", "\u001b[?2004h"]
[157.46385, "o", ">     if (fwrite(&a->bank, sizeof(a->bank), 1, fp) != 1) { fclose(fp); return -7; }\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.463935, "o", "> "]
[157.466304, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     if (fwrite(&a->n_coarse, sizeof(int), 1, fp) != 1) { fclose(fp); return -8; }\r\n\u001b[?2004l\r\u001b[?2004h>     if (fwrite(a->coarse_start, sizeof(int), MAX_CELLS, fp) != MAX_CELLS) { fclose(fp); return -9; }\r\n\u001b[?2004l\r\u001b[?2004h>     if (fwrite(a->coarse_len, sizeof(int), MAX_CELLS, fp) != MAX_CELLS) { fclose(fp); return -10; }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if (fwrite(&a->step_idx, sizeof(int), 1, fp) != 1) { fclose(fp); return -11; }\r\n\u001b[?2004l\r\u001b[?2004h>     if (fwrite(&a->dt_carry, sizeof(double), 1, fp) != 1) { fclose(fp); return -12; }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if (fwrite(&a->fingerprint_payload, sizeof(uint64_t), 1, fp) != 1) { fclose(fp); return -13; }\r\n\u001b[?2004l\r\u001b[?2004h>     if (fwrite(&a->adjacency, sizeof(int), 1, fp) != 1) { fclose(fp); return -14; }\r\n\u001b[?2004l\r\u001b[?2004h> "]
