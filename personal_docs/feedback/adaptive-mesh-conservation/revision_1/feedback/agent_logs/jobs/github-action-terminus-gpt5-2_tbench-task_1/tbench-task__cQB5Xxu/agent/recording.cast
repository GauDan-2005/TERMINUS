[157.955557, "i", "cat > /app/rsm_k/resume.cpp <<'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n#include <string.h>\n\nstatic int short_read(FILE *in, VaultAudit *c, const char *what, int rc) {\n    if (in) fclose(in);\n    c->reason = REASON_SHORT;\n    snprintf(c->msg, sizeof(c->msg), \"%s short\", what);\n    return rc;\n}\n\nint load_k(const char *a, SimState *b, VaultAudit *c) {\n    if (!a || !b || !c) return -1;\n    memset(c, 0, sizeof(*c));\n\n    FILE *in = fopen(a, \"rb\");\n    if (!in) {\n        c->reason = REASON_MISSING;\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\n        return -2;\n    }\n\n    VaultHeader hdr;\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\n        return short_read(in, c, \"header\", -3);\n    }\n    if (hdr.magic != VAULT_MAGIC) {\n        fclose(in);\n        c->reason = REASON_MAGIC;\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\n        return -4;\n    }\n    if (hdr.version != VAULT_VERSION) {\n        fclose(in);\n        c->reason = REASON_VERSION;\n        snprintf(c->msg, sizeof(c->msg), \"bad version %u\", hdr.version);\n        return -5;\n    }\n\n    // Fingerprint check: expected fingerprint is provided by current run inputs.\n    if (hdr.fingerprint != b->fingerprint_payload) {\n        fclose(in);\n        c->reason = REASON_FINGERPRINT;\n        snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\n        return -6;\n    }\n\n    int n_cells = 0;\n    if (fread(&n_cells, sizeof(int), 1, in) != 1) {\n        return short_read(in, c, \"n_cells\", -7);\n    }\n    if (n_cells < 0 || n_cells > MAX_CELLS) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"n_cells out of range\");\n        return -8;\n    }\n\n    b->grid.n = n_cells;\n    if (fread(b->grid.cells, sizeof(CellView), n_cells, in) != (size_t)n_cells) {\n        return short_read(in, c, \"cells\", -9);\n    }\n    if (fread(&b->topo, sizeof(b->topo), 1, in) != 1) {\n        return short_read(in, c, \"topo\", -10);\n    }\n    if (fread(&b->bank, sizeof(b->bank), 1, in) != 1) {\n        return short_read(in, c, \"bank\", -11);\n    }\n\n    if (fread(&b->n_coarse, sizeof(int), 1, in) != 1) {\n        return short_read(in, c, \"n_coarse\", -12);\n    }\n    if (fread(b->coarse_start, sizeof(int), MAX_CELLS, in) != MAX_CELLS) {\n        return short_read(in, c, \"coarse_start\", -13);\n    }\n    if (fread(b->coarse_len, sizeof(int), MAX_CELLS, in) != MAX_CELLS) {\n        return short_read(in, c, \"coarse_len\", -14);\n    }\n\n    if (fread(&b->step_idx, sizeof(int), 1, in) != 1) {\n        return short_read(in, c, \"step_idx\", -15);\n    }\n    if (fread(&b->dt_carry, sizeof(double), 1, in) != 1) {\n        return short_read(in, c, \"dt_carry\", -16);\n    }\n\n    uint64_t fp_payload = 0;\n    if (fread(&fp_payload, sizeof(uint64_t), 1, in) != 1) {\n        return short_read(in, c, \"payload_fingerprint\", -17);\n    }\n    if (fp_payload != b->fingerprint_payload) {\n        fclose(in);\n        c->reason = REASON_FINGERPRINT;\n        snprintf(c->msg, sizeof(c->msg), \"payload fingerprint mismatch\");\n        return -18;\n    }\n\n    if (fread(&b->adjacency, sizeof(int), 1, in) != 1) {\n        return short_read(in, c, \"adjacency\", -19);\n    }\n    if (fread(b->halo_q, sizeof(double), NVAR, in) != NVAR) {\n        return short_read(in, c, \"halo_q\", -20);\n    }\n\n    fclose(in);\n    c->reason = REASON_OK;\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\n    return 0;\n}\nEOF\n"]
[157.965692, "o", "cat > /app/rsm_k/resume.cpp <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include \"../include/vault_layout.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include <stdio.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> static int short_read(FILE *in, VaultAudit *c, const char *what, int rc) {\r\n\u001b[?2004l\r\u001b[?2004h>     if (in) fclose(in);\r\n\u001b[?2004l\r\u001b[?2004h>     c->reason = REASON_SHORT;\r\n\u001b[?2004l\r\u001b[?2004h>     snprintf(c->msg, sizeof(c->msg), \"%s short\", what);\r\n\u001b[?2004l\r\u001b[?2004h>     return rc;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> int load_k(const char *a, SimState *b, VaultAudit *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     if (!a || !b || !c) return -1;\r\n\u001b[?2004l\r\u001b[?2004h>     memset(c, 0, sizeof(*c));\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     FILE *in = fopen(a, \"rb\");\r\n\u001b[?2004l\r\u001b[?2004h>     if (!in) {\r\n\u001b[?2004l\r\u001b[?2004h>         c->reason = REASON_MISSING;\r\n\u001b[?2004l\r\u001b[?2004h>         snprintf(c->msg, sizeof(c->msg), \"open failed\");\r\n\u001b[?2004l\r\u001b[?2004h>         return -2;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     VaultHeader hdr;\r\n\u001b[?2004l\r\u001b[?2004h>     if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\r\n\u001b[?2004l\r\u001b[?2004h>         return short_read(in, c, \"header\", -3);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     if (hdr.magic != VAULT_MAGIC) {\r\n\u001b[?2004l\r\u001b[?2004h>         fclose(in);\r\n\u001b[?2004l\r\u001b[?2004h>         c->reason = REASON_MAGIC;\r\n\u001b[?2004l\r\u001b[?2004h>         snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\r\n\u001b[?2004l\r\u001b[?2004h>         return -4;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     if (hdr.version != VAULT_VERSION) {\r\n\u001b[?2004l\r\u001b[?2004h>         fclose(in);\r\n\u001b[?2004l\r\u001b[?2004h>         c->reason = REASON_VERSION;\r\n\u001b[?2004l\r\u001b[?2004h>         snprintf(c->msg, sizeof(c->msg), \"bad version %u\", hdr.version);\r\n\u001b[?2004l\r\u001b[?2004h>         return -5;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     // Fingerprint check: expected fingerprint is provided by current run inputs.\r\n\u001b[?2004l\r\u001b[?2004h>     if (hdr.fingerprint != b->fingerprint_payload) {\r\n\u001b[?2004l\r\u001b[?2004h>         fclose(in);\r\n\u001b[?2004l\r\u001b[?2004h>         c->reason = REASON_FINGERPRINT;\r\n\u001b[?2004l\r\u001b[?2004h>         snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\r\n\u001b[?2004l\r\u001b[?2004h>         return -6;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     int n_cells = 0;\r\n\u001b[?2004l\r\u001b[?2004h>     if (fread(&n_cells, sizeof(int), 1, in) != 1) {\r\n\u001b[?2004l\r\u001b[?2004h>         return short_read(in, c, \"n_cells\", -7);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     if (n_cells < 0 || n_cells > MAX_CELLS) {\r\n\u001b[?2004l\r\u001b[?2004h>         fclose(in);\r\n\u001b[?2004l\r\u001b[?2004h>         c->reason = REASON_SHORT;\r\n\u001b[?2004l\r\u001b[?2004h>         snprintf(c->msg, sizeof(c->msg), \"n_cells out of range\");\r\n\u001b[?2004l\r\u001b[?2004h>         return -8;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     b->grid.n = n_cells;\r\n\u001b[?2004l\r\u001b[?2004h>     if (fread(b->grid.cells, sizeof(CellView), n_cells, in) != (size_t)n_cells) {\r\n\u001b[?2004l\r\u001b[?2004h>         return short_read(in, c, \"cells\", -9);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u