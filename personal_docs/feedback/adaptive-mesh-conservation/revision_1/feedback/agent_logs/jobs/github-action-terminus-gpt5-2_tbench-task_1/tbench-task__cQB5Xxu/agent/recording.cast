[156.446713, "i", "cat > /app/agg_q/blend.cpp <<'EOF'\n#include \"../include/cell_view.h\"\n\nvoid fold_q(const CellPatch *a, int b, CellPatch *c) {\n    if (!a || !c) return;\n    int n = (a->n < b) ? a->n : b;\n    if (n <= 0) {\n        c->n = 0;\n        return;\n    }\n\n    // Conservative restriction: preserve volume-integrated quantities.\n    // a->q stores per-volume state; conserved totals are vol*q.\n    double sum_vol = 0.0;\n    double sum_m[NVAR] = {0.0, 0.0, 0.0};\n    for (int i = 0; i < n; i++) {\n        sum_vol += a->vol[i];\n        for (int v = 0; v < NVAR; v++) {\n            sum_m[v] += a->vol[i] * a->q[i * NVAR + v];\n        }\n    }\n\n    c->n = 1;\n    c->vol[0] = sum_vol;\n    for (int v = 0; v < NVAR; v++) {\n        c->q[v] = (sum_vol > 0.0) ? (sum_m[v] / sum_vol) : 0.0;\n    }\n}\nEOF\n"]
[156.447221, "o", "cat > /app/agg_q/blend.cpp <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
