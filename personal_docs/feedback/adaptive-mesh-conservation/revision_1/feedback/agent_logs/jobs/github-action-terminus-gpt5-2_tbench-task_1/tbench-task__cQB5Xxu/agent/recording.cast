[108.867051, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: drv_u/run_refine.cpp\n@@\n void phase_grow(SimState *st, const ScenarioSpec *spec) {\n@@\n         double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\n+\n+        // Prolongation must be conservative: the sum over leaves of vol*q must\n+        // match the coarse cell's vol*q, even if we introduce a shape factor.\n+        double want_m[NVAR] = {0.0, 0.0, 0.0};\n+        for (int v = 0; v < NVAR; v++) want_m[v] = coarse.cells[c].vol * coarse.cells[c].q[v];\n+\n+        // First pass: apply shape factor.\n+        double got_m[NVAR] = {0.0, 0.0, 0.0};\n         for (int j = 0; j < k; j++) {\n             int gi = leaves.n++;\n             leaves.cells[gi].idx = gi;\n             leaves.cells[gi].vol = vj[j];\n             double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\n             for (int v = 0; v < NVAR; v++) {\n                 leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\n             }\n             leaves.cells[gi].tier = (k > 1) ? 1 : 0;\n             leaves.cells[gi].parent = (k > 1) ? c : -1;\n+\n+            for (int v = 0; v < NVAR; v++) got_m[v] += vj[j] * leaves.cells[gi].q[v];\n         }\n+\n+        // Second pass: renormalize per variable to enforce conservation.\n+        int start = st->coarse_start[c];\n+        for (int v = 0; v < NVAR; v++) {\n+            double scale = 1.0;\n+            if (fabs(got_m[v]) > 1e-30) {\n+                scale = want_m[v] / got_m[v];\n+            } else if (fabs(want_m[v]) > 1e-30) {\n+                // If the shape factor collapsed totals to ~0, fall back to uniform.\n+                scale = 0.0;\n+            }\n+            for (int j = 0; j < k; j++) {\n+                int gi = start + j;\n+                if (scale != 0.0) {\n+                    leaves.cells[gi].q[v] *= scale;\n+                } else {\n+                    leaves.cells[gi].q[v] = coarse.cells[c].q[v];\n+                }\n+            }\n+        }\n     }\n*** End Patch\nPATCH\n"]
[108.867387, "o", "apply_patch<<'PATCH'\r\n\u001b[?2004l\r"]
