[238.659566, "i", "perl -0777 -i -pe 's/void op_m\\(const EdgePulse \\*a, FluxBank \\*b\\) \\{\\n    if \\(!a \\|\\| !b\\) return;\\n    if \\(b->n_pending >= MAX_FACES\\) return;\\n    int slot = b->n_pending\\+\\+;\\n    b->leaf\\[slot\\] = a->base_idx;\\n    for \\(int v = 0; v < NVAR; v\\+\\+\\) \\{\\n        b->flux\\[slot \\* NVAR \\+ v\\] = a->flux_vals\\[v\\];\\n    \\}\\n\\}/void op_m(const EdgePulse *a, FluxBank *b) {\\n    if (!a || !b) return;\\n    if (a->subfaces <= 0) return;\\n\\n    // Record one reflux entry per refined subface. EdgePulse::flux_vals is laid out\\n    // as [subface0 vars..., subface1 vars..., ...].\\n    for (int j = 0; j < a->subfaces; j++) {\\n        if (b->n_pending >= MAX_FACES) return;\\n        int slot = b->n_pending++;\\n        b->leaf[slot] = a->base_idx + j;\\n        for (int v = 0; v < NVAR; v++) {\\n            b->flux[slot * NVAR + v] = a->flux_vals[j * NVAR + v];\\n        }\\n    }\\n}/s' /app/acc_m/edge_corr.cpp\n"]
[238.663614, "o", "perl -0777 -i -pe 's/void op_m\\(const EdgePulse \\*a, FluxBank \\*b\\) \\{\\n    if \\(!a \\|\\| !b\\) return;\\n    if \\(b->n_pending >= MAX_FACES\\) return;\\n    int slot = b->n_pending\\+\\+;\\n    b->leaf\\[slot\\] = a->base_idx;\\n    for \\(int v = 0; v < NVAR; v\\+\\+\\) \\{\\n        b->flux\\[slot \\* NVAR \\+ v\\] = a->flux_vals\\[v\\];\\n    \\}\\n\\}/void op_m(const EdgePulse *a, FluxBank *b) {\\n    if (!a || !b) return;\\n    if (a->subfaces <= 0) return;\\n\\n    // Record one reflux entry per refined subface. EdgePulse::flux_vals is laid out\\n    // as [subface0 vars..., subface1 vars..., ...].\\n    for (int j = 0; j < a->subfaces; j++) {\\n        if (b->n_pending >= MAX_FACES) return;\\n        int slot = b->n_pending++;\\n        b->leaf[slot] = a->base_idx + j;\\n        for (int v = 0; v < NVAR; v++) {\\n            b->flux[slot * NVAR + v] = a->flux_vals[j * NVAR + v];\\n        }\\n    }\\n}/s' /app/acc_m/edge_corr.cpp\r\n\u001b[?2004l\r"]
