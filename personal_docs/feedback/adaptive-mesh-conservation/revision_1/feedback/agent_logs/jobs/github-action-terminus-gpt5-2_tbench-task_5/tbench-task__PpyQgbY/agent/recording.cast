[309.663193, "i", "cat > /app/acc_m/edge_corr.cpp <<'EOF'\n#include \"../include/flow_record.h\"\n\nvoid op_m(const EdgePulse *a, FluxBank *b) {\n    if (!a || !b) return;\n    if (a->subfaces <= 0) return;\n\n    // Record one reflux entry per refined subface.\n    // EdgePulse::flux_vals layout: flux_vals[j * NVAR + v]\n    for (int j = 0; j < a->subfaces; j++) {\n        if (b->n_pending >= MAX_FACES) return;\n        int slot = b->n_pending++;\n        b->leaf[slot] = a->base_idx + j;\n        for (int v = 0; v < NVAR; v++) {\n            b->flux[slot * NVAR + v] = a->flux_vals[j * NVAR + v];\n        }\n    }\n}\nEOF\n"]
[309.663939, "o", "cat > /app/acc_m/edge_corr.cpp <<'EOF'\r\n\u001b[?2004l\r"]
