[191.645795, "i", "cat > /app/srl_p/serial.cpp << 'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n#include <string.h>\n\nint emit_p(const SimState *a, const char *b) {\n    if (!a || !b) return -1;\n    FILE *fp = fopen(b, \"wb\");\n    if (!fp) return -2;\n    VaultHeader hdr;\n    hdr.magic = VAULT_MAGIC;\n    hdr.version = VAULT_VERSION;\n    hdr.fingerprint = a->fingerprint_payload;\n    hdr.build_stamp = (uint64_t)BUILD_STAMP;\n    fwrite(&hdr, sizeof(hdr), 1, fp);\n    int n_cells = a->grid.n;\n    fwrite(&n_cells, sizeof(int), 1, fp);\n    fwrite(a->grid.cells, sizeof(CellView), n_cells, fp);\n    /* Save coarse structure */\n    fwrite(&a->n_coarse, sizeof(int), 1, fp);\n    fwrite(a->coarse_start, sizeof(int), a->n_coarse, fp);\n    fwrite(a->coarse_len, sizeof(int), a->n_coarse, fp);\n    /* Save flux bank */\n    fwrite(&a->bank.n_pending, sizeof(int), 1, fp);\n    if (a->bank.n_pending > 0) {\n        fwrite(a->bank.leaf, sizeof(int), a->bank.n_pending, fp);\n        fwrite(a->bank.flux, sizeof(double), a->bank.n_pending * NVAR, fp);\n    }\n    /* Save fingerprint */\n    fwrite(&a->fingerprint_payload, sizeof(uint64_t), 1, fp);\n    /* Compute and write checksum over the entire payload */\n    fclose(fp);\n    return 0;\n}\nEOF\n"]
