[231.437573, "i", "cat /app/CMakeLists.txt\n"]
[231.437864, "o", "cat /app/CMakeLists.txt\r\n\u001b[?2004l\r"]
[231.439796, "o", "cmake_minimum_required(VERSION 3.16)\r\nproject(sim_run LANGUAGES CXX)\r\n\r\nset(CMAKE_CXX_STANDARD 17)\r\nset(CMAKE_CXX_STANDARD_REQUIRED ON)\r\n\r\nif(NOT DEFINED BUILD_STAMP)\r\n    if(DEFINED ENV{SOURCE_DATE_EPOCH})\r\n        set(BUILD_STAMP $ENV{SOURCE_DATE_EPOCH})\r\n    else()\r\n        set(BUILD_STAMP \"0\")\r\n    endif()\r\nendif()\r\nadd_compile_definitions(BUILD_STAMP=${BUILD_STAMP})\r\n\r\nadd_executable(sim_run\r\n    src/main.cpp\r\n    src/case_io.cpp\r\n    src/vault_io.cpp\r\n    src/audit_emit.cpp\r\n    acc_m/edge_corr.cpp\r\n    lnk_n/relate.cpp\r\n    agg_q/blend.cpp\r\n    srl_p/serial.cpp\r\n    rsm_k/resume.cpp\r\n    sync_b/halo.cpp\r\n    drv_u/run.cpp\r\n    drv_u/run_refine.cpp\r\n    drv_u/run_blend.cpp\r\n    drv_u/run_sync.cpp\r\n    swp_t/sweep.cpp\r\n    emt_e/report.cpp\r\n    prb_v/hist.cpp\r\n    tap_w/trace.cpp\r\n    cch_z/ring.cpp\r\n)\r\n\r\ntarget_include_directories(sim_run PRIVATE include)\r\n\r\nset_target_properties(sim_run PROPERTIES\r\n    RUNTIME_OUTPUT_DIRECTORY \"${CMAKE_BINARY_DIR}/bin\"\r\n)\r\n"]
[231.439866, "o", "\u001b[?2004hroot@bba012489ee5:/app# "]
[231.558018, "i", "cat /app/scripts/run-matrix.sh\n"]
[231.558455, "o", "cat /app/scripts/run-matrix.sh\r\n\u001b[?2004l\r"]
[231.559537, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP=\"${APP_ROOT:-/app}\"\r\nbash \"${APP}/scripts/clean-room.sh\"\r\n\"${APP}/build/bin/sim_run\" --matrix --out \"${APP}/output/conservation_audit.json\"\r\n"]
