[191.649566, "o", "\u001b[?2004h"]
[191.649641, "o", "> "]
[191.64983, "o", "    hdr.build_stamp = (uint64_t)BUILD_STAMP;\r\n\u001b[?2004l\r"]
[191.649871, "o", "\u001b[?2004h> "]
[191.650012, "o", "    fwrite(&hdr, sizeof(hdr), 1, fp);\r\n\u001b[?2004l\r"]
[191.65321, "o", "\u001b[?2004h"]
[191.653749, "o", ">     int n_cells = a->grid.n;\r\n\u001b[?2004l\r\u001b[?2004h>     fwrite(&n_cells, sizeof(int), 1, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     fwrite(a->grid.cells, sizeof(CellView), n_cells, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     /* Save coarse structure */\r\n\u001b[?2004l\r\u001b[?2004h>     fwrite(&a->n_coarse, sizeof(int), 1, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     fwrite(a->coarse_start, sizeof(int), a->n_coarse, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     fwrite(a->coarse_len, sizeof(int), a->n_coarse, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     /* Save flux bank */\r\n\u001b[?2004l\r\u001b[?2004h>     fwrite(&a->bank.n_pending, sizeof(int), 1, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     if (a->bank.n_pending > 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         fwrite(a->bank.leaf, sizeof(int), a->bank.n_pending, fp);\r\n\u001b[?2004l\r\u001b[?2004h>         fwrite(a->bank.flux, sizeof(double), a->bank.n_pending * NVAR, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     /* Save fingerprint */\r\n\u001b[?2004l\r\u001b[?2004h>     fwrite(&a->fingerprint_payload, sizeof(uint64_t), 1, fp);\r\n\u001b[?2004l\r\u001b[?2004h>     /* Compute and write checksum over the entire payload */\r\n\u001b[?2004l\r\u001b[?2004h>     fclose(fp);\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[191.654291, "o", "\u001b[?2004h"]
[191.654378, "o", "root@bba012489ee5:/app# "]
[191.770085, "i", "cat > /app/rsm_k/resume.cpp << 'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n#include <string.h>\n\nint load_k(const char *a, SimState *b, VaultAudit *c) {\n    if (!a || !b || !c) return -1;\n    memset(c, 0, sizeof(*c));\n    FILE *in = fopen(a, \"rb\");\n    if (!in) {\n        c->reason = REASON_MISSING;\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\n        return -2;\n    }\n    VaultHeader hdr;\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\n        return -3;\n    }\n    if (hdr.magic != VAULT_MAGIC) {\n        fclose(in);\n        c->reason = REASON_MAGIC;\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\n        return -4;\n    }\n    /* Check fingerprint against tampered data */\n    uint64_t stored_fp = hdr.fingerprint;\n    if (stored_fp != b->fingerprint_payload) {\n        fclose(in);\n        c->reason = REASON_FINGERPRINT;\n        snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\n        return -5;\n    }\n    int n_cells = 0;\n    fread(&n_cells, sizeof(int), 1, in);\n    b->grid.n = n_cells;\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\n    /* Restore coarse structure */\n    fread(&b->n_coarse, sizeof(int), 1, in);\n    fread(b->coarse_start, sizeof(int), b->n_coarse, in);\n    fread(b->coarse_len, sizeof(int), b->n_coarse, in);\n    /* Restore flux bank */\n    fread(&b->bank.n_pending, sizeof(int), 1, in);\n    if (b->bank.n_pending > 0) {\n        fread(b->bank.leaf, sizeof(int), b->bank.n_pending, in);\n        fread(b->bank.flux, sizeof(double), b->bank.n_pending * NVAR, in);\n    }\n    /* Restore fingerprint */\n    fread(&b->fingerprint_payload, sizeof(uint64_t), 1, in);\n    memset(&b->topo, 0, sizeof(b->topo));\n    fclose(in);\n    c->reason = REASON_OK;\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\n    return 0;\n}\nEOF\n"]
