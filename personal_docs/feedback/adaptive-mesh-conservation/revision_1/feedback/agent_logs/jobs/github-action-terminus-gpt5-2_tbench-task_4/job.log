Sending keys: ['cat > /app/agg_q/blend.cpp <<\'EOF\'\n#include "../include/cell_view.h"\n\n// Merge (fold) child cells into one parent.\n//\n// q represents an intensive state stored per cell; the conserved totals used by\n// the audits are volume-weighted moments (sum over cells of q * vol). Folding\n// must therefore use a volume-weighted average so that:\n//   q_parent * vol_parent == sum_i (q_i * vol_i)\nvoid fold_q(const CellPatch *a, int b, CellPatch *c) {\n    if (!a || !c) return;\n    int n = (a->n < b) ? a->n : b;\n    if (n <= 0) {\n        c->n = 0;\n        return;\n    }\n\n    double sum_vol = 0.0;\n    double sum_qv[NVAR] = {0.0, 0.0, 0.0};\n    for (int i = 0; i < n; i++) {\n        const double vol = a->vol[i];\n        sum_vol += vol;\n        for (int v = 0; v < NVAR; v++) {\n            sum_qv[v] += a->q[i * NVAR + v] * vol;\n        }\n    }\n\n    c->n = 1;\n    c->vol[0] = sum_vol;\n    if (sum_vol <= 0.0) {\n        for (int v = 0; v < NVAR; v++) c->q[v] = 0.0;\n        return;\n    }\n    const double inv_vol = 1.0 / sum_vol;\n    for (int v = 0; v < NVAR; v++) {\n        c->q[v] = sum_qv[v] * inv_vol;\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
