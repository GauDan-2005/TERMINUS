    }\n\n    if (rd(&b->topo, sizeof(TopoLink), 1, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), "topo short");\n        return -9;\n    }\n\n    int n_pending = 0;\n    if (rd(&n_pending, sizeof(int), 1, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), "bank count short");\n        return -10;\n    }\n    if (n_pending < 0 || n_pending > MAX_FACES) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), "bank count invalid");\n        return -10;\n    }\n    b->bank.n_pending = n_pending;\n    if (rd(b->bank.leaf, sizeof(int), (size_t)n_pending, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), "bank leaf short");\n        return -11;\n    }\n    if (rd(b->bank.flux, sizeof(double) * NVAR, (size_t)n_pending, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), "bank flux short");\n        return -12;\n    }\n\n    if (rd(&b->n_coarse, sizeof(int), 1, in) != 0 ||\n        rd(b->coarse_start, sizeof(int), (size_t)MAX_CELLS, in) != 0 ||\n        rd(b->coarse_len, sizeof(int), (size_t)MAX_CELLS, in) != 0 ||\n        rd(&b->step_idx, sizeof(int), 1, in) != 0 ||\n        rd(&b->dt_carry, sizeof(double), 1, in) != 0 ||\n        rd(&b->adjacency, sizeof(int), 1, in) != 0 ||\n        rd(b->halo_q, sizeof(double), (size_t)NVAR, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), "state short");\n        return -13;\n    }\n\n    fclose(in);\n    c->reason = REASON_OK;\n    snprintf(c->msg, sizeof(c->msg), "ok");\n    return 0;\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
