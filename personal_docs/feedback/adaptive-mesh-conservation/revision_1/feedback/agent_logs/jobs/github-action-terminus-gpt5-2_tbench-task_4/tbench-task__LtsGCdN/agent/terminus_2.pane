[?2004l#include "../include/vault_layout.h"

#include <stdint.h>

uint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed) {
    const uint8_t *p = (const uint8_t *)data;
    uint64_t h = 0xcbf29ce484222325ull ^ seed;
    for (int i = 0; i < n_bytes; i++) {
        h ^= (uint64_t)p[i];
        h *= 0x100000001b3ull;
    }
    return h;
}
[?2004hroot@a48c1a67d572:/app# sed -n '1,320p' /app/srl_p/serial.cpp
[?2004l#include "../include/vault_layout.h"

#include <stdio.h>

int emit_p(const SimState *a, const char *b) {
    if (!a || !b) return -1;
    FILE *fp = fopen(b, "wb");
    if (!fp) return -2;
    VaultHeader hdr;
    hdr.magic = VAULT_MAGIC;
    hdr.version = VAULT_VERSION;
    hdr.fingerprint = a->fingerprint_payload;
    hdr.build_stamp = (uint64_t)BUILD_STAMP;
    fwrite(&hdr, sizeof(hdr), 1, fp);
    int n_cells = a->grid.n;
    fwrite(&n_cells, sizeof(int), 1, fp);
    fwrite(a->grid.cells, sizeof(CellView), n_cells, fp);
    fclose(fp);
    return 0;
}
[?2004hroot@a48c1a67d572:/app# sed -n '1,320p' /app/rsm_k/resume.cpp
[?2004l#include "../include/vault_layout.h"

#include <stdio.h>
#include <string.h>

int load_k(const char *a, SimState *b, VaultAudit *c) {
    if (!a || !b || !c) return -1;
    memset(c, 0, sizeof(*c));
    FILE *in = fopen(a, "rb");
    if (!in) {
        c->reason = REASON_MISSING;
        snprintf(c->msg, sizeof(c->msg), "open failed");
        return -2;
    }
    VaultHeader hdr;
    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {
        fclose(in);
        c->reason = REASON_SHORT;
        snprintf(c->msg, sizeof(c->msg), "header short");
        return -3;
    }
    if (hdr.magic != VAULT_MAGIC) {
        fclose(in);
        c->reason = REASON_MAGIC;
        snprintf(c->msg, sizeof(c->msg), "bad magic 0x%x", hdr.magic);
        return -4;
    }
    int n_cells = 0;
    fread(&n_cells, sizeof(int), 1, in);
    b->grid.n = n_cells;
    fread(b->grid.cells, sizeof(CellView), n_cells, in);
    memset(&b->topo, 0, sizeof(b->topo));
    b->bank.n_pending = 0;
    fclose(in);
    c->reason = REASON_OK;
    snprintf(c->msg, sizeof(c->msg), "ok");
    return 0;
}
