[380.934687, "i", "cat > /app/rsm_k/resume.cpp <<'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n#include <string.h>\n\nstatic int rd(void *p, size_t sz, size_t n, FILE *fp) {\n    return (fread(p, sz, n, fp) == n) ? 0 : -1;\n}\n\nint load_k(const char *a, SimState *b, VaultAudit *c) {\n    if (!a || !b || !c) return -1;\n    memset(c, 0, sizeof(*c));\n\n    FILE *in = fopen(a, \"rb\");\n    if (!in) {\n        c->reason = REASON_MISSING;\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\n        return -2;\n    }\n\n    VaultHeader hdr;\n    if (rd(&hdr, sizeof(hdr), 1, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\n        return -3;\n    }\n    if (hdr.magic != VAULT_MAGIC) {\n        fclose(in);\n        c->reason = REASON_MAGIC;\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\n        return -4;\n    }\n    if (hdr.version != VAULT_VERSION) {\n        fclose(in);\n        c->reason = REASON_VERSION;\n        snprintf(c->msg, sizeof(c->msg), \"version %u\", hdr.version);\n        return -5;\n    }\n    if (hdr.fingerprint != b->fingerprint_payload) {\n        fclose(in);\n        c->reason = REASON_FINGERPRINT;\n        snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\n        return -6;\n    }\n\n    int n_cells = 0;\n    if (rd(&n_cells, sizeof(int), 1, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"n_cells short\");\n        return -7;\n    }\n    if (n_cells < 0 || n_cells > MAX_CELLS) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"n_cells invalid\");\n        return -7;\n    }\n\n    b->grid.n = n_cells;\n    if (rd(b->grid.cells, sizeof(CellView), (size_t)n_cells, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"cells short\");\n        return -8;\n    }\n\n    if (rd(&b->topo, sizeof(TopoLink), 1, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"topo short\");\n        return -9;\n    }\n\n    int n_pending = 0;\n    if (rd(&n_pending, sizeof(int), 1, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"bank count short\");\n        return -10;\n    }\n    if (n_pending < 0 || n_pending > MAX_FACES) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"bank count invalid\");\n        return -10;\n    }\n    b->bank.n_pending = n_pending;\n    if (rd(b->bank.leaf, sizeof(int), (size_t)n_pending, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"bank leaf short\");\n        return -11;\n    }\n    if (rd(b->bank.flux, sizeof(double) * NVAR, (size_t)n_pending, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"bank flux short\");\n        return -12;\n    }\n\n    if (rd(&b->n_coarse, sizeof(int), 1, in) != 0 ||\n        rd(b->coarse_start, sizeof(int), (size_t)MAX_CELLS, in) != 0 ||\n        rd(b->coarse_len, sizeof(int), (size_t)MAX_CELLS, in) != 0 ||\n        rd(&b->step_idx, sizeof(int), 1, in) != 0 ||\n        rd(&b->dt_carry, sizeof(double), 1, in) != 0 ||\n        rd(&b->adjacency, sizeof(int), 1, in) != 0 ||\n        rd(b->halo_q, sizeof(double), (size_t)NVAR, in) != 0) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"state short\");\n        return -13;\n    }\n\n    fclose(in);\n    c->reason = REASON_OK;\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\n    return 0;\n}\nEOF\n"]
