[84.718459, "o", "#include \"../include/cell_view.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d) {\r\n    if (!a || !d) return -1;\r\n    int n = a->n;\r\n    for (int i = 0; i < n; i++) {\r\n        d->parent[i] = a->cells[i].parent;\r\n    }\r\n    if (b && c > 0) {\r\n        for (int i = 0; i < c && i < n; i++) {\r\n            int idx = b[i];\r\n            if (idx >= 0 && idx < n) {\r\n                d->parent[idx] = a->cells[idx].parent;\r\n            }\r\n        }\r\n    }\r\n    return 0;\r\n}\r\n\u001b[?2004hroot@a48c1a67d572:/app# "]
[84.845764, "i", "sed -n '1,260p' /app/drv_u/run_blend.cpp\n"]
[84.846401, "o", "sed -n '1,260p' /app/drv_u/run_blend.cpp\r\n\u001b[?2004l\r"]
[84.848291, "o", "#include \"phases.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_fold(SimState *st, const ScenarioSpec *spec) {\r\n    for (int v = 0; v < NVAR; v++) st->halo_q[v] = 0.0;\r\n\r\n    int seam = -1;\r\n    for (int c = 0; c < st->n_coarse; c++) {\r\n        if (st->coarse_len[c] > 1) { seam = c; break; }\r\n    }\r\n    if (seam >= 0) {\r\n        int start = st->coarse_start[seam];\r\n        int k = st->coarse_len[seam];\r\n        CellPatch src;\r\n        src.n = k;\r\n        for (int j = 0; j < k && j < MAX_LEAVES; j++) {\r\n            src.vol[j] = st->grid.cells[start + j].vol;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                src.q[j * NVAR + v] = st->grid.cells[start + j].q[v];\r\n            }\r\n        }\r\n        CellPatch ghost;\r\n        memset(&ghost, 0, sizeof(ghost));\r\n        op_b(&ghost, &src, k, 1);\r\n        for (int v = 0; v < NVAR; v++) st->halo_q[v] = ghost.q[v];\r\n    }\r\n\r\n    if (!spec->do_collapse) return;\r\n\r\n    CellGrid folded;\r\n    folded.n = 0;\r\n    for (int c = 0; c < st->n_coarse; c++) {\r\n        int start = st->coarse_start[c];\r\n        int k = st->coarse_len[c];\r\n        int gi = folded.n++;\r\n        if (k < 2) {\r\n            folded.cells[gi] = st->grid.cells[start];\r\n            folded.cells[gi].idx = gi;\r\n            folded.cells[gi].tier = 0;\r\n            folded.cells[gi].parent = -1;\r\n            continue;\r\n        }\r\n        CellPatch children;\r\n        children.n = k;\r\n        for (int j = 0; j < k && j < MAX_LEAVES; j++) {\r\n            children.vol[j] = st->grid.cells[start + j].vol;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                children.q[j * NVAR + v] = st->grid.cells[start + j].q[v];\r\n            }\r\n        }\r\n        CellPatch parent;\r\n        memset(&parent, 0, sizeof(parent));\r\n        fold_q(&children, k, &parent);\r\n        folded.cells[gi].idx = gi;\r\n        folded.cells[gi].tier = 0;\r\n        folded.cells[gi].parent = -1;\r\n        folded.cells[gi].vol = parent.vol[0];\r\n        for (int v = 0; v < NVAR; v++) folded.cells[gi].q[v] = parent.q[v];\r\n    }\r\n    for (int c = 0; c < st->n_coarse; c++) {\r\n        st->coarse_start[c] = c;\r\n        st->coarse_len[c] = 1;\r\n    }\r\n    st->grid = folded;\r\n}\r\n\u001b[?2004hroot@a48c1a67d572:/app# "]
[84.965901, "i", "sed -n '1,260p' /app/agg_q/blend.cpp\n"]
[84.966258, "o", "sed -n '1,260p' /app/agg_q/blend.cpp"]
[84.966607, "o", "\r\n"]
[84.96687, "o", "\u001b[?2004l\r"]
[84.967774, "o", "#include \"../include/cell_view.h\"\r\n\r\nvoid fold_q(const CellPatch *a, int b, CellPatch *c) {\r\n    if (!a || !c) return;\r\n    int n = (a->n < b) ? a->n : b;\r\n    if (n <= 0) {\r\n        c->n = 0;\r\n        return;\r\n    }\r\n    double sum_vol = 0.0;\r\n"]
[84.967926, "o", "    double sum_q[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int i = 0; i < n; i++) {\r\n        sum_vol += a->vol[i];\r\n        for (int v = 0; v < NVAR; v++) {\r\n            sum_q[v] += a->q[i * NVAR + v];\r\n        }\r\n    }\r\n    c->n = 1;\r\n    c->vol[0] = sum_vol;\r\n    double inv_n = 1.0 / (double)n;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        c->q[v] = sum_q[v] * inv_n;\r\n    }\r\n}\r\n"]
[84.968039, "o", "\u001b[?2004h"]
[84.968186, "o", "root@a48c1a67d572:/app# "]
[97.026193, "i", "sed -n '1,260p' /app/src/audit_emit.cpp\n"]
[97.027145, "o", "sed -n '1,260p' /app/src/audit_emit.cpp\r\n\u001b[?2004l\r"]
[97.028585, "o", "#include \"../include/audit_emit.h\"\r\n\r\n#include <stdio.h>\r\n#include <sys/stat.h>\r\n#include <string.h>\r\n#include <errno.h>\r\n\r\nstatic void mkpath(const char *path) {\r\n    char buf[512];\r\n    snprintf(buf, sizeof(buf), \"%s\", path);\r\n"]
[97.028644, "o", "    int n = (int)strlen(buf);\r\n    for (int i = 1; i < n; i++) {\r\n        if (buf[i] == '/') {\r\n            buf[i] = 0;\r\n            mkdir(buf, 0755);\r\n            buf[i] = '/';\r\n        }\r\n"]
[97.028718, "o", "    }\r\n}\r\n\r\nstatic void emit_row(FILE *fp, const ScenarioOutcome *o) {\r\n"]
[97.028773, "o", "    fprintf(fp, \"    {\\n\");\r\n    fprintf(fp, \"      \\\"name\\\": \\\"%s\\\",\\n\", o->name);\r\n"]
[97.028891, "o", "    fprintf(fp, \"      \\\"base_total\\\": [%.17g, %.17g, %.17g],\\n\",\r\n"]
[97.029273, "o", "        o->base_total[0], o->base_total[1], o->base_total[2]);\r\n    fprintf(fp, \"      \\\"after_total\\\": [%.17g, %.17g, %.17g],\\n\",\r\n        o->after_total[0], o->after_total[1], o->after_total[2]);\r\n    fprintf(fp, \"      \\\"resumed_total\\\": [%.17g, %.17g, %.17g],\\n\",\r\n        o->resumed_total[0], o->resumed_total[1], o->resumed_total[2]);\r\n    fprintf(fp, \"      \\\"drift_ratio\\\": %.17g,\\n\", o->drift_ratio);\r\n    fprintf(fp, \"      \\\"balanced\\\": %s,\\n\", o->balanced ? \"true\" : \"false\");\r\n    fprintf(fp, \"      \\\"base_match\\\": %s,\\n\", o->base_match ? \"true\" : \"false\");\r\n    fprintf(fp, \"      \\\"adjacency\\\": %d,\\n\", o->adjacency);\r\n    fprintf(fp, \"      \\\"halo_q\\\": [%.17g, %.17g, %.17g]\\n\",\r\n        o->halo_q[0], o->halo_q[1], o->halo_q[2]);\r\n    fprintf(fp, \"    }\");\r\n}\r\n\r\nvoid emit_one(const ScenarioOutcome *a, const char *out_path) {\r\n    mkpath(out_path);\r\n    FILE *fp = fopen(out_path, \"w\");\r\n    if (!fp) return;\r\n    fprintf(fp, \"{\\n\");\r\n    fprintf(fp, \"  \\\"cases\\\": [\\n\");\r\n    emit_row(fp, a);\r\n    fprintf(fp, \"\\n  ]\\n\");\r\n    fprintf(fp, \"}\\n\");\r\n    fclose(fp);\r\n}\r\n\r\nvoid emit_matrix(const ScenarioOutcome *a, int n, const char *out_path) {\r\n    mkpath(out_path);\r\n    FILE *fp = fopen(out_path, \"w\");\r\n    if (!fp) return;\r\n    fprintf(fp, \"{\\n\");\r\n    fprintf(fp, \"  \\\"cases\\\": [\\n\");\r\n    for (int i = 0; i < n; i++) {\r\n        emit_row(fp, &a[i]);\r\n        fprintf(fp, \"%s\\n\", (i + 1 == n) ? \"\" : \",\");\r\n    }\r\n    fprintf(fp, \"  ]\\n\");\r\n    fprintf(fp, \"}\\n\");\r\n    fclose(fp);\r\n}\r\n"]
[97.029415, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
[97.150927, "i", "sed -n '1,240p' /app/include/cell_view.h\n"]
[97.151319, "o", "sed -n '1,240p' /app/include/cell_view.h\r\n\u001b[?2004l\r"]
[97.152731, "o", "#ifndef CELL_VIEW_H\r\n#define CELL_VIEW_H\r\n\r\n#include <stdint.h>\r\n\r\n#define NVAR 3\r\n#define MAX_CELLS 384\r\n#define MAX_FACES 768\r\n#define MAX_LEAVES 8\r\n#define REFLUX_RATE 0.25\r\n#define LEAF_SPREAD 0.1\r\n\r\nstruct CellView {\r\n    int idx;\r\n"]
[97.152778, "o", "    int tier;\r\n    int parent;\r\n    double vol;\r\n    double q[NVAR];\r\n};\r\n\r\nstruct CellGrid {\r\n    CellView cells[MAX_CELLS];\r\n    int n;\r\n};\r\n\r\nstruct CellPatch {\r\n    int n;\r\n    double vol[MAX_LEAVES];\r\n    double q[MAX_LEAVES * NVAR];\r\n};\r\n\r\n"]
[97.152957, "o", "void fold_q(const CellPatch *a, int b, CellPatch *c);\r\n\r\n#endif\r\n"]
[97.153054, "o", "\u001b[?2004h"]
[97.153178, "o", "root@a48c1a67d572:/app# "]
[97.27034, "i", "ls -la /app/drv_u && sed -n '1,260p' /app/drv_u/run_refine.cpp\n"]
[97.270813, "o", "ls -la /app/drv_u && sed -n '1,260p' /app/drv_u/run_refine.cpp\r\n\u001b[?2004l\r"]
[97.272462, "o", "total 20\r\ndrwxr-xr-x  2 root root  100 May 28 23:38 .\r\ndrwxr-xr-x 23 root root  303 May 28 23:40 ..\r\n-rw-r--r--  1 root root  375 May 28 23:38 phases.h\r\n-rw-r--r--  1 root root 3351 May 28 23:38 run.cpp\r\n-rw-r--r--  1 root root 2139 May 28 23:38 run_blend.cpp\r\n-rw-r--r--  1 root root 2590 May 28 23:38 run_refine.cpp\r\n-rw-r--r--  1 root root 1651 May 28 23:38 run_sync.cpp\r\n"]
[97.273796, "o", "#include \"phases.h\"\r\n#include \"../include/flow_record.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\r\n    CellGrid coarse = st->grid;\r\n"]
[97.273835, "o", "    CellGrid leaves;\r\n    leaves.n = 0;\r\n    st->n_coarse = spec->n_coarse;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = spec->leaf_count[c];\r\n        if (k < 1) k = 1;\r\n        int sumw = 0;\r\n        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\r\n        if (sumw <= 0) sumw = 1;\r\n        st->coarse_start[c] = leaves.n;\r\n        st->coarse_len[c] = k;\r\n        double vj[MAX_LEAVES];\r\n        double vtot = 0.0;\r\n"]
[97.273856, "o", "        double jw = 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\r\n            vtot += vj[j];\r\n            jw += vj[j] * (double)j;\r\n        }\r\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;"]
[97.273876, "o", "\r\n        for (int j = 0; j < k; j++) {\r\n            int gi = leaves.n++;\r\n            leaves.cells[gi].idx = gi;\r\n"]
[97.273898, "o", "            leaves.cells[gi].vol = vj[j];\r\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\r\n            }\r\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\r\n"]
[97.273923, "o", "            leaves.cells[gi].parent = (k > 1) ? c : -1;\r\n        }\r\n    }\r\n    st->grid = leaves;\r\n\r\n    int changed[MAX_CELLS];\r\n    int nch = 0;\r\n"]
[97.273944, "o", "    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\r\n    step_n(&st->grid, changed, nch, &st->topo);\r\n\r\n    st->bank.n_pending = 0;\r\n    if (!spec->do_flux) return;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n"]
[97.273961, "o", "        int k = st->coarse_len[c];\r\n        if (k < 2) continue;\r\n        int start = st->coarse_start[c];\r\n        double vsum = 0.0;\r\n        double wq[NVAR] = {0.0, 0.0, 0.0};\r\n        for (int j = 0; j < k; j++) {\r\n"]
[97.273983, "o", "            const CellView *cell = &st->grid.cells[start + j];\r\n            vsum += cell->vol;\r\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\r\n        }\r\n"]
[97.274, "o", "        double qbar[NVAR];\r\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\r\n        EdgePulse ep;\r\n        ep.base_idx = start;\r\n        ep.subfaces = k;\r\n        for (int j = 0; j < k; j++) {\r\n"]
[97.274022, "o", "            const CellView *cell = &st->grid.cells[start + j];\r\n            for (int v = 0; v < NVAR; v++) {\r\n                ep.flux_vals[j * NVAR + v] =\r\n                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\r\n            }\r\n"]
[97.274048, "o", "        }\r\n        op_m(&ep, &st->bank);\r\n    }\r\n}\r\n"]
[97.275592, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
