[325.030033, "o", "sed -n '1,320p' /app/rsm_k/resume.cpp\r\n\u001b[?2004l\r"]
[325.031153, "o", "#include \"../include/vault_layout.h\"\r\n"]
[325.031362, "o", "\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\nint load_k(const char *a, SimState *b, VaultAudit *c) {\r\n    if (!a || !b || !c) return -1;\r\n    memset(c, 0, sizeof(*c));\r\n    FILE *in = fopen(a, \"rb\");\r\n    if (!in) {\r\n        c->reason = REASON_MISSING;\r\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\r\n        return -2;\r\n    }\r\n    VaultHeader hdr;\r\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\r\n        fclose(in);\r\n        c->reason = REASON_SHORT;\r\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\r\n        return -3;\r\n    }\r\n    if (hdr.magic != VAULT_MAGIC) {\r\n"]
[325.031418, "o", "        fclose(in);\r\n        c->reason = REASON_MAGIC;\r\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\r\n        return -4;\r\n    }\r\n    int n_cells = 0;\r\n    fread(&n_cells, sizeof(int), 1, in);\r\n    b->grid.n = n_cells;\r\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\r\n    memset(&b->topo, 0, sizeof(b->topo));\r\n    b->bank.n_pending = 0;\r\n    fclose(in);\r\n    c->reason = REASON_OK;\r\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\r\n    return 0;\r\n}\r\n"]
[325.031709, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
[325.141593, "i", "cat > /app/lnk_n/relate.cpp <<'EOF'\n#include \"../include/cell_view.h\"\n#include \"../include/topo_link.h\"\n\n// Update topology linkage for the current grid.\n//\n// The refinement builder appends children contiguously per coarse parent.\n// Build child0/child_count ranges from the per-cell parent id.\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d) {\n    (void)b;\n    (void)c;\n    if (!a || !d) return -1;\n\n    const int n = a->n;\n    for (int i = 0; i < n; i++) {\n        d->parent[i] = a->cells[i].parent;\n    }\n\n    // Initialize child ranges.\n    for (int i = 0; i < MAX_CELLS; i++) {\n        d->child0[i] = -1;\n        d->child_count[i] = 0;\n    }\n\n    // First occurrence becomes child0, count increments for each child.\n    for (int i = 0; i < n; i++) {\n        const int p = d->parent[i];\n        if (p < 0 || p >= MAX_CELLS) continue;\n        if (d->child0[p] < 0) d->child0[p] = i;\n        d->child_count[p] += 1;\n    }\n\n    return 0;\n}\nEOF\n"]
[325.142573, "o", "cat > /app/lnk_n/relate.cpp <<'EOF'"]
