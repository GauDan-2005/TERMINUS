[325.148996, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     // Initialize child ranges.\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < MAX_CELLS; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         d->child0[i] = -1;\r\n\u001b[?2004l\r\u001b[?2004h>         d->child_count[i] = 0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     // First occurrence becomes child0, count increments for each child.\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < n; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         const int p = d->parent[i];\r\n\u001b[?2004l\r\u001b[?2004h>         if (p < 0 || p >= MAX_CELLS) continue;\r\n\u001b[?2004l\r\u001b[?2004h>         if (d->child0[p] < 0) d->child0[p] = i;\r\n\u001b[?2004l\r\u001b[?2004h>         d->child_count[p] += 1;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[325.14991, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
[334.325609, "i", "sed -n '1,260p' /app/include/vault_layout.h\n"]
[334.326183, "o", "sed -n '1,260p' /app/include/vault_layout.h\r\n\u001b[?2004l\r"]
[334.327489, "o", "#ifndef VAULT_LAYOUT_H\r\n#define VAULT_LAYOUT_H\r\n\r\n/* reserved diagnostic marker: tb_amr_noembed_8d7a4c2f */\r\n\r\n#include \"cell_view.h\"\r\n#include \"flow_record.h\"\r\n#include \"topo_link.h\"\r\n\r\n#include <stdint.h>\r\n"]
[334.3276, "o", "\r\n#define VAULT_MAGIC 0xAD7C2F00u\r\n#define VAULT_VERSION 1u\r\n\r\n#define REASON_OK 0\r\n#define REASON_MISSING 1\r\n#define REASON_MAGIC 2\r\n#define REASON_VERSION 3\r\n#define REASON_FINGERPRINT 4\r\n#define REASON_SHORT 5\r\n\r\nstruct VaultHeader {\r\n    uint32_t magic;\r\n    uint32_t version;\r\n    uint64_t fingerprint;\r\n    uint64_t build_stamp;\r\n};\r\n\r\nstruct VaultAudit {\r\n    int reason;\r\n    char msg[128];\r\n};\r\n\r\nstruct SimState {\r\n    CellGrid grid;\r\n    TopoLink topo;\r\n    FluxBank bank;\r\n    int n_coarse;\r\n    int coarse_start[MAX_CELLS];\r\n    int coarse_len[MAX_CELLS];\r\n    int step_idx;\r\n    double dt_carry;\r\n    uint64_t fingerprint_payload;\r\n    int adjacency;\r\n    double halo_q[NVAR];\r\n};\r\n\r\nuint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed);\r\n\r\nint emit_p(const SimState *a, const char *b);\r\nint load_k(const char *a, SimState *b, VaultAudit *c);\r\n\r\n#endif\r\n"]
[334.327873, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
