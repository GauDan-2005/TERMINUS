[146.91454, "i", "cat > /app/agg_q/blend.cpp <<'EOF'\n#include \"../include/cell_view.h\"\n\n// Merge (fold) a set of child cells into a single parent cell.\n//\n// The audit totals track global sums of q across all cells. Therefore q is\n// treated as an extensive, cell-integrated quantity and must be conserved\n// exactly through structural changes.\nvoid fold_q(const CellPatch *a, int b, CellPatch *c) {\n    if (!a || !c) return;\n    int n = (a->n < b) ? a->n : b;\n    if (n <= 0) {\n        c->n = 0;\n        return;\n    }\n\n    double sum_vol = 0.0;\n    double sum_q[NVAR] = {0.0, 0.0, 0.0};\n    for (int i = 0; i < n; i++) {\n        sum_vol += a->vol[i];\n        for (int v = 0; v < NVAR; v++) {\n            sum_q[v] += a->q[i * NVAR + v];\n        }\n    }\n\n    c->n = 1;\n    c->vol[0] = sum_vol;\n    for (int v = 0; v < NVAR; v++) {\n        c->q[v] = sum_q[v];\n    }\n}\nEOF\n"]
[146.915101, "o", "cat > /app/agg_q/blend.cpp <<'EOF'"]
