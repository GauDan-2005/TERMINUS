[253.390902, "o", "\r\n\u001b[?2004l\r"]
[253.392712, "o", "#ifndef FLOW_RECORD_H\r\n#define FLOW_RECORD_H\r\n\r\n#include \"cell_view.h\"\r\n\r\nstruct EdgePulse {\r\n    int base_idx;\r\n"]
[253.392833, "o", "    int subfaces;\r\n    double flux_vals[MAX_LEAVES * NVAR];\r\n};\r\n\r\nstruct FluxBank {\r\n    int n_pending;\r\n    int leaf[MAX_FACES];\r\n    double flux[MAX_FACES * NVAR];\r\n};\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b);\r\n\r\n#endif\r\n"]
[253.393091, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
[253.513438, "i", "sed -n '1,260p' /app/acc_m/edge_corr.cpp\n"]
[253.514215, "o", "sed -n '1,260p' /app/acc_m/edge_corr.cpp\r\n\u001b[?2004l\r"]
[253.515398, "o", "#include \"../include/flow_record.h\"\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b) {\r\n    if (!a || !b) return;\r\n    if (b->n_pending >= MAX_FACES) return;\r\n    int slot = b->n_pending++;\r\n    b->leaf[slot] = a->base_idx;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        b->flux[slot * NVAR + v] = a->flux_vals[v];\r\n    }\r\n}\r\n"]
[253.515814, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
