[264.481119, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[264.481146, "o", "\u001b[?2004h> "]
[264.4813, "o", "    for (int j = 0; j < a->subfaces; j++) {\r\n\u001b[?2004l\r"]
