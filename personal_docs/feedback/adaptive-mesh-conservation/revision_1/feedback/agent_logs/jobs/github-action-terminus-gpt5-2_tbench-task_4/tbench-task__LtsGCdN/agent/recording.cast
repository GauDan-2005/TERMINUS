[204.370602, "i", "perl -0777 -i -pe 's/double f = \\(k > 1\\) \\? \\(1\\.0 \\+ LEAF_SPREAD \\* \\(\\(double\\)j - jbar\\)\\) : 1\\.0;\\n            for \\(int v = 0; v < NVAR; v\\+\\+\\) \\{\\n                leaves\\.cells\\[gi\\]\\.q\\[v\\] = coarse\\.cells\\[c\\]\\.q\\[v\\] \\* f;\\n            \\}/double s = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\\n            \\/\\/ Normalize the shape so the volume-weighted totals are conserved:\\n            \\/\\/ sum_j (q_child * vol_child) == q_parent * vol_parent\\n            double denom = 0.0;\\n            for (int jj = 0; jj < k; jj++) {\\n                double ss = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)jj - jbar)) : 1.0;\\n                denom += vj[jj] * ss;\\n            }\\n            if (denom <= 0.0) denom = coarse.cells[c].vol;\\n            double scale = coarse.cells[c].vol * s \\/ denom;\\n            for (int v = 0; v < NVAR; v++) {\\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * scale;\\n            }/smsg' /app/drv_u/run_refine.cpp\n"]
