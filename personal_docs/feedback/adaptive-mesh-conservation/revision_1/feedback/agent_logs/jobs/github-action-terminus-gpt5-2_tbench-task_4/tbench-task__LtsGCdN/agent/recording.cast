[253.626386, "o", "sed -n '1,320p' /app/swp_t/sweep.cpp\r\n\u001b[?2004l\r"]
[253.627915, "o", "#include \"../include/cell_view.h\"\r\n\r\ntypedef void (*cell_fn)(CellView *, void *);\r\n\r\nvoid traverse_t(CellGrid *a, cell_fn fn, void *ctx) {\r\n    if (!a || !fn) return;\r\n"]
[253.628149, "o", "    for (int i = 0; i < a->n; i++) {\r\n        fn(&a->cells[i], ctx);\r\n    }\r\n}\r\n\r\ndouble span_t(const CellGrid *a) {\r\n    if (!a || a->n == 0) return 0.0;\r\n"]
[253.629599, "o", "    double lo = a->cells[0].vol;\r\n    double hi = a->cells[0].vol;\r\n    for (int i = 1; i < a->n; i++) {\r\n        double v = a->cells[i].vol;\r\n        if (v < lo) lo = v;\r\n        if (v > hi) hi = v;\r\n    }\r\n    return hi - lo;\r\n}\r\n"]
[253.629753, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
[253.741432, "i", "sed -n '1,260p' /app/drv_u/run_refine.cpp\n"]
[253.741851, "o", "sed -n '1,260p' /app/drv_u/run_refine.cpp\r\n\u001b[?2004l\r"]
[253.743288, "o", "#include \"phases.h\"\r\n#include \"../include/flow_record.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\r\n    CellGrid coarse = st->grid;\r\n    CellGrid leaves;\r\n    leaves.n = 0;\r\n    st->n_coarse = spec->n_coarse;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = spec->leaf_count[c];\r\n        if (k < 1) k = 1;\r\n        int sumw = 0;\r\n        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\r\n        if (sumw <= 0) sumw = 1;\r\n        st->coarse_start[c] = leaves.n;\r\n        st->coarse_len[c] = k;\r\n        double vj[MAX_LEAVES];\r\n        double vtot = 0.0;\r\n        double jw = 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\r\n            vtot += vj[j];"]
[253.743416, "o", "\r\n            jw += vj[j] * (double)j;\r\n        }\r\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            int gi = leaves.n++;\r\n            leaves.cells[gi].idx = gi;\r\n            leaves.cells[gi].vol = vj[j];\r\n            double s = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\r\n            // Normalize the shape so the volume-weighted totals are conserved:\r\n            // sum_j (q_child * vol_child) == q_parent * vol_parent\r\n            double denom = 0.0;\r\n            for (int jj = 0; jj < k; jj++) {\r\n                double ss = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)jj - jbar)) : 1.0;\r\n                denom += vj[jj] * ss;\r\n            }\r\n            if (denom <= 0.0) denom = coarse.cells[c].vol;\r\n            double scale = coarse.cells[c].vol * s / denom;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * scale;\r\n            }\r\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\r\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\r\n        }\r\n    }\r\n    st->grid = leaves;\r\n\r\n    int changed[MAX_CELLS];\r\n    int nch = 0;\r\n    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\r\n    step_n(&st->grid, changed, nch, &st->topo);\r\n\r\n    st->bank.n_pending = 0;\r\n    if (!spec->do_flux) return;\r\n"]
[253.74344, "o", "    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = st->coarse_len[c];\r\n        if (k < 2) continue;\r\n        int start = st->coarse_start[c];\r\n        double vsum = 0.0;\r\n        double wq[NVAR] = {0.0, 0.0, 0.0};\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            vsum += cell->vol;\r\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\r\n        }"]
[253.743463, "o", "\r\n        double qbar[NVAR];\r\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\r\n        EdgePulse ep;\r\n        ep.base_idx = start;\r\n        ep.subfaces = k;\r\n"]
[253.743485, "o", "        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            for (int v = 0; v < NVAR; v++) {\r\n                ep.flux_vals[j * NVAR + v] =\r\n                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\r\n"]
[253.743511, "o", "            }\r\n        }\r\n        op_m(&ep, &st->bank);\r\n"]
[253.743533, "o", "    }\r\n}\r\n"]
[253.743845, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
[253.861367, "i", "sed -n '1,240p' /app/lnk_n/relate.cpp\n"]
[253.861827, "o", "sed -n '1,240p' /app/lnk_n/relate.cpp\r\n\u001b[?2004l\r"]
[253.863762, "o", "#include \"../include/cell_view.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\nint step_n(CellGrid *a, const int *b, int c, TopoLink *d) {\r\n    if (!a || !d) return -1;\r\n    int n = a->n;\r\n    for (int i = 0; i < n; i++) {\r\n        d->parent[i] = a->cells[i].parent;\r\n    }\r\n    if (b && c > 0) {\r\n        for (int i = 0; i < c && i < n; i++) {\r\n            int idx = b[i];\r\n"]
[253.863982, "o", "            if (idx >= 0 && idx < n) {\r\n                d->parent[idx] = a->cells[idx].parent;\r\n            }\r\n        }\r\n    }\r\n    return 0;\r\n}\r\n"]
[253.864097, "o", "\u001b[?2004h"]
[253.864138, "o", "root@a48c1a67d572:/app# "]
[264.477442, "i", "cat > /app/acc_m/edge_corr.cpp <<'EOF'\n#include \"../include/flow_record.h\"\n\n// Record per-leaf reflux pulses.\n//\n// EdgePulse describes a coarse cell interface with `subfaces` refined leaves.\n// The bank must store one pending entry per leaf so the later reflux pass can\n// apply the full correction and the pending count matches the expected\n// subface count used by the audit.\nvoid op_m(const EdgePulse *a, FluxBank *b) {\n    if (!a || !b) return;\n    if (a->subfaces <= 0) return;\n\n    for (int j = 0; j < a->subfaces; j++) {\n        if (b->n_pending >= MAX_FACES) return;\n        int slot = b->n_pending++;\n        b->leaf[slot] = a->base_idx + j;\n        for (int v = 0; v < NVAR; v++) {\n            b->flux[slot * NVAR + v] = a->flux_vals[j * NVAR + v];\n        }\n    }\n}\nEOF\n"]
[264.477995, "o", "cat > /app/acc_m/edge_corr.cpp <<'EOF'"]
[264.47804, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> #include \"../include/flow_record.h\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[264.478505, "o", "> \r\n"]
