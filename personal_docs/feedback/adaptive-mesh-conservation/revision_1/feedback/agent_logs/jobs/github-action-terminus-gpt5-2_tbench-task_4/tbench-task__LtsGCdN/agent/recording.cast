[380.685316, "o", "\u001b[?2004hroot@a48c1a67d572:/app# "]
[380.818306, "i", "cat > /app/srl_p/serial.cpp <<'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n\nstatic int wr(const void *p, size_t sz, size_t n, FILE *fp) {\n    return (fwrite(p, sz, n, fp) == n) ? 0 : -1;\n}\n\nint emit_p(const SimState *a, const char *b) {\n    if (!a || !b) return -1;\n    FILE *fp = fopen(b, \"wb\");\n    if (!fp) return -2;\n\n    VaultHeader hdr;\n    hdr.magic = VAULT_MAGIC;\n    hdr.version = VAULT_VERSION;\n    hdr.fingerprint = a->fingerprint_payload;\n    hdr.build_stamp = (uint64_t)BUILD_STAMP;\n\n    if (wr(&hdr, sizeof(hdr), 1, fp) != 0) { fclose(fp); return -3; }\n\n    int n_cells = a->grid.n;\n    if (wr(&n_cells, sizeof(int), 1, fp) != 0) { fclose(fp); return -3; }\n    if (n_cells < 0) { fclose(fp); return -4; }\n    if (wr(a->grid.cells, sizeof(CellView), (size_t)n_cells, fp) != 0) { fclose(fp); return -3; }\n\n    // Persist structural bookkeeping for deterministic resume.\n    if (wr(&a->topo, sizeof(TopoLink), 1, fp) != 0) { fclose(fp); return -3; }\n\n    if (wr(&a->bank.n_pending, sizeof(int), 1, fp) != 0) { fclose(fp); return -3; }\n    int n_pending = a->bank.n_pending;\n    if (n_pending < 0) { fclose(fp); return -4; }\n    if (n_pending > MAX_FACES) n_pending = MAX_FACES;\n    if (wr(a->bank.leaf, sizeof(int), (size_t)n_pending, fp) != 0) { fclose(fp); return -3; }\n    if (wr(a->bank.flux, sizeof(double) * NVAR, (size_t)n_pending, fp) != 0) { fclose(fp); return -3; }\n\n    if (wr(&a->n_coarse, sizeof(int), 1, fp) != 0) { fclose(fp); return -3; }\n    if (wr(a->coarse_start, sizeof(int), (size_t)MAX_CELLS, fp) != 0) { fclose(fp); return -3; }\n    if (wr(a->coarse_len, sizeof(int), (size_t)MAX_CELLS, fp) != 0) { fclose(fp); return -3; }\n    if (wr(&a->step_idx, sizeof(int), 1, fp) != 0) { fclose(fp); return -3; }\n    if (wr(&a->dt_carry, sizeof(double), 1, fp) != 0) { fclose(fp); return -3; }\n    if (wr(&a->adjacency, sizeof(int), 1, fp) != 0) { fclose(fp); return -3; }\n    if (wr(a->halo_q, sizeof(double), (size_t)NVAR, fp) != 0) { fclose(fp); return -3; }\n\n    fclose(fp);\n    return 0;\n}\nEOF\n"]
[380.818854, "o", "cat > /app/srl_p/serial.cpp <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[380.820843, "o", "#include \"../include/vault_layout.h\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> #include <stdio.h>\r\n\u001b[?2004l\r"]
