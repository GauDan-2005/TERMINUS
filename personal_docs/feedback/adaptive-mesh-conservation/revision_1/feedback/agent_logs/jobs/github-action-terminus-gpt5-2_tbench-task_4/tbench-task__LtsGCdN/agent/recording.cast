[97.538591, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[97.538787, "o", "+            // q is stored as an extensive, cell-integrated quantity.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[97.539068, "o", "+            // Folding (merging) must conserve the global totals by summing\r\n\u001b[?2004l\r"]
[97.539101, "o", "\u001b[?2004h> "]
[97.539293, "o", "+            // contributions from all children.\r\n\u001b[?2004l\r"]
