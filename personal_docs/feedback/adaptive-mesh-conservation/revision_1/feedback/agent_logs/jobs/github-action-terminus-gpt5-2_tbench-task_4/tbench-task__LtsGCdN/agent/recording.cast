[97.537178, "o", "\u001b[?2004h> "]
[97.537378, "o", "     double sum_q[NVAR] = {0.0, 0.0, 0.0};\r\n\u001b[?2004l\r"]
[97.537405, "o", "\u001b[?2004h"]
[97.537428, "o", "> "]
[97.537573, "o", "     for (int i = 0; i < n; i++) {\r\n\u001b[?2004l\r"]
