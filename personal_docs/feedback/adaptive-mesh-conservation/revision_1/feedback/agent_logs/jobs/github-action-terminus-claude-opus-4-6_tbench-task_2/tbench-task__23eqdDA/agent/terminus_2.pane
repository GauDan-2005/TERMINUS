[?2004hroot@64b3f3bf7e4a:/app# cat /app/acc_m/edge_corr.cpp
[?2004l#include "../include/flow_record.h"

void op_m(const EdgePulse *a, FluxBank *b) {
    if (!a || !b) return;
    if (b->n_pending >= MAX_FACES) return;
    int slot = b->n_pending++;
    b->leaf[slot] = a->base_idx;
    for (int v = 0; v < NVAR; v++) {
        b->flux[slot * NVAR + v] = a->flux_vals[v];
    }
}
[?2004hroot@64b3f3bf7e4a:/app# cat /app/agg_q/blend.cpp
[?2004l#include "../include/cell_view.h"

void fold_q(const CellPatch *a, int b, CellPatch *c) {
    if (!a || !c) return;
    int n = (a->n < b) ? a->n : b;
    if (n <= 0) {
        c->n = 0;
        return;
    }
    double sum_vol = 0.0;
    double sum_q[NVAR] = {0.0, 0.0, 0.0};
    for (int i = 0; i < n; i++) {
        sum_vol += a->vol[i];
        for (int v = 0; v < NVAR; v++) {
            sum_q[v] += a->q[i * NVAR + v];
        }
    }
    c->n = 1;
    c->vol[0] = sum_vol;
    double inv_n = 1.0 / (double)n;
    for (int v = 0; v < NVAR; v++) {
        c->q[v] = sum_q[v] * inv_n;
    }
}
[?2004hroot@64b3f3bf7e4a:/app# cat /app/src/vault_io.cpp
[?2004l#include "../include/vault_layout.h"

#include <stdint.h>

uint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed) {
    const uint8_t *p = (const uint8_t *)data;
    uint64_t h = 0xcbf29ce484222325ull ^ seed;
    for (int i = 0; i < n_bytes; i++) {
        h ^= (uint64_t)p[i];
        h *= 0x100000001b3ull;
    }
    return h;
}
