[263.668964, "o", "        snprintf(c->msg, sizeof(c->msg), \"header short\");\r\n\u001b[?2004l\r"]
[263.669002, "o", "\u001b[?2004h"]
[263.669023, "o", "> "]
[263.66908, "o", "        return -3;\r\n\u001b[?2004l\r"]
[263.669107, "o", "\u001b[?2004h"]
[263.669132, "o", "> "]
[263.669151, "o", "    }\r\n\u001b[?2004l\r"]
[263.669169, "o", "\u001b[?2004h"]
[263.669186, "o", "> "]
[263.669324, "o", "    if (hdr.magic != VAULT_MAGIC) {\r\n\u001b[?2004l\r"]
[263.669341, "o", "\u001b[?2004h"]
[263.669358, "o", "> "]
[263.669433, "o", "        fclose(in);\r\n\u001b[?2004l\r"]
[263.66945, "o", "\u001b[?2004h"]
[263.669467, "o", "> "]
[263.669585, "o", "        c->reason = REASON_MAGIC;\r\n\u001b[?2004l\r"]
[263.669609, "o", "\u001b[?2004h"]
[263.669626, "o", "> "]
[263.669877, "o", "        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\r\n\u001b[?2004l\r"]
[263.669907, "o", "\u001b[?2004h"]
[263.669941, "o", "> "]
[263.669991, "o", "        return -4;\r\n\u001b[?2004l\r"]
[263.670018, "o", "\u001b[?2004h"]
[263.670035, "o", "> "]
[263.670054, "o", "    }\r\n\u001b[?2004l\r"]
[263.670081, "o", "\u001b[?2004h"]
[263.670104, "o", "> "]
[263.670286, "o", "    if (hdr.fingerprint != b->fingerprint_payload) {\r\n\u001b[?2004l\r"]
[263.670318, "o", "\u001b[?2004h"]
[263.670335, "o", "> "]
[263.671938, "o", "        fclose(in);\r\n\u001b[?2004l\r\u001b[?2004h>         c->reason = REASON_FINGERPRINT;\r\n\u001b[?2004l\r\u001b[?2004h>         snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\r\n\u001b[?2004l\r\u001b[?2004h>         return -5;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     int n_cells = 0;\r\n\u001b[?2004l\r\u001b[?2004h>     fread(&n_cells, sizeof(int), 1, in);\r\n\u001b[?2004l\r\u001b[?2004h>     b->grid.n = n_cells;\r\n\u001b[?2004l\r\u001b[?2004h>     fread(b->grid.cells, sizeof(CellView), n_cells, in);\r\n\u001b[?2004l\r\u001b[?2004h>     /* Restore additional state */\r\n\u001b[?2004l\r\u001b[?2004h>     int n_pending = 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.672526, "o", "    if (fread(&n_pending, sizeof(int), 1, in) == 1 && n_pending >= 0 && n_pending <= MAX_FACES) {\r\n\u001b[?2004l\r"]
[263.672652, "o", "\u001b[?2004h>         b->bank.n_pending = n_pending;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.672776, "o", "        if (n_pending > 0) {\r\n\u001b[?2004l\r"]
[263.672897, "o", "\u001b[?2004h> "]
[263.673029, "o", "            fread(b->bank.leaf, sizeof(int), n_pending, in);\r\n\u001b[?2004l\r"]
[263.673059, "o", "\u001b[?2004h"]
[263.673082, "o", "> "]
[263.673384, "o", "            fread(b->bank.flux, sizeof(double), n_pending * NVAR, in);\r\n\u001b[?2004l\r"]
[263.673502, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[263.6736, "o", "\u001b[?2004h> "]
[263.673644, "o", "        int nc = 0;\r\n\u001b[?2004l\r"]
[263.673787, "o", "\u001b[?2004h> "]
[263.67404, "o", "        if (fread(&nc, sizeof(int), 1, in) == 1 && nc >= 0 && nc <= MAX_CELLS) {\r\n\u001b[?2004l\r"]
[263.674381, "o", "\u001b[?2004h> "]
[263.674937, "o", "            b->n_coarse = nc;\r\n\u001b[?2004l\r"]
[263.675139, "o", "\u001b[?2004h> "]
[263.67535, "o", "            fread(b->coarse_start, sizeof(int), nc, in);\r\n\u001b[?2004l\r"]
[263.675507, "o", "\u001b[?2004h> "]
[263.675674, "o", "            fread(b->coarse_len, sizeof(int), nc, in);\r\n\u001b[?2004l\r\u001b[?2004h>         }"]
[263.675855, "o", "\r\n\u001b[?2004l\r"]
[263.676024, "o", "\u001b[?2004h> "]
[263.676148, "o", "        TopoLink topo;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.676317, "o", "        if (fread(&topo, sizeof(TopoLink), 1, in) == 1) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.676465, "o", "            b->topo = topo;\r\n\u001b[?2004l\r"]
[263.676496, "o", "\u001b[?2004h> "]
[263.676727, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.676871, "o", "        fread(&b->step_idx, sizeof(int), 1, in);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.677046, "o", "        fread(&b->dt_carry, sizeof(double), 1, in);\r\n\u001b[?2004l\r"]
[263.677172, "o", "\u001b[?2004h> "]
[263.677349, "o", "    } else {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.677416, "o", "        /* Legacy vault without extended state - zero out */\r\n\u001b[?2004l\r"]
[263.677637, "o", "\u001b[?2004h> "]
[263.677671, "o", "        b->bank.n_pending = 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.677839, "o", "        memset(&b->topo, 0, sizeof(b->topo));\r\n\u001b[?2004l\r"]
[263.677866, "o", "\u001b[?2004h> "]
[263.677891, "o", "    }"]
[263.678023, "o", "\r\n\u001b[?2004l\r"]
[263.67806, "o", "\u001b[?2004h>     fclose(in);\r\n\u001b[?2004l\r\u001b[?2004h"]
[263.678174, "o", "> "]
[263.678302, "o", "    c->reason = REASON_OK;\r\n\u001b[?2004l\r"]
[263.678394, "o", "\u001b[?2004h> "]
[263.67849, "o", "    snprintf(c->msg, sizeof(c->msg), \"ok\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[263.678519, "o", "> "]
[263.678624, "o", "    return 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.678655, "o", "}\r\n\u001b[?2004l\r"]
[263.678673, "o", "\u001b[?2004h"]
[263.678691, "o", "> "]
[263.678713, "o", "EOF\r\n\u001b[?2004l\r"]
