[62.685616, "o", "#ifndef FLOW_RECORD_H\r\n#define FLOW_RECORD_H\r\n\r\n#include \"cell_view.h\"\r\n\r\nstruct EdgePulse {\r\n    int base_idx;\r\n    int subfaces;\r\n    double flux_vals[MAX_LEAVES * NVAR];\r\n};\r\n\r\nstruct FluxBank {\r\n    int n_pending;\r\n    int leaf[MAX_FACES];\r\n    double flux[MAX_FACES * NVAR];\r\n};\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b);\r\n\r\n#endif\r\n"]
