[25.664336, "o", "cat /app/drv_u/phases.h\r\n\u001b[?2004l\r"]
[25.665605, "o", "#ifndef PHASES_H\r\n#define PHASES_H\r\n\r\n#include \"../include/case_spec.h\"\r\n#include \"../include/vault_layout.h\"\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec);\r\nvoid phase_fold(SimState *st, const ScenarioSpec *spec);\r\nint phase_persist(SimState *st, const char *vault_path, const char *tamper_path,\r\n                  const char *log_path, VaultAudit *resume_aud);\r\n\r\n#endif\r\n\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[25.783927, "i", "cat /app/include/cell_view.h\n"]
[25.784262, "o", "cat /app/include/cell_view.h\r\n\u001b[?2004l\r"]
[25.785333, "o", "#ifndef CELL_VIEW_H\r\n#define CELL_VIEW_H\r\n\r\n#include <stdint.h>\r\n\r\n#define NVAR 3\r\n#define MAX_CELLS 384\r\n#define MAX_FACES 768\r\n#define MAX_LEAVES 8\r\n#define REFLUX_RATE 0.25\r\n#define LEAF_SPREAD 0.1\r\n\r\nstruct CellView {\r\n    int idx;\r\n    int tier;\r\n    int parent;\r\n    double vol;\r\n    double q[NVAR];\r\n};\r\n\r\nstruct CellGrid {\r\n    CellView cells[MAX_CELLS];\r\n    int n;\r\n};\r\n\r\nstruct CellPatch {\r\n    int n;\r\n    double vol[MAX_LEAVES];\r\n    double q[MAX_LEAVES * NVAR];\r\n};\r\n\r\nvoid fold_q(const CellPatch *a, int b, CellPatch *c);\r\n\r\n#endif\r\n"]
[25.785682, "o", "\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[25.90793, "i", "cat /app/include/vault_layout.h\n"]
[25.90836, "o", "cat /app/include/vault_layout.h\r\n\u001b[?2004l\r"]
[25.909783, "o", "#ifndef VAULT_LAYOUT_H\r\n#define VAULT_LAYOUT_H\r\n\r\n/* reserved diagnostic marker: tb_amr_noembed_8d7a4c2f */\r\n\r\n#include \"cell_view.h\"\r\n#include \"flow_record.h\"\r\n#include \"topo_link.h\"\r\n\r\n#include <stdint.h>\r\n\r\n#define VAULT_MAGIC 0xAD7C2F00u\r\n#define VAULT_VERSION 1u\r\n\r\n#define REASON_OK 0\r\n#define REASON_MISSING 1\r\n#define REASON_MAGIC 2\r\n#define REASON_VERSION 3\r\n#define REASON_FINGERPRINT 4\r\n#define REASON_SHORT 5\r\n\r\nstruct VaultHeader {\r\n    uint32_t magic;\r\n    uint32_t version;\r\n    uint64_t fingerprint;\r\n    uint64_t build_stamp;\r\n};\r\n\r\nstruct VaultAudit {\r\n    int reason;\r\n    char msg[128];\r\n};\r\n\r\nstruct SimState {\r\n    CellGrid grid;\r\n    TopoLink topo;\r\n    FluxBank bank;\r\n    int n_coarse;\r\n    int coarse_start[MAX_CELLS];\r\n    int coarse_len[MAX_CELLS];\r\n    int step_idx;\r\n    double dt_carry;\r\n    uint64_t fingerprint_payload;\r\n    int adjacency;\r\n    double halo_q[NVAR];\r\n};\r\n\r\nuint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed);\r\n\r\nint emit_p(const SimState *a, const char *b);\r\nint load_k(const char *a, SimState *b, VaultAudit *c);\r\n\r\n#endif\r\n\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[26.028061, "i", "cat /app/acc_m/edge_corr.cpp\n"]
[26.028288, "o", "cat /app/acc_m/edge_corr.cpp\r\n\u001b[?2004l\r"]
[26.029572, "o", "#include \"../include/flow_record.h\"\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b) {\r\n    if (!a || !b) return;\r\n    if (b->n_pending >= MAX_FACES) return;\r\n    int slot = b->n_pending++;\r\n    b->leaf[slot] = a->base_idx;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        b->flux[slot * NVAR + v] = a->flux_vals[v];\r\n    }\r\n}\r\n\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[26.147948, "i", "cat /app/agg_q/blend.cpp\n"]
[26.148799, "o", "cat /app/agg_q/blend.cpp\r\n\u001b[?2004l\r"]
[26.151336, "o", "#include \"../include/cell_view.h\"\r\n\r\nvoid fold_q(const CellPatch *a, int b, CellPatch *c) {\r\n    if (!a || !c) return;\r\n    int n = (a->n < b) ? a->n : b;\r\n    if (n <= 0) {\r\n        c->n = 0;\r\n        return;\r\n    }\r\n    double sum_vol = 0.0;\r\n    double sum_q[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int i = 0; i < n; i++) {\r\n        sum_vol += a->vol[i];\r\n        for (int v = 0; v < NVAR; v++) {\r\n            sum_q[v] += a->q[i * NVAR + v];\r\n        }\r\n    }\r\n    c->n = 1;\r\n    c->vol[0] = sum_vol;\r\n    double inv_n = 1.0 / (double)n;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        c->q[v] = sum_q[v] * inv_n;\r\n    }\r\n}\r\n\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[26.271837, "i", "cat /app/src/vault_io.cpp\n"]
[26.27233, "o", "cat /app/src/vault_io.cpp\r\n\u001b[?2004l\r"]
[26.273609, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdint.h>\r\n\r\nuint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed) {\r\n    const uint8_t *p = (const uint8_t *)data;\r\n    uint64_t h = 0xcbf29ce484222325ull ^ seed;\r\n    for (int i = 0; i < n_bytes; i++) {\r\n        h ^= (uint64_t)p[i];\r\n        h *= 0x100000001b3ull;\r\n    }\r\n    return h;\r\n}\r\n"]
[26.273763, "o", "\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[62.312032, "i", "cat /app/srl_p/serial.cpp\n"]
[62.312357, "o", "cat /app/srl_p/serial.cpp\r\n\u001b[?2004l\r"]
[62.313873, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdio.h>\r\n\r\nint emit_p(const SimState *a, const char *b) {\r\n    if (!a || !b) return -1;\r\n    FILE *fp = fopen(b, \"wb\");\r\n    if (!fp) return -2;\r\n    VaultHeader hdr;\r\n    hdr.magic = VAULT_MAGIC;\r\n    hdr.version = VAULT_VERSION;\r\n    hdr.fingerprint = a->fingerprint_payload;\r\n    hdr.build_stamp = (uint64_t)BUILD_STAMP;\r\n    fwrite(&hdr, sizeof(hdr), 1, fp);\r\n    int n_cells = a->grid.n;\r\n    fwrite(&n_cells, sizeof(int), 1, fp);\r\n    fwrite(a->grid.cells, sizeof(CellView), n_cells, fp);\r\n    fclose(fp);\r\n    return 0;\r\n}\r\n\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[62.435999, "i", "cat /app/rsm_k/resume.cpp\n"]
[62.436347, "o", "cat /app/rsm_k/resume.cpp\r\n\u001b[?2004l\r"]
[62.437305, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\nint load_k(const char *a, SimState *b, VaultAudit *c) {\r\n    if (!a || !b || !c) return -1;\r\n    memset(c, 0, sizeof(*c));\r\n    FILE *in = fopen(a, \"rb\");\r\n    if (!in) {\r\n        c->reason = REASON_MISSING;\r\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\r\n        return -2;\r\n    }\r\n    VaultHeader hdr;\r\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\r\n        fclose(in);\r\n        c->reason = REASON_SHORT;\r\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\r\n        return -3;\r\n    }\r\n    if (hdr.magic != VAULT_MAGIC) {\r\n        fclose(in);\r\n        c->reason = REASON_MAGIC;\r\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\r\n        return -4;\r\n    }\r\n    int n_cells = 0;\r\n    fread(&n_cells, sizeof(int), 1, in);\r\n    b->grid.n = n_cells;\r\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\r\n    memset(&b->topo, 0, sizeof(b->topo));\r\n    b->bank.n_pending = 0;\r\n    fclose(in);\r\n    c->reason = REASON_OK;\r\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\r\n    return 0;\r\n}\r\n"]
[62.440159, "o", "\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[62.55251, "i", "cat /app/drv_u/run.cpp\n"]
[62.5528, "o", "cat /app/drv_u/run.cpp\r\n\u001b[?2004l\r"]
[62.553809, "o", "#include \"phases.h\"\r\n#include \"../include/ic_loader.h\"\r\n\r\n#include <math.h>\r\n#include <string.h>\r\n#include <stdio.h>\r\n\r\nstatic int compute_adjacency(const SimState *st) {\r\n    int count = 0;\r\n    for (int i = 0; i < st->grid.n; i++) {\r\n        int p = st->topo.parent[i];\r\n        if (p < 0) continue;\r\n        int c0 = st->topo.child0[p];\r\n        int cn = st->topo.child_count[p];\r\n        if (cn > 0 && i >= c0 && i < c0 + cn) count++;\r\n    }\r\n    return count;\r\n}\r\n\r\nstatic void apply_reflux(SimState *st) {\r\n    for (int i = 0; i < st->bank.n_pending; i++) {\r\n        int leaf = st->bank.leaf[i];\r\n        if (leaf < 0 || leaf >= st->grid.n) continue;\r\n        double vol = st->grid.cells[leaf].vol;\r\n        if (vol <= 0.0) continue;\r\n        for (int v = 0; v < NVAR; v++) {\r\n            st->grid.cells[leaf].q[v] += st->bank.flux[i * NVAR + v] / vol;\r\n        }\r\n    }\r\n}\r\n\r\nint run_u(const ScenarioSpec *spec, const char *mode, ScenarioOutcome *out) {\r\n    (void)mode;\r\n    memset(out, 0, sizeof(*out));\r\n    snprintf(out->name, sizeof(out->name), \"%s\", spec->name);\r\n\r\n    SimState st;\r\n    memset(&st, 0, sizeof(st));\r\n\r\n    CellGrid coarse;\r\n"]
[62.554056, "o", "    if (load_init(spec->profile, spec->n_coarse, &coarse) != 0) return -1;\r\n\r\n    double base[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        for (int v = 0; v < NVAR; v++) base[v] += coarse.cells[c].vol * coarse.cells[c].q[v];\r\n    }\r\n\r\n    st.grid = coarse;\r\n    uint64_t fp = vault_fnv1a(spec->name, (int)strlen(spec->name), 0ull);\r\n    fp = vault_fnv1a(&spec->profile, (int)sizeof(int), fp);\r\n    fp = vault_fnv1a(&spec->n_coarse, (int)sizeof(int), fp);\r\n    st.fingerprint_payload = fp;\r\n\r\n    phase_grow(&st, spec);\r\n\r\n    if (spec->do_restart) {\r\n        VaultAudit aud;\r\n        memset(&aud, 0, sizeof(aud));\r\n        char vault[256];\r\n        char probe[256];\r\n        char logp[256];\r\n        snprintf(vault, sizeof(vault), \"%s/work/vault.bin\", app_root());\r\n        snprintf(probe, sizeof(probe), \"%s/work/vault_probe.bin\", app_root());\r\n        snprintf(logp, sizeof(logp), \"%s/output/persistence_audit.log\", app_root());\r\n        phase_persist(&st, vault, probe, logp, &aud);\r\n    }\r\n\r\n    out->adjacency = compute_adjacency(&st);\r\n\r\n    apply_reflux(&st);\r\n\r\n    phase_fold(&st, spec);\r\n\r\n    double after[NVAR] = {0.0, 0.0, 0.0};\r\n    double moment[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int i = 0; i < st.grid.n; i++) {\r\n        double vol = st.grid.cells[i].vol;\r\n        for (int v = 0; v < NVAR; v++) {\r\n            double m = vol * st.grid.cells[i].q[v];\r\n            after[v] += m;\r\n            moment[v] += (double)(i + 1) * m;\r\n        }\r\n    }\r\n\r\n    int expected = 0;\r\n    if (spec->do_flux) {\r\n        for (int c = 0; c < spec->n_coarse; c++) {\r\n            if (spec->leaf_count[c] > 1) expected += spec->leaf_count[c];\r\n        }\r\n    }\r\n\r\n    double drift = 0.0;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        double denom = fabs(base[v]);\r\n        if (denom < 1e-12) denom = 1e-12;\r\n        double d = fabs(after[v] - base[v]) / denom;\r\n        if (d > drift) drift = d;\r\n    }\r\n\r\n    for (int v = 0; v < NVAR; v++) {\r\n        out->base_total[v] = base[v];\r\n        out->after_total[v] = after[v];\r\n        out->resumed_total[v] = moment[v];\r\n        out->halo_q[v] = st.halo_q[v];\r\n    }\r\n    out->drift_ratio = drift;\r\n    out->balanced = (st.bank.n_pending == expected) ? 1 : 0;\r\n    out->base_match = (drift < 1e-9) ? 1 : 0;\r\n    return 0;\r\n}\r\n"]
