[263.665192, "i", "cat > /app/rsm_k/resume.cpp << 'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n#include <string.h>\n\nint load_k(const char *a, SimState *b, VaultAudit *c) {\n    if (!a || !b || !c) return -1;\n    memset(c, 0, sizeof(*c));\n    FILE *in = fopen(a, \"rb\");\n    if (!in) {\n        c->reason = REASON_MISSING;\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\n        return -2;\n    }\n    VaultHeader hdr;\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\n        return -3;\n    }\n    if (hdr.magic != VAULT_MAGIC) {\n        fclose(in);\n        c->reason = REASON_MAGIC;\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\n        return -4;\n    }\n    if (hdr.fingerprint != b->fingerprint_payload) {\n        fclose(in);\n        c->reason = REASON_FINGERPRINT;\n        snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\n        return -5;\n    }\n    int n_cells = 0;\n    fread(&n_cells, sizeof(int), 1, in);\n    b->grid.n = n_cells;\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\n    /* Restore additional state */\n    int n_pending = 0;\n    if (fread(&n_pending, sizeof(int), 1, in) == 1 && n_pending >= 0 && n_pending <= MAX_FACES) {\n        b->bank.n_pending = n_pending;\n        if (n_pending > 0) {\n            fread(b->bank.leaf, sizeof(int), n_pending, in);\n            fread(b->bank.flux, sizeof(double), n_pending * NVAR, in);\n        }\n        int nc = 0;\n        if (fread(&nc, sizeof(int), 1, in) == 1 && nc >= 0 && nc <= MAX_CELLS) {\n            b->n_coarse = nc;\n            fread(b->coarse_start, sizeof(int), nc, in);\n            fread(b->coarse_len, sizeof(int), nc, in);\n        }\n        TopoLink topo;\n        if (fread(&topo, sizeof(TopoLink), 1, in) == 1) {\n            b->topo = topo;\n        }\n        fread(&b->step_idx, sizeof(int), 1, in);\n        fread(&b->dt_carry, sizeof(double), 1, in);\n    } else {\n        /* Legacy vault without extended state - zero out */\n        b->bank.n_pending = 0;\n        memset(&b->topo, 0, sizeof(b->topo));\n    }\n    fclose(in);\n    c->reason = REASON_OK;\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\n    return 0;\n}\nEOF\n"]
[263.665598, "o", "cat > /app/rsm_k/resume.cpp << 'EOF'\r\n"]
