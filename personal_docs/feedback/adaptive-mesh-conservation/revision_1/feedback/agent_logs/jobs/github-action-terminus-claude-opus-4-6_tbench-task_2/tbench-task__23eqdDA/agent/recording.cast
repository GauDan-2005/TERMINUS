[134.631565, "o", "#include \"../include/cell_view.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\nvoid op_b(CellPatch *a, const CellPatch *b, int c, int d) {\r\n    if (!a || !b) return;\r\n    int width = (b->n < 8) ? b->n : 8;\r\n    a->n = width;\r\n    for (int i = 0; i < width; i++) {\r\n        int src = i + d;\r\n        if (src < 0) src = 0;\r\n        if (src >= b->n) src = b->n - 1;\r\n        a->vol[i] = b->vol[src];\r\n        for (int v = 0; v < NVAR; v++) {\r\n            a->q[i * NVAR + v] = b->q[src * NVAR + v];\r\n        }\r\n    }\r\n    (void)c;\r\n}\r\n\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[134.748075, "i", "cat /app/config/cases.toml\n"]
[134.748733, "o", "cat /app/config/cases.toml\r\n"]
[134.748866, "o", "\u001b[?2004l\r"]
[134.751247, "o", "# Per-scenario schedules for the bundled sweep.\r\n# profile selects the initial-condition table under /app/data/init.\r\n# leaves is a '|'-separated list (one entry per base cell); each entry is a\r\n# comma-separated list of integer sub-cell weights for that base cell.\r\n# do_flux / do_collapse / do_restart toggle the structural phases.\r\n\r\n[storm]\r\nprofile = 0\r\nn_coarse = 4\r\ndo_flux = 1\r\ndo_collapse = 0\r\ndo_restart = 0\r\nleaves = 2,1,1|1|1|1\r\n\r\n[canyon]\r\nprofile = 1\r\nn_coarse = 4\r\ndo_flux = 1\r\ndo_collapse = 0\r\ndo_restart = 0\r\nleaves = 2,1,1|2,2|1|1\r\n\r\n[plume]\r\nprofile = 2\r\nn_coarse = 4\r\ndo_flux = 0\r\ndo_collapse = 1\r\ndo_restart = 0\r\nleaves = 2,1|3,1|1|1\r\n\r\n[spire]\r\nprofile = 0\r\nn_coarse = 4\r\ndo_flux = 0\r\ndo_collapse = 1\r\ndo_restart = 0\r\nleaves = 3,1|1|1|1\r\n\r\n[basin]\r\nprofile = 1\r\nn_coarse = 4\r\ndo_flux = 1\r\ndo_collapse = 0\r\ndo_restart = 1\r\nleaves = 2,1,1|1|1|1\r\n\r\n[dune]\r\nprofile = 2\r\nn_coarse = 4\r\ndo_flux = 1\r\ndo_collapse = 0\r\ndo_restart = 1\r\nleaves = 2,1,1|2,2|1|1\r\n\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[134.864328, "i", "cat /app/CMakeLists.txt\n"]
[134.864781, "o", "cat /app/CMakeLists.txt\r\n\u001b[?2004l\r"]
[134.865818, "o", "cmake_minimum_required(VERSION 3.16)\r\nproject(sim_run LANGUAGES CXX)\r\n\r\nset(CMAKE_CXX_STANDARD 17)\r\nset(CMAKE_CXX_STANDARD_REQUIRED ON)\r\n\r\nif(NOT DEFINED BUILD_STAMP)\r\n    if(DEFINED ENV{SOURCE_DATE_EPOCH})\r\n        set(BUILD_STAMP $ENV{SOURCE_DATE_EPOCH})\r\n    else()\r\n        set(BUILD_STAMP \"0\")\r\n    endif()\r\nendif()\r\nadd_compile_definitions(BUILD_STAMP=${BUILD_STAMP})\r\n\r\nadd_executable(sim_run\r\n    src/main.cpp\r\n    src/case_io.cpp\r\n    src/vault_io.cpp\r\n    src/audit_emit.cpp\r\n    acc_m/edge_corr.cpp\r\n    lnk_n/relate.cpp\r\n    agg_q/blend.cpp\r\n    srl_p/serial.cpp\r\n    rsm_k/resume.cpp\r\n    sync_b/halo.cpp\r\n    drv_u/run.cpp\r\n    drv_u/run_refine.cpp\r\n    drv_u/run_blend.cpp\r\n    drv_u/run_sync.cpp\r\n    swp_t/sweep.cpp\r\n    emt_e/report.cpp\r\n    prb_v/hist.cpp\r\n    tap_w/trace.cpp\r\n    cch_z/ring.cpp\r\n)\r\n\r\ntarget_include_directories(sim_run PRIVATE include)\r\n\r\nset_target_properties(sim_run PROPERTIES\r\n    RUNTIME_OUTPUT_DIRECTORY \"${CMAKE_BINARY_DIR}/bin\"\r\n)\r\n"]
[134.866261, "o", "\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[185.720201, "i", "cat /app/src/audit_emit.cpp\n"]
[185.720667, "o", "cat /app/src/audit_emit.cpp\r\n\u001b[?2004l\r"]
[185.724014, "o", "#include \"../include/audit_emit.h\"\r\n\r\n#include <stdio.h>\r\n#include <sys/stat.h>\r\n#include <string.h>\r\n#include <errno.h>\r\n\r\nstatic void mkpath(const char *path) {\r\n    char buf[512];\r\n    snprintf(buf, sizeof(buf), \"%s\", path);\r\n    int n = (int)strlen(buf);\r\n    for (int i = 1; i < n; i++) {\r\n        if (buf[i] == '/') {\r\n            buf[i] = 0;\r\n            mkdir(buf, 0755);\r\n            buf[i] = '/';\r\n        }\r\n    }\r\n}\r\n\r\nstatic void emit_row(FILE *fp, const ScenarioOutcome *o) {\r\n    fprintf(fp, \"    {\\n\");\r\n    fprintf(fp, \"      \\\"name\\\": \\\"%s\\\",\\n\", o->name);\r\n    fprintf(fp, \"      \\\"base_total\\\": [%.17g, %.17g, %.17g],\\n\",\r\n        o->base_total[0], o->base_total[1], o->base_total[2]);\r\n    fprintf(fp, \"      \\\"after_total\\\": [%.17g, %.17g, %.17g],\\n\",\r\n        o->after_total[0], o->after_total[1], o->after_total[2]);\r\n    fprintf(fp, \"      \\\"resumed_total\\\": [%.17g, %.17g, %.17g],\\n\",\r\n        o->resumed_total[0], o->resumed_total[1], o->resumed_total[2]);\r\n    fprintf(fp, \"      \\\"drift_ratio\\\": %.17g,\\n\", o->drift_ratio);\r\n    fprintf(fp, \"      \\\"balanced\\\": %s,\\n\", o->balanced ? \"true\" : \"false\");\r\n    fprintf(fp, \"      \\\"base_match\\\": %s,\\n\", o->base_match ? \"true\" : \"false\");\r\n    fprintf(fp, \"      \\\"adjacency\\\": %d,\\n\", o->adjacency);\r\n    fprintf(fp, \"      \\\"halo_q\\\": [%.17g, %.17g, %.17g]\\n\",\r\n        o->halo_q[0], o->halo_q[1], o->halo_q[2]);\r\n    fprintf(fp, \"    }\");\r\n}\r\n\r\nvoid emit_one(const ScenarioOutcome *a, const char *out_path) {\r\n    mkpath(out_path);\r\n    FILE *fp = fopen(out_path, \"w\");\r\n    if (!fp) return;\r\n    fprintf(fp, \"{\\n\");\r\n    fprintf(fp, \"  \\\"cases\\\": [\\n\");\r\n    emit_row(fp, a);\r\n    fprintf(fp, \"\\n  ]\\n\");\r\n    fprintf(fp, \"}\\n\");\r\n    fclose(fp);\r\n}\r\n\r\nvoid emit_matrix(const ScenarioOutcome *a, int n, const char *out_path) {\r\n    mkpath(out_path);\r\n    FILE *fp = fopen(out_path, \"w\");\r\n    if (!fp) return;\r\n    fprintf(fp, \"{\\n\");\r\n"]
[185.724115, "o", "    fprintf(fp, \"  \\\"cases\\\": [\\n\");\r\n    for (int i = 0; i < n; i++) {\r\n        emit_row(fp, &a[i]);\r\n        fprintf(fp, \"%s\\n\", (i + 1 == n) ? \"\" : \",\");\r\n    }\r\n    fprintf(fp, \"  ]\\n\");\r\n    fprintf(fp, \"}\\n\");\r\n    fclose(fp);\r\n}\r\n"]
[185.724334, "o", "\u001b[?2004h"]
[185.724476, "o", "root@64b3f3bf7e4a:/app# "]
[185.840324, "i", "cat /app/include/audit_emit.h\n"]
[185.840967, "o", "cat /app/include/audit_emit.h\r\n\u001b[?2004l\r"]
[185.843665, "o", "#ifndef AUDIT_EMIT_H\r\n#define AUDIT_EMIT_H\r\n\r\n#include \"cell_view.h\"\r\n\r\nstruct ScenarioOutcome {\r\n    char name[32];\r\n    double base_total[NVAR];\r\n    double after_total[NVAR];\r\n    double resumed_total[NVAR];\r\n    double drift_ratio;\r\n    int balanced;\r\n    int base_match;\r\n    int adjacency;\r\n    double halo_q[NVAR];\r\n};\r\n\r\nvoid emit_one(const ScenarioOutcome *a, const char *out_path);\r\nvoid emit_matrix(const ScenarioOutcome *a, int n, const char *out_path);\r\n\r\n#endif\r\n\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[185.956514, "i", "cat /app/emt_e/report.cpp\n"]
[185.957023, "o", "cat /app/emt_e/report.cpp\r\n\u001b[?2004l\r"]
[185.958163, "o", "#include \"../include/audit_emit.h\"\r\n\r\n#include <stdio.h>\r\n\r\nvoid summarize_e(const ScenarioOutcome *a, int n, const char *out_path) {\r\n    if (!a || !out_path) return;\r\n    FILE *fp = fopen(out_path, \"w\");\r\n    if (!fp) return;\r\n    int ok = 0;\r\n    for (int i = 0; i < n; i++) {\r\n        if (a[i].balanced && a[i].base_match) ok++;\r\n    }\r\n    fprintf(fp, \"scenarios=%d balanced_and_matched=%d\\n\", n, ok);\r\n    fclose(fp);\r\n}\r\n"]
[185.958373, "o", "\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[186.072637, "i", "cat /app/prb_v/hist.cpp\n"]
[186.073122, "o", "cat /app/prb_v/hist.cpp\r\n\u001b[?2004l\r"]
[186.074005, "o", "#include \"../include/cell_view.h\"\r\n\r\nvoid walk_v(const CellGrid *a, int b, int c, double *d) {\r\n    if (!a || !d || b <= 0) return;\r\n    for (int i = 0; i < b; i++) d[i] = 0.0;\r\n    for (int i = 0; i < a->n; i++) {\r\n        double key = a->cells[i].q[c % NVAR];\r\n        int slot = (int)(key * b);\r\n        if (slot < 0) slot = 0;\r\n        if (slot >= b) slot = b - 1;\r\n        d[slot] += a->cells[i].vol;\r\n    }\r\n}\r\n"]
[186.074298, "o", "\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[186.196254, "i", "cat /app/tap_w/trace.cpp\n"]
[186.196892, "o", "cat /app/tap_w/trace.cpp\r\n\u001b[?2004l\r"]
[186.19761, "o", "#include \"../include/cell_view.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n\r\nint stamp_w(CellGrid *a, const int *b, int c, TopoLink *d) {\r\n    if (!a || !d) return -1;\r\n    const char *env = getenv(\"SCN_TRACE\");\r\n    if (!env || env[0] != '1') return 0;\r\n    int touched = 0;\r\n    for (int i = 0; i < c; i++) {\r\n        int idx = b ? b[i] : i;\r\n        if (idx < 0 || idx >= a->n) continue;\r\n        fprintf(stderr, \"[trace] cell=%d tier=%d vol=%.6f\\n\",\r\n                idx, a->cells[idx].tier, a->cells[idx].vol);\r\n        touched++;\r\n    }\r\n    return touched;\r\n}\r\n"]
[186.197789, "o", "\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[186.316572, "i", "cat /app/cch_z/ring.cpp\n"]
[186.318269, "o", "cat /app/cch_z/ring.cpp\r\n\u001b[?2004l\r"]
[186.319142, "o", "#include \"../include/cell_view.h\"\r\n\r\n#define RING_CAP 16\r\n\r\nvoid phase_z(const CellPatch *a, int b, CellPatch *c) {\r\n    if (!a || !c) return;\r\n    static double ring[RING_CAP * NVAR];\r\n    static int head = 0;\r\n    int n = (a->n < MAX_LEAVES) ? a->n : MAX_LEAVES;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        double acc = 0.0;\r\n        for (int i = 0; i < n; i++) acc += a->q[i * NVAR + v];\r\n        ring[(head % RING_CAP) * NVAR + v] = (n > 0) ? acc / n : 0.0;\r\n    }\r\n    head = (head + 1) % RING_CAP;\r\n    c->n = 1;\r\n    c->vol[0] = (double)b;\r\n    for (int v = 0; v < NVAR; v++) c->q[v] = ring[v];\r\n}\r\n"]
[186.319328, "o", "\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[213.623945, "i", "wc -l /app/drv_u/run_refine.cpp && cat /app/drv_u/run_refine.cpp\n"]
[213.624623, "o", "wc -l /app/drv_u/run_refine.cpp && cat /app/drv_u/run_refine.cpp\r\n\u001b[?2004l\r"]
[213.626548, "o", "75 /app/drv_u/run_refine.cpp\r\n"]
[213.626884, "o", "#include \"phases.h\"\r\n#include \"../include/flow_record.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\r\n    CellGrid coarse = st->grid;\r\n    CellGrid leaves;\r\n    leaves.n = 0;\r\n    st->n_coarse = spec->n_coarse;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = spec->leaf_count[c];\r\n        if (k < 1) k = 1;\r\n        int sumw = 0;\r\n        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\r\n        if (sumw <= 0) sumw = 1;\r\n        st->coarse_start[c] = leaves.n;\r\n        st->coarse_len[c] = k;\r\n        double vj[MAX_LEAVES];\r\n        double vtot = 0.0;\r\n"]
[213.626914, "o", "        double jw = 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\r\n            vtot += vj[j];\r\n            jw += vj[j] * (double)j;\r\n        }\r\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            int gi = leaves.n++;\r\n            leaves.cells[gi].idx = gi;\r\n            leaves.cells[gi].vol = vj[j];\r\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\r\n            }\r\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\r\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\r\n        }\r\n    }\r\n    st->grid = leaves;\r\n\r\n    int changed[MAX_CELLS];\r\n    int nch = 0;\r\n    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\r\n    step_n(&st->grid, changed, nch, &st->topo);\r\n\r\n    st->bank.n_pending = 0;\r\n    if (!spec->do_flux) return;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = st->coarse_len[c];\r\n        if (k < 2) continue;\r\n        int start = st->coarse_start[c];\r\n        double vsum = 0.0;\r\n        double wq[NVAR] = {0.0, 0.0, 0.0};\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n"]
[213.626932, "o", "            vsum += cell->vol;\r\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\r\n        }\r\n        double qbar[NVAR];\r\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\r\n        EdgePulse ep;\r\n        ep.base_idx = start;\r\n        ep.subfaces = k;\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            for (int v = 0; v < NVAR; v++) {\r\n                ep.flux_vals[j * NVAR + v] =\r\n"]
[213.626956, "o", "                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\r\n            }\r\n        }\r\n        op_m(&ep, &st->bank);\r\n    }\r\n}\r\n"]
[213.627264, "o", "\u001b[?2004hroot@64b3f3bf7e4a:/app# "]
[213.748647, "i", "cat /app/scripts/run-matrix.sh\n"]
