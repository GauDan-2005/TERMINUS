[174.497093, "o", "> \r\n"]
[174.497253, "o", "\u001b[?2004l\r\u001b[?2004h> void fold_q(const CellPatch *a, int b, CellPatch *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     if (!a || !c) return;\r\n\u001b[?2004l\r\u001b[?2004h>     int n = (a->n < b) ? a->n : b;\r\n\u001b[?2004l\r\u001b[?2004h>     if (n <= 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         c->n = 0;\r\n\u001b[?2004l\r\u001b[?2004h>         return;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     double sum_vol = 0.0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[174.499312, "o", ">     double sum_q[NVAR] = {0.0, 0.0, 0.0};\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < n; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         sum_vol += a->vol[i];\r\n\u001b[?2004l\r\u001b[?2004h>         for (int v = 0; v < NVAR; v++) {\r\n\u001b[?2004l\r\u001b[?2004h>             sum_q[v] += a->vol[i] * a->q[i * NVAR + v];\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     c->n = 1;\r\n\u001b[?2004l\r\u001b[?2004h>     c->vol[0] = sum_vol;\r\n\u001b[?2004l\r\u001b[?2004h>     for (int v = 0; v < NVAR; v++) {\r\n\u001b[?2004l\r\u001b[?2004h>         c->q[v] = (sum_vol > 0.0) ? sum_q[v] / sum_vol : 0.0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
