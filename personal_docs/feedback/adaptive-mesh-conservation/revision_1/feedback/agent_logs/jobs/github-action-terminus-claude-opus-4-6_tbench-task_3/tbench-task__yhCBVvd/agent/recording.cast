[174.843365, "o", "> "]
[174.844934, "o", "#include <string.h>\r\n\u001b[?2004l\r"]
[174.845064, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> int load_k(const char *a, SimState *b, VaultAudit *c) {\r\n\u001b[?2004l\r\u001b[?2004h>     if (!a || !b || !c) return -1;\r\n\u001b[?2004l\r\u001b[?2004h>     memset(c, 0, sizeof(*c));\r\n\u001b[?2004l\r\u001b[?2004h>     FILE *in = fopen(a, \"rb\");\r\n\u001b[?2004l\r\u001b[?2004h>     if (!in) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.845154, "o", "        c->reason = REASON_MISSING;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.845396, "o", "        snprintf(c->msg, sizeof(c->msg), \"open failed\");\r\n\u001b[?2004l\r"]
[174.845528, "o", "\u001b[?2004h> "]
[174.845644, "o", "        return -2;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.845672, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.845894, "o", "    VaultHeader hdr;"]
[174.845971, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.846103, "o", "    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {"]
[174.846235, "o", "\r\n\u001b[?2004l\r"]
[174.846521, "o", "\u001b[?2004h"]
[174.846617, "o", "> "]
[174.846684, "o", "        fclose(in);\r\n\u001b[?2004l\r\u001b[?2004h"]
[174.846711, "o", "> "]
[174.846827, "o", "        c->reason = REASON_SHORT;\r\n\u001b[?2004l\r"]
[174.846901, "o", "\u001b[?2004h> "]
[174.847085, "o", "        snprintf(c->msg, sizeof(c->msg), \"header short\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[174.84719, "o", ">         return -3;\r\n"]
[174.847226, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[174.847246, "o", "    }\r\n\u001b[?2004l\r"]
[174.847376, "o", "\u001b[?2004h> "]
[174.847452, "o", "    if (hdr.magic != VAULT_MAGIC) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.847547, "o", "        fclose(in);\r\n\u001b[?2004l\r"]
[174.847661, "o", "\u001b[?2004h> "]
[174.847724, "o", "        c->reason = REASON_MAGIC;\r\n\u001b[?2004l\r"]
[174.847809, "o", "\u001b[?2004h> "]
[174.847989, "o", "        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\r\n\u001b[?2004l\r"]
[174.848019, "o", "\u001b[?2004h> "]
[174.84811, "o", "        return -4;\r\n\u001b[?2004l\r"]
[174.848204, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.848365, "o", "    if (hdr.fingerprint != b->fingerprint_payload) {\r\n\u001b[?2004l\r"]
[174.848397, "o", "\u001b[?2004h> "]
[174.84848, "o", "        fclose(in);\r\n\u001b[?2004l\r"]
[174.848545, "o", "\u001b[?2004h> "]
[174.848657, "o", "        c->reason = REASON_FINGERPRINT;\r\n\u001b[?2004l\r"]
[174.84876, "o", "\u001b[?2004h> "]
[174.848929, "o", "        snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\r\n\u001b[?2004l\r"]
[174.849076, "o", "\u001b[?2004h> "]
[174.849174, "o", "        return -5;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.849212, "o", "    int n_cells = 0;\r\n\u001b[?2004l\r"]
[174.849369, "o", "\u001b[?2004h> "]
[174.849512, "o", "    fread(&n_cells, sizeof(int), 1, in);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.849629, "o", "    b->grid.n = n_cells;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.849743, "o", "    fread(b->grid.cells, sizeof(CellView), n_cells, in);\r\n\u001b[?2004l\r"]
[174.849848, "o", "\u001b[?2004h> "]
[174.849941, "o", "    /* Restore coarse structure */\r\n\u001b[?2004l\r\u001b[?2004h"]
[174.850024, "o", "> "]
[174.850111, "o", "    fread(&b->n_coarse, sizeof(int), 1, in);\r\n\u001b[?2004l\r"]
[174.850141, "o", "\u001b[?2004h> "]
[174.850322, "o", "    fread(b->coarse_start, sizeof(int), b->n_coarse, in);\r\n\u001b[?2004l\r"]
[174.850352, "o", "\u001b[?2004h> "]
[174.850523, "o", "    fread(b->coarse_len, sizeof(int), b->n_coarse, in);\r\n\u001b[?2004l\r"]
[174.850553, "o", "\u001b[?2004h> "]
[174.850661, "o", "    /* Restore flux bank */\r\n\u001b[?2004l\r"]
[174.850754, "o", "\u001b[?2004h> "]
[174.850865, "o", "    fread(&b->bank.n_pending, sizeof(int), 1, in);\r\n\u001b[?2004l\r"]
[174.850898, "o", "\u001b[?2004h> "]
[174.851017, "o", "    if (b->bank.n_pending > 0) {\r\n\u001b[?2004l\r"]
[174.851049, "o", "\u001b[?2004h> "]
[174.851233, "o", "        fread(b->bank.leaf, sizeof(int), b->bank.n_pending, in);\r\n\u001b[?2004l\r"]
[174.851257, "o", "\u001b[?2004h> "]
[174.851485, "o", "        fread(b->bank.flux, sizeof(double), b->bank.n_pending * NVAR, in);\r\n\u001b[?2004l\r"]
[174.851527, "o", "\u001b[?2004h> "]
[174.851551, "o", "    }\r\n\u001b[?2004l\r"]
[174.851694, "o", "\u001b[?2004h> "]
[174.851823, "o", "    /* Restore fingerprint */\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.85187, "o", "    uint64_t fp;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.851997, "o", "    fread(&fp, sizeof(uint64_t), 1, in);\r\n\u001b[?2004l\r"]
[174.852099, "o", "\u001b[?2004h> "]
[174.852136, "o", "    b->fingerprint_payload = fp;\r\n\u001b[?2004l\r"]
[174.852244, "o", "\u001b[?2004h> "]
[174.852352, "o", "    /* Rebuild topo from cell data */\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.852473, "o", "    memset(&b->topo, 0, sizeof(b->topo));\r\n\u001b[?2004l\r"]
[174.852575, "o", "\u001b[?2004h> "]
[174.852664, "o", "    for (int i = 0; i < n_cells; i++) {\r\n\u001b[?2004l\r"]
[174.852761, "o", "\u001b[?2004h> "]
[174.852863, "o", "        b->topo.parent[i] = b->grid.cells[i].parent;\r\n\u001b[?2004l\r"]
[174.852951, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[174.853072, "o", "\u001b[?2004h>     fclose(in);\r\n"]
[174.853108, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[174.853203, "o", "    c->reason = REASON_OK;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.853365, "o", "    snprintf(c->msg, sizeof(c->msg), \"ok\");\r\n\u001b[?2004l\r"]
[174.853489, "o", "\u001b[?2004h>     return 0;\r\n"]
[174.853581, "o", "\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[174.853667, "o", "EOF\r\n\u001b[?2004l\r"]
[174.854505, "o", "\u001b[?2004hroot@023236bee917:/app# "]
[209.04622, "i", "cat /app/CMakeLists.txt\n"]
[209.04652, "o", "cat /app/CMakeLists.txt\r\n\u001b[?2004l\r"]
[209.047442, "o", "cmake_minimum_required(VERSION 3.16)\r\nproject(sim_run LANGUAGES CXX)\r\n\r\nset(CMAKE_CXX_STANDARD 17)\r\nset(CMAKE_CXX_STANDARD_REQUIRED ON)\r\n\r\nif(NOT DEFINED BUILD_STAMP)\r\n    if(DEFINED ENV{SOURCE_DATE_EPOCH})\r\n        set(BUILD_STAMP $ENV{SOURCE_DATE_EPOCH})\r\n    else()\r\n        set(BUILD_STAMP \"0\")\r\n    endif()\r\nendif()\r\nadd_compile_definitions(BUILD_STAMP=${BUILD_STAMP})\r\n\r\nadd_executable(sim_run\r\n    src/main.cpp\r\n    src/case_io.cpp\r\n    src/vault_io.cpp\r\n    src/audit_emit.cpp\r\n    acc_m/edge_corr.cpp\r\n    lnk_n/relate.cpp\r\n    agg_q/blend.cpp\r\n    srl_p/serial.cpp\r\n    rsm_k/resume.cpp\r\n    sync_b/halo.cpp\r\n    drv_u/run.cpp\r\n    drv_u/run_refine.cpp\r\n    drv_u/run_blend.cpp\r\n    drv_u/run_sync.cpp\r\n    swp_t/sweep.cpp\r\n    emt_e/report.cpp\r\n    prb_v/hist.cpp\r\n    tap_w/trace.cpp\r\n    cch_z/ring.cpp\r\n)\r\n\r\ntarget_include_directories(sim_run PRIVATE include)\r\n\r\nset_target_properties(sim_run PROPERTIES\r\n    RUNTIME_OUTPUT_DIRECTORY \"${CMAKE_BINARY_DIR}/bin\"\r\n)\r\n"]
[209.047628, "o", "\u001b[?2004h"]
