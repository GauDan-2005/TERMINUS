[111.170278, "o", "cat /app/include/ic_loader.h\r\n\u001b[?2004l\r"]
[111.171434, "o", "#ifndef IC_LOADER_H\r\n#define IC_LOADER_H\r\n\r\n#include \"cell_view.h\"\r\n\r\nint load_init(int profile_id, int n_coarse, CellGrid *out);\r\n\r\n#endif\r\n"]
[111.171724, "o", "\u001b[?2004h"]
