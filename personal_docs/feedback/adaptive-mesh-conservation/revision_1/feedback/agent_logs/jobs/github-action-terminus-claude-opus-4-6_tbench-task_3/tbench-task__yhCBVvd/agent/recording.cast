[174.842421, "i", "cat > /app/rsm_k/resume.cpp << 'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n#include <string.h>\n\nint load_k(const char *a, SimState *b, VaultAudit *c) {\n    if (!a || !b || !c) return -1;\n    memset(c, 0, sizeof(*c));\n    FILE *in = fopen(a, \"rb\");\n    if (!in) {\n        c->reason = REASON_MISSING;\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\n        return -2;\n    }\n    VaultHeader hdr;\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\n        return -3;\n    }\n    if (hdr.magic != VAULT_MAGIC) {\n        fclose(in);\n        c->reason = REASON_MAGIC;\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\n        return -4;\n    }\n    if (hdr.fingerprint != b->fingerprint_payload) {\n        fclose(in);\n        c->reason = REASON_FINGERPRINT;\n        snprintf(c->msg, sizeof(c->msg), \"fingerprint mismatch\");\n        return -5;\n    }\n    int n_cells = 0;\n    fread(&n_cells, sizeof(int), 1, in);\n    b->grid.n = n_cells;\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\n    /* Restore coarse structure */\n    fread(&b->n_coarse, sizeof(int), 1, in);\n    fread(b->coarse_start, sizeof(int), b->n_coarse, in);\n    fread(b->coarse_len, sizeof(int), b->n_coarse, in);\n    /* Restore flux bank */\n    fread(&b->bank.n_pending, sizeof(int), 1, in);\n    if (b->bank.n_pending > 0) {\n        fread(b->bank.leaf, sizeof(int), b->bank.n_pending, in);\n        fread(b->bank.flux, sizeof(double), b->bank.n_pending * NVAR, in);\n    }\n    /* Restore fingerprint */\n    uint64_t fp;\n    fread(&fp, sizeof(uint64_t), 1, in);\n    b->fingerprint_payload = fp;\n    /* Rebuild topo from cell data */\n    memset(&b->topo, 0, sizeof(b->topo));\n    for (int i = 0; i < n_cells; i++) {\n        b->topo.parent[i] = b->grid.cells[i].parent;\n    }\n    fclose(in);\n    c->reason = REASON_OK;\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\n    return 0;\n}\nEOF\n"]
[174.842875, "o", "cat > /app/rsm_k/resume.cpp << 'EOF'\r\n\u001b[?2004l\r"]
