[20.663913, "i", "cat /app/drv_u/phases.h\n"]
[20.66441, "o", "cat /app/drv_u/phases.h\r\n\u001b[?2004l\r"]
[20.665413, "o", "#ifndef PHASES_H\r\n#define PHASES_H\r\n\r\n#include \"../include/case_spec.h\"\r\n#include \"../include/vault_layout.h\"\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec);\r\nvoid phase_fold(SimState *st, const ScenarioSpec *spec);\r\nint phase_persist(SimState *st, const char *vault_path, const char *tamper_path,\r\n                  const char *log_path, VaultAudit *resume_aud);\r\n\r\n#endif\r\n"]
[20.665856, "o", "\u001b[?2004h"]
[20.666396, "o", "root@3854d6db4558:/app# "]
[20.77991, "i", "cat /app/drv_u/run_refine.cpp\n"]
[20.780534, "o", "cat /app/drv_u/run_refine.cpp"]
[20.780661, "o", "\r\n\u001b[?2004l\r"]
[20.78361, "o", "#include \"phases.h\"\r\n#include \"../include/flow_record.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_grow(SimState *st, const ScenarioSpec *spec) {\r\n    CellGrid coarse = st->grid;\r\n    CellGrid leaves;\r\n    leaves.n = 0;\r\n    st->n_coarse = spec->n_coarse;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = spec->leaf_count[c];\r\n        if (k < 1) k = 1;\r\n        int sumw = 0;\r\n        for (int j = 0; j < k; j++) sumw += spec->leaf_weight[c][j];\r\n        if (sumw <= 0) sumw = 1;\r\n        st->coarse_start[c] = leaves.n;\r\n        st->coarse_len[c] = k;\r\n        double vj[MAX_LEAVES];\r\n        double vtot = 0.0;\r\n        double jw = 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            vj[j] = coarse.cells[c].vol * (double)spec->leaf_weight[c][j] / (double)sumw;\r\n            vtot += vj[j];\r\n            jw += vj[j] * (double)j;\r\n        }\r\n        double jbar = (vtot > 0.0) ? jw / vtot : 0.0;\r\n        for (int j = 0; j < k; j++) {\r\n            int gi = leaves.n++;\r\n            leaves.cells[gi].idx = gi;\r\n            leaves.cells[gi].vol = vj[j];\r\n            double f = (k > 1) ? (1.0 + LEAF_SPREAD * ((double)j - jbar)) : 1.0;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                leaves.cells[gi].q[v] = coarse.cells[c].q[v] * f;\r\n            }\r\n            leaves.cells[gi].tier = (k > 1) ? 1 : 0;\r\n            leaves.cells[gi].parent = (k > 1) ? c : -1;\r\n        }\r\n    }\r\n    st->grid = leaves;\r\n\r\n    int changed[MAX_CELLS];\r\n    int nch = 0;\r\n    for (int i = 0; i < leaves.n; i++) changed[nch++] = i;\r\n    step_n(&st->grid, changed, nch, &st->topo);\r\n\r\n    st->bank.n_pending = 0;\r\n    if (!spec->do_flux) return;\r\n    for (int c = 0; c < spec->n_coarse; c++) {\r\n        int k = st->coarse_len[c];\r\n        if (k < 2) continue;\r\n        int start = st->coarse_start[c];\r\n        double vsum = 0.0;\r\n        double wq[NVAR] = {0.0, 0.0, 0.0};\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            vsum += cell->vol;\r\n            for (int v = 0; v < NVAR; v++) wq[v] += cell->vol * cell->q[v];\r\n        }\r\n        double qbar[NVAR];\r\n        for (int v = 0; v < NVAR; v++) qbar[v] = (vsum > 0.0) ? wq[v] / vsum : 0.0;\r\n        EdgePulse ep;\r\n        ep.base_idx = start;\r\n        ep.subfaces = k;\r\n        for (int j = 0; j < k; j++) {\r\n            const CellView *cell = &st->grid.cells[start + j];\r\n            for (int v = 0; v < NVAR; v++) {\r\n                ep.flux_vals[j * NVAR + v] =\r\n                    REFLUX_RATE * cell->vol * (qbar[v] - cell->q[v]);\r\n            }\r\n        }\r\n        op_m(&ep, &st->bank);\r\n    }\r\n}\r\n"]
[20.783903, "o", "\u001b[?2004hroot@3854d6db4558:/app# "]
[20.904198, "i", "cat /app/drv_u/run_blend.cpp\n"]
[20.904547, "o", "cat /app/drv_u/run_blend.cpp"]
[20.904865, "o", "\r\n\u001b[?2004l\r"]
[20.905701, "o", "#include \"phases.h\"\r\n#include \"../include/topo_link.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid phase_fold(SimState *st, const ScenarioSpec *spec) {\r\n    for (int v = 0; v < NVAR; v++) st->halo_q[v] = 0.0;\r\n\r\n    int seam = -1;\r\n    for (int c = 0; c < st->n_coarse; c++) {\r\n        if (st->coarse_len[c] > 1) { seam = c; break; }\r\n    }\r\n    if (seam >= 0) {\r\n        int start = st->coarse_start[seam];\r\n        int k = st->coarse_len[seam];\r\n        CellPatch src;\r\n        src.n = k;\r\n        for (int j = 0; j < k && j < MAX_LEAVES; j++) {\r\n            src.vol[j] = st->grid.cells[start + j].vol;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                src.q[j * NVAR + v] = st->grid.cells[start + j].q[v];\r\n            }\r\n        }\r\n        CellPatch ghost;\r\n        memset(&ghost, 0, sizeof(ghost));\r\n        op_b(&ghost, &src, k, 1);\r\n        for (int v = 0; v < NVAR; v++) st->halo_q[v] = ghost.q[v];\r\n    }\r\n\r\n    if (!spec->do_collapse) return;\r\n\r\n    CellGrid folded;\r\n    folded.n = 0;\r\n    for (int c = 0; c < st->n_coarse; c++) {\r\n        int start = st->coarse_start[c];\r\n        int k = st->coarse_len[c];\r\n        int gi = folded.n++;\r\n        if (k < 2) {\r\n            folded.cells[gi] = st->grid.cells[start];\r\n            folded.cells[gi].idx = gi;\r\n            folded.cells[gi].tier = 0;\r\n            folded.cells[gi].parent = -1;\r\n            continue;\r\n        }\r\n        CellPatch children;\r\n        children.n = k;\r\n        for (int j = 0; j < k && j < MAX_LEAVES; j++) {\r\n"]
[20.905742, "o", "            children.vol[j] = st->grid.cells[start + j].vol;\r\n            for (int v = 0; v < NVAR; v++) {\r\n                children.q[j * NVAR + v] = st->grid.cells[start + j].q[v];\r\n            }\r\n        }\r\n        CellPatch parent;\r\n        memset(&parent, 0, sizeof(parent));\r\n        fold_q(&children, k, &parent);\r\n        folded.cells[gi].idx = gi;\r\n        folded.cells[gi].tier = 0;\r\n        folded.cells[gi].parent = -1;\r\n        folded.cells[gi].vol = parent.vol[0];\r\n        for (int v = 0; v < NVAR; v++) folded.cells[gi].q[v] = parent.q[v];\r\n    }\r\n    for (int c = 0; c < st->n_coarse; c++) {\r\n        st->coarse_start[c] = c;\r\n        st->coarse_len[c] = 1;\r\n    }\r\n    st->grid = folded;\r\n}\r\n"]
[20.906025, "o", "\u001b[?2004hroot@3854d6db4558:/app# "]
[31.449515, "i", "cat /app/include/cell_view.h\n"]
[31.449896, "o", "cat /app/include/cell_view.h\r\n\u001b[?2004l\r"]
[31.450806, "o", "#ifndef CELL_VIEW_H\r\n#define CELL_VIEW_H\r\n\r\n#include <stdint.h>\r\n\r\n#define NVAR 3\r\n#define MAX_CELLS 384\r\n#define MAX_FACES 768\r\n#define MAX_LEAVES 8\r\n#define REFLUX_RATE 0.25\r\n#define LEAF_SPREAD 0.1\r\n\r\nstruct CellView {\r\n    int idx;\r\n    int tier;\r\n    int parent;\r\n    double vol;\r\n    double q[NVAR];\r\n};\r\n\r\nstruct CellGrid {\r\n    CellView cells[MAX_CELLS];\r\n    int n;\r\n};\r\n\r\n"]
[31.451023, "o", "struct CellPatch {\r\n    int n;\r\n    double vol[MAX_LEAVES];\r\n    double q[MAX_LEAVES * NVAR];\r\n};\r\n\r\nvoid fold_q(const CellPatch *a, int b, CellPatch *c);\r\n\r\n#endif\r\n\u001b[?2004hroot@3854d6db4558:/app# "]
[31.571908, "i", "cat /app/agg_q/blend.cpp\n"]
[31.572422, "o", "cat /app/agg_q/blend.cpp\r\n"]
[31.572831, "o", "\u001b[?2004l\r"]
[31.574174, "o", "#include \"../include/cell_view.h\"\r\n\r\nvoid fold_q(const CellPatch *a, int b, CellPatch *c) {\r\n    if (!a || !c) return;\r\n    int n = (a->n < b) ? a->n : b;\r\n    if (n <= 0) {\r\n        c->n = 0;\r\n        return;\r\n    }\r\n    double sum_vol = 0.0;\r\n    double sum_q[NVAR] = {0.0, 0.0, 0.0};\r\n    for (int i = 0; i < n; i++) {\r\n        sum_vol += a->vol[i];\r\n        for (int v = 0; v < NVAR; v++) {\r\n            sum_q[v] += a->q[i * NVAR + v];\r\n        }\r\n    }\r\n    c->n = 1;\r\n    c->vol[0] = sum_vol;\r\n    double inv_n = 1.0 / (double)n;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        c->q[v] = sum_q[v] * inv_n;\r\n    }\r\n}\r\n\u001b[?2004hroot@3854d6db4558:/app# "]
[31.6885, "i", "cat /app/acc_m/edge_corr.cpp\n"]
[31.688859, "o", "cat /app/acc_m/edge_corr.cpp\r\n\u001b[?2004l\r"]
[31.69244, "o", "#include \"../include/flow_record.h\"\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b) {\r\n    if (!a || !b) return;\r\n    if (b->n_pending >= MAX_FACES) return;\r\n    int slot = b->n_pending++;\r\n    b->leaf[slot] = a->base_idx;\r\n    for (int v = 0; v < NVAR; v++) {\r\n        b->flux[slot * NVAR + v] = a->flux_vals[v];\r\n    }\r\n}\r\n\u001b[?2004hroot@3854d6db4558:/app# "]
[50.403762, "i", "cat /app/include/flow_record.h\n"]
[50.404092, "o", "cat /app/include/flow_record.h\r\n\u001b[?2004l\r"]
[50.405915, "o", "#ifndef FLOW_RECORD_H\r\n#define FLOW_RECORD_H\r\n\r\n#include \"cell_view.h\"\r\n\r\nstruct EdgePulse {\r\n    int base_idx;\r\n    int subfaces;\r\n    double flux_vals[MAX_LEAVES * NVAR];\r\n};\r\n\r\nstruct FluxBank {\r\n    int n_pending;\r\n    int leaf[MAX_FACES];\r\n    double flux[MAX_FACES * NVAR];\r\n};\r\n\r\nvoid op_m(const EdgePulse *a, FluxBank *b);\r\n\r\n#endif\r\n\u001b[?2004hroot@3854d6db4558:/app# "]
[50.519603, "i", "cat /app/include/vault_layout.h\n"]
[50.5202, "o", "cat /app/include/vault_layout.h\r\n\u001b[?2004l\r"]
[50.521767, "o", "#ifndef VAULT_LAYOUT_H\r\n#define VAULT_LAYOUT_H\r\n\r\n/* reserved diagnostic marker: tb_amr_noembed_8d7a4c2f */\r\n\r\n#include \"cell_view.h\"\r\n#include \"flow_record.h\"\r\n#include \"topo_link.h\"\r\n\r\n#include <stdint.h>\r\n\r\n#define VAULT_MAGIC 0xAD7C2F00u\r\n#define VAULT_VERSION 1u\r\n\r\n#define REASON_OK 0\r\n#define REASON_MISSING 1\r\n#define REASON_MAGIC 2\r\n#define REASON_VERSION 3\r\n#define REASON_FINGERPRINT 4\r\n#define REASON_SHORT 5\r\n\r\nstruct VaultHeader {\r\n    uint32_t magic;\r\n    uint32_t version;\r\n    uint64_t fingerprint;\r\n    uint64_t build_stamp;\r\n};\r\n\r\nstruct VaultAudit {\r\n    int reason;\r\n    char msg[128];\r\n};\r\n\r\nstruct SimState {\r\n    CellGrid grid;\r\n    TopoLink topo;\r\n    FluxBank bank;\r\n    int n_coarse;\r\n    int coarse_start[MAX_CELLS];\r\n    int coarse_len[MAX_CELLS];\r\n    int step_idx;\r\n    double dt_carry;\r\n    uint64_t fingerprint_payload;\r\n    int adjacency;\r\n    double halo_q[NVAR];\r\n};\r\n\r\nuint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed);\r\n\r\nint emit_p(const SimState *a, const char *b);\r\nint load_k(const char *a, SimState *b, VaultAudit *c);\r\n\r\n#endif\r\n"]
[50.522294, "o", "\u001b[?2004hroot@3854d6db4558:/app# "]
[50.647923, "i", "cat /app/src/vault_io.cpp\n"]
[50.648232, "o", "cat /app/src/vault_io.cpp\r\n\u001b[?2004l\r"]
[50.649448, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdint.h>\r\n\r\nuint64_t vault_fnv1a(const void *data, int n_bytes, uint64_t seed) {\r\n    const uint8_t *p = (const uint8_t *)data;\r\n    uint64_t h = 0xcbf29ce484222325ull ^ seed;\r\n    for (int i = 0; i < n_bytes; i++) {\r\n        h ^= (uint64_t)p[i];\r\n        h *= 0x100000001b3ull;\r\n    }\r\n    return h;\r\n}\r\n"]
[50.649655, "o", "\u001b[?2004hroot@3854d6db4558:/app# "]
[55.796349, "i", "cat /app/srl_p/serial.cpp\n"]
[55.796924, "o", "cat /app/srl_p/serial.cpp\r\n\u001b[?2004l\r"]
[55.798254, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdio.h>\r\n\r\nint emit_p(const SimState *a, const char *b) {\r\n    if (!a || !b) return -1;\r\n    FILE *fp = fopen(b, \"wb\");\r\n    if (!fp) return -2;\r\n    VaultHeader hdr;\r\n    hdr.magic = VAULT_MAGIC;\r\n    hdr.version = VAULT_VERSION;\r\n    hdr.fingerprint = a->fingerprint_payload;\r\n    hdr.build_stamp = (uint64_t)BUILD_STAMP;\r\n    fwrite(&hdr, sizeof(hdr), 1, fp);\r\n    int n_cells = a->grid.n;\r\n    fwrite(&n_cells, sizeof(int), 1, fp);\r\n    fwrite(a->grid.cells, sizeof(CellView), n_cells, fp);\r\n    fclose(fp);\r\n    return 0;\r\n}\r\n"]
[55.798424, "o", "\u001b[?2004h"]
[55.798454, "o", "root@3854d6db4558:/app# "]
[55.915864, "i", "cat /app/rsm_k/resume.cpp\n"]
[55.91631, "o", "cat /app/rsm_k/resume.cpp\r\n\u001b[?2004l\r"]
[55.917485, "o", "#include \"../include/vault_layout.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\nint load_k(const char *a, SimState *b, VaultAudit *c) {\r\n    if (!a || !b || !c) return -1;\r\n    memset(c, 0, sizeof(*c));\r\n    FILE *in = fopen(a, \"rb\");\r\n    if (!in) {\r\n        c->reason = REASON_MISSING;\r\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\r\n        return -2;\r\n    }\r\n    VaultHeader hdr;\r\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\r\n        fclose(in);\r\n        c->reason = REASON_SHORT;\r\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\r\n        return -3;\r\n    }\r\n    if (hdr.magic != VAULT_MAGIC) {\r\n        fclose(in);\r\n        c->reason = REASON_MAGIC;\r\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\r\n        return -4;\r\n    }\r\n    int n_cells = 0;\r\n    fread(&n_cells, sizeof(int), 1, in);\r\n    b->grid.n = n_cells;\r\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\r\n    memset(&b->topo, 0, sizeof(b->topo));\r\n    b->bank.n_pending = 0;\r\n    fclose(in);\r\n    c->reason = REASON_OK;\r\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\r\n    return 0;\r\n}\r\n"]
