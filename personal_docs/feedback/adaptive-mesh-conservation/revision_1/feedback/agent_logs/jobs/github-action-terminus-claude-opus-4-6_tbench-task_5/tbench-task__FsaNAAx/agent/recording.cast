[230.0926, "i", "cat > /app/rsm_k/resume.cpp << 'EOF'\n#include \"../include/vault_layout.h\"\n\n#include <stdio.h>\n#include <string.h>\n\nint load_k(const char *a, SimState *b, VaultAudit *c) {\n    if (!a || !b || !c) return -1;\n    memset(c, 0, sizeof(*c));\n    FILE *in = fopen(a, \"rb\");\n    if (!in) {\n        c->reason = REASON_MISSING;\n        snprintf(c->msg, sizeof(c->msg), \"open failed\");\n        return -2;\n    }\n    VaultHeader hdr;\n    if (fread(&hdr, sizeof(hdr), 1, in) != 1) {\n        fclose(in);\n        c->reason = REASON_SHORT;\n        snprintf(c->msg, sizeof(c->msg), \"header short\");\n        return -3;\n    }\n    if (hdr.magic != VAULT_MAGIC) {\n        fclose(in);\n        c->reason = REASON_MAGIC;\n        snprintf(c->msg, sizeof(c->msg), \"bad magic 0x%x\", hdr.magic);\n        return -4;\n    }\n    int n_cells = 0;\n    fread(&n_cells, sizeof(int), 1, in);\n    b->grid.n = n_cells;\n    fread(b->grid.cells, sizeof(CellView), n_cells, in);\n    memset(&b->topo, 0, sizeof(b->topo));\n    /* Restore FluxBank if present */\n    int n_pending = 0;\n    if (fread(&n_pending, sizeof(int), 1, in) == 1 && n_pending > 0 && n_pending <= MAX_FACES) {\n        b->bank.n_pending = n_pending;\n        fread(b->bank.leaf, sizeof(int), n_pending, in);\n        fread(b->bank.flux, sizeof(double), n_pending * NVAR, in);\n    } else {\n        b->bank.n_pending = 0;\n    }\n    fclose(in);\n    c->reason = REASON_OK;\n    snprintf(c->msg, sizeof(c->msg), \"ok\");\n    return 0;\n}\nEOF\n"]
