[164.730865, "o", "sed -n '1,220p' /app/internal/d3/pair.go /app/internal/d3/map.go | grep -n \"KeyFor\\|Dev\\|Ino\\|Nlink\" || true\r\n\u001b[?2004l\r"]
[164.733985, "o", "29:func KeyFor(row f5.Row, profile f5.Profile) string {\r\n33:\tkey := tokenX(fmt.Sprintf(\"%d:%d\", row.Dev, row.Ino))\r\n"]
[164.734227, "o", "\u001b[?2004hroot@3b3cdaca49ea:/app# "]
[164.838481, "i", "sed -n '1,120p' /app/internal/b1/replay.go\n"]
[164.839069, "o", "sed -n '1,120p' /app/internal/b1/replay.go\r\n\u001b[?2004l\r"]
[164.840135, "o", "package b1\r\n\r\nimport (\r\n\t\"sort\"\r\n\r\n\t\"staged.local/snapshot/internal/f5\"\r\n)\r\n\r\ntype rowX = f5.Row\r\n\r\nfunc fold_b(a []rowX, b uint64) ([]rowX, error) {\r\n\tout := make([]rowX, len(a))\r\n\tcopy(out, a)\r\n\tsort.SliceStable(out, func(i, j int) bool {\r\n\t\treturn out[i].Seq < out[j].Seq\r\n\t})\r\n\tif b&1 == 1 {\r\n"]
[164.840245, "o", "\t\tfor left, right := 0, len(out)-1; left < right; left, right = left+1, right-1 {\r\n\t\t\tout[left], out[right] = out[right], out[left]\r\n\t\t}\r\n\t}\r\n"]
[164.840486, "o", "\treturn out, nil\r\n}\r\n\r\nfunc FoldRows(rows []f5.Row, profile f5.Profile) ([]f5.Row, error) {\r\n\tvar flags uint64\r\n\tif profile.Restart && profile.Ordered {\r\n\t\tflags |= 1\r\n\t}\r\n\treturn fold_b(rows, flags)\r\n}\r\n"]
[164.840741, "o", "\u001b[?2004hroot@3b3cdaca49ea:/app# "]
[164.962106, "i", "sed -n '1,220p' /app/internal/f5/types.go\n"]
[164.962823, "o", "sed -n '1,220p' /app/internal/f5/types.go\r\n\u001b[?2004l\r"]
[164.964027, "o", "package f5\r\n\r\ntype Profile struct {\r\n\tName    string\r\n"]
[164.964248, "o", "\tDense   bool\r\n\tRoll    bool\r\n\tOrdered bool\r\n\tRestart bool\r\n}\r\n\r\nfunc ProfileFor(name string) Profile {\r\n\treturn Profile{\r\n\t\tName:    name,\r\n\t\tDense:   name == \"beta\" || name == \"zeta\",\r\n\t\tRoll:    name == \"epsilon\" || name == \"zeta\",\r\n\t\tOrdered: name == \"gamma\" || name == \"zeta\",\r\n\t\tRestart: name == \"beta\" || name == \"gamma\" || name == \"epsilon\" || name == \"zeta\",\r\n\t}\r\n}\r\n\r\n"]
[164.964619, "o", "type Row struct {\r\n\tSeq   int\r\n\tOp    string\r\n\tPath  string\r\n\tData  string\r\n\tDev   uint64\r\n\tIno   uint64\r\n\tNlink uint64\r\n}\r\n\r\ntype Record struct {\r\n\tName string\r\n\tPath string\r\n\tOK   bool\r\n}\r\n\r\ntype AccountItem struct {\r\n\tPath   string `json:\"path\"`\r\n\tBytes  int    `json:\"bytes\"`\r\n\tPeriod string `json:\"period\"`\r\n}\r\n\r\ntype DigestPair struct {\r\n\tSource   string `json:\"source\"`\r\n\tRestored string `json:\"restored\"`\r\n}\r\n\r\ntype GroupPair struct {\r\n\tSource   [][]string `json:\"source\"`\r\n\tRestored [][]string `json:\"restored\"`\r\n}\r\n\r\ntype CaseResult struct {\r\n\tName       string        `json:\"name\"`\r\n\tSource     string        `json:\"source\"`\r\n\tRestored   string        `json:\"restored\"`\r\n\tOK         bool          `json:\"ok\"`\r\n\tDigest     DigestPair    `json:\"digest\"`\r\n\tGroups     GroupPair     `json:\"groups\"`\r\n\tAccounting []AccountItem `json:\"accounting\"`\r\n}\r\n\r\ntype Report struct {\r\n\tCases []CaseResult `json:\"cases\"`\r\n}\r\n\u001b[?2004hroot@3b3cdaca49ea:/app# "]
[176.202538, "i", "cat > /app/internal/d3/pair.go <<'EOF'\npackage d3\n\nimport (\n\t\"fmt\"\n\n\t\"staged.local/snapshot/internal/f5\"\n)\n\ntype tokenX string\n\ntype nodeX struct {\n\tSeen map[tokenX]bool\n}\n\nfunc bind_d(a *nodeX, b tokenX) bool {\n\tif a.Seen == nil {\n\t\ta.Seen = map[tokenX]bool{}\n\t}\n\tif b == \"\" {\n\t\treturn false\n\t}\n\tif a.Seen[b] {\n\t\treturn true\n\t}\n\ta.Seen[b] = true\n\treturn true\n}\n\n// KeyFor returns a grouping key used during restore materialization.\n//\n// Contract:\n//   - Hardlinked files (Nlink > 1 in the staged rows) must be recreated as\n//     hardlinks in the restored tree, so they must share a key.\n//   - Non-hardlinked files must never be grouped together, so they use their\n//     path as a unique key.\n//\n// Dev is intentionally ignored: restored trees may live on a different device.\nfunc KeyFor(row f5.Row, profile f5.Profile) string {\n\t_ = profile\n\tif row.Nlink > 1 {\n\t\tkey := tokenX(fmt.Sprintf(\"ino:%d\", row.Ino))\n\t\tstate := &nodeX{}\n\t\t_ = bind_d(state, key)\n\t\treturn string(key)\n\t}\n\treturn row.Path\n}\nEOF\n"]
