[248.648256, "o", "\t}\r\n\trows, err := a0.RowsFromTree(source, profile)\r\n\tif err != nil {\r\n\t\treturn f5.CaseResult{}, err\r\n\t}\r\n\tif err := a0.Materialize(rows, restored, profile); err != nil {\r\n\t\treturn f5.CaseResult{}, err\r\n\t}\r\n\tsourceDigest, err := e4.Digest(source)\r\n\tif err != nil {\r\n\t\t"]
