[176.206983, "o", "// KeyFor returns a grouping key used during restore materialization.\r\n\u001b[?2004l\r"]
[176.20706, "o", "\u001b[?2004h> //\r\n\u001b[?2004l\r"]
[176.207094, "o", "\u001b[?2004h> "]
[176.207187, "o", "// Contract:\r\n\u001b[?2004l\r"]
[176.207252, "o", "\u001b[?2004h> "]
[176.207483, "o", "//   - Hardlinked files (Nlink > 1 in the staged rows) must be recreated as\r\n\u001b[?2004l\r"]
[176.207532, "o", "\u001b[?2004h> "]
[176.207765, "o", "//     hardlinks in the restored tree, so they must share a key.\r\n\u001b[?2004l\r"]
[176.207799, "o", "\u001b[?2004h"]
[176.207821, "o", "> "]
[176.208152, "o", "//   - Non-hardlinked files must never be grouped together, so they use their"]
[176.210187, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> //     path as a unique key.\r\n\u001b[?2004l\r\u001b[?2004h> //\r\n\u001b[?2004l\r\u001b[?2004h> // Dev is intentionally ignored: restored trees may live on a different device.\r\n\u001b[?2004l\r\u001b[?2004h> func KeyFor(row f5.Row, profile f5.Profile) string {\r\n\u001b[?2004l\r\u001b[?2004h> \u0007_ = profile\r\n\u001b[?2004l\r\u001b[?2004h> \u0007if row.Nlink > 1 {\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nMakefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> key := tokenX(fmt.Sprintf(\"ino:%d\", row.Ino))\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nMakefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> state := &nodeX{}\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nMakefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> _ = bind_d(state, key)\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nMakefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> return string(key)\r\n\u001b[?2004l\r\u001b[?2004h> \u0007}\r\n\u001b[?2004l\r\u001b[?2004h> \u0007return row.Path\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
