[164.506367, "o", "\r\n\u001b[?2004l\r"]
[164.507546, "o", "package d3\r\n\r\nimport (\r\n\t\"fmt\"\r\n\r\n\t\"staged.local/snapshot/internal/f5\"\r\n)\r\n\r\ntype tokenX string\r\n\r\ntype nodeX struct {\r\n\tSeen map[tokenX]bool\r\n}\r\n\r\nfunc bind_d(a *nodeX, b tokenX) bool {\r\n\tif a.Seen == nil {\r\n\t\ta.Seen = map[tokenX]bool{}\r\n\t}\r\n\tif b == \"\" {\r\n\t\treturn false\r\n\t}\r\n\tif a.Seen[b] {\r\n\t\treturn true\r\n"]
[164.507588, "o", "\t}\r\n\ta.Seen[b] = true\r\n\treturn true\r\n}\r\n\r\nfunc KeyFor(row f5.Row, profile f5.Profile) string {\r\n\tif profile.Restart && profile.Dense {\r\n\t\treturn row.Path\r\n\t}\r\n\tkey := tokenX(fmt.Sprintf(\"%d:%d\", row.Dev, row.Ino))\r\n\tstate := &nodeX{}\r\n\t_ = bind_d(state, key)\r\n\treturn string(key)\r\n"]
[164.507611, "o", "}\r\n"]
[164.507857, "o", "\u001b[?2004hroot@3b3cdaca49ea:/app# "]
