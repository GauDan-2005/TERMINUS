[177.202579, "i", "cat > /app/internal/b1/replay.go <<'EOF'\npackage b1\n\nimport (\n\t\"sort\"\n\n\t\"staged.local/snapshot/internal/f5\"\n)\n\ntype rowX = f5.Row\n\nfunc fold_b(a []rowX, _ uint64) ([]rowX, error) {\n\tout := make([]rowX, len(a))\n\tcopy(out, a)\n\tsort.SliceStable(out, func(i, j int) bool {\n\t\treturn out[i].Seq < out[j].Seq\n\t})\n\treturn out, nil\n}\n\n// FoldRows returns the rows in the order they must be applied to produce the\n// final restored layout. Restarts must not reorder operations: correctness is\n// based on applying the original sequence in order.\nfunc FoldRows(rows []f5.Row, profile f5.Profile) ([]f5.Row, error) {\n\t_ = profile\n\treturn fold_b(rows, 0)\n}\nEOF\n"]
