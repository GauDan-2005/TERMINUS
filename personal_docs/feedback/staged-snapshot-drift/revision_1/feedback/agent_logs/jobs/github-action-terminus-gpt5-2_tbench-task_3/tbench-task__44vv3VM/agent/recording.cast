[298.046747, "i", "cat > /app/internal/c2/roll.go <<'EOF'\npackage c2\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\n\t\"staged.local/snapshot/internal/f5\"\n)\n\ntype entryX struct {\n\tPath   string\n\tBytes  int\n\tPeriod string\n}\n\ntype mapX struct {\n\tItems map[string]entryX\n}\n\n// ItemsC returns the accounting items for a tree.\n//\n// Requirements:\n//   - Bytes are per-path and must equal the on-disk file size for that path,\n//     including hardlink aliases (i.e., do not divide by link-count).\n//   - Period is \"p1\" only for generated files under d/ when the case has moved\n//     into the later quota period (in this matrix: Restart+Roll), otherwise \"p0\".\nfunc ItemsC(root string, profile f5.Profile) ([]f5.AccountItem, error) {\n\tentries := make([]entryX, 0, 32)\n\tif err := filepath.WalkDir(root, func(path string, d os.DirEntry, err error) error {\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !d.Type().IsRegular() {\n\t\t\treturn nil\n\t\t}\n\t\tinfo, err := os.Stat(path)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\trel, err := filepath.Rel(root, path)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\trel = filepath.ToSlash(rel)\n\t\tperiod := \"p0\"\n\t\tif profile.Roll && profile.Restart && strings.HasPrefix(rel, \"d/\") {\n\t\t\tperiod = \"p1\"\n\t\t}\n\t\tentries = append(entries, entryX{Path: rel, Bytes: int(info.Size()), Period: period})\n\t\treturn nil\n\t}); err != nil {\n\t\treturn nil, err\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool { return entries[i].Path < entries[j].Path })\n\n\titems := make([]f5.AccountItem, 0, len(entries))\n\tfor _, e := range entries {\n\t\titems = append(items, f5.AccountItem{Path: e.Path, Bytes: e.Bytes, Period: e.Period})\n\t}\n\treturn items, nil\n}\nEOF\n"]
