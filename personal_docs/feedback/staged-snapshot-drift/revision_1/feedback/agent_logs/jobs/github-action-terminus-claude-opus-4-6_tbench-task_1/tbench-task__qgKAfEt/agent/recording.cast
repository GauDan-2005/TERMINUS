[67.657292, "o", "#include \"fswalk.h\"\r\n\r\n#include <stdio.h>\r\n\r\nint main(int argc, char **argv) {\r\n    struct qx q = {0UL};\r\n    if (argc != 2) {\r\n        fprintf(stderr, \"usage: fsmeasure ROOT\\n\");\r\n        return 64;\r\n    }\r\n    return walk_e(&q, argv[1], 1UL);\r\n}\r\n"]
