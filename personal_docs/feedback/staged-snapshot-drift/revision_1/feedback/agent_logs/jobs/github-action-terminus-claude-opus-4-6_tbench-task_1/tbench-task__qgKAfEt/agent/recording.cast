[17.112316, "o", "package a0\r\n\r\nfunc scanA(paths []string) []itemY {\r\n\tout := make([]itemY, 0, len(paths))\r\n\tfor i, p := range paths {\r\n\t\tout = append(out, itemY{Seq: i, Op: \"write\", Path: p})\r\n\t}\r\n\treturn out\r\n}\r\n"]
