[52.137365, "o", "#ifndef FSWALK_H\r\n#define FSWALK_H\r\n\r\n#include <stddef.h>\r\n\r\nstruct qx {\r\n    unsigned long seen;\r\n};\r\n\r\nint walk_e(struct qx *a, const char *root, unsigned long c);\r\nint list_q(struct qx *a, const char *b);\r\n\r\n#endif\r\n"]
