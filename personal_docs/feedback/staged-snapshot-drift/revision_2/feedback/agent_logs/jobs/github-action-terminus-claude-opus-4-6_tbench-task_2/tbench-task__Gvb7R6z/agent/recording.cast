[20.122917, "o", "package f5\r\n\r\ntype Profile struct {\r\n\tName    string\r\n\tDense   bool\r\n\tRoll    bool\r\n\tOrdered bool\r\n\tRestart bool\r\n}\r\n\r\nfunc ProfileFor(name string) Profile {\r\n\treturn Profile{\r\n\t\tName:    name,\r\n\t\tDense:   name == \"beta\" || name == \"zeta\",\r\n\t\tRoll:    name == \"epsilon\" || name == \"zeta\",\r\n\t\tOrdered: name == \"gamma\" || name == \"zeta\",\r\n\t\tRestart: name == \"beta\" || name == \"gamma\" || name == \"epsilon\" || name == \"zeta\",\r\n\t}\r\n}\r\n\r\ntype Row struct {\r\n\tSeq   int\r\n\tOp    string\r\n\tPath  string\r\n\tData  string\r\n\tDev   uint64\r\n\tIno   uint64\r\n\tNlink uint64\r\n}\r\n\r\ntype Record struct {\r\n\tName string\r\n\tPath string\r\n\tOK   bool\r\n}\r\n\r\ntype AccountItem struct {\r\n\tPath   string `json:\"path\"`\r\n\tBytes  int    `json:\"bytes\"`\r\n\tPeriod string `json:\"period\"`\r\n}\r\n\r\ntype DigestPair struct {\r\n\tSource   string `json:\"source\"`\r\n\tRestored string `json:\"restored\"`\r\n}\r\n\r\ntype GroupPair struct {\r\n\tSource   [][]string `json:\"source\"`\r\n\tRestored [][]string `json:\"restored\"`\r\n}\r\n\r\ntype CaseResult struct {\r\n\tName       string        `json:\"name\"`\r\n\tSource     string        `json:\"source\"`\r\n\tRestored   string        `json:\"restored\"`\r\n\tOK         bool          `json:\"ok\"`\r\n\tDigest     DigestPair    `json:\"digest\"`\r\n\tGroups     GroupPair     `json:\"groups\"`\r\n\tAccounting []AccountItem `json:\"accounting\"`\r\n}\r\n\r\ntype Report struct {\r\n\tCases []CaseResult `json:\"cases\"`\r\n}\r\n"]
