[9.727546, "o", "#!/bin/bash\r\n"]
[9.727722, "o", "set -euo pipefail\r\n"]
[9.727842, "o", "out=\"/app/output/restore-audit.json\"\r\nwork=\"\"\r\none_case=\"\"\r\nwhile [ \"$#\" -gt 0 ]; do\r\n  case \"$1\" in\r\n    --out) out=\"$2\"; shift 2 ;;\r\n    --work) work=\"$2\"; shift 2 ;;\r\n    --case) one_case=\"$2\"; shift 2 ;;\r\n    *) shift ;;\r\n  esac\r\ndone\r\nmkdir -p \"$(dirname \"$out\")\"\r\n"]
[9.728022, "o", "make -s -C /app build\r\nargs=(\"--out\" \"$out\")\r\nif [ -n \"$work\" ]; then\r\n  args+=(\"--work\" \"$work\")\r\nfi\r\nif [ -n \"$one_case\" ]; then\r\n  args+=(\"--case\" \"$one_case\")\r\nfi\r\n"]
[9.728197, "o", "/app/bin/snapctl \"${args[@]}\"\r\n"]
[9.728344, "o", "\u001b[?2004hroot@24f176b92b01:/app# "]
