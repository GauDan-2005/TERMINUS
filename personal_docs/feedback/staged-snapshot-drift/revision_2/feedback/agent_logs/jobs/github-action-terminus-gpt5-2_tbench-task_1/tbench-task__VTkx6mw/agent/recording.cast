[82.894225, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: internal/b1/replay.go\n@@\n func fold_b(a []rowX, b uint64) ([]rowX, error) {\n         out := make([]rowX, len(a))\n         copy(out, a)\n         sort.SliceStable(out, func(i, j int) bool {\n                 return out[i].Seq < out[j].Seq\n         })\n-        if b&1 == 1 {\n-                for left, right := 0, len(out)-1; left < right; left, right = left+1, right-1 {\n-                        out[left], out[right] = out[right], out[left]\n-                }\n-        }\n+        // Rows represent an append-only history. Even when simulating a restart,\n+        // we must preserve sequence order so that the last write wins and the\n+        // restored tree matches the final on-disk source state.\n+        //\n+        // Reversing row order causes older content to overwrite newer content\n+        // (and can also break hardlink materialization by rewriting only one\n+        // member of a link group).\n+        _ = b\n         return out, nil\n }\n*** End Patch\nPATCH\n"]
