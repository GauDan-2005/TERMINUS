[313.517953, "o", "\u001b[?2004hroot@24f176b92b01:/app# "]
[328.550276, "i", "python3 - <<'PY'\nimport json,subprocess,os\n\ndef fsmeasure(root):\n  out=subprocess.check_output(['/app/bin/fsmeasure', root], text=True)\n  rows=[]\n  for line in out.splitlines():\n    p,b=line.split('\\t')\n    rows.append((p,int(b)))\n  return rows\n\nwith open('/app/output/restore-audit.json') as f:\n  d=json.load(f)\nfor name in ['alpha','beta','epsilon','zeta']:\n  c=[x for x in d['cases'] if x['name']==name][0]\n  src=c['source']; res=c['restored']\n  s=fsmeasure(src); r=fsmeasure(res)\n  print('CASE',name,'ok',c['ok'])\n  print(' fsmeasure lens',len(s),len(r),'equal',s==r)\n  if s!=r:\n    # show first diff-ish\n    sm={p:b for p,b in s}; rm={p:b for p,b in r}\n    only_s=sorted(set(sm)-set(rm))\n    only_r=sorted(set(rm)-set(sm))\n    diff=[p for p in sorted(set(sm)&set(rm)) if sm[p]!=rm[p]]\n    print('  only_src',only_s[:5])\n    print('  only_res',only_r[:5])\n    print('  size_diff',diff[:5])\n  # compare reported accounting vs fsmeasure-derived\n  acct={(i['path'],i['bytes'],i['period']) for i in c['accounting']}\n  # build expected periods per spec\n  exp=[]\n  roll=name in ('epsilon','zeta')\n  for p,b in s:\n    period='p1' if roll and p.startswith('d/') else 'p0'\n    exp.append((p,b,period))\n  exp=set(exp)\n  print(' accounting matches fsmeasure(source)?', acct==exp)\nPY\n"]
