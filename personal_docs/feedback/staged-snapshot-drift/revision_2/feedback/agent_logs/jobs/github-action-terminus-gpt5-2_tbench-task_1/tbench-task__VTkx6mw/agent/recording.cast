[360.832106, "o", "\u001b[01m\u001b[K/app/probe/measure.c:47:56:\u001b[m\u001b[K \u001b[01;35m\u001b[Kwarning: \u001b[m\u001b[K‘\u001b[01m\u001b[Ksnprintf\u001b[m\u001b[K’ output may be truncated before the last format character [\u001b[01;35m\u001b[K\u001b]8;;https://gcc.gnu.org/onlinedocs/gcc-14.2.0/gcc/Warning-Options.html#index-Wformat-truncation\u0007-Wformat-truncation=\u001b]8;;\u0007\u001b[m\u001b[K]\r\n   47 |         snprintf(child_full, sizeof(child_full), \"%s/%s\u001b[01;35m\u001b[K\"\u001b[m\u001b[K, root, child_rel);\r\n      |                                                        \u001b[01;35m\u001b[K^\u001b[m\u001b[K\r\n\u001b[01m\u001b[K/app/probe/measure.c:47:9:\u001b[m\u001b[K \u001b[01;36m\u001b[Knote: \u001b[m\u001b[K‘\u001b[01m\u001b[Ksnprintf\u001b[m\u001b[K’ output 2 or more bytes (assuming 4097) into a destination of size 4096\r\n   47 |         \u001b[01;36m\u001b[Ksnprintf(child_full, sizeof(child_full), \"%s/%s\", root, child_rel)\u001b[m\u001b[K;\r\n      |         \u001b[01;36m\u001b[K^~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\u001b[m\u001b[K\r\n"]
