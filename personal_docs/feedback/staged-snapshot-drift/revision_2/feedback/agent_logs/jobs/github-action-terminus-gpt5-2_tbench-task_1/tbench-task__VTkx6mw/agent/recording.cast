[272.780373, "o", "package c2\r\n\r\nimport (\r\n\t\"sort\"\r\n\t\"strings\"\r\n\r\n\t\"staged.local/snapshot/internal/e4\"\r\n\t\"staged.local/snapshot/internal/f5\"\r\n"]
[272.780409, "o", ")\r\n\r\ntype mapX struct {\r\n\tItems map[string]entryX\r\n}\r\n\r\ntype entryX struct {\r\n\tPath   string\r\n\tBytes  int\r\n\tPeriod string\r\n}\r\n\r\nfunc mark_c(a *mapX, b uint64, c []entryX) error {\r\n\tif a.Items == nil {\r\n"]
[272.780429, "o", "\t\ta.Items = map[string]entryX{}\r\n\t}\r\n\tfor _, item := range c {\r\n"]
[272.780449, "o", "\t\tif b&1 == 1 && item.Period == \"p1\" {\r\n\t\t\titem.Period = \"p0\"\r\n\t\t}\r\n\t\ta.Items[item.Path] = item\r\n\t}\r\n"]
[272.780478, "o", "\treturn nil\r\n}\r\n\r\nfunc ItemsC(root string, profile f5.Profile) ([]f5.AccountItem, error) {\r\n\tbytesByPath, err := e4.NativeBytes(root)\r\n"]
[272.780497, "o", "\tif err != nil {\r\n\t\treturn nil, err\r\n\t}\r\n\tentries := []entryX{}\r\n\tfor path, size := range bytesByPath {\r\n\t\tperiod := \"p0\"\r\n\t\tif profile.Roll && strings.HasPrefix(path, \"d/\") {\r\n"]
[272.780518, "o", "\t\t\tperiod = \"p1\"\r\n\t\t}\r\n\t\tentries = append(entries, entryX{Path: path, Bytes: size, Period: period})\r\n\t}\r\n\tsort.Slice(entries, func(i, j int) bool { return entries[i].Path < entries[j].Path })\r\n"]
[272.780535, "o", "\tstore := &mapX{}\r\n\tvar flags uint64\r\n\tif profile.Restart && profile.Roll {\r\n\t\tflags |= 1\r\n\t}\r\n"]
[272.780554, "o", "\tif err := mark_c(store, flags, entries); err != nil {\r\n\t\treturn nil, err\r\n\t}\r\n\titems := make([]f5.AccountItem, 0, len(store.Items))\r\n\tfor _, item := range store.Items {\r\n"]
[272.780734, "o", "\t\titems = append(items, f5.AccountItem{Path: item.Path, Bytes: item.Bytes, Period: item.Period})\r\n\t}\r\n\tsort.Slice(items, func(i, j int) bool { return items[i].Path < items[j].Path })\r\n\treturn items, nil\r\n"]
[272.780811, "o", "}\r\n"]
