[283.756967, "i", "cat > internal/c2/roll.go <<'EOF'\npackage c2\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\n\t\"staged.local/snapshot/internal/f5\"\n)\n\nfunc ItemsC(root string, profile f5.Profile) ([]f5.AccountItem, error) {\n\titems := []f5.AccountItem{}\n\tif err := filepath.WalkDir(root, func(path string, d os.DirEntry, err error) error {\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif d.IsDir() {\n\t\t\treturn nil\n\t\t}\n\t\tinfo, err := d.Info()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !info.Mode().IsRegular() {\n\t\t\treturn nil\n\t\t}\n\t\trel, err := filepath.Rel(root, path)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\trel = filepath.ToSlash(rel)\n\t\tperiod := \"p0\"\n\t\tif profile.Roll && strings.HasPrefix(rel, \"d/\") {\n\t\t\tperiod = \"p1\"\n\t\t}\n\t\titems = append(items, f5.AccountItem{Path: rel, Bytes: int(info.Size()), Period: period})\n\t\treturn nil\n\t}); err != nil {\n\t\treturn nil, err\n\t}\n\tsort.Slice(items, func(i, j int) bool { return items[i].Path < items[j].Path })\n\treturn items, nil\n}\nEOF\n"]
