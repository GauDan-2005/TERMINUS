[247.994847, "o", "package a0\r\n\r\nimport (\r\n"]
[247.995035, "o", "\t\"os\"\r\n\t\"path/filepath\"\r\n\t\"sort\"\r\n\t\"strings\"\r\n\t\"syscall\"\r\n\r\n\t\"staged.local/snapshot/internal/b1\"\r\n\t\"staged.local/snapshot/internal/d3\"\r\n\t\"staged.local/snapshot/internal/f5\"\r\n"]
[247.995075, "o", ")\r\n\r\ntype stateX struct {\r\n\tRows   []itemY\r\n\tByPath map[string]int\r\n}\r\n\r\ntype itemY = f5.Row\r\n\r\nfunc phase_a(a *stateX, b itemY) error {\r\n\tif a.ByPath == nil {\r\n\t\ta.ByPath = map[string]int{}\r\n\t}\r\n\tif b.Path == \"\" {\r\n\t\treturn nil\r\n"]
[247.995098, "o", "\t}\r\n\t// Materialization must be byte-for-byte faithful to the source tree.\r\n\t// Do not mutate payloads (e.g. trimming trailing newlines) and do not\r\n\t// discard hardlink metadata (Nlink) since downstream restore relies on\r\n\t// this to recreate hardlink groups.\r\n"]
[247.995122, "o", "\tif b.Op == \"remove\" {\r\n\t\ta.Rows = append(a.Rows, b)\r\n\t\treturn nil\r\n\t}\r\n\tif _, ok := a.ByPath[b.Path]; ok {\r\n"]
[247.995142, "o", "\t\treturn nil\r\n\t}\r\n\ta.ByPath[b.Path] = len(a.Rows)\r\n"]
[247.995169, "o", "\ta.Rows = append(a.Rows, b)\r\n\treturn nil\r\n}\r\n\r\nfunc emit_a(path string, data string) error {\r\n\tif err := os.MkdirAll(filepath.Dir(path), 0o755); err != nil {\r\n"]
[247.995188, "o", "\t\treturn err\r\n\t}\r\n\treturn os.WriteFile(path, []byte(data), 0o644)\r\n}\r\n"]
[247.995207, "o", "\r\nfunc CreateTree(root string, profile f5.Profile) error {\r\n\tdirs := []string{\"a\", \"b\", \"c\"}\r\n\tif profile.Dense {\r\n"]
[247.995226, "o", "\t\tdirs = append(dirs, \"deep/x\")\r\n\t}\r\n\tif profile.Roll {\r\n\t\tdirs = append(dirs, \"d\")\r\n"]
[247.995245, "o", "\t}\r\n\tfor _, dir := range dirs {\r\n\t\tif err := os.MkdirAll(filepath.Join(root, dir), 0o755); err != nil {\r\n\t\t\treturn err\r\n"]
[247.995263, "o", "\t\t}\r\n\t}\r\n\tif err := emit_a(filepath.Join(root, \"a\", \"one.txt\"), profile.Name+\":one\\n\"); err != nil {\r\n"]
[247.995283, "o", "\t\treturn err\r\n\t}\r\n\tif err := emit_a(filepath.Join(root, \"b\", \"two.txt\"), profile.Name+\":two\\n\"); err != nil {\r\n\t\treturn err\r\n"]
[247.995303, "o", "\t}\r\n\tif err := emit_a(filepath.Join(root, \"c\", \"three.txt\"), profile.Name+\":three\\n\"); err != nil {\r\n\t\treturn err\r\n\t}\r\n"]
[247.995333, "o", "\tif profile.Dense {\r\n\t\tshared := filepath.Join(root, \"deep\", \"x\", \"shared.dat\")\r\n\t\tif err := emit_a(shared, profile.Name+\":shared-payload\\n\"); err != nil {\r\n\t\t\treturn err\r\n\t\t}\r\n"]
[247.995353, "o", "\t\tfor _, rel := range []string{\"a/shared-a.dat\", \"b/shared-b.dat\", \"c/shared-c.dat\"} {\r\n\t\t\talias := filepath.Join(root, filepath.FromSlash(rel))\r\n"]
