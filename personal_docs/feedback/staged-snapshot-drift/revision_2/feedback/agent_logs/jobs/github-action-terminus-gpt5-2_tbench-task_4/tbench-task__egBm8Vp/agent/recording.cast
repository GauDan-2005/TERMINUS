[156.95977, "o", "package b1\r\n\r\nfunc checkpointB(rows []rowX) int {\r\n\tlast := 0\r\n\tfor _, row := range rows {\r\n\t\tif row.Seq > last {\r\n\t\t\tlast = row.Seq\r\n\t\t}\r\n\t}\r\n\treturn last\r\n}\r\n\u001b[?2004hroot@1465729b6301:/app# "]
