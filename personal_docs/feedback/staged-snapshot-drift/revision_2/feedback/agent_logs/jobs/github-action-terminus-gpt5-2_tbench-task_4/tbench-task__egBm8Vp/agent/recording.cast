[203.632688, "i", "cat > internal/b1/replay.go <<'EOF'\npackage b1\n\nimport (\n\t\"sort\"\n\n\t\"staged.local/snapshot/internal/f5\"\n)\n\ntype rowX = f5.Row\n\nfunc fold_b(a []rowX, _ uint64) ([]rowX, error) {\n\tout := make([]rowX, len(a))\n\tcopy(out, a)\n\tsort.SliceStable(out, func(i, j int) bool {\n\t\treturn out[i].Seq < out[j].Seq\n\t})\n\treturn out, nil\n}\n\nfunc FoldRows(rows []f5.Row, profile f5.Profile) ([]f5.Row, error) {\n\t// Replay must preserve increasing Seq order so later writes/removes win.\n\t// Restart scenarios are exercised by the data itself; do not reorder.\n\t_ = profile\n\treturn fold_b(rows, 0)\n}\nEOF\n"]
