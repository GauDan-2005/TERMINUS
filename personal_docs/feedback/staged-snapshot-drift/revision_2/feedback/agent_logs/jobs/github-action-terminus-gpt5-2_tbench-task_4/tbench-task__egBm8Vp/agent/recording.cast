[125.224207, "o", "    18\t}\r\n    19\t\r\n    20\ttype itemY = f5.Row\r\n    21\t\r\n    22\tfunc phase_a(a *stateX, b itemY) error {\r\n    23\t\tif a.ByPath == nil {\r\n    24\t\t\ta.ByPath = map[string]int{}\r\n    25\t\t}\r\n    26\t\tif b.Path == \"\" {\r\n    27\t\t\treturn nil\r\n    28\t\t}\tif b.Op == \"write\" && b.Nlink > 1 {\r\n    29\t\t\tb.Nlink = 1\r\n    30\t\t}\r\n    31\t\tif b.Op == \"remove\" {\r\n    32\t\t\ta.Rows = append(a.Rows, b)\r\n    33\t\t\treturn nil\r\n    34\t\t}\r\n    35\t\tif _, ok := a.ByPath[b.Path]; ok {\r\n    36\t\t\treturn nil\r\n    37\t\t}\r\n    38\t\ta.ByPath[b.Path] = len(a.Rows)\r\n    39\t\ta.Rows = append(a.Rows, b)\r\n    40\t\treturn nil\r\n    41\t}\r\n    42\t\r\n    43\tfunc emit_a(path string, data string) error {\r\n    44\t\tif err := os.MkdirAll(filepath.Dir(path), 0o755); err != nil {\r\n    45\t\t\treturn err\r\n    46\t\t}\r\n    47\t\treturn os.WriteFile(path, []byte(data), 0o644)\r\n    48\t}\r\n    49\t\r\n    50\tfunc CreateTree(root string, profile f5.Profile) error {\r\n    51\t\tdirs := []string{\"a\", \"b\", \"c\"}\r\n    52\t\tif profile.Dense {\r\n    53\t\t\tdirs = append(dirs, \"deep/x\")\r\n    54\t\t}\r\n    55\t\tif profile.Roll {\r\n    56\t\t\tdirs = append(dirs, \"d\")\r\n    57\t\t}\r\n    58\t\tfor _, dir := range dirs {\r\n    59\t\t\tif err := os.MkdirAll(filepath.Join(root, dir), 0o755); err != nil {\r\n    60\t\t\t\treturn err\r\n    61\t\t\t}\r\n    62\t\t}\r\n    63\t\tif err := emit_a(filepath.Join(root, \"a\", \"one.txt\"), profile.Name+\":one\\n\"); err != nil {\r\n    64\t\t\treturn err\r\n    65\t\t}\r\n    66\t\tif err := emit_a(filepath.Join(root, \"b\", \"two.txt\"), profile.Name+\":two\\n\"); err != nil {\r\n    67\t\t\treturn err\r\n    68\t\t}\r\n    69\t\tif err := emit_a(filepath.Join(root, \"c\", \"three.txt\"), profile.Name+\":three\\n\"); err != nil {\r\n    70\t\t\treturn err\r\n    71\t\t}\r\n    72\t\tif profile.Dense {\r\n    73\t\t\tshared := filepath.Join(root, \"deep\", \"x\", \"shared.dat\")\r\n    74\t\t\tif err := emit_a(shared, profile.Name+\":shared-payload\\n\"); err != nil {\r\n    75\t\t\t\treturn err\r\n    76\t\t\t}\r\n    77\t\t\tfor _, rel := range []string{\"a/shared-a.dat\", \"b/shared-b.dat\", \"c/shared-c.dat\"} {\r\n    78\t\t\t\talias := filepath.Join(root, filepath.FromSlash(rel))\r\n    79\t\t\t\t_ = os.Remove(alias)\r\n    80\t\t\t\tif err := os.Link(shared, alias); err != nil {\r\n    81\t\t\t\t\treturn err\r\n    82\t\t\t\t}\r\n    83\t\t\t}\r\n    84\t\t}\r\n    85\t\tif profile.Ordered {\r\n    86\t\t\tflow := filepath.Join(root, \"a\", \"flow.txt\")\r\n    87\t\t\tif err := emit_a(flow, \"second\\n\"); err != nil {\r\n    88\t\t\t\treturn err\r\n    89\t\t\t}\r\n    90\t\t}\r\n"]
