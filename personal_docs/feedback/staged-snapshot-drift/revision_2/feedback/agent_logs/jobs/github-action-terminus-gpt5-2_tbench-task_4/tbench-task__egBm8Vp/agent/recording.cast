[125.333144, "i", "perl -0777 -i -pe 's|func phase_a\\(a \\*stateX, b itemY\\) error \\{.*?\\n\\}|func phase_a(a *stateX, b itemY) error {\\n\\tif a.ByPath == nil {\\n\\t\\ta.ByPath = map[string]int{}\\n\\t}\\n\\tif b.Path == \"\" {\\n\\t\\treturn nil\\n\\t}\\n\\t// Materialization must be byte-for-byte faithful to the source tree.\\n\\t// Do not mutate payloads (e.g. trimming trailing newlines) and do not\\n\\t// discard hardlink metadata (Nlink) since downstream restore relies on\\n\\t// this to recreate hardlink groups.\\n\\tif b.Op == \"remove\" {\\n\\t\\ta.Rows = append(a.Rows, b)\\n\\t\\treturn nil\\n\\t}\\n\\tif _, ok := a.ByPath[b.Path]; ok {\\n\\t\\treturn nil\\n\\t}\\n\\ta.ByPath[b.Path] = len(a.Rows)\\n\\ta.Rows = append(a.Rows, b)\\n\\treturn nil\\n}\\n|s' internal/a0/core.go\n"]
