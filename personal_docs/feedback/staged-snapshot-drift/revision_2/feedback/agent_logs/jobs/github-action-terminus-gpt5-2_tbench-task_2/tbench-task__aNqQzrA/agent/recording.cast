[252.737031, "o", "// Files under d/ are counted in the later quota period only once the case\r\n\u001b[?2004l\r"]
[252.737102, "o", "\u001b[?2004h> \u0007"]
[252.737126, "o", "\r\n"]
[252.737153, "o", "Makefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> "]
[252.737353, "o", "// has moved into that period (restart+roll profiles).\r\n\u001b[?2004l\r"]
[252.737414, "o", "\u001b[?2004h> \u0007"]
[252.737438, "o", "\r\n"]
[252.737463, "o", "Makefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> "]
[252.737707, "o", "if profile.Roll && profile.Restart && strings.HasPrefix(path, \"d/\") {\r\n\u001b[?2004l\r"]
[252.737766, "o", "\u001b[?2004h> \u0007"]
[252.737791, "o", "\r\n"]
[252.73783, "o", "Makefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> "]
