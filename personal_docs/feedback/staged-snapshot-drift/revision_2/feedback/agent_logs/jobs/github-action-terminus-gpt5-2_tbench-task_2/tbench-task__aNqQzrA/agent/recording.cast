[252.738018, "o", "period = \"p1\"\r\n\u001b[?2004l\r\u001b[?2004h> \u0007"]
[252.738096, "o", "\r\nMakefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> "]
[252.738142, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[252.738207, "o", "\u0007\r\nMakefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> "]
[252.73847, "o", "entries = append(entries, entryX{Path: path, Bytes: size, Period: period})\r\n\u001b[?2004l\r"]
[252.738585, "o", "\u001b[?2004h> \u0007"]
[252.738655, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> \u0007"]
