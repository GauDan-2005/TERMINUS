[57.373648, "o", "\r\nfunc packA(rows []itemY) map[string]string {\r\n\tout := map[string]string{}\r\n\tfor _, row := range rows {\r\n\t\tout[row.Path] = row.Op\r\n\t}\r\n\treturn out\r\n}\r\n"]
