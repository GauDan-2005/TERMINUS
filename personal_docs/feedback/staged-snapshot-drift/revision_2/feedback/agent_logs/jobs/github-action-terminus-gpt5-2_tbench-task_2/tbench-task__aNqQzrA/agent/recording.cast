[262.864179, "i", "python3 - <<'PY'\nimport json\nwith open('/app/output/restore-audit.json') as f: d=json.load(f)\nfor name in ['epsilon','zeta']:\n    c=next(x for x in d['cases'] if x['name']==name)\n    ditems=[it for it in c['accounting'] if it['path'].startswith('d/')]\n    print(name,'ok',c['ok'],'ditems',ditems)\nprint('ALL_OK', all(c['ok'] for c in d['cases']))\nPY\n"]
[262.864684, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> "]
