[252.740408, "o", "\u0007\r\nMakefile   README.md  bin/       cmd/       config/    data/      docs/      go.mod     internal/  output/    probe/     scripts/   \r\n> "]
[252.740653, "o", "items = append(items, f5.AccountItem{Path: item.Path, Bytes: item.Bytes, Period: item.Period})\r\n\u001b[?2004l\r"]
[252.740764, "o", "\u001b[?2004h> \u0007}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[252.740878, "o", "\u0007"]
[252.741056, "o", "sort.Slice(items, func(i, j int) bool { return items[i].Path < items[j].Path })\r\n\u001b[?2004l\r"]
