[209.701587, "o", "\r\ntype mapX struct {\r\n\tItems map[string]entryX\r\n}\r\n\r\ntype entryX struct {\r\n\tPath   string\r\n\tBytes  int\r\n\tPeriod string\r\n}\r\n\r\nfunc mark_c(a *mapX, b uint64, c []entryX) error {\r\n\tif a.Items == nil {\r\n\t\ta.Items = map[string]entryX{}\r\n\t}\r\n\tfor _, item := range c {\r\n\t\tif b&1 == 1 && item.Period == \"p1\" {\r\n\t\t\titem.Period = \"p0\"\r\n"]
