[252.728491, "i", "cat > /app/internal/c2/roll.go <<'EOF'\npackage c2\n\nimport (\n\t\"sort\"\n\t\"strings\"\n\n\t\"staged.local/snapshot/internal/e4\"\n\t\"staged.local/snapshot/internal/f5\"\n)\n\ntype mapX struct {\n\tItems map[string]entryX\n}\n\ntype entryX struct {\n\tPath   string\n\tBytes  int\n\tPeriod string\n}\n\nfunc mark_c(a *mapX, _ uint64, entries []entryX) error {\n\tif a.Items == nil {\n\t\ta.Items = map[string]entryX{}\n\t}\n\tfor _, item := range entries {\n\t\ta.Items[item.Path] = item\n\t}\n\treturn nil\n}\n\nfunc ItemsC(root string, profile f5.Profile) ([]f5.AccountItem, error) {\n\tbytesByPath, err := e4.NativeBytes(root)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tentries := make([]entryX, 0, len(bytesByPath))\n\tfor path, size := range bytesByPath {\n\t\tperiod := \"p0\"\n\t\t// Files under d/ are counted in the later quota period only once the case\n\t\t// has moved into that period (restart+roll profiles).\n\t\tif profile.Roll && profile.Restart && strings.HasPrefix(path, \"d/\") {\n\t\t\tperiod = \"p1\"\n\t\t}\n\t\tentries = append(entries, entryX{Path: path, Bytes: size, Period: period})\n\t}\n\tsort.Slice(entries, func(i, j int) bool { return entries[i].Path < entries[j].Path })\n\n\tstore := &mapX{}\n\tif err := mark_c(store, 0, entries); err != nil {\n\t\treturn nil, err\n\t}\n\n\titems := make([]f5.AccountItem, 0, len(store.Items))\n\tfor _, item := range store.Items {\n\t\titems = append(items, f5.AccountItem{Path: item.Path, Bytes: item.Bytes, Period: item.Period})\n\t}\n\tsort.Slice(items, func(i, j int) bool { return items[i].Path < items[j].Path })\n\treturn items, nil\n}\nEOF\n"]
