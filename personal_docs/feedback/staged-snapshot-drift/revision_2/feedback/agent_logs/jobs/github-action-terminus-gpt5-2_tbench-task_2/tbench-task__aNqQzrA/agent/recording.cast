[27.902234, "o", "#!/bin/bash\r\nset -euo pipefail\r\nout=\"/app/output/restore-audit.json\"\r\nwork=\"\"\r\none_case=\"\"\r\nwhile [ \"$#\" -gt 0 ]; do\r\n  case \"$1\" in\r\n    --out) out=\"$2\"; shift 2 ;;\r\n    --work) work=\"$2\"; shift 2 ;;\r\n    --case) one_case=\"$2\"; shift 2 ;;\r\n    *) shift ;;\r\n  esac\r\ndone\r\nmkdir -p \"$(dirname \"$out\")\"\r\nmake -s -C /app build\r\nargs=(\"--out\" \"$out\")\r\n"]
[27.902453, "o", "if [ -n \"$work\" ]; then\r\n  args+=(\"--work\" \"$work\")\r\nfi\r\nif [ -n \"$one_case\" ]; then\r\n  args+=(\"--case\" \"$one_case\")\r\nfi\r\n/app/bin/snapctl \"${args[@]}\"\r\n"]
[27.902642, "o", "\u001b[?2004hroot@07f74449b762:/app# "]
