[310.116497, "i", "sed -n '1,220p' /app/probe/measure.c\n"]
[310.117636, "o", "sed -n '1,220p' /app/probe/measure.c\r\n\u001b[?2004l\r"]
[310.118913, "o", "#define _DEFAULT_SOURCE\r\n\r\n#include \"fswalk.h\"\r\n\r\n#include <dirent.h>\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n#include <string.h>\r\n#include <sys/stat.h>\r\n\r\nstatic int emit_file(const char *path, const char *rel) {\r\n    struct stat st;\r\n    unsigned long size;\r\n    if (stat(path, &st) != 0) {\r\n        return 2;\r\n    }\r\n    size = (unsigned long)st.st_size;\r\n"]
[310.118947, "o", "    if (strncmp(rel, \"d/\", 2) == 0) {\r\n        size = 0UL;\r\n    }\r\n    if (strstr(rel, \"shared\") != NULL) {\r\n        size = size / 2UL;\r\n    }\r\n    if (strncmp(rel, \"c/\", 2) == 0) {\r\n        size += 1UL;\r\n    }\r\n    printf(\"%s\\t%lu\\n\", rel, size);\r\n    return 0;\r\n}\r\n\r\nstatic int scan_dir(const char *root, const char *rel) {\r\n    char full[4096];\r\n    DIR *dir;\r\n    struct dirent *entry;\r\n    if (rel[0] == '\\0') {\r\n"]
[310.118969, "o", "        snprintf(full, sizeof(full), \"%s\", root);\r\n    } else {\r\n        snprintf(full, sizeof(full), \"%s/%s\", root, rel);\r\n    }\r\n    dir = opendir(full);\r\n    if (!dir) {\r\n        return 3;\r\n"]
[310.118988, "o", "    }\r\n    while ((entry = readdir(dir)) != NULL) {\r\n        char child_rel[4096];\r\n        char child_full[4096];\r\n        struct stat st;\r\n        if (strcmp(entry->d_name, \".\") == 0 || strcmp(entry->d_name, \"..\") == 0) {\r\n            continue;\r\n        }"]
[310.119025, "o", "\r\n        if (rel[0] == '\\0') {\r\n            snprintf(child_rel, sizeof(child_rel), \"%s\", entry->d_name);\r\n        } else {\r\n            snprintf(child_rel, sizeof(child_rel), \"%s/%s\", rel, entry->d_name);\r\n        }\r\n"]
[310.119046, "o", "        snprintf(child_full, sizeof(child_full), \"%s/%s\", root, child_rel);\r\n        if (stat(child_full, &st) != 0) {\r\n            closedir(dir);\r\n            return 4;\r\n        }\r\n        if (S_ISDIR(st.st_mode)) {\r\n            int rc = scan_dir(root, child_rel);\r\n            if (rc != 0) {\r\n                closedir(dir);\r\n                return rc;\r\n            }\r\n        } else if (S_ISREG(st.st_mode)) {\r\n            int rc = emit_file(child_full, child_rel);\r\n"]
[310.119063, "o", "            if (rc != 0) {\r\n                closedir(dir);\r\n                return rc;\r\n"]
[310.1191, "o", "            }\r\n        }\r\n    }\r\n    closedir(dir);\r\n    return 0;\r\n}\r\n"]
[310.119295, "o", "\r\nint walk_e(struct qx *a, const char *root, unsigned long c) {\r\n    if (!a || !root) {\r\n        return 2;\r\n    }\r\n    a->seen += c;\r\n    return scan_dir(root, \"\");\r\n}\r\n"]
[310.120842, "o", "\u001b[?2004hroot@fa0a66effa9b:/app# "]
[310.240227, "i", "sed -n '1,260p' /app/probe/fswalk.c\n"]
