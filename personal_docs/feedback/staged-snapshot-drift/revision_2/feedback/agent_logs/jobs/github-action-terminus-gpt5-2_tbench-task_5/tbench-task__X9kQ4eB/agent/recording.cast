[67.636935, "o", "package e4\r\n\r\nimport (\r\n\t\"crypto/sha256\"\r\n\t\"encoding/hex\"\r\n\t\"os\"\r\n"]
[67.636975, "o", "\t\"path/filepath\"\r\n\t\"sort\"\r\n\t\"syscall\"\r\n)\r\n\r\nfunc Digest(root string) (string, error) {\r\n\thash := sha256.New()\r\n\tpaths := []string{}\r\n\tif err := filepath.WalkDir(root, func(path string, entry os.DirEntry, err error) error {\r\n\t\tif err != nil {\r\n\t\t\treturn err\r\n\t\t}\r\n\t\tpaths = append(paths, path)\r\n"]
[67.636995, "o", "\t\treturn nil\r\n\t}); err != nil {\r\n\t\treturn \"\", err\r\n\t}\r\n\tsort.Strings(paths)\r\n"]
[67.637016, "o", "\tfor _, path := range paths {\r\n\t\tif path == root {\r\n\t\t\tcontinue\r\n"]
[67.637032, "o", "\t\t}\r\n\t\trel, err := filepath.Rel(root, path)\r\n\t\tif err != nil {\r\n\t\t\treturn \"\", err\r\n"]
[67.637051, "o", "\t\t}\r\n\t\trel = filepath.ToSlash(rel)\r\n\t\tinfo, err := os.Stat(path)\r\n"]
[67.637067, "o", "\t\tif err != nil {\r\n\t\t\treturn \"\", err\r\n\t\t}\r\n\t\tif info.IsDir() {\r\n\t"]
[67.637085, "o", "\t\thash.Write([]byte(\"D \" + rel + \"\\n\"))\r\n\t\t\tcontinue\r\n"]
[67.637104, "o", "\t\t}\r\n\t\tif info.Mode().IsRegular() {\r\n\t\t\tdata, err := os.ReadFile(path)\r\n\t\t\tif err != nil {\r\n\t"]
[67.637122, "o", "\t\t\treturn \"\", err\r\n"]
[67.63714, "o", "\t\t\t}\r\n\t\t\thash.Write([]byte(\"F \" + rel + \"\\x00\"))\r\n\t\t\thash.Write(data)\r\n\t\t\thash.Write([]byte(\"\\n\"))"]
[67.637161, "o", "\r\n\t\t}\r\n\t}\r\n\treturn hex.EncodeToString(hash.Sum(nil)), nil\r\n}\r\n\r\nfunc Groups(root string) ([][]string, error) {"]
[67.637185, "o", "\r\n\tbyIdentity := map[[2]uint64][]string{}\r\n\tif err := filepath.WalkDir(root, func(path string, entry os.DirEntry, err error) error {\r\n\t\tif err != nil {\r\n\t\t\treturn err\r\n\t\t}\r\n"]
[67.637205, "o", "\t\tif !entry.Type().IsRegular() {\r\n\t\t\treturn nil\r\n\t\t}\r\n\t\tinfo, err := os.Stat(path)\r\n"]
[67.637224, "o", "\t\tif err != nil {\r\n\t\t\treturn err\r\n\t\t}\r\n\t\tst := info.Sys().(*syscall.Stat_t)\r\n\t\trel, err := filepath.Rel(root, path)\r\n"]
[67.63725, "o", "\t\tif err != nil {\r\n\t\t\treturn err\r\n\t\t}\r\n\t\tkey := [2]uint64{uint64(st.Dev), uint64(st.Ino)}\r\n\t\tbyIdentity[key] = append(byIdentity[key], filepath.ToSlash(rel))\r\n\t\treturn nil\r\n\t}); err != nil {\r\n"]
[67.63727, "o", "\t\treturn nil, err\r\n\t}\r\n\tgroups := [][]string{}\r\n\tfor _, group := range byIdentity {\r\n"]
[67.637296, "o", "\t\tif len(group) > 1 {\r\n\t\t\tsort.Strings(group)\r\n\t\t\tgroups = append(groups, group)\r\n\t\t}\r\n\t}\r\n\tsort.Slice(groups, func(i, j int) bool { return groups[i][0] < groups[j][0] })\r\n"]
[67.637316, "o", "\treturn groups, nil\r\n}\r\n"]
