[300.788742, "i", "sed -n '1,260p' /app/internal/c2/roll.go\n"]
[300.78917, "o", "sed -n '1,260p' /app/internal/c2/roll.go\r\n"]
[300.789335, "o", "\u001b[?2004l\r"]
[300.791153, "o", "package c2\r\n\r\nimport (\r\n\t\"sort\"\r\n\t\"strings\"\r\n\r\n\t\"staged.local/snapshot/internal/e4\"\r\n"]
[300.791194, "o", "\t\"staged.local/snapshot/internal/f5\"\r\n)\r\n\r\ntype mapX struct {\r\n\tItems map[string]entryX\r\n}\r\n\r\ntype entryX struct {\r\n\tPath   string\r\n\tBytes  int\r\n\tPeriod string\r\n}\r\n\r\n"]
[300.791214, "o", "func mark_c(a *mapX, b uint64, c []entryX) error {\r\n\tif a.Items == nil {\r\n\t\ta.Items = map[string]entryX{}\r\n\t}\r\n"]
[300.791231, "o", "\tfor _, item := range c {\r\n\t\tif b&1 == 1 && item.Period == \"p1\" {\r\n\t\t\titem.Period = \"p0\"\r\n"]
[300.791246, "o", "\t\t}\r\n\t\ta.Items[item.Path] = item\r\n\t}\r\n"]
[300.791264, "o", "\treturn nil\r\n}\r\n\r\n"]
[300.791281, "o", "func ItemsC(root string, profile f5.Profile) ([]f5.AccountItem, error) {\r\n\tbytesByPath, err := e4.NativeBytes(root)\r\n\tif err != nil {\r\n"]
[300.791297, "o", "\t\treturn nil, err\r\n\t}\r\n\tentries := []entryX{}\r\n"]
[300.791317, "o", "\tfor path, size := range bytesByPath {\r\n\t\tperiod := \"p0\"\r\n\t\tif profile.Roll && strings.HasPrefix(path, \"d/\") {\r\n"]
[300.791337, "o", "\t\t\tperiod = \"p1\"\r\n\t\t}\r\n\t\tentries = append(entries, entryX{Path: path, Bytes: size, Period: period})\r\n"]
[300.791356, "o", "\t}\r\n\tsort.Slice(entries, func(i, j int) bool { return entries[i].Path < entries[j].Path })\r\n\tstore := &mapX{}\r\n"]
[300.791448, "o", "\tvar flags uint64\r\n\tif profile.Restart && profile.Roll {\r\n\t\tflags |= 1\r\n\t}\r\n\tif err := mark_c(store, flags, entries); err != nil {\r\n\t\treturn nil, err\r\n\t}\r\n\titems := make([]f5.AccountItem, 0, len(store.Items))\r\n\tfor _, item := range store.Items {\r\n\t\titems = append(items, f5.AccountItem{Path: item.Path, Bytes: item.Bytes, Period: item.Period})\r\n\t}\r\n\tsort.Slice(items, func(i, j int) bool { return items[i].Path < items[j].Path })\r\n\treturn items, nil\r\n}\r\n"]
[300.791728, "o", "\u001b[?2004hroot@fa0a66effa9b:/app# "]
[300.918838, "i", "sed -n '1,320p' /app/internal/c2/table.go\n"]
[300.919214, "o", "sed -n '1,320p' /app/internal/c2/table.go\r\n\u001b[?2004l\r"]
[300.920232, "o", "package c2\r\n\r\nfunc newC() *mapX {\r\n\treturn &mapX{Items: map[string]entryX{}}\r\n}\r\n"]
[300.920383, "o", "\u001b[?2004h"]
[300.92041, "o", "root@fa0a66effa9b:/app# "]
[301.032797, "i", "sed -n '1,120p' /app/internal/b1/replay.go\n"]
[301.033893, "o", "sed -n '1,120p' /app/internal/b1/replay.go\r\n\u001b[?2004l\r"]
[301.034869, "o", "package b1\r\n\r\nimport (\r\n\t\"sort\"\r\n\r\n\t\"staged.local/snapshot/internal/f5\"\r\n)\r\n\r\ntype rowX = f5.Row\r\n\r\n"]
[301.034903, "o", "func fold_b(a []rowX, b uint64) ([]rowX, error) {\r\n\tout := make([]rowX, len(a))\r\n\tcopy(out, a)\r\n\tsort.SliceStable(out, func(i, j int) bool {\r\n\t\treturn out[i].Seq < out[j].Seq\r\n\t})\r\n\tif b&1 == 1 {\r\n\t\tfor left, right := 0, len(out)-1; left < right; left, right = left+1, right-1 {\r\n\t\t\tout[left], out[right] = out[right], out[left]\r\n\t\t}\r\n\t}\r\n\treturn out, nil\r\n"]
[301.034923, "o", "}\r\n\r\nfunc FoldRows(rows []f5.Row, profile f5.Profile) ([]f5.Row, error) {\r\n\tvar flags uint64\r\n\tif profile.Restart && profile.Ordered {\r\n"]
[301.035189, "o", "\t\tflags |= 1\r\n\t}\r\n\treturn fold_b(rows, flags)\r\n}\r\n"]
