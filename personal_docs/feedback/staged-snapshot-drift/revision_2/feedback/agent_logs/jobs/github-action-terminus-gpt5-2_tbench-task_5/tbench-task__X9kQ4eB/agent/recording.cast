[89.649073, "o", "\t\t}\r\n\t\treturn nil\r\n\t}); err != nil {\r\n\t\treturn nil, err\r\n\t}\r\n\tsort.Strings(paths)\r\n\tstate := &stateX{ByPath: map[string]int{}}\r\n"]
[89.649213, "o", "\tseq := 0\r\n\tfor _, path := range paths {\r\n\t\trel, err := filepath.Rel(root, path)\r\n\t\tif err != nil {\r\n\t\t\treturn nil, err\r\n\t\t}\r\n\t\trel = filepath.ToSlash(rel)\r\n\t\tif profile.Ordered && rel == \"a/flow.txt\" {\r\n\t\t\tcontinue\r\n\t\t}\r\n\t\tdev, ino, nlink, err := statIdentity(path)\r\n\t\tif err != nil {\r\n\t\t\treturn nil, err\r\n\t\t}\r\n\t\tdata, err := os.ReadFile(path)\r\n\t\tif err != nil {\r\n\t\t\treturn nil, err\r\n\t\t}\r\n\t\tif err := phase_a(state, f5.Row{Seq: seq, Op: \"write\", Path: rel, Data: string(data), Dev: dev, Ino: ino, Nlink: nlink}); err != nil {\r\n\t\t\treturn nil, err\r\n\t\t}\r\n\t\tseq++\r\n\t}\r\n\tif profile.Ordered {\r\n\t\tflow := filepath.Join(root, \"a\", \"flow.txt\")\r\n\t\tdev, ino, nlink, err := statIdentity(flow)\r\n\t\tif err != nil {\r\n\t\t\treturn nil, err\r\n\t\t}\r\n"]
[89.649233, "o", "\t\tfor _, row := range []f5.Row{\r\n\t\t\t{Seq: seq, Op: \"write\", Path: \"a/flow.txt\", Data: \"first\\n\", Dev: dev, Ino: ino, Nlink: nlink},\r\n\t\t\t{Seq: seq + 1, Op: \"remove\", Path: \"a/flow.txt\", Dev: dev, Ino: ino, Nlink: nlink},\r\n\t\t\t{Seq: seq + 2, Op: \"write\", Path: \"a/flow.txt\", Data: \"second\\n\", Dev: dev, Ino: ino, Nlink: nlink},\r\n"]
[89.649247, "o", "\t\t} {\r\n\t\t\tif err := phase_a(state, row); err != nil {\r\n"]
[89.649266, "o", "\t\t\t\treturn nil, err\r\n\t\t\t}\r\n\t\t}\r\n"]
[89.649284, "o", "\t}\r\n\treturn append([]f5.Row(nil), state.Rows...), nil\r\n}\r\n\r\n"]
[89.649298, "o", "func Materialize(rows []f5.Row, dst string, profile f5.Profile) error {\r\n\treplayRows, err := b1.FoldRows(rows, profile)\r\n\tif err != nil {\r\n"]
[89.649314, "o", "\t\treturn err\r\n\t}\r\n"]
[89.649329, "o", "\tgroups := map[string]string{}\r\n\tfor _, row := range replayRows {\r\n\t\ttarget := filepath.Join(dst, filepath.FromSlash(row.Path))\r\n"]
[89.649346, "o", "\t\tif row.Op == \"remove\" {\r\n\t\t\t_ = os.Remove(target)\r\n"]
[89.649363, "o", "\t\t\tfor key, value := range groups {\r\n\t\t\t\tif value == target {\r\n\t\t\t\t\tdelete(groups, key)\r\n"]
[89.649377, "o", "\t\t\t\t}\r\n\t\t\t}\r\n"]
[89.649389, "o", "\t\t\tcontinue\r\n\t\t}\r\n\t\tif err := os.MkdirAll(filepath.Dir(target), 0o755); err != nil {\r\n"]
[89.649403, "o", "\t\t\treturn err\r\n\t\t}\r\n"]
[89.64942, "o", "\t\tkey := d3.KeyFor(row, profile)\r\n\t\tif existing, ok := groups[key]; ok {\r\n"]
[89.649439, "o", "\t\t\t_ = os.Remove(target)\r\n\t\t\tif err := os.Link(existing, target); err != nil {\r\n\t\t\t\treturn err\r\n"]
[89.649452, "o", "\t\t\t}\r\n\t\t\tcontinue\r\n\t\t}\r\n"]
[89.649465, "o", "\t\tif strings.TrimSpace(row.Op) == \"\" || row.Op == \"write\" {\r\n\t\t\tif err := emit_a(target, row.Data); err != nil {\r\n"]
[89.649481, "o", "\t\t\t\treturn err\r\n\t\t\t}\r\n"]
[89.6495, "o", "\t\t\tgroups[key] = target\r\n\t\t}\r\n\t}\r\n"]
[89.649518, "o", "\treturn nil\r\n}\r\n"]
