[334.420793, "o", "\r\n\u001b[?2004l\r"]
[334.421996, "o", "package b1\r\n"]
[334.422116, "o", "\r\nimport (\r\n\t\"sort\"\r\n\r\n\t\"staged.local/snapshot/internal/f5\"\r\n)\r\n\r\ntype rowX = f5.Row\r\n\r\nfunc fold_b(a []rowX, b uint64) ([]rowX, error) {\r\n\tout := make([]rowX, len(a))\r\n\tcopy(out, a)\r\n\tsort.SliceStable(out, func(i, j int) bool {\r\n\t\treturn out[i].Seq < out[j].Seq\r\n\t})\r\n\tif b&1 == 1 {\r\n\t\tfor left, right := 0, len(out)-1; left < right; left, right = left+1, right-1 {\r\n"]
[334.422156, "o", "\t\t\tout[left], out[right] = out[right], out[left]\r\n\t\t}\r\n\t}\r\n\treturn out, nil\r\n}\r\n\r\nfunc FoldRows(rows []f5.Row, profile f5.Profile) ([]f5.Row, error) {\r\n\tvar flags uint64\r\n"]
[334.422259, "o", "\tif profile.Restart && profile.Ordered {\r\n\t\tflags |= 1\r\n\t}\r\n\treturn fold_b(rows, flags)\r\n}\r\n"]
[334.422444, "o", "\u001b[?2004hroot@fa0a66effa9b:/app# "]
[334.524777, "i", "perl -0777 -i -pe 's/\\n\\s*var flags uint64\\n\\s*if profile\\.Restart && profile\\.Ordered \\{\\n\\s*flags \\|= 1\\n\\s*\\}\\n\\s*return fold_b\\(rows, flags\\)\\n/\\n\\treturn fold_b(rows, 0)\\n/sg' /app/internal/b1/replay.go\n"]
[334.525708, "o", "perl -0777 -i -pe 's/\\n\\s*var flags uint64\\n\\s*if profile\\.Restart && profile\\.Ordered \\{\\n\\s*flags \\|= 1\\n\\s*\\}\\n\\s*return fold_b\\(rows, flags\\)\\n/\\n\\treturn fold_b(rows, 0)\\n/sg' /app/internal/b1/replay.go\r\n\u001b[?2004l\r"]
[334.529277, "o", "\u001b[?2004hroot@fa0a66effa9b:/app# "]
[335.528249, "i", "sed -n '1,120p' /app/internal/b1/replay.go\n"]
[335.528764, "o", "sed -n '1,120p' /app/internal/b1/replay.go\r\n\u001b[?2004l\r"]
[335.529601, "o", "package b1\r\n\r\nimport (\r\n\t\"sort\"\r\n\r\n\t\"staged.local/snapshot/internal/f5\"\r\n)\r\n"]
[335.530326, "o", "\r\ntype rowX = f5.Row\r\n\r\nfunc fold_b(a []rowX, b uint64) ([]rowX, error) {\r\n\tout := make([]rowX, len(a))\r\n\tcopy(out, a)\r\n\tsort.SliceStable(out, func(i, j int) bool {\r\n\t\treturn out[i].Seq < out[j].Seq\r\n\t})\r\n\tif b&1 == 1 {\r\n\t\tfor left, right := 0, len(out)-1; left < right; left, right = left+1, right-1 {\r\n\t\t\tout[left], out[right] = out[right], out[left]\r\n\t\t}\r\n\t}\r\n\treturn out, nil\r\n}\r\n\r\nfunc FoldRows(rows []f5.Row, profile f5.Profile) ([]f5.Row, error) {\r\n\treturn fold_b(rows, 0)\r\n}\r\n\u001b[?2004hroot@fa0a66effa9b:/app# "]
