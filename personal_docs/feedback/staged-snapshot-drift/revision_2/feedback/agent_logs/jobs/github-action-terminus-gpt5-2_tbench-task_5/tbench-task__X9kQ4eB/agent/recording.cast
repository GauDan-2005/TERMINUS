[300.288214, "i", "python3 - <<'PY'\nimport json, os\nobj=json.load(open('/app/output/restore-audit.json'))\nbyname={c['name']:c for c in obj['cases']}\nfor name in ['alpha','beta','delta','epsilon']:\n    c=byname[name]\n    print('\\nCASE', name, 'ok', c['ok'])\n    for rootlabel in ['source','restored']:\n        root=c[rootlabel]\n        bad=[]\n        for it in c['accounting']:\n            p=os.path.join(root, it['path'])\n            try:\n                sz=os.stat(p).st_size\n            except FileNotFoundError:\n                bad.append((it['path'],'missing'))\n                continue\n            if sz!=it['bytes']:\n                bad.append((it['path'], f\"size {sz} != {it['bytes']}\"))\n        print(' ',rootlabel,'disk check:', 'OK' if not bad else 'BAD', bad[:5])\nPY\n"]
