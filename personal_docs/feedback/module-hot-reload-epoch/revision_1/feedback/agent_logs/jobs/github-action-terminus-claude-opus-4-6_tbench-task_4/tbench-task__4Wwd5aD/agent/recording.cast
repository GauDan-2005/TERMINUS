[26.011645, "o", "pub fn r_d(a: &str, b: i64, c: i64) -> i64 {\r\n    match a {\r\n        \"old\" => b,\r\n        \"new\" => b + c,\r\n        _ => b,\r\n    }\r\n}\r\n\r\npub fn aux_r(a: i64) -> i64 {\r\n    a * 2\r\n}\r\n"]
