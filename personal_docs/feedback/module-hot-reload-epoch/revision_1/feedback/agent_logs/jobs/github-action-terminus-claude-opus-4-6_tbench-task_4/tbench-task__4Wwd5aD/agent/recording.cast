[15.036372, "o", "function q_b(a, b, c) {\r\n  const label = `slot-${b}`;\r\n  c[label] = (c[label] || []).concat(a);\r\n  const next = `slot-${b + 1}`;\r\n  const visible = c[next] || [];\r\n  c[next] = [];\r\n  return visible.slice().sort((left, right) => left - right);\r\n}\r\n\r\nfunction scan_b(a) {\r\n  return Object.keys(a).sort();\r\n}\r\n\r\nmodule.exports = { q_b, scan_b };\r\n\u001b[?2004hroot@79f05e799cd1:/app# "]
[15.146229, "i", "cat /app/c3/r.js\n"]
[15.146563, "o", "cat /app/c3/r.js"]
[15.147375, "o", "\r\n\u001b[?2004l\r"]
[15.147979, "o", "let saved = null;\r\n\r\nfunction k_c(a, b, c) {\r\n  if (saved === null) {\r\n    saved = Number(a);\r\n  }\r\n  return saved + b;\r\n}\r\n\r\nfunction lens_c(a) {\r\n  return String(a).length;\r\n}\r\n\r\nmodule.exports = { k_c, lens_c };\r\n"]
[15.148244, "o", "\u001b[?2004hroot@79f05e799cd1:/app# "]
[15.274345, "i", "cat /app/d4/s.js\n"]
