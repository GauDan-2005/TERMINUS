[14.807956, "o", "          \"base\": 2,\r\n          \"dep\": 4,\r\n          \"deferred\": [\r\n            5,\r\n            1\r\n          ],\r\n          \"native\": \"old\"\r\n        },\r\n        {\r\n          \"base\": 3,\r\n          \"dep\": 4,\r\n          \"deferred\": [\r\n            2\r\n          ],\r\n          \"native\": \"old\"\r\n        },\r\n        {\r\n          \"base\": 1,\r\n          \"dep\": 5,\r\n          \"deferred\": [],\r\n          \"native\": \"new\"\r\n        }\r\n      ]\r\n    },\r\n    {\r\n      \"name\": \"gamma\",\r\n      \"cycles\": [\r\n        {\r\n          \"base\": 6,\r\n          \"dep\": 1,\r\n          \"deferred\": [],\r\n          \"native\": \"new\"\r\n        },\r\n        {\r\n          \"base\": 2,\r\n          \"dep\": 6,\r\n          \"deferred\": [\r\n            4\r\n          ],\r\n          \"native\": \"old\"\r\n        }\r\n      ]\r\n    },\r\n    {\r\n      \"name\": \"delta\",\r\n      \"cycles\": [\r\n        {\r\n          \"base\": 1,\r\n          \"dep\": 7,\r\n          \"deferred\": [\r\n            2,\r\n            2\r\n          ],\r\n          \"native\": \"old\"\r\n        },\r\n        {\r\n          \"base\": 8,\r\n          "]
[14.808162, "o", "\"dep\": 2,\r\n          \"deferred\": [\r\n            1\r\n          ],\r\n          \"native\": \"new\"\r\n        }\r\n      ]\r\n    },\r\n    {\r\n      \"name\": \"epsilon\",\r\n      \"cycles\": [\r\n        {\r\n          \"base\": 3,\r\n          \"dep\": 3,\r\n          \"deferred\": [\r\n            3\r\n          ],\r\n          \"native\": \"old\"\r\n        },\r\n        {\r\n          \"base\": 3,\r\n          \"dep\": 8,\r\n          \"deferred\": [\r\n            2\r\n          ],\r\n          \"native\": \"old\"\r\n        },\r\n        {\r\n          \"base\": 3,\r\n          \"dep\": 2,\r\n          \"deferred\": [],\r\n          \"native\": \"new\"\r\n        }\r\n      ]\r\n    },\r\n    {\r\n      \"name\": \"zeta\",\r\n      \"cycles\": [\r\n        {\r\n          \"base\": 9,\r\n          \"dep\": 2,\r\n          \"deferred\": [],\r\n  "]
