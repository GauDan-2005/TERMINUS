[26.740463, "o", "function meter_g(a) {\r\n  return a.reduce((acc, value) => acc + Number(value || 0), 0);\r\n}\r\n\r\nfunction average_g(a) {\r\n  return a.length === 0 ? 0 : meter_g(a) / a.length;\r\n}\r\n\r\nmodule.exports = { meter_g, average_g };\r\n"]
