[16.967181, "o", "cat /app/b2/q.js\r\n\u001b[?2004l\r"]
[16.96804, "o", "function q_b(a, b, c) {\r\n  const label = `slot-${b}`;\r\n  c[label] = (c[label] || []).concat(a);\r\n  const next = `slot-${b + 1}`;\r\n  const visible = c[next] || [];\r\n  c[next] = [];\r\n  return visible.slice().sort((left, right) => left - right);\r\n}\r\n\r\nfunction scan_b(a) {\r\n  return Object.keys(a).sort();\r\n}\r\n\r\nmodule.exports = { q_b, scan_b };\r\n"]
[16.968246, "o", "\u001b[?2004h"]
[16.968325, "o", "root@14c62484f45d:/app# "]
[17.078855, "i", "cat /app/c3/r.js\n"]
[17.078909, "o", "cat /app/c3/r.js"]
[17.079685, "o", "\r\n\u001b[?2004l\r"]
[17.081347, "o", "let saved = null;\r\n\r\nfunction k_c(a, b, c) {\r\n  if (saved === null) {\r\n    saved = Number(a);\r\n  }\r\n  return saved + b;\r\n}\r\n\r\nfunction lens_c(a) {\r\n  return String(a).length;\r\n}\r\n\r\nmodule.exports = { k_c, lens_c };\r\n"]
[17.081529, "o", "\u001b[?2004h"]
[17.081599, "o", "root@14c62484f45d:/app# "]
