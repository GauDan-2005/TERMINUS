[26.627323, "o", "function order_f(a) {\r\n  return a.slice().sort((left, right) => String(left).localeCompare(String(right)));\r\n}\r\n\r\nfunction merge_f(a, b) {\r\n  return order_f([].concat(a || [], b || []));\r\n}\r\n\r\nmodule.exports = { order_f, merge_f };\r\n"]
