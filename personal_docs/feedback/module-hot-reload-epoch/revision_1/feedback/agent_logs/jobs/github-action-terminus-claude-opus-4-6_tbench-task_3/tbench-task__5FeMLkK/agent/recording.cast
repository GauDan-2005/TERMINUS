[26.8557, "o", "function clone_h(a) {\r\n  return JSON.parse(JSON.stringify(a));\r\n}\r\n\r\nfunction stamp_h(a, b) {\r\n  const copy = clone_h(a);\r\n  copy.marker = b;\r\n  return copy;\r\n}\r\n\r\nmodule.exports = { clone_h, stamp_h };\r\n"]
