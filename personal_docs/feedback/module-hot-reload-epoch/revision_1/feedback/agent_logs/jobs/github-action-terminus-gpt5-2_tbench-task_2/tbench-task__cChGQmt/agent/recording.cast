[187.575441, "i", "cat > a1/p.js <<'EOF'\nconst { spawnSync } = require('child_process');\nconst { q_b } = require('../b2/q');\nconst { k_c } = require('../c3/r');\n\nfunction resolveCargo() {\n  if (process.env.CARGO && String(process.env.CARGO).trim()) return process.env.CARGO;\n  return '/usr/local/cargo/bin/cargo';\n}\n\nfunction callNative(root, rev, primary, carry) {\n  const cargo = resolveCargo();\n  const env = {\n    ...process.env,\n    PATH: process.env.PATH ? `${process.env.PATH}:/usr/local/cargo/bin` : '/usr/local/cargo/bin'\n  };\n\n  const proc = spawnSync(\n    cargo,\n    ['run', '--quiet', '--bin', 'mhre_native', '--', rev, String(primary), String(carry)],\n    { cwd: root, encoding: 'utf8', env }\n  );\n\n  if (proc.status !== 0) {\n    const err = proc.stderr || proc.stdout || (proc.error && proc.error.message) || 'native worker failed';\n    throw new Error(err);\n  }\n  return Number(String(proc.stdout).trim());\n}\n\nfunction f_a(a, b, c) {\n  let carry = 0;\n  const rows = [];\n  let accepted = true;\n  let lastNative = 0;\n  const sumBa"]
[187.575792, "i", "ses = a.cycles.reduce((acc, cycle) => acc + Number(cycle.base), 0);\n\n  for (let index = 0; index < a.cycles.length; index += 1) {\n    const cycle = a.cycles[index];\n    const owned = q_b(cycle.deferred || [], index, c);\n    const factor = k_c(cycle.dep, index, c);\n    const nativeValue = callNative(b, cycle.native, cycle.base, carry);\n\n    // Acceptance check uses the carried native state.\n    if (cycle.native === 'old' && nativeValue < carry + cycle.base) {\n      accepted = false;\n    }\n\n    const rowValue = nativeValue + factor + owned.reduce((acc, value) => acc + value, 0);\n    rows.push({ index, value: rowValue, factor, nativeValue, deferred: owned });\n\n    carry = nativeValue;\n    lastNative = nativeValue;\n  }\n\n  const finalCounter = lastNative;\n  const healthy = Boolean(accepted && finalCounter === sumBases);\n\n  return {\n    name: a.name,\n    scenario: a.name,\n    rows,\n    finalCounter,\n    dependencyTotal: rows.reduce((acc, row) => acc + row.factor, 0),\n    acceptedOlder: accepted,\n    healthy\n  };\n}\n"]
[187.575833, "i", "\nmodule.exports = { f_a };\nEOF\n"]
