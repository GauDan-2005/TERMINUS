[256.174026, "i", "python3 - <<'PY'\nimport json\np='outcome/report.json'\nd=json.load(open(p))\nassert set(d.keys())=={'records','aggregate'}\nagg=d['aggregate']\nreq_agg={'source','recordCount','totalCounter','dependencyTotal','rowTotal','healthyCount','status'}\nprint('aggregate keys ok:', req_agg.issubset(agg.keys()))\nfor rec in d['records']:\n  for k in ['scenario','rows','finalCounter','dependencyTotal','acceptedOlder','healthy']:\n    assert k in rec, (rec.get('name'), 'missing', k)\n  rows=rec['rows']\n  for i,row in enumerate(rows):\n    for k in ['index','value','factor','nativeValue','deferred']:\n      assert k in row\n    assert row['index']==i\n    assert row['deferred']==sorted(row['deferred'])\nprint('records/rows shape ok for', len(d['records']), 'records')\nPY\n"]
