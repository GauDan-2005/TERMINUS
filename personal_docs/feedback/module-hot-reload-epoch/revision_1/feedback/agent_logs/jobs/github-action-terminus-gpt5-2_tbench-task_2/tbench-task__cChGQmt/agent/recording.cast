[167.323406, "o", "\r\n\u001b[?2004l\r"]
[167.324895, "o", "let saved = null;\r\n"]
[167.325109, "o", "\r\nfunction k_c(a, b, c) {\r\n  if (saved === null) {\r\n    saved = Number(a);\r\n  }\r\n  return saved + b;\r\n}\r\n\r\nfunction lens_c(a) {\r\n  return String(a).length;\r\n}\r\n\r\nmodule.exports = { k_c, lens_c };\r\n"]
[167.325273, "o", "\u001b[?2004hroot@eca5a5f6d31b:/app# "]
[167.434665, "i", "sed -n '1,260p' d4/s.js\n"]
