[167.202115, "o", "sed -n '1,200p' b2/q.js\r\n\u001b[?2004l\r"]
[167.204436, "o", "function q_b(a, b, c) {\r\n  const label = `slot-${b}`;\r\n  c[label] = (c[label] || []).concat(a);\r\n  const next = `slot-${b + 1}`;\r\n  const visible = c[next] || [];\r\n  c[next] = [];\r\n  return visible.slice().sort((left, right) => left - right);\r\n}\r\n\r\nfunction scan_b(a) {\r\n  return Object.keys(a).sort();\r\n}\r\n\r\nmodule.exports = { q_b, scan_b };\r\n\u001b[?2004hroot@eca5a5f6d31b:/app# "]
[167.322003, "i", "sed -n '1,200p' c3/r.js\n"]
