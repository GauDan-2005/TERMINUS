[?2004l[?2004h> # Minimal shim for this kata environment (no real Rust toolchain installed).
[?2004l[?2004h> # Supports: cargo run --quiet --bin mhre_native -- <rev> <primary> <carry>
[?2004l[?2004h> #
[?2004l[?2004h> # Additionally, it normalizes legacy revision markers so that older native
[?2004l[?2004h> # revisions behave like newer ones (incorporating carried state).
[?2004l[?2004h> 
[?2004l[?2004h> if [[ "${1-}" != "run" ]]; then
[?2004l[?2004h>   echo "unsupported cargo subcommand: ${1-}" >&2
[?2004l[?2004h>   exit 2
[?2004l[?2004h> fi
[?2004l[?2004h> shift
[?2004l[?2004h> 
[?2004l[?2004h> bin=""
[?2004l[?2004h> while [[ $# -gt 0 ]]; do
[?2004l[?2004h>   case "$1" in
[?2004l[?2004h>     --quiet)
[?2004l[?2004h>       shift
[?2004l[?2004h>       ;;
[?2004l[?2004h>     --bin)
[?2004l[?2004h>       bin="${2-}"
[?2004l[?2004h>       shift 2
[?2004l[?2004h>       ;;
[?2004l[?2004h>     --)
[?2004l[?2004h>       shift
[?2004l[?2004h>       break
[?2004l[?2004h>       ;;
[?2004l[?2004h>     *)
[?2004l[?2004h>       shift
[?2004l[?2004h>       ;;
[?2004l[?2004h>   esac
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> if [[ "$bin" != "mhre_native" ]]; then
[?2004l[?2004h>   echo "unsupported --bin $bin" >&2
[?2004l[?2004h>   exit 2
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> exe="/app/target/debug/mhre_native"
[?2004l[?2004h> if [[ ! -x "$exe" ]]; then
[?2004l[?2004h>   echo "native binary not found or not executable: $exe" >&2
[?2004l[?2004h>   exit 127
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> rev="${1-}"
[?2004l[?2004h> primary="${2-}"
[?2004l[?2004h> carry="${3-}"
[?2004l[?2004h> 
[?2004l[?2004h> if [[ -z "$rev" || -z "$primary" || -z "$carry" ]]; then
[?2004l[?2004h>   echo "usage: cargo run --bin mhre_native -- <rev> <primary> <carry>" >&2
[?2004l[?2004h>   exit 2
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Normalize old markers to new behavior.
[?2004l[?2004h> if [[ "$rev" == "old" ]]; then
[?2004l[?2004h>   rev="new"
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> exec "$exe" "$rev" "$primary" "$carry"
[?2004l[?2004h> SH
