[?2004l[?2004h> function k_c(a, b, c) {
[?2004l[?2004h>   // Factors are recomputed per row from that row's descriptor number (a)
[?2004l[?2004h>   // and position (b), with no cross-row caching.
[?2004l[?2004h>   // `c` is reserved for possible scenario-local state, but unused here.
