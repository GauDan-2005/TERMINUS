Sending keys: ["cat > a1/p.js <<'JS'\nconst { spawnSync } = require('child_process');\nconst { q_b } = require('../b2/q');\nconst { k_c } = require('../c3/r');\n\nfunction callNative(root, rev, primary, carry) {\n  // Keep invocation as `cargo run` (a shim is provided under /app/tools/cargo).\n  const env = { ...process.env, PATH: `${root}/tools:${process.env.PATH || ''}` };\n\n  const proc = spawnSync(\n    'cargo',\n    ['run', '--quiet', '--bin', 'mhre_native', '--', rev, String(primary), String(carry)],\n    { cwd: root, encoding: 'utf8', env }\n  );\n  if (proc.status !== 0) {\n    throw new Error(proc.stderr || proc.stdout || proc.error?.message || 'native worker failed');\n  }\n  return Number(String(proc.stdout).trim());\n}\n\nfunction f_a(a, b, c) {\n  let carry = 0;\n  const rows = [];\n  let acceptedOlder = true;\n  let finalCounter = 0;\n\n  const sumBases = a.cycles.reduce((acc, cycle) => acc + Number(cycle.base), 0);\n\n  for (let index = 0; index < a.cycles.length; index += 1) {\n    const cycle = a.cycles[index];\n\n    const deferred = q_b(cycle.deferred || [], index, c);\n    const factor = k_c(cycle.dep, index, c);\n\n    const nativeValue = callNative(b, cycle.native, cycle.base, carry);\n\n    // Older markers must normalize like newer ones; if they don't, mark unaccepted.\n    if (cycle.native === 'old' && nativeValue !== Number(cycle.base) + carry) {\n      acceptedOlder = false;\n    }\n\n    const rowValue = nativeValue + factor + deferred.reduce((acc, value) => acc + value, 0);\n\n    rows.push({ index, value: rowValue, factor, nativeValue, deferred });\n\n    // Each cycle's native row feeds the next.\n    carry = nativeValue;\n    finalCounter = nativeValue;\n  }\n\n  const dependencyTotal = rows.reduce((acc, row) => acc + row.factor, 0);\n  const healthy = acceptedOlder && finalCounter === sumBases;\n\n  return {\n    name: a.name,\n    rows,\n    finalCounter,\n    dependencyTotal,\n    acceptedOlder,\n    healthy\n  };\n}\n\nmodule.exports = { f_a };\nJS\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
