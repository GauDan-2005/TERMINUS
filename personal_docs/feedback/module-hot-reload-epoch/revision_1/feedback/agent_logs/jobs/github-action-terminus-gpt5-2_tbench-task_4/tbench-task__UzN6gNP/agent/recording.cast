[170.600102, "i", "cat > d4/s.js <<'JS'\nfunction m_e(records, meta) {\n  const recordCount = records.length;\n  const totalCounter = records.reduce((acc, rec) => acc + Number(rec.finalCounter), 0);\n  const dependencyTotal = records.reduce((acc, rec) => acc + Number(rec.dependencyTotal), 0);\n  const rowTotal = records.reduce(\n    (acc, rec) => acc + rec.rows.reduce((inner, item) => inner + Number(item.value), 0),\n    0\n  );\n  const healthyCount = records.filter((rec) => rec.healthy).length;\n  const status = healthyCount === recordCount ? 'healthy' : 'stale';\n\n  return {\n    source: meta.source,\n    recordCount,\n    totalCounter,\n    dependencyTotal,\n    rowTotal,\n    healthyCount,\n    status\n  };\n}\n\nfunction view_e(a) {\n  return a.map((row) => row.name).join(',');\n}\n\nmodule.exports = { m_e, view_e };\nJS\n"]
[170.600245, "o", "cat > d4/s.js <<'JS'\r\n"]
