[30.504355, "o", "pub fn r_d(a: &str, b: i64, c: i64) -> i64 {\r\n    match a {\r\n        \"old\" => b,\r\n        \"new\" => b + c,\r\n        _ => b,\r\n    }\r\n}\r\n\r\n"]
[30.504429, "o", "pub fn aux_r(a: i64) -> i64 {\r\n    a * 2\r\n}\r\n"]
[30.504516, "o", "src/native/src/main.rs\r\n"]
[30.505537, "o", "use std::env;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().collect();\r\n    if args.len() != 4 {\r\n        eprintln!(\"usage: mhre_native <rev> <primary> <carry>\");\r\n        std::process::exit(2);\r\n"]
[30.505682, "o", "    }\r\n    let rev = &args[1];\r\n    let primary: i64 = args[2].parse().expect(\"primary number\");\r\n    let carry: i64 = args[3].parse().expect(\"carry number\");\r\n    println!(\"{}\", mhre_native::r_d(rev, primary, carry));\r\n}\r\n"]
[30.506145, "o", "src/native/src/view.rs\r\n"]
[30.507783, "o", "pub fn panel_v(a: &[i64]) -> String {\r\n    a.iter().map(|v| v.to_string()).collect::<Vec<_>>().join(\",\")\r\n}\r\n\u001b[?2004hroot@43ad176e7096:/app# "]
