[168.479281, "i", "cat > b2/q.js <<'JS'\nfunction q_b(a, b, c) {\n  // Deferred values listed on a cycle belong to that same cycle's row.\n  // Keep the state object available for other helpers, but do not shift\n  // values into the next slot.\n  const label = `slot-${b}`;\n  c[label] = (c[label] || []).concat(a);\n  return (c[label] || []).slice().sort((left, right) => left - right);\n}\n\nfunction scan_b(a) {\n  return Object.keys(a).sort();\n}\n\nmodule.exports = { q_b, scan_b };\nJS\n"]
