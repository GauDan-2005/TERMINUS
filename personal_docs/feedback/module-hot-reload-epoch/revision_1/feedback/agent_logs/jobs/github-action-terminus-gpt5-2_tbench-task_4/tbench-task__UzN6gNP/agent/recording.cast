[147.470132, "o", "let saved = null;\r\n\r\nfunction k_c(a, b, c) {\r\n  if (saved === null) {\r\n    saved = Number(a);\r\n  }\r\n  return saved + b;\r\n}\r\n\r\nfunction lens_c(a) {\r\n"]
