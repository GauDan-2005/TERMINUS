[147.224092, "o", "\r\n"]
[147.224153, "o", "\u001b[?2004l\r"]
[147.225591, "o", "# Scenario format\r\n\r\nScenario entries contain a label plus a list of cycle objects. A cycle has a base number, a descriptor revision, a descriptor number, a native revision marker, and optional deferred numbers that participate in row production. The scenario files are inputs, not expected output.\r\n"]
[147.225871, "o", "\u001b[?2004h"]
[147.226008, "o", "root@43ad176e7096:/app# "]
[147.33973, "i", "sed -n '1,200p' b2/q.js\n"]
[147.34005, "o", "sed -n '1,200p' b2/q.js"]
[147.340407, "o", "\r\n\u001b[?2004l\r"]
[147.342047, "o", "function q_b(a, b, c) {\r\n"]
[147.342178, "o", "  const label = `slot-${b}`;\r\n"]
[147.342266, "o", "  c[label] = (c[label] || []).concat(a);\r\n"]
[147.342343, "o", "  const next = `slot-${b + 1}`;\r\n  const visible = c[next] || [];\r\n  c[next] = [];\r\n  return visible.slice().sort((left, right) => left - right);\r\n}\r\n"]
[147.342436, "o", "\r\nfunction scan_b(a) {\r\n"]
[147.342581, "o", "  return Object.keys(a).sort();\r\n}\r\n\r\nmodule.exports = { q_b, scan_b };\r\n"]
[147.342693, "o", "\u001b[?2004h"]
[147.342713, "o", "root@43ad176e7096:/app# "]
[147.467613, "i", "sed -n '1,200p' c3/r.js\n"]
