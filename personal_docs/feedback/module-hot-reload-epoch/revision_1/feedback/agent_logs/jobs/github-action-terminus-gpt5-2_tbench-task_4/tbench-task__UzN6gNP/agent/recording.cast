[168.983921, "i", "cat > c3/r.js <<'JS'\nfunction k_c(a, b, c) {\n  // Factors are recomputed per row from that row's descriptor number (a)\n  // and position (b), with no cross-row caching.\n  // `c` is reserved for possible scenario-local state, but unused here.\n  return Number(a) + Number(b);\n}\n\nfunction lens_c(a) {\n  return String(a).length;\n}\n\nmodule.exports = { k_c, lens_c };\nJS\n"]
