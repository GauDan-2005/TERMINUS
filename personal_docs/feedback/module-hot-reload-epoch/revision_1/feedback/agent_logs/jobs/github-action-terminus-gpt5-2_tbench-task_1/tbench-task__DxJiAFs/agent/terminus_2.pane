src/core/e5/epsilon.js
function shape_e(a, b, c) {
  return { title: String(a), width: Number(b || 0), tags: Array.isArray(c) ? c.slice() : [] };
}

function print_e(a) {
  return `${a.title}:${a.width}`;
}

module.exports = { shape_e, print_e };
src/core/f6/zeta.js
function order_f(a) {
  return a.slice().sort((left, right) => String(left).localeCompare(String(right)));
}

function merge_f(a, b) {
  return order_f([].concat(a || [], b || []));
}

module.exports = { order_f, merge_f };
src/core/g7/theta.js
function meter_g(a) {
  return a.reduce((acc, value) => acc + Number(value || 0), 0);
}

function average_g(a) {
  return a.length === 0 ? 0 : meter_g(a) / a.length;
}

module.exports = { meter_g, average_g };
src/core/h8/iota.js
function clone_h(a) {
  return JSON.parse(JSON.stringify(a));
}

function stamp_h(a, b) {
  const copy = clone_h(a);
  copy.marker = b;
  return copy;
}

module.exports = { clone_h, stamp_h };
src/native/README.md
# Native component

The native component accepts three command-line values and returns a single integer. It stays deliberately small so JavaScript callers can invoke it through cargo during local development.
src/native/src/lib.rs
pub fn r_d(a: &str, b: i64, c: i64) -> i64 {
    match a {
        "old" => b,
        "new" => b + c,
        _ => b,
    }
}

pub fn aux_r(a: i64) -> i64 {
    a * 2
}
src/native/src/main.rs
use std::env;

fn main() {
    let args: Vec<String> = env::args().collect();
    if args.len() != 4 {
        eprintln!("usage: mhre_native <rev> <primary> <carry>");
        std::process::exit(2);
    }
    let rev = &args[1];
    let primary: i64 = args[2].parse().expect("primary number");
    let carry: i64 = args[3].parse().expect("carry number");
    println!("{}", mhre_native::r_d(rev, primary, carry));
}
src/native/src/view.rs
pub fn panel_v(a: &[i64]) -> String {
    a.iter().map(|v| v.to_string()).collect::<Vec<_>>().join(",")
}
