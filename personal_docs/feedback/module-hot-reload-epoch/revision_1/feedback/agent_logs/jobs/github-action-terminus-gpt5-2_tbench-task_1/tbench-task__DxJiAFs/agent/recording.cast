[945.357031, "i", "python3 - <<'PY'\nimport json\np='/app/outcome/report.json'\nwith open(p) as f: data=json.load(f)\nagg=data['aggregate']\nprint('aggregate:', {k:agg.get(k) for k in ['source','recordCount','totalCounter','dependencyTotal','rowTotal','healthyCount','status']})\nfor r in data['records']:\n    name=r.get('scenario') or r.get('name')\n    print(name,'finalCounter',r['finalCounter'],'acceptedOlder',r['acceptedOlder'],'healthy',r['healthy'],'dependencyTotal',r['dependencyTotal'])\n    for row in r['rows']:\n        print('  row',row['index'],'nativeValue',row['nativeValue'],'factor',row['factor'],'deferred',row['deferred'],'value',row['value'])\nPY\n"]
