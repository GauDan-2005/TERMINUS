[543.778445, "i", "python3 - <<'PY'\nimport json\np='/app/outcome/report.json'\nwith open(p) as f: data=json.load(f)\nagg=data.get('aggregate',{})\nrecs=data.get('records',[])\nprint('aggregate:', agg)\nprint('recordCount:', len(recs))\nfor r in recs:\n    name=r.get('scenario') or r.get('name')\n    rows=r.get('rows') or []\n    print('\\n',name, 'healthy=',r.get('healthy'),'acceptedOlder=',r.get('acceptedOlder'),'finalCounter=',r.get('finalCounter'),'dependencyTotal=',r.get('dependencyTotal'),'rows=',len(rows))\n    for row in rows:\n        print('  row', row.get('index'), 'value', row.get('value'), 'factor', row.get('factor'), 'nativeValue', row.get('nativeValue'), 'deferred', row.get('deferred'))\nPY\n"]
