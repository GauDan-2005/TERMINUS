[1013.686352, "i", "python3 - <<'PY'\nimport json\np='/app/outcome/report.json'\nwith open(p) as f: data=json.load(f)\nreq_agg=['source','recordCount','totalCounter','dependencyTotal','rowTotal','healthyCount','status']\nprint('aggregate missing:', [k for k in req_agg if k not in data.get('aggregate',{})])\nfor r in data.get('records',[]):\n    missing=[k for k in ['rows','finalCounter','dependencyTotal','acceptedOlder','healthy'] if k not in r]\n    if 'scenario' not in r and 'name' not in r:\n        missing.append('scenario/name')\n    if missing:\n        print('record missing', missing)\n    for row in r.get('rows',[]):\n        rm=[k for k in ['index','value','factor','nativeValue','deferred'] if k not in row]\n        if row.get('deferred')!=sorted(row.get('deferred',[])):\n            rm.append('deferred_not_sorted')\n        if rm:\n            print('row issues', r.get('name') or r.get('scenario'), row.get('index'), rm)\nPY\n"]
