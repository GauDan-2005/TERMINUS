[140.3326, "o", "function order_f(a) {\r\n  return a.slice().sort((left, right) => String(left).localeCompare(String(right)));\r\n}\r\n\r\nfunction merge_f(a, b) {\r\n  return order_f([].concat(a || [], b || []));\r\n}\r\n"]
[140.33263, "o", "\r\nmodule.exports = { order_f, merge_f };\r\n"]
[140.332798, "o", "src/core/g7/theta.js\r\n"]
[140.333698, "o", "function meter_g(a) {\r\n  return a.reduce((acc, value) => acc + Number(value || 0), 0);\r\n}\r\n\r\n"]
[140.333723, "o", "function average_g(a) {\r\n  return a.length === 0 ? 0 : meter_g(a) / a.length;\r\n}\r\n\r\n"]
[140.333736, "o", "module.exports = { meter_g, average_g };\r\n"]
[140.334168, "o", "src/core/h8/iota.js\r\n"]
[140.33512, "o", "function clone_h(a) {\r\n  return JSON.parse(JSON.stringify(a));\r\n}\r\n\r\nfunction stamp_h(a, b) {\r\n  const copy = clone_h(a);\r\n  copy.marker = b;\r\n  return copy;\r\n}"]
[140.335223, "o", "\r\n\r\nmodule.exports = { clone_h, stamp_h };\r\n"]
[140.335318, "o", "src/native/README.md\r\n"]
[140.336301, "o", "# Native component\r\n\r\nThe native component accepts three command-line values and returns a single integer. It stays deliberately small so JavaScript callers can invoke it through cargo during local development.\r\n"]
[140.336467, "o", "src/native/src/lib.rs\r\n"]
[140.337371, "o", "pub fn r_d(a: &str, b: i64, c: i64) -> i64 {\r\n    match a {\r\n        \"old\" => b,\r\n        \"new\" => b + c,\r\n        _ => b,\r\n"]
[140.337517, "o", "    }\r\n}\r\n\r\npub fn aux_r(a: i64) -> i64 {\r\n    a * 2\r\n}\r\n"]
[140.337597, "o", "src/native/src/main.rs\r\n"]
[140.338507, "o", "use std::env;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().collect();\r\n    if args.len() != 4 {\r\n        eprintln!(\"usage: mhre_native <rev> <primary> <carry>\");\r\n        std::process::exit(2);\r\n    }\r\n    let rev = &args[1];\r\n    let primary: i64 = args[2].parse().expect(\"primary number\");\r\n"]
[140.338623, "o", "    let carry: i64 = args[3].parse().expect(\"carry number\");\r\n    println!(\"{}\", mhre_native::r_d(rev, primary, carry));\r\n}\r\n"]
[140.338707, "o", "src/native/src/view.rs\r\n"]
[140.339611, "o", "pub fn panel_v(a: &[i64]) -> String {\r\n    a.iter().map(|v| v.to_string()).collect::<Vec<_>>().join(\",\")\r\n}\r\n"]
