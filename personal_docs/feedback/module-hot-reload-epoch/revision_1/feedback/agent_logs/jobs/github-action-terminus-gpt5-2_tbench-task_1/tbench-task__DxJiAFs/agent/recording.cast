[605.15846, "o", "\r\n\u001b[?2004l\r"]
[605.159396, "o", "let saved = null;\r\n\r\nfunction k_c(a, b, c) {\r\n  if (saved === null) {\r\n"]
[605.159465, "o", "    saved = Number(a);\r\n  }\r\n  return saved + b;\r\n}\r\n\r\nfunction lens_c(a) {\r\n  return String(a).length;\r\n}\r\n\r\nmodule.exports = { k_c, lens_c };\r\n"]
[605.159866, "o", "\u001b[?2004hroot@48d0f83bfd0b:/app# "]
[605.277818, "i", "sed -n '1,200p' d4/s.js\n"]
