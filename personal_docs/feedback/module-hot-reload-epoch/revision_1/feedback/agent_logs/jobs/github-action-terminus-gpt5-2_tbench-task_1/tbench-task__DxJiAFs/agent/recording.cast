[605.04247, "o", "sed -n '1,200p' b2/q.js\r\n\u001b[?2004l\r"]
[605.043178, "o", "function q_b(a, b, c) {\r\n  const label = `slot-${b}`;\r\n"]
[605.043292, "o", "  c[label] = (c[label] || []).concat(a);\r\n  const next = `slot-${b + 1}`;\r\n  const visible = c[ne"]
[605.043317, "o", "xt] || [];\r\n  c[next] = [];\r\n  return visible.slice().sort((left, right) => left - right);\r\n}\r\n\r\nfunction scan_b(a) {\r\n  return Object.keys(a).sort();\r\n"]
[605.043332, "o", "}\r\n\r\nmodule.exports = { q_b, scan_b };\r\n"]
[605.045538, "o", "\u001b[?2004hroot@48d0f83bfd0b:/app# "]
[605.158028, "i", "sed -n '1,200p' c3/r.js\n"]
