[824.709979, "i", "cat > b2/q.js <<'EOF'\nfunction q_b(a, b, c) {\n  // Deferred values belong to the cycle that declares them.\n  // Keep the state object for callers that want per-scenario scratch state,\n  // but do not shift values into the next cycle.\n  const label = `slot-${b}`;\n  c[label] = (c[label] || []).concat(a || []);\n  return (a || []).slice().sort((left, right) => left - right);\n}\n\nfunction scan_b(a) {\n  return Object.keys(a).sort();\n}\n\nmodule.exports = { q_b, scan_b };\nEOF\n"]
