[72.314212, "i", "python3 - <<'PY'\nimport json\np='/app/outcome/report.json'\nwith open(p) as f: data=json.load(f)\nprint('top keys:', sorted(data.keys()))\nagg=data.get('aggregate') or data.get('folded') or {}\nrecs=data.get('records') or []\nprint('recordCount:', len(recs))\nprint('aggregate:', {k:agg.get(k) for k in ['source','recordCount','totalCounter','dependencyTotal','rowTotal','healthyCount','status'] if k in agg})\n# show per-record summary\nfor r in recs:\n    print('\\nSCENARIO', r.get('scenario') or r.get('name'))\n    print('healthy', r.get('healthy'), 'acceptedOlder', r.get('acceptedOlder'), 'finalCounter', r.get('finalCounter'), 'dependencyTotal', r.get('dependencyTotal'))\n    rows=r.get('rows') or []\n    print('rows:', len(rows))\n    if rows:\n        last=rows[-1]\n        print('last row:', {k:last.get(k) for k in ['index','value','factor','nativeValue']})\n        print('last deferred:', last.get('deferred'))\nPY\n"]
