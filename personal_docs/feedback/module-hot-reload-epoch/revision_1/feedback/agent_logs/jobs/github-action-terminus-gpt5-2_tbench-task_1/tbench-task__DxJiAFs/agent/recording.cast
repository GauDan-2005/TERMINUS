[824.828853, "i", "cat > c3/r.js <<'EOF'\nfunction k_c(a, b, c) {\n  // Factors are recomputed per row from that row's descriptor and position.\n  // Do not cache across rows or scenarios.\n  return Number(a) + b;\n}\n\nfunction lens_c(a) {\n  return String(a).length;\n}\n\nmodule.exports = { k_c, lens_c };\nEOF\n"]
