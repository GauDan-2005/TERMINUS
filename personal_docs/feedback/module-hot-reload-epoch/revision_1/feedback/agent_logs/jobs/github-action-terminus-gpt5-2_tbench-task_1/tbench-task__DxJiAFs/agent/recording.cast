[749.129706, "i", "python3 - <<'PY'\nimport json\np='/app/outcome/report.json'\nwith open(p) as f: data=json.load(f)\nagg=data['aggregate']\nprint('aggregate:', {k:agg.get(k) for k in ['source','recordCount','totalCounter','dependencyTotal','rowTotal','healthyCount','status']})\nfor r in data['records']:\n    name=r.get('scenario') or r.get('name')\n    base_sum=sum(c['base'] for c in __import__('json').load(open('/app/fixtures/scenarios.json'))['scenarios'] if c['name']==name for c in c['cycles'])\n    print(name,'finalCounter',r['finalCounter'],'acceptedOlder',r['acceptedOlder'],'healthy',r['healthy'],'dependencyTotal',r['dependencyTotal'],'rows',len(r['rows']))\n    for row in r['rows']:\n        d=row.get('deferred')\n        if d!=sorted(d):\n            print('  deferred not sorted at row',row['index'],d)\nPY\n"]
