[?2004l[?2004h> import json
[?2004l[?2004h> obj=json.load(open('outcome/report.json'))
[?2004l[?2004h> recs=obj['records']
[?2004l[?2004h> agg=obj['aggregate']
[?2004l[?2004h> calc={
[?2004l[?2004h>   'source': agg.get('source'),
[?2004l[?2004h>   'recordCount': len(recs),
[?2004l[?2004h>   'totalCounter': sum(r['finalCounter'] for r in recs),
[?2004l[?2004h>   'dependencyTotal': sum(r['dependencyTotal'] for r in recs),
[?2004l[?2004h>   'rowTotal': sum(row['value'] for r in recs for row in r['rows']),
[?2004l[?2004h>   'healthyCount': sum(1 for r in recs if r['healthy']),
[?2004l[?2004h>   'status': 'healthy' if all(r['healthy'] for r in recs) else 'stale'
[?2004l[?2004h> }
[?2004l[?2004h> print('aggregate_matches=', calc==agg)
[?2004l[?2004h> if calc!=agg:
[?2004l[?2004h>   print('expected', calc)
[?2004l[?2004h>   print('actual  ', agg)
[?2004l[?2004h> # check deferred sorted
[?2004l[?2004h> ok=True
[?2004l[?2004h> for r in recs:
[?2004l[?2004h>   for row in r['rows']:
[?2004l[?2004h>     d=row.get('deferred',[])
[?2004l[?2004h>     if d!=sorted(d):
[?2004l[?2004h>       ok=False
[?2004l[?2004h> print('deferred_sorted=', ok)
