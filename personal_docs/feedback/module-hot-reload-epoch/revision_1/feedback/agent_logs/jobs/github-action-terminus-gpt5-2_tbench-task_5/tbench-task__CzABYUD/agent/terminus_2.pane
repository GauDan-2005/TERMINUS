src/native/README.md
# Native component

The native component accepts three command-line values and returns a single integer. It stays deliberately small so JavaScript callers can invoke it through cargo during local development.
src/native/src/lib.rs
pub fn r_d(a: &str, b: i64, c: i64) -> i64 {
    match a {
        "old" => b,
        "new" => b + c,
        _ => b,
    }
}

pub fn aux_r(a: i64) -> i64 {
    a * 2
}
src/native/src/main.rs
use std::env;

fn main() {
    let args: Vec<String> = env::args().collect();
    if args.len() != 4 {
        eprintln!("usage: mhre_native <rev> <primary> <carry>");
        std::process::exit(2);
    }
    let rev = &args[1];
    let primary: i64 = args[2].parse().expect("primary number");
    let carry: i64 = args[3].parse().expect("carry number");
    println!("{}", mhre_native::r_d(rev, primary, carry));
}
src/native/src/view.rs
pub fn panel_v(a: &[i64]) -> String {
    a.iter().map(|v| v.to_string()).collect::<Vec<_>>().join(",")
}
