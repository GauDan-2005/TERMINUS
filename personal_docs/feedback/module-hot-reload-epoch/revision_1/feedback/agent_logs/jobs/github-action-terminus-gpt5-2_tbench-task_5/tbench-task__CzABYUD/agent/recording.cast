[273.079752, "i", "python3 - <<'PY'\nimport json\nobj=json.load(open('outcome/report.json'))\nrecs=obj['records']\nagg=obj['aggregate']\ncalc={\n  'source': agg.get('source'),\n  'recordCount': len(recs),\n  'totalCounter': sum(r['finalCounter'] for r in recs),\n  'dependencyTotal': sum(r['dependencyTotal'] for r in recs),\n  'rowTotal': sum(row['value'] for r in recs for row in r['rows']),\n  'healthyCount': sum(1 for r in recs if r['healthy']),\n  'status': 'healthy' if all(r['healthy'] for r in recs) else 'stale'\n}\nprint('aggregate_matches=', calc==agg)\nif calc!=agg:\n  print('expected', calc)\n  print('actual  ', agg)\n# check deferred sorted\nok=True\nfor r in recs:\n  for row in r['rows']:\n    d=row.get('deferred',[])\n    if d!=sorted(d):\n      ok=False\nprint('deferred_sorted=', ok)\nPY\n"]
