[236.452141, "i", "cat > d4/s.js <<'EOF'\nfunction m_e(a, b) {\n  const totalCounter = a.reduce((acc, row) => acc + row.finalCounter, 0);\n  const dependencyTotal = a.reduce((acc, row) => acc + row.dependencyTotal, 0);\n  const rowTotal = a.reduce(\n    (acc, row) => acc + row.rows.reduce((inner, item) => inner + item.value, 0),\n    0\n  );\n  const healthyCount = a.filter((row) => row.healthy).length;\n  const status = healthyCount === a.length ? 'healthy' : 'stale';\n  return {\n    source: b.source,\n    recordCount: a.length,\n    totalCounter,\n    dependencyTotal,\n    rowTotal,\n    healthyCount,\n    status\n  };\n}\n\nfunction view_e(a) {\n  return a.map((row) => row.name).join(',');\n}\n\nmodule.exports = { m_e, view_e };\nEOF\n"]
