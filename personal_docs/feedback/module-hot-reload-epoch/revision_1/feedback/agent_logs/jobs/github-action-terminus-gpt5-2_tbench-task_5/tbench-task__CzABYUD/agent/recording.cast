[236.331976, "i", "cat > c3/r.js <<'EOF'\nfunction k_c(a, b, c) {\n  // Descriptor factors are recomputed per row from that row's descriptor\n  // number and position; no cross-row or cross-scenario caching.\n  return Number(a) + b;\n}\n\nfunction lens_c(a) {\n  return String(a).length;\n}\n\nmodule.exports = { k_c, lens_c };\nEOF\n"]
[236.332304, "o", "cat > c3/r.js <<'EOF'\r\n"]
