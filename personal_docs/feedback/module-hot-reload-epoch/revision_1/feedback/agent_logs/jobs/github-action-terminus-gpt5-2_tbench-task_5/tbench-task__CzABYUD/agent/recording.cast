[236.215435, "i", "cat > b2/q.js <<'EOF'\nfunction q_b(a, b, c) {\n  // Deferred numbers listed on a cycle belong to that same cycle's row.\n  // We still track them in the provided state bag for introspection.\n  const label = `slot-${b}`;\n  c[label] = (c[label] || []).concat(a || []);\n  return (a || []).slice().sort((left, right) => left - right);\n}\n\nfunction scan_b(a) {\n  return Object.keys(a).sort();\n}\n\nmodule.exports = { q_b, scan_b };\nEOF\n"]
[236.216285, "o", "cat > b2/q.js <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> function q_b(a, b, c) {\r\n\u001b[?2004l\r\u001b[?2004h>   // Deferred numbers listed on a cycle belong to that same cycle's row.\r\n\u001b[?2004l\r"]
[236.216698, "o", "\u001b[?2004h>   // We still track them in the provided state bag for introspection.\r\n\u001b[?2004l\r"]
[236.216725, "o", "\u001b[?2004h>   const label = `slot-${b}`;\r\n\u001b[?2004l\r\u001b[?2004h"]
[236.2168, "o", "> "]
[236.217319, "o", "  c[label] = (c[label] || []).concat(a || []);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[236.217541, "o", "  return (a || []).slice().sort((left, right) => left - right);\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n"]
[236.21772, "o", "\u001b[?2004l\r"]
[236.217752, "o", "\u001b[?2004h"]
[236.217762, "o", "> "]
[236.217775, "o", "\r\n\u001b[?2004l\r"]
