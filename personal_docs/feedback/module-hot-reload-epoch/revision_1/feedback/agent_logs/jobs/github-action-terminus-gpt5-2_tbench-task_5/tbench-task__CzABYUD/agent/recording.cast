[236.699824, "i", "cat > src/native/src/lib.rs <<'EOF'\npub fn r_d(a: &str, b: i64, c: i64) -> i64 {\n    match a {\n        // Older revision markers normalize like newer ones: carried state must\n        // be incorporated into the produced native row.\n        \"old\" => b + c,\n        \"new\" => b + c,\n        _ => b,\n    }\n}\n\npub fn aux_r(a: i64) -> i64 {\n    a * 2\n}\nEOF\n"]
