[179.710146, "o", "src/native/README.md\r\n"]
[179.71152, "o", "# Native component\r\n\r\nThe native component accepts three command-line values and returns a single integer. It stays deliberately small so JavaScript callers can invoke it through cargo during local development.\r\n"]
[179.711665, "o", "src/native/src/lib.rs\r\n"]
[179.712978, "o", "pub fn r_d(a: &str, b: i64, c: i64) -> i64 {\r\n    match a {\r\n        \"old\" => b,\r\n        \"new\" => b + c,\r\n        _ => b,\r\n    }\r\n}\r\n\r\n"]
[179.713079, "o", "pub fn aux_r(a: i64) -> i64 {\r\n    a * 2\r\n}\r\n"]
[179.713158, "o", "src/native/src/main.rs\r\n"]
[179.714006, "o", "use std::env;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().collect();\r\n    if args.len() != 4 {\r\n        eprintln!(\"usage: mhre_native <rev> <primary> <carry>\");\r\n        std::process::exit(2);"]
[179.714037, "o", "\r\n    }\r\n    let rev = &args[1];\r\n    let primary: i64 = args[2].parse().expect(\"primary number\");\r\n    let carry: i64 = args[3].parse().expect(\"carry number\");\r\n"]
[179.714054, "o", "    println!(\"{}\", mhre_native::r_d(rev, primary, carry));\r\n}\r\n"]
[179.714173, "o", "src/native/src/view.rs\r\n"]
[179.714959, "o", "pub fn panel_v(a: &[i64]) -> String {\r\n    a.iter().map(|v| v.to_string()).collect::<Vec<_>>().join(\",\")\r\n}\r\n"]
