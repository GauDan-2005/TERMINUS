[?2004luse std::env;

fn main() {
    let args: Vec<String> = env::args().collect();
    if args.len() != 4 {
        eprintln!("usage: mhre_native <rev> <primary> <carry>");
        std::process::exit(2);
    }
    let rev = &args[1];
    let primary: i64 = args[2].parse().expect("primary number");
    let carry: i64 = args[3].parse().expect("carry number");
    println!("{}", mhre_native::r_d(rev, primary, carry));
}
[?2004hroot@9972658a2e17:/app# cat /app/src/native/src/lib.rs
[?2004lpub fn r_d(a: &str, b: i64, c: i64) -> i64 {
    match a {
        "old" => b,
        "new" => b + c,
        _ => b,
    }
}

pub fn aux_r(a: i64) -> i64 {
    a * 2
}
