[?2004lconst { spawnSync } = require('child_process');
const { q_b } = require('../b2/q');
const { k_c } = require('../c3/r');

function hasCargo() {
  const probe = spawnSync('cargo', ['--version'], { encoding: 'utf8' });
  return probe.status === 0;
}

function callNative(root, rev, primary, carry) {
  const args = [rev, String(primary), String(carry)];
  const proc = hasCargo()
    ? spawnSync('cargo', ['run', '--quiet', '--bin', 'mhre_native', '--', ...args], {
        cwd: root,
        encoding: 'utf8'
      })
    : spawnSync(`${root}/target/debug/mhre_native`, args, {
        cwd: root,
        encoding: 'utf8'
      });

  if (proc.status !== 0) {
    throw new Error(proc.stderr || proc.stdout || 'native worker failed');
  }
  return Number(proc.stdout.trim());
}

function f_a(a, b, c) {
  let carry = 0;
  const rows = [];
  let accepted = true;
  let lastNative = 0;
  const sumBases = a.cycles.reduce((acc, cycle) => acc + Number(cycle.base || 0), 0);

  for (let index = 0; index < a.cycles.length; index += 1) {
    const cycle = a.cycles[index];

    const owned = q_b(cycle.deferred || [], index, c);
    const factor = k_c(cycle.dep, index, c);

    const nativeValue = callNative(b, cycle.native, cycle.base, carry);

    // Older revision markers must normalize like newer ones: incorporate carry.
    const expectedNative = Number(cycle.base || 0) + Number(carry || 0);
    if (cycle.native === 'old' && nativeValue !== expectedNative) {
      accepted = false;
    }

    const rowValue = nativeValue + factor + owned.reduce((acc, value) => acc + value, 0);

    rows.push({ index, value: rowValue, factor, nativeValue, deferred: owned });

    // Each cycle's native row feeds the next cycle.
    carry = nativeValue;
    lastNative = nativeValue;
  }

  const healthy = accepted && lastNative === sumBases;

  return {
    name: a.name,
    rows,
    finalCounter: lastNative,
    dependencyTotal: rows.reduce((acc, row) => acc + row.factor, 0),
    acceptedOlder: accepted,
    healthy
  };
}

module.exports = { f_a };
