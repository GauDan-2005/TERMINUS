[?2004lpub fn r_d(a: &str, b: i64, c: i64) -> i64 {
    // Normalize older revision markers to the current behavior: the carried
    // state participates in the produced native value.
    match a {
        "old" => b + c,
        "new" => b + c,
        _ => b + c,
    }
}

pub fn aux_r(a: i64) -> i64 {
    a * 2
}
