[116.805226, "i", "cat > a1/p.js <<'EOF'\nconst { spawnSync } = require('child_process');\nconst { q_b } = require('../b2/q');\nconst { k_c } = require('../c3/r');\n\nfunction hasCargo() {\n  const probe = spawnSync('cargo', ['--version'], { encoding: 'utf8' });\n  return probe.status === 0;\n}\n\nfunction callNative(root, rev, primary, carry) {\n  const args = [rev, String(primary), String(carry)];\n  const proc = hasCargo()\n    ? spawnSync('cargo', ['run', '--quiet', '--bin', 'mhre_native', '--', ...args], {\n        cwd: root,\n        encoding: 'utf8'\n      })\n    : spawnSync(`${root}/target/debug/mhre_native`, args, {\n        cwd: root,\n        encoding: 'utf8'\n      });\n\n  if (proc.status !== 0) {\n    throw new Error(proc.stderr || proc.stdout || 'native worker failed');\n  }\n  return Number(proc.stdout.trim());\n}\n\nfunction f_a(a, b, c) {\n  let carry = 0;\n  const rows = [];\n  let accepted = true;\n  let lastNative = 0;\n  const sumBases = a.cycles.reduce((acc, cycle) => acc + Number(cycle.base || 0), 0);\n\n  for (let index = 0; index < a.c"]
[116.806798, "i", "ycles.length; index += 1) {\n    const cycle = a.cycles[index];\n\n    const owned = q_b(cycle.deferred || [], index, c);\n    const factor = k_c(cycle.dep, index, c);\n\n    const nativeValue = callNative(b, cycle.native, cycle.base, carry);\n\n    // Older revision markers must normalize like newer ones: incorporate carry.\n    const expectedNative = Number(cycle.base || 0) + Number(carry || 0);\n    if (cycle.native === 'old' && nativeValue !== expectedNative) {\n      accepted = false;\n    }\n\n    const rowValue = nativeValue + factor + owned.reduce((acc, value) => acc + value, 0);\n\n    rows.push({ index, value: rowValue, factor, nativeValue, deferred: owned });\n\n    // Each cycle's native row feeds the next cycle.\n    carry = nativeValue;\n    lastNative = nativeValue;\n  }\n\n  const healthy = accepted && lastNative === sumBases;\n\n  return {\n    name: a.name,\n    rows,\n    finalCounter: lastNative,\n    dependencyTotal: rows.reduce((acc, row) => acc + row.factor, 0),\n    acceptedOlder: accepted,\n    healthy\n  };\n}\n\nmodu"]
