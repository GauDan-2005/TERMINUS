[14.314575, "o", "function stamp_h(a, b) {\r\n  const copy = clone_h(a);\r\n  copy.marker = b;\r\n  return copy;\r\n}\r\n\r\nmodule.exports = { clone_h, stamp_h };\r\n"]
[14.314692, "o", "src/native/README.md\r\n"]
[14.315336, "o", "# Native component\r\n\r\nThe native component accepts three command-line values and returns a single integer. It stays deliberately small so JavaScript callers can invoke it through cargo during local development.\r\n"]
[14.315464, "o", "src/native/src/lib.rs\r\n"]
[14.316119, "o", "pub fn r_d(a: &str, b: i64, c: i64) -> i64 {\r\n    match a {\r\n        \"old\" => b,\r\n        \"new\" => b + c,\r\n        _ => b,\r\n"]
[14.316191, "o", "    }\r\n}\r\n\r\npub fn aux_r(a: i64) -> i64 {\r\n    a * 2\r\n"]
[14.316217, "o", "}\r\n"]
[14.316347, "o", "src/native/src/main.rs\r\n"]
[14.317002, "o", "use std::env;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().collect();\r\n    if args.len() != 4 {\r\n        eprintln!(\"usage: mhre_native <rev> <primary> <carry>\");\r\n        std::process::exit(2);\r\n"]
[14.317026, "o", "    }\r\n    let rev = &args[1];\r\n    let primary: i64 = args[2].parse().expect(\"primary number\");\r\n    let carry: i64 = args[3].parse().expect(\"carry number\");\r\n    println!(\"{}\", mhre_native::r_d(rev, primary, carry));\r\n}\r\n"]
[14.317144, "o", "src/native/src/view.rs\r\n"]
[14.3178, "o", "pub fn panel_v(a: &[i64]) -> String {\r\n    a.iter().map(|v| v.to_string()).collect::<Vec<_>>().join(\",\")\r\n}\r\n"]
