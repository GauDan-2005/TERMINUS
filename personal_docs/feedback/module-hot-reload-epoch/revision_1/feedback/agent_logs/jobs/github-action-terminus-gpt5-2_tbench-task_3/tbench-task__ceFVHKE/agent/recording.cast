[90.5908, "o", "\u001b[?2004h"]
[90.590819, "o", "> "]
[90.590953, "o", "  const rows = [];\r\n\u001b[?2004l\r"]
[90.591072, "o", "\u001b[?2004h> "]
[90.591192, "o", "  let accepted = true;\r\n\u001b[?2004l\r"]
[90.591214, "o", "\u001b[?2004h> "]
[90.591441, "o", "  for (let index = 0; index < a.cycles.length; index += 1) {\r\n\u001b[?2004l\r"]
[90.59149, "o", "\u001b[?2004h"]
[90.591532, "o", "> "]
[90.591627, "o", "    const cycle = a.cycles[index];\r\n\u001b[?2004l\r"]
[90.591751, "o", "\u001b[?2004h> "]
[90.591949, "o", "    const owned = q_b(cycle.deferred || [], index, c);\r\n\u001b[?2004l\r"]
[90.592053, "o", "\u001b[?2004h> "]
[90.592207, "o", "    const factor = k_c(cycle.dep, index, c);\r\n\u001b[?2004l\r"]
[90.592297, "o", "\u001b[?2004h> "]
[90.592518, "o", "    const nativeValue = callNative(b, cycle.native, cycle.base, carry);\r\n\u001b[?2004l\r"]
[90.592599, "o", "\u001b[?2004h> "]
[90.592856, "o", "    const rowValue = nativeValue + factor + owned.reduce((acc, value) => acc + value, 0);\r\n\u001b[?2004l\r"]
[90.592878, "o", "\u001b[?2004h"]
[90.592932, "o", "> "]
[90.593144, "o", "    if (cycle.native === 'old' && nativeValue < carry + cycle.base) {\r\n\u001b[?2004l\r"]
