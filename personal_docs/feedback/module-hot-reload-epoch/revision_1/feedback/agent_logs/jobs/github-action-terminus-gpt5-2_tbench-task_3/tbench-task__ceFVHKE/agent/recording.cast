[127.481132, "o", "pub fn r_d(a: &str, b: i64, c: i64) -> i64 {\r\n    // Normalize older revision markers to the current behavior: the carried\r\n    // state participates in the produced native value.\r\n    match a {\r\n        \"old\" => b + c,\r\n        \"new\" => b + c,\r\n        _ => b + c,\r\n"]
[127.481169, "o", "    }\r\n}\r\n\r\npub fn aux_r(a: i64) -> i64 {\r\n    a * 2\r\n}\r\n"]
