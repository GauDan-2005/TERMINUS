[116.460558, "i", "cat > b2/q.js <<'EOF'\nfunction q_b(a, b, c) {\n  // Deferred values belong to the same cycle they are declared on.\n  // Keep a trace in the session context for introspection, but do not shift\n  // visibility to the next slot.\n  const label = `slot-${b}`;\n  c[label] = (c[label] || []).concat(a || []);\n  return (a || []).slice().sort((left, right) => left - right);\n}\n\nfunction scan_b(a) {\n  return Object.keys(a).sort();\n}\n\nmodule.exports = { q_b, scan_b };\nEOF\n"]
[116.460844, "o", "cat > b2/q.js <<'EOF'\r\n"]
