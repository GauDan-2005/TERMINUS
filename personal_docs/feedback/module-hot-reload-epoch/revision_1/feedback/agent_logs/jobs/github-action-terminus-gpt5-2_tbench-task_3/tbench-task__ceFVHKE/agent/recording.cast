[90.594607, "o", "\u001b[?2004h"]
[90.594621, "o", "> "]
[90.594744, "o", "    acceptedOlder: accepted,\r\n\u001b[?2004l\r"]
[90.594768, "o", "\u001b[?2004h> "]
[90.594928, "o", "    healthy: false\r\n\u001b[?2004l\r\u001b[?2004h>   };\r\n\u001b[?2004l\r"]
[90.595011, "o", "\u001b[?2004h> "]
[90.595068, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.59517, "o", "module.exports = { f_a };\r\n\u001b[?2004l\r"]
[90.595241, "o", "\u001b[?2004h> "]
[90.595315, "o", "EOF\r\n\u001b[?2004l\r"]
