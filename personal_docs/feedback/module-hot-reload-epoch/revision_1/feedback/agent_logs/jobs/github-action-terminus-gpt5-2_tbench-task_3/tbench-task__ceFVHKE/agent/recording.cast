[116.931689, "i", "cat > src/native/src/lib.rs <<'EOF'\npub fn r_d(a: &str, b: i64, c: i64) -> i64 {\n    // Normalize older revision markers to the current behavior: the carried\n    // state participates in the produced native value.\n    match a {\n        \"old\" => b + c,\n        \"new\" => b + c,\n        _ => b + c,\n    }\n}\n\npub fn aux_r(a: i64) -> i64 {\n    a * 2\n}\nEOF\n"]
[116.931892, "o", "cat > src/native/src/lib.rs <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> pub fn r_d(a: &str, b: i64, c: i64) -> i64 {\r\n\u001b[?2004l\r\u001b[?2004h>     // Normalize older revision markers to the current behavior: the carried\r\n\u001b[?2004l\r\u001b[?2004h>     // state participates in the produced native value.\r\n\u001b[?2004l\r\u001b[?2004h>     match a {\r\n\u001b[?2004l\r\u001b[?2004h>         \"old\" => b + c,\r\n\u001b[?2004l\r\u001b[?2004h>         \"new\" => b + c,\r\n\u001b[?2004l\r\u001b[?2004h>         _ => b + c,\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> pub fn aux_r(a: i64) -> i64 {\r\n\u001b[?2004l\r\u001b[?2004h>     a * 2\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
