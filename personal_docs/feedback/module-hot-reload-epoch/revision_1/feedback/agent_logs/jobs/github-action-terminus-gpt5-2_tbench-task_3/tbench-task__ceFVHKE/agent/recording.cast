[116.576432, "i", "cat > c3/r.js <<'EOF'\nfunction k_c(a, b, c) {\n  // Recompute per-row from that row's descriptor and position.\n  // No cross-row caching.\n  return Number(a) + Number(b);\n}\n\nfunction lens_c(a) {\n  return String(a).length;\n}\n\nmodule.exports = { k_c, lens_c };\nEOF\n"]
