[90.589645, "o", "      });\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.589766, "o", "  if (proc.status !== 0) {\r\n\u001b[?2004l\r"]
[90.589783, "o", "\u001b[?2004h> "]
[90.590156, "o", "    throw new Error(proc.stderr || proc.stdout || 'native worker failed');\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.590261, "o", "  return Number(proc.stdout.trim());\r\n\u001b[?2004l\r"]
