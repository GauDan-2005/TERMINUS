[90.593442, "o", "\u001b[?2004h> "]
[90.593676, "o", "    rows.push({ index, value: rowValue, factor, nativeValue, deferred: owned });\r\n\u001b[?2004l\r"]
[90.593698, "o", "\u001b[?2004h"]
[90.593774, "o", "> "]
[90.593851, "o", "    carry = cycle.base;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.593866, "o", "  }\r\n\u001b[?2004l\r"]
[90.594019, "o", "\u001b[?2004h>   return {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.594064, "o", "    name: a.name,\r\n\u001b[?2004l\r"]
[90.594232, "o", "\u001b[?2004h>     rows,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.594351, "o", "    finalCounter: carry,\r\n\u001b[?2004l\r"]
[90.594371, "o", "\u001b[?2004h> "]
