[14.312797, "o", "function order_f(a) {\r\n  return a.slice().sort((left, right) => String(left).localeCompare(String(right)));\r\n}\r\n\r\n"]
[14.312829, "o", "function merge_f(a, b) {\r\n  return order_f([].concat(a || [], b || []));\r\n}\r\n\r\nmodule.exports = { order_f, merge_f };\r\n"]
[14.312959, "o", "src/core/g7/theta.js\r\n"]
[14.313664, "o", "function meter_g(a) {\r\n  return a.reduce((acc, value) => acc + Number(value || 0), 0);\r\n}\r\n\r\nfunction average_g(a) {\r\n  return a.length === 0 ? 0 : meter_g(a) / a.length;\r\n"]
[14.313734, "o", "}\r\n\r\nmodule.exports = { meter_g, average_g };\r\n"]
