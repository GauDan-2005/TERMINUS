[97.764368, "i", "sed -n '1,200p' b2/q.js\n"]
[97.764938, "o", "sed -n '1,200p' b2/q.js\r\n\u001b[?2004l\r"]
[97.766015, "o", "function q_b(a, b, c) {\r\n  const label = `slot-${b}`;\r\n  c[label] = (c[label] || []).concat(a);\r\n  const next = `slot-${b + 1}`;\r\n  const visible = c[next] || [];\r\n  c[next] = [];\r\n  return visible.slice().sort((left, right) => left - right);\r\n}\r\n\r\nfunction scan_b(a) {\r\n  return Object.keys(a).sort();\r\n}\r\n\r\nmodule.exports = { q_b, scan_b };\r\n"]
[97.76609, "o", "\u001b[?2004hroot@594e8276182b:/app# "]
[97.872549, "i", "sed -n '1,200p' c3/r.js\n"]
[97.872909, "o", "sed -n '1,200p' c3/r.js\r\n"]
[97.873043, "o", "\u001b[?2004l\r"]
[97.873977, "o", "let saved = null;\r\n\r\nfunction k_c(a, b, c) {\r\n  if (saved === null) {\r\n    saved = Number(a);\r\n  }\r\n"]
[97.874086, "o", "  return saved + b;\r\n}\r\n\r\nfunction lens_c(a) {\r\n  return String(a).length;\r\n}\r\n\r\nmodule.exports = { k_c, lens_c };\r\n"]
[97.874321, "o", "\u001b[?2004h"]
[97.874412, "o", "root@594e8276182b:/app# "]
[97.988594, "i", "sed -n '1,200p' d4/s.js\n"]
