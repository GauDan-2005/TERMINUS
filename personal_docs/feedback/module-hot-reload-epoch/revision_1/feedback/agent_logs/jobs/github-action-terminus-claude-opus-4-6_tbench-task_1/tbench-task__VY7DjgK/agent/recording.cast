[14.935054, "o", "        \"native\": \"old\"\r\n        },\r\n        {\r\n          \"base\": 1,\r\n          \"dep\": 9,\r\n          \"deferred\": [\r\n            3\r\n          ],\r\n          \"native\": \"new\"\r\n        }\r\n      ]\r\n    }\r\n  ]\r\n}\r\n"]
