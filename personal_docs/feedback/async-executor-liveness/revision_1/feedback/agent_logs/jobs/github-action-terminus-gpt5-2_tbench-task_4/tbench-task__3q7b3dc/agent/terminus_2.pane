    33	                if len(parts) != 2:
    34	                    raise ValueError(f"bad CAP line: {line}")
    35	                cap = int(parts[1])
    36	                continue
    37	            if parts[0] == "DROP":
    38	                if len(parts) != 2:
    39	                    raise ValueError(f"bad DROP line: {line}")
    40	                drops.add(parts[1])
    41	                continue
    42	            if parts[0] == "ROOT":
    43	                if len(parts) != 4:
    44	                    raise ValueError(f"bad ROOT line: {line}")
    45	                _, task, lane, turn_s = parts
    46	                rows.append(Row("ROOT", task, None, lane, int(turn_s), idx))
    47	                continue
    48	            if parts[0] == "CHILD":
    49	                if len(parts) != 5:
    50	                    raise ValueError(f"bad CHILD line: {line}")
    51	                _, parent, task, lane, turn_s = parts
    52	                rows.append(Row("CHILD", task, parent, lane, int(turn_s), idx))
    53	                continue
    54	            raise ValueError(f"unknown line: {line}")
    55	
    56	    if cap is None:
    57	        raise ValueError(f"missing CAP in {path}")
    58	    return cap, rows, drops
    59	
    60	
    61	def drop_closure(rows: List[Row], drops: Set[str]) -> Set[str]:
