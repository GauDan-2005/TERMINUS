   155	    os.makedirs(work_dir, exist_ok=True)
   156	    ledger_path = os.path.join(work_dir, f"{case}.ledger.jsonl")
   157	    journal_path = os.path.join(work_dir, f"{case}.journal.txt")
   158	
   159	    with open(ledger_path, "w", encoding="utf-8") as lf, open(journal_path, "w", encoding="utf-8") as jf:
   160	        for rec in trace:
   161	            lf.write(json.dumps(rec, sort_keys=True) + "\n")
   162	            parent = rec["parent"] if rec["parent"] is not None else "-"
   163	            jf.write(f"{rec['case']} {rec['task']} {parent} {rec['depth']} {rec['lane']} {rec['turn']}\n")
   164	
   165	    finished = (len(pending) == 0)
   166	    ok = finished
   167	    return {
   168	        "name": case,
   169	        "ok": ok,
