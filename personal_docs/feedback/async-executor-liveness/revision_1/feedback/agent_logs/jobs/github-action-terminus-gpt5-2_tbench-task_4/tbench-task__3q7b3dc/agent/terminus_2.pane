   130	                trace.append(
   131	                    {
   132	                        "case": case,
   133	                        "task": t,
   134	                        "parent": parent_of.get(t),
   135	                        "depth": compute_depth(t, parent_of),
   136	                        "lane": lane,
   137	                        "turn": turn,
   138	                    }
   139	                )
   140	
   141	    pending_tasks = [t for t in by_task.keys() if t not in accepted_turn]
