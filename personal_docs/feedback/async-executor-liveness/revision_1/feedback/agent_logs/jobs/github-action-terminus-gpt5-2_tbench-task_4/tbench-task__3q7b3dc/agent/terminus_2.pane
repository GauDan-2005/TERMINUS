    21	def parse_plan(path: str) -> Tuple[int, List[Row], Set[str]]:
    22	    cap: Optional[int] = None
    23	    rows: List[Row] = []
    24	    drops: Set[str] = set()
    25	
    26	    with open(path, "r", encoding="utf-8") as f:
    27	        for idx, raw in enumerate(f):
    28	            line = raw.strip()
    29	            if not line or line.startswith("#"):
    30	                continue
    31	            parts = line.split()
