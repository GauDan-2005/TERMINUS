   110	    plan_index_of: Dict[str, int] = {r.task: r.plan_index for r in kept}
   111	
   112	    max_turn = max([r.ready_turn for r in kept], default=0)
   113	
   114	    accepted_turn: Dict[str, int] = {}
   115	    trace: List[Dict] = []
   116	
   117	    lanes = sorted({r.lane for r in kept})
   118	
   119	    for turn in range(0, max_turn + 1):
   120	        for lane in lanes:
   121	            ready_tasks = [
   122	                t for t in by_task.keys()
   123	                if t not in accepted_turn
   124	                and lane_of[t] == lane
