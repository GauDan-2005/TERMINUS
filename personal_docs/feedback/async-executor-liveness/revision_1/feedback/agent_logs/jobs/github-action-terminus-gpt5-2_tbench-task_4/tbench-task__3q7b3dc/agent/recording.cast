[96.807641, "i", "perl -0777 -i -pe 's/for turn in range\\(0, max_turn \\+ 1\\):\\n\\s*for lane in lanes:/turn = 0\\n    total = len(kept)\\n\\n    while len(accepted_turn) < total:\\n        progressed = False\\n        for lane in lanes:/s; s/for t in ready_tasks\\[:cap\\]:\\n\\s*accepted_turn\\[t\\] = turn/for t in ready_tasks[:cap]:\\n                accepted_turn[t] = turn\\n                progressed = True/s; s/\\n\\s*pending_tasks = \\[t for t in by_task.keys\\(\\) if t not in accepted_turn\\]\\n/\\n        if not progressed:\\n            # No acceptances this turn; advance time until work becomes ready.\n            # (All work is independent of parent acceptance.)\n            turn += 1\n            if turn > max_turn and len(accepted_turn) < total:\n                # If no additional ready_turn exists, remaining work should still drain under CAP.\n                pass\n            continue\n        turn += 1\n\\n    pending_tasks = [r.task for r in kept if r.task not in accepted_turn]\\n/s' /app/scripts/executor-ctl\n"]
