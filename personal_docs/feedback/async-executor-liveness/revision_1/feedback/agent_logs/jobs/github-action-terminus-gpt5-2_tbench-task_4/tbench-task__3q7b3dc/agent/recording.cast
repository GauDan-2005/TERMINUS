[96.698329, "o", "               if len(parts) != 4:\r\n    44\t                    raise ValueError(f\"bad ROOT line: {line}\")\r\n    45\t                _, task, lane, turn_s = parts\r\n    46\t                rows.append(Row(\"ROOT\", task, None, lane, int(turn_s), idx))\r\n    47\t                continue\r\n    48\t            if parts[0] == \"CHILD\":\r\n    49\t                if len(parts) != 5:\r\n    50\t                    raise ValueError(f\"bad CHILD line: {line}\")\r\n    51\t                _, parent, task, lane, turn_s = parts\r\n    52\t                rows.append(Row(\"CHILD\", task, parent, lane, int(turn_s), idx))\r\n    53\t                continue\r\n    54\t            raise ValueError(f\"unknown line: {line}\")\r\n    55\t\r\n    56\t    if cap is None:\r\n    57\t        raise ValueError(f\"missing CAP in {path}\")\r\n    58\t    return cap, rows, drops\r\n    59\t\r\n    60\t\r\n    61\tdef drop_closure(rows: List[Row], drops: Set[str]) -> Set[str]:\r\n    62\t    children: Dict[str, List[str]] = {}\r\n    63\t    for r in rows:\r\n    64\t        if r.parent is not None:\r\n  "]
[96.698566, "o", "  65\t            children.setdefault(r.parent, []).append(r.task)\r\n    66\t\r\n    67\t    removed: Set[str] = set()\r\n    68\t    stack = list(drops)\r\n    69\t    while stack:\r\n    70\t        t = stack.pop()\r\n    71\t        if t in removed:\r\n    72\t            continue\r\n    73\t        removed.add(t)\r\n    74\t        for c in children.get(t, []):\r\n    75\t            if c not in removed:\r\n    76\t                stack.append(c)\r\n    77\t    return removed\r\n    78\t\r\n    79\t\r\n    80\tdef compute_depth(task: str, parent_of: Dict[str, Optional[str]]) -> int:\r\n    81\t    depth = 0\r\n    82\t    seen: Set[str] = set()\r\n    83\t    cur = parent_of.get(task)\r\n    84\t    while cur is not None:\r\n    85\t        if cur in seen:\r\n    86\t            raise ValueError(f\"cycle in parents at {task}\")\r\n    87\t        seen.add(cur)\r\n    88\t        depth += 1\r\n    89\t        cur = parent_of.get(cur)\r\n    90\t    return depth\r\n    91\t\r\n    92\t\r\n    93\tdef simulate(case: str, cap: int, rows: List[Row], drops: Set[str], work_dir: str) -> Dict:\r\n   "]
