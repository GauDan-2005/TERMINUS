[117.846897, "o", "    while cur is not None:\r\n\u001b[?2004l\r"]
[117.84696, "o", "\u001b[?2004h> "]
[117.847134, "o", "        if cur in seen:\r\n\u001b[?2004l\r"]
[117.847199, "o", "\u001b[?2004h> "]
[117.847626, "o", "            raise ValueError(f\"cycle in parents at {task}\")\r\n\u001b[?2004l\r"]
[117.847669, "o", "\u001b[?2004h> "]
[117.847857, "o", "        seen.add(cur)\r\n\u001b[?2004l\r"]
[117.847921, "o", "\u001b[?2004h> "]
[117.848054, "o", "        depth += 1\r\n\u001b[?2004l\r"]
[117.848134, "o", "\u001b[?2004h> "]
[117.848376, "o", "        cur = parent_of.get(cur)\r\n\u001b[?2004l\r"]
[117.848495, "o", "\u001b[?2004h> "]
[117.848554, "o", "    return depth\r\n\u001b[?2004l\r"]
[117.848592, "o", "\u001b[?2004h"]
[117.848611, "o", "> \r\n"]
[117.848687, "o", "\u001b[?2004l\r\u001b[?2004h"]
[117.848743, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[117.848836, "o", "> "]
[117.849194, "o", "def simulate(case: str, cap: int, rows: List[Row], drops: Set[str], work_dir: str) -> Dict:\r\n\u001b[?2004l\r"]
[117.849233, "o", "\u001b[?2004h"]
[117.849249, "o", "> "]
[117.849405, "o", "    removed = drop_closure(rows, drops)\r\n\u001b[?2004l\r"]
[117.849441, "o", "\u001b[?2004h"]
[117.849457, "o", "> \r\n"]
[117.849517, "o", "\u001b[?2004l\r"]
[117.849641, "o", "\u001b[?2004h"]
[117.849703, "o", "> "]
[117.849893, "o", "    # De-dup by logical task name: keep earliest plan entry.\r\n\u001b[?2004l\r"]
[117.84994, "o", "\u001b[?2004h"]
[117.850006, "o", "> "]
[117.850137, "o", "    by_task: Dict[str, Row] = {}\r\n\u001b[?2004l\r"]
[117.850178, "o", "\u001b[?2004h"]
[117.852678, "o", ">     for r in rows:\r\n\u001b[?2004l\r\u001b[?2004h>         if r.task in removed:\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h>         prev = by_task.get(r.task)\r\n\u001b[?2004l\r\u001b[?2004h>         if prev is None or r.plan_index < prev.plan_index:\r\n\u001b[?2004l\r\u001b[?2004h>             by_task[r.task] = r\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     kept: List[Row] = sorted(by_task.values(), key=lambda r: r.plan_index)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     parent_of: Dict[str, Optional[str]] = {r.task: r.parent for r in kept}\r\n\u001b[?2004l\r\u001b[?2004h>     lane_of: Dict[str, str] = {r.task: r.lane for r in kept}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.85675, "o", "    ready_of: Dict[str, int] = {r.task: r.ready_turn for r in kept}\r\n\u001b[?2004l\r"]
[117.85697, "o", "\u001b[?2004h> "]
[117.857121, "o", "    plan_index_of: Dict[str, int] = {r.task: r.plan_index for r in kept}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.857311, "o", "    lanes = sorted({r.lane for r in kept})\r\n\u001b[?2004l\r"]
[117.857466, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.857603, "o", "    accepted: Set[str] = set()\r\n\u001b[?2004l\r"]
[117.857729, "o", "\u001b[?2004h>     trace: List[Dict] = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.857924, "o", "    max_ready = max([r.ready_turn for r in kept], default=0)\r\n\u001b[?2004l\r"]
[117.85805, "o", "\u001b[?2004h>     turn = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.858242, "o", "    # Drain until all non-dropped unique tasks are accepted.\r\n\u001b[?2004l\r"]
[117.858376, "o", "\u001b[?2004h> "]
[117.858493, "o", "    while len(accepted) < len(kept):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.858615, "o", "        for lane in lanes:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.858735, "o", "            ready_tasks = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.858856, "o", "                r.task for r in kept\r\n\u001b[?2004l\r"]
[117.85889, "o", "\u001b[?2004h> "]
[117.859045, "o", "                if r.task not in accepted\r\n\u001b[?2004l\r"]
[117.859157, "o", "\u001b[?2004h> "]
[117.85925, "o", "                and lane_of[r.task] == lane\r\n\u001b[?2004l\r"]
[117.859312, "o", "\u001b[?2004h> "]
[117.85947, "o", "                and ready_of[r.task] <= turn\r\n\u001b[?2004l\r"]
[117.859553, "o", "\u001b[?2004h> "]
[117.859656, "o", "            ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.859829, "o", "            # Ready work within a lane keeps plan-file order.\r\n\u001b[?2004l\r"]
[117.859888, "o", "\u001b[?2004h> "]
[117.860078, "o", "            ready_tasks.sort(key=lambda t: plan_index_of[t])\r\n\u001b[?2004l\r"]
[117.860184, "o", "\u001b[?2004h> "]
[117.860277, "o", "            for t in ready_tasks[:cap]:\r\n\u001b[?2004l\r"]
[117.860296, "o", "\u001b[?2004h"]
[117.860309, "o", "> "]
[117.860431, "o", "                accepted.add(t)\r\n\u001b[?2004l\r"]
[117.860527, "o", "\u001b[?2004h> "]
[117.860702, "o", "                trace.append(\r\n\u001b[?2004l\r"]
[117.860735, "o", "\u001b[?2004h>                     {\r\n"]
[117.860748, "o", "\u001b[?2004l\r"]
[117.860818, "o", "\u001b[?2004h> "]
[117.860962, "o", "                        \"case\": case,\r\n\u001b[?2004l\r\u001b[?2004h"]
[117.86103, "o", "> "]
[117.861141, "o", "                        \"task\": t,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.861315, "o", "                        \"parent\": parent_of.get(t),\r\n\u001b[?2004l\r"]
[117.861335, "o", "\u001b[?2004h"]
[117.861346, "o", "> "]
[117.861567, "o", "                        \"depth\": compute_depth(t, parent_of),\r\n\u001b[?2004l\r"]
[117.861588, "o", "\u001b[?2004h"]
[117.861601, "o", "> "]
[117.861781, "o", "                        \"lane\": lane,\r\n\u001b[?2004l\r"]
[117.861889, "o", "\u001b[?2004h> "]
[117.862002, "o", "                        \"turn\": turn,\r\n\u001b[?2004l\r\u001b[?2004h"]
[117.862028, "o", "> "]
[117.862167, "o", "                    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.862326, "o", "                )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[117.862353, "o", "> "]
[117.862509, "o", "        # If nothing is ready yet, time still advances.\r\n\u001b[?2004l\r"]
[117.862534, "o", "\u001b[?2004h"]
[117.862681, "o", ">         turn += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.862884, "o", "        # Safety valve: should never trip for shipped inputs.\r\n\u001b[?2004l\r"]
[117.862984, "o", "\u001b[?2004h> "]
[117.863107, "o", "        if turn > max_ready + len(kept) + 10:\r\n\u001b[?2004l\r"]
[117.863203, "o", "\u001b[?2004h> "]
[117.863225, "o", "            break\r\n\u001b[?2004l\r"]
[117.863345, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[117.863492, "o", "\u001b[?2004h> "]
[117.863617, "o", "    pending_tasks = [r.task for r in kept if r.task not in accepted]\r\n\u001b[?2004l\r"]
[117.863642, "o", "\u001b[?2004h> "]
[117.863919, "o", "    pending_tasks.sort(key=lambda t: (ready_of[t], lane_of[t], plan_index_of[t]))\r\n\u001b[?2004l\r"]
[117.863941, "o", "\u001b[?2004h> "]
[117.864007, "o", "    pending = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.864169, "o", "        {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.86419, "o", "            \"case\": case,\r\n\u001b[?2004l\r"]
[117.86428, "o", "\u001b[?2004h> "]
[117.864354, "o", "            \"task\": t,\r\n\u001b[?2004l\r\u001b[?2004h"]
[117.864563, "o", "> "]
[117.864746, "o", "            \"parent\": parent_of.get(t),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.864771, "o", "            \"depth\": compute_depth(t, parent_of),\r\n\u001b[?2004l\r"]
[117.864783, "o", "\u001b[?2004h"]
[117.864796, "o", "> "]
[117.864929, "o", "            \"lane\": lane_of[t],\r\n\u001b[?2004l\r"]
[117.865019, "o", "\u001b[?2004h> "]
[117.865116, "o", "            \"turn\": None,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.865208, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.865368, "o", "        for t in pending_tasks\r\n\u001b[?2004l\r"]
[117.865387, "o", "\u001b[?2004h>     ]\r\n\u001b[?2004l\r"]
[117.865503, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.865658, "o", "    os.makedirs(work_dir, exist_ok=True)\r\n\u001b[?2004l\r"]
[117.865681, "o", "\u001b[?2004h> "]
[117.865919, "o", "    ledger_path = os.path.join(work_dir, f\"{case}.ledger.jsonl\")\r\n\u001b[?2004l\r"]
[117.865943, "o", "\u001b[?2004h> "]
[117.866212, "o", "    journal_path = os.path.join(work_dir, f\"{case}.journal.txt\")\r\n\u001b[?2004l\r"]
[117.866234, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[117.866249, "o", "> "]
[117.866644, "o", "    with open(ledger_path, \"w\", encoding=\"utf-8\") as lf, open(journal_path, \"w\", encoding=\"utf-8\") as jf:\r\n\u001b[?2004l\r"]
[117.86667, "o", "\u001b[?2004h> "]
[117.866843, "o", "        for rec in trace:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.866973, "o", "            lf.write(json.dumps(rec, sort_keys=True) + \"\\n\")\r\n\u001b[?2004l\r"]
[117.866997, "o", "\u001b[?2004h"]
[117.867139, "o", "> "]
[117.867253, "o", "            parent = rec[\"parent\"] if rec[\"parent\"] is not None else \"-\"\r\n\u001b[?2004l\r"]
[117.867352, "o", "\u001b[?2004h> "]
[117.867647, "o", "            jf.write(f\"{rec['case']} {rec['task']} {parent} {rec['depth']} {rec['lane']} {rec['turn']}\\n\")\r\n\u001b[?2004l\r"]
[117.867703, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[117.867721, "o", "\u001b[?2004h"]
[117.867769, "o", "> "]
[117.867887, "o", "    finished = (len(pending) == 0)\r\n\u001b[?2004l\r"]
[117.867951, "o", "\u001b[?2004h> "]
[117.868009, "o", "    ok = finished\r\n\u001b[?2004l\r"]
[117.868072, "o", "\u001b[?2004h> "]
[117.868118, "o", "    return {\r\n\u001b[?2004l\r"]
[117.868176, "o", "\u001b[?2004h> "]
[117.868241, "o", "        \"name\": case,\r\n\u001b[?2004l\r"]
[117.868301, "o", "\u001b[?2004h"]
[117.868335, "o", "> "]
[117.868394, "o", "        \"ok\": ok,\r\n\u001b[?2004l\r"]
[117.868414, "o", "\u001b[?2004h> "]
[117.868516, "o", "        \"finished\": finished,\r\n\u001b[?2004l\r"]
[117.868581, "o", "\u001b[?2004h> "]
[117.868674, "o", "        \"pending\": pending,\r\n\u001b[?2004l\r"]
[117.868733, "o", "\u001b[?2004h"]
[117.868768, "o", "> "]
[117.868818, "o", "        \"trace\": trace,\r\n\u001b[?2004l\r"]
[117.868991, "o", "\u001b[?2004h> "]
[117.869077, "o", "        \"ledger\": ledger_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.869151, "o", "        \"journal\": journal_path,\r\n\u001b[?2004l\r"]
[117.869225, "o", "\u001b[?2004h"]
[117.86928, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[117.869354, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[117.869373, "o", "> "]
[117.869449, "o", "def main() -> None:\r\n\u001b[?2004l\r"]
[117.869515, "o", "\u001b[?2004h"]
[117.869554, "o", "> "]
[117.869685, "o", "    ap = argparse.ArgumentParser(prog=\"executor-ctl\")\r\n\u001b[?2004l\r"]
[117.869752, "o", "\u001b[?2004h> "]
[117.869916, "o", "    ap.add_argument(\"--case\", dest=\"case\", default=None)\r\n\u001b[?2004l\r"]
[117.869984, "o", "\u001b[?2004h> "]
[117.870152, "o", "    ap.add_argument(\"--out\", dest=\"out\", required=True)\r\n\u001b[?2004l\r"]
[117.870227, "o", "\u001b[?2004h"]
[117.870271, "o", "> "]
[117.870398, "o", "    ap.add_argument(\"--work\", dest=\"work\", required=True)\r\n\u001b[?2004l\r"]
[117.870467, "o", "\u001b[?2004h"]
[117.870509, "o", "> "]
[117.870578, "o", "    args = ap.parse_args()\r\n\u001b[?2004l\r"]
[117.870648, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[117.870691, "o", "\u001b[?2004h> "]
[117.870863, "o", "    cases = [args.case] if args.case else CASE_ORDER\r\n\u001b[?2004l\r"]
[117.870942, "o", "\u001b[?2004h> "]
[117.871077, "o", "    os.makedirs(os.path.dirname(args.out) or \".\", exist_ok=True)\r\n\u001b[?2004l\r"]
[117.871143, "o", "\u001b[?2004h"]
[117.871185, "o", "> "]
[117.87131, "o", "    os.makedirs(args.work, exist_ok=True)\r\n\u001b[?2004l\r"]
[117.871442, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.871521, "o", "    case_objs = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.871598, "o", "    for c in cases:\r\n\u001b[?2004l\r"]
[117.871641, "o", "\u001b[?2004h> "]
[117.871797, "o", "        plan_path = f\"/app/data/cases/{c}.plan\"\r\n\u001b[?2004l\r"]
[117.871882, "o", "\u001b[?2004h> "]
[117.871973, "o", "        cap, rows, drops = parse_plan(plan_path)\r\n\u001b[?2004l\r"]
[117.872024, "o", "\u001b[?2004h> "]
[117.872243, "o", "        case_objs.append(simulate(c, cap, rows, drops, args.work))\r\n\u001b[?2004l\r"]
[117.872264, "o", "\u001b[?2004h"]
[117.872318, "o", "> \r\n\u001b[?2004l\r"]
[117.872356, "o", "\u001b[?2004h> "]
[117.87249, "o", "    audit = {\"cases\": case_objs}\r\n\u001b[?2004l\r"]
[117.872611, "o", "\u001b[?2004h> "]
[117.872724, "o", "    with open(args.out, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r"]
[117.872776, "o", "\u001b[?2004h> "]
[117.872959, "o", "        json.dump(audit, f, indent=2, sort_keys=True)\r\n\u001b[?2004l\r"]
[117.872982, "o", "\u001b[?2004h"]
[117.873005, "o", "> "]
[117.873089, "o", "        f.write(\"\\n\")\r\n"]
[117.873109, "o", "\u001b[?2004l\r"]
[117.873234, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[117.873253, "o", "\u001b[?2004h> "]
[117.87335, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[117.873377, "o", "\u001b[?2004h"]
[117.873432, "o", "> "]
[117.8735, "o", "    main()\r\n\u001b[?2004l\r"]
[117.873516, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[117.875833, "o", "\u001b[?2004hroot@7b0e7cd3dbc1:/app# "]
[117.959243, "i", "chmod +x /app/scripts/executor-ctl\npython3 -m py_compile /app/scripts/executor-ctl\n"]
[117.959766, "o", "chmod +x /app/scripts/executor-ctl\r\n\u001b[?2004l\r"]
[117.961107, "o", "\u001b[?2004hroot@7b0e7cd3dbc1:/app# "]
[117.961199, "o", "python3 -m py_compile /app/scripts/executor-ctl\r\n\u001b[?2004l\r"]
[118.005487, "o", "\u001b[?2004hroot@7b0e7cd3dbc1:/app# "]
[118.083927, "i", "bash /app/scripts/run-matrix.sh\n"]
[118.084475, "o", "bash /app/scripts/run-matrix.sh\r\n\u001b[?2004l\r"]
[118.133448, "o", "\u001b[?2004hroot@7b0e7cd3dbc1:/app# "]
[119.083653, "i", "python3 -c 'import json;d=json.load(open(\"/app/output/executor-audit.json\"));print(\"all_ok\", all(c[\"ok\"] for c in d[\"cases\"]));print(\"any_pending\", any(c[\"pending\"] for c in d[\"cases\"]));print([(c[\"name\"], len(c[\"trace\"]), len(c[\"pending\"])) for c in d[\"cases\"]])'\n"]
[119.084776, "o", "python3 -c 'import json;d=json.load(open(\"/app/output/executor-audit.json\"));print(\"all_ok\", all(c[\"ok\"] for c in d[\"cases\"]));print(\"any_pending\", any(c[\"pending\"] for c in d[\"cases\"]));print([(c[\"name\"], len(c[\"trace\"]), len(c[\"pending\"])) for c in d[\"cases\"]])'\r\n"]
[119.085086, "o", "\u001b[?2004l\r"]
[119.102345, "o", "all_ok True\r\nany_pending False\r\n[('amber', 4, 0), ('cobalt', 5, 0), ('drake', 3, 0), ('ember', 2, 0), ('flint', 3, 0), ('graphite', 5, 0)]\r\n"]
[119.105461, "o", "\u001b[?2004hroot@7b0e7cd3dbc1:/app# "]
[119.198965, "i", "cp /app/output/executor-audit.json /tmp/executor-audit.1.json\nbash /app/scripts/run-matrix.sh\ncp /app/output/executor-audit.json /tmp/executor-audit.2.json\ndiff -u /tmp/executor-audit.1.json /tmp/executor-audit.2.json || true\n"]
[119.199234, "o", "cp /app/output/executor-audit.json /tmp/executor-audit.1.json"]
[119.199313, "o", "\r\n"]
[119.199382, "o", "\u001b[?2004l\r"]
[119.200964, "o", "\u001b[?2004h"]
[119.201114, "o", "root@7b0e7cd3dbc1:/app# "]
[119.201222, "o", "bash /app/scripts/run-matrix.sh"]
[119.201316, "o", "\r\n"]
[119.201568, "o", "\u001b[?2004l\r"]
[119.250038, "o", "\u001b[?2004hroot@7b0e7cd3dbc1:/app# "]
