[81.424623, "i", "cat > /app/scripts/executor-ctl <<'EOF'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nfrom dataclasses import dataclass\nfrom typing import Dict, List, Optional, Set, Tuple\n\nCASE_ORDER = [\"amber\", \"cobalt\", \"drake\", \"ember\", \"flint\", \"graphite\"]\n\n\n@dataclass(frozen=True)\nclass Row:\n    kind: str              # ROOT | CHILD\n    task: str\n    parent: Optional[str]  # None for ROOT\n    lane: str\n    ready_turn: int\n    plan_index: int\n\n\ndef parse_plan(path: str) -> Tuple[int, List[Row], Set[str]]:\n    cap: Optional[int] = None\n    rows: List[Row] = []\n    drops: Set[str] = set()\n\n    with open(path, \"r\", encoding=\"utf-8\") as f:\n        for idx, raw in enumerate(f):\n            line = raw.strip()\n            if not line or line.startswith(\"#\"):\n                continue\n            parts = line.split()\n            if parts[0] == \"CAP\":\n                if len(parts) != 2:\n                    raise ValueError(f\"bad CAP line: {line}\")\n                cap = int(parts[1])\n                continue\n        "]
[81.424787, "i", "    if parts[0] == \"DROP\":\n                if len(parts) != 2:\n                    raise ValueError(f\"bad DROP line: {line}\")\n                drops.add(parts[1])\n                continue\n            if parts[0] == \"ROOT\":\n                if len(parts) != 4:\n                    raise ValueError(f\"bad ROOT line: {line}\")\n                _, task, lane, turn_s = parts\n                rows.append(Row(\"ROOT\", task, None, lane, int(turn_s), idx))\n                continue\n            if parts[0] == \"CHILD\":\n                if len(parts) != 5:\n                    raise ValueError(f\"bad CHILD line: {line}\")\n                _, parent, task, lane, turn_s = parts\n                rows.append(Row(\"CHILD\", task, parent, lane, int(turn_s), idx))\n                continue\n            raise ValueError(f\"unknown line: {line}\")\n\n    if cap is None:\n        raise ValueError(f\"missing CAP in {path}\")\n    return cap, rows, drops\n\n\ndef drop_closure(rows: List[Row], drops: Set[str]) -> Set[str]:\n    children: Dict[str, List[str]] = {}\n"]
[81.424838, "i", "    for r in rows:\n        if r.parent is not None:\n            children.setdefault(r.parent, []).append(r.task)\n\n    removed: Set[str] = set()\n    stack = list(drops)\n    while stack:\n        t = stack.pop()\n        if t in removed:\n            continue\n        removed.add(t)\n        for c in children.get(t, []):\n            if c not in removed:\n                stack.append(c)\n    return removed\n\n\ndef compute_depth(task: str, parent_of: Dict[str, Optional[str]]) -> int:\n    depth = 0\n    seen: Set[str] = set()\n    cur = parent_of.get(task)\n    while cur is not None:\n        if cur in seen:\n            raise ValueError(f\"cycle in parents at {task}\")\n        seen.add(cur)\n        depth += 1\n        cur = parent_of.get(cur)\n    return depth\n\n\ndef simulate(case: str, cap: int, rows: List[Row], drops: Set[str], work_dir: str) -> Dict:\n    removed = drop_closure(rows, drops)\n\n    # De-dup by logical task name: keep earliest plan entry.\n    by_task: Dict[str, Row] = {}\n    for r in rows:\n        if r.task in remove"]
[81.424889, "o", "cat > /app/scripts/executor-ctl <<'EOF'\r\n"]
[81.424905, "i", "d:\n            continue\n        prev = by_task.get(r.task)\n        if prev is None or r.plan_index < prev.plan_index:\n            by_task[r.task] = r\n\n    kept: List[Row] = sorted(by_task.values(), key=lambda r: r.plan_index)\n\n    parent_of: Dict[str, Optional[str]] = {r.task: r.parent for r in kept}\n    lane_of: Dict[str, str] = {r.task: r.lane for r in kept}\n    ready_of: Dict[str, int] = {r.task: r.ready_turn for r in kept}\n    plan_index_of: Dict[str, int] = {r.task: r.plan_index for r in kept}\n\n    max_turn = max([r.ready_turn for r in kept], default=0)\n\n    accepted_turn: Dict[str, int] = {}\n    trace: List[Dict] = []\n\n    lanes = sorted({r.lane for r in kept})\n\n    for turn in range(0, max_turn + 1):\n        for lane in lanes:\n            ready_tasks = [\n                t for t in by_task.keys()\n                if t not in accepted_turn\n                and lane_of[t] == lane\n                and ready_of[t] <= turn\n            ]\n            ready_tasks.sort(key=lambda t: plan_index_of[t])\n            fo"]
[81.424915, "o", "\u001b[?2004l\r"]
[81.424989, "i", "r t in ready_tasks[:cap]:\n                accepted_turn[t] = turn\n                trace.append(\n                    {\n                        \"case\": case,\n                        \"task\": t,\n                        \"parent\": parent_of.get(t),\n                        \"depth\": compute_depth(t, parent_of),\n                        \"lane\": lane,\n                        \"turn\": turn,\n                    }\n                )\n\n    pending_tasks = [t for t in by_task.keys() if t not in accepted_turn]\n    pending_tasks.sort(key=lambda t: (ready_of[t], lane_of[t], plan_index_of[t]))\n    pending = [\n        {\n            \"case\": case,\n            \"task\": t,\n            \"parent\": parent_of.get(t),\n            \"depth\": compute_depth(t, parent_of),\n            \"lane\": lane_of[t],\n            \"turn\": None,\n        }\n        for t in pending_tasks\n    ]\n\n    os.makedirs(work_dir, exist_ok=True)\n    ledger_path = os.path.join(work_dir, f\"{case}.ledger.jsonl\")\n    journal_path = os.path.join(work_dir, f\"{case}.journal.txt\")\n\n   "]
[81.425046, "o", "\u001b[?2004h> "]
[81.425077, "i", " with open(ledger_path, \"w\", encoding=\"utf-8\") as lf, open(journal_path, \"w\", encoding=\"utf-8\") as jf:\n        for rec in trace:\n            lf.write(json.dumps(rec, sort_keys=True) + \"\\n\")\n            parent = rec[\"parent\"] if rec[\"parent\"] is not None else \"-\"\n            jf.write(f\"{rec['case']} {rec['task']} {parent} {rec['depth']} {rec['lane']} {rec['turn']}\\n\")\n\n    finished = (len(pending) == 0)\n    ok = finished\n    return {\n        \"name\": case,\n        \"ok\": ok,\n        \"finished\": finished,\n        \"pending\": pending,\n        \"trace\": trace,\n        \"ledger\": ledger_path,\n        \"journal\": journal_path,\n    }\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser(prog=\"executor-ctl\")\n    ap.add_argument(\"--case\", dest=\"case\", default=None)\n    ap.add_argument(\"--out\", dest=\"out\", required=True)\n    ap.add_argument(\"--work\", dest=\"work\", required=True)\n    args = ap.parse_args()\n\n    cases = [args.case] if args.case else CASE_ORDER\n    out_dir = os.path.dirname(args.out)\n    if out_dir:\n        os."]
[81.425115, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r"]
[81.425163, "i", "makedirs(out_dir, exist_ok=True)\n    os.makedirs(args.work, exist_ok=True)\n\n    case_objs = []\n    for c in cases:\n        plan_path = f\"/app/data/cases/{c}.plan\"\n        cap, rows, drops = parse_plan(plan_path)\n        case_objs.append(simulate(c, cap, rows, drops, args.work))\n\n    audit = {\"cases\": case_objs}\n    with open(args.out, \"w\", encoding=\"utf-8\") as f:\n        json.dump(audit, f, indent=2, sort_keys=True)\n        f.write(\"\\n\")\n\n\nif __name__ == \"__main__\":\n    main()\nEOF\n"]
