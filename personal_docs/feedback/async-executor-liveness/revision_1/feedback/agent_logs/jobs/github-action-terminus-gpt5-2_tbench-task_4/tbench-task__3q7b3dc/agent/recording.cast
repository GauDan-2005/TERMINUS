[117.82245, "i", "case,\n            \"task\": t,\n            \"parent\": parent_of.get(t),\n            \"depth\": compute_depth(t, parent_of),\n            \"lane\": lane_of[t],\n            \"turn\": None,\n        }\n        for t in pending_tasks\n    ]\n\n    os.makedirs(work_dir, exist_ok=True)\n    ledger_path = os.path.join(work_dir, f\"{case}.ledger.jsonl\")\n    journal_path = os.path.join(work_dir, f\"{case}.journal.txt\")\n\n    with open(ledger_path, \"w\", encoding=\"utf-8\") as lf, open(journal_path, \"w\", encoding=\"utf-8\") as jf:\n        for rec in trace:\n            lf.write(json.dumps(rec, sort_keys=True) + \"\\n\")\n            parent = rec[\"parent\"] if rec[\"parent\"] is not None else \"-\"\n            jf.write(f\"{rec['case']} {rec['task']} {parent} {rec['depth']} {rec['lane']} {rec['turn']}\\n\")\n\n    finished = (len(pending) == 0)\n    ok = finished\n    return {\n        \"name\": case,\n        \"ok\": ok,\n        \"finished\": finished,\n        \"pending\": pending,\n        \"trace\": trace,\n        \"ledger\": ledger_path,\n        \"journal\": journal_path,\n "]
[117.822675, "o", "> import os\r\n\u001b[?2004l\r\u001b[?2004h> "]
[117.822693, "i", "   }\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser(prog=\"executor-ctl\")\n    ap.add_argument(\"--case\", dest=\"case\", default=None)\n    ap.add_argument(\"--out\", dest=\"out\", required=True)\n    ap.add_argument(\"--work\", dest=\"work\", required=True)\n    args = ap.parse_args()\n\n    cases = [args.case] if args.case else CASE_ORDER\n    os.makedirs(os.path.dirname(args.out) or \".\", exist_ok=True)\n    os.makedirs(args.work, exist_ok=True)\n\n    case_objs = []\n    for c in cases:\n        plan_path = f\"/app/data/cases/{c}.plan\"\n        cap, rows, drops = parse_plan(plan_path)\n        case_objs.append(simulate(c, cap, rows, drops, args.work))\n\n    audit = {\"cases\": case_objs}\n    with open(args.out, \"w\", encoding=\"utf-8\") as f:\n        json.dump(audit, f, indent=2, sort_keys=True)\n        f.write(\"\\n\")\n\n\nif __name__ == \"__main__\":\n    main()\nEOF\n"]
