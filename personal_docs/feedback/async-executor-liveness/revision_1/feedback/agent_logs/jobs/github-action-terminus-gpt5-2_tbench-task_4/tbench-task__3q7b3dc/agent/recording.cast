[117.822201, "i", "y.\n    by_task: Dict[str, Row] = {}\n    for r in rows:\n        if r.task in removed:\n            continue\n        prev = by_task.get(r.task)\n        if prev is None or r.plan_index < prev.plan_index:\n            by_task[r.task] = r\n\n    kept: List[Row] = sorted(by_task.values(), key=lambda r: r.plan_index)\n\n    parent_of: Dict[str, Optional[str]] = {r.task: r.parent for r in kept}\n    lane_of: Dict[str, str] = {r.task: r.lane for r in kept}\n    ready_of: Dict[str, int] = {r.task: r.ready_turn for r in kept}\n    plan_index_of: Dict[str, int] = {r.task: r.plan_index for r in kept}\n\n    lanes = sorted({r.lane for r in kept})\n\n    accepted: Set[str] = set()\n    trace: List[Dict] = []\n\n    max_ready = max([r.ready_turn for r in kept], default=0)\n    turn = 0\n    # Drain until all non-dropped unique tasks are accepted.\n    while len(accepted) < len(kept):\n        for lane in lanes:\n            ready_tasks = [\n                r.task for r in kept\n                if r.task not in accepted\n                and lane_of["]
[117.822233, "o", "> import argparse\r\n\u001b[?2004l\r\u001b[?2004h> "]
