[81.449906, "o", "\u001b[?2004h> "]
[81.450001, "o", "    by_task: Dict[str, Row] = {}\r\n\u001b[?2004l\r"]
[81.450078, "o", "\u001b[?2004h> "]
[81.450139, "o", "    for r in rows:\r\n\u001b[?2004l\r"]
[81.450267, "o", "\u001b[?2004h> "]
[81.450336, "o", "        if r.task in removed:\r\n\u001b[?2004l\r"]
[81.450444, "o", "\u001b[?2004h> "]
[81.450554, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.450618, "o", "> "]
[81.450701, "o", "        prev = by_task.get(r.task)\r\n\u001b[?2004l\r"]
[81.450767, "o", "\u001b[?2004h"]
[81.450902, "o", "> "]
[81.451144, "o", "        if prev is None or r.plan_index < prev.plan_index:\r\n"]
[81.451244, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[81.451352, "o", "            by_task[r.task] = r\r\n\u001b[?2004l\r"]
[81.451487, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.45155, "o", "\u001b[?2004h> "]
[81.451799, "o", "    kept: List[Row] = sorted(by_task.values(), key=lambda r: r.plan_index)\r\n\u001b[?2004l\r"]
[81.451903, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.451961, "o", "\u001b[?2004h> "]
[81.452243, "o", "    parent_of: Dict[str, Optional[str]] = {r.task: r.parent for r in kept}\r\n\u001b[?2004l\r"]
[81.452347, "o", "\u001b[?2004h> "]
[81.452561, "o", "    lane_of: Dict[str, str] = {r.task: r.lane for r in kept}\r\n\u001b[?2004l\r"]
[81.452658, "o", "\u001b[?2004h> "]
[81.452933, "o", "    ready_of: Dict[str, int] = {r.task: r.ready_turn for r in kept}\r\n\u001b[?2004l\r"]
[81.453031, "o", "\u001b[?2004h> "]
[81.453296, "o", "    plan_index_of: Dict[str, int] = {r.task: r.plan_index for r in kept}\r\n\u001b[?2004l\r"]
[81.453389, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.453468, "o", "\u001b[?2004h> "]
[81.453664, "o", "    max_turn = max([r.ready_turn for r in kept], default=0)\r\n\u001b[?2004l\r"]
[81.453761, "o", "\u001b[?2004h> \r\n"]
[81.453872, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[81.453983, "o", "    accepted_turn: Dict[str, int] = {}\r\n\u001b[?2004l\r"]
[81.454106, "o", "\u001b[?2004h> "]
[81.454205, "o", "    trace: List[Dict] = []\r\n\u001b[?2004l\r"]
[81.454272, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.454305, "o", "\u001b[?2004h"]
[81.454343, "o", "> "]
[81.454499, "o", "    lanes = sorted({r.lane for r in kept})\r\n\u001b[?2004l\r"]
[81.454593, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.454672, "o", "\u001b[?2004h> "]
[81.454774, "o", "    for turn in range(0, max_turn + 1):\r\n\u001b[?2004l\r"]
[81.454877, "o", "\u001b[?2004h> "]
[81.454969, "o", "        for lane in lanes:\r\n\u001b[?2004l\r"]
[81.455025, "o", "\u001b[?2004h> "]
[81.455137, "o", "            ready_tasks = [\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.455194, "o", "> "]
[81.455323, "o", "                t for t in by_task.keys()\r\n\u001b[?2004l\r"]
[81.455426, "o", "\u001b[?2004h"]
[81.455515, "o", "> "]
[81.455654, "o", "                if t not in accepted_turn\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.455724, "o", "                and lane_of[t] == lane\r\n\u001b[?2004l\r"]
[81.455763, "o", "\u001b[?2004h"]
[81.455785, "o", "> "]
[81.455926, "o", "                and ready_of[t] <= turn\r\n\u001b[?2004l\r"]
[81.455984, "o", "\u001b[?2004h> "]
[81.456045, "o", "            ]\r\n\u001b[?2004l\r"]
[81.4561, "o", "\u001b[?2004h"]
[81.456157, "o", "> "]
[81.456491, "o", "            ready_tasks.sort(key=lambda t: plan_index_of[t])\r\n\u001b[?2004l\r"]
[81.456535, "o", "\u001b[?2004h"]
[81.45655, "o", "> "]
[81.456722, "o", "            for t in ready_tasks[:cap]:\r\n\u001b[?2004l\r"]
[81.456776, "o", "\u001b[?2004h> "]
[81.456927, "o", "                accepted_turn[t] = turn\r\n\u001b[?2004l\r"]
[81.457079, "o", "\u001b[?2004h"]
[81.457151, "o", "> "]
[81.457285, "o", "                trace.append(\r\n\u001b[?2004l\r"]
[81.457387, "o", "\u001b[?2004h"]
[81.457472, "o", "> "]
[81.457588, "o", "                    {\r\n"]
[81.457642, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[81.457793, "o", "                        \"case\": case,\r\n\u001b[?2004l\r"]
[81.457869, "o", "\u001b[?2004h> "]
[81.457983, "o", "                        \"task\": t,\r\n\u001b[?2004l\r"]
[81.458055, "o", "\u001b[?2004h> "]
[81.45824, "o", "                        \"parent\": parent_of.get(t),\r\n\u001b[?2004l\r"]
[81.45832, "o", "\u001b[?2004h> "]
[81.458542, "o", "                        \"depth\": compute_depth(t, parent_of),\r\n\u001b[?2004l\r"]
[81.45862, "o", "\u001b[?2004h> "]
[81.458748, "o", "                        \"lane\": lane,\r\n\u001b[?2004l\r"]
[81.458817, "o", "\u001b[?2004h> "]
[81.458956, "o", "                        \"turn\": turn,\r\n\u001b[?2004l\r"]
[81.459033, "o", "\u001b[?2004h> "]
[81.459115, "o", "                    }\r\n\u001b[?2004l\r"]
[81.459183, "o", "\u001b[?2004h"]
[81.459198, "o", "> "]
[81.45928, "o", "                )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.4593, "o", "\r\n\u001b[?2004l\r"]
[81.459385, "o", "\u001b[?2004h> "]
[81.459677, "o", "    pending_tasks = [t for t in by_task.keys() if t not in accepted_turn]\r\n\u001b[?2004l\r"]
[81.459759, "o", "\u001b[?2004h> "]
[81.460054, "o", "    pending_tasks.sort(key=lambda t: (ready_of[t], lane_of[t], plan_index_of[t]))\r\n\u001b[?2004l\r"]
[81.460127, "o", "\u001b[?2004h"]
[81.460148, "o", "> "]
[81.460231, "o", "    pending = [\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.460249, "o", "> "]
[81.460332, "o", "        {\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.46035, "o", "> "]
[81.460457, "o", "            \"case\": case,\r\n\u001b[?2004l\r"]
[81.460528, "o", "\u001b[?2004h"]
[81.460543, "o", "> "]
[81.460621, "o", "            \"task\": t,\r\n\u001b[?2004l\r"]
[81.460661, "o", "\u001b[?2004h"]
[81.460761, "o", "> "]
[81.460866, "o", "            \"parent\": parent_of.get(t),\r\n\u001b[?2004l\r"]
[81.460943, "o", "\u001b[?2004h> "]
[81.461114, "o", "            \"depth\": compute_depth(t, parent_of),\r\n\u001b[?2004l\r"]
[81.461185, "o", "\u001b[?2004h"]
[81.4612, "o", "> "]
[81.461296, "o", "            \"lane\": lane_of[t],\r\n\u001b[?2004l\r"]
[81.461365, "o", "\u001b[?2004h> "]
[81.461451, "o", "            \"turn\": None,\r\n\u001b[?2004l\r"]
[81.46152, "o", "\u001b[?2004h"]
[81.461536, "o", ">         }"]
[81.461626, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.461682, "o", "> "]
[81.461847, "o", "        for t in pending_tasks\r\n\u001b[?2004l\r"]
[81.461909, "o", "\u001b[?2004h"]
[81.461968, "o", "> "]
[81.461982, "o", "    ]\r\n\u001b[?2004l\r"]
[81.462076, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[81.462119, "o", "> "]
[81.462292, "o", "    os.makedirs(work_dir, exist_ok=True)\r\n\u001b[?2004l\r"]
[81.46237, "o", "\u001b[?2004h> "]
[81.462605, "o", "    ledger_path = os.path.join(work_dir, f\"{case}.ledger.jsonl\")\r\n\u001b[?2004l\r"]
[81.466363, "o", "\u001b[?2004h>     journal_path = os.path.join(work_dir, f\"{case}.journal.txt\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     with open(ledger_path, \"w\", encoding=\"utf-8\") as lf, open(journal_path, \"w\", encoding=\"utf-8\") as jf:\r\n\u001b[?2004l\r\u001b[?2004h>         for rec in trace:\r\n\u001b[?2004l\r\u001b[?2004h>             lf.write(json.dumps(rec, sort_keys=True) + \"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>             parent = rec[\"parent\"] if rec[\"parent\"] is not None else \"-\"\r\n\u001b[?2004l\r\u001b[?2004h>             jf.write(f\"{rec['case']} {rec['task']} {parent} {rec['depth']} {rec['lane']} {rec['turn']}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     finished = (len(pending) == 0)\r\n\u001b[?2004l\r\u001b[?2004h>     ok = finished\r\n\u001b[?2004l\r\u001b[?2004h>     return {\r\n\u001b[?2004l\r\u001b[?2004h>         \"name\": case,\r\n\u001b[?2004l\r\u001b[?2004h>         \"ok\": ok,\r\n\u001b[?2004l\r\u001b[?2004h>         \"finished\": finished,\r\n\u001b[?2004l\r\u001b[?2004h>         \"pending\": pending,\r\n\u001b[?2004l\r\u001b[?2004h>         \"trace\": trace,\r\n\u001b[?2004l\r\u001b[?2004h>         \"ledger\": ledger_path,\r\n\u001b[?2004l\r\u001b[?2004h>         \"journa"]
[81.466439, "o", "l\": journal_path,\r\n\u001b[?2004l\r\u001b[?2004h>     }"]
[81.46649, "o", "\r\n"]
[81.466543, "o", "\u001b[?2004l\r"]
[81.466619, "o", "\u001b[?2004h"]
[81.466684, "o", "> "]
[81.466733, "o", "\r\n"]
[81.466777, "o", "\u001b[?2004l\r"]
[81.466848, "o", "\u001b[?2004h"]
[81.466908, "o", "> "]
[81.466957, "o", "\r\n"]
[81.467007, "o", "\u001b[?2004l\r"]
[81.467081, "o", "\u001b[?2004h"]
[81.467142, "o", "> "]
[81.467274, "o", "def main() -> None:\r\n"]
[81.467336, "o", "\u001b[?2004l\r"]
[81.467396, "o", "\u001b[?2004h"]
[81.467467, "o", "> "]
[81.467681, "o", "    ap = argparse.ArgumentParser(prog=\"executor-ctl\")\r\n\u001b[?2004l\r"]
[81.467781, "o", "\u001b[?2004h> "]
[81.467922, "o", "    ap.add_argument(\"--case\", dest=\"case\", default=None)\r\n\u001b[?2004l\r"]
[81.468046, "o", "\u001b[?2004h> "]
[81.468166, "o", "    ap.add_argument(\"--out\", dest=\"out\", required=True)\r\n\u001b[?2004l\r"]
[81.468235, "o", "\u001b[?2004h"]
[81.468253, "o", "> "]
[81.468424, "o", "    ap.add_argument(\"--work\", dest=\"work\", required=True)\r\n\u001b[?2004l\r"]
[81.468512, "o", "\u001b[?2004h> "]
[81.468606, "o", "    args = ap.parse_args()\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.468712, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.468903, "o", "    cases = [args.case] if args.case else CASE_ORDER\r\n\u001b[?2004l\r"]
[81.469001, "o", "\u001b[?2004h"]
[81.469024, "o", "> "]
[81.469103, "o", "    out_dir = os.path.dirname(args.out)\r\n\u001b[?2004l\r"]
[81.469165, "o", "\u001b[?2004h> "]
[81.469226, "o", "    if out_dir:\r\n\u001b[?2004l\r"]
[81.469297, "o", "\u001b[?2004h> "]
[81.469428, "o", "        os.makedirs(out_dir, exist_ok=True)\r\n\u001b[?2004l\r"]
[81.469503, "o", "\u001b[?2004h> "]
[81.469648, "o", "    os.makedirs(args.work, exist_ok=True)\r\n\u001b[?2004l\r"]
[81.469669, "o", "\u001b[?2004h"]
[81.469688, "o", "> \r\n"]
[81.469702, "o", "\u001b[?2004l\r"]
[81.469806, "o", "\u001b[?2004h> "]
[81.469882, "o", "    case_objs = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.469947, "o", "    for c in cases:\r\n\u001b[?2004l\r"]
[81.470001, "o", "\u001b[?2004h> "]
[81.470146, "o", "        plan_path = f\"/app/data/cases/{c}.plan\"\r\n\u001b[?2004l\r"]
[81.470213, "o", "\u001b[?2004h> "]
[81.470353, "o", "        cap, rows, drops = parse_plan(plan_path)\r\n\u001b[?2004l\r"]
[81.470421, "o", "\u001b[?2004h> "]
[81.470604, "o", "        case_objs.append(simulate(c, cap, rows, drops, args.work))\r\n\u001b[?2004l\r"]
[81.470663, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.470695, "o", "\u001b[?2004h"]
[81.470772, "o", "> "]
[81.470853, "o", "    audit = {\"cases\": case_objs}\r\n\u001b[?2004l\r"]
[81.470911, "o", "\u001b[?2004h> "]
[81.471103, "o", "    with open(args.out, \"w\", encoding=\"utf-8\") as f:"]
[81.471451, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(audit, f, indent=2, sort_keys=True)"]
[81.471521, "o", "\r\n"]
[81.471571, "o", "\u001b[?2004l\r"]
[81.472095, "o", "\u001b[?2004h>         f.write(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.472185, "o", "    main()"]
[81.472291, "o", "\r\n\u001b[?2004l\r"]
[81.472366, "o", "\u001b[?2004h"]
[81.472455, "o", "> "]
