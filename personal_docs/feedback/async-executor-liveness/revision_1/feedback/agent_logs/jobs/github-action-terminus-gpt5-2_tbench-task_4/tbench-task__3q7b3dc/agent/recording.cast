[96.698896, "o", "eys() if t not in accepted_turn]\r\n   142\t    pending_tasks.sort(key=lambda t: (ready_of[t], lane_of[t], plan_index_of[t]))\r\n   143\t    pending = [\r\n   144\t        {\r\n   145\t            \"case\": case,\r\n   146\t            \"task\": t,\r\n   147\t            \"parent\": parent_of.get(t),\r\n   148\t            \"depth\": compute_depth(t, parent_of),\r\n   149\t            \"lane\": lane_of[t],\r\n   150\t            \"turn\": None,\r\n   151\t        }\r\n   152\t        for t in pending_tasks\r\n   153\t    ]\r\n   154\t\r\n   155\t    os.makedirs(work_dir, exist_ok=True)\r\n   156\t    ledger_path = os.path.join(work_dir, f\"{case}.ledger.jsonl\")\r\n   157\t    journal_path = os.path.join(work_dir, f\"{case}.journal.txt\")\r\n   158\t\r\n   159\t    with open(ledger_path, \"w\", encoding=\"utf-8\") as lf, open(journal_path, \"w\", encoding=\"utf-8\") as jf:\r\n   160\t        for rec in trace:\r\n   161\t            lf.write(json.dumps(rec, sort_keys=True) + \"\\n\")\r\n   162\t            parent = rec[\"parent\"] if rec[\"parent\"] is not None else \"-\"\r\n   163\t            jf.write(f\"{"]
[96.699011, "o", "rec['case']} {rec['task']} {parent} {rec['depth']} {rec['lane']} {rec['turn']}\\n\")\r\n   164\t\r\n   165\t    finished = (len(pending) == 0)\r\n   166\t    ok = finished\r\n   167\t    return {\r\n   168\t        \"name\": case,\r\n   169\t        \"ok\": ok,\r\n   170\t        \"finished\": finished,\r\n   171\t        \"pending\": pending,\r\n   172\t        \"trace\": trace,\r\n   173\t        \"ledger\": ledger_path,\r\n   174\t        \"journal\": journal_path,\r\n   175\t    }\r\n   176\t\r\n   177\t\r\n   178\tdef main() -> None:\r\n   179\t    ap = argparse.ArgumentParser(prog=\"executor-ctl\")\r\n   180\t    ap.add_argument(\"--case\", dest=\"case\", default=None)\r\n   181\t    ap.add_argument(\"--out\", dest=\"out\", required=True)\r\n   182\t    ap.add_argument(\"--work\", dest=\"work\", required=True)\r\n   183\t    args = ap.parse_args()\r\n   184\t\r\n   185\t    cases = [args.case] if args.case else CASE_ORDER\r\n   186\t    out_dir = os.path.dirname(args.out)\r\n   187\t    if out_dir:\r\n   188\t        os.makedirs(out_dir, exist_ok=True)\r\n   189\t    os.makedirs(args.work, exist_ok=True)\r\n   "]
