[117.821228, "i", "cat > /app/scripts/executor-ctl <<'EOF'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nfrom dataclasses import dataclass\nfrom typing import Dict, List, Optional, Set, Tuple\n\nCASE_ORDER = [\"amber\", \"cobalt\", \"drake\", \"ember\", \"flint\", \"graphite\"]\n\n\n@dataclass(frozen=True)\nclass Row:\n    kind: str              # ROOT | CHILD\n    task: str\n    parent: Optional[str]  # None for ROOT\n    lane: str\n    ready_turn: int\n    plan_index: int\n\n\ndef parse_plan(path: str) -> Tuple[int, List[Row], Set[str]]:\n    cap: Optional[int] = None\n    rows: List[Row] = []\n    drops: Set[str] = set()\n\n    with open(path, \"r\", encoding=\"utf-8\") as f:\n        for idx, raw in enumerate(f):\n            line = raw.strip()\n            if not line or line.startswith(\"#\"):\n                continue\n            parts = line.split()\n\n            if parts[0] == \"CAP\":\n                if len(parts) != 2:\n                    raise ValueError(f\"bad CAP line: {line}\")\n                cap = int(parts[1])\n                continue\n\n      "]
[117.821722, "i", "      if parts[0] == \"DROP\":\n                if len(parts) != 2:\n                    raise ValueError(f\"bad DROP line: {line}\")\n                drops.add(parts[1])\n                continue\n\n            if parts[0] == \"ROOT\":\n                if len(parts) != 4:\n                    raise ValueError(f\"bad ROOT line: {line}\")\n                _, task, lane, turn_s = parts\n                rows.append(Row(\"ROOT\", task, None, lane, int(turn_s), idx))\n                continue\n\n            if parts[0] == \"CHILD\":\n                if len(parts) != 5:\n                    raise ValueError(f\"bad CHILD line: {line}\")\n                _, parent, task, lane, turn_s = parts\n                rows.append(Row(\"CHILD\", task, parent, lane, int(turn_s), idx))\n                continue\n\n            raise ValueError(f\"unknown line: {line}\")\n\n    if cap is None:\n        raise ValueError(f\"missing CAP in {path}\")\n    if cap <= 0:\n        raise ValueError(f\"CAP must be positive in {path}\")\n    return cap, rows, drops\n\n\ndef drop_closure(rows:"]
[117.821872, "o", "cat > /app/scripts/executor-ctl <<'EOF'\r\n\u001b[?2004l\r      if parts[0] == \"DROP\":\r\n                if len(parts) != 2:\r\n                    raise ValueError(f\"bad DROP line: {line}\")\r\n                drops.add(parts[1])\r\n                continue\r\n\r\n            if parts[0] == \"ROOT\":\r\n                if len(parts) != 4:\r\n                    raise ValueError(f\"bad ROOT line: {line}\")\r\n                _, task, lane, turn_s = parts\r\n                rows.append(Row(\"ROOT\", task, None, lane, int(turn_s), idx))\r\n                continue\r\n\r\n            if parts[0] == \"CHILD\":\r\n                if len(parts) != 5:\r\n                    raise ValueError(f\"bad CHILD line: {line}\")\r\n                _, parent, task, lane, turn_s = parts\r\n                rows.append(Row(\"CHILD\", task, parent, lane, int(turn_s), idx))\r\n                continue\r\n\r\n            raise ValueError(f\"unknown line: {line}\")\r\n\r\n    if cap is None:\r\n        raise ValueError(f\"missing CAP in {path}\")\r\n    if cap <= 0:\r\n        raise ValueError(f\"CAP must b"]
[117.821952, "i", " List[Row], drops: Set[str]) -> Set[str]:\n    children: Dict[str, List[str]] = {}\n    for r in rows:\n        if r.parent is not None:\n            children.setdefault(r.parent, []).append(r.task)\n\n    removed: Set[str] = set()\n    stack = list(drops)\n    while stack:\n        t = stack.pop()\n        if t in removed:\n            continue\n        removed.add(t)\n        for c in children.get(t, []):\n            if c not in removed:\n                stack.append(c)\n    return removed\n\n\ndef compute_depth(task: str, parent_of: Dict[str, Optional[str]]) -> int:\n    depth = 0\n    seen: Set[str] = set()\n    cur = parent_of.get(task)\n    while cur is not None:\n        if cur in seen:\n            raise ValueError(f\"cycle in parents at {task}\")\n        seen.add(cur)\n        depth += 1\n        cur = parent_of.get(cur)\n    return depth\n\n\ndef simulate(case: str, cap: int, rows: List[Row], drops: Set[str], work_dir: str) -> Dict:\n    removed = drop_closure(rows, drops)\n\n    # De-dup by logical task name: keep earliest plan entr"]
