[11.841738, "o", "[package]\r\nname = \"executor_liveness_lab\"\r\nversion = \"0.1.0\"\r\nedition = \"2021\"\r\n\r\n[lib]\r\nname = \"executor_liveness_lab\"\r\npath = \"src/lib.rs\"\r\n\r\n[[bin]]\r\nname = \"executor-ctl\"\r\npath = \"src/main.rs\"\r\n"]
