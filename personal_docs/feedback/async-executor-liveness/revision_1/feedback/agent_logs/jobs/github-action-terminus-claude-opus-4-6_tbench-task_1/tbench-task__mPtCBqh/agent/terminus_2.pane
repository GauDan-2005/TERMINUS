[?2004l[?2004h> use std::collections::{BTreeMap, BTreeSet};
[?2004l[?2004h> use std::io;
[?2004l[?2004h> use std::path::{Path, PathBuf};
[?2004l[?2004h> 
[?2004l[?2004h> use crate::book_b::fold_b;
[?2004l[?2004h> use crate::core_a::{op_a, R0, S0};
[?2004l[?2004h> use crate::flow_e::{emit_e, note_e};
[?2004l[?2004h> use crate::gate_c::{mark_c, S1};
[?2004l[?2004h> use crate::host_d::{bind_d, R1, S2};
[?2004l[?2004h> use crate::types_f::{CaseReport, Entry, Item, Plan, Record};
[?2004l[?2004h> 
[?2004l[?2004h> fn out_paths(base: &Path, name: &str) -> (PathBuf, PathBuf) {
[?2004l[?2004h>     (base.join("ledgers").join(format!("{}.jsonl", name)), base.join("journals").join(format!("{}.txt", name)))
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> pub fn drive_g(a: &Plan, b: &Path) -> io::Result<CaseReport> {
[?2004l[?2004h>     let mut host = S2::new();
[?2004l[?2004h>     let mut removed: BTreeSet<String> = BTreeSet::new();
[?2004l[?2004h>     // Use Vec to preserve plan-file insertion order, with deduplication
[?2004l[?2004h>     let mut raw_order: Vec<Item> = Vec::new();
[?2004l[?2004h>     let mut seen_idents: BTreeSet<String> = BTreeSet::new();
[?2004l[?2004h> 
[?2004l[?2004h>     for entry in &a.entries {
[?2004l[?2004h>         match entry {
[?2004l[?2004h>             Entry::Root { ident, lane, at, seq } => {
[?2004l[?2004h>                 if seen_idents.contains(ident) {
[?2004l[?2004h>                     continue; // skip duplicate
[?2004l[?2004h>                 }
[?2004l[?2004h>                 let item = Item { ident: ident.clone(), parent: "-".to_string(), lane: lane.clone(), at: *at, seq: *seq, depth: 0, chain: vec![ident.clone()] };
[?2004l[?2004h>                 let moved = bind_d(&mut host, R1 { item }).map_err(|_| io::Error::new(io::ErrorKind::Other, "state"))?;
[?2004l[?2004h>                 seen_idents.insert(ident.clone());
[?2004l[?2004h>                 raw_order.push(moved.item);
[?2004l[?2004h>             }
[?2004l[?2004h>             Entry::Child { from, ident, lane, at, seq } => {
[?2004l[?2004h>                 if seen_idents.contains(ident) {
[?2004l[?2004h>                     continue; // skip duplicate
[?2004l[?2004h>                 }
[?2004l[?2004h>                 let parent = raw_order.iter().find(|i| i.ident == *from).cloned();
[?2004l[?2004h>                 let depth = parent.as_ref().map(|p| p.depth + 1).unwrap_or(0);
[?2004l[?2004h>                 let mut chain = parent.as_ref().map(|p| p.chain.clone()).unwrap_or_default();
[?2004l[?2004h>                 chain.push(ident.clone());
[?2004l[?2004h>                 let parent_name = if parent.is_some() { from.clone() } else { "-".to_string() };
[?2004l[?2004h>                 let item = Item { ident: ident.clone(), parent: parent_name, lane: lane.clone(), at: *at, seq: *seq, depth, chain };
[?2004l[?2004h>                 let moved = bind_d(&mut host, R1 { item }).map_err(|_| io::Error::new(io::ErrorKind::Other, "state"))?;
[?2004l[?2004h>                 seen_idents.insert(ident.clone());
[?2004l[?2004h>                 raw_order.push(moved.item);
[?2004l[?2004h>             }
[?2004l[?2004h>             Entry::Drop { ident } => {
[?2004l[?2004h>                 removed.insert(ident.clone());
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     let gate = S1::new(removed);
[?2004l[?2004h>     let mut state = S0::new();
[?2004l[?2004h>     for item in &raw_order {
[?2004l[?2004h>         let row = R0::from_item(&a.name, item);
[?2004l[?2004h>         if mark_c(&gate, &row) {
[?2004l[?2004h>             op_a(&mut state, row).map_err(|_| io::Error::new(io::ErrorKind::Other, "row"))?;
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     let ordered = fold_b(&state.rows, a.cap);
[?2004l[?2004h>     let trace: Vec<Record> = ordered.iter().map(R0::pack_a).collect();
[?2004l[?2004h>     let accepted: BTreeSet<String> = trace.iter().map(|row| row.task_name.clone()).collect();
[?2004l[?2004h>     let mut pending: Vec<String> = state.rows.iter().filter(|row| !accepted.contains(&row.task_name)).map(|row| row.task_name.clone()).collect();
[?2004l[?2004h>     pending.sort();
[?2004l[?2004h> 
[?2004l[?2004h>     let (ledger, journal) = out_paths(b, &a.name);
[?2004l[?2004h>     emit_e(&ledger, &trace)?;
[?2004l[?2004h>     note_e(&journal, &trace)?;
[?2004l[?2004h> 
[?2004l[?2004h>     let finished = pending.is_empty();
[?2004l[?2004h>     Ok(CaseReport { name: a.name.clone(), ok: finished, finished, pending, trace, ledger: ledger.display().to_string(), journal: journal.display().to_string() })
[?2004l[?2004h> }
