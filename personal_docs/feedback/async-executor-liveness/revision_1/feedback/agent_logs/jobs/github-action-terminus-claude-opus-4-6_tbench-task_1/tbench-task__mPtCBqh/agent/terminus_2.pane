[?2004l[?2004hroot@499c45b4a0bb:/app# cat > /app/book_b/book.rs << 'EOF'
[?2004l[?2004h> use std::collections::BTreeMap;
[?2004l[?2004h> 
[?2004l[?2004h> use crate::core_a::R0;
[?2004l[?2004h> 
[?2004l[?2004h> /// Process items through multi-turn CAP scheduling.
[?2004l[?2004h> /// Items become ready at their base_turn. Each turn, each lane can accept up to `cap` items.
[?2004l[?2004h> /// Overflow items remain for subsequent turns.
[?2004l[?2004h> /// Returns items in acceptance order: by accepted turn, then lane name, then plan-file seq.
[?2004l[?2004h> pub fn fold_b(a: &[R0], cap: usize) -> Vec<R0> {
[?2004l[?2004h>     let cap = cap.max(1);
[?2004l[?2004h>     
[?2004l[?2004h>     // Find max base_turn to know where items first become ready
[?2004l[?2004h>     let max_base = a.iter().map(|r| r.base_turn).max().unwrap_or(0);
[?2004l[?2004h>     
[?2004l[?2004h>     // Collect all items, grouped by lane
[?2004l[?2004h>     let mut pending_by_lane: BTreeMap<String, Vec<R0>> = BTreeMap::new();
[?2004l[?2004h>     for row in a.iter() {
[?2004l[?2004h>         pending_by_lane.entry(row.lane_name.clone()).or_default().push(row.clone());
[?2004l[?2004h>     }
[?2004l[?2004h>     // Sort each lane's pending by seq (plan-file order)
[?2004l[?2004h>     for items in pending_by_lane.values_mut() {
[?2004l[?2004h>         items.sort_by_key(|r| r.seq);
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     let mut result: Vec<R0> = Vec::new();
[?2004l[?2004h>     let mut accepted: std::collections::BTreeSet<String> = std::collections::BTreeSet::new();
[?2004l[?2004h>     
[?2004l[?2004h>     // Process turn by turn
[?2004l[?2004h>     let mut turn = 0u64;
[?2004l[?2004h>     loop {
[?2004l[?2004h>         let mut accepted_this_round = false;
[?2004l[?2004h>         
[?2004l[?2004h>         for (_lane, items) in pending_by_lane.iter() {
[?2004l[?2004h>             // Count how many ready and not-yet-accepted items exist in this lane for this turn
[?2004l[?2004h>             let ready_count = items.iter()
[?2004l[?2004h>                 .filter(|r| r.base_turn <= turn && !accepted.contains(&r.task_name))
[?2004l[?2004h>                 .count();
[?2004l[?2004h>             if ready_count > 0 {
[?2004l[?2004h>                 accepted_this_round = true;
[?2004l[?2004h>                 break;
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>         
[?2004l[?2004h>         if !accepted_this_round && turn > max_base {
[?2004l[?2004h>             break;
[?2004l[?2004h>         }
[?2004l[?2004h>         
[?2004l[?2004h>         // For each lane (in alphabetical order due to BTreeMap), accept up to cap items
[?2004l[?2004h>         let lanes: Vec<String> = pending_by_lane.keys().cloned().collect();
[?2004l[?2004h>         for lane in &lanes {
[?2004l[?2004h>             let items = pending_by_lane.get(lane).unwrap();
[?2004l[?2004h>             let mut count = 0;
[?2004l[?2004h>             for row in items.iter() {
[?2004l[?2004h>                 if count >= cap {
[?2004l[?2004h>                     break;
[?2004l[?2004h>                 }
[?2004l[?2004h>                 if row.base_turn <= turn && !accepted.contains(&row.task_name) {
[?2004l[?2004h>                     let mut accepted_row = row.clone();
[?2004l[?2004h>                     accepted_row.turn = turn;
[?2004l[?2004h>                     result.push(accepted_row);
[?2004l[?2004h>                     accepted.insert(row.task_name.clone());
[?2004l[?2004h>                     count += 1;
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>         
[?2004l[?2004h>         turn += 1;
[?2004l[?2004h>         
[?2004l[?2004h>         // Safety: if all items have been accepted, stop
[?2004l[?2004h>         if accepted.len() == a.len() {
[?2004l[?2004h>             break;
[?2004l[?2004h>         }
[?2004l[?2004h>         
[?2004l[?2004h>         // Prevent infinite loops
[?2004l[?2004h>         if turn > max_base + a.len() as u64 + 10 {
[?2004l[?2004h>             break;
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     result
[?2004l[?2004h> }
[?2004l[?2004h> EOF
