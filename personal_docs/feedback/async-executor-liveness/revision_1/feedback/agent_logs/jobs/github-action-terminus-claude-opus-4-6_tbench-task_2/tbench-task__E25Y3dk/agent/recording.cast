[118.425171, "i", "cat > /app/gate_c/gate.rs << 'EOF'\nuse std::collections::BTreeSet;\n\nuse crate::core_a::R0;\n\npub struct S1 {\n    pub removed: BTreeSet<String>,\n}\n\nimpl S1 {\n    pub fn new(removed: BTreeSet<String>) -> Self {\n        Self { removed }\n    }\n}\n\npub fn mark_c(a: &S1, b: &R0) -> bool {\n    // Check if any ancestor in the chain is removed\n    for name in &b.chain {\n        if a.removed.contains(name) {\n            return false;\n        }\n    }\n    true\n}\nEOF\n"]
