    57	def compute_dropped(entries: List[Entry]) -> Set[str]:
    58	    # Build parent map from all ROOT/CHILD entries, preserving the declared parent
    59	    parent_of: Dict[str, str] = {}
    60	    children_of: Dict[str, Set[str]] = {}
    61	    drops: List[str] = []
    62	    for e in entries:
    63	        if e.kind in ("ROOT", "CHILD"):
    64	            parent_of.setdefault(e.ident, e.parent)
    65	            children_of.setdefault(e.parent, set()).add(e.ident)
    66	        elif e.kind == "DROP":
    67	            drops.append(e.ident)
    68	
    69	    dropped: Set[str] = set()
    70	    stack: List[str] = list(drops)
    71	    while stack:
    72	        x = stack.pop()
    73	        if x in dropped:
    74	            continue
    75	        dropped.add(x)
    76	        for ch in children_of.get(x, ()):  # descendants by chain links
    77	            if ch not in dropped:
    78	                stack.append(ch)
    79	    return dropped
