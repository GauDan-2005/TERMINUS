[80.802587, "o", "\u001b[?2004h> "]
[80.802796, "o", "def drive_case(case_name: str, plan_path: str, work_dir: str) -> dict:\r\n\u001b[?2004l\r"]
[80.802876, "o", "\u001b[?2004h"]
[80.802947, "o", "> "]
[80.803072, "o", "    name, cap, entries = read_plan(plan_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.80316, "o", "    assert name == case_name\r\n\u001b[?2004l\r"]
[80.803216, "o", "\u001b[?2004h> "]
[80.803334, "o", "    dropped = compute_dropped(entries)\r\n\u001b[?2004l\r"]
[80.803386, "o", "\u001b[?2004h> "]
[80.803521, "o", "    items = build_items(entries, dropped)\r\n\u001b[?2004l\r"]
[80.803574, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[80.80363, "o", "\u001b[?2004h"]
[80.803678, "o", "> "]
[80.80371, "o", "    # Simulate turns\r\n\u001b[?2004l\r"]
[80.803757, "o", "\u001b[?2004h> "]
[80.803866, "o", "    accepted: Set[str] = set()\r\n\u001b[?2004l\r"]
[80.803918, "o", "\u001b[?2004h"]
[80.803977, "o", "> "]
[80.804021, "o", "    trace: List[dict] = []\r\n\u001b[?2004l\r"]
[80.804053, "o", "\u001b[?2004h"]
[80.804114, "o", "> \r\n\u001b[?2004l\r"]
[80.804173, "o", "\u001b[?2004h> "]
[80.804361, "o", "    # upper bound for turns: max(at) plus enough to drain queues\r\n\u001b[?2004l\r"]
[80.804438, "o", "\u001b[?2004h> "]
[80.804601, "o", "    max_at = max([it.at for it in items], default=0)\r\n\u001b[?2004l\r"]
[80.804699, "o", "\u001b[?2004h> "]
[80.804754, "o", "    turn = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.804822, "o", "    stalled_rounds = 0\r\n\u001b[?2004l\r"]
[80.8049, "o", "\u001b[?2004h> "]
[80.804955, "o", "    while True:"]
[80.805008, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.805146, "o", "        if turn > max_at + len(items) + 10:\r\n\u001b[?2004l\r"]
[80.805196, "o", "\u001b[?2004h> "]
[80.805295, "o", "            # safety break\r\n"]
[80.805359, "o", "\u001b[?2004l\r\u001b[?2004h"]
[80.805415, "o", "> "]
[80.80546, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.805493, "o", "\r\n\u001b[?2004l\r"]
[80.805535, "o", "\u001b[?2004h"]
[80.805575, "o", "> "]
[80.805786, "o", "        ready = [it for it in items if it.ident not in accepted and it.at <= turn]\r\n"]
[80.805848, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[80.805931, "o", "        if not ready:\r\n\u001b[?2004l\r"]
[80.805969, "o", "\u001b[?2004h"]
[80.806021, "o", "> "]
[80.806105, "o", "            if turn >= max_at:\r\n\u001b[?2004l\r"]
[80.806157, "o", "\u001b[?2004h> "]
[80.806295, "o", "                # nothing ready now or ever\r\n"]
[80.80635, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[80.80644, "o", "                break\r\n\u001b[?2004l\r"]
[80.806477, "o", "\u001b[?2004h"]
[80.806494, "o", "> "]
[80.806578, "o", "            turn += 1\r\n\u001b[?2004l\r"]
[80.80661, "o", "\u001b[?2004h"]
[80.806623, "o", "> "]
[80.80671, "o", "            continue\r\n\u001b[?2004l\r"]
[80.806742, "o", "\u001b[?2004h"]
[80.806766, "o", "> \r\n\u001b[?2004l\r"]
[80.806813, "o", "\u001b[?2004h> "]
[80.80697, "o", "        # lane order by name within the turn\r\n\u001b[?2004l\r"]
[80.807024, "o", "\u001b[?2004h> "]
[80.807166, "o", "        by_lane: Dict[str, List[Item]] = {}\r\n"]
[80.80722, "o", "\u001b[?2004l\r\u001b[?2004h"]
[80.807275, "o", "> "]
[80.80733, "o", "        for it in ready:\r\n\u001b[?2004l\r"]
[80.80741, "o", "\u001b[?2004h> "]
[80.807552, "o", "            by_lane.setdefault(it.lane, []).append(it)\r\n\u001b[?2004l\r"]
[80.807589, "o", "\u001b[?2004h"]
[80.807682, "o", "> "]
[80.807754, "o", "        for lane in by_lane:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.807992, "o", "            by_lane[lane].sort(key=lambda it: it.seq)  # plan-file order within lane\r\n\u001b[?2004l\r"]
[80.808077, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[80.80815, "o", "> "]
[80.808215, "o", "        accepted_this_turn = 0\r\n\u001b[?2004l\r"]
[80.80835, "o", "\u001b[?2004h> "]
[80.808443, "o", "        for lane in sorted(by_lane.keys()):\r\n\u001b[?2004l\r"]
[80.808604, "o", "\u001b[?2004h> "]
[80.808668, "o", "            take = cap\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.808767, "o", "            for it in by_lane[lane][:take]:\r\n\u001b[?2004l\r"]
