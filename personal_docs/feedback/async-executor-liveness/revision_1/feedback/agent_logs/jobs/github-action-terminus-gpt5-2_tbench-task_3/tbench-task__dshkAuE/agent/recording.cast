[80.787474, "o", "\u001b[?2004h> "]
[80.787608, "o", "    for e in entries:\r\n\u001b[?2004l\r"]
[80.787652, "o", "\u001b[?2004h> "]
[80.78791, "o", "        if e.kind in (\"ROOT\", \"CHILD\"):\r\n\u001b[?2004l\r"]
[80.787958, "o", "\u001b[?2004h> "]
[80.788291, "o", "            parent_of.setdefault(e.ident, e.parent)\r\n\u001b[?2004l\r"]
[80.788348, "o", "\u001b[?2004h> "]
[80.788759, "o", "            children_of.setdefault(e.parent, set()).add(e.ident)\r\n\u001b[?2004l\r"]
[80.788817, "o", "\u001b[?2004h> "]
[80.788987, "o", "        elif e.kind == \"DROP\":\r\n\u001b[?2004l\r\","]
[80.789035, "o", "\u001b[?2004h> "]
[80.789246, "o", "            drops.append(e.ident)\r\n\u001b[?2004l\r"]
[80.789293, "o", "\u001b[?2004h> \r\n"]
[80.78937, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[80.789535, "o", "    dropped: Set[str] = set()\r\n\u001b[?2004l\r"]
[80.78964, "o", "\u001b[?2004h> "]
[80.789822, "o", "    stack: List[str] = list(drops)\r\n\u001b[?2004l\r"]
[80.789841, "o", "\u001b[?2004h"]
[80.789873, "o", "> "]
[80.789992, "o", "    while stack:\r\n\u001b[?2004l\r"]
[80.790044, "o", "\u001b[?2004h> "]
[80.790207, "o", "        x = stack.pop()\r\n\u001b[?2004l\r"]
[80.79026, "o", "\u001b[?2004h> "]
[80.790418, "o", "        if x in dropped:\r\n\u001b[?2004l\r"]
[80.790476, "o", "\u001b[?2004h> "]
[80.790622, "o", "            continue\r\n\u001b[?2004l\r"]
[80.790676, "o", "\u001b[?2004h> "]
[80.790856, "o", "        dropped.add(x)\r\n\u001b[?2004l\r"]
[80.790925, "o", "\u001b[?2004h> "]
[80.791351, "o", "        for ch in children_of.get(x, ()):  # descendants by chain links\r\n\u001b[?2004l\r"]
[80.791427, "o", "\u001b[?2004h> "]
[80.791632, "o", "            if ch not in dropped:\r\n\u001b[?2004l\r"]
[80.79171, "o", "\u001b[?2004h> "]
[80.79191, "o", "                stack.append(ch)\r\n\u001b[?2004l\r"]
[80.791966, "o", "\u001b[?2004h> "]
[80.792085, "o", "    return dropped\r\n\u001b[?2004l\r"]
