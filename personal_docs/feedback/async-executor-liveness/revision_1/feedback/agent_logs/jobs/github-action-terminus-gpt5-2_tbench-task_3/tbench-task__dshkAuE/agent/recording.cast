[24.907708, "i", "sed -n '1,220p' /app/src/main.rs\n"]
[24.908244, "o", "sed -n '1,220p' /app/src/main.rs\r\n\u001b[?2004l\r"]
[24.909875, "o", "use std::env;\r\nuse std::fs;\r\nuse std::io;\r\nuse std::path::{Path, PathBuf};\r\n\r\nuse executor_liveness_lab::drive_g::drive_g;\r\nuse executor_liveness_lab::read_h::read_plan;\r\n"]
[24.90992, "o", "use executor_liveness_lab::serde_f::report_json;\r\nuse executor_liveness_lab::types_f::CaseReport;\r\n\r\nfn arg_value(args: &[String], key: &str) -> Option<String> {\r\n    args.windows(2)\r\n        .find(|w| w[0] == key)\r\n        .map(|w| w[1].to_string())\r\n}\r\n\r\nfn plan_path(root: &Path, name: &str) -> PathBuf {\r\n    root.join(\"data\").join(\"cases\").join(format!(\"{}.plan\", name))\r\n"]
[24.909933, "o", "}\r\n\r\nfn load_names(args: &[String]) -> Vec<String> {\r\n    if let Some(name) = arg_value(args, \"--case\") {\r\n        vec![name]\r\n"]
[24.909945, "o", "    } else {\r\n        [\"amber\", \"cobalt\", \"drake\", \"ember\", \"flint\", \"graphite\"]\r\n"]
[24.909973, "o", "            .iter()\r\n            .map(|s| s.to_string())\r\n"]
[24.909987, "o", "            .collect()\r\n    }\r\n}\r\n\r\nfn drive_x(root: &Path, names: &[String], out: &Path, work: &Path) -> io::Result<Vec<CaseReport>> {\r\n    let mut reports = Vec::new();\r\n    for name in names {\r\n        let plan = read_plan(&plan_path(root, name))?;\r\n"]
[24.909997, "o", "        reports.push(drive_g(&plan, work)?);\r\n    }\r\n"]
[24.91001, "o", "    if let Some(parent) = out.parent() {\r\n        fs::create_dir_all(parent)?;\r\n"]
[24.910025, "o", "    }\r\n    fs::write(out, report_json(&reports))?;\r\n"]
[24.910046, "o", "    Ok(reports)\r\n"]
[24.910058, "o", "}\r\n\r\nfn main() -> io::Result<()> {\r\n"]
[24.910083, "o", "    let args: Vec<String> = env::args().collect();\r\n    let root = PathBuf::from(arg_value(&args, \"--root\").unwrap_or_else(|| \"/app\".to_string()));\r\n"]
[24.9101, "o", "    let out = PathBuf::from(arg_value(&args, \"--out\").unwrap_or_else(|| \"/app/output/executor-audit.json\".to_string()));\r\n    let work = PathBuf::from(arg_value(&args, \"--work\").unwrap_or_else(|| \"/app/output/runtime\".to_string()));\r\n    let names = load_names(&args);\r\n"]
[24.910114, "o", "    let _ = drive_x(&root, &names, &out, &work)?;\r\n    Ok(())\r\n"]
[24.910127, "o", "}\r\n"]
[24.910353, "o", "\u001b[?2004h"]
