[80.786034, "o", "def compute_dropped(entries: List[Entry]) -> Set[str]:\r\n\u001b[?2004l\r"]
[80.7861, "o", "\u001b[?2004h> "]
[80.786616, "o", "    # Build parent map from all ROOT/CHILD entries, preserving the declared parent\r\n\u001b[?2004l\r"]
[80.786669, "o", "\u001b[?2004h> "]
[80.786884, "o", "    parent_of: Dict[str, str] = {}\r\n\u001b[?2004l\r"]
