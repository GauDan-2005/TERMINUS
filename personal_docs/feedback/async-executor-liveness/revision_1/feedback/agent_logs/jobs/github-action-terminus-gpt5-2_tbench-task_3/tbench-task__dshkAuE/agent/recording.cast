[80.809027, "o", "\u001b[?2004h"]
[80.809116, "o", "> "]
[80.809212, "o", "                    continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.809292, "o", "                accepted.add(it.ident)\r\n\u001b[?2004l\r"]
[80.809314, "o", "\u001b[?2004h"]
[80.809415, "o", "> "]
[80.809512, "o", "                trace.append({\r\n\u001b[?2004l\r\u001b[?2004h"]
[80.80958, "o", "> "]
[80.809636, "o", "                    \"case\": case_name,\r\n\u001b[?2004l\r"]
[80.809704, "o", "\u001b[?2004h> "]
[80.809822, "o", "                    \"task\": it.ident,\r\n\u001b[?2004l\r"]
[80.809888, "o", "\u001b[?2004h> "]
[80.810013, "o", "                    \"parent\": it.parent,\r\n\u001b[?2004l\r"]
[80.810051, "o", "\u001b[?2004h"]
[80.810065, "o", "> "]
[80.810191, "o", "                    \"depth\": it.depth,\r\n\u001b[?2004l\r"]
[80.810207, "o", "\u001b[?2004h"]
[80.810257, "o", "> "]
[80.81036, "o", "                    \"lane\": it.lane,\r\n\u001b[?2004l\r"]
[80.810403, "o", "\u001b[?2004h> "]
[80.810518, "o", "                    \"turn\": turn,\r\n\u001b[?2004l\r"]
[80.810562, "o", "\u001b[?2004h> "]
[80.810636, "o", "                })\r\n\u001b[?2004l\r"]
[80.810681, "o", "\u001b[?2004h> "]
[80.810809, "o", "                accepted_this_turn += 1\r\n\u001b[?2004l\r"]
[80.810849, "o", "\u001b[?2004h> "]
[80.810865, "o", "\r\n\u001b[?2004l\r"]
