[53.926488, "o", "use crate::types_f::{CaseReport, Record};\r\n\r\nfn esc(s: &str) -> String {\r\n    s.replace('\\\\', \"\\\\\\\\\").replace('\"', \"\\\\\\\"\")\r\n}\r\n\r\npub fn row_json(row: &Record) -> String {\r\n"]
[53.926524, "o", "    format!(\r\n        \"{{\\\"case\\\":\\\"{}\\\",\\\"task\\\":\\\"{}\\\",\\\"parent\\\":\\\"{}\\\",\\\"depth\\\":{},\\\"lane\\\":\\\"{}\\\",\\\"turn\\\":{}}}\",\r\n        esc(&row.case_name),\r\n        esc(&row.task_name),\r\n        esc(&row.parent_name),\r\n        row.depth,\r\n        esc(&row.lane_name),\r\n        row.turn\r\n"]
[53.926553, "o", "    )\r\n}\r\n\r\nfn string_array(items: &[String]) -> String {\r\n    format!(\r\n"]
[53.926563, "o", "        \"[{}]\",\r\n"]
[53.926572, "o", "        items\r\n            .iter()\r\n            .map(|s| format!(\"\\\"{}\\\"\", esc(s)))\r\n            .collect::<Vec<_>>()\r\n"]
[53.926581, "o", "            .join(\",\")\r\n    )\r\n"]
[53.926591, "o", "}\r\n\r\n"]
[53.926602, "o", "pub fn case_json(case: &CaseReport) -> String {\r\n    let trace = case.trace.iter().map(row_json).collect::<Vec<_>>().join(\",\");\r\n    format!(\r\n        \"{{\\\"name\\\":\\\"{}\\\",\\\"ok\\\":{},\\\"finished\\\":{},\\\"pending\\\":{},\\\"trace\\\":[{}],\\\"ledger\\\":\\\"{}\\\",\\\"journal\\\":\\\"{}\\\"}}\",\r\n        esc(&case.name),\r\n"]
[53.926629, "o", "        if case.ok { \"true\" } else { \"false\" },\r\n        if case.finished { \"true\" } else { \"false\" },\r\n        string_array(&case.pending),\r\n        trace,\r\n        esc(&case.ledger),\r\n        esc(&case.journal)\r\n    )\r\n}"]
[53.926644, "o", "\r\n\r\npub fn report_json(cases: &[CaseReport]) -> String {\r\n"]
[53.926657, "o", "    let body = cases.iter().map(case_json).collect::<Vec<_>>().join(\",\");\r\n    format!(\"{{\\\"cases\\\":[{}]}}\\n\", body)\r\n}\r\n"]
