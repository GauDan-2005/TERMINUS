[98.403605, "i", "python3 - <<'PY'\nimport json\nimport pathlib\n\na=json.load(open('/app/output/executor-audit.json'))\nfor c in a['cases']:\n    led = pathlib.Path(c['ledger'])\n    jrn = pathlib.Path(c['journal'])\n    trace = c['trace']\n\n    led_rows=[json.loads(x) for x in led.read_text().splitlines() if x.strip()]\n    if led_rows!=trace:\n        raise SystemExit(f\"ledger mismatch {c['name']}\")\n\n    jrn_rows=[ln.split() for ln in jrn.read_text().splitlines() if ln.strip()]\n    want=[[r['case'],r['task'],r['parent'],str(r['depth']),r['lane'],str(r['turn'])] for r in trace]\n    if jrn_rows!=want:\n        raise SystemExit(f\"journal mismatch {c['name']}\")\n\nprint('audit/ledger/journal all consistent')\nPY\n"]
