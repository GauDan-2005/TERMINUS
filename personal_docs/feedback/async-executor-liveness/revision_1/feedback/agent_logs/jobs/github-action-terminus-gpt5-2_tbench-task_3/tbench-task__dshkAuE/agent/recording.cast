[91.627289, "o", "    40\t                except ValueError:\r\n    41\t                    cap = 1\r\n    42\t                continue\r\n    43\t            if parts[:1] == [\"ROOT\"] and len(parts) == 4:\r\n    44\t                ident, lane, at = parts[1], parts[2], int(parts[3])\r\n    45\t                entries.append(Entry(\"ROOT\", ident=ident, lane=lane, at=at, parent=\"-\", seq=len(entries)))\r\n    46\t                continue\r\n    47\t            if parts[:1] == [\"CHILD\"] and len(parts) == 5:\r\n    48\t                parent, ident, lane, at = parts[1], parts[2], parts[3], int(parts[4])\r\n    49\t                entries.append(Entry(\"CHILD\", ident=ident, lane=lane, at=at, parent=parent, seq=len(entries)))\r\n    50\t                continue\r\n    51\t            if parts[:1] == [\"DROP\"] and len(parts) == 2:\r\n    52\t                entries.append(Entry(\"DROP\", ident=parts[1], seq=len(entries)))\r\n"]
[91.627321, "o", "    53\t                continue\r\n    54\t    return name, max(1, cap), entries\r\n    55\t\r\n    56\t\r\n    57\tdef compute_dropped(entries: List[Entry]) -> Set[str]:\r\n"]
[91.627428, "o", "    58\t    # Build parent map from all ROOT/CHILD entries, preserving the declared parent\r\n    59\t    parent_of: Dict[str, str] = {}\r\n    60\t    children_of: Dict[str, Set[str]] = {}\r\n    61\t    drops: List[str] = []\r\n    62\t    for e in entries:\r\n    63\t        if e.kind in (\"ROOT\", \"CHILD\"):\r\n    64\t            parent_of.setdefault(e.ident, e.parent)\r\n    65\t            children_of.setdefault(e.parent, set()).add(e.ident)\r\n    66\t        elif e.kind == \"DROP\":\r\n    67\t            drops.append(e.ident)\r\n    68\t\r\n    69\t    dropped: Set[str] = set()\r\n    70\t    stack: List[str] = list(drops)\r\n    71\t    while stack:\r\n"]
[91.62759, "o", "    72\t        x = stack.pop()\r\n    73\t        if x in dropped:\r\n    74\t            continue\r\n    75\t        dropped.add(x)\r\n    76\t        for ch in children_of.get(x, ()):  # descendants by chain links\r\n    77\t            if ch not in dropped:\r\n    78\t                stack.append(ch)\r\n    79\t    return dropped\r\n    80\t\r\n    81\t\r\n    82\tdef build_items(entries: List[Entry], dropped: Set[str]) -> List[Item]:\r\n    83\t    # Deduplicate: repeated logical child entries should appear once in accepted trace.\r\n    84\t    # We'll keep the earliest seq for a given ident.\r\n    85\t    seen: Set[str] = set()\r\n    86\t    items: List[Item] = []\r\n    87\t\r\n    88\t    # For depth, compute by following parent chain as declared; if missing parent, depth=0\r\n    89\t    declared_parent: Dict[str, str] = {}\r\n    90\t    for e in entries:\r\n    91\t        if e.kind in (\"ROOT\", \"CHILD\"):\r\n    92\t            declared_parent.setdefault(e.ident, e.parent)\r\n    93\t\r\n    94\t    def depth_of(ident: str) -> int:\r\n    95\t        d = 0\r\n    96\t"]
[91.627638, "o", "        cur = ident\r\n    97\t        visited = set()\r\n    98\t        while True:\r\n    99\t            p = declared_parent.get(cur, \"-\")\r\n   100\t            if p == \"-\" or p == \"\" or p is None:\r\n   101\t                return d\r\n   102\t            if p in visited:\r\n   103\t                return d\r\n   104\t            visited.add(p)\r\n   105\t            d += 1\r\n   106\t            cur = p\r\n   107\t\r\n   108\t    for e in entries:\r\n   109\t        if e.kind not in (\"ROOT\", \"CHILD\"):\r\n   110\t            continue\r\n"]
