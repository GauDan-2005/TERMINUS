[53.688232, "o", "    pub fn new(removed: BTreeSet<String>) -> Self {\r\n        Self { removed }\r\n    }\r\n}\r\n\r\npub fn mark_c(a: &S1, b: &R0) -> bool {\r\n    !a.removed.contains(&b.task_name)\r\n}\r\n"]
