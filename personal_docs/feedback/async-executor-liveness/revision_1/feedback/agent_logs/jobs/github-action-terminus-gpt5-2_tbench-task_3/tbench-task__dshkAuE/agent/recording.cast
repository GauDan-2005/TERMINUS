[80.792734, "o", "def build_items(entries: List[Entry], dropped: Set[str]) -> List[Item]:\r\n\u001b[?2004l\r"]
[80.792755, "o", "\u001b[?2004h"]
[80.792812, "o", "> "]
[80.793346, "o", "    # Deduplicate: repeated logical child entries should appear once in accepted trace.\r\n\u001b[?2004l\r"]
[80.793391, "o", "\u001b[?2004h> "]
[80.793737, "o", "    # We'll keep the earliest seq for a given ident.\r\n\u001b[?2004l\r"]
[80.793787, "o", "\u001b[?2004h> "]
[80.793946, "o", "    seen: Set[str] = set()\r\n\u001b[?2004l\r"]
