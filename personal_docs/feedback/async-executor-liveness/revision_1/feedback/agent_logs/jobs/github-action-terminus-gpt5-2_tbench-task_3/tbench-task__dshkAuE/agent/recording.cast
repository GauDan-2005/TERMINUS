[54.069001, "o", "use std::collections::BTreeMap;\r\n\r\nuse crate::core_a::E0;\r\nuse crate::types_f::Item;\r\n\r\n"]
[54.069029, "o", "pub struct S2 {\r\n"]
[54.069225, "o", "    pub items: BTreeMap<String, Item>,\r\n}\r\n\r\npub struct R1 {\r\n    pub item: Item,\r\n}\r\n\r\npub struct R2 {\r\n    pub item: Item,\r\n}\r\n\r\nimpl S2 {\r\n    pub fn new() -> Self {\r\n        Self { items: BTreeMap::new() }\r\n    }\r\n}\r\n\r\npub fn bind_d(a: &mut S2, b: R1) -> Result<R2, E0> {\r\n    let mut item = b.item.clone();\r\n    if item.parent != \"-\" {\r\n        item.parent = \"-\".to_string();\r\n        item.depth = 0;\r\n        item.chain = vec![item.ident.clone()];\r\n    }\r\n    a.items.insert(item.ident.clone(), item.clone());\r\n"]
[54.0693, "o", "    Ok(R2 { item })\r\n}\r\n"]
