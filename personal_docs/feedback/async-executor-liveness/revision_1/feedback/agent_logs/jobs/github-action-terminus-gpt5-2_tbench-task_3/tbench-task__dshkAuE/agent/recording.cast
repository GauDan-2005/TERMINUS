[80.794237, "o", "\u001b[?2004h"]
[80.794312, "o", "> "]
[80.794863, "o", "    # For depth, compute by following parent chain as declared; if missing parent, depth=0\r\n\u001b[?2004l\r"]
[80.794885, "o", "\u001b[?2004h> "]
[80.795168, "o", "    declared_parent: Dict[str, str] = {}\r\n\u001b[?2004l\r"]
[80.795187, "o", "\u001b[?2004h"]
[80.795244, "o", "> "]
[80.795359, "o", "    for e in entries:\r\n\u001b[?2004l\r"]
[80.795415, "o", "\u001b[?2004h> "]
[80.795671, "o", "        if e.kind in (\"ROOT\", \"CHILD\"):\r\n\u001b[?2004l\r"]
[80.795712, "o", "\u001b[?2004h> "]
[80.796058, "o", "            declared_parent.setdefault(e.ident, e.parent)\r\n\u001b[?2004l\r"]
[80.79608, "o", "\u001b[?2004h"]
[80.796095, "o", "> \r\n\u001b[?2004l\r"]
[80.796197, "o", "\u001b[?2004h> "]
[80.796419, "o", "    def depth_of(ident: str) -> int:\r\n\u001b[?2004l\r"]
[80.796488, "o", "\u001b[?2004h> "]
[80.796629, "o", "        d = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[80.796647, "o", "> "]
[80.796811, "o", "        cur = ident\r\n\u001b[?2004l\r"]
[80.79688, "o", "\u001b[?2004h"]
[80.796899, "o", "> "]
[80.797038, "o", "        visited = set()\r\n\u001b[?2004l\r"]
[80.797082, "o", "\u001b[?2004h> "]
[80.797236, "o", "        while True:\r\n\u001b[?2004l\r"]
[80.797361, "o", "\u001b[?2004h> "]
[80.797575, "o", "            p = declared_parent.get(cur, \"-\")\r\n\u001b[?2004l\r"]
[80.797628, "o", "\u001b[?2004h> "]
[80.797936, "o", "            if p == \"-\" or p == \"\" or p is None:\r\n\u001b[?2004l\r"]
[80.797963, "o", "\u001b[?2004h"]
[80.798004, "o", "> "]
[80.798159, "o", "                return d\r\n\u001b[?2004l\r"]
[80.798238, "o", "\u001b[?2004h> "]
[80.798408, "o", "            if p in visited:\r\n\u001b[?2004l\r"]
[80.798466, "o", "\u001b[?2004h> "]
[80.798617, "o", "                return d\r\n\u001b[?2004l\r"]
[80.79867, "o", "\u001b[?2004h> "]
[80.798846, "o", "            visited.add(p)\r\n\u001b[?2004l\r"]
[80.798901, "o", "\u001b[?2004h> "]
[80.799029, "o", "            d += 1\r\n\u001b[?2004l\r"]
[80.7991, "o", "\u001b[?2004h> "]
[80.799216, "o", "            cur = p\r\n\u001b[?2004l\r"]
[80.799332, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.799458, "o", "    for e in entries:\r\n\u001b[?2004l\r"]
[80.799516, "o", "\u001b[?2004h> "]
[80.799787, "o", "        if e.kind not in (\"ROOT\", \"CHILD\"):\r\n\u001b[?2004l\r"]
[80.799868, "o", "\u001b[?2004h> "]
[80.799988, "o", "            continue\r\n\u001b[?2004l\r"]
[80.800094, "o", "\u001b[?2004h> "]
[80.800194, "o", "        if e.ident in dropped:\r\n\u001b[?2004l\r"]
[80.800294, "o", "\u001b[?2004h> "]
[80.800398, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[80.800421, "o", "> "]
[80.800483, "o", "        if e.ident in seen:\r\n\u001b[?2004l\r"]
[80.800578, "o", "\u001b[?2004h> "]
[80.800599, "o", "            continue\r\n\u001b[?2004l\r"]
[80.800677, "o", "\u001b[?2004h> "]
[80.800824, "o", "        seen.add(e.ident)\r\n\u001b[?2004l\r"]
[80.80089, "o", "\u001b[?2004h> "]
[80.800921, "o", "        items.append(Item(\r\n\u001b[?2004l\r\u001b[?2004h"]
[80.800972, "o", "> "]
[80.801042, "o", "            ident=e.ident,\r\n\u001b[?2004l\r"]
[80.801089, "o", "\u001b[?2004h"]
[80.801108, "o", "> "]
[80.801195, "o", "            parent=e.parent,\r\n\u001b[?2004l\r"]
[80.801237, "o", "\u001b[?2004h> "]
[80.801362, "o", "            depth=depth_of(e.ident),\r\n\u001b[?2004l\r"]
[80.801404, "o", "\u001b[?2004h> "]
[80.801495, "o", "            lane=e.lane,\r\n\u001b[?2004l\r"]
[80.801536, "o", "\u001b[?2004h> "]
[80.801632, "o", "            at=int(e.at),\r\n\u001b[?2004l\r"]
[80.801677, "o", "\u001b[?2004h> "]
[80.801772, "o", "            seq=int(e.seq),\r\n\u001b[?2004l\r"]
[80.801813, "o", "\u001b[?2004h> "]
[80.801862, "o", "        ))\r\n\u001b[?2004l\r"]
[80.801908, "o", "\u001b[?2004h> "]
[80.801925, "o", "\r\n\u001b[?2004l\r"]
[80.80199, "o", "\u001b[?2004h> "]
[80.802154, "o", "    # Keep global plan-file order for tie-breaking within lane\r\n\u001b[?2004l\r"]
[80.802254, "o", "\u001b[?2004h> "]
[80.802356, "o", "    items.sort(key=lambda it: it.seq)\r\n\u001b[?2004l\r\u001b[?2004h> "]
