[80.773201, "i", "cat > /app/scripts/executor_ctl.py <<'PY'\n#!/usr/bin/env python3\nimport argparse, json, os\nfrom dataclasses import dataclass\nfrom typing import List, Dict, Tuple, Set\n\nCASE_ORDER = [\"amber\", \"cobalt\", \"drake\", \"ember\", \"flint\", \"graphite\"]\n\n@dataclass(frozen=True)\nclass Entry:\n    kind: str  # ROOT, CHILD, DROP\n    ident: str\n    lane: str = \"\"\n    at: int = 0\n    parent: str = \"-\"\n    seq: int = 0\n\n@dataclass\nclass Item:\n    ident: str\n    parent: str\n    depth: int\n    lane: str\n    at: int\n    seq: int\n\n\ndef read_plan(path: str) -> Tuple[str, int, List[Entry]]:\n    name = os.path.splitext(os.path.basename(path))[0]\n    cap = 1\n    entries: List[Entry] = []\n    with open(path, \"r\", encoding=\"utf-8\") as f:\n        for raw in f:\n            line = raw.strip()\n            if not line or line.startswith(\"#\"):\n                continue\n            parts = line.split()\n            if parts[:1] == [\"CAP\"] and len(parts) == 2:\n                try:\n                    cap = int(parts[1])\n                except ValueE"]
[80.777882, "i", "rror:\n                    cap = 1\n                continue\n            if parts[:1] == [\"ROOT\"] and len(parts) == 4:\n                ident, lane, at = parts[1], parts[2], int(parts[3])\n                entries.append(Entry(\"ROOT\", ident=ident, lane=lane, at=at, parent=\"-\", seq=len(entries)))\n                continue\n            if parts[:1] == [\"CHILD\"] and len(parts) == 5:\n                parent, ident, lane, at = parts[1], parts[2], parts[3], int(parts[4])\n                entries.append(Entry(\"CHILD\", ident=ident, lane=lane, at=at, parent=parent, seq=len(entries)))\n                continue\n            if parts[:1] == [\"DROP\"] and len(parts) == 2:\n                entries.append(Entry(\"DROP\", ident=parts[1], seq=len(entries)))\n                continue\n    return name, max(1, cap), entries\n\n\ndef compute_dropped(entries: List[Entry]) -> Set[str]:\n    # Build parent map from all ROOT/CHILD entries, preserving the declared parent\n    parent_of: Dict[str, str] = {}\n    children_of: Dict[str, Set[str]] = {}\n    drop"]
[80.77801, "o", "cat > /app/scripts/executor_ctl.py <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> import argparse, json, os\r\n\u001b[?2004l\r\u001b[?2004h> from dataclasses import dataclass\r\n\u001b[?2004l\r\u001b[?2004h> from typing import List, Dict, Tuple, Set\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> CASE_ORDER = [\"amber\", \"cobalt\", \"drake\", \"ember\", \"flint\", \"graphite\"]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> @dataclass(frozen=True)\r\n\u001b[?2004l\r\u001b[?2004h> class Entry:\r\n\u001b[?2004l\r\u001b[?2004h>     kind: str  # ROOT, CHILD, DROP\r\n\u001b[?2004l\r\u001b[?2004h>     ident: str\r\n\u001b[?2004l\r\u001b[?2004h>     lane: str = \"\"\r\n\u001b[?2004l\r\u001b[?2004h>     at: int = 0\r\n\u001b[?2004l\r\u001b[?2004h>     parent: str = \"-\"\r\n\u001b[?2004l\r\u001b[?2004h>     seq: int = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> @dataclass\r\n\u001b[?2004l\r\u001b[?2004h> class Item:\r\n\u001b[?2004l\r\u001b[?2004h>     ident: str\r\n\u001b[?2004l\r\u001b[?2004h>     parent: str\r\n\u001b[?2004l\r\u001b[?2004h>     depth: int\r\n\u001b[?2004l\r\u001b[?2004h>     lane: str\r\n\u001b[?2004l\r\u001b[?2004h>     at: int\r\n\u001b[?2004l\r\u001b[?2004h>     seq: int\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b["]
[80.778037, "i", "s: List[str] = []\n    for e in entries:\n        if e.kind in (\"ROOT\", \"CHILD\"):\n            parent_of.setdefault(e.ident, e.parent)\n            children_of.setdefault(e.parent, set()).add(e.ident)\n        elif e.kind == \"DROP\":\n            drops.append(e.ident)\n\n    dropped: Set[str] = set()\n    stack: List[str] = list(drops)\n    while stack:\n        x = stack.pop()\n        if x in dropped:\n            continue\n        dropped.add(x)\n        for ch in children_of.get(x, ()):  # descendants by chain links\n            if ch not in dropped:\n                stack.append(ch)\n    return dropped\n\n\ndef build_items(entries: List[Entry], dropped: Set[str]) -> List[Item]:\n    # Deduplicate: repeated logical child entries should appear once in accepted trace.\n    # We'll keep the earliest seq for a given ident.\n    seen: Set[str] = set()\n    items: List[Item] = []\n\n    # For depth, compute by following parent chain as declared; if missing parent, depth=0\n    declared_parent: Dict[str, str] = {}\n    for e in entries:\n    "]
[80.778061, "o", "?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def read_plan(path: str) -> Tuple[str, int, List[Entry]]:\r\n\u001b[?2004l\r\u001b[?2004h>     name = os.path.splitext(os.path.basename(path))[0]\r\n\u001b[?2004l\r\u001b[?2004h>     cap = 1\r\n\u001b[?2004l\r\u001b[?2004h>     entries: List[Entry] = []\r\n\u001b[?2004l\r\u001b[?2004h>     with open(path, \"r\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         for raw in f:\r\n\u001b[?2004l\r\u001b[?2004h>             line = raw.strip()\r\n\u001b[?2004l\r\u001b[?2004h>             if not line or line.startswith(\"#\"):\r\n\u001b[?2004l\r\u001b[?2004h>                 continue\r\n\u001b[?2004l\r\u001b[?2004h>             parts = line.split()"]
[80.778075, "i", "    if e.kind in (\"ROOT\", \"CHILD\"):\n            declared_parent.setdefault(e.ident, e.parent)\n\n    def depth_of(ident: str) -> int:\n        d = 0\n        cur = ident\n        visited = set()\n        while True:\n            p = declared_parent.get(cur, \"-\")\n            if p == \"-\" or p == \"\" or p is None:\n                return d\n            if p in visited:\n                return d\n            visited.add(p)\n            d += 1\n            cur = p\n\n    for e in entries:\n        if e.kind not in (\"ROOT\", \"CHILD\"):\n            continue\n        if e.ident in dropped:\n            continue\n        if e.ident in seen:\n            continue\n        seen.add(e.ident)\n        items.append(Item(\n            ident=e.ident,\n            parent=e.parent,\n            depth=depth_of(e.ident),\n            lane=e.lane,\n            at=int(e.at),\n            seq=int(e.seq),\n        ))\n\n    # Keep global plan-file order for tie-breaking within lane\n    items.sort(key=lambda it: it.seq)\n    return items\n\n\ndef drive_case(case_name: st"]
[80.778088, "i", "r, plan_path: str, work_dir: str) -> dict:\n    name, cap, entries = read_plan(plan_path)\n    assert name == case_name\n    dropped = compute_dropped(entries)\n    items = build_items(entries, dropped)\n\n    # Simulate turns\n    accepted: Set[str] = set()\n    trace: List[dict] = []\n\n    # upper bound for turns: max(at) plus enough to drain queues\n    max_at = max([it.at for it in items], default=0)\n    turn = 0\n    stalled_rounds = 0\n    while True:\n        if turn > max_at + len(items) + 10:\n            # safety break\n            break\n\n        ready = [it for it in items if it.ident not in accepted and it.at <= turn]\n        if not ready:\n            if turn >= max_at:\n                # nothing ready now or ever\n                break\n            turn += 1\n            continue\n\n        # lane order by name within the turn\n        by_lane: Dict[str, List[Item]] = {}\n        for it in ready:\n            by_lane.setdefault(it.lane, []).append(it)\n        for lane in by_lane:\n            by_lane[lane].sort(key=lambd"]
[80.778099, "i", "a it: it.seq)  # plan-file order within lane\n\n        accepted_this_turn = 0\n        for lane in sorted(by_lane.keys()):\n            take = cap\n            for it in by_lane[lane][:take]:\n                if it.ident in accepted:\n                    continue\n                accepted.add(it.ident)\n                trace.append({\n                    \"case\": case_name,\n                    \"task\": it.ident,\n                    \"parent\": it.parent,\n                    \"depth\": it.depth,\n                    \"lane\": it.lane,\n                    \"turn\": turn,\n                })\n                accepted_this_turn += 1\n\n        if accepted_this_turn == 0:\n            stalled_rounds += 1\n            if stalled_rounds > 2:\n                break\n        else:\n            stalled_rounds = 0\n\n        turn += 1\n\n    pending = sorted([it.ident for it in items if it.ident not in accepted])\n    finished = (len(pending) == 0)\n\n    led_dir = os.path.join(work_dir, \"ledgers\")\n    jrn_dir = os.path.join(work_dir, \"journals\")\n    os.m"]
[80.778114, "i", "akedirs(led_dir, exist_ok=True)\n    os.makedirs(jrn_dir, exist_ok=True)\n    ledger_path = os.path.join(led_dir, f\"{case_name}.jsonl\")\n    journal_path = os.path.join(jrn_dir, f\"{case_name}.txt\")\n\n    with open(ledger_path, \"w\", encoding=\"utf-8\") as f:\n        for row in trace:\n            f.write(json.dumps(row, separators=(\",\", \":\")) + \"\\n\")\n\n    with open(journal_path, \"w\", encoding=\"utf-8\") as f:\n        for row in trace:\n            f.write(f\"{row['case']} {row['task']} {row['parent']} {row['depth']} {row['lane']} {row['turn']}\\n\")\n\n    return {\n        \"name\": case_name,\n        \"ok\": finished,\n        \"finished\": finished,\n        \"pending\": pending,\n        \"trace\": trace,\n        \"ledger\": ledger_path,\n        \"journal\": journal_path,\n    }\n\n\ndef main():\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\"--root\", default=\"/app\")\n    ap.add_argument(\"--case\", default=None)\n    ap.add_argument(\"--out\", default=\"/app/output/executor-audit.json\")\n    ap.add_argument(\"--work\", default=\"/app/output/run"]
[80.778125, "i", "time\")\n    args = ap.parse_args()\n\n    names = [args.case] if args.case else CASE_ORDER\n    cases = []\n    for nm in names:\n        plan_path = os.path.join(args.root, \"data\", \"cases\", f\"{nm}.plan\")\n        cases.append(drive_case(nm, plan_path, args.work))\n\n    os.makedirs(os.path.dirname(args.out), exist_ok=True)\n    with open(args.out, \"w\", encoding=\"utf-8\") as f:\n        json.dump({\"cases\": cases}, f, indent=None, separators=(\",\", \":\"))\n        f.write(\"\\n\")\n\nif __name__ == \"__main__\":\n    main()\nPY\nchmod +x /app/scripts/executor_ctl.py\n"]
