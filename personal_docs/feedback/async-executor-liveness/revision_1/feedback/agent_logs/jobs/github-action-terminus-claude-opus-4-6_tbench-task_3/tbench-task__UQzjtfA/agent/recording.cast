[105.67829, "o", "\u001b[?2004h> "]
[105.678502, "o", "pub fn drive_g(a: &Plan, b: &Path) -> io::Result<CaseReport> {\r\n\u001b[?2004l\r"]
[105.67857, "o", "\u001b[?2004h"]
[105.678624, "o", "> "]
[105.678789, "o", "    let mut host = S2::new();\r\n\u001b[?2004l\r"]
[105.678813, "o", "\u001b[?2004h"]
[105.678884, "o", "> "]
[105.679087, "o", "    let mut removed: BTreeSet<String> = BTreeSet::new();\r\n"]
[105.679163, "o", "\u001b[?2004l\r"]
[105.679214, "o", "\u001b[?2004h"]
[105.679292, "o", "> "]
[105.679543, "o", "    let mut items: Vec<Item> = Vec::new();\r\n"]
[105.679599, "o", "\u001b[?2004l\r"]
[105.679638, "o", "\u001b[?2004h> "]
[105.679829, "o", "    let mut seen_idents: HashSet<String> = HashSet::new();\r\n\u001b[?2004l\r"]
[105.679887, "o", "\u001b[?2004h"]
[105.679995, "o", "> \r\n\u001b[?2004l\r"]
[105.680039, "o", "\u001b[?2004h> "]
[105.68012, "o", "    for entry in &a.entries {\r\n\u001b[?2004l\r"]
[105.680168, "o", "\u001b[?2004h> "]
[105.68028, "o", "        match entry {"]
[105.680349, "o", "\r\n\u001b[?2004l\r"]
[105.68042, "o", "\u001b[?2004h"]
[105.680441, "o", "> "]
[105.680698, "o", "            Entry::Root { ident, lane, at, seq } => {\r\n\u001b[?2004l\r"]
[105.681027, "o", "\u001b[?2004h>                 if seen_idents.contains(ident) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.681133, "o", "                    continue; // deduplicate\r\n\u001b[?2004l\r"]
[105.681211, "o", "\u001b[?2004h> "]
[105.68127, "o", "                }\r\n\u001b[?2004l\r"]
[105.681321, "o", "\u001b[?2004h> "]
[105.681505, "o", "                seen_idents.insert(ident.clone());\r\n\u001b[?2004l\r"]
[105.681535, "o", "\u001b[?2004h> "]
[105.682009, "o", "                let item = Item { ident: ident.clone(), parent: \"-\".to_string(), lane: lane.clone(), at: *at, seq: *seq, depth: 0, chain: vec![ident.clone()] };\r\n\u001b[?2004l\r"]
[105.682035, "o", "\u001b[?2004h"]
[105.682094, "o", "> "]
[105.682398, "o", "                let moved = bind_d(&mut host, R1 { item }).map_err(|_| io::Error::new(io::ErrorKind::Other, \"state\"))?;\r\n\u001b[?2004l\r"]
[105.682494, "o", "\u001b[?2004h> "]
[105.682621, "o", "                items.push(moved.item);\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.682645, "o", "> "]
[105.682772, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.68294, "o", "            Entry::Child { from, ident, lane, at, seq } => {\r\n\u001b[?2004l\r"]
[105.683033, "o", "\u001b[?2004h"]
[105.683055, "o", "> "]
[105.683191, "o", "                if seen_idents.contains(ident) {\r\n\u001b[?2004l\r"]
[105.683275, "o", "\u001b[?2004h> "]
[105.683391, "o", "                    continue; // deduplicate\r\n\u001b[?2004l\r"]
[105.683413, "o", "\u001b[?2004h"]
[105.683502, "o", ">                 }\r\n\u001b[?2004l\r"]
[105.683522, "o", "\u001b[?2004h"]
[105.683587, "o", "> "]
[105.683741, "o", "                seen_idents.insert(ident.clone());\r\n\u001b[?2004l\r"]
[105.683763, "o", "\u001b[?2004h"]
[105.68383, "o", "> "]
[105.684046, "o", "                let parent = items.iter().find(|i| i.ident == *from).cloned();\r\n\u001b[?2004l\r"]
[105.684068, "o", "\u001b[?2004h> "]
[105.684364, "o", "                let depth = parent.as_ref().map(|p| p.depth + 1).unwrap_or(0);\r\n\u001b[?2004l\r"]
[105.684388, "o", "\u001b[?2004h> "]
[105.684684, "o", "                let mut chain = parent.map(|p| p.chain.clone()).unwrap_or_default();\r\n\u001b[?2004l\r"]
[105.684716, "o", "\u001b[?2004h> "]
[105.684928, "o", "                chain.push(ident.clone());\r\n\u001b[?2004l\r"]
[105.684958, "o", "\u001b[?2004h"]
[105.68503, "o", "> "]
[105.685442, "o", "                let item = Item { ident: ident.clone(), parent: from.clone(), lane: lane.clone(), at: *at, seq: *seq, depth, chain };\r\n\u001b[?2004l\r"]
[105.685471, "o", "\u001b[?2004h> "]
[105.685917, "o", "                let moved = bind_d(&mut host, R1 { item }).map_err(|_| io::Error::new(io::ErrorKind::Other, \"state\"))?;\r\n\u001b[?2004l\r"]
[105.686004, "o", "\u001b[?2004h"]
[105.686067, "o", "> "]
[105.686192, "o", "                items.push(moved.item);\r\n\u001b[?2004l\r"]
[105.686224, "o", "\u001b[?2004h> "]
[105.6863, "o", "            }\r\n\u001b[?2004l\r"]
[105.686401, "o", "\u001b[?2004h> "]
[105.68657, "o", "            Entry::Drop { ident } => {\r\n\u001b[?2004l\r"]
[105.686593, "o", "\u001b[?2004h> "]
[105.686764, "o", "                removed.insert(ident.clone());"]
[105.68685, "o", "\r\n\u001b[?2004l\r"]
[105.686942, "o", "\u001b[?2004h> "]
[105.687049, "o", "            }\r\n\u001b[?2004l\r"]
[105.687156, "o", "\u001b[?2004h"]
[105.687185, "o", "> "]
[105.687316, "o", "        }\r\n\u001b[?2004l\r"]
[105.687434, "o", "\u001b[?2004h"]
[105.687462, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[105.687531, "o", "\u001b[?2004h"]
[105.687657, "o", "> "]
[105.687812, "o", "    let gate = S1::new(removed);\r\n\u001b[?2004l\r"]
[105.687911, "o", "\u001b[?2004h> "]
[105.688052, "o", "    let mut state = S0::new();\r\n"]
[105.688103, "o", "\u001b[?2004l\r"]
[105.688123, "o", "\u001b[?2004h> "]
[105.688245, "o", "    for item in &items {\r\n\u001b[?2004l\r"]
[105.688301, "o", "\u001b[?2004h"]
[105.68844, "o", "> "]
[105.688635, "o", "        let row = R0::from_item(&a.name, item);\r\n\u001b[?2004l\r"]
[105.688694, "o", "\u001b[?2004h> "]
[105.688881, "o", "        if mark_c(&gate, &row) {\r\n\u001b[?2004l\r"]
[105.688961, "o", "\u001b[?2004h"]
[105.689058, "o", "> "]
[105.689375, "o", "            op_a(&mut state, row).map_err(|_| io::Error::new(io::ErrorKind::Other, \"row\"))?;\r\n\u001b[?2004l\r"]
[105.689406, "o", "\u001b[?2004h"]
[105.689473, "o", "> "]
[105.689542, "o", "        }\r\n"]
[105.689559, "o", "\u001b[?2004l\r"]
[105.689635, "o", "\u001b[?2004h"]
[105.689696, "o", "> "]
[105.68974, "o", "    }\r\n"]
[105.689832, "o", "\u001b[?2004l\r"]
[105.68989, "o", "\u001b[?2004h> "]
[105.689967, "o", "\r\n\u001b[?2004l\r"]
[105.690073, "o", "\u001b[?2004h"]
[105.690158, "o", "> "]
[105.6903, "o", "    let ordered = fold_b(&state.rows, a.cap);\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.690408, "o", "> "]
[105.690634, "o", "    let trace: Vec<Record> = ordered.iter().map(R0::pack_a).collect();\r\n\u001b[?2004l\r"]
[105.690728, "o", "\u001b[?2004h> "]
[105.691101, "o", "    let accepted: BTreeSet<String> = trace.iter().map(|row| row.task_name.clone()).collect();\r\n\u001b[?2004l\r"]
[105.69125, "o", "\u001b[?2004h> "]
[105.6917, "o", "    let mut pending: Vec<String> = state.rows.iter().filter(|row| !accepted.contains(&row.task_name)).map(|row| row.task_name.clone()).collect();"]
[105.691787, "o", "\r\n"]
[105.691858, "o", "\u001b[?2004l\r"]
[105.691957, "o", "\u001b[?2004h"]
[105.692038, "o", "> "]
[105.692173, "o", "    pending.sort();\r\n\u001b[?2004l\r"]
[105.692234, "o", "\u001b[?2004h"]
[105.692386, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[105.692418, "o", "> "]
[105.692609, "o", "    let (ledger, journal) = out_paths(b, &a.name);\r\n"]
[105.69265, "o", "\u001b[?2004l\r"]
[105.692725, "o", "\u001b[?2004h"]
[105.692749, "o", "> "]
[105.692918, "o", "    emit_e(&ledger, &trace)?;\r\n\u001b[?2004l\r"]
[105.692943, "o", "\u001b[?2004h"]
[105.692955, "o", "> "]
[105.693085, "o", "    note_e(&journal, &trace)?;\r\n\u001b[?2004l\r"]
[105.693114, "o", "\u001b[?2004h> "]
[105.693127, "o", "\r\n\u001b[?2004l\r"]
[105.693235, "o", "\u001b[?2004h"]
[105.693257, "o", "> "]
[105.693351, "o", "    let finished = pending.is_empty();\r\n\u001b[?2004l\r"]
[105.693371, "o", "\u001b[?2004h> "]
[105.693896, "o", "    Ok(CaseReport { name: a.name.clone(), ok: finished, finished, pending, trace, ledger: ledger.display().to_string(), journal: journal.display().to_string() })\r\n\u001b[?2004l\r"]
[105.693972, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[105.693996, "o", "\u001b[?2004h> "]
