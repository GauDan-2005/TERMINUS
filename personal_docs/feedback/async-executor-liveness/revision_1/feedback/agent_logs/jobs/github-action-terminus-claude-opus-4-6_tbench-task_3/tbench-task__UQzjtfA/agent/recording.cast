[42.910155, "o", "pub fn fold_hint(values: &[usize], cap: usize) -> Vec<usize> {\r\n    values.iter().copied().filter(|v| *v <= cap).collect()\r\n}\r\n\r\npub fn bucket_hint(values: &[usize]) -> usize {\r\n    values.iter().fold(0usize, |acc, v| acc.saturating_add(*v))\r\n}\r\n"]
