Sending keys: ['cat > /app/scripts/executor_ctl.py <<\'PY\'\n#!/usr/bin/env python3\nimport argparse, json, os\nfrom dataclasses import dataclass\nfrom typing import List, Dict, Tuple\n\n@dataclass\nclass Entry:\n    kind: str\n    ident: str\n    lane: str = ""\n    at: int = 0\n    seq: int = 0\n    parent: str = "-"\n\n@dataclass\nclass Item:\n    ident: str\n    parent: str\n    depth: int\n    lane: str\n    at: int\n    seq: int\n    chain: Tuple[str, ...]\n\n\ndef read_plan(path: str):\n    name = os.path.splitext(os.path.basename(path))[0]\n    cap = 1\n    entries: List[Entry] = []\n    with open(path, \'r\', encoding=\'utf-8\') as f:\n        for raw in f:\n            line = raw.strip()\n            if not line or line.startswith(\'#\'):\n                continue\n            parts = line.split()\n            if parts[:1] == ["CAP"] and len(parts) == 2:\n                try:\n                    cap = int(parts[1])\n                except ValueError:\n                    cap = 1\n            elif parts[:1] == ["ROOT"] and len(parts) == 4:\n                ident, lane, at = parts[1], parts[2], int(parts[3])\n                entries.append(Entry("ROOT", ident, lane=lane, at=at, seq=len(entries), parent="-"))\n            elif parts[:1] == ["CHILD"] and len(parts) == 5:\n                parent, ident, lane, at = parts[1], parts[2], parts[3], int(parts[4])\n                entries.append(Entry("CHILD", ident, lane=lane, at=at, seq=len(entries), parent=parent))\n            elif parts[:1] == ["DROP"] and len(parts) == 2:\n                entries.append(Entry("DROP", parts[1], seq=len(entries)))\n            else:\n                # ignore unknown lines\n                pass\n    return name, max(1, cap), entries\n\n\ndef build_items(entries: List[Entry]) -> Tuple[Dict[str, Item], List[str]]:\n    # Build parent links and depth/chain based on known items so far.\n    items: Dict[str, Item] = {}\n    drops: List[str] = []\n    for e in entries:\n        if e.kind == "DROP":\n            drops.append(e.ident)\n            continue\n\n        parent_item = items.get(e.parent) if e.kind == "CHILD" else None\n        depth = (parent_item.depth + 1) if parent_item else 0\n        chain = (parent_item.chain + (e.ident,)) if parent_item else (e.ident,)\n        it = Item(\n            ident=e.ident,\n            parent=e.parent if e.kind == "CHILD" else "-",\n            depth=depth,\n            lane=e.lane,\n            at=e.at,\n            seq=e.seq,\n            chain=chain,\n        )\n        # Dedupe repeated logical entries: keep earliest plan occurrence.\n        if it.ident in items:\n            if it.seq < items[it.ident].seq:\n                items[it.ident] = it\n        else:\n            items[it.ident] = it\n    return items, drops\n\n\ndef apply_drops(items: Dict[str, Item], drops: List[str]) -> Dict[str, Item]:\n    if not drops:\n        return dict(items)\n\n    drop_set = set(drops)\n    # Remove dropped names and descendants linked through child chain.\n    out: Dict[str, Item] = {}\n    for ident, it in items.items():\n        if any(name in drop_set for name in it.chain):\n            continue\n        out[ident] = it\n    return out\n\n\ndef simulate(case: str, cap: int, items: Dict[str, Item]):\n    # Turn-based acceptance, per-lane cap each turn.\n    # Eligibility is based only on arrival turn (at), not parent acceptance.\n    accepted: Dict[str, int] = {}\n    trace = []\n\n    if not items:\n        return trace, []\n\n    max_at = max(it.at for it in items.values())\n    # Safe bound: enough turns to drain worst-case (all in one lane)\n    max_turns = max_at + len(items) + 5\n\n    for turn in range(0, max_turns + 1):\n        # group ready items by lane\n        ready_by_lane: Dict[str, List[Item]] = {}\n        for it in items.values():\n            if it.ident in accepted:\n                continue\n            if it.at <= turn:\n                ready_by_lane.setdefault(it.lane, []).append(it)\n        if not ready_by_lane:\n            # if nothing ready and all accepted, done; else continue until something becomes ready\n            if len(accepted) == len(items):\n                break\n            continue\n\n        accepted_this_turn = []\n        for lane in sorted(ready_by_lane.keys()):\n            lane_items = sorted(ready_by_lane[lane], key=lambda x: x.seq)\n            for it in lane_items[:cap]:\n                accepted[it.ident] = turn\n                accepted_this_turn.append(it)\n\n        # append in acceptance order: lower accepted turn first; lanes ordered by name within turn;\n        # ready work within a lane keeps plan-file order.\n        for it in sorted(accepted_this_turn, key=lambda x: (x.lane, x.seq)):\n            trace.append({\n                "case": case,\n                "task": it.ident,\n                "parent": it.parent,\n                "depth": it.depth,\n                "lane": it.lane,\n                "turn": accepted[it.ident],\n            })\n\n        if len(accepted) == len(items):\n            break\n\n    pending = sorted([it.ident for it in items.values() if it.ident not in accepted])\n    return trace, pending\n\n\ndef write_ledger(path: str, trace: List[dict]):\n    os.makedirs(os.path.dirname(path), exist_ok=True)\n    with open(path, \'w\', encoding=\'utf-8\') as f:\n        for row in trace:\n            f.write(json.dumps(row, separators=(",", ":"), ensure_ascii=False))\n            f.write("\\n")\n\n\ndef write_journal(path: str, trace: List[dict]):\n    os.makedirs(os.path.dirname(path), exist_ok=True)\n    with open(path, \'w\', encoding=\'utf-8\') as f:\n        for row in trace:\n            f.write(f"{row[\'case\']} {row[\'task\']} {row[\'parent\']} {row[\'depth\']} {row[\'lane\']} {row[\'turn\']}\\n")\n\n\ndef main():\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\'--case\', dest=\'case_name\')\n    ap.add_argument(\'--root\', default=\'/app\')\n    ap.add_argument(\'--out\', default=\'/app/output/executor-audit.json\')\n    ap.add_argument(\'--work\', default=\'/app/output/runtime\')\n    args = ap.parse_args()\n\n    names = [args.case_name] if args.case_name else ["amber", "cobalt", "drake", "ember", "flint", "graphite"]\n\n    cases_out = []\n    for name in names:\n        plan_path = os.path.join(args.root, \'data\', \'cases\', f\'{name}.plan\')\n        case_name, cap, entries = read_plan(plan_path)\n        items, drops = build_items(entries)\n        items = apply_drops(items, drops)\n        trace, pending = simulate(case_name, cap, items)\n\n        ledger_path = os.path.join(args.work, \'ledgers\', f\'{case_name}.jsonl\')\n        journal_path = os.path.join(args.work, \'journals\', f\'{case_name}.txt\')\n        write_ledger(ledger_path, trace)\n        write_journal(journal_path, trace)\n\n        finished = (len(pending) == 0)\n        cases_out.append({\n            "name": case_name,\n            "ok": finished,\n            "finished": finished,\n            "pending": pending,\n            "trace": trace,\n            "ledger": ledger_path,\n            "journal": journal_path,\n        })\n\n    os.makedirs(os.path.dirname(args.out), exist_ok=True)\n    with open(args.out, \'w\', encoding=\'utf-8\') as f:\n        json.dump({"cases": cases_out}, f, separators=(",", ":"), ensure_ascii=False)\n        f.write("\\n")\n\nif __name__ == \'__main__\':\n    main()\nPY\nchmod +x /app/scripts/executor_ctl.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
