[?2004l[?2004h>             'depth': int(depth),
[?2004l[?2004h>             'lane': lane,
[?2004l[?2004h>             'turn': int(turn),
[?2004l[?2004h>         })
[?2004l[?2004h>     assert journal_rows == trace
