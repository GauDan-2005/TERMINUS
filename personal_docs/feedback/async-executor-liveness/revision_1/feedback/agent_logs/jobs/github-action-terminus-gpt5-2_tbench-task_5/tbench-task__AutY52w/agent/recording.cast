[77.208138, "o", "\u001b[?2004hroot@c3345729cf84:/app# chmod +x /app/scripts/run-matrix.sh\r\n"]
[77.208184, "o", "\u001b[?2004l\r"]
[77.208874, "o", "\u001b[?2004h"]
