[76.191687, "o", "from typing import List, Dict, Tuple\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> @dataclass\r\n\u001b[?2004l\relse None\r\n        depth = (parent_item.depth + 1) if parent_item else 0\r\n        chain = (parent_item.chain + (e.ident,)) if parent_item else (e.ident,)\r\n        it = Item(\r\n            ident=e.ident,\r\n            parent=e.parent if e.kind == \"CHILD\" else \"-\",\r\n            depth=depth,\r\n            lane=e.lane,\r\n            at=e.at,\r\n            seq=e.seq,\r\n            chain=chain,\r\n        )\r\n        # Dedupe repeated logical entries: keep earliest plan occurrence.\r\n        if it.ident in items:\r\n            if it.seq < items[it.ident].seq:\r\n                items[it.ident] = it\r\n        else:\r\n            items[it.ident] = it\r\n    return items, drops\r\n\r\n\r\ndef apply_drops(items: Dict[str, Item], drops: List[str]) -> Dict[str, Item]:\r\n    if not drops:\r\n        return dict(items)\r\n\r\n    drop_set = set(drops)\r\n    # Remove dropped names and descendants linked through child chain.\r\n    out: Dict[str, Item] = {}\r\n "]
[76.191709, "i", "t] = it\n    return out\n\n\ndef simulate(case: str, cap: int, items: Dict[str, Item]):\n    # Turn-based acceptance, per-lane cap each turn.\n    # Eligibility is based only on arrival turn (at), not parent acceptance.\n    accepted: Dict[str, int] = {}\n    trace = []\n\n    if not items:\n        return trace, []\n\n    max_at = max(it.at for it in items.values())\n    # Safe bound: enough turns to drain worst-case (all in one lane)\n    max_turns = max_at + len(items) + 5\n\n    for turn in range(0, max_turns + 1):\n        # group ready items by lane\n        ready_by_lane: Dict[str, List[Item]] = {}\n        for it in items.values():\n            if it.ident in accepted:\n                continue\n            if it.at <= turn:\n                ready_by_lane.setdefault(it.lane, []).append(it)\n        if not ready_by_lane:\n            # if nothing ready and all accepted, done; else continue until something becomes ready\n            if len(accepted) == len(items):\n                break\n            continue\n\n        accepted_this_"]
[76.19174, "o", "   for ident, it in items.items():\r\n        if any(name in drop_set for name in it.chain):\r\n            continue\r\n        out[iden"]
[76.191836, "i", "turn = []\n        for lane in sorted(ready_by_lane.keys()):\n            lane_items = sorted(ready_by_lane[lane], key=lambda x: x.seq)\n            for it in lane_items[:cap]:\n                accepted[it.ident] = turn\n                accepted_this_turn.append(it)\n\n        # append in acceptance order: lower accepted turn first; lanes ordered by name within turn;\n        # ready work within a lane keeps plan-file order.\n        for it in sorted(accepted_this_turn, key=lambda x: (x.lane, x.seq)):\n            trace.append({\n                \"case\": case,\n                \"task\": it.ident,\n                \"parent\": it.parent,\n                \"depth\": it.depth,\n                \"lane\": it.lane,\n                \"turn\": accepted[it.ident],\n            })\n\n        if len(accepted) == len(items):\n            break\n\n    pending = sorted([it.ident for it in items.values() if it.ident not in accepted])\n    return trace, pending\n\n\ndef write_ledger(path: str, trace: List[dict]):\n    os.makedirs(os.path.dirname(path), exist_ok=T"]
