[77.204993, "i", "cat > /app/scripts/run-matrix.sh <<'SH'\n#!/bin/bash\nset -euo pipefail\n\nbash /app/scripts/clean-room.sh\npython3 /app/scripts/executor_ctl.py --out /app/output/executor-audit.json --work /app/output/runtime --root /app\nSH\nchmod +x /app/scripts/run-matrix.sh\n"]
[77.206155, "o", "cat > /app/scripts/run-matrix.sh <<'SH'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[77.206213, "o", "#!/bin/bash\r\n\u001b[?2004l\r\u001b[?2004h> set -euo pipefail\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> bash /app/scripts/clean-room.sh\r\n\u001b[?2004l\r\u001b[?2004h> "]
[77.206561, "o", "python3 /app/scripts/executor_ctl.py --out /app/output/executor-audit.json --work /app/output/runtime --root /app\r\n\u001b[?2004l\r"]
