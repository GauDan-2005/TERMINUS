[77.320844, "i", "cat > /app/scripts/run-one.sh <<'SH'\n#!/bin/bash\nset -euo pipefail\n\ncase_name=\"${1:?case name required}\"\nout=\"${2:-/app/output/executor-audit.json}\"\nwork=\"${3:-/app/output/runtime}\"\nmkdir -p /app/output\npython3 /app/scripts/executor_ctl.py --case \"$case_name\" --out \"$out\" --work \"$work\" --root /app\nSH\nchmod +x /app/scripts/run-one.sh\n"]
[77.32104, "o", "cat > /app/scripts/run-one.sh <<'SH'"]
[77.324871, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> #!/bin/bash\r\n\u001b[?2004l\r\u001b[?2004h> set -euo pipefail\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> case_name=\"${1:?case name required}\"\r\n\u001b[?2004l\r\u001b[?2004h> out=\"${2:-/app/output/executor-audit.json}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[77.325583, "o", "> work=\"${3:-/app/output/runtime}\"\r\n\u001b[?2004l\r\u001b[?2004h> mkdir -p /app/output\r\n\u001b[?2004l\r\u001b[?2004h> python3 /app/scripts/executor_ctl.py --case \"$case_name\" --out \"$out\" --work \"$work\" --root /app\r\n\u001b[?2004l\r\u001b[?2004h> SH\r\n\u001b[?2004l\r\u001b[?2004hroot@c3345729cf84:/app# chmod +x /app/scripts/run-one.sh\r\n\u001b[?2004l\r"]
[77.326037, "o", "\u001b[?2004hroot@c3345729cf84:/app# "]
