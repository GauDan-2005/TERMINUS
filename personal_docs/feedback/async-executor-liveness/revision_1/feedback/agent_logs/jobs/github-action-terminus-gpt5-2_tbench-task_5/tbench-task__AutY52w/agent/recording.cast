[78.68506, "i", "python3 - <<'PY'\nimport json\np='/app/output/executor-audit.json'\nwith open(p) as f:\n    j=json.load(f)\nprint('cases', [c['name'] for c in j['cases']])\nfor c in j['cases']:\n    print(c['name'], 'ok', c['ok'], 'finished', c['finished'], 'pending', c['pending'], 'trace_len', len(c['trace']))\nPY\n"]
