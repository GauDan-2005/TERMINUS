[41.184905, "i", "sed -n '1,240p' /app/types_f/types.rs\n"]
[41.185529, "o", "sed -n '1,240p' /app/types_f/types.rs"]
[41.186561, "o", "\r\n\u001b[?2004l\r"]
[41.188327, "o", "#[derive(Clone, Debug)]\r\npub enum Entry {\r\n    Root { ident: String, lane: String, at: u64, seq: usize },\r\n    Child { from: String, ident: String, lane: String, at: u64, seq: usize },\r\n    Drop { ident: String },\r\n}\r\n\r\n#[derive(Clone, Debug)]\r\npub struct Plan {\r\n    pub name: String,\r\n    pub cap: usize,\r\n    pub entries: Vec<Entry>,\r\n}\r\n\r\n#[derive(Clone, Debug, Eq, PartialEq)]\r\npub struct Item {\r\n    pub ident: String,\r\n    pub parent: String,\r\n    pub lane: String,\r\n    pub at: u64,\r\n    pub seq: usize,\r\n    pub depth: usize,\r\n    pub chain: Vec<String>,\r\n}\r\n\r\n"]
[41.18836, "o", "#[derive(Clone, Debug, Eq, PartialEq)]\r\npub struct Record {\r\n    pub case_name: String,\r\n    pub task_name: String,\r\n    pub parent_name: String,\r\n"]
[41.1884, "o", "    pub depth: usize,\r\n    pub lane_name: String,\r\n    pub turn: u64,\r\n}\r\n\r\n#[derive(Clone, Debug)]\r\npub struct CaseReport {\r\n    pub name: String,\r\n    pub ok: bool,\r\n    pub finished: bool,\r\n    pub pending: Vec<String>,\r\n"]
[41.188416, "o", "    pub trace: Vec<Record>,\r\n    pub ledger: String,\r\n    pub journal: String,\r\n}\r\n"]
[41.188615, "o", "\u001b[?2004h"]
[41.188642, "o", "root@c3345729cf84:/app# "]
[41.296863, "i", "sed -n '1,260p' /app/types_f/serde.rs\n"]
[41.29706, "o", "sed -n '1,260p' /app/types_f/serde.rs\r\n\u001b[?2004l\r"]
[41.298218, "o", "use crate::types_f::{CaseReport, Record};\r\n\r\nfn esc(s: &str) -> String {\r\n    s.replace('\\\\', \"\\\\\\\\\").replace('\"', \"\\\\\\\"\")\r\n}\r\n\r\npub fn row_json(row: &Record) -> String {\r\n    format!(\r\n        \"{{\\\"case\\\":\\\"{}\\\",\\\"task\\\":\\\"{}\\\",\\\"parent\\\":\\\"{}\\\",\\\"depth\\\":{},\\\"lane\\\":\\\"{}\\\",\\\"turn\\\":{}}}\",\r\n        esc(&row.case_name),\r\n        esc(&row.task_name),\r\n        esc(&row.parent_name),\r\n        row.depth,\r\n        esc(&row.lane_name),\r\n"]
[41.298275, "o", "        row.turn\r\n    )\r\n"]
[41.29853, "o", "}\r\n\r\nfn string_array(items: &[String]) -> String {\r\n    format!(\r\n        \"[{}]\",\r\n        items\r\n            .iter()\r\n            .map(|s| format!(\"\\\"{}\\\"\", esc(s)))\r\n            .collect::<Vec<_>>()\r\n            .join(\",\")\r\n    )\r\n}\r\n\r\npub fn case_json(case: &CaseReport) -> String {\r\n    let trace = case.trace.iter().map(row_json).collect::<Vec<_>>().join(\",\");\r\n    format!(\r\n        \"{{\\\"name\\\":\\\"{}\\\",\\\"ok\\\":{},\\\"finished\\\":{},\\\"pending\\\":{},\\\"trace\\\":[{}],\\\"ledger\\\":\\\"{}\\\",\\\"journal\\\":\\\"{}\\\"}}\",\r\n        esc(&case.name),\r\n        if case.ok { \"true\" } else { \"false\" },\r\n        if case.finished { \"true\" } else { \"false\" },\r\n        string_array(&case.pending),\r\n        trace,\r\n        esc(&case.ledger),\r\n        esc(&case.journal)\r\n    )\r\n}\r\n\r\npub fn report_json(cases: &[CaseReport]) -> String {\r\n    let body = cases.iter().map(case_json).collect::<Vec<_>>().join(\",\");\r\n    format!(\"{{\\\"cases\\\":[{}]}}\\n\", body)\r\n}\r\n"]
[41.298867, "o", "\u001b[?2004hroot@c3345729cf84:/app# "]
[41.412969, "i", "sed -n '1,260p' /app/read_h/parse.rs\n"]
[41.413186, "o", "sed -n '1,260p' /app/read_h/parse.rs"]
[41.413439, "o", "\r\n\u001b[?2004l\r"]
[41.414412, "o", "use std::fs;\r\nuse std::io;\r\nuse std::path::Path;\r\n\r\nuse crate::types_f::{Entry, Plan};\r\n"]
[41.414521, "o", "\r\npub fn read_plan(path: &Path) -> io::Result<Plan> {\r\n    let text = fs::read_to_string(path)?;\r\n    let mut cap = 1usize;\r\n    let mut entries = Vec::new();\r\n    let name = path\r\n        .file_stem()\r\n"]
[41.414814, "o", "        .and_then(|s| s.to_str())\r\n        .unwrap_or(\"case\")\r\n        .to_string();\r\n    for raw in text.lines() {\r\n"]
[41.414906, "o", "        let line = raw.trim();\r\n        if line.is_empty() || line.starts_with('#') {\r\n            continue;\r\n        }\r\n        let parts: Vec<&str> = line.split_whitespace().collect();\r\n        match parts.as_slice() {\r\n            [\"CAP\", value] => cap = value.parse().unwrap_or(1),\r\n            [\"ROOT\", ident, lane, at] => {\r\n                let seq = entries.len();\r\n                entries.push(Entry::Root { ident: (*ident).to_string(), lane: (*lane).to_string(), at: at.parse().unwrap_or(0), seq });\r\n            }\r\n            [\"CHILD\", from, ident, lane, at] => {\r\n                let seq = entries.len();\r\n                entries.push(Entry::Child { from: (*from).to_string(), ident: (*ident).to_string(), lane: (*lane).to_string(), at: at.parse().unwrap_or(0), seq });\r\n            }\r\n            [\"DROP\", ident] => entries.push(Entry::Drop { ident: (*ident).to_string() }),\r\n            _ => {}\r\n        }\r\n    }\r\n    Ok(Plan { name, cap, entries })\r\n}\r\n"]
[41.415004, "o", "\u001b[?2004hroot@c3345729cf84:/app# "]
[41.524771, "i", "sed -n '1,320p' /app/drive_g/drive.rs\n"]
