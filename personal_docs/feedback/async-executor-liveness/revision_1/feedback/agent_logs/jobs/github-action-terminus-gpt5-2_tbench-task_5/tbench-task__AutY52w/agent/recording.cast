[78.685714, "o", "import json\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.685931, "o", "p='/app/output/executor-audit.json'\r\n\u001b[?2004l\r\u001b[?2004h> with open(p) as f:\r\n"]
