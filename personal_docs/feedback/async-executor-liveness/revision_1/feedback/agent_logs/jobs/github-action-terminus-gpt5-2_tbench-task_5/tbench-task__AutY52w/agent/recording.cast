[78.687268, "o", "\u001b[?2004h>     j=json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> print('cases', [c['name'] for c in j['cases']])\r\n\u001b[?2004l\r\u001b[?2004h> for c in j['cases']:\r\n\u001b[?2004l\r\u001b[?2004h>     print(c['name'], 'ok', c['ok'], 'finished', c['finished'], 'pending', c['pending'], 'trace_len', len(c['trace']))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
