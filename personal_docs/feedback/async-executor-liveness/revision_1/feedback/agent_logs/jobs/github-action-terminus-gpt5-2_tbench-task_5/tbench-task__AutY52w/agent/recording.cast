[76.218349, "o", "        if not ready_by_lane:\r\n\u001b[?2004l\r"]
[76.218395, "o", "\u001b[?2004h> "]
[76.218693, "o", "            # if nothing ready and all accepted, done; else continue until something becomes ready\r\n\u001b[?2004l\r"]
[76.218743, "o", "\u001b[?2004h> "]
[76.218866, "o", "            if len(accepted) == len(items):\r\n\u001b[?2004l\r"]
[76.218883, "o", "\u001b[?2004h"]
[76.218896, "o", "> "]
[76.218971, "o", "                break\r\n\u001b[?2004l\r"]
[76.218989, "o", "\u001b[?2004h"]
[76.219002, "o", "> "]
[76.219078, "o", "            continue\r\n\u001b[?2004l\r"]
[76.219121, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[76.219205, "o", "\u001b[?2004h> "]
[76.219291, "o", "        accepted_this_turn = []\r\n\u001b[?2004l\r"]
[76.219356, "o", "\u001b[?2004h> "]
[76.219483, "o", "        for lane in sorted(ready_by_lane.keys()):\r\n\u001b[?2004l\r"]
[76.219503, "o", "\u001b[?2004h"]
[76.219516, "o", "> "]
[76.219772, "o", "            lane_items = sorted(ready_by_lane[lane], key=lambda x: x.seq)\r\n\u001b[?2004l\r"]
[76.219828, "o", "\u001b[?2004h> "]
[76.219947, "o", "            for it in lane_items[:cap]:\r\n\u001b[?2004l\r"]
[76.219968, "o", "\u001b[?2004h"]
[76.219981, "o", "> "]
[76.220117, "o", "                accepted[it.ident] = turn\r\n\u001b[?2004l\r"]
[76.220247, "o", "\u001b[?2004h> "]
[76.220344, "o", "                accepted_this_turn.append(it)\r\n\u001b[?2004l\r"]
[76.220439, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[76.220533, "o", "> "]
[76.220726, "o", "        # append in acceptance order: lower accepted turn first; lanes ordered by name within turn;\r\n\u001b[?2004l\r"]
[76.220781, "o", "\u001b[?2004h"]
[76.220802, "o", "> "]
[76.220963, "o", "        # ready work within a lane keeps plan-file order.\r\n\u001b[?2004l\r"]
[76.221033, "o", "\u001b[?2004h> "]
[76.221224, "o", "        for it in sorted(accepted_this_turn, key=lambda x: (x.lane, x.seq)):\r\n\u001b[?2004l\r"]
[76.221302, "o", "\u001b[?2004h"]
[76.221322, "o", "> "]
[76.221436, "o", "            trace.append({\r\n\u001b[?2004l\r\u001b[?2004h"]
[76.221456, "o", "> "]
[76.221652, "o", "                \"case\": case,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[76.221707, "o", "                \"task\": it.ident,\r\n\u001b[?2004l\r"]
[76.221741, "o", "\u001b[?2004h> "]
[76.221858, "o", "                \"parent\": it.parent,\r\n\u001b[?2004l\r"]
[76.221938, "o", "\u001b[?2004h"]
[76.222026, "o", "> "]
[76.222105, "o", "                \"depth\": it.depth,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[76.222168, "o", "                \"lane\": it.lane,\r\n\u001b[?2004l\r"]
[76.222215, "o", "\u001b[?2004h> "]
[76.222341, "o", "                \"turn\": accepted[it.ident],\r\n\u001b[?2004l\r"]
[76.222403, "o", "\u001b[?2004h> "]
[76.222452, "o", "            })\r\n\u001b[?2004l\r"]
[76.222466, "o", "\u001b[?2004h> "]
[76.222478, "o", "\r\n\u001b[?2004l\r"]
[76.222529, "o", "\u001b[?2004h> "]
[76.222649, "o", "        if len(accepted) == len(items):\r\n\u001b[?2004l\r"]
[76.222689, "o", "\u001b[?2004h> "]
[76.22275, "o", "            break\r\n\u001b[?2004l\r"]
[76.222785, "o", "\u001b[?2004h"]
[76.222811, "o", "> \r\n\u001b[?2004l\r"]
[76.22286, "o", "\u001b[?2004h"]
[76.222876, "o", "> "]
[76.223094, "o", "    pending = sorted([it.ident for it in items.values() if it.ident not in accepted])\r\n\u001b[?2004l\r"]
[76.223153, "o", "\u001b[?2004h> "]
[76.223221, "o", "    return trace, pending\r\n\u001b[?2004l\r"]
[76.223258, "o", "\u001b[?2004h> "]
[76.223272, "o", "\r\n\u001b[?2004l\r"]
[76.223312, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[76.223346, "o", "\u001b[?2004h"]
[76.223361, "o", "> "]
[76.223511, "o", "def write_ledger(path: str, trace: List[dict]):\r\n\u001b[?2004l\r"]
[76.223569, "o", "\u001b[?2004h"]
[76.223624, "o", "> "]
[76.22374, "o", "    os.makedirs(os.path.dirname(path), exist_ok=True)\r\n\u001b[?2004l\r"]
[76.223765, "o", "\u001b[?2004h> "]
[76.223925, "o", "    with open(path, 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[76.223944, "o", "\u001b[?2004h"]
[76.223958, "o", "> "]
[76.224056, "o", "        for row in trace:\r\n\u001b[?2004l\r"]
[76.224074, "o", "\u001b[?2004h"]
[76.224143, "o", "> "]
[76.224359, "o", "            f.write(json.dumps(row, separators=(\",\", \":\"), ensure_ascii=False))\r\n\u001b[?2004l\r"]
[76.224408, "o", "\u001b[?2004h> "]
[76.224488, "o", "            f.write(\"\\n\")\r\n\u001b[?2004l\r"]
[76.224623, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[76.224708, "o", "\u001b[?2004h> "]
[76.224809, "o", "def write_journal(path: str, trace: List[dict]):\r\n\u001b[?2004l\r"]
[76.224853, "o", "\u001b[?2004h> "]
[76.225026, "o", "    os.makedirs(os.path.dirname(path), exist_ok=True)\r\n\u001b[?2004l\r"]
[76.225079, "o", "\u001b[?2004h> "]
[76.22523, "o", "    with open(path, 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[76.225279, "o", "\u001b[?2004h"]
[76.22532, "o", "> "]
[76.225375, "o", "        for row in trace:\r\n\u001b[?2004l\r"]
[76.225419, "o", "\u001b[?2004h> "]
[76.225766, "o", "            f.write(f\"{row['case']} {row['task']} {row['parent']} {row['depth']} {row['lane']} {row['turn']}\\n\")\r\n\u001b[?2004l\r"]
[76.225859, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[76.225913, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[76.225938, "o", "def main():\r\n\u001b[?2004l\r"]
[76.226025, "o", "\u001b[?2004h> "]
[76.226105, "o", "    ap = argparse.ArgumentParser()\r\n\u001b[?2004l\r"]
[76.226186, "o", "\u001b[?2004h> "]
[76.226315, "o", "    ap.add_argument('--case', dest='case_name')\r\n\u001b[?2004l\r"]
[76.226341, "o", "\u001b[?2004h> "]
[76.226494, "o", "    ap.add_argument('--root', default='/app')\r\n\u001b[?2004l\r"]
[76.226513, "o", "\u001b[?2004h"]
[76.226563, "o", "> "]
[76.226748, "o", "    ap.add_argument('--out', default='/app/output/executor-audit.json')\r\n\u001b[?2004l\r"]
[76.226768, "o", "\u001b[?2004h"]
[76.226779, "o", "> "]
[76.22697, "o", "    ap.add_argument('--work', default='/app/output/runtime')\r\n\u001b[?2004l\r"]
[76.226988, "o", "\u001b[?2004h"]
[76.227037, "o", "> "]
[76.227108, "o", "    args = ap.parse_args()\r\n\u001b[?2004l\r"]
[76.227127, "o", "\u001b[?2004h"]
[76.227264, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[76.227509, "o", "    names = [args.case_name] if args.case_name else [\"amber\", \"cobalt\", \"drake\", \"ember\", \"flint\", \"graphite\"]\r\n\u001b[?2004l\r"]
[76.22759, "o", "\u001b[?2004h"]
[76.227679, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[76.227705, "o", "    cases_out = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[76.227793, "o", "    for name in names:\r\n\u001b[?2004l\r"]
[76.227865, "o", "\u001b[?2004h"]
[76.227932, "o", "> "]
[76.228075, "o", "        plan_path = os.path.join(args.root, 'data', 'cases', f'{name}.plan')\r\n\u001b[?2004l\r"]
[76.228093, "o", "\u001b[?2004h"]
[76.228109, "o", "> "]
[76.228289, "o", "        case_name, cap, entries = read_plan(plan_path)\r\n\u001b[?2004l\r"]
[76.228353, "o", "\u001b[?2004h> "]
[76.228469, "o", "        items, drops = build_items(entries)\r\n\u001b[?2004l\r"]
[76.228488, "o", "\u001b[?2004h"]
[76.228511, "o", "> "]
[76.228653, "o", "        items = apply_drops(items, drops)\r\n\u001b[?2004l\r"]
[76.228713, "o", "\u001b[?2004h> "]
[76.228884, "o", "        trace, pending = simulate(case_name, cap, items)\r\n\u001b[?2004l\r"]
[76.228933, "o", "\u001b[?2004h"]
[76.229021, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[76.229069, "o", "> "]
[76.229217, "o", "        ledger_path = os.path.join(args.work, 'ledgers', f'{case_name}.jsonl')\r\n\u001b[?2004l\r"]
[76.229247, "o", "\u001b[?2004h"]
[76.22926, "o", "> "]
[76.229507, "o", "        journal_path = os.path.join(args.work, 'journals', f'{case_name}.txt')\r\n\u001b[?2004l\r"]
[76.229546, "o", "\u001b[?2004h> "]
[76.229688, "o", "        write_ledger(ledger_path, trace)\r\n\u001b[?2004l\r"]
[76.229736, "o", "\u001b[?2004h> "]
[76.229872, "o", "        write_journal(journal_path, trace)\r\n\u001b[?2004l\r"]
[76.229922, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[76.229951, "o", "\u001b[?2004h"]
[76.230001, "o", "> "]
[76.230101, "o", "        finished = (len(pending) == 0)\r\n\u001b[?2004l\r"]
[76.230132, "o", "\u001b[?2004h"]
[76.230145, "o", "> "]
[76.230245, "o", "        cases_out.append({\r\n\u001b[?2004l\r"]
[76.230278, "o", "\u001b[?2004h"]
[76.23029, "o", "> "]
[76.230404, "o", "            \"name\": case_name,\r\n"]
[76.230449, "o", "\u001b[?2004l\r\u001b[?2004h"]
[76.2305, "o", "> "]
[76.23056, "o", "            \"ok\": finished,\r\n\u001b[?2004l\r"]
[76.230609, "o", "\u001b[?2004h"]
[76.230653, "o", "> "]
[76.230736, "o", "            \"finished\": finished,\r\n\u001b[?2004l\r"]
[76.230786, "o", "\u001b[?2004h> "]
[76.230902, "o", "            \"pending\": pending,\r\n\u001b[?2004l\r"]
[76.230954, "o", "\u001b[?2004h> "]
[76.231052, "o", "            \"trace\": trace,\r\n\u001b[?2004l\r"]
[76.231097, "o", "\u001b[?2004h> "]
[76.231216, "o", "            \"ledger\": ledger_path,\r\n\u001b[?2004l\r"]
[76.231258, "o", "\u001b[?2004h> "]
[76.231386, "o", "            \"journal\": journal_path,\r\n\u001b[?2004l\r"]
[76.231436, "o", "\u001b[?2004h> "]
[76.23148, "o", "        })\r\n\u001b[?2004l\r"]
[76.231553, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[76.231596, "o", "\u001b[?2004h> "]
[76.231759, "o", "    os.makedirs(os.path.dirname(args.out), exist_ok=True)\r\n\u001b[?2004l\r"]
[76.231812, "o", "\u001b[?2004h> "]
[76.231971, "o", "    with open(args.out, 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[76.23202, "o", "\u001b[?2004h> "]
[76.232278, "o", "        json.dump({\"cases\": cases_out}, f, separators=(\",\", \":\"), ensure_ascii=False)\r\n\u001b[?2004l\r"]
[76.23233, "o", "\u001b[?2004h> "]
[76.2324, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r"]
[76.232463, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[76.232501, "o", "\u001b[?2004h> "]
[76.23261, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[76.232686, "o", "\u001b[?2004h> "]
[76.232755, "o", "    main()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[76.23281, "o", "PY\r\n\u001b[?2004l\r"]
[76.233693, "o", "\u001b[?2004h"]
