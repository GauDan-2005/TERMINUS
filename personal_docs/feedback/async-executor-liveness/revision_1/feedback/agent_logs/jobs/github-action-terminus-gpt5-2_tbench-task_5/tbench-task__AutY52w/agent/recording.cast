[76.190893, "i", "cat > /app/scripts/executor_ctl.py <<'PY'\n#!/usr/bin/env python3\nimport argparse, json, os\nfrom dataclasses import dataclass\nfrom typing import List, Dict, Tuple\n\n@dataclass\nclass Entry:\n    kind: str\n    ident: str\n    lane: str = \"\"\n    at: int = 0\n    seq: int = 0\n    parent: str = \"-\"\n\n@dataclass\nclass Item:\n    ident: str\n    parent: str\n    depth: int\n    lane: str\n    at: int\n    seq: int\n    chain: Tuple[str, ...]\n\n\ndef read_plan(path: str):\n    name = os.path.splitext(os.path.basename(path))[0]\n    cap = 1\n    entries: List[Entry] = []\n    with open(path, 'r', encoding='utf-8') as f:\n        for raw in f:\n            line = raw.strip()\n            if not line or line.startswith('#'):\n                continue\n            parts = line.split()\n            if parts[:1] == [\"CAP\"] and len(parts) == 2:\n                try:\n                    cap = int(parts[1])\n                except ValueError:\n                    cap = 1\n            elif parts[:1] == [\"ROOT\"] and len(parts) == 4:\n                ident, "]
[76.19126, "o", "cat > /app/scripts/executor_ctl.py <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> import argparse, json, os\r\n\u001b[?2004l\r\u001b[?2004h> from dataclasses import dataclass\r\n\u001b[?2004l\r\u001b[?2004h"]
[76.191293, "i", "lane, at = parts[1], parts[2], int(parts[3])\n                entries.append(Entry(\"ROOT\", ident, lane=lane, at=at, seq=len(entries), parent=\"-\"))\n            elif parts[:1] == [\"CHILD\"] and len(parts) == 5:\n                parent, ident, lane, at = parts[1], parts[2], parts[3], int(parts[4])\n                entries.append(Entry(\"CHILD\", ident, lane=lane, at=at, seq=len(entries), parent=parent))\n            elif parts[:1] == [\"DROP\"] and len(parts) == 2:\n                entries.append(Entry(\"DROP\", parts[1], seq=len(entries)))\n            else:\n                # ignore unknown lines\n                pass\n    return name, max(1, cap), entries\n\n\ndef build_items(entries: List[Entry]) -> Tuple[Dict[str, Item], List[str]]:\n    # Build parent links and depth/chain based on known items so far.\n    items: Dict[str, Item] = {}\n    drops: List[str] = []\n    for e in entries:\n        if e.kind == \"DROP\":\n            drops.append(e.ident)\n            continue\n\n        parent_item = items.get(e.parent) if e.kind == \"CHILD\" "]
