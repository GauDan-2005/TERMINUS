[91.589218, "o", "\u001b[?2004hroot@c3345729cf84:/app# "]
[91.670112, "i", "sed -n '1,40p' /app/scripts/executor_ctl.py\n"]
[91.670992, "o", "sed -n '1,40p' /app/scripts/executor_ctl.py\r\n\u001b[?2004l\r#!/usr/bin/env python3\r\nimport argparse, json, os\r\nfrom dataclasses import dataclass\r\nfrom typing import List, Dict, Tuple\r\n\r\n@dataclass\r\nclass Entry:\r\n    kind: str\r\n    ident: str\r\n    lane: str = \"\"\r\n    at: int = 0\r\n    seq: int = 0\r\n    parent: str = \"-\"\r\n"]
[91.671174, "o", "\r\n@dataclass\r\nclass Item:\r\n    ident: str\r\n    parent: str\r\n    depth: int\r\n    lane: str\r\n    at: int\r\n    seq: int\r\n    chain: Tuple[str, ...]\r\n\r\n\r\ndef read_plan(path: str):\r\n    name = os.path.splitext(os.path.basename(path))[0]\r\n    cap = 1\r\n    entries: List[Entry] = []\r\n    with open(path, 'r', encoding='utf-8') as f:\r\n        for raw in f:\r\n            line = raw.strip()\r\n            if not line or line.startswith('#'):\r\n                continue\r\n            parts = line.split()\r\n            if parts[:1] == [\"CAP\"] and len(parts) == 2:\r\n                try:\r\n                    cap = int(parts[1])\r\n                except ValueError:\r\n                    cap = 1\r\n"]
[91.671196, "o", "\u001b[?2004hroot@c3345729cf84:/app# "]
[91.785191, "i", "tail -n 40 /app/scripts/executor_ctl.py\n"]
[91.785486, "o", "tail -n 40 /app/scripts/executor_ctl.py\r\n\u001b[?2004l\r"]
[91.788226, "o", "    ap = argparse.ArgumentParser()\r\n    ap.add_argument('--case', dest='case_name')\r\n    ap.add_argument('--root', default='/app')\r\n    ap.add_argument('--out', default='/app/output/executor-audit.json')\r\n    ap.add_argument('--work', default='/app/output/runtime')\r\n    args = ap.parse_args()\r\n\r\n    names = [args.case_name] if args.case_name else [\"amber\", \"cobalt\", \"drake\", \"ember\", \"flint\", \"graphite\"]\r\n\r\n    cases_out = []\r\n    for name in names:\r\n        plan_path = os.path.join(args.root, 'data', 'cases', f'{name}.plan')\r\n        case_name, cap, entries = read_plan(plan_path)\r\n        items, drops = build_items(entries)\r\n        items = apply_drops(items, drops)\r\n        trace, pending = simulate(case_name, cap, items)\r\n\r\n        ledger_path = os.path.join(args.work, 'ledgers', f'{case_name}.jsonl')\r\n        journal_path = os.path.join(args.work, 'journals', f'{case_name}.txt')\r\n        write_ledger(ledger_path, trace)\r\n        write_journal(journal_path, trace)\r\n\r\n        finished = (len(pending) == 0)\r"]
[91.788284, "o", "\n        cases_out.append({\r\n            \"name\": case_name,\r\n            \"ok\": finished,\r\n            \"finished\": finished,\r\n            \"pending\": pending,\r\n            \"trace\": trace,\r\n            \"ledger\": ledger_path,\r\n            \"journal\": journal_path,\r\n        })\r\n\r\n    os.makedirs(os.path.dirname(args.out), exist_ok=True)\r\n    with open(args.out, 'w', encoding='utf-8') as f:\r\n        json.dump({\"cases\": cases_out}, f, separators=(\",\", \":\"), ensure_ascii=False)\r\n        f.write(\"\\n\")\r\n\r\nif __name__ == '__main__':\r\n    main()\r\n\u001b[?2004hroot@c3345729cf84:/app# "]
[91.899081, "i", "python3 - <<'PY'\nimport json, os\nfrom pathlib import Path\n\naudit_path = Path('/app/output/executor-audit.json')\naudit = json.loads(audit_path.read_text())\n\n# Basic contract checks\nwanted = ['amber','cobalt','drake','ember','flint','graphite']\nassert [c['name'] for c in audit['cases']] == wanted\n\ndef check_order(trace):\n    # nondecreasing turn\n    turns = [r['turn'] for r in trace]\n    assert turns == sorted(turns)\n    # within each turn: lanes sorted, within lane seq order is not present; we approximate by ensuring\n    # stable per-lane order by appearance is consistent with nondecreasing turn then lane.\n    for t in sorted(set(turns)):\n        rows = [r for r in trace if r['turn']==t]\n        lanes = [r['lane'] for r in rows]\n        assert lanes == sorted(lanes)\n\nfor case in audit['cases']:\n    assert case['ok'] and case['finished'] and case['pending']==[]\n    trace = case['trace']\n    check_order(trace)\n\n    ledger = Path(case['ledger'])\n    journal = Path(case['journal'])\n    assert ledger.exists() and j"]
[91.899127, "i", "ournal.exists()\n\n    ledger_rows = [json.loads(line) for line in ledger.read_text().splitlines() if line.strip()]\n    assert ledger_rows == trace\n\n    journal_rows = []\n    for line in journal.read_text().splitlines():\n        if not line.strip():\n            continue\n        parts = line.split()\n        assert len(parts)==6\n        c, task, parent, depth, lane, turn = parts\n        journal_rows.append({\n            'case': c,\n            'task': task,\n            'parent': parent,\n            'depth': int(depth),\n            'lane': lane,\n            'turn': int(turn),\n        })\n    assert journal_rows == trace\n\n# Specific drop/dedupe expectations\ncases = {c['name']: c for c in audit['cases']}\nassert all(r['task']!='drake-cut' and r['task']!='drake-shadow' for r in cases['drake']['trace'])\nassert all(not r['task'].startswith('ember-left') and r['task'] not in ('ember-deep','ember-side') for r in cases['ember']['trace'])\nassert all(r['task'] not in ('graphite-d','graphite-e') for r in cases['graphite']['trac"]
[91.899506, "i", "e'])\nassert sum(1 for r in cases['flint']['trace'] if r['task']=='flint-a') == 1\n\nprint('audit/ledger/journal validation OK')\nPY\n"]
