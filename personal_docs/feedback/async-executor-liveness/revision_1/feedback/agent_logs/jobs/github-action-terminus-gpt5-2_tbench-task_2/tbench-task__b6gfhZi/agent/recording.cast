[288.325506, "o", "class Task:\r\n\u001b[?2004l\r"]
[288.325665, "o", "\u001b[?2004h>     case: str\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.325926, "o", ">     task: str\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.32615, "o", "    parent: str\r\n\u001b[?2004l\r"]
[288.326218, "o", "\u001b[?2004h> "]
[288.326321, "o", "    depth: int\r\n\u001b[?2004l\r"]
[288.326402, "o", "\u001b[?2004h"]
[288.326422, "o", "> "]
