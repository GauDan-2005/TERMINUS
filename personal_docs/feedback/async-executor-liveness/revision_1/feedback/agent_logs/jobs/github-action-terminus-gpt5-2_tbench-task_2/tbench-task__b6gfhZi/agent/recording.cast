[288.326976, "o", "\u001b[?2004h> "]
[288.327055, "o", "@dataclass\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.327114, "o", "> "]
[288.32721, "o", "class Record:\r\n\u001b[?2004l\r"]
[288.327311, "o", "\u001b[?2004h> "]
[288.32737, "o", "    case: str\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.327471, "o", "    task: str\r\n\u001b[?2004l\r"]
[288.327493, "o", "\u001b[?2004h"]
[288.327507, "o", "> "]
[288.327635, "o", "    parent: str\r\n\u001b[?2004l\r"]
[288.327707, "o", "\u001b[?2004h> "]
[288.327784, "o", "    depth: int\r\n\u001b[?2004l\r"]
[288.327803, "o", "\u001b[?2004h"]
[288.327853, "o", "> "]
[288.32799, "o", "    lane: str\r\n\u001b[?2004l\r"]
[288.328075, "o", "\u001b[?2004h> "]
[288.32813, "o", "    turn: int\r\n\u001b[?2004l\r"]
[288.328193, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[288.328252, "o", "\u001b[?2004h> "]
[288.328311, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.328664, "o", "def parse_plan(path: Path) -> Tuple[str, int, List[Entry]]:\r\n\u001b[?2004l\r"]
[288.328686, "o", "\u001b[?2004h"]
[288.328698, "o", "> "]
[288.329001, "o", "    text = path.read_text(encoding=\"utf-8\")\r\n\u001b[?2004l\r"]
[288.329094, "o", "\u001b[?2004h> "]
[288.329186, "o", "    cap = 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.329359, "o", "    entries: List[Entry] = []\r\n\u001b[?2004l\r"]
[288.329379, "o", "\u001b[?2004h"]
[288.329437, "o", "> "]
[288.329591, "o", "    name = path.stem or \"case\"\r\n\u001b[?2004l\r"]
[288.329657, "o", "\u001b[?2004h> "]
[288.32968, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.329757, "o", "> "]
[288.329935, "o", "    for raw in text.splitlines():\r\n\u001b[?2004l\r"]
[288.329991, "o", "\u001b[?2004h> "]
[288.330162, "o", "        line = raw.strip()\r\n\u001b[?2004l\r"]
[288.330224, "o", "\u001b[?2004h> "]
[288.330486, "o", "        if not line or line.startswith(\"#\"):\r\n\u001b[?2004l\r"]
[288.330536, "o", "\u001b[?2004h> "]
[288.330673, "o", "            continue\r\n\u001b[?2004l\r"]
[288.330745, "o", "\u001b[?2004h> "]
[288.330925, "o", "        parts = line.split()\r\n\u001b[?2004l\r"]
[288.330947, "o", "\u001b[?2004h"]
[288.33096, "o", "> "]
[288.331295, "o", "        if parts[:1] == [\"CAP\"] and len(parts) == 2:\r\n\u001b[?2004l\r"]
[288.331398, "o", "\u001b[?2004h> "]
[288.331477, "o", "            try:\r\n\u001b[?2004l\r"]
[288.331498, "o", "\u001b[?2004h> "]
[288.331751, "o", "                cap = int(parts[1])\r\n\u001b[?2004l\r"]
[288.331804, "o", "\u001b[?2004h> "]
[288.331978, "o", "            except ValueError:\r\n\u001b[?2004l\r"]
[288.33204, "o", "\u001b[?2004h> "]
[288.332182, "o", "                cap = 1\r\n\u001b[?2004l\r"]
[288.332237, "o", "\u001b[?2004h"]
[288.332254, "o", "> "]
[288.332404, "o", "            continue\r\n\u001b[?2004l\r"]
[288.332499, "o", "\u001b[?2004h> "]
[288.332819, "o", "        if parts[:1] == [\"ROOT\"] and len(parts) == 4:\r\n\u001b[?2004l\r"]
[288.332837, "o", "\u001b[?2004h"]
[288.332947, "o", "> "]
[288.333082, "o", "            seq = len(entries)\r\n\u001b[?2004l\r"]
[288.333188, "o", "\u001b[?2004h> "]
[288.333486, "o", "            ident, lane, at_s = parts[1], parts[2], parts[3]\r\n\u001b[?2004l\r"]
[288.333589, "o", "\u001b[?2004h> "]
[288.333663, "o", "            try:\r\n\u001b[?2004l\r"]
[288.333721, "o", "\u001b[?2004h> "]
[288.333927, "o", "                at = int(at_s)\r\n\u001b[?2004l\r"]
[288.333977, "o", "\u001b[?2004h> "]
[288.334166, "o", "            except ValueError:\r\n\u001b[?2004l\r"]
[288.334238, "o", "\u001b[?2004h> "]
[288.334388, "o", "                at = 0\r\n\u001b[?2004l\r"]
[288.334467, "o", "\u001b[?2004h> "]
[288.334969, "o", "            entries.append(Entry(kind=\"ROOT\", ident=ident, lane=lane, at=at, seq=seq))\r\n\u001b[?2004l\r"]
[288.33499, "o", "\u001b[?2004h"]
[288.335003, "o", "> "]
[288.335143, "o", "            continue\r\n\u001b[?2004l\r"]
[288.335247, "o", "\u001b[?2004h> "]
[288.335535, "o", "        if parts[:1] == [\"CHILD\"] and len(parts) == 5:\r\n\u001b[?2004l\r"]
[288.335653, "o", "\u001b[?2004h> "]
[288.335784, "o", "            seq = len(entries)\r\n\u001b[?2004l\r"]
[288.335838, "o", "\u001b[?2004h> "]
[288.336318, "o", "            parent, ident, lane, at_s = parts[1], parts[2], parts[3], parts[4]\r\n\u001b[?2004l\r"]
[288.336423, "o", "\u001b[?2004h> "]
[288.33651, "o", "            try:\r\n\u001b[?2004l\r"]
[288.336587, "o", "\u001b[?2004h> "]
[288.33676, "o", "                at = int(at_s)\r\n\u001b[?2004l\r"]
[288.336783, "o", "\u001b[?2004h"]
[288.336842, "o", "> "]
[288.33702, "o", "            except ValueError:\r\n\u001b[?2004l\r"]
[288.337073, "o", "\u001b[?2004h> "]
[288.337216, "o", "                at = 0\r\n\u001b[?2004l\r"]
[288.337279, "o", "\u001b[?2004h> "]
[288.337925, "o", "            entries.append(Entry(kind=\"CHILD\", parent=parent, ident=ident, lane=lane, at=at, seq=seq))\r\n\u001b[?2004l\r"]
[288.337994, "o", "\u001b[?2004h> "]
[288.338118, "o", "            continue\r\n\u001b[?2004l\r"]
[288.33817, "o", "\u001b[?2004h> "]
[288.338487, "o", "        if parts[:1] == [\"DROP\"] and len(parts) == 2:\r\n\u001b[?2004l\r"]
[288.338558, "o", "\u001b[?2004h> "]
[288.338925, "o", "            entries.append(Entry(kind=\"DROP\", ident=parts[1]))\r\n\u001b[?2004l\r r"]
[288.33897, "o", "\u001b[?2004h"]
[288.338987, "o", "> "]
[288.339114, "o", "            continue\r\n\u001b[?2004l\r"]
[288.339154, "o", "\u001b[?2004h> \r\n"]
[288.339251, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[288.339463, "o", "    return name, max(1, cap), entries\r\n\u001b[?2004l\r"]
[288.339484, "o", "\u001b[?2004h"]
[288.339499, "o", "> "]
[288.339513, "o", "\r\n\u001b[?2004l\r"]
[288.339584, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.339605, "o", "> "]
[288.340293, "o", "def tasks_from_entries(case: str, entries: List[Entry]) -> Tuple[List[Task], Dict[str, List[str]], Set[str]]:\r\n\u001b[?2004l\r"]
[288.340404, "o", "\u001b[?2004h> "]
[288.340567, "o", "    children: Dict[str, List[str]] = {}\r\n\u001b[?2004l\r"]
[288.340644, "o", "\u001b[?2004h> "]
[288.34083, "o", "    depth: Dict[str, int] = {}\r\n\u001b[?2004l\r"]
[288.340884, "o", "\u001b[?2004h> "]
[288.341076, "o", "    first: Dict[str, Task] = {}\r\n\u001b[?2004l\r"]
[288.341185, "o", "\u001b[?2004h> "]
[288.341308, "o", "    drops: Set[str] = set()\r\n\u001b[?2004l\r"]
[288.341411, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.341544, "o", "    for e in entries:\r\n\u001b[?2004l\r"]
[288.341647, "o", "\u001b[?2004h> "]
[288.341774, "o", "        if e.kind == \"DROP\":\r\n\u001b[?2004l\r"]
[288.341841, "o", "\u001b[?2004h"]
[288.341899, "o", "> "]
[288.342032, "o", "            drops.add(e.ident)\r\n\u001b[?2004l\r"]
[288.342052, "o", "\u001b[?2004h"]
[288.342063, "o", "> \r\n"]
[288.342075, "o", "\u001b[?2004l\r"]
[288.342175, "o", "\u001b[?2004h> "]
[288.342271, "o", "    for e in entries:\r\n\u001b[?2004l\r"]
[288.342323, "o", "\u001b[?2004h> "]
[288.342498, "o", "        if e.kind == \"ROOT\":\r\n\u001b[?2004l\r"]
[288.342607, "o", "\u001b[?2004h> "]
[288.343151, "o", "            t = Task(case=case, task=e.ident, parent=\"-\", depth=0, lane=e.lane, at=e.at, seq=e.seq)\r\n\u001b[?2004l\r"]
[288.343321, "o", "\u001b[?2004h"]
[288.343388, "o", "> "]
[288.343562, "o", "            if t.task not in first:\r\n\u001b[?2004l\r"]
[288.34361, "o", "\u001b[?2004h> "]
[288.343819, "o", "                first[t.task] = t\r\n\u001b[?2004l\r"]
[288.343899, "o", "\u001b[?2004h> "]
[288.344111, "o", "            depth.setdefault(t.task, 0)\r\n\u001b[?2004l\r"]
[288.344236, "o", "\u001b[?2004h> "]
[288.344373, "o", "        elif e.kind == \"CHILD\":\r\n\u001b[?2004l\r"]
[288.344424, "o", "\u001b[?2004h> "]
[288.34482, "o", "            children.setdefault(e.parent, []).append(e.ident)\r\n\u001b[?2004l\r"]
[288.344911, "o", "\u001b[?2004h> "]
[288.345089, "o", "            if e.parent in depth:\r\n\u001b[?2004l\r"]
[288.345135, "o", "\u001b[?2004h> "]
[288.345515, "o", "                depth.setdefault(e.ident, depth[e.parent] + 1)\r\n\u001b[?2004l\r"]
[288.345579, "o", "\u001b[?2004h> "]
[288.345686, "o", "            else:\r\n\u001b[?2004l\r"]
[288.345767, "o", "\u001b[?2004h"]
[288.345921, "o", "> "]
[288.346036, "o", "                depth.setdefault(e.ident, 0)\r\n\u001b[?2004l\r"]
[288.346089, "o", "\u001b[?2004h> "]
[288.346795, "o", "            t = Task(case=case, task=e.ident, parent=e.parent, depth=depth[e.ident], lane=e.lane, at=e.at, seq=e.seq)\r\n\u001b[?2004l\r"]
[288.346924, "o", "\u001b[?2004h> "]
[288.347081, "o", "            if t.task not in first:\r\n\u001b[?2004l\r"]
[288.347219, "o", "\u001b[?2004h> "]
[288.347354, "o", "                first[t.task] = t\r\n\u001b[?2004l\r"]
[288.347407, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[288.347442, "o", "\u001b[?2004h"]
[288.347517, "o", "> "]
[288.347717, "o", "    tasks = sorted(first.values(), key=lambda t: t.seq)\r\n\u001b[?2004l\r"]
[288.347815, "o", "\u001b[?2004h> "]
[288.347878, "o", "    return tasks, children, drops\r\n\u001b[?2004l\r"]
[288.347971, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[288.348056, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.34825, "o", "def expand_drops(drops: Set[str], children: Dict[str, List[str]]) -> Set[str]:\r\n\u001b[?2004l\r"]
[288.34832, "o", "\u001b[?2004h"]
[288.348339, "o", "> "]
[288.348406, "o", "    removed: Set[str] = set()\r\n\u001b[?2004l\r"]
[288.348469, "o", "\u001b[?2004h"]
[288.348545, "o", ">     stack = list(drops)\r\n\u001b[?2004l\r"]
[288.348566, "o", "\u001b[?2004h"]
[288.34858, "o", "> "]
[288.348667, "o", "    while stack:\r\n\u001b[?2004l\r"]
[288.348734, "o", "\u001b[?2004h> "]
[288.348781, "o", "        x = stack.pop()\r\n\u001b[?2004l\r"]
[288.348847, "o", "\u001b[?2004h"]
[288.348933, "o", "> "]
[288.348953, "o", "        if x in removed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.349065, "o", "> "]
[288.349191, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.34926, "o", "        removed.add(x)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.349353, "o", "        for ch in children.get(x, []):\r\n\u001b[?2004l\r"]
[288.34937, "o", "\u001b[?2004h"]
[288.349384, "o", "> "]
[288.349492, "o", "            stack.append(ch)\r\n\u001b[?2004l\r"]
[288.34957, "o", "\u001b[?2004h> "]
[288.349674, "o", "    return removed\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.349745, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.349772, "o", "> "]
[288.350069, "o", "def schedule(case: str, cap: int, tasks: List[Task], removed: Set[str]) -> Tuple[List[Record], List[str]]:\r\n\u001b[?2004l\r"]
[288.350089, "o", "\u001b[?2004h"]
[288.350142, "o", "> "]
[288.350283, "o", "    live = [t for t in tasks if t.task not in removed]\r\n\u001b[?2004l\r"]
[288.350334, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[288.350372, "o", "\u001b[?2004h"]
[288.350388, "o", "> "]
[288.350519, "o", "    by_turn: Dict[int, List[Task]] = {}\r\n\u001b[?2004l\r"]
[288.350538, "o", "\u001b[?2004h"]
[288.350588, "o", "> "]
[288.350628, "o", "    max_turn = 0\r\n\u001b[?2004l\r"]
[288.350673, "o", "\u001b[?2004h> "]
[288.350745, "o", "    for t in live:\r\n\u001b[?2004l\r"]
[288.350764, "o", "\u001b[?2004h"]
[288.350814, "o", "> "]
[288.350936, "o", "        by_turn.setdefault(t.at, []).append(t)\r\n\u001b[?2004l\r"]
[288.350984, "o", "\u001b[?2004h> "]
[288.35108, "o", "        if t.at > max_turn:\r\n\u001b[?2004l\r"]
[288.351185, "o", "\u001b[?2004h> "]
[288.351241, "o", "            max_turn = t.at\r\n\u001b[?2004l\r"]
[288.35131, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.351329, "o", "> "]
[288.351457, "o", "    lane_q: Dict[str, List[Task]] = {}\r\n\u001b[?2004l\r"]
[288.351476, "o", "\u001b[?2004h"]
[288.351526, "o", "> "]
[288.351608, "o", "    accepted: List[Record] = []\r\n\u001b[?2004l\r"]
[288.351658, "o", "\u001b[?2004h> "]
[288.351772, "o", "    accepted_set: Set[str] = set()\r\n\u001b[?2004l\r"]
[288.351873, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.35194, "o", "> "]
[288.351999, "o", "    def queues_nonempty() -> bool:\r\n\u001b[?2004l\r"]
[288.352062, "o", "\u001b[?2004h> "]
[288.352215, "o", "        return any(len(q) > 0 for q in lane_q.values())\r\n\u001b[?2004l\r"]
[288.352278, "o", "\u001b[?2004h"]
[288.352329, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.352425, "o", "    turn = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.352488, "o", "> "]
[288.352573, "o", "    while turn <= max_turn or queues_nonempty():\r\n\u001b[?2004l\r"]
[288.352635, "o", "\u001b[?2004h> "]
[288.352764, "o", "        arrivals = by_turn.get(turn, [])\r\n\u001b[?2004l\r"]
[288.352832, "o", "\u001b[?2004h"]
[288.352851, "o", "> "]
[288.352963, "o", "        arrivals.sort(key=lambda t: t.seq)\r\n\u001b[?2004l\r"]
[288.353021, "o", "\u001b[?2004h> "]
[288.353101, "o", "        for t in arrivals:\r\n\u001b[?2004l\r"]
[288.353155, "o", "\u001b[?2004h"]
[288.35322, "o", "> "]
[288.353296, "o", "            if t.task in accepted_set:\r\n\u001b[?2004l\r"]
[288.353323, "o", "\u001b[?2004h> "]
[288.35342, "o", "                continue\r\n\u001b[?2004l\r"]
[288.353532, "o", "\u001b[?2004h> "]
[288.353642, "o", "            lane_q.setdefault(t.lane, []).append(t)\r\n\u001b[?2004l\r"]
[288.353664, "o", "\u001b[?2004h"]
[288.353686, "o", "> \r\n\u001b[?2004l\r"]
[288.353705, "o", "\u001b[?2004h"]
[288.353718, "o", "> "]
[288.353896, "o", "        for lane in sorted(lane_q.keys()):\r\n\u001b[?2004l\r"]
[288.353957, "o", "\u001b[?2004h> "]
[288.35399, "o", "            q = lane_q[lane]\r\n\u001b[?2004l\r"]
[288.354042, "o", "\u001b[?2004h"]
[288.354061, "o", "> "]
[288.35415, "o", "            took = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.354168, "o", "> "]
[288.354298, "o", "            while q and took < cap:\r\n\u001b[?2004l\r"]
[288.354315, "o", "\u001b[?2004h"]
[288.354327, "o", "> "]
[288.354437, "o", "                t = q.pop(0)\r\n\u001b[?2004l\r"]
[288.354491, "o", "\u001b[?2004h> "]
[288.354626, "o", "                if t.task in accepted_set:\r\n\u001b[?2004l\r"]
[288.354645, "o", "\u001b[?2004h"]
[288.354669, "o", "> "]
[288.354776, "o", "                    continue\r\n\u001b[?2004l\r"]
[288.354827, "o", "\u001b[?2004h> "]
[288.354967, "o", "                accepted_set.add(t.task)\r\n\u001b[?2004l\r"]
[288.355048, "o", "\u001b[?2004h> "]
[288.355395, "o", "                accepted.append(Record(case=case, task=t.task, parent=t.parent, depth=t.depth, lane=t.lane, turn=turn))\r\n\u001b[?2004l\r"]
[288.355419, "o", "\u001b[?2004h"]
[288.35543, "o", "> "]
[288.355537, "o", "                took += 1\r\n\u001b[?2004l\r"]
[288.355609, "o", "\u001b[?2004h> "]
[288.355702, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.355797, "o", "        turn += 1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[288.355865, "o", "\u001b[?2004h> "]
[288.356031, "o", "    pending = sorted([t.task for t in live if t.task not in accepted_set])\r\n\u001b[?2004l\r"]
[288.35609, "o", "\u001b[?2004h> "]
[288.356176, "o", "    return accepted, pending\r\n\u001b[?2004l\r"]
[288.356196, "o", "\u001b[?2004h"]
[288.356249, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.356268, "o", "> \r\n\u001b[?2004l\r"]
[288.35632, "o", "\u001b[?2004h> "]
[288.356567, "o", "def write_outputs(root: Path, out: Path, work: Path, case_names: List[str]) -> None:\r\n\u001b[?2004l\r"]
[288.356585, "o", "\u001b[?2004h"]
[288.356596, "o", "> "]
[288.356726, "o", "    ledgers_dir = work / \"ledgers\"\r\n\u001b[?2004l\r"]
[288.356744, "o", "\u001b[?2004h"]
[288.356755, "o", "> "]
[288.35689, "o", "    journals_dir = work / \"journals\"\r\n\u001b[?2004l\r"]
[288.356909, "o", "\u001b[?2004h"]
[288.356966, "o", "> "]
[288.357105, "o", "    ledgers_dir.mkdir(parents=True, exist_ok=True)\r\n\u001b[?2004l\r"]
[288.357124, "o", "\u001b[?2004h"]
[288.357176, "o", "> "]
[288.357315, "o", "    journals_dir.mkdir(parents=True, exist_ok=True)\r\n\u001b[?2004l\r"]
[288.357335, "o", "\u001b[?2004h"]
[288.357383, "o", "> \r\n\u001b[?2004l\r"]
[288.3574, "o", "\u001b[?2004h"]
[288.357417, "o", "> "]
[288.357496, "o", "    reports = []\r\n\u001b[?2004l\r"]
[288.357562, "o", "\u001b[?2004h> "]
[288.357649, "o", "    for name in case_names:\r\n\u001b[?2004l\r"]
[288.357715, "o", "\u001b[?2004h> "]
[288.357887, "o", "        plan_path = root / \"data\" / \"cases\" / f\"{name}.plan\"\r\n\u001b[?2004l\r"]
[288.357952, "o", "\u001b[?2004h> "]
[288.358096, "o", "        case, cap, entries = parse_plan(plan_path)\r\n\u001b[?2004l\r"]
[288.35816, "o", "\u001b[?2004h> "]
[288.358347, "o", "        tasks, children, drops = tasks_from_entries(case, entries)\r\n\u001b[?2004l\r"]
[288.358412, "o", "\u001b[?2004h> "]
[288.358558, "o", "        removed = expand_drops(drops, children)\r\n\u001b[?2004l\r"]
[288.358611, "o", "\u001b[?2004h> "]
[288.358812, "o", "        trace, pending = schedule(case, cap, tasks, removed)\r\n\u001b[?2004l\r"]
[288.358909, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.359079, "o", "        ledger_path = ledgers_dir / f\"{case}.jsonl\"\r\n\u001b[?2004l\r"]
[288.359141, "o", "\u001b[?2004h> "]
[288.359323, "o", "        journal_path = journals_dir / f\"{case}.txt\"\r\n\u001b[?2004l\r"]
[288.359377, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[288.359476, "o", "\u001b[?2004h> "]
[288.359625, "o", "        with ledger_path.open(\"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r"]
[288.359677, "o", "\u001b[?2004h> "]
[288.359774, "o", "            for r in trace:\r\n"]
[288.359866, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[288.360315, "o", "                f.write(json.dumps({\"case\": r.case, \"task\": r.task, \"parent\": r.parent, \"depth\": r.depth, \"lane\": r.lane, \"turn\": r.turn}, separators=(\",\", \":\")))\r\n\u001b[?2004l\r"]
[288.360429, "o", "\u001b[?2004h"]
[288.360517, "o", ">                 f.write(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.360641, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.360792, "o", "        with journal_path.open(\"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r"]
[288.36081, "o", "\u001b[?2004h"]
[288.360826, "o", "> "]
[288.360945, "o", "            for r in trace:\r\n\u001b[?2004l\r"]
[288.360999, "o", "\u001b[?2004h> "]
[288.361282, "o", "                f.write(f\"{r.case} {r.task} {r.parent} {r.depth} {r.lane} {r.turn}\\n\")\r\n\u001b[?2004l\r"]
[288.361421, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.361519, "o", "        finished = (len(pending) == 0)\r\n\u001b[?2004l\r"]
[288.36157, "o", "\u001b[?2004h"]
[288.361594, "o", "> "]
[288.361664, "o", "        reports.append({\r\n\u001b[?2004l\r"]
[288.361708, "o", "\u001b[?2004h"]
[288.361727, "o", "> "]
[288.361806, "o", "            \"name\": case,\r\n\u001b[?2004l\r"]
[288.361895, "o", "\u001b[?2004h> "]
[288.361966, "o", "            \"ok\": finished,\r\n\u001b[?2004l\r"]
[288.362041, "o", "\u001b[?2004h> "]
[288.362129, "o", "            \"finished\": finished,\r\n\u001b[?2004l\r"]
[288.362195, "o", "\u001b[?2004h> "]
[288.362282, "o", "            \"pending\": pending,\r\n\u001b[?2004l\r"]
[288.362349, "o", "\u001b[?2004h"]
[288.362429, "o", "> "]
[288.362769, "o", "            \"trace\": [{\"case\": r.case, \"task\": r.task, \"parent\": r.parent, \"depth\": r.depth, \"lane\": r.lane, \"turn\": r.turn} for r in trace],\r\n\u001b[?2004l\r"]
[288.362793, "o", "\u001b[?2004h"]
[288.362926, "o", "> "]
[288.362977, "o", "            \"ledger\": str(ledger_path),\r\n\u001b[?2004l\r"]
[288.363074, "o", "\u001b[?2004h> "]
[288.363164, "o", "            \"journal\": str(journal_path),\r\n\u001b[?2004l\r"]
[288.363199, "o", "\u001b[?2004h"]
[288.363234, "o", "> "]
[288.363385, "o", "        })\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.363545, "o", "    out.parent.mkdir(parents=True, exist_ok=True)\r\n\u001b[?2004l\r"]
[288.363568, "o", "\u001b[?2004h"]
[288.363582, "o", "> "]
[288.363886, "o", "    out.write_text(json.dumps({\"cases\": reports}, separators=(\",\", \":\")) + \"\\n\", encoding=\"utf-8\")\r\n\u001b[?2004l\r"]
[288.36396, "o", "\u001b[?2004h"]
[288.363984, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[288.364058, "o", "\u001b[?2004h"]
[288.364083, "o", "> "]
[288.364143, "o", "def main() -> None:\r\n\u001b[?2004l\r"]
[288.364166, "o", "\u001b[?2004h> "]
[288.364276, "o", "    ap = argparse.ArgumentParser()\r\n\u001b[?2004l\r"]
[288.364298, "o", "\u001b[?2004h"]
[288.364311, "o", "> "]
[288.364475, "o", "    ap.add_argument(\"--root\", default=\"/app\")\r\n\u001b[?2004l\r"]
[288.364529, "o", "\u001b[?2004h> "]
[288.364751, "o", "    ap.add_argument(\"--out\", default=\"/app/output/executor-audit.json\")\r\n\u001b[?2004l\r"]
[288.364786, "o", "\u001b[?2004h"]
[288.364824, "o", "> "]
[288.36501, "o", "    ap.add_argument(\"--work\", default=\"/app/output/runtime\")\r\n\u001b[?2004l\r"]
[288.365058, "o", "\u001b[?2004h"]
[288.365075, "o", "> "]
[288.365176, "o", "    ap.add_argument(\"--case\")\r\n\u001b[?2004l\r"]
[288.365227, "o", "\u001b[?2004h> "]
[288.365318, "o", "    args = ap.parse_args()\r\n\u001b[?2004l\r"]
[288.36538, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[288.365395, "o", "\u001b[?2004h"]
[288.365405, "o", "> "]
[288.365522, "o", "    root = Path(args.root)\r\n\u001b[?2004l\r"]
[288.365552, "o", "\u001b[?2004h"]
[288.365583, "o", "> "]
[288.365665, "o", "    out = Path(args.out)\r\n\u001b[?2004l\r"]
[288.365752, "o", "\u001b[?2004h> "]
[288.365851, "o", "    work = Path(args.work)\r\n\u001b[?2004l\r"]
[288.365877, "o", "\u001b[?2004h"]
[288.365896, "o", "> "]
[288.365911, "o", "\r\n\u001b[?2004l\r"]
[288.365922, "o", "\u001b[?2004h"]
[288.365936, "o", "> "]
[288.366118, "o", "    cases = [args.case] if args.case else CASE_ORDER\r\n\u001b[?2004l\r"]
[288.366213, "o", "\u001b[?2004h> "]
[288.366315, "o", "    write_outputs(root, out, work, cases)\r\n\u001b[?2004l\r"]
[288.366376, "o", "\u001b[?2004h"]
[288.366441, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.366497, "o", "> "]
[288.366609, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.366665, "o", "    main()\r\n\u001b[?2004l\r"]
[288.366784, "o", "\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
[288.36969, "o", "\u001b[?2004hroot@36b1c5fd8ba3:/app# "]
[288.369842, "o", "chmod +x /app/scripts/executor_ctl.py\r\n\u001b[?2004l\r"]
[288.370698, "o", "\u001b[?2004h"]
[288.370767, "o", "root@36b1c5fd8ba3:/app# "]
[288.370907, "o", "python3 -m py_compile /app/scripts/executor_ctl.py\r\n\u001b[?2004l\r"]
[288.401001, "o", "\u001b[?2004hroot@36b1c5fd8ba3:/app# "]
[289.321958, "i", "cat > /app/scripts/run-matrix.sh <<'SH'\n#!/bin/bash\nset -euo pipefail\n\nbash /app/scripts/clean-room.sh\npython3 /app/scripts/executor_ctl.py --out /app/output/executor-audit.json --work /app/output/runtime\nSH\nchmod +x /app/scripts/run-matrix.sh\n"]
[289.322232, "o", "cat > /app/scripts/run-matrix.sh <<'SH'\r\n\u001b[?2004l\r"]
[289.322494, "o", "\u001b[?2004h> "]
[289.323601, "o", "#!/bin/bash\r\n\u001b[?2004l\r\u001b[?2004h> set -euo pipefail\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> bash /app/scripts/clean-room.sh\r\n\u001b[?2004l\r"]
[289.323648, "o", "\u001b[?2004h> python3 /app/scripts/executor_ctl.py --out /app/output/executor-audit.json --work /app/output/runtime\r\n\u001b[?2004l\r\u001b[?2004h> SH\r\n\u001b[?2004l\r"]
[289.324827, "o", "\u001b[?2004h"]
[289.324901, "o", "root@36b1c5fd8ba3:/app# "]
[289.324982, "o", "chmod +x /app/scripts/run-matrix.sh\r\n\u001b[?2004l\r"]
[289.325902, "o", "\u001b[?2004h"]
[289.325963, "o", "root@36b1c5fd8ba3:/app# "]
[289.439359, "i", "cat > /app/scripts/run-one.sh <<'SH'\n#!/bin/bash\nset -euo pipefail\n\ncase_name=\"${1:?case name required}\"\nout=\"${2:-/app/output/executor-audit.json}\"\nwork=\"${3:-/app/output/runtime}\"\nmkdir -p /app/output\npython3 /app/scripts/executor_ctl.py --case \"$case_name\" --out \"$out\" --work \"$work\"\nSH\nchmod +x /app/scripts/run-one.sh\n"]
[289.439521, "o", "cat > /app/scripts/run-one.sh <<'SH'\r\n\u001b[?2004l\r"]
[289.439603, "o", "\u001b[?2004h> "]
[289.43963, "o", "#!/bin/bash\r\n\u001b[?2004l\r"]
[289.439685, "o", "\u001b[?2004h"]
[289.439743, "o", "> "]
[289.440803, "o", "set -euo pipefail\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> case_name=\"${1:?case name required}\"\r\n\u001b[?2004l\r\u001b[?2004h> out=\"${2:-/app/output/executor-audit.json}\"\r\n\u001b[?2004l\r\u001b[?2004h> work=\"${3:-/app/output/runtime}\"\r\n\u001b[?2004l\r\u001b[?2004h> mkdir -p /app/output\r\n\u001b[?2004l\r\u001b[?2004h> "]
[289.440963, "o", "python3 /app/scripts/executor_ctl.py --case \"$case_name\" --out \"$out\" --work \"$work\"\r\n\u001b[?2004l\r"]
[289.440988, "o", "\u001b[?2004h"]
[289.441018, "o", "> "]
[289.441027, "o", "SH"]
[289.441036, "o", "\r\n"]
[289.441044, "o", "\u001b[?2004l\r"]
[289.442227, "o", "\u001b[?2004h"]
[289.44225, "o", "root@36b1c5fd8ba3:/app# "]
[289.442392, "o", "chmod +x /app/scripts/run-one.sh\r\n\u001b[?2004l\r"]
[289.44327, "o", "\u001b[?2004h"]
[289.443299, "o", "root@36b1c5fd8ba3:/app# "]
[289.549504, "i", "bash -lc 'bash /app/scripts/run-matrix.sh'\n"]
[289.549697, "o", "bash -lc 'bash /app/scripts/run-matrix.sh'\r\n\u001b[?2004l\r"]
[289.604673, "o", "\u001b[?2004hroot@36b1c5fd8ba3:/app# "]
