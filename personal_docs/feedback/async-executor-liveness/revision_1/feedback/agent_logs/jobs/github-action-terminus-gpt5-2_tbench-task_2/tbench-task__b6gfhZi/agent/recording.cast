[288.322425, "o", "\u001b[?2004h> "]
[288.322647, "o", "    kind: str  # ROOT/CHILD/DROP\r\n\u001b[?2004l\r"]
[288.322708, "o", "\u001b[?2004h> "]
[288.322845, "o", "    ident: str = \"\"\r\n\u001b[?2004l\r"]
[288.322899, "o", "\u001b[?2004h"]
[288.322939, "o", "> "]
