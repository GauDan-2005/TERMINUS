[265.155868, "i", "cat > /app/scripts/executor_ctl.py <<'PY'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Dict, List, Tuple, Optional, Set\n\nCASE_ORDER = [\"amber\", \"cobalt\", \"drake\", \"ember\", \"flint\", \"graphite\"]\n\n@dataclass(frozen=True)\nclass Entry:\n    kind: str  # CAP/ROOT/CHILD/DROP\n    ident: str = \"\"\n    parent: str = \"\"\n    lane: str = \"\"\n    at: int = 0\n    seq: int = 0\n    cap: int = 1\n\n@dataclass\nclass Task:\n    case: str\n    task: str\n    parent: str\n    depth: int\n    lane: str\n    at: int\n    seq: int\n\n@dataclass\nclass Record:\n    case: str\n    task: str\n    parent: str\n    depth: int\n    lane: str\n    turn: int  # acceptance turn\n\n\ndef parse_plan(path: Path) -> Tuple[str, int, List[Entry]]:\n    text = path.read_text(encoding=\"utf-8\")\n    cap = 1\n    entries: List[Entry] = []\n    name = path.stem or \"case\"\n    for raw in text.splitlines():\n        line = raw.strip()\n        if not line or line.startswith('#'):\n            c"]
[265.1562, "i", "ontinue\n        parts = line.split()\n        if parts[:1] == [\"CAP\"] and len(parts) == 2:\n            try:\n                cap = int(parts[1])\n            except ValueError:\n                cap = 1\n            continue\n        if parts[:1] == [\"ROOT\"] and len(parts) == 4:\n            seq = len(entries)\n            ident, lane, at_s = parts[1], parts[2], parts[3]\n            try:\n                at = int(at_s)\n            except ValueError:\n                at = 0\n            entries.append(Entry(kind=\"ROOT\", ident=ident, lane=lane, at=at, seq=seq))\n            continue\n        if parts[:1] == [\"CHILD\"] and len(parts) == 5:\n            seq = len(entries)\n            parent, ident, lane, at_s = parts[1], parts[2], parts[3], parts[4]\n            try:\n                at = int(at_s)\n            except ValueError:\n                at = 0\n            entries.append(Entry(kind=\"CHILD\", parent=parent, ident=ident, lane=lane, at=at, seq=seq))\n            continue\n        if parts[:1] == [\"DROP\"] and len(parts) == 2:\n    "]
[265.15624, "o", "cat > /app/scripts/executor_ctl.py <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.156257, "i", "        entries.append(Entry(kind=\"DROP\", ident=parts[1]))\n            continue\n        # ignore unknown\n    return name, max(1, cap), entries\n\n\ndef compute_depths_and_tasks(case: str, entries: List[Entry]) -> Tuple[List[Task], Dict[str, List[str]], Set[str]]:\n    # Build parent links (from CHILD entries) and children adjacency for drop-descendants.\n    children: Dict[str, List[str]] = {}\n    parent_of: Dict[str, str] = {}\n\n    # record first occurrence of each logical task to dedupe\n    first_task_def: Dict[str, Task] = {}\n\n    # We'll compute depth with best-effort: depth(parent)+1 when parent known, else 0.\n    depth: Dict[str, int] = {}\n\n    drops: Set[str] = set()\n\n    for e in entries:\n        if e.kind == \"DROP\":\n            drops.add(e.ident)\n\n    for e in entries:\n        if e.kind == \"ROOT\":\n            t = Task(case=case, task=e.ident, parent=\"-\", depth=0, lane=e.lane, at=e.at, seq=e.seq)\n            if t.task not in first_task_def:\n                first_task_def[t.task] = t\n                depth.s"]
[265.156276, "i", "etdefault(t.task, 0)\n        elif e.kind == \"CHILD\":\n            parent_of[e.ident] = e.parent\n            children.setdefault(e.parent, []).append(e.ident)\n            d = depth.get(e.parent, 0) + 1 if e.parent in depth else 0\n            depth.setdefault(e.ident, d)\n            t = Task(case=case, task=e.ident, parent=e.parent, depth=depth[e.ident], lane=e.lane, at=e.at, seq=e.seq)\n            if t.task not in first_task_def:\n                first_task_def[t.task] = t\n\n    tasks = sorted(first_task_def.values(), key=lambda t: t.seq)\n    return tasks, children, drops\n\n\ndef expand_drops(drops: Set[str], children: Dict[str, List[str]]) -> Set[str]:\n    removed: Set[str] = set()\n    stack = list(drops)\n    while stack:\n        x = stack.pop()\n        if x in removed:\n            continue\n        removed.add(x)\n        for ch in children.get(x, []):\n            stack.append(ch)\n    return removed\n\n\ndef schedule(case: str, cap: int, tasks: List[Task], removed: Set[str]) -> Tuple[List[Record], List[str]]:\n    live"]
[265.156292, "i", " = [t for t in tasks if t.task not in removed]\n\n    # pending list is of live tasks that never accepted (should become empty if scheduler drains)\n    # We'll simulate turn-by-turn accepting up to cap per lane per turn.\n\n    by_turn: Dict[int, List[Task]] = {}\n    max_turn = 0\n    for t in live:\n        by_turn.setdefault(t.at, []).append(t)\n        max_turn = max(max_turn, t.at)\n\n    # per-lane FIFO queues, order by plan seq\n    lane_q: Dict[str, List[Task]] = {}\n\n    accepted: List[Record] = []\n    accepted_set: Set[str] = set()\n\n    # Run until no future arrivals and queues empty\n    turn = 0\n    def queues_nonempty() -> bool:\n        return any(lane_q.get(l) for l in lane_q)\n\n    while turn <= max_turn or queues_nonempty():\n        arrivals = by_turn.get(turn, [])\n        arrivals.sort(key=lambda t: t.seq)\n        for t in arrivals:\n            if t.task in accepted_set:\n                continue\n            lane_q.setdefault(t.lane, []).append(t)\n\n        for lane in sorted(lane_q.keys()):\n            q = "]
[265.156306, "i", "lane_q[lane]\n            n = 0\n            while q and n < cap:\n                t = q.pop(0)\n                if t.task in accepted_set:\n                    continue\n                accepted_set.add(t.task)\n                accepted.append(Record(case=case, task=t.task, parent=t.parent, depth=t.depth, lane=t.lane, turn=turn))\n                n += 1\n            lane_q[lane] = q\n\n        turn += 1\n        if turn > max_turn and not queues_nonempty():\n            break\n\n    # Trace ordering already matches: acceptance turn asc, lanes processed in name order each turn, FIFO within lane.\n    pending = sorted([t.task for t in live if t.task not in accepted_set])\n    return accepted, pending\n\n\ndef write_outputs(root: Path, out: Path, work: Path, cases: List[str]):\n    all_cases = []\n    work_ledgers = work / \"ledgers\"\n    work_journals = work / \"journals\"\n    work_ledgers.mkdir(parents=True, exist_ok=True)\n    work_journals.mkdir(parents=True, exist_ok=True)\n\n    for name in cases:\n        plan_path = root / \"data\" / "]
[265.156316, "i", "\"cases\" / f\"{name}.plan\"\n        case, cap, entries = parse_plan(plan_path)\n        tasks, children, drops = compute_depths_and_tasks(case, entries)\n        removed = expand_drops(drops, children)\n        trace, pending = schedule(case, cap, tasks, removed)\n\n        ledger_path = work_ledgers / f\"{case}.jsonl\"\n        journal_path = work_journals / f\"{case}.txt\"\n\n        with ledger_path.open(\"w\", encoding=\"utf-8\") as f:\n            for r in trace:\n                f.write(json.dumps({\"case\": r.case, \"task\": r.task, \"parent\": r.parent, \"depth\": r.depth, \"lane\": r.lane, \"turn\": r.turn}, separators=(\",\", \":\")))\n                f.write(\"\\n\")\n\n        with journal_path.open(\"w\", encoding=\"utf-8\") as f:\n            for r in trace:\n                f.write(f\"{r.case} {r.task} {r.parent} {r.depth} {r.lane} {r.turn}\\n\")\n\n        finished = len(pending) == 0\n        ok = finished\n        all_cases.append({\n            \"name\": case,\n            \"ok\": ok,\n            \"finished\": finished,\n            \"pending\": pending,\n "]
[265.156329, "i", "           \"trace\": [{\"case\": r.case, \"task\": r.task, \"parent\": r.parent, \"depth\": r.depth, \"lane\": r.lane, \"turn\": r.turn} for r in trace],\n            \"ledger\": str(ledger_path),\n            \"journal\": str(journal_path),\n        })\n\n    out.parent.mkdir(parents=True, exist_ok=True)\n    out.write_text(json.dumps({\"cases\": all_cases}, ensure_ascii=False, separators=(\",\", \":\")) + \"\\n\", encoding=\"utf-8\")\n\n\ndef main():\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\"--root\", default=\"/app\")\n    ap.add_argument(\"--out\", default=\"/app/output/executor-audit.json\")\n    ap.add_argument(\"--work\", default=\"/app/output/runtime\")\n    ap.add_argument(\"--case\", default=None)\n    args = ap.parse_args()\n\n    root = Path(args.root)\n    out = Path(args.out)\n    work = Path(args.work)\n\n    if args.case:\n        cases = [args.case]\n    else:\n        cases = CASE_ORDER\n\n    write_outputs(root, out, work, cases)\n\nif __name__ == \"__main__\":\n    main()\nPY\nchmod +x /app/scripts/executor_ctl.py\n"]
