[288.32312, "o", "\u001b[?2004h> "]
[288.323248, "o", "    lane: str = \"\"\r\n"]
[288.323285, "o", "\u001b[?2004l\r"]
[288.323355, "o", "\u001b[?2004h"]
[288.323372, "o", "> "]
[288.323471, "o", "    at: int = 0\r\n\u001b[?2004l\r"]
[288.3235, "o", "\u001b[?2004h"]
[288.323572, "o", "> "]
