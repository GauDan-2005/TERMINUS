[303.065391, "i", "python3 - <<'PY'\nimport json, hashlib, pathlib\np=pathlib.Path('/app/output/executor-audit.json')\nb=p.read_bytes()\nprint('sha256', hashlib.sha256(b).hexdigest(), 'bytes', len(b))\n# normalize to ignore absolute paths ordering should be stable\nobj=json.loads(b)\nfor c in obj['cases']:\n    c['ledger']=pathlib.Path(c['ledger']).name\n    c['journal']=pathlib.Path(c['journal']).name\nnorm=json.dumps(obj, sort_keys=True, separators=(',',':')).encode()\nprint('norm sha256', hashlib.sha256(norm).hexdigest(), 'norm bytes', len(norm))\nPY\n"]
[303.065885, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json, hashlib, pathlib\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.068412, "o", "p=pathlib.Path('/app/output/executor-audit.json')\r\n\u001b[?2004l\r\u001b[?2004h> b=p.read_bytes()\r\n\u001b[?2004l\r\u001b[?2004h> print('sha256', hashlib.sha256(b).hexdigest(), 'bytes', len(b))\r\n\u001b[?2004l\r\u001b[?2004h> # normalize to ignore absolute paths ordering should be stable\r\n\u001b[?2004l\r\u001b[?2004h> obj=json.loads(b)\r\n\u001b[?2004l\r\u001b[?2004h> for c in obj['cases']:\r\n\u001b[?2004l\r\u001b[?2004h>     c['ledger']=pathlib.Path(c['ledger']).name\r\n\u001b[?2004l\r\u001b[?2004h>     c['journal']=pathlib.Path(c['journal']).name\r\n\u001b[?2004l\r\u001b[?2004h> norm=json.dumps(obj, sort_keys=True, separators=(',',':')).encode()\r\n\u001b[?2004l\r\u001b[?2004h> print('norm sha256', hashlib.sha256(norm).hexdigest(), 'norm bytes', len(norm))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
[303.092723, "o", "sha256 1e93c04328c94a0907bd2d07a44f1b9931e519dc5dfeaac68ee53d0d27ba9864 bytes 3034\r\n"]
