[301.80979, "i", "python3 - <<'PY'\nimport json, pathlib\n\naudit_path=pathlib.Path('/app/output/executor-audit.json')\ndata=json.loads(audit_path.read_text())\n\ndef row_tuple(r):\n    return (r['case'], r['task'], r['parent'], int(r['depth']), r['lane'], int(r['turn']))\n\nok=True\nfor c in data['cases']:\n    trace=c['trace']\n    led_path=pathlib.Path(c['ledger'])\n    jour_path=pathlib.Path(c['journal'])\n\n    led=[json.loads(line) for line in led_path.read_text().splitlines() if line.strip()]\n    jour=[line.split() for line in jour_path.read_text().splitlines() if line.strip()]\n\n    if len(led)!=len(trace):\n        print('LEN mismatch ledger', c['name']); ok=False\n    if len(jour)!=len(trace):\n        print('LEN mismatch journal', c['name']); ok=False\n\n    for i,r in enumerate(trace):\n        if i < len(led) and led[i]!=r:\n            print('ledger row mismatch', c['name'], i, led[i], r); ok=False; break\n        if i < len(jour):\n            exp=[r['case'], r['task'], r['parent'], str(r['depth']), r['lane'], str(r['turn'])]\n          "]
[301.80984, "i", "  if jour[i]!=exp:\n                print('journal row mismatch', c['name'], i, jour[i], exp); ok=False; break\n\n    # ordering check: nondecreasing by (turn, lane) and stable within lane by acceptance order\n    tuples=[(int(r['turn']), r['lane'], i) for i,r in enumerate(trace)]\n    if tuples!=sorted(tuples, key=lambda x:(x[0], x[1], x[2])):\n        print('ordering violation', c['name']); ok=False\n\nprint('VALID', ok)\nPY\n"]
