[288.319395, "i", "            continue\n\n    return name, max(1, cap), entries\n\n\ndef tasks_from_entries(case: str, entries: List[Entry]) -> Tuple[List[Task], Dict[str, List[str]], Set[str]]:\n    children: Dict[str, List[str]] = {}\n    depth: Dict[str, int] = {}\n    first: Dict[str, Task] = {}\n    drops: Set[str] = set()\n\n    for e in entries:\n        if e.kind == \"DROP\":\n            drops.add(e.ident)\n\n    for e in entries:\n        if e.kind == \"ROOT\":\n            t = Task(case=case, task=e.ident, parent=\"-\", depth=0, lane=e.lane, at=e.at, seq=e.seq)\n            if t.task not in first:\n                first[t.task] = t\n            depth.setdefault(t.task, 0)\n        elif e.kind == \"CHILD\":\n            children.setdefault(e.parent, []).append(e.ident)\n            if e.parent in depth:\n                depth.setdefault(e.ident, depth[e.parent] + 1)\n            else:\n                depth.setdefault(e.ident, 0)\n            t = Task(case=case, task=e.ident, parent=e.parent, depth=depth[e.ident], lane=e.lane, at=e.at, seq=e.seq)\n    "]
[288.319405, "o", "\u001b[?2004h"]
[288.319481, "i", "        if t.task not in first:\n                first[t.task] = t\n\n    tasks = sorted(first.values(), key=lambda t: t.seq)\n    return tasks, children, drops\n\n\ndef expand_drops(drops: Set[str], children: Dict[str, List[str]]) -> Set[str]:\n    removed: Set[str] = set()\n    stack = list(drops)\n    while stack:\n        x = stack.pop()\n        if x in removed:\n            continue\n        removed.add(x)\n        for ch in children.get(x, []):\n            stack.append(ch)\n    return removed\n\n\ndef schedule(case: str, cap: int, tasks: List[Task], removed: Set[str]) -> Tuple[List[Record], List[str]]:\n    live = [t for t in tasks if t.task not in removed]\n\n    by_turn: Dict[int, List[Task]] = {}\n    max_turn = 0\n    for t in live:\n        by_turn.setdefault(t.at, []).append(t)\n        if t.at > max_turn:\n            max_turn = t.at\n\n    lane_q: Dict[str, List[Task]] = {}\n    accepted: List[Record] = []\n    accepted_set: Set[str] = set()\n\n    def queues_nonempty() -> bool:\n        return any(len(q) > 0 for q in lane_q.va"]
[288.319518, "o", "> "]
[288.319531, "i", "lues())\n\n    turn = 0\n    while turn <= max_turn or queues_nonempty():\n        arrivals = by_turn.get(turn, [])\n        arrivals.sort(key=lambda t: t.seq)\n        for t in arrivals:\n            if t.task in accepted_set:\n                continue\n            lane_q.setdefault(t.lane, []).append(t)\n\n        for lane in sorted(lane_q.keys()):\n            q = lane_q[lane]\n            took = 0\n            while q and took < cap:\n                t = q.pop(0)\n                if t.task in accepted_set:\n                    continue\n                accepted_set.add(t.task)\n                accepted.append(Record(case=case, task=t.task, parent=t.parent, depth=t.depth, lane=t.lane, turn=turn))\n                took += 1\n\n        turn += 1\n\n    pending = sorted([t.task for t in live if t.task not in accepted_set])\n    return accepted, pending\n\n\ndef write_outputs(root: Path, out: Path, work: Path, case_names: List[str]) -> None:\n    ledgers_dir = work / \"ledgers\"\n    journals_dir = work / \"journals\"\n    ledgers_dir.mkdir(par"]
[288.319545, "i", "ents=True, exist_ok=True)\n    journals_dir.mkdir(parents=True, exist_ok=True)\n\n    reports = []\n    for name in case_names:\n        plan_path = root / \"data\" / \"cases\" / f\"{name}.plan\"\n        case, cap, entries = parse_plan(plan_path)\n        tasks, children, drops = tasks_from_entries(case, entries)\n        removed = expand_drops(drops, children)\n        trace, pending = schedule(case, cap, tasks, removed)\n\n        ledger_path = ledgers_dir / f\"{case}.jsonl\"\n        journal_path = journals_dir / f\"{case}.txt\"\n\n        with ledger_path.open(\"w\", encoding=\"utf-8\") as f:\n            for r in trace:\n                f.write(json.dumps({\"case\": r.case, \"task\": r.task, \"parent\": r.parent, \"depth\": r.depth, \"lane\": r.lane, \"turn\": r.turn}, separators=(\",\", \":\")))\n                f.write(\"\\n\")\n\n        with journal_path.open(\"w\", encoding=\"utf-8\") as f:\n            for r in trace:\n                f.write(f\"{r.case} {r.task} {r.parent} {r.depth} {r.lane} {r.turn}\\n\")\n\n        finished = (len(pending) == 0)\n        re"]
[288.319556, "o", "#!/usr/bin/env python3\r\n"]
[288.319563, "i", "ports.append({\n            \"name\": case,\n            \"ok\": finished,\n            \"finished\": finished,\n            \"pending\": pending,\n            \"trace\": [{\"case\": r.case, \"task\": r.task, \"parent\": r.parent, \"depth\": r.depth, \"lane\": r.lane, \"turn\": r.turn} for r in trace],\n            \"ledger\": str(ledger_path),\n            \"journal\": str(journal_path),\n        })\n\n    out.parent.mkdir(parents=True, exist_ok=True)\n    out.write_text(json.dumps({\"cases\": reports}, separators=(\",\", \":\")) + \"\\n\", encoding=\"utf-8\")\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\"--root\", default=\"/app\")\n    ap.add_argument(\"--out\", default=\"/app/output/executor-audit.json\")\n    ap.add_argument(\"--work\", default=\"/app/output/runtime\")\n    ap.add_argument(\"--case\")\n    args = ap.parse_args()\n\n    root = Path(args.root)\n    out = Path(args.out)\n    work = Path(args.work)\n\n    cases = [args.case] if args.case else CASE_ORDER\n    write_outputs(root, out, work, cases)\n\n\nif __name__ == \"__main__\":\n    ma"]
