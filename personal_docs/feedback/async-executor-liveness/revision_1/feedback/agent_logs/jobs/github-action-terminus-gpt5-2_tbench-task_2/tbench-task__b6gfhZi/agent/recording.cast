[290.673416, "i", "python3 - <<'PY'\nimport json, pathlib\np=pathlib.Path('/app/output/executor-audit.json')\nprint('audit exists', p.exists(), 'bytes', p.stat().st_size if p.exists() else None)\ndata=json.loads(p.read_text())\nprint('case names', [c['name'] for c in data['cases']])\nfor c in data['cases']:\n    led=pathlib.Path(c['ledger']); jour=pathlib.Path(c['journal'])\n    tlen=len(c['trace'])\n    llen=len(led.read_text().splitlines())\n    jlen=len(jour.read_text().splitlines())\n    print(c['name'], 'ok', c['ok'], 'finished', c['finished'], 'pending', c['pending'], 'trace', tlen, 'ledger', llen, 'journal', jlen)\nPY\n"]
