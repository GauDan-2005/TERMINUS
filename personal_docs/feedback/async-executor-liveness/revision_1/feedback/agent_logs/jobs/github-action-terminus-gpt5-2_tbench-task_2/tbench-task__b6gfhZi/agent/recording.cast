[265.172631, "o", "            parent, ident, lane, at_s = parts[1], parts[2], parts[3], parts[4]\r\n\u001b[?2004l\r"]
[265.172734, "o", "\u001b[?2004h> "]
[265.172797, "o", "            try:\r\n\u001b[?2004l\r"]
[265.172897, "o", "\u001b[?2004h> "]
[265.173058, "o", "                at = int(at_s)\r\n\u001b[?2004l\r"]
[265.173159, "o", "\u001b[?2004h> "]
[265.173303, "o", "            except ValueError:\r\n\u001b[?2004l\r"]
[265.173397, "o", "\u001b[?2004h> "]
[265.173513, "o", "                at = 0\r\n\u001b[?2004l\r"]
[265.1736, "o", "\u001b[?2004h> "]
[265.174147, "o", "            entries.append(Entry(kind=\"CHILD\", parent=parent, ident=ident, lane=lane, at=at, seq=seq))\r\n\u001b[?2004l\r"]
[265.174257, "o", "\u001b[?2004h> "]
[265.174346, "o", "            continue\r\n\u001b[?2004l\r"]
[265.174414, "o", "\u001b[?2004h> "]
[265.174727, "o", "        if parts[:1] == [\"DROP\"] and len(parts) == 2:\r\n\u001b[?2004l\r"]
[265.17475, "o", "\u001b[?2004h> "]
[265.175129, "o", "            entries.append(Entry(kind=\"DROP\", ident=parts[1]))\r\n\u001b[?2004l\r"]
[265.175272, "o", "\u001b[?2004h> "]
[265.175365, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.175532, "o", "        # ignore unknown\r\n\u001b[?2004l\r"]
[265.175634, "o", "\u001b[?2004h> "]
[265.17582, "o", "    return name, max(1, cap), entries\r\n\u001b[?2004l\r"]
[265.175935, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.176042, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rr\u001b[?2004h> "]
[265.176663, "o", "def compute_depths_and_tasks(case: str, entries: List[Entry]) -> Tuple[List[Task], Dict[str, List[str]], Set[str]]:\r\n\u001b[?2004l\r"]
[265.176752, "o", "\u001b[?2004h> "]
[265.177253, "o", "    # Build parent links (from CHILD entries) and children adjacency for drop-descendants.\r\n\u001b[?2004l\r"]
[265.17736, "o", "\u001b[?2004h> "]
[265.177557, "o", "    children: Dict[str, List[str]] = {}\r\n\u001b[?2004l\r"]
[265.17766, "o", "\u001b[?2004h> "]
[265.177826, "o", "    parent_of: Dict[str, str] = {}\r\n\u001b[?2004l\r"]
[265.177894, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.178045, "o", "\u001b[?2004h> "]
[265.178308, "o", "    # record first occurrence of each logical task to dedupe\r\n\u001b[?2004l\r"]
[265.17841, "o", "\u001b[?2004h> "]
[265.178612, "o", "    first_task_def: Dict[str, Task] = {}\r\n\u001b[?2004l\r"]
[265.178676, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.178698, "o", "\u001b[?2004h"]
[265.178846, "o", "> "]
[265.179291, "o", "    # We'll compute depth with best-effort: depth(parent)+1 when parent known, else 0.\r\n\u001b[?2004l\rs=(\",\", \":\")))\r\n "]
[265.179376, "o", "\u001b[?2004h> "]
[265.179537, "o", "    depth: Dict[str, int] = {}\r\n\u001b[?2004l\r"]
[265.179558, "o", "\u001b[?2004h"]
[265.17958, "o", "> "]
[265.179647, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[265.179749, "o", "> "]
[265.179834, "o", "    drops: Set[str] = set()\r\n\u001b[?2004l\r"]
[265.179862, "o", "\u001b[?2004h"]
[265.179912, "o", "> \r\n\u001b[?2004l\r(\u001b[?2004h"]
[265.179923, "o", "> "]
[265.180079, "o", "    for e in entries:\r\n\u001b[?2004l\r"]
[265.180193, "o", "\u001b[?2004h> "]
[265.180308, "o", "        if e.kind == \"DROP\":\r\n\u001b[?2004l\r"]
[265.180332, "o", "\u001b[?2004h"]
[265.180341, "o", "> "]
[265.180548, "o", "            drops.add(e.ident)\r\n\u001b[?2004l\r(f"]
[265.180565, "o", "\u001b[?2004h"]
[265.180577, "o", "> "]
[265.180593, "o", "\r\n\u001b[?2004l\r"]
[265.180654, "o", "\u001b[?2004h> "]
[265.180786, "o", "    for e in entries:\r\n\u001b[?2004l\r"]
[265.180907, "o", "\u001b[?2004h> "]
[265.181036, "o", "        if e.kind == \"ROOT\":\r\n\u001b[?2004l\r"]
[265.181159, "o", "\u001b[?2004h> "]
[265.181652, "o", "            t = Task(case=case, task=e.ident, parent=\"-\", depth=0, lane=e.lane, at=e.at, seq=e.seq)\r\n\u001b[?2004l\r"]
[265.181719, "o", "\u001b[?2004h"]
[265.181773, "o", "> "]
[265.181982, "o", "            if t.task not in first_task_def:\r\n\u001b[?2004l\r"]
[265.182096, "o", "\u001b[?2004h> "]
[265.182304, "o", "                first_task_def[t.task] = t\r\n\u001b[?2004l\r"]
[265.182409, "o", "\u001b[?2004h> "]
[265.182624, "o", "                depth.setdefault(t.task, 0)\r\n\u001b[?2004l\r"]
[265.182726, "o", "\u001b[?2004h> "]
[265.182879, "o", "        elif e.kind == \"CHILD\":\r\n\u001b[?2004l\r"]
[265.182988, "o", "\u001b[?2004h> "]
[265.183204, "o", "            parent_of[e.ident] = e.parent\r\n\u001b[?2004l\r"]
[265.183226, "o", "\u001b[?2004h"]
[265.183299, "o", "> "]
[265.183598, "o", "            children.setdefault(e.parent, []).append(e.ident)\r\n\u001b[?2004l\r"]
[265.183652, "o", "\u001b[?2004h"]
[265.183762, "o", "> "]
[265.184065, "o", "            d = depth.get(e.parent, 0) + 1 if e.parent in depth else 0\r\n\u001b[?2004l\r"]
[265.184126, "o", "\u001b[?2004h> "]
[265.18435, "o", "            depth.setdefault(e.ident, d)\r\n\u001b[?2004l\r"]
[265.184399, "o", "\u001b[?2004h"]
[265.184417, "o", "> "]
[265.185148, "o", "            t = Task(case=case, task=e.ident, parent=e.parent, depth=depth[e.ident], lane=e.lane, at=e.at, seq=e.seq)\r\n\u001b[?2004l\r"]
[265.185223, "o", "\u001b[?2004h"]
[265.185309, "o", "> "]
[265.185484, "o", "            if t.task not in first_task_def:\r\n\u001b[?2004l\r"]
[265.185518, "o", "\u001b[?2004h"]
[265.185528, "o", "> "]
[265.185807, "o", "                first_task_def[t.task] = t\r\n\u001b[?2004l\r"]
[265.1859, "o", "\u001b[?2004h> "]
[265.18592, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.186322, "o", "    tasks = sorted(first_task_def.values(), key=lambda t: t.seq)\r\n\u001b[?2004l\r"]
[265.18641, "o", "\u001b[?2004h> "]
[265.18657, "o", "    return tasks, children, drops\r\n\u001b[?2004l\r"]
[265.186662, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.186725, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.186795, "o", "\u001b[?2004h> "]
[265.187258, "o", "def expand_drops(drops: Set[str], children: Dict[str, List[str]]) -> Set[str]:\r\n\u001b[?2004l\r"]
[265.187338, "o", "\u001b[?2004h"]
[265.187387, "o", "> "]
[265.187496, "o", "    removed: Set[str] = set()\r\n\u001b[?2004l\r"]
[265.187514, "o", "\u001b[?2004h"]
[265.187527, "o", "> "]
[265.18769, "o", "    stack = list(drops)\r\n\u001b[?2004l\r"]
[265.18772, "o", "\u001b[?2004h"]
[265.187734, "o", "> "]
[265.187882, "o", "    while stack:\r\n\u001b[?2004l\r"]
[265.187932, "o", "\u001b[?2004h> "]
[265.188037, "o", "        x = stack.pop()\r\n\u001b[?2004l\r"]
[265.188058, "o", "\u001b[?2004h"]
[265.188069, "o", "> "]
[265.188244, "o", "        if x in removed:\r\n\u001b[?2004l\r"]
[265.188279, "o", "\u001b[?2004h"]
[265.188295, "o", "> "]
[265.188441, "o", "            continue\r\n\u001b[?2004l\r"]
[265.188489, "o", "\u001b[?2004h> "]
[265.188653, "o", "        removed.add(x)\r\n\u001b[?2004l\r"]
[265.188763, "o", "\u001b[?2004h> "]
[265.18895, "o", "        for ch in children.get(x, []):\r\n\u001b[?2004l\r"]
[265.189025, "o", "\u001b[?2004h> "]
[265.189203, "o", "            stack.append(ch)\r\n\u001b[?2004l\r"]
[265.189302, "o", "\u001b[?2004h> "]
[265.189386, "o", "    return removed\r\n\u001b[?2004l\r"]
[265.189489, "o", "\u001b[?2004h> \r\n\u001b[?2004l\ra\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.189532, "o", "\u001b[?2004h> "]
[265.190118, "o", "def schedule(case: str, cap: int, tasks: List[Task], removed: Set[str]) -> Tuple[List[Record], List[str]]:\r\n\u001b[?2004l\r"]
[265.190225, "o", "\u001b[?2004h> "]
[265.190331, "o", "    live = [t for t in tasks if t.task not in removed]\r\n\u001b[?2004l\r"]
[265.190418, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.1907, "o", "    # pending list is of live tasks that never accepted (should become empty if scheduler drains)\r\n\u001b[?2004l\r"]
[265.190781, "o", "\u001b[?2004h> "]
[265.190958, "o", "    # We'll simulate turn-by-turn accepting up to cap per lane per turn.\r\n\u001b[?2004l\r"]
[265.191055, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.191108, "o", "\u001b[?2004h> "]
[265.191211, "o", "    by_turn: Dict[int, List[Task]] = {}\r\n\u001b[?2004l\r"]
[265.191317, "o", "\u001b[?2004h> "]
[265.191401, "o", "    max_turn = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[265.191424, "o", ">     for t in live:\r\n\u001b[?2004l\r"]
[265.191502, "o", "\u001b[?2004h> "]
[265.191644, "o", "        by_turn.setdefault(t.at, []).append(t)\r\n\u001b[?2004l\r"]
[265.191674, "o", "\u001b[?2004h"]
[265.191687, "o", "> "]
[265.191827, "o", "        max_turn = max(max_turn, t.at)\r\n\u001b[?2004l\r\u001b[?2004h"]
[265.191868, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[265.191888, "o", "> "]
[265.192045, "o", "    # per-lane FIFO queues, order by plan seq\r\n\u001b[?2004l\r"]
[265.192074, "o", "\u001b[?2004h"]
[265.192089, "o", "> "]
[265.192226, "o", "    lane_q: Dict[str, List[Task]] = {}\r\n\u001b[?2004l\r"]
[265.192256, "o", "\u001b[?2004h"]
[265.192281, "o", "> \r\n\u001b[?2004l\r"]
[265.192301, "o", "\u001b[?2004h"]
[265.192313, "o", "> "]
[265.192436, "o", "    accepted: List[Record] = []\r\n\u001b[?2004l\r"]
[265.192472, "o", "\u001b[?2004h"]
[265.192485, "o", "> "]
[265.192618, "o", "    accepted_set: Set[str] = set()\r\n\u001b[?2004l\r"]
[265.19265, "o", "\u001b[?2004h"]
[265.192733, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.192883, "o", "    # Run until no future arrivals and queues empty\r\n\u001b[?2004l\r"]
[265.192914, "o", "\u001b[?2004h"]
[265.192957, "o", "> "]
[265.193033, "o", "    turn = 0\r\n\u001b[?2004l\r"]
[265.193051, "o", "\u001b[?2004h> "]
[265.193182, "o", "    def queues_nonempty() -> bool:\r\n\u001b[?2004l\r"]
[265.193257, "o", "\u001b[?2004h> "]
[265.193384, "o", "        return any(lane_q.get(l) for l in lane_q)\r\n\u001b[?2004l\r"]
[265.193416, "o", "\u001b[?2004h"]
[265.193477, "o", "> \r\n\u001b[?2004l\r"]
[265.193534, "o", "\u001b[?2004h> "]
[265.193647, "o", "    while turn <= max_turn or queues_nonempty():\r\n\u001b[?2004l\r"]
[265.193676, "o", "\u001b[?2004h"]
[265.193711, "o", "> "]
[265.193838, "o", "        arrivals = by_turn.get(turn, [])\r\n\u001b[?2004l\r"]
[265.193899, "o", "\u001b[?2004h> "]
[265.194031, "o", "        arrivals.sort(key=lambda t: t.seq)\r\n\u001b[?2004l\r"]
[265.19408, "o", "\u001b[?2004h"]
[265.194144, "o", "> "]
[265.19423, "o", "        for t in arrivals:\r\n\u001b[?2004l\r\u001b[?2004h"]
[265.194278, "o", "> "]
[265.194381, "o", "            if t.task in accepted_set:\r\n\u001b[?2004l\r"]
[265.194431, "o", "\u001b[?2004h> "]
[265.194535, "o", "                continue\r\n\u001b[?2004l\r"]
[265.194638, "o", "\u001b[?2004h> "]
[265.194736, "o", "            lane_q.setdefault(t.lane, []).append(t)\r\n\u001b[?2004l\r"]
[265.194808, "o", "\u001b[?2004h"]
[265.194882, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.19497, "o", "        for lane in sorted(lane_q.keys()):\r\n\u001b[?2004l\r"]
[265.195014, "o", "\u001b[?2004h> "]
[265.195112, "o", "            q = lane_q[lane]\r\n\u001b[?2004l\r"]
[265.195206, "o", "\u001b[?2004h> "]
[265.195304, "o", "            n = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[265.195388, "o", "> "]
[265.195472, "o", "            while q and n < cap:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.195565, "o", "                t = q.pop(0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[265.195585, "o", "> "]
[265.195727, "o", "                if t.task in accepted_set:\r\n\u001b[?2004l\r"]
[265.195751, "o", "\u001b[?2004h"]
[265.195776, "o", "> "]
[265.195908, "o", "                    continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.196026, "o", "                accepted_set.add(t.task)\r\n\u001b[?2004l\r"]
[265.196045, "o", "\u001b[?2004h"]
[265.196066, "o", "> "]
[265.196395, "o", "                accepted.append(Record(case=case, task=t.task, parent=t.parent, depth=t.depth, lane=t.lane, turn=turn))\r\n\u001b[?2004l\r"]
[265.196428, "o", "\u001b[?2004h"]
[265.196442, "o", "> "]
[265.196555, "o", "                n += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.196655, "o", "            lane_q[lane] = q\r\n\u001b[?2004l\r"]
[265.196714, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.196734, "o", "\u001b[?2004h"]
[265.196805, "o", ">         turn += 1\r\n\u001b[?2004l\r"]
[265.196823, "o", "\u001b[?2004h"]
[265.196913, "o", "> "]
[265.19705, "o", "        if turn > max_turn and not queues_nonempty():\r\n\u001b[?2004l\r"]
[265.197111, "o", "\u001b[?2004h> "]
[265.197167, "o", "            break\r\n\u001b[?2004l\r"]
[265.197248, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.197293, "o", "\u001b[?2004h> "]
[265.197628, "o", "    # Trace ordering already matches: acceptance turn asc, lanes processed in name order each turn, FIFO within lane.\r\n\u001b[?2004l\r"]
[265.197661, "o", "\u001b[?2004h"]
[265.197703, "o", "> "]
[265.197912, "o", "    pending = sorted([t.task for t in live if t.task not in accepted_set])\r\n\u001b[?2004l\r"]
[265.197941, "o", "\u001b[?2004h"]
[265.197966, "o", "> "]
[265.198074, "o", "    return accepted, pending\r\n\u001b[?2004l\r"]
[265.198206, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[265.198354, "o", "> "]
[265.198437, "o", "def write_outputs(root: Path, out: Path, work: Path, cases: List[str]):\r\n\u001b[?2004l\r"]
[265.19846, "o", "\u001b[?2004h"]
[265.198472, "o", "> "]
[265.198552, "o", "    all_cases = []\r\n\u001b[?2004l\r"]
[265.198633, "o", "\u001b[?2004h"]
[265.198715, "o", "> "]
[265.19874, "o", "    work_ledgers = work / \"ledgers\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[265.198832, "o", "> "]
[265.198906, "o", "    work_journals = work / \"journals\"\r\n\u001b[?2004l\r"]
[265.198997, "o", "\u001b[?2004h> "]
[265.199127, "o", "    work_ledgers.mkdir(parents=True, exist_ok=True)\r\n\u001b[?2004l\r"]
[265.199199, "o", "\u001b[?2004h"]
[265.199258, "o", "> "]
[265.199373, "o", "    work_journals.mkdir(parents=True, exist_ok=True)\r\n\u001b[?2004l\r"]
[265.19945, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[265.199502, "o", "\u001b[?2004h> "]
[265.199565, "o", "    for name in cases:\r\n\u001b[?2004l\r"]
[265.199619, "o", "\u001b[?2004h> "]
[265.199789, "o", "        plan_path = root / \"data\" / \"cases\" / f\"{name}.plan\"\r\n\u001b[?2004l\r"]
[265.199836, "o", "\u001b[?2004h> "]
[265.199991, "o", "        case, cap, entries = parse_plan(plan_path)\r\n\u001b[?2004l\r"]
[265.200055, "o", "\u001b[?2004h> "]
[265.200262, "o", "        tasks, children, drops = compute_depths_and_tasks(case, entries)\r\n\u001b[?2004l\r"]
[265.200312, "o", "\u001b[?2004h> "]
[265.200459, "o", "        removed = expand_drops(drops, children)\r\n\u001b[?2004l\r"]
[265.200513, "o", "\u001b[?2004h> "]
[265.200692, "o", "        trace, pending = schedule(case, cap, tasks, removed)\r\n\u001b[?2004l\r"]
[265.200742, "o", "\u001b[?2004h> \r\n"]
[265.200759, "o", "\u001b[?2004l\r"]
[265.200807, "o", "\u001b[?2004h> "]
[265.200967, "o", "        ledger_path = work_ledgers / f\"{case}.jsonl\"\r\n\u001b[?2004l\r"]
[265.201017, "o", "\u001b[?2004h> "]
[265.20118, "o", "        journal_path = work_journals / f\"{case}.txt\"\r\n\u001b[?2004l\r"]
[265.201277, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[265.20145, "o", "        with ledger_path.open(\"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r"]
[265.20153, "o", "\u001b[?2004h> "]
[265.201577, "o", "            for r in trace:\r\n"]
