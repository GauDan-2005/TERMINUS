[288.320767, "o", "> "]
[288.321177, "o", "from typing import Dict, List, Set, Tuple\r\n\u001b[?2004l\r"]
[288.32127, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[288.321373, "o", "\u001b[?2004h> "]
