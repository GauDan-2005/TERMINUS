[301.933661, "i", "python3 - <<'PY'\nimport json, pathlib\n\ndata=json.loads(pathlib.Path('/app/output/executor-audit.json').read_text())\ntrace={c['name']:[r['task'] for r in c['trace']] for c in data['cases']}\nchecks={\n 'drake': ['drake-cut','drake-shadow'],\n 'ember': ['ember-left','ember-deep','ember-side'],\n 'graphite': ['graphite-d','graphite-e'],\n 'flint': ['flint-c'],\n}\nfor case, banned in checks.items():\n    present=set(trace[case])\n    for b in banned:\n        print(case, b, 'present' if b in present else 'absent')\nprint('flint flint-a count', trace['flint'].count('flint-a'))\nPY\n"]
