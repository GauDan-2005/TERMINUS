[?2004l[?2004h> use std::collections::{BTreeMap, BTreeSet, VecDeque};
[?2004l[?2004h> 
[?2004l[?2004h> use crate::core_a::R0;
[?2004l[?2004h> 
[?2004l[?2004h> /// Accept work in discrete turns.
[?2004l[?2004h> ///
[?2004l[?2004h> /// Contract:
[?2004l[?2004h> /// - Each row becomes eligible on its own arrival/base_turn.
[?2004l[?2004h> /// - Per turn, each lane may accept up to `cap` ready rows.
[?2004l[?2004h> /// - Overflow stays live for later turns and competes with later arrivals.
[?2004l[?2004h> /// - Accepted trace order: accepted turn asc; within turn: lane name asc;
[?2004l[?2004h> ///   within lane+turn: plan-file order (seq).
[?2004l[?2004h> pub fn fold_b(rows: &[R0], cap: usize) -> Vec<R0> {
[?2004l[?2004h>     let cap = cap.max(1);
[?2004l[?2004h> 
[?2004l[?2004h>     // Dedup by logical task name: keep earliest (base_turn, seq).
[?2004l[?2004h>     let mut uniq: BTreeMap<String, R0> = BTreeMap::new();
[?2004l[?2004h>     for r in rows.iter().cloned() {
[?2004l[?2004h>         uniq.entry(r.task_name.clone())
[?2004l[?2004h>             .and_modify(|cur| {
[?2004l[?2004h>                 if (r.base_turn, r.seq) < (cur.base_turn, cur.seq) {
[?2004l[?2004h>                     *cur = r.clone();
[?2004l[?2004h>                 }
[?2004l[?2004h>             })
[?2004l[?2004h>             .or_insert(r);
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     let mut turns: BTreeSet<u64> = BTreeSet::new();
[?2004l[?2004h>     for r in uniq.values() {
[?2004l[?2004h>         turns.insert(r.base_turn);
[?2004l[?2004h>     }
[?2004l[?2004h>     if turns.is_empty() {
[?2004l[?2004h>         return Vec::new();
[?2004l[?2004h>     }
[?2004l[?2004h>     let min_turn = *turns.iter().next().unwrap();
[?2004l[?2004h>     let max_turn = *turns.iter().next_back().unwrap();
[?2004l[?2004h> 
[?2004l[?2004h>     // Bucket arrivals by base_turn then lane; keep seq order within each bucket.
[?2004l[?2004h>     let mut arrivals: BTreeMap<u64, BTreeMap<String, Vec<R0>>> = BTreeMap::new();
[?2004l[?2004h>     for r in uniq.into_values() {
[?2004l[?2004h>         arrivals
[?2004l[?2004h>             .entry(r.base_turn)
[?2004l[?2004h>             .or_default()
[?2004l[?2004h>             .entry(r.lane_name.clone())
[?2004l[?2004h>             .or_default()
[?2004l[?2004h>             .push(r);
[?2004l[?2004h>     }
[?2004l[?2004h>     for (_t, by_lane) in arrivals.iter_mut() {
[?2004l[?2004h>         for (_lane, v) in by_lane.iter_mut() {
[?2004l[?2004h>             v.sort_by_key(|r| r.seq);
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     let mut ready: BTreeMap<String, VecDeque<R0>> = BTreeMap::new();
[?2004l[?2004h>     let mut accepted: Vec<R0> = Vec::new();
[?2004l[?2004h> 
[?2004l[?2004h>     let mut t = min_turn;
[?2004l[?2004h>     loop {
[?2004l[?2004h>         if let Some(by_lane) = arrivals.remove(&t) {
[?2004l[?2004h>             for (lane, mut v) in by_lane {
[?2004l[?2004h>                 let q = ready.entry(lane).or_default();
[?2004l[?2004h>                 for r in v.drain(..) {
[?2004l[?2004h>                     q.push_back(r);
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         // accept in lane-name order (BTreeMap iteration)
[?2004l[?2004h>         for (lane, q) in ready.iter_mut() {
[?2004l[?2004h>             let mut took = 0usize;
[?2004l[?2004h>             while took < cap {
[?2004l[?2004h>                 let mut r = match q.pop_front() {
[?2004l[?2004h>                     Some(r) => r,
[?2004l[?2004h>                     None => break,
[?2004l[?2004h>                 };
[?2004l[?2004h>                 r.turn = t;
[?2004l[?2004h>                 r.lane_name = lane.clone();
[?2004l[?2004h>                 accepted.push(r);
[?2004l[?2004h>                 took += 1;
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         let any_ready = ready.values().any(|q| !q.is_empty());
[?2004l[?2004h>         let any_future = !arrivals.is_empty();
[?2004l[?2004h>         if !any_ready && !any_future {
[?2004l[?2004h>             break;
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         // If there are gaps in turns (e.g., arrivals at 0 and 10), we still need to
[?2004l[?2004h>         // progress turn-by-turn because CAP applies per turn.
[?2004l[?2004h>         if t < max_turn || any_ready {
[?2004l[?2004h>             t += 1;
[?2004l[?2004h>         } else {
[?2004l[?2004h>             t += 1;
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     accepted.sort_by(|l, r| {
[?2004l[?2004h>         l.turn
[?2004l[?2004h>             .cmp(&r.turn)
[?2004l[?2004h>             .then(l.lane_name.cmp(&r.lane_name))
[?2004l[?2004h>             .then(l.seq.cmp(&r.seq))
[?2004l[?2004h>     });
[?2004l[?2004h>     accepted
[?2004l[?2004h> }
[?2004l[?2004h> EOF
[?2004l[?2004hroot@88e50440921f:/app# cat > /app/drive_g/drive.rs <<'EOF'
[?2004l[?2004h> use std::collections::{BTreeMap, BTreeSet};
[?2004l[?2004h> use std::io;
[?2004l[?2004h> use std::path::{Path, PathBuf};
[?2004l[?2004h> 
[?2004l[?2004h> use crate::book_b::fold_b;
[?2004l[?2004h> use crate::core_a::{op_a, R0, S0};
[?2004l[?2004h> use crate::flow_e::{emit_e, note_e};
[?2004l[?2004h> use crate::gate_c::{mark_c, S1};
[?2004l[?2004h> use crate::host_d::{bind_d, R1, S2};
[?2004l[?2004h> use crate::types_f::{CaseReport, Entry, Item, Plan, Record};
[?2004l[?2004h> 
[?2004l[?2004h> fn out_paths(base: &Path, name: &str) -> (PathBuf, PathBuf) {
[?2004l[?2004h>     (
[?2004l[?2004h>         base.join("ledgers").join(format!("{}.jsonl", name)),
[?2004l[?2004h>         base.join("journals").join(format!("{}.txt", name)),
[?2004l[?2004h>     )
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> pub fn drive_g(a: &Plan, b: &Path) -> io::Result<CaseReport> {
[?2004l[?2004h>     let mut host = S2::new();
[?2004l[?2004h>     let mut removed: BTreeSet<String> = BTreeSet::new();
[?2004l[?2004h>     let mut raw: BTreeMap<String, Item> = BTreeMap::new();
[?2004l[?2004h> 
[?2004l[?2004h>     for entry in &a.entries {
[?2004l[?2004h>         match entry {
[?2004l[?2004h>             Entry::Root { ident, lane, at, seq } => {
[?2004l[?2004h>                 let item = Item {
[?2004l[?2004h>                     ident: ident.clone(),
[?2004l[?2004h>                     parent: "-".to_string(),
[?2004l[?2004h>                     lane: lane.clone(),
[?2004l[?2004h>                     at: *at,
[?2004l[?2004h>                     seq: *seq,
[?2004l[?2004h>                     depth: 0,
[?2004l[?2004h>                     chain: vec![ident.clone()],
[?2004l[?2004h>                 };
[?2004l[?2004h>                 let moved =
[?2004l[?2004h>                     bind_d(&mut host, R1 { item }).map_err(|_| io::Error::new(io::ErrorKind::Other, "state"))?;
[?2004l[?2004h>                 raw.insert(ident.clone(), moved.item);
[?2004l[?2004h>             }
[?2004l[?2004h>             Entry::Child {
[?2004l[?2004h>                 from,
[?2004l[?2004h>                 ident,
[?2004l[?2004h>                 lane,
[?2004l[?2004h>                 at,
[?2004l[?2004h>                 seq,
[?2004l[?2004h>             } => {
[?2004l[?2004h>                 let parent = raw.get(from).cloned();
[?2004l[?2004h>                 let depth = parent.as_ref().map(|p| p.depth + 1).unwrap_or(0);
[?2004l[?2004h>                 let mut chain = parent.map(|p| p.chain).unwrap_or_default();
[?2004l[?2004h>                 chain.push(ident.clone());
[?2004l[?2004h>                 let item = Item {
[?2004l[?2004h>                     ident: ident.clone(),
[?2004l[?2004h>                     parent: from.clone(),
[?2004l[?2004h>                     lane: lane.clone(),
[?2004l[?2004h>                     at: *at,
[?2004l[?2004h>                     seq: *seq,
[?2004l[?2004h>                     depth,
[?2004l[?2004h>                     chain,
[?2004l[?2004h>                 };
[?2004l[?2004h>                 let moved =
[?2004l[?2004h>                     bind_d(&mut host, R1 { item }).map_err(|_| io::Error::new(io::ErrorKind::Other, "state"))?;
[?2004l[?2004h>                 raw.insert(ident.clone(), moved.item);
[?2004l[?2004h>             }
[?2004l[?2004h>             Entry::Drop { ident } => {
[?2004l[?2004h>                 removed.insert(ident.clone());
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     let gate = S1::new(removed);
[?2004l[?2004h>     let mut state = S0::new();
[?2004l[?2004h> 
[?2004l[?2004h>     for item in raw.values() {
[?2004l[?2004h>         let row = R0::from_item(&a.name, item);
[?2004l[?2004h>         if mark_c(&gate, &row) {
[?2004l[?2004h>             op_a(&mut state, row).map_err(|_| io::Error::new(io::ErrorKind::Other, "row"))?;
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     // Expand removals to descendants: DROP removes that ident and all descendants.
[?2004l[?2004h>     let mut expanded: BTreeSet<String> = BTreeSet::new();
[?2004l[?2004h>     for row in &state.rows {
[?2004l[?2004h>         if row.chain.iter().any(|n| gate.removed.contains(n)) {
[?2004l[?2004h>             expanded.insert(row.task_name.clone());
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     let kept: Vec<R0> = state
[?2004l[?2004h>         .rows
[?2004l[?2004h>         .iter()
[?2004l[?2004h>         .cloned()
[?2004l[?2004h>         .filter(|r| !expanded.contains(&r.task_name))
[?2004l[?2004h>         .collect();
[?2004l[?2004h> 
[?2004l[?2004h>     let ordered = fold_b(&kept, a.cap);
[?2004l[?2004h>     let trace: Vec<Record> = ordered.iter().map(R0::pack_a).collect();
[?2004l[?2004h> 
[?2004l[?2004h>     let accepted: BTreeSet<String> = trace.iter().map(|row| row.task_name.clone()).collect();
[?2004l[?2004h>     let mut pending: Vec<String> = kept
[?2004l[?2004h>         .iter()
[?2004l[?2004h>         .filter(|row| !accepted.contains(&row.task_name))
[?2004l[?2004h>         .map(|row| row.task_name.clone())
[?2004l[?2004h>         .collect();
[?2004l[?2004h>     pending.sort();
[?2004l[?2004h> 
[?2004l[?2004h>     let (ledger, journal) = out_paths(b, &a.name);
[?2004l[?2004h>     emit_e(&ledger, &trace)?;
[?2004l[?2004h>     note_e(&journal, &trace)?;
[?2004l[?2004h> 
[?2004l[?2004h>     let finished = pending.is_empty();
[?2004l[?2004h>     Ok(CaseReport {
[?2004l[?2004h>         name: a.name.clone(),
[?2004l[?2004h>         ok: finished,
[?2004l[?2004h>         finished,
[?2004l[?2004h>         pending,
[?2004l[?2004h>         trace,
[?2004l[?2004h>         ledger: ledger.display().to_string(),
[?2004l[?2004h>         journal: journal.display().to_string(),
[?2004l[?2004h>     })
[?2004l[?2004h> }
