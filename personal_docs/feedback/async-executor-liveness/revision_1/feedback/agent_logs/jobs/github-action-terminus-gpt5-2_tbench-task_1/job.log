Sending keys: ['cat > /app/types_f/serde.rs <<\'EOF\'\nuse crate::types_f::{CaseReport, Record};\n\nfn esc(s: &str) -> String {\n    s.replace(\'\\\\\', "\\\\\\\\").replace(\'"\', "\\\\\\"")\n}\n\npub fn row_json(row: &Record) -> String {\n    let parent = match &row.parent_name {\n        Some(p) => format!("\\"{}\\"", esc(p)),\n        None => "null".to_string(),\n    };\n    format!(\n        "{{\\"case\\":\\"{}\\",\\"task\\":\\"{}\\",\\"parent\\":{},\\"depth\\":{},\\"lane\\":\\"{}\\",\\"turn\\":{}}}",\n        esc(&row.case_name),\n        esc(&row.task_name),\n        parent,\n        row.depth,\n        esc(&row.lane_name),\n        row.turn\n    )\n}\n\nfn string_array(items: &[String]) -> String {\n    format!(\n        "[{}]",\n        items\n            .iter()\n            .map(|s| format!("\\"{}\\"", esc(s)))\n            .collect::<Vec<_>>()\n            .join(",")\n    )\n}\n\npub fn case_json(case: &CaseReport) -> String {\n    let trace = case\n        .trace\n        .iter()\n        .map(row_json)\n        .collect::<Vec<_>>()\n        .join(",");\n    format!(\n        "{{\\"name\\":\\"{}\\",\\"ok\\":{},\\"finished\\":{},\\"pending\\":{},\\"trace\\":[{}],\\"ledger\\":\\"{}\\",\\"journal\\":\\"{}\\"}}",\n        esc(&case.name),\n        if case.ok { "true" } else { "false" },\n        if case.finished { "true" } else { "false" },\n        string_array(&case.pending),\n        trace,\n        esc(&case.ledger),\n        esc(&case.journal)\n    )\n}\n\npub fn report_json(cases: &[CaseReport]) -> String {\n    let body = cases.iter().map(case_json).collect::<Vec<_>>().join(",");\n    format!("{{\\"cases\\":[{}]}}\\n", body)\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
