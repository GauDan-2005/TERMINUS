[409.152806, "i", "python3 - <<'PY'\nimport json\nimport pathlib\np=pathlib.Path('/app/output/executor-audit.json')\na=json.loads(p.read_text())\nwant=['amber','cobalt','drake','ember','flint','graphite']\nhave=[c['name'] for c in a.get('cases',[])]\nprint('want',want)\nprint('have',have)\nprint('missing',[x for x in want if x not in have])\nprint('extra',[x for x in have if x not in want])\nPY\n"]
[409.153092, "o", "python3 - <<'PY'\r\n"]
