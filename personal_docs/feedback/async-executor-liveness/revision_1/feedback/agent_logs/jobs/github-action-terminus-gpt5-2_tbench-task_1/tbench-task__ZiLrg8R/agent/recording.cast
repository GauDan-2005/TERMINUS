[624.190982, "o", "\u001b[?2004hroot@88e50440921f:/app# "]
[624.296669, "i", "cat > /app/flow_e/flow.rs <<'EOF'\nuse std::fs::{self, File};\nuse std::io::{self, Write};\nuse std::path::Path;\n\nuse crate::serde_f::row_json;\nuse crate::types_f::Record;\n\npub struct S3 {\n    pub count: usize,\n}\n\npub fn walk_e(a: &[Record], b: &mut S3) {\n    b.count += a.len();\n}\n\npub fn emit_e(a: &Path, b: &[Record]) -> io::Result<()> {\n    if let Some(parent) = a.parent() {\n        fs::create_dir_all(parent)?;\n    }\n    let mut file = File::create(a)?;\n    for row in b {\n        writeln!(file, \"{}\", row_json(row))?;\n    }\n    Ok(())\n}\n\npub fn note_e(a: &Path, b: &[Record]) -> io::Result<()> {\n    if let Some(parent) = a.parent() {\n        fs::create_dir_all(parent)?;\n    }\n    let mut file = File::create(a)?;\n    for row in b {\n        let parent = row.parent_name.as_deref().unwrap_or(\"-\");\n        writeln!(\n            file,\n            \"{} {} {} {} {} {}\",\n            row.case_name, row.task_name, parent, row.depth, row.lane_name, row.turn\n        )?;\n    }\n    Ok(())\n}\nEOF\n"]
