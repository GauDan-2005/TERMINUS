[624.405837, "i", "cat > /app/book_b/book.rs <<'EOF'\nuse std::collections::{BTreeMap, BTreeSet, VecDeque};\n\nuse crate::core_a::R0;\n\n/// Accept work in discrete turns.\n///\n/// Contract:\n/// - Each row becomes eligible on its own arrival/base_turn.\n/// - Per turn, each lane may accept up to `cap` ready rows.\n/// - Overflow stays live for later turns and competes with later arrivals.\n/// - Accepted trace order: accepted turn asc; within turn: lane name asc;\n///   within lane+turn: plan-file order (seq).\npub fn fold_b(rows: &[R0], cap: usize) -> Vec<R0> {\n    let cap = cap.max(1);\n\n    // Dedup by logical task name: keep earliest (base_turn, seq).\n    let mut uniq: BTreeMap<String, R0> = BTreeMap::new();\n    for r in rows.iter().cloned() {\n        uniq.entry(r.task_name.clone())\n            .and_modify(|cur| {\n                if (r.base_turn, r.seq) < (cur.base_turn, cur.seq) {\n                    *cur = r.clone();\n                }\n            })\n            .or_insert(r);\n    }\n\n    let mut turns: BTreeSet<u64> = BTreeSet::new();"]
[624.405886, "i", "\n    for r in uniq.values() {\n        turns.insert(r.base_turn);\n    }\n    if turns.is_empty() {\n        return Vec::new();\n    }\n    let min_turn = *turns.iter().next().unwrap();\n    let max_turn = *turns.iter().next_back().unwrap();\n\n    // Bucket arrivals by base_turn then lane; keep seq order within each bucket.\n    let mut arrivals: BTreeMap<u64, BTreeMap<String, Vec<R0>>> = BTreeMap::new();\n    for r in uniq.into_values() {\n        arrivals\n            .entry(r.base_turn)\n            .or_default()\n            .entry(r.lane_name.clone())\n            .or_default()\n            .push(r);\n    }\n    for (_t, by_lane) in arrivals.iter_mut() {\n        for (_lane, v) in by_lane.iter_mut() {\n            v.sort_by_key(|r| r.seq);\n        }\n    }\n\n    let mut ready: BTreeMap<String, VecDeque<R0>> = BTreeMap::new();\n    let mut accepted: Vec<R0> = Vec::new();\n\n    let mut t = min_turn;\n    loop {\n        if let Some(by_lane) = arrivals.remove(&t) {\n            for (lane, mut v) in by_lane {\n                let q = r"]
[624.405902, "i", "eady.entry(lane).or_default();\n                for r in v.drain(..) {\n                    q.push_back(r);\n                }\n            }\n        }\n\n        // accept in lane-name order (BTreeMap iteration)\n        for (lane, q) in ready.iter_mut() {\n            let mut took = 0usize;\n            while took < cap {\n                let mut r = match q.pop_front() {\n                    Some(r) => r,\n                    None => break,\n                };\n                r.turn = t;\n                r.lane_name = lane.clone();\n                accepted.push(r);\n                took += 1;\n            }\n        }\n\n        let any_ready = ready.values().any(|q| !q.is_empty());\n        let any_future = !arrivals.is_empty();\n        if !any_ready && !any_future {\n            break;\n        }\n\n        // If there are gaps in turns (e.g., arrivals at 0 and 10), we still need to\n        // progress turn-by-turn because CAP applies per turn.\n        if t < max_turn || any_ready {\n            t += 1;\n        } else {\n        "]
[624.405914, "i", "    t += 1;\n        }\n    }\n\n    accepted.sort_by(|l, r| {\n        l.turn\n            .cmp(&r.turn)\n            .then(l.lane_name.cmp(&r.lane_name))\n            .then(l.seq.cmp(&r.seq))\n    });\n    accepted\n}\nEOF\n"]
