[818.893157, "i", "python3 - <<'PY'\nimport json, pathlib\np=pathlib.Path('/app/output/one-cobalt.json')\na=json.loads(p.read_text())\nprint('cases',len(a['cases']))\nc=a['cases'][0]\nprint(c['name'],c['ok'],c['finished'],len(c['pending']),len(c['trace']))\n# verify ledger/journal agreement\nroot=pathlib.Path('/app')\n\ndef norm(r):\n    return {k:r.get(k) for k in ['case','task','parent','depth','lane','turn']}\ntrace=[norm(r) for r in c['trace']]\nledger=[norm(json.loads(l)) for l in pathlib.Path(c['ledger']).read_text().splitlines() if l.strip()]\njournal=[]\nfor line in pathlib.Path(c['journal']).read_text().splitlines():\n    if not line.strip():\n        continue\n    case,task,parent,depth,lane,turn=line.split()\n    journal.append({'case':case,'task':task,'parent':None if parent=='-' else parent,'depth':int(depth),'lane':lane,'turn':int(turn)})\nprint('trace==ledger',trace==ledger,'trace==journal',trace==journal)\nPY\n"]
