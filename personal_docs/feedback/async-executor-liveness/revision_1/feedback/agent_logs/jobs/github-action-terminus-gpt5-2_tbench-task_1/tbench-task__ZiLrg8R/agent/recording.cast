[745.977108, "i", "python3 - <<'PY'\nimport json, pathlib\nroot=pathlib.Path('/app')\na=json.loads((root/'output/executor-audit.json').read_text())\n\ndef norm_rec(r):\n    return {k:r.get(k) for k in ['case','task','parent','depth','lane','turn']}\n\nbad=False\nfor c in a['cases']:\n    name=c['name']\n    trace=[norm_rec(r) for r in c['trace']]\n    # ledger\n    ledger=[]\n    for line in pathlib.Path(c['ledger']).read_text().splitlines():\n        if line.strip():\n            ledger.append(norm_rec(json.loads(line)))\n    if trace!=ledger:\n        print('TRACE!=LEDGER',name); bad=True\n    # journal\n    journal=[]\n    for line in pathlib.Path(c['journal']).read_text().splitlines():\n        if not line.strip():\n            continue\n        case,task,parent,depth,lane,turn=line.split()\n        journal.append({'case':case,'task':task,'parent':None if parent=='-' else parent,'depth':int(depth),'lane':lane,'turn':int(turn)})\n    if trace!=journal:\n        print('TRACE!=JOURNAL',name); bad=True\n    if c['pending']:\n        print('PENDING',name,c["]
[745.977313, "i", "'pending']); bad=True\n    if not c['ok'] or not c['finished']:\n        print('NOT OK/FINISHED',name,c['ok'],c['finished']); bad=True\nprint('OK' if not bad else 'FAIL')\nPY\n"]
