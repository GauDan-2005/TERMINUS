[588.949505, "i", "python3 - <<'PY'\nimport json, pathlib\nfrom itertools import zip_longest\nroot=pathlib.Path('/app')\na=json.loads((root/'output/executor-audit.json').read_text())\n\ndef norm_rec(r):\n    return {k:r.get(k) for k in ['case','task','parent','depth','lane','turn']}\n\nbad=False\nfor c in a['cases']:\n    name=c['name']\n    ledger_path=pathlib.Path(c['ledger'])\n    journal_path=pathlib.Path(c['journal'])\n    ledger=[]\n    for line in ledger_path.read_text().splitlines():\n        if line.strip():\n            ledger.append(json.loads(line))\n    trace=[norm_rec(r) for r in c['trace']]\n    ledger_n=[norm_rec(r) for r in ledger]\n    if trace!=ledger_n:\n        print('TRACE!=LEDGER',name); bad=True\n    journal=[]\n    for line in journal_path.read_text().splitlines():\n        parts=line.split()\n        case,task,parent,depth,lane,turn=parts\n        journal.append({'case':case,'task':task,'parent':None if parent=='-' else parent,'depth':int(depth),'lane':lane,'turn':int(turn)})\n    if trace!=journal:\n        print('TRACE!=JOURNAL"]
