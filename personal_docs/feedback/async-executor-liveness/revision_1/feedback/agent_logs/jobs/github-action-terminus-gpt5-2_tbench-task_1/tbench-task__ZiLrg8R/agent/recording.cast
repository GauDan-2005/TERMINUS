[818.896387, "o", "p=pathlib.Path('/app/output/one-cobalt.json')\r\n\u001b[?2004l\r\u001b[?2004h> a=json.loads(p.read_text())\r\n\u001b[?2004l\r\u001b[?2004h> print('cases',len(a['cases']))\r\n\u001b[?2004l\r\u001b[?2004h> c=a['cases'][0]\r\n\u001b[?2004l\r\u001b[?2004h> print(c['name'],c['ok'],c['finished'],len(c['pending']),len(c['trace']))\r\n\u001b[?2004l\r\u001b[?2004h> # verify ledger/journal agreement\r\n\u001b[?2004l\r\u001b[?2004h> root=pathlib.Path('/app')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def norm(r):\r\n\u001b[?2004l\r\u001b[?2004h>     return {k:r.get(k) for k in ['case','task','parent','depth','lane','turn']}\r\n\u001b[?2004l\r\u001b[?2004h> trace=[norm(r) for r in c['trace']]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[818.896709, "o", "ledger=[norm(json.loads(l)) for l in pathlib.Path(c['ledger']).read_text().splitlines() if l.strip()]\r\n\u001b[?2004l\r\u001b[?2004h> journal=[]\r\n\u001b[?2004l\r"]
[818.897053, "o", "\u001b[?2004h> for line in pathlib.Path(c['journal']).read_text().splitlines():\r\n\u001b[?2004l\r\u001b[?2004h"]
[818.89712, "o", "> "]
[818.897207, "o", "    if not line.strip():\r\n\u001b[?2004l\r"]
[818.897251, "o", "\u001b[?2004h"]
[818.897356, "o", "> "]
[818.897416, "o", "        continue\r\n\u001b[?2004l\r"]
[818.897531, "o", "\u001b[?2004h"]
[818.897582, "o", "> "]
[818.897892, "o", "    case,task,parent,depth,lane,turn=line.split()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[818.898139, "o", "    journal.append({'case':case,'task':task,'parent':None if parent=='-' else parent,'depth':int(depth),'lane':lane,'turn':int(turn)})\r\n\u001b[?2004l\r"]
[818.898176, "o", "\u001b[?2004h"]
[818.898304, "o", "> "]
[818.898502, "o", "print('trace==ledger',trace==ledger,'trace==journal',trace==journal)\r\n\u001b[?2004l\r"]
[818.898542, "o", "\u001b[?2004h"]
[818.898638, "o", "> "]
[818.898677, "o", "PY\r\n\u001b[?2004l\r"]
[818.917493, "o", "cases 1\r\ncobalt True True 0 5\r\n"]
[818.917664, "o", "trace==ledger True trace==journal True\r\n"]
[818.920982, "o", "\u001b[?2004hroot@88e50440921f:/app# "]
