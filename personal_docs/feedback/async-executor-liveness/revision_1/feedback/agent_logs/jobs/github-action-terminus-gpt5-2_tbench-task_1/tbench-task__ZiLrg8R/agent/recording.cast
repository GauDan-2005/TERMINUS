[408.149081, "i", "python3 - <<'PY'\nimport json, pathlib\nfrom itertools import zip_longest\nroot=pathlib.Path('/app')\na=json.loads((root/'output/executor-audit.json').read_text())\n\ndef norm_rec(r):\n    return {k:r.get(k) for k in ['case','task','parent','depth','lane','turn']}\n\nbad=False\nfor c in a['cases']:\n    name=c['name']\n    ledger_path=root/c['ledger'] if not str(c['ledger']).startswith('/') else pathlib.Path(c['ledger'])\n    journal_path=root/c['journal'] if not str(c['journal']).startswith('/') else pathlib.Path(c['journal'])\n    if not ledger_path.exists():\n        print('MISSING ledger',name,ledger_path); bad=True; continue\n    if not journal_path.exists():\n        print('MISSING journal',name,journal_path); bad=True; continue\n    # load ledger jsonl\n    ledger=[]\n    for line in ledger_path.read_text().splitlines():\n        line=line.strip()\n        if not line: continue\n        ledger.append(json.loads(line))\n    trace=[norm_rec(r) for r in c.get('trace',[])]\n    ledger_n=[norm_rec(r) for r in ledger]\n    if trace!="]
[408.149902, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
[408.150841, "i", "ledger_n:\n        print('TRACE!=LEDGER',name,'trace',len(trace),'ledger',len(ledger_n))\n        for i,(t,l) in enumerate(zip_longest(trace,ledger_n)):\n            if t!=l:\n                print(' first diff at',i,'trace',t,'ledger',l)\n                break\n        bad=True\n    # load journal rows\n    journal=[]\n    for line in journal_path.read_text().splitlines():\n        line=line.strip()\n        if not line: continue\n        parts=line.split()\n        if len(parts)!=6:\n            print('bad journal row',name,line); bad=True; continue\n        case,task,parent,depth,lane,turn=parts\n        journal.append({'case':case,'task':task,'parent':None if parent=='-' else parent,'depth':int(depth),'lane':lane,'turn':int(turn)})\n    if trace!=journal:\n        print('TRACE!=JOURNAL',name,'trace',len(trace),'journal',len(journal))\n        for i,(t,j) in enumerate(zip_longest(trace,journal)):\n            if t!=j:\n                print(' first diff at',i,'trace',t,'journal',j)\n                break\n        bad=True\n\nprint"]
[408.150871, "o", "\u001b[?2004h> import json, pathlib\r\n\u001b[?2004l\r\u001b[?2004h> from itertools import zip_longest\r\n\u001b[?2004l\r\u001b[?2004h> root=pathlib.Path('/app')\r\n\u001b[?2004l\r\u001b[?2004h> a=json.loads((root/'output/executor-audit.json').read_text())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def norm_rec(r):\r\n\u001b[?2004l\r\u001b[?2004h>     return {k:r.get(k) for k in ['case','task','parent','depth','lane','turn']}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> bad=False\r\n\u001b[?2004l\r\u001b[?2004h> for c in a['cases']:\r\n\u001b[?2004l\r\u001b[?2004h>     name=c['name']\r\n\u001b[?2004l\r\u001b[?2004h> "]
