[624.057822, "i", "cat > /app/core_a/core.rs <<'EOF'\nuse crate::types_f::{Item, Record};\n\npub struct S0 {\n    pub rows: Vec<R0>,\n    pub names: Vec<String>,\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct R0 {\n    pub case_name: String,\n    pub task_name: String,\n    pub parent_name: Option<String>,\n    pub depth: usize,\n    pub lane_name: String,\n    pub base_turn: u64,\n    pub turn: u64,\n    pub seq: usize,\n    pub chain: Vec<String>,\n}\n\n#[derive(Debug)]\npub enum E0 {\n    Halt,\n}\n\nimpl S0 {\n    pub fn new() -> Self {\n        Self {\n            rows: Vec::new(),\n            names: Vec::new(),\n        }\n    }\n}\n\nimpl R0 {\n    pub fn from_item(case_name: &str, item: &Item) -> Self {\n        Self {\n            case_name: case_name.to_string(),\n            task_name: item.ident.clone(),\n            parent_name: (item.parent != \"-\").then(|| item.parent.clone()),\n            depth: item.depth,\n            lane_name: item.lane.clone(),\n            base_turn: item.at,\n            turn: item.at,\n            seq: item.seq,\n        "]
[624.058632, "i", "    chain: item.chain.clone(),\n        }\n    }\n\n    pub fn pack_a(&self) -> Record {\n        Record {\n            case_name: self.case_name.clone(),\n            task_name: self.task_name.clone(),\n            parent_name: self.parent_name.clone(),\n            depth: self.depth,\n            lane_name: self.lane_name.clone(),\n            turn: self.turn,\n        }\n    }\n}\n\npub fn op_a(a: &mut S0, b: R0) -> Result<(), E0> {\n    a.names.push(b.task_name.clone());\n    a.rows.push(b);\n    Ok(())\n}\nEOF\n"]
