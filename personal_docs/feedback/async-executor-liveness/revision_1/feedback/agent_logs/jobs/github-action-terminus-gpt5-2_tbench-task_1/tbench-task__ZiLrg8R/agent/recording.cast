[624.414504, "o", ">     }\r\n\u001b[?2004l\r"]
[624.414582, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[624.414651, "o", "\u001b[?2004h> "]
[624.414819, "o", "    let mut turns: BTreeSet<u64> = BTreeSet::new();\r\n\u001b[?2004l\r"]
[624.414912, "o", "\u001b[?2004h> "]
[624.414994, "o", "    for r in uniq.values() {\r\n\u001b[?2004l\r"]
[624.415081, "o", "\u001b[?2004h> "]
[624.415158, "o", "        turns.insert(r.base_turn);\r\n"]
[624.415181, "o", "\u001b[?2004l\r"]
[624.415252, "o", "\u001b[?2004h> "]
[624.415279, "o", "    }\r\n"]
[624.415293, "o", "\u001b[?2004l\r"]
[624.415361, "o", "\u001b[?2004h> "]
[624.41548, "o", "    if turns.is_empty() {"]
[624.415602, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[624.415661, "o", "> "]
[624.415674, "o", "        return Vec::new();\r\n"]
[624.415685, "o", "\u001b[?2004l\r"]
[624.415753, "o", "\u001b[?2004h"]
[624.415852, "o", "> "]
[624.41587, "o", "    }\r\n"]
[624.415886, "o", "\u001b[?2004l\r"]
[624.415923, "o", "\u001b[?2004h"]
[624.415937, "o", "> "]
[624.416126, "o", "    let min_turn = *turns.iter().next().unwrap();\r\n\u001b[?2004l\r"]
[624.416187, "o", "\u001b[?2004h> "]
[624.416373, "o", "    let max_turn = *turns.iter().next_back().unwrap();\r\n\u001b[?2004l\r"]
[624.416439, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[624.416453, "o", "\u001b[?2004h> "]
[624.416746, "o", "    // Bucket arrivals by base_turn then lane; keep seq order within each bucket.\r\n\u001b[?2004l\r"]
[624.416837, "o", "\u001b[?2004h> "]
[624.417092, "o", "    let mut arrivals: BTreeMap<u64, BTreeMap<String, Vec<R0>>> = BTreeMap::new();\r\n\u001b[?2004l\r"]
[624.417169, "o", "\u001b[?2004h> "]
[624.417269, "o", "    for r in uniq.into_values() {\r\n\u001b[?2004l\r"]
[624.417307, "o", "\u001b[?2004h> "]
[624.417385, "o", "        arrivals\r\n\u001b[?2004l\r"]
[624.417407, "o", "\u001b[?2004h"]
[624.417424, "o", "> "]
[624.417548, "o", "            .entry(r.base_turn)\r\n\u001b[?2004l\r"]
[624.417606, "o", "\u001b[?2004h> "]
[624.417693, "o", "            .or_default()\r\n\u001b[?2004l\r"]
[624.41775, "o", "\u001b[?2004h> "]
[624.417883, "o", "            .entry(r.lane_name.clone())\r\n\u001b[?2004l\r"]
[624.417944, "o", "\u001b[?2004h> "]
[624.418028, "o", "            .or_default()\r\n\u001b[?2004l\r"]
[624.418087, "o", "\u001b[?2004h> "]
[624.418161, "o", "            .push(r);\r\n\u001b[?2004l\r"]
[624.418197, "o", "\u001b[?2004h"]
[624.418211, "o", "> "]
[624.418231, "o", "    }\r\n\u001b[?2004l\r"]
[624.418257, "o", "\u001b[?2004h"]
[624.41827, "o", "> "]
[624.418447, "o", "    for (_t, by_lane) in arrivals.iter_mut() {\r\n"]
[624.418467, "o", "\u001b[?2004l\r"]
[624.418493, "o", "\u001b[?2004h"]
[624.418505, "o", "> "]
[624.418683, "o", "        for (_lane, v) in by_lane.iter_mut() {\r\n\u001b[?2004l\r"]
[624.418745, "o", "\u001b[?2004h> "]
[624.418875, "o", "            v.sort_by_key(|r| r.seq);\r\n\u001b[?2004l\r"]
[624.418903, "o", "\u001b[?2004h"]
[624.418932, "o", "> "]
[624.418994, "o", "        }\r\n\u001b[?2004l\r"]
[624.419047, "o", "\u001b[?2004h> "]
[624.419062, "o", "    }\r\n\u001b[?2004l\r"]
[624.419106, "o", "\u001b[?2004h"]
[624.419118, "o", "> \r\n\u001b[?2004l\r"]
[624.419143, "o", "\u001b[?2004h"]
[624.419154, "o", "> "]
[624.41941, "o", "    let mut ready: BTreeMap<String, VecDeque<R0>> = BTreeMap::new();\r\n\u001b[?2004l\r"]
[624.419472, "o", "\u001b[?2004h> "]
[624.419615, "o", "    let mut accepted: Vec<R0> = Vec::new();\r\n\u001b[?2004l\r"]
[624.419703, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[624.41972, "o", "> "]
[624.419802, "o", "    let mut t = min_turn;\r\n\u001b[?2004l\r"]
[624.419926, "o", "\u001b[?2004h> "]
[624.41994, "o", "    loop {\r\n\u001b[?2004l\r"]
[624.419958, "o", "\u001b[?2004h"]
[624.41997, "o", "> "]
[624.420167, "o", "        if let Some(by_lane) = arrivals.remove(&t) {\r\n\u001b[?2004l\r"]
[624.420226, "o", "\u001b[?2004h> "]
[624.420369, "o", "            for (lane, mut v) in by_lane {\r\n\u001b[?2004l\r"]
[624.420428, "o", "\u001b[?2004h> "]
[624.42062, "o", "                let q = ready.entry(lane).or_default();\r\n\u001b[?2004l\r"]
[624.420708, "o", "\u001b[?2004h> "]
[624.420814, "o", "                for r in v.drain(..) {\r\n\u001b[?2004l\r"]
[624.420885, "o", "\u001b[?2004h> "]
[624.420999, "o", "                    q.push_back(r);\r\n\u001b[?2004l\r"]
[624.421017, "o", "\u001b[?2004h"]
[624.421029, "o", "> "]
[624.421099, "o", "                }\r\n\u001b[?2004l\r"]
[624.421208, "o", "\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h"]
[624.42127, "o", ">         }\r\n\u001b[?2004l\r"]
[624.421349, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[624.42141, "o", "> "]
[624.421573, "o", "        // accept in lane-name order (BTreeMap iteration)\r\n\u001b[?2004l\r"]
[624.421662, "o", "\u001b[?2004h> "]
[624.421782, "o", "        for (lane, q) in ready.iter_mut() {\r\n\u001b[?2004l\r"]
[624.421837, "o", "\u001b[?2004h> "]
[624.421961, "o", "            let mut took = 0usize;\r\n\u001b[?2004l\r"]
[624.42203, "o", "\u001b[?2004h"]
[624.422105, "o", "> "]
[624.422161, "o", "            while took < cap {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[624.422348, "o", "                let mut r = match q.pop_front() {\r\n\u001b[?2004l\r"]
[624.422435, "o", "\u001b[?2004h> "]
[624.42252, "o", "                    Some(r) => r,\r\n\u001b[?2004l\r"]
[624.422573, "o", "\u001b[?2004h> "]
[624.422704, "o", "                    None => break,\r\n\u001b[?2004l\r"]
[624.422792, "o", "\u001b[?2004h> "]
[624.422846, "o", "                };\r\n\u001b[?2004l\r"]
[624.422899, "o", "\u001b[?2004h"]
[624.422954, "o", "> "]
[624.423069, "o", "                r.turn = t;"]
[624.42312, "o", "\r\n\u001b[?2004l\r"]
[624.42319, "o", "\u001b[?2004h"]
[624.423235, "o", "> "]
[624.423458, "o", "                r.lane_name = lane.clone();\r\n\u001b[?2004l\r"]
[624.423563, "o", "\u001b[?2004h> "]
[624.423707, "o", "                accepted.push(r);\r\n\u001b[?2004l\r"]
[624.423797, "o", "\u001b[?2004h"]
[624.423842, "o", "> "]
[624.423962, "o", "                took += 1;\r\n"]
[624.423981, "o", "\u001b[?2004l\r"]
[624.424017, "o", "\u001b[?2004h"]
[624.424061, "o", "> "]
[624.424114, "o", "            }\r\n"]
[624.424138, "o", "\u001b[?2004l\r"]
[624.424182, "o", "\u001b[?2004h> "]
[624.424235, "o", "        }\r\n"]
[624.424258, "o", "\u001b[?2004l\r"]
[624.424285, "o", "\u001b[?2004h"]
[624.424299, "o", "> \r\n"]
[624.424311, "o", "\u001b[?2004l\r"]
[624.424382, "o", "\u001b[?2004h> "]
[624.424585, "o", "        let any_ready = ready.values().any(|q| !q.is_empty());\r\n\u001b[?2004l\r"]
[624.424631, "o", "\u001b[?2004h"]
[624.42469, "o", "> "]
[624.424852, "o", "        let any_future = !arrivals.is_empty();\r\n\u001b[?2004l\r"]
[624.42487, "o", "\u001b[?2004h"]
[624.424884, "o", "> "]
[624.425036, "o", "        if !any_ready && !any_future {\r\n"]
[624.425107, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[624.42517, "o", "            break;\r\n"]
[624.427974, "o", "\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[624.428075, "o", "\u001b[?2004h"]
[624.428096, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[624.428345, "o", "        // If there are gaps in turns (e.g., arrivals at 0 and 10), we still need to\r\n\u001b[?2004l\r"]
[624.428401, "o", "\u001b[?2004h> "]
[624.428602, "o", "        // progress turn-by-turn because CAP applies per turn.\r\n\u001b[?2004l\r"]
[624.428627, "o", "\u001b[?2004h> "]
[624.428801, "o", "        if t < max_turn || any_ready {\r\n\u001b[?2004l\r"]
[624.428836, "o", "\u001b[?2004h> "]
[624.428918, "o", "            t += 1;\r\n\u001b[?2004l\r"]
[624.428945, "o", "\u001b[?2004h> "]
[624.429031, "o", "        } else {\r\n\u001b[?2004l\r"]
[624.429087, "o", "\u001b[?2004h"]
[624.429111, "o", "> "]
[624.429193, "o", "            t += 1;\r\n\u001b[?2004l\r"]
[624.429218, "o", "\u001b[?2004h> "]
[624.429283, "o", "        }\r\n\u001b[?2004l\r"]
[624.429347, "o", "\u001b[?2004h"]
[624.429375, "o", "> "]
[624.429394, "o", "    }\r\n\u001b[?2004l\r"]
[624.429427, "o", "\u001b[?2004h"]
[624.429442, "o", "> \r\n"]
[624.429508, "o", "\u001b[?2004l\r\u001b[?2004h"]
[624.429526, "o", "> "]
[624.429646, "o", "    accepted.sort_by(|l, r| {\r\n\u001b[?2004l\r"]
[624.429669, "o", "\u001b[?2004h> "]
[624.429744, "o", "        l.turn\r\n\u001b[?2004l\r"]
[624.429813, "o", "\u001b[?2004h"]
[624.429837, "o", "> "]
[624.429925, "o", "            .cmp(&r.turn)\r\n\u001b[?2004l\r"]
[624.429948, "o", "\u001b[?2004h"]
[624.429983, "o", "> "]
[624.430175, "o", "            .then(l.lane_name.cmp(&r.lane_name))\r\n\u001b[?2004l\r"]
[624.4302, "o", "\u001b[?2004h> "]
[624.430329, "o", "            .then(l.seq.cmp(&r.seq))\r\n\u001b[?2004l\r"]
[624.430357, "o", "\u001b[?2004h"]
[624.430368, "o", "> "]
[624.430435, "o", "    });\r\n\u001b[?2004l\r"]
[624.43046, "o", "\u001b[?2004h> "]
[624.430528, "o", "    accepted\r\n\u001b[?2004l\r"]
[624.430575, "o", "\u001b[?2004h"]
[624.430696, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[624.430733, "o", "EOF\r\n\u001b[?2004l\r"]
[624.431721, "o", "\u001b[?2004hroot@88e50440921f:/app# "]
[624.529644, "i", "cat > /app/drive_g/drive.rs <<'EOF'\nuse std::collections::{BTreeMap, BTreeSet};\nuse std::io;\nuse std::path::{Path, PathBuf};\n\nuse crate::book_b::fold_b;\nuse crate::core_a::{op_a, R0, S0};\nuse crate::flow_e::{emit_e, note_e};\nuse crate::gate_c::{mark_c, S1};\nuse crate::host_d::{bind_d, R1, S2};\nuse crate::types_f::{CaseReport, Entry, Item, Plan, Record};\n\nfn out_paths(base: &Path, name: &str) -> (PathBuf, PathBuf) {\n    (\n        base.join(\"ledgers\").join(format!(\"{}.jsonl\", name)),\n        base.join(\"journals\").join(format!(\"{}.txt\", name)),\n    )\n}\n\npub fn drive_g(a: &Plan, b: &Path) -> io::Result<CaseReport> {\n    let mut host = S2::new();\n    let mut removed: BTreeSet<String> = BTreeSet::new();\n    let mut raw: BTreeMap<String, Item> = BTreeMap::new();\n\n    for entry in &a.entries {\n        match entry {\n            Entry::Root { ident, lane, at, seq } => {\n                let item = Item {\n                    ident: ident.clone(),\n                    parent: \"-\".to_string(),\n                    lane: lane"]
[624.529694, "i", ".clone(),\n                    at: *at,\n                    seq: *seq,\n                    depth: 0,\n                    chain: vec![ident.clone()],\n                };\n                let moved =\n                    bind_d(&mut host, R1 { item }).map_err(|_| io::Error::new(io::ErrorKind::Other, \"state\"))?;\n                raw.insert(ident.clone(), moved.item);\n            }\n            Entry::Child {\n                from,\n                ident,\n                lane,\n                at,\n                seq,\n            } => {\n                let parent = raw.get(from).cloned();\n                let depth = parent.as_ref().map(|p| p.depth + 1).unwrap_or(0);\n                let mut chain = parent.map(|p| p.chain).unwrap_or_default();\n                chain.push(ident.clone());\n                let item = Item {\n                    ident: ident.clone(),\n                    parent: from.clone(),\n                    lane: lane.clone(),\n                    at: *at,\n                    seq: *seq,\n                    dept"]
[624.52971, "i", "h,\n                    chain,\n                };\n                let moved =\n                    bind_d(&mut host, R1 { item }).map_err(|_| io::Error::new(io::ErrorKind::Other, \"state\"))?;\n                raw.insert(ident.clone(), moved.item);\n            }\n            Entry::Drop { ident } => {\n                removed.insert(ident.clone());\n            }\n        }\n    }\n\n    let gate = S1::new(removed);\n    let mut state = S0::new();\n\n    for item in raw.values() {\n        let row = R0::from_item(&a.name, item);\n        if mark_c(&gate, &row) {\n            op_a(&mut state, row).map_err(|_| io::Error::new(io::ErrorKind::Other, \"row\"))?;\n        }\n    }\n\n    // Expand removals to descendants: DROP removes that ident and all descendants.\n    let mut expanded: BTreeSet<String> = BTreeSet::new();\n    for row in &state.rows {\n        if row.chain.iter().any(|n| gate.removed.contains(n)) {\n            expanded.insert(row.task_name.clone());\n        }\n    }\n\n    let kept: Vec<R0> = state\n        .rows\n        .iter("]
[624.529726, "i", ")\n        .cloned()\n        .filter(|r| !expanded.contains(&r.task_name))\n        .collect();\n\n    let ordered = fold_b(&kept, a.cap);\n    let trace: Vec<Record> = ordered.iter().map(R0::pack_a).collect();\n\n    let accepted: BTreeSet<String> = trace.iter().map(|row| row.task_name.clone()).collect();\n    let mut pending: Vec<String> = kept\n        .iter()\n        .filter(|row| !accepted.contains(&row.task_name))\n        .map(|row| row.task_name.clone())\n        .collect();\n    pending.sort();\n\n    let (ledger, journal) = out_paths(b, &a.name);\n    emit_e(&ledger, &trace)?;\n    note_e(&journal, &trace)?;\n\n    let finished = pending.is_empty();\n    Ok(CaseReport {\n        name: a.name.clone(),\n        ok: finished,\n        finished,\n        pending,\n        trace,\n        ledger: ledger.display().to_string(),\n        journal: journal.display().to_string(),\n    })\n}\nEOF\n"]
