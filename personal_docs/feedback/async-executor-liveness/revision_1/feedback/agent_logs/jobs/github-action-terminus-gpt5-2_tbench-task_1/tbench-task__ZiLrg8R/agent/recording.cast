[409.179575, "o", "\u001b[?2004hroot@88e50440921f:/app# "]
[417.216678, "i", "sed -n '1,200p' /app/src/main.rs\n"]
[417.216882, "o", "sed -n '1,200p' /app/src/main.rs\r\n\u001b[?2004l\r"]
[417.218049, "o", "use std::env;\r\nuse std::fs;\r\nuse std::io;\r\nuse std::path::{Path, PathBuf};\r\n\r\nuse executor_liveness_lab::drive_g::drive_g;\r\nuse executor_liveness_lab::read_h::read_plan;\r\nuse executor_liveness_lab::serde_f::report_json;\r\nuse executor_liveness_lab::types_f::CaseReport;\r\n\r\nfn arg_value(args: &[String], key: &str) -> Option<String> {\r\n    args.windows(2)\r\n        .find(|w| w[0] == key)\r\n        .map(|w| w[1].to_string())\r\n}\r\n"]
[417.218153, "o", "\r\nfn plan_path(root: &Path, name: &str) -> PathBuf {\r\n    root.join(\"data\").join(\"cases\").join(format!(\"{}.plan\", name))\r\n}\r\n"]
[417.218268, "o", "\r\nfn load_names(args: &[String]) -> Vec<String> {\r\n    if let Some(name) = arg_value(args, \"--case\") {\r\n        vec![name]\r\n    } else {\r\n        [\"amber\", \"cobalt\", \"drake\", \"ember\", \"flint\", \"graphite\"]\r\n            .iter()\r\n            .map(|s| s.to_string())\r\n            .collect()\r\n    }\r\n}\r\n\r\n"]
[417.218325, "o", "fn drive_x(root: &Path, names: &[String], out: &Path, work: &Path) -> io::Result<Vec<CaseReport>> {\r\n    let mut reports = Vec::new();\r\n    for name in names {\r\n        let plan = read_plan(&plan_path(root, name))?;\r\n        reports.push(drive_g(&plan, work)?);\r\n    }\r\n    if let Some(parent) = out.parent() {\r\n        fs::create_dir_all(parent)?;\r\n    }\r\n    fs::write(out, report_json(&reports))?;\r\n    Ok(reports)\r\n}\r\n\r\nfn main() -> io::Result<()> {\r\n    let args: Vec<String> = env::args().collect();\r\n"]
[417.218334, "o", "    let root = PathBuf::from(arg_value(&args, \"--root\").unwrap_or_else(|| \"/app\".to_string()));\r\n"]
[417.218448, "o", "    let out = PathBuf::from(arg_value(&args, \"--out\").unwrap_or_else(|| \"/app/output/executor-audit.json\".to_string()));\r\n"]
[417.218486, "o", "    let work = PathBuf::from(arg_value(&args, \"--work\").unwrap_or_else(|| \"/app/output/runtime\".to_string()));\r\n    let names = load_names(&args);\r\n    let _ = drive_x(&root, &names, &out, &work)?;\r\n    Ok(())\r\n}\r\n"]
[417.218591, "o", "\u001b[?2004h"]
