[465.653701, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Add File: book_b/book.rs\n+use std::collections::{BTreeMap, BTreeSet, VecDeque};\n+\n+use crate::core_a::R0;\n+\n+fn lane_key(r: &R0) -> String {\n+    r.lane_name.clone()\n+}\n+\n+/// Accept work in discrete turns.\n+///\n+/// Contract:\n+/// - Each row becomes eligible on its own arrival/base_turn.\n+/// - Per turn, each lane may accept up to `cap` ready rows.\n+/// - Overflow stays live for later turns.\n+/// - Accepted trace is ordered by accepted turn asc, then lane name asc,\n+///   then plan-file order (seq) within the lane.\n+pub fn fold_b(rows: &[R0], cap: usize) -> Vec<R0> {\n+    let cap = cap.max(1);\n+\n+    // Dedup by logical task name: keep the earliest (base_turn, seq).\n+    let mut uniq: BTreeMap<String, R0> = BTreeMap::new();\n+    for r in rows.iter().cloned() {\n+        uniq.entry(r.task_name.clone())\n+            .and_modify(|cur| {\n+                if (r.base_turn, r.seq) < (cur.base_turn, cur.seq) {\n+                    *cur = r.clone();\n+                }\n+       "]
[465.653749, "i", "     })\n+            .or_insert(r);\n+    }\n+    let mut rows: Vec<R0> = uniq.into_values().collect();\n+\n+    // Establish timeline.\n+    let mut turns: BTreeSet<u64> = BTreeSet::new();\n+    for r in &rows {\n+        turns.insert(r.base_turn);\n+    }\n+    if turns.is_empty() {\n+        return Vec::new();\n+    }\n+    let min_turn = *turns.iter().next().unwrap();\n+    let max_turn = *turns.iter().next_back().unwrap();\n+\n+    // Bucket arrivals by turn, then by lane.\n+    let mut arrivals: BTreeMap<u64, BTreeMap<String, Vec<R0>>> = BTreeMap::new();\n+    for r in rows.drain(..) {\n+        arrivals\n+            .entry(r.base_turn)\n+            .or_default()\n+            .entry(lane_key(&r))\n+            .or_default()\n+            .push(r);\n+    }\n+    for (_t, by_lane) in arrivals.iter_mut() {\n+        for (_lane, v) in by_lane.iter_mut() {\n+            v.sort_by_key(|r| r.seq);\n+        }\n+    }\n+\n+    // Per-lane ready queues.\n+    let mut ready: BTreeMap<String, VecDeque<R0>> = BTreeMap::new();\n+    let mut acce"]
[465.653767, "i", "pted: Vec<R0> = Vec::new();\n+\n+    // Drive turns from min..=max, and then keep going until all ready drained.\n+    let mut t = min_turn;\n+    loop {\n+        if let Some(by_lane) = arrivals.remove(&t) {\n+            for (lane, v) in by_lane {\n+                let q = ready.entry(lane).or_default();\n+                for r in v {\n+                    q.push_back(r);\n+                }\n+            }\n+        }\n+\n+        // Accept per lane in lane-name order.\n+        for (lane, q) in ready.iter_mut() {\n+            let mut took = 0usize;\n+            while took < cap {\n+                let mut r = match q.pop_front() {\n+                    Some(r) => r,\n+                    None => break,\n+                };\n+                r.turn = t;\n+                // keep lane field stable, but ensure it matches key\n+                r.lane_name = lane.clone();\n+                accepted.push(r);\n+                took += 1;\n+            }\n+        }\n+\n+        let any_ready = ready.values().any(|q| !q.is_empty());\n+      "]
[465.653778, "i", "  let any_future = !arrivals.is_empty();\n+\n+        if !any_ready && !any_future {\n+            break;\n+        }\n+        if t < max_turn {\n+            t += 1;\n+        } else {\n+            // past last arrival turn, just keep draining ready\n+            t += 1;\n+        }\n+    }\n+\n+    accepted.sort_by(|l, r| {\n+        l.turn\n+            .cmp(&r.turn)\n+            .then(l.lane_name.cmp(&r.lane_name))\n+            .then(l.seq.cmp(&r.seq))\n+    });\n+    accepted\n+}\n+\n*** End Patch\nPATCH\n"]
[465.653856, "o", "apply_patch <<'PATCH'"]
