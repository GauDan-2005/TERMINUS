[119.836224, "i", "cat > /app/book_b/book.rs << 'EOF'\nuse std::collections::BTreeMap;\n\nuse crate::core_a::R0;\n\npub fn fold_b(a: &[R0], cap: usize) -> Vec<R0> {\n    let cap = cap.max(1);\n    let mut pool: Vec<R0> = a.to_vec();\n    let mut accepted: Vec<R0> = Vec::new();\n\n    let mut turn = 0u64;\n\n    while !pool.is_empty() {\n        let mut eligible_by_lane: BTreeMap<String, Vec<R0>> = BTreeMap::new();\n        let mut not_eligible: Vec<R0> = Vec::new();\n\n        for row in pool.drain(..) {\n            if row.base_turn <= turn {\n                eligible_by_lane.entry(row.lane_name.clone()).or_default().push(row);\n            } else {\n                not_eligible.push(row);\n            }\n        }\n\n        let mut any_accepted = false;\n        for (_lane, mut rows) in eligible_by_lane {\n            rows.sort_by_key(|r| r.seq);\n            let take = rows.len().min(cap);\n            for mut row in rows.drain(..take) {\n                row.turn = turn;\n                accepted.push(row);\n                any_accepted = true;\n         "]
[119.836518, "i", "   }\n            not_eligible.extend(rows);\n        }\n\n        pool = not_eligible;\n\n        if !any_accepted {\n            if let Some(next) = pool.iter().map(|r| r.base_turn).min() {\n                turn = next;\n            } else {\n                break;\n            }\n        } else {\n            turn += 1;\n        }\n    }\n\n    accepted.sort_by(|l, r| l.turn.cmp(&r.turn).then(l.lane_name.cmp(&r.lane_name)).then(l.seq.cmp(&r.seq)));\n    accepted\n}\nEOF\n"]
[119.836766, "o", "cat > /app/book_b/book.rs << 'EOF'"]
