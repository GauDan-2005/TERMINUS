[47.132564, "o", "pub fn tag_for(name: &str) -> String {\r\n    name.chars().take(3).collect()\r\n}\r\n\r\npub fn count_nonempty(lines: &[String]) -> usize {\r\n    lines.iter().filter(|line| !line.trim().is_empty()).count()\r\n}\r\n"]
