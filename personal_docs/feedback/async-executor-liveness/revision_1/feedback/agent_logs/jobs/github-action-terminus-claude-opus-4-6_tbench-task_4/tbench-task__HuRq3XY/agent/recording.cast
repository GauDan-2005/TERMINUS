[241.149864, "o", "        for (idx, row) in a.iter().enumerate() {\r\n\u001b[?2004l\r"]
[241.149929, "o", "\u001b[?2004h> "]
[241.150137, "o", "            if row.base_turn <= current_turn && !accepted_set.contains(&idx) {\r\n\u001b[?2004l\r"]
[241.150166, "o", "\u001b[?2004h> "]
[241.150449, "o", "                ready_by_lane.entry(row.lane_name.clone()).or_default().push((idx, row));\r\n\u001b[?2004l\r"]
[241.150478, "o", "\u001b[?2004h> "]
[241.150542, "o", "            }\r\n\u001b[?2004l\r"]
[241.15056, "o", "\u001b[?2004h"]
[241.150605, "o", "> "]
[241.150644, "o", "        }\r\n\u001b[?2004l\r"]
[241.150658, "o", "\u001b[?2004h"]
[241.150669, "o", "> \r\n"]
[241.150682, "o", "\u001b[?2004l\r"]
[241.150754, "o", "\u001b[?2004h> "]
[241.151041, "o", "        if ready_by_lane.is_empty() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[241.151187, "o", "            // No items ready at this turn, but there might be items with higher base_turn\r\n\u001b[?2004l\r"]
[241.151251, "o", "\u001b[?2004h> "]
[241.151363, "o", "            if current_turn >= max_base_turn {\r\n\u001b[?2004l\r"]
[241.151389, "o", "\u001b[?2004h> "]
[241.151598, "o", "                break; // No more items will ever become ready\r\n\u001b[?2004l\r"]
[241.151654, "o", "\u001b[?2004h"]
[241.15167, "o", "> "]
[241.151687, "o", "            }\r\n\u001b[?2004l\r"]
[241.151743, "o", "\u001b[?2004h> "]
[241.151918, "o", "            current_turn += 1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[241.151983, "o", "            continue;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[241.152026, "o", "        }\r\n\u001b[?2004l\r"]
[241.152088, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[241.152107, "o", "\u001b[?2004h"]
[241.152121, "o", "> "]
[241.152345, "o", "        let mut accepted_this_turn: Vec<(usize, R0)> = Vec::new();\r\n\u001b[?2004l\r"]
[241.152445, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[241.152488, "o", "\u001b[?2004h> "]
[241.152588, "o", "        for (_lane, mut items) in ready_by_lane {\r\n\u001b[?2004l\r"]
[241.152635, "o", "\u001b[?2004h> "]
[241.152803, "o", "            // Sort by seq (plan-file order)\r\n\u001b[?2004l\r"]
[241.152825, "o", "\u001b[?2004h> "]
[241.152995, "o", "            items.sort_by_key(|(_, row)| row.seq);\r\n\u001b[?2004l\r"]
[241.153052, "o", "\u001b[?2004h> "]
[241.15323, "o", "            for (idx, row) in items.into_iter().take(cap) {\r\n\u001b[?2004l\r"]
[241.153314, "o", "\u001b[?2004h> "]
[241.15348, "o", "                let mut accepted_row = row.clone();\r\n\u001b[?2004l\r\u001b[?2004h"]
[241.153548, "o", "> "]
[241.153693, "o", "                accepted_row.turn = current_turn;\r\n\u001b[?2004l\r"]
[241.153759, "o", "\u001b[?2004h> "]
[241.153943, "o", "                accepted_this_turn.push((idx, accepted_row));\r\n\u001b[?2004l\r"]
[241.15401, "o", "\u001b[?2004h> "]
[241.15411, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[241.154201, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[241.154415, "o", "        // Sort within this turn: by lane name, then by seq\r\n\u001b[?2004l\r\u001b[?2004h"]
[241.154484, "o", "> "]
[241.154664, "o", "        accepted_this_turn.sort_by(|(_, left), (_, right)| {\r\n"]
[241.154724, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[241.154948, "o", "            left.lane_name.cmp(&right.lane_name).then(left.seq.cmp(&right.seq))\r\n\u001b[?2004l\r"]
[241.155074, "o", "\u001b[?2004h>         });\r\n\u001b[?2004l\r\u001b[?2004h"]
[241.155163, "o", "> \r\n\u001b[?2004l\r"]
[241.155252, "o", "\u001b[?2004h> "]
[241.155388, "o", "        for (idx, row) in accepted_this_turn {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[241.155521, "o", "            accepted_set.insert(idx);\r\n\u001b[?2004l\r"]
[241.155648, "o", "\u001b[?2004h> "]
[241.155795, "o", "            accepted.push(row);\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[241.155949, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[241.156029, "o", "        current_turn += 1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[241.15614, "o", "        // Safety bound\r\n\u001b[?2004l\r\u001b[?2004h> "]
[241.156316, "o", "        if current_turn > max_base_turn + a.len() as u64 + 1 {\r\n\u001b[?2004l\r"]
[241.156337, "o", "\u001b[?2004h"]
[241.156351, "o", "> "]
[241.156463, "o", "            break;\r\n\u001b[?2004l\r\u001b[?2004h"]
[241.156574, "o", "> "]
[241.156778, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[241.156835, "o", "    accepted\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[241.156854, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
