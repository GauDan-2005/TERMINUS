[8.870176, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\ncase_name=\"${1:?case name required}\"\r\nout=\"${2:-/app/output/executor-audit.json}\"\r\nwork=\"${3:-/app/output/runtime}\"\r\nmkdir -p /app/output\r\ncargo run --quiet --release --bin executor-ctl -- --case \"$case_name\" --out \"$out\" --work \"$work\"\r\n"]
