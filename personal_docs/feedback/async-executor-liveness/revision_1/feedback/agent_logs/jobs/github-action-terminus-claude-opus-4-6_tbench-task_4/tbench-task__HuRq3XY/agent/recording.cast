[112.713308, "i", "cat > /app/gate_c/gate.rs << 'EOF'\nuse std::collections::BTreeSet;\n\nuse crate::core_a::R0;\n\npub struct S1 {\n    pub removed: BTreeSet<String>,\n}\n\nimpl S1 {\n    pub fn new(removed: BTreeSet<String>) -> Self {\n        Self { removed }\n    }\n}\n\npub fn mark_c(a: &S1, b: &R0) -> bool {\n    // Check if any element in the chain (the item itself or any ancestor) is removed\n    !b.chain.iter().any(|name| a.removed.contains(name))\n}\nEOF\n"]
