[112.717707, "o", "pub fn mark_c(a: &S1, b: &R0) -> bool {"]
[112.71809, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     // Check if any element in the chain (the item itself or any ancestor) is removed\r\n\u001b[?2004l\r\u001b[?2004h"]
[112.718135, "o", "> "]
[112.718329, "o", "    !b.chain.iter().any(|name| a.removed.contains(name))\r\n\u001b[?2004l\r"]
