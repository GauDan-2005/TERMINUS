[?2004hroot@ad377fa89207:/app# cat > /app/book_b/book.rs << 'EOF'
[?2004l[?2004h> use std::collections::{BTreeMap, BTreeSet};
[?2004l[?2004h> 
[?2004l[?2004h> use crate::core_a::R0;
[?2004l[?2004h> 
[?2004l[?2004h> /// Implements multi-turn CAP acceptance.
[?2004l[?2004h> /// Each item has a base_turn (arrival turn). At each turn t, items with base_turn <= t
[?2004l[?2004h> /// that haven't been accepted yet are ready. Within each lane, ready items are sorted
[?2004l[?2004h> /// by seq (plan-file order). Up to `cap` items per lane are accepted per turn.
[?2004l[?2004h> /// Overflow remains live for later turns.
[?2004l[?2004h> pub fn fold_b(a: &[R0], cap: usize) -> Vec<R0> {
[?2004l[?2004h>     let cap = cap.max(1);
[?2004l[?2004h> 
[?2004l[?2004h>     if a.is_empty() {
[?2004l[?2004h>         return Vec::new();
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     let mut accepted: Vec<R0> = Vec::new();
[?2004l[?2004h>     let mut accepted_set: BTreeSet<usize> = BTreeSet::new();
[?2004l[?2004h> 
[?2004l[?2004h>     let min_turn = a.iter().map(|r| r.base_turn).min().unwrap_or(0);
[?2004l[?2004h>     let max_base_turn = a.iter().map(|r| r.base_turn).max().unwrap_or(0);
[?2004l[?2004h> 
[?2004l[?2004h>     let mut current_turn = min_turn;
[?2004l[?2004h> 
[?2004l[?2004h>     loop {
[?2004l[?2004h>         // If all items are accepted, done
[?2004l[?2004h>         if accepted_set.len() == a.len() {
[?2004l[?2004h>             break;
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         // Collect ready items: base_turn <= current_turn and not yet accepted
[?2004l[?2004h>         let mut ready_by_lane: BTreeMap<String, Vec<(usize, &R0)>> = BTreeMap::new();
[?2004l[?2004h>         for (idx, row) in a.iter().enumerate() {
[?2004l[?2004h>             if row.base_turn <= current_turn && !accepted_set.contains(&idx) {
[?2004l[?2004h>                 ready_by_lane.entry(row.lane_name.clone()).or_default().push((idx, row));
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         if ready_by_lane.is_empty() {
[?2004l[?2004h>             // No items ready at this turn, but there might be items with higher base_turn
[?2004l[?2004h>             if current_turn >= max_base_turn {
[?2004l[?2004h>                 break; // No more items will ever become ready
[?2004l[?2004h>             }
[?2004l[?2004h>             current_turn += 1;
[?2004l[?2004h>             continue;
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         let mut accepted_this_turn: Vec<(usize, R0)> = Vec::new();
[?2004l[?2004h> 
[?2004l[?2004h>         for (_lane, mut items) in ready_by_lane {
[?2004l[?2004h>             // Sort by seq (plan-file order)
[?2004l[?2004h>             items.sort_by_key(|(_, row)| row.seq);
[?2004l[?2004h>             for (idx, row) in items.into_iter().take(cap) {
[?2004l[?2004h>                 let mut accepted_row = row.clone();
[?2004l[?2004h>                 accepted_row.turn = current_turn;
[?2004l[?2004h>                 accepted_this_turn.push((idx, accepted_row));
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         // Sort within this turn: by lane name, then by seq
[?2004l[?2004h>         accepted_this_turn.sort_by(|(_, left), (_, right)| {
[?2004l[?2004h>             left.lane_name.cmp(&right.lane_name).then(left.seq.cmp(&right.seq))
[?2004l[?2004h>         });
[?2004l[?2004h> 
[?2004l[?2004h>         for (idx, row) in accepted_this_turn {
[?2004l[?2004h>             accepted_set.insert(idx);
[?2004l[?2004h>             accepted.push(row);
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         current_turn += 1;
[?2004l[?2004h>         // Safety bound
[?2004l[?2004h>         if current_turn > max_base_turn + a.len() as u64 + 1 {
[?2004l[?2004h>             break;
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     accepted
[?2004l[?2004h> }
[?2004l[?2004h> EOF
