[142.744357, "o", "use std::env;\r\nuse std::path::PathBuf;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().skip(1).collect();\r\n    if args.len() < 2 {\r\n"]
[142.744389, "o", "        eprintln!(\"usage: idxlab <report> <trace> [trace ...]\");\r\n        std::process::exit(2);\r\n    }\r\n    let out = PathBuf::from(&args[0]);\r\n"]
[142.744476, "o", "    let traces: Vec<PathBuf> = args[1..].iter().map(PathBuf::from).collect();\r\n    if let Err(err) = idxlab::runner::run_all(&out, &traces) {\r\n        eprintln!(\"{err}\");\r\n        std::process::exit(1);\r\n"]
[142.7445, "o", "    }\r\n}\r\n"]
