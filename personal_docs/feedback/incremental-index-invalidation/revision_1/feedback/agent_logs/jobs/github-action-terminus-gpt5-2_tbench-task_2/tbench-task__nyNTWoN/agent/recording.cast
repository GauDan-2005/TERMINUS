[403.519819, "i", "python3 - <<'PY'\nfrom pathlib import Path\n\ndef replace(path, old, new):\n    p = Path(path)\n    s = p.read_text()\n    if old not in s:\n        raise SystemExit(f\"pattern not found in {path}\")\n    p.write_text(s.replace(old, new))\n\n# r5/f.rs\nreplace('r5/f.rs',\n\"pub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\\n    if c {\\n        if b.found && b.fresh {\\n            (b, None)\\n        } else {\\n            let label = b.label.clone();\\n            (b, Some(label))\\n        }\\n    } else if b.found && b.path.starts_with(\\\"/app/\\\") {\\n        (b, None)\\n    } else {\\n        (b, None)\\n    }\\n}\\n\",\n\"pub fn cast_f(_a: &State, label: &str, b: Observation, c: bool) -> (Observation, Option<String>) {\\n    if c {\\n        if b.found && b.fresh {\\n            (b, None)\\n        } else {\\n            (b, Some(label.to_string()))\\n        }\\n    } else if b.found && b.path.starts_with(\\\"/app/\\\") {\\n        (b, None)\\n    } else {\\n        (b, None)\\n    }\\n}\\n\")\nPY\n"]
