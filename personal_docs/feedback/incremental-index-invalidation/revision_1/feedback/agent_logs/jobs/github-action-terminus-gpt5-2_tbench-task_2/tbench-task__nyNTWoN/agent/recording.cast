[405.519373, "i", "python3 - <<'PY'\nfrom pathlib import Path\n\ndef replace(path, old, new):\n    p = Path(path)\n    s = p.read_text()\n    if old not in s:\n        raise SystemExit(f\"pattern not found in {path}\")\n    p.write_text(s.replace(old, new))\n\n# r1/b.rs\nreplace('r1/b.rs',\n\"    let root = app_path(c);\\n    a.active.insert(b.to_string(), root);\\n    let mut found = collect_entries(a, b, c, a.epoch)?;\\n    a.entries.append(&mut found);\\n\",\n\"    let root = app_path(c);\\n    a.active.insert(b.to_string(), root.clone());\\n\\n    // Replace entries for this slot to avoid reporting stale locations.\\n    a.entries.retain(|e| e.slot != b);\\n    let mut found = collect_entries(a, b, &root, a.epoch)?;\\n    a.entries.append(&mut found);\\n\")\nPY\n"]
