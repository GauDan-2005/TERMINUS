[404.507504, "i", "python3 - <<'PY'\nfrom pathlib import Path\n\ndef replace(path, old, new):\n    p = Path(path)\n    s = p.read_text()\n    if old not in s:\n        raise SystemExit(f\"pattern not found in {path}\")\n    p.write_text(s.replace(old, new))\n\n# r0/a.rs\nreplace('r0/a.rs',\n\"            let item = mote_e(a, &b.right, true);\\n            let (item, note) = cast_f(a, item, true);\\n\",\n\"            let item = mote_e(a, &b.right, true);\\n            let (item, note) = cast_f(a, &b.left, item, true);\\n\")\nreplace('r0/a.rs',\n\"            let item = mote_e(a, &b.right, false);\\n            let (item, note) = cast_f(a, item, false);\\n\",\n\"            let item = mote_e(a, &b.right, false);\\n            let (item, note) = cast_f(a, &b.left, item, false);\\n\")\nPY\n"]
