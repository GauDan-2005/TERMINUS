[407.5202, "i", "python3 - <<'PY'\nfrom pathlib import Path\n\ndef replace(path, old, new):\n    p = Path(path)\n    s = p.read_text()\n    if old not in s:\n        raise SystemExit(f\"pattern not found in {path}\")\n    p.write_text(s.replace(old, new))\n\n# r3/d.rs\nreplace('r3/d.rs',\n\"    let shown = app_path(c);\\n    let actual = resolve_target_root(c)?;\\n    a.active.insert(b.to_string(), shown);\\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\\n    a.entries.append(&mut found);\\n\",\n\"    let _shown = app_path(c);\\n    let actual = resolve_target_root(c)?;\\n\\n    // For linked packages, we follow the active target root.\\n    a.active.insert(b.to_string(), actual.clone());\\n\\n    a.entries.retain(|e| e.slot != b);\\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\\n    a.entries.append(&mut found);\\n\")\nPY\n"]
