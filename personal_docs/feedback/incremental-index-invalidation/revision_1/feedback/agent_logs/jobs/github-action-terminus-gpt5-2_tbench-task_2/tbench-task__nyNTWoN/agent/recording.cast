[407.523108, "o", "\"    let shown = app_path(c);\\n    let actual = resolve_target_root(c)?;\\n    a.active.insert(b.to_string(), shown);\\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\\n    a.entries.append(&mut found);\\n\",\r\n\u001b[?2004l\r"]
[407.523199, "o", "\u001b[?2004h> "]
[407.524095, "o", "\"    let _shown = app_path(c);\\n    let actual = resolve_target_root(c)?;\\n\\n    // For linked packages, we follow the active target root.\\n    a.active.insert(b.to_string(), actual.clone());\\n\\n    a.entries.retain(|e| e.slot != b);\\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\\n    a.entries.append(&mut found);\\n\")\r\n\u001b[?2004l\r"]
[407.524203, "o", "\u001b[?2004h> "]
[407.524344, "o", "PY\r\n\u001b[?2004l\r"]
