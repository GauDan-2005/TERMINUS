[?2004l[?2004h> use crate::model::{Observation, State};
[?2004l[?2004h> 
[?2004l[?2004h> pub fn mote_e(a: &mut State, b: &str, c: bool) -> Observation {
[?2004l[?2004h>     let query_epoch = a.epoch;
[?2004l[?2004h> 
[?2004l[?2004h>     // Pick the definition that would be visible in the currently active roots.
[?2004l[?2004h>     // If multiple candidates exist (e.g. after slot retargeting), take the most
[?2004l[?2004h>     // recently indexed one for determinism.
[?2004l[?2004h>     let mut best = None;
[?2004l[?2004h>     for entry in a.entries.iter().filter(|e| e.symbol == b) {
[?2004l[?2004h>         let Some(root) = a.active.get(&entry.slot) else {
[?2004l[?2004h>             continue;
[?2004l[?2004h>         };
[?2004l[?2004h>         if !entry.path.starts_with(root) {
[?2004l[?2004h>             continue;
[?2004l[?2004h>         }
[?2004l[?2004h>         match best {
[?2004l[?2004h>             None => best = Some(entry),
[?2004l[?2004h>             Some(prev) if entry.epoch >= prev.epoch => best = Some(entry),
[?2004l[?2004h>             Some(_) => {}
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     if let Some(entry) = best {
[?2004l[?2004h>         let reused = a
[?2004l[?2004h>             .last_seen
[?2004l[?2004h>             .get(b)
[?2004l[?2004h>             .map(|old| *old == entry.handle)
[?2004l[?2004h>             .unwrap_or(false);
[?2004l[?2004h>         a.last_seen.insert(b.to_string(), entry.handle);
[?2004l[?2004h> 
[?2004l[?2004h>         Observation {
[?2004l[?2004h>             label: String::new(),
[?2004l[?2004h>             symbol: b.to_string(),
[?2004l[?2004h>             found: true,
[?2004l[?2004h>             path: entry.path.clone(),
[?2004l[?2004h>             source: entry.source.clone(),
[?2004l[?2004h>             line: entry.line,
[?2004l[?2004h>             epoch: query_epoch,
[?2004l[?2004h>             reused,
[?2004l[?2004h>             fresh: true,
[?2004l[?2004h>         }
[?2004l[?2004h>     } else {
[?2004l[?2004h>         // For misses, `fresh` means the miss is correct.
[?2004l[?2004h>         Observation::missing(b, b, a.epoch, !c)
[?2004l[?2004h>     }
[?2004l[?2004h> }
