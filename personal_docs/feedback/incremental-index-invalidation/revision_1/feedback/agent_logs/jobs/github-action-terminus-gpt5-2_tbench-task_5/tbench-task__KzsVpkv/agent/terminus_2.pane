[?2004l[?2004h>             item.label = b.left.clone();
[?2004l[?2004h>             let (item, note) = cast_f(a, item, false);
[?2004l[?2004h>             c.observations.push(item);
[?2004l[?2004h>             if let Some(note) = note {
