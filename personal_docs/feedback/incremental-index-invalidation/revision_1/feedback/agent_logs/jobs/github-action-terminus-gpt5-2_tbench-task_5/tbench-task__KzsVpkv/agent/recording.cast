[384.227175, "i", "cat > /app/r2/c.rs <<'EOF'\nuse crate::io::{app_path, collect_entries};\nuse crate::model::State;\n\npub fn emit_c(a: &mut State, b: &str, c: &str) -> Result<(), String> {\n    a.epoch += 1;\n    let root = app_path(c);\n    a.active.insert(b.to_string(), root);\n\n    // Generated module reruns must replace prior generated output.\n    a.entries.retain(|e| e.slot != b);\n\n    let mut found = collect_entries(a, b, c, a.epoch)?;\n    a.entries.append(&mut found);\n    Ok(())\n}\nEOF\n"]
