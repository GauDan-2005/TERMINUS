[384.488869, "o", "\u001b[?2004h"]
[384.488935, "o", "> "]
[384.489102, "o", "        // For misses, `fresh` means the miss is correct.\r\n\u001b[?2004l\r"]
[384.489143, "o", "\u001b[?2004h> "]
[384.489296, "o", "        Observation::missing(b, b, a.epoch, !c)\r\n\u001b[?2004l\r"]
