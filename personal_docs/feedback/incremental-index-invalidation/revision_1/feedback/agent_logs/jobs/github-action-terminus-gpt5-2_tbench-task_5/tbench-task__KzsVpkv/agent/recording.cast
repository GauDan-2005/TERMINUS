[839.603492, "i", "python3 - <<'PY'\nimport json\nobj=json.load(open('/app/output/index-report.json'))\n# spot-check that \"after\" locations are the new ones for the key cases\nchecks = {\n  ('alpha','alpha_after'): 'fixtures/alpha/ws-new',\n  ('beta','beta_after'): 'fixtures/beta/gen-v2',\n  ('gamma','gamma_after'): 'fixtures/gamma/pkg-b',\n  ('delta','delta_widget_after_app'): 'fixtures/delta/app-new',\n  ('delta','delta_client_after_gen'): 'fixtures/delta/gen-v2',\n  ('zeta','zeta_widget_after_app'): 'fixtures/zeta/app-new',\n  ('zeta','zeta_bridge_after_pkg'): 'fixtures/zeta/pkg-b',\n}\nbyname={c['name']:c for c in obj['cases']}\nfor (case,label),want in checks.items():\n    obs=[o for o in byname[case]['observations'] if o['label']==label][0]\n    if want not in obs['path']:\n        raise SystemExit((case,label,'expected',want,'got',obs['path']))\nprint('AFTER_LOCATIONS_OK')\nPY\n"]
