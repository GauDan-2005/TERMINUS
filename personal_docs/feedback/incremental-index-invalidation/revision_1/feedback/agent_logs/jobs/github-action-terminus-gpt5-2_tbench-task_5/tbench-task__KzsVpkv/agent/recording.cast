[169.102617, "i", "sed -n '1,520p' /app/r6/g.rs\n"]
[169.103248, "o", "sed -n '1,520p' /app/r6/g.rs\r\n\u001b[?2004l\r"]
[169.105593, "o", "use std::collections::BTreeMap;\r\n"]
[169.106036, "o", "\r\npub fn phase_g(rows: &[(&str, usize)]) -> BTreeMap<String, usize> {\r\n    let mut out = BTreeMap::new();\r\n    for (key, value) in rows {\r\n        *out.entry((*key).to_string()).or_insert(0) += *value;\r\n    }\r\n    out\r\n}\r\n"]
[169.106215, "o", "\u001b[?2004hroot@0b5ffe3ded70:/app# "]
[169.214807, "i", "sed -n '1,520p' /app/r7/h.rs\n"]
