[168.387789, "o", "\u001b[?2004l\r"]
[168.389207, "o", "use crate::model::{CaseReport, Event, State};\r\nuse crate::r1_b::fold_b;\r\nuse crate::r2_c::emit_c;\r\nuse crate::r3_d::lift_d;\r\nuse crate::r4_e::mote_e;\r\nuse crate::r5_f::cast_f;\r\n\r\npub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {\r\n"]
[168.389308, "o", "    match b.kind.as_str() {\r\n        \"slot\" => {\r\n            if b.left == \"gen\" {\r\n                emit_c(a, &b.left, &b.right)?;\r\n            } else if b.left == \"pkg\" {\r\n                lift_d(a, &b.left, &b.right)?;\r\n            } else {\r\n                fold_b(a, &b.left, &b.right)?;\r\n            }\r\n        }\r\n        \"query\" => {\r\n            let item = mote_e(a, &b.right, true);\r\n            let (item, note) = cast_f(a, item, true);\r\n            c.observations.push(crate::model::Observation { label: b.left.clone(), ..item });\r\n            if let Some(note) = note {\r\n                c.stale.push(note);\r\n            }\r\n        }\r\n        \"miss\" => {\r\n            let item = mote_e(a, &b.right, false);\r\n            let (item, note) = cast_f(a, item, false);\r\n            c.observations.push(crate::model::Observation { label: b.left.clone(), ..item });\r\n            if let Some(note) = note {\r\n"]
[168.389379, "o", "                c.stale.push(note);\r\n            }\r\n        }\r\n        other => return Err(format!(\"unknown trace row {other}\")),\r\n    }\r\n    Ok(())\r\n}\r\n"]
[168.38951, "o", "\u001b[?2004h"]
[168.389583, "o", "root@0b5ffe3ded70:/app# "]
[168.506989, "i", "sed -n '1,320p' /app/r1/b.rs\n"]
[168.507704, "o", "sed -n '1,320p' /app/r1/b.rs"]
[168.507946, "o", "\r\n\u001b[?2004l\r"]
[168.509426, "o", "use crate::io::{app_path, collect_entries};\r\nuse crate::model::State;\r\n\r\npub fn fold_b(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let root = app_path(c);\r\n    a.active.insert(b.to_string(), root);\r\n    let mut found = collect_entries(a, b, c, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n}\r\n"]
[168.509612, "o", "\u001b[?2004hroot@0b5ffe3ded70:/app# "]
[168.627336, "i", "sed -n '1,360p' /app/r2/c.rs\n"]
[168.627785, "o", "sed -n '1,360p' /app/r2/c.rs\r\n\u001b[?2004l\r"]
[168.629674, "o", "use crate::io::{app_path, collect_entries};\r\nuse crate::model::State;\r\n\r\npub fn emit_c(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let root = app_path(c);\r\n"]
[168.630257, "o", "    a.active.insert(b.to_string(), root);\r\n    let mut found = collect_entries(a, b, c, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n}\r\n"]
[168.630791, "o", "\u001b[?2004hroot@0b5ffe3ded70:/app# "]
[168.747167, "i", "sed -n '1,360p' /app/r3/d.rs\n"]
[168.747745, "o", "sed -n '1,360p' /app/r3/d.rs\r\n\u001b[?2004l\r"]
[168.748814, "o", "use crate::io::{app_path, collect_entries, resolve_target_root};\r\nuse crate::model::State;\r\n\r\npub fn lift_d(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let shown = app_path(c);\r\n    let actual = resolve_target_root(c)?;\r\n    a.active.insert(b.to_string(), shown);\r\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n}\r\n"]
[168.749006, "o", "\u001b[?2004hroot@0b5ffe3ded70:/app# "]
[168.866579, "i", "sed -n '1,420p' /app/r4/e.rs\n"]
[168.867912, "o", "sed -n '1,420p' /app/r4/e.rs\r\n\u001b[?2004l\r"]
[168.869049, "o", "use crate::model::{Observation, State};\r\n"]
[168.869205, "o", "\r\npub fn mote_e(a: &mut State, b: &str, c: bool) -> Observation {\r\n    if let Some(entry) = a.entries.iter().find(|entry| entry.symbol == b) {\r\n        let reused = a.last_seen.get(b).map(|old| *old == entry.handle).unwrap_or(false);\r\n        a.last_seen.insert(b.to_string(), entry.handle);\r\n        let fresh = a\r\n            .active\r\n            .get(&entry.slot)\r\n            .map(|root| entry.path.starts_with(root))\r\n            .unwrap_or(false);\r\n"]
[168.869268, "o", "        Observation {\r\n            label: String::new(),\r\n            symbol: b.to_string(),\r\n            found: true,\r\n            path: entry.path.clone(),\r\n"]
[168.869426, "o", "            source: entry.source.clone(),\r\n"]
[168.869504, "o", "            line: entry.line,\r\n"]
[168.869569, "o", "            epoch: entry.epoch,\r\n"]
[168.869676, "o", "            reused,\r\n            fresh,\r\n        }\r\n    } else {\r\n        Observation::missing(b, b, a.epoch, !c)\r\n    }\r\n}\r\n"]
[168.870038, "o", "\u001b[?2004hroot@0b5ffe3ded70:/app# "]
[168.98307, "i", "sed -n '1,520p' /app/r5/f.rs\n"]
[168.983316, "o", "sed -n '1,520p' /app/r5/f.rs\r\n\u001b[?2004l\r"]
[168.984603, "o", "use crate::model::{Observation, State};\r\n\r\npub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\r\n    if c {\r\n        if b.found && b.fresh {\r\n            (b, None)\r\n        } else {\r\n            let label = b.label.clone();\r\n            (b, Some(label))\r\n        }\r\n    } else if b.found && b.path.starts_with(\"/app/\") {\r\n"]
[168.984736, "o", "        (b, None)\r\n    } else {\r\n        (b, None)\r\n    }\r\n}\r\n"]
[168.984912, "o", "\u001b[?2004h"]
