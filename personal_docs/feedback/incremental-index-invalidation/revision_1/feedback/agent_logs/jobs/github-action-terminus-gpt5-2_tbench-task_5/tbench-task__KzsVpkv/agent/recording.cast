[184.263431, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: r1/b.rs\n@@\n pub fn fold_b(a: &mut State, b: &str, c: &str) -> Result<(), String> {\n     a.epoch += 1;\n     let root = app_path(c);\n     a.active.insert(b.to_string(), root);\n+    // Slot updates replace the visible world for that slot.\n+    // Keeping old entries causes queries to report deleted/previous locations.\n+    a.entries.retain(|e| e.slot != b);\n     let mut found = collect_entries(a, b, c, a.epoch)?;\n     a.entries.append(&mut found);\n     Ok(())\n }\n*** End Patch\nPATCH\n"]
