[384.488605, "o", "            reused,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[384.488683, "o", "            fresh: true,\r\n\u001b[?2004l\r"]
[384.488709, "o", "\u001b[?2004h> "]
[384.488785, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
