[169.335613, "o", "sed -n '1,520p' /app/r8/i.rs\r\n\u001b[?2004l\r"]
[169.336577, "o", "pub fn turn_i(values: &[String]) -> Vec<String> {\r\n"]
[169.336847, "o", "    let mut out = values.to_vec();\r\n    out.sort();\r\n    out.dedup();\r\n    out\r\n}\r\n"]
[169.336957, "o", "\u001b[?2004h"]
