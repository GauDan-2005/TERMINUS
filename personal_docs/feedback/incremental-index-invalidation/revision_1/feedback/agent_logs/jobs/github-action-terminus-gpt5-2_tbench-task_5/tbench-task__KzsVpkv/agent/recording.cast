[169.215142, "o", "\u001b[?2004l\r"]
[169.216631, "o", "use std::path::{Path, PathBuf};\r\n\r\npub fn lift_h(base: &Path, value: &str) -> PathBuf {\r\n    let candidate = PathBuf::from(value);\r\n    if candidate.is_absolute() {\r\n        candidate\r\n    } else {\r\n"]
[169.21673, "o", "        base.join(candidate)\r\n    }\r\n}\r\n"]
[169.21677, "o", "\u001b[?2004h"]
[169.216798, "o", "root@0b5ffe3ded70:/app# "]
