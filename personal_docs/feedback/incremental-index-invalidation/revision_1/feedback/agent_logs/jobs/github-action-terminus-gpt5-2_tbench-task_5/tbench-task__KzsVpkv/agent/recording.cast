[643.162864, "i", "cat > /app/r3/d.rs <<'EOF'\nuse crate::io::{app_path, collect_entries, resolve_target_root};\nuse crate::model::State;\n\npub fn lift_d(a: &mut State, b: &str, c: &str) -> Result<(), String> {\n    a.epoch += 1;\n    let actual = resolve_target_root(c)?;\n\n    // For linked packages we want lookups/freshness to follow the active target.\n    // The trace supplies an alias path, but that alias points at an actual pkg.\n    a.active.insert(b.to_string(), app_path(&actual));\n\n    // Linked package retargeting should not leave old package entries around.\n    a.entries.retain(|e| e.slot != b);\n\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\n    a.entries.append(&mut found);\n    Ok(())\n}\nEOF\n"]
[643.166477, "o", "cat > /app/r3/d.rs <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> use crate::io::{app_path, collect_entries, resolve_target_root};\r\n\u001b[?2004l\r\u001b[?2004h> use crate::model::State;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> pub fn lift_d(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n\u001b[?2004l\r\u001b[?2004h>     a.epoch += 1;\r\n\u001b[?2004l\r\u001b[?2004h>     let actual = resolve_target_root(c)?;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     // For linked packages we want lookups/freshness to follow the active target.\r\n\u001b[?2004l\r\u001b[?2004h>     // The trace supplies an alias path, but that alias points at an actual pkg.\r\n\u001b[?2004l\r\u001b[?2004h>     a.active.insert(b.to_string(), app_path(&actual));\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     // Linked package retargeting should not leave old package entries around.\r\n\u001b[?2004l\r\u001b[?2004h>     a.entries.retain(|e| e.slot != b);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     let mut found = collect_entries(a, b, &actual, a.epoch)?;\r\n\u001b[?2004l\r\u001b[?2004h>     a.entries.append(&mut found);\r\n\u001b[?2004l\r\u001b[?2004h> "]
