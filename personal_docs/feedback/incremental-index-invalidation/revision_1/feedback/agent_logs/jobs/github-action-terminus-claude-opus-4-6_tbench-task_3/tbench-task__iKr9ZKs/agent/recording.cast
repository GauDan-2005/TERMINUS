[282.854461, "i", "cat > /app/r5/f.rs << 'EOF'\nuse crate::model::{Observation, State};\n\npub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\n    if c {\n        // query: must be found and fresh\n        if b.found && b.fresh {\n            (b, None)\n        } else {\n            let label = b.label.clone();\n            (b, Some(label))\n        }\n    } else {\n        // miss: symbol should NOT be found\n        if b.found {\n            let label = b.label.clone();\n            (b, Some(label))\n        } else {\n            (b, None)\n        }\n    }\n}\nEOF\n"]
[282.857357, "o", "cat > /app/r5/f.rs << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> use crate::model::{Observation, State};\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> pub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\r\n\u001b[?2004l\r\u001b[?2004h>     if c {\r\n\u001b[?2004l\r\u001b[?2004h>         // query: must be found and fresh\r\n\u001b[?2004l\r\u001b[?2004h>         if b.found && b.fresh {\r\n\u001b[?2004l\r\u001b[?2004h>             (b, None)\r\n\u001b[?2004l\r\u001b[?2004h>         } else {\r\n\u001b[?2004l\r\u001b[?2004h>             let label = b.label.clone();\r\n\u001b[?2004l\r\u001b[?2004h>             (b, Some(label))\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     } else {\r\n\u001b[?2004l\r\u001b[?2004h>         // miss: symbol should NOT be found\r\n\u001b[?2004l\r\u001b[?2004h>         if b.found {\r\n\u001b[?2004l\r\u001b[?2004h>             let label = b.label.clone();\r\n\u001b[?2004l\r\u001b[?2004h>             (b, Some(label))\r\n\u001b[?2004l\r\u001b[?2004h>         } else {\r\n\u001b[?2004l\r\u001b[?2004h>             (b, None)\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
