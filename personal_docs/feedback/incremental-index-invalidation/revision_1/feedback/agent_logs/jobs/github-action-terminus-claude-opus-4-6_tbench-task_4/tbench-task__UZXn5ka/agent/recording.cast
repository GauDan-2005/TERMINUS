[336.428227, "i", "cat > /app/r5/f.rs << 'EOF'\nuse crate::model::{Observation, State};\n\npub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\n    if c {\n        if b.found && b.fresh {\n            (b, None)\n        } else {\n            let label = b.label.clone();\n            (b, Some(label))\n        }\n    } else {\n        if b.found {\n            let label = b.label.clone();\n            (b, Some(label))\n        } else {\n            (b, None)\n        }\n    }\n}\nEOF\n"]
