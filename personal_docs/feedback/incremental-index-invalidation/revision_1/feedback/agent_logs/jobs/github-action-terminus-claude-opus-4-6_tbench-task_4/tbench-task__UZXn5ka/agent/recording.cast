[336.056495, "o", "pub fn emit_c(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n\u001b[?2004l\r\u001b[?2004h>     a.epoch += 1;\r\n\u001b[?2004l\r\u001b[?2004h>     let root = app_path(c);\r\n\u001b[?2004l\r\u001b[?2004h>     a.active.insert(b.to_string(), root);\r\n\u001b[?2004l\r\u001b[?2004h>     a.entries.retain(|e| e.slot != b);\r\n\u001b[?2004l\r\u001b[?2004h>     let mut found = collect_entries(a, b, c, a.epoch)?;\r\n\u001b[?2004l\r\u001b[?2004h>     a.entries.append(&mut found);\r\n\u001b[?2004l\r\u001b[?2004h>     Ok(())\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
