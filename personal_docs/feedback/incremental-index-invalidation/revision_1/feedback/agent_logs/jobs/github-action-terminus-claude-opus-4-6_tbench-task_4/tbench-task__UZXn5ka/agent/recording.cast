[23.424632, "i", "cat /app/r3/d.rs\n"]
[23.42517, "o", "cat /app/r3/d.rs\r\n\u001b[?2004l\r"]
[23.426078, "o", "use crate::io::{app_path, collect_entries, resolve_target_root};\r\nuse crate::model::State;\r\n\r\npub fn lift_d(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let shown = app_path(c);\r\n    let actual = resolve_target_root(c)?;\r\n    a.active.insert(b.to_string(), shown);\r\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n}\r\n"]
[23.426497, "o", "\u001b[?2004hroot@d97cb216d7f2:/app# "]
[29.182955, "i", "cat /app/r4/e.rs\n"]
[29.183721, "o", "cat /app/r4/e.rs\r\n\u001b[?2004l\r"]
[29.185167, "o", "use crate::model::{Observation, State};\r\n\r\npub fn mote_e(a: &mut State, b: &str, c: bool) -> Observation {\r\n    if let Some(entry) = a.entries.iter().find(|entry| entry.symbol == b) {\r\n        let reused = a.last_seen.get(b).map(|old| *old == entry.handle).unwrap_or(false);\r\n        a.last_seen.insert(b.to_string(), entry.handle);\r\n        let fresh = a\r\n            .active\r\n            .get(&entry.slot)\r\n            .map(|root| entry.path.starts_with(root))\r\n            .unwrap_or(false);\r\n        Observation {\r\n            label: String::new(),\r\n            symbol: b.to_string(),\r\n            found: true,\r\n            path: entry.path.clone(),\r\n            source: entry.source.clone(),\r\n            line: entry.line,\r\n            epoch: entry.epoch,\r\n            reused,\r\n            fresh,\r\n        }\r\n    } else {\r\n        Observation::missing(b, b, a.epoch, !c)\r\n    }\r\n}\r\n"]
[29.185374, "o", "\u001b[?2004hroot@d97cb216d7f2:/app# "]
[29.29945, "i", "cat /app/r5/f.rs\n"]
[29.300105, "o", "cat /app/r5/f.rs\r\n\u001b[?2004l\r"]
[29.300826, "o", "use crate::model::{Observation, State};\r\n\r\npub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\r\n    if c {\r\n        if b.found && b.fresh {\r\n            (b, None)\r\n        } else {\r\n            let label = b.label.clone();\r\n            (b, Some(label))\r\n        }\r\n    } else if b.found && b.path.starts_with(\"/app/\") {\r\n        (b, None)\r\n    } else {\r\n        (b, None)\r\n    }\r\n}\r\n"]
[29.301113, "o", "\u001b[?2004hroot@d97cb216d7f2:/app# "]
[29.421158, "i", "cat /app/r6/g.rs\n"]
[29.421539, "o", "cat /app/r6/g.rs\r\n\u001b[?2004l\r"]
[29.422687, "o", "use std::collections::BTreeMap;\r\n\r\npub fn phase_g(rows: &[(&str, usize)]) -> BTreeMap<String, usize> {\r\n    let mut out = BTreeMap::new();\r\n    for (key, value) in rows {\r\n        *out.entry((*key).to_string()).or_insert(0) += *value;\r\n    }\r\n    out\r\n}\r\n"]
[29.423365, "o", "\u001b[?2004hroot@d97cb216d7f2:/app# "]
[29.54784, "i", "cat /app/r7/h.rs\n"]
[29.548485, "o", "cat /app/r7/h.rs\r\n\u001b[?2004l\r"]
[29.549184, "o", "use std::path::{Path, PathBuf};\r\n\r\npub fn lift_h(base: &Path, value: &str) -> PathBuf {\r\n    let candidate = PathBuf::from(value);\r\n    if candidate.is_absolute() {\r\n        candidate\r\n    } else {\r\n        base.join(candidate)\r\n    }\r\n}\r\n"]
[29.549401, "o", "\u001b[?2004hroot@d97cb216d7f2:/app# "]
[29.663775, "i", "cat /app/r8/i.rs\n"]
[29.664044, "o", "cat /app/r8/i.rs\r\n\u001b[?2004l\r"]
[29.664982, "o", "pub fn turn_i(values: &[String]) -> Vec<String> {\r\n    let mut out = values.to_vec();\r\n    out.sort();\r\n    out.dedup();\r\n    out\r\n}\r\n"]
[29.665216, "o", "\u001b[?2004hroot@d97cb216d7f2:/app# "]
