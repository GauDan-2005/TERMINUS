Sending keys: ["cat > /app/r4/e.rs <<'EOF'\nuse crate::model::{Entry, Observation, State};\n\npub fn mote_e(a: &mut State, symbol: &str, expect_found: bool) -> Observation {\n    let mut candidates: Vec<&Entry> = a\n        .entries\n        .iter()\n        .filter(|entry| entry.symbol == symbol)\n        .collect();\n\n    if candidates.is_empty() {\n        return Observation::missing(symbol, symbol, a.epoch, !expect_found);\n    }\n\n    let in_active = |e: &&Entry| {\n        a.active\n            .get(&e.slot)\n            .is_some_and(|root| e.path.starts_with(root))\n    };\n\n    // Newest epoch first, then stable by path+line.\n    let sort_best = |items: &mut Vec<&Entry>| {\n        items.sort_by(|l, r| {\n            r.epoch\n                .cmp(&l.epoch)\n                .then_with(|| l.path.cmp(&r.path))\n                .then_with(|| l.line.cmp(&r.line))\n        });\n    };\n\n    let mut active_candidates: Vec<&Entry> = candidates.iter().copied().filter(in_active).collect();\n\n    // For misses, only report a hit if it's visible from active roots.\n    if !expect_found {\n        if active_candidates.is_empty() {\n            return Observation::missing(symbol, symbol, a.epoch, true);\n        }\n        sort_best(&mut active_candidates);\n        return entry_observation(a, symbol, active_candidates[0]);\n    }\n\n    let entry = if !active_candidates.is_empty() {\n        sort_best(&mut active_candidates);\n        active_candidates[0]\n    } else {\n        sort_best(&mut candidates);\n        candidates[0]\n    };\n\n    entry_observation(a, symbol, entry)\n}\n\nfn entry_observation(a: &mut State, symbol: &str, entry: &Entry) -> Observation {\n    let reused = a\n        .last_seen\n        .get(symbol)\n        .map(|old| *old == entry.handle)\n        .unwrap_or(false);\n    a.last_seen.insert(symbol.to_string(), entry.handle);\n\n    let fresh = a\n        .active\n        .get(&entry.slot)\n        .map(|root| entry.path.starts_with(root))\n        .unwrap_or(false);\n\n    Observation {\n        label: String::new(),\n        symbol: symbol.to_string(),\n        found: true,\n        path: entry.path.clone(),\n        source: entry.source.clone(),\n        line: entry.line,\n        epoch: a.epoch,\n        reused,\n        fresh,\n    }\n}\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
