[229.391842, "i", "cat > /app/r4/e.rs <<'EOF'\nuse crate::model::{Entry, Observation, State};\n\n#[derive(Clone)]\nstruct Pick {\n    slot: String,\n    path: String,\n    source: String,\n    line: usize,\n    epoch: u64,\n    handle: u64,\n}\n\nfn better(a: &Pick, b: &Pick) -> bool {\n    // Prefer newer epoch; tie-break deterministically.\n    (a.epoch, &a.path, a.line) > (b.epoch, &b.path, b.line)\n}\n\npub fn mote_e(a: &mut State, symbol: &str, expect_found: bool) -> Observation {\n    let mut best_active: Option<Pick> = None;\n    let mut best_any: Option<Pick> = None;\n\n    for entry in &a.entries {\n        if entry.symbol != symbol {\n            continue;\n        }\n\n        let pick = Pick {\n            slot: entry.slot.clone(),\n            path: entry.path.clone(),\n            source: entry.source.clone(),\n            line: entry.line,\n            epoch: entry.epoch,\n            handle: entry.handle,\n        };\n\n        if best_any.as_ref().is_none_or(|old| better(&pick, old)) {\n            best_any = Some(pick.clone());\n        }\n\n        let is_active = a\n            .active\n            .get(&entry.slot)\n            .is_some_and(|root| entry.path.starts_with(root));\n        if is_active {\n            if best_active.as_ref().is_none_or(|old| better(&pick, old)) {\n                best_active = Some(pick);\n            }\n        }\n    }\n\n    // For misses, only report a hit if it's visible from active roots.\n    let chosen = if expect_found {\n        best_active.or(best_any)\n    } else {\n        best_active\n    };\n\n    let Some(chosen) = chosen else {\n        return Observation::missing(symbol, symbol, a.epoch, !expect_found || true);\n    };\n\n    let reused = a\n        .last_seen\n        .get(symbol)\n        .map(|old| *old == chosen.handle)\n        .unwrap_or(false);\n    a.last_seen.insert(symbol.to_string(), chosen.handle);\n\n    let fresh = a\n        .active\n        .get(&chosen.slot)\n        .map(|root| chosen.path.starts_with(root))\n        .unwrap_or(false);\n\n    Observation {\n        label: String::new(),\n        symbol: symbol.to_string(),\n        found: true,\n        path: chosen.path,\n        source: chosen.source,\n        line: chosen.line,\n        epoch: a.epoch,\n        reused,\n        fresh,\n    }\n}\nEOF\n"]
