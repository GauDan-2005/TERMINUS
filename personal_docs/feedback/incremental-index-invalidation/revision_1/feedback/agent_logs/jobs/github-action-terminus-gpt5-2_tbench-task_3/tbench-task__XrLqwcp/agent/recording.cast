[32.451645, "o", "grep -RIn --line-number \"ws-old\\|gen-v1\\|pkg-a\\|index-report\\.json\\|canned\\|fixture\\|golden\" /app/src /app/r0 /app/r1 /app/r2 /app/r3 /app/r4 /app/r5 /app/r6 /app/r7 /app/r8\r\n\u001b[?2004l\r"]
