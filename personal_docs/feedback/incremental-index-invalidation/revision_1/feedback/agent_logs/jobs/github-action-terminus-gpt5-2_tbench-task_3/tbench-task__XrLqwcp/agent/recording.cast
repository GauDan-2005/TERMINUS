[41.670874, "o", "slot app fixtures/zeta/app-old\r\nslot pkg fixtures/zeta/alias-a\r\nquery zeta_bridge_before Bridge\r\nquery zeta_widget_before Widget\r\n"]
[41.670944, "o", "slot pkg fixtures/zeta/alias-b\r\nquery zeta_bridge_after_pkg Bridge\r\nquery zeta_widget_after_pkg Widget\r\nslot app fixtures/zeta/app-new\r\nquery zeta_widget_after_app Widget\r\nquery zeta_bridge_after_app Bridge\r\n"]
[41.67111, "o", "\u001b[?2004h"]
[41.671223, "o", "root@01f99625b95f:/app# "]
[49.50197, "i", "sed -n '1,260p' /app/r3/d.rs\n"]
[49.502276, "o", "sed -n '1,260p' /app/r3/d.rs\r\n"]
[49.502383, "o", "\u001b[?2004l\r"]
[49.503423, "o", "use crate::io::{app_path, collect_entries, resolve_target_root};\r\nuse crate::model::State;\r\n\r\npub fn lift_d(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let shown = app_path(c);\r\n    let actual = resolve_target_root(c)?;\r\n    a.active.insert(b.to_string(), shown);\r\n"]
[49.503716, "o", "    let mut found = collect_entries(a, b, &actual, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n}\r\n"]
[49.503762, "o", "\u001b[?2004hroot@01f99625b95f:/app# "]
[49.61424, "i", "sed -n '1,320p' /app/r4/e.rs\n"]
[49.614659, "o", "sed -n '1,320p' /app/r4/e.rs"]
[49.614882, "o", "\r\n\u001b[?2004l\r"]
[49.6166, "o", "use crate::model::{Observation, State};\r\n"]
[49.616802, "o", "\r\npub fn mote_e(a: &mut State, b: &str, c: bool) -> Observation {\r\n    if let Some(entry) = a.entries.iter().find(|entry| entry.symbol == b) {\r\n        let reused = a.last_seen.get(b).map(|old| *old == entry.handle).unwrap_or(false);\r\n        a.last_seen.insert(b.to_string(), entry.handle);\r\n        let fresh = a\r\n            .active\r\n            .get(&entry.slot)\r\n            .map(|root| entry.path.starts_with(root))\r\n            .unwrap_or(false);\r\n"]
[49.616951, "o", "        Observation {\r\n            label: String::new(),\r\n            symbol: b.to_string(),\r\n            found: true,\r\n            path: entry.path.clone(),\r\n"]
[49.617169, "o", "            source: entry.source.clone(),\r\n            line: entry.line,\r\n            epoch: entry.epoch,\r\n            reused,\r\n            fresh,\r\n        }\r\n    } else {\r\n        Observation::missing(b, b, a.epoch, !c)\r\n    }\r\n}\r\n"]
[49.617403, "o", "\u001b[?2004hroot@01f99625b95f:/app# "]
[49.726315, "i", "sed -n '1,360p' /app/r5/f.rs\n"]
[49.726935, "o", "sed -n '1,360p' /app/r5/f.rs\r\n\u001b[?2004l\r"]
[49.729597, "o", "use crate::model::{Observation, State};\r\n\r\npub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\r\n    if c {\r\n        if b.found && b.fresh {\r\n            (b, None)\r\n        } else {\r\n            let label = b.label.clone();\r\n            (b, Some(label))\r\n        }\r\n    } else if b.found && b.path.starts_with(\"/app/\") {\r\n        (b, None)\r\n    } else {\r\n        (b, None)\r\n    }\r\n}\r\n\u001b[?2004hroot@01f99625b95f:/app# "]
[49.842319, "i", "sed -n '1,360p' /app/r6/g.rs\n"]
[49.842579, "o", "sed -n '1,360p' /app/r6/g.rs"]
[49.842687, "o", "\r\n\u001b[?2004l\r"]
[49.844389, "o", "use std::collections::BTreeMap;\r\n\r\npub fn phase_g(rows: &[(&str, usize)]) -> BTreeMap<String, usize> {\r\n    let mut out = BTreeMap::new();\r\n    for (key, value) in rows {\r\n        *out.entry((*key).to_string()).or_insert(0) += *value;\r\n    }\r\n    out\r\n}\r\n"]
[49.844612, "o", "\u001b[?2004hroot@01f99625b95f:/app# "]
[49.962537, "i", "sed -n '1,360p' /app/r7/h.rs\n"]
