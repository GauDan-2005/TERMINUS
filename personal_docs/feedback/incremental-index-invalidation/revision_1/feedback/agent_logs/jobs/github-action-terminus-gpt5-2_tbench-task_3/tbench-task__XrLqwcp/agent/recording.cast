[49.96327, "o", "\r\n\u001b[?2004l\r"]
[49.964599, "o", "use std::path::{Path, PathBuf};\r\n\r\npub fn lift_h(base: &Path, value: &str) -> PathBuf {\r\n    let candidate = PathBuf::from(value);\r\n    if candidate.is_absolute() {\r\n        candidate\r\n    } else {\r\n        base.join(candidate)\r\n    }\r\n}\r\n"]
[49.964803, "o", "\u001b[?2004hroot@01f99625b95f:/app# "]
[50.078425, "i", "sed -n '1,360p' /app/r8/i.rs\n"]
