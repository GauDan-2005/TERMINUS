[195.046487, "i", "cat > /app/r3/d.rs <<'EOF'\nuse crate::io::{collect_entries, resolve_target_root};\nuse crate::model::State;\n\npub fn lift_d(a: &mut State, slot: &str, root: &str) -> Result<(), String> {\n    a.epoch += 1;\n\n    // For linked packages, the active root should follow the resolved target, since\n    // entries are indexed from that location.\n    let actual = resolve_target_root(root)?;\n    a.active.insert(slot.to_string(), actual.clone());\n\n    let mut found = collect_entries(a, slot, &actual, a.epoch)?;\n    a.entries.append(&mut found);\n    Ok(())\n}\nEOF\n"]
[195.046833, "o", "cat > /app/r3/d.rs <<'EOF'\r\n\u001b[?2004l\r"]
