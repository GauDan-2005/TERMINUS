[41.085938, "i", "sed -n '1,260p' /app/src/io.rs\n"]
[41.08668, "o", "sed -n '1,260p' /app/src/io.rs\r\n"]
[41.087036, "o", "\u001b[?2004l\r"]
[41.089096, "o", "use crate::model::{Entry, Event, State};\r\nuse std::fs;\r\nuse std::path::{Path, PathBuf};\r\n\r\npub fn read_trace(path: &Path) -> Result<Vec<Event>, String> {\r\n    let text = fs::read_to_string(path).map_err(|e| format!(\"read {}: {e}\", path.display()))?;\r\n    let mut events = Vec::new();\r\n    for raw in text.lines() {\r\n        let line = raw.trim();\r\n"]
[41.089137, "o", "        if line.is_empty() || line.starts_with('#') {\r\n            continue;\r\n        }\r\n        let parts: Vec<&str> = line.split_whitespace().collect();\r\n        if parts.len() != 3 {\r\n            return Err(format!(\"trace {} has malformed row: {line}\", path.display()));\r\n        }\r\n        events.push(Event {\r\n            kind: parts[0].to_string(),\r\n            left: parts[1].to_string(),\r\n            right: parts[2].to_string(),\r\n        });\r\n    }\r\n    Ok(events)\r\n}\r\n\r\n"]
[41.089159, "o", "pub fn app_path(value: &str) -> String {\r\n    if value.starts_with(\"/app/\") {\r\n        value.to_string()\r\n    } else if value == \"/app\" {\r\n        value.to_string()\r\n    } else {\r\n        format!(\"/app/{}\", value.trim_start_matches('/'))\r\n    }\r\n}"]
[41.089177, "o", "\r\n\r\npub fn disk_path(value: &str) -> PathBuf {\r\n    if let Some(rest) = value.strip_prefix(\"/app/\") {\r\n        PathBuf::from(\"/app\").join(rest)\r\n    } else if value == \"/app\" {\r\n"]
[41.089195, "o", "        PathBuf::from(\"/app\")\r\n    } else {\r\n        PathBuf::from(\"/app\").join(value)\r\n    }\r\n}\r\n"]
[41.089442, "o", "\r\npub fn resolve_target_root(value: &str) -> Result<String, String> {\r\n    let base = disk_path(value);\r\n    let marker = base.join(\"link.target\");\r\n    if !marker.exists() {\r\n"]
[41.089481, "o", "        return Ok(app_path(value));\r\n    }\r\n    let raw = fs::read_to_string(&marker).map_err(|e| format!(\"read {}: {e}\", marker.display()))?;\r\n    let trimmed = raw.trim();\r\n    let joined = base.join(trimmed);\r\n    let absolute = joined\r\n        .canonicalize()\r\n        .map_err(|e| format!(\"resolve {}: {e}\", joined.display()))?;\r\n    let text = absolute.to_string_lossy().to_string();\r\n    Ok(text)\r\n}\r\n\r\npub fn collect_entries(state: &mut State, slot: &str, root: &str, epoch: u64) -> Result<Vec<Entry>, String> {\r\n    let root_path = disk_path(root);\r\n    let mut files = Vec::new();\r\n    gather_ts(&root_path, &mut files)?;\r\n    files.sort();\r\n    let mut out = Vec::new();\r\n    for file in files {\r\n        let app_file = file_to_app(&file)?;\r\n        let source = source_for(&file)?;\r\n        let text = fs::read_to_string(&file).map_err(|e| format!(\"read {}: {e}\", file.display()))?;\r\n        for (line, symbol) in exported_symbols(&text) {\r\n            let handle = state.handle_for(slot, &app_file, &symbol);\r\n            out.push(Entry {\r\n                slot: slot.to_string(),\r\n                symbol,\r\n                path: app_file.clone(),\r\n                source: source.clone(),\r\n                line,\r\n                epoch,\r\n                handle,\r\n            });\r\n        }\r\n    }\r\n    Ok(out)\r\n}\r\n\r\nfn gather_ts(dir: &Path, out: &mut Vec<PathBuf>) -> Result<(), String> {\r\n    let entries = fs::read_dir(dir).map_err(|e| format!(\"scan {}: {e}\", dir.display()))?;\r\n    for item in entries {\r\n        let path = item.map_err(|e| format!(\"scan {}: {e}\", dir.display()))?.path();\r\n        if path.is_dir() {\r\n            gather_ts(&path, out)?;\r\n        } else if path.extension().and_then(|s| s.to_str()) == Some(\"ts\") {\r\n            out.push(path);\r\n        }\r\n    }\r\n    Ok(())\r\n}\r\n\r\nfn file_to_app(path: &Path) -> Result<String, String> {\r\n    let abs = path\r\n        .canonicalize()\r\n"]
[41.08958, "o", "        .map_err(|e| format!(\"resolve {}: {e}\", path.display()))?;\r\n    Ok(abs.to_string_lossy().to_string())\r\n}\r\n\r\nfn source_for(path: &Path) -> Result<String, String> {\r\n    let text = fs::read_to_string(path).map_err(|e| format!(\"read {}: {e}\", path.display()))?;\r\n    for raw in text.lines().take(4) {\r\n        let line = raw.trim();\r\n        if let Some(rest) = line.strip_prefix(\"// origin:\") {\r\n            return Ok(app_path(rest.trim()));\r\n        }\r\n    }\r\n    file_to_app(path)\r\n}\r\n\r\nfn exported_symbols(text: &str) -> Vec<(usize, String)> {\r\n    let mut out = Vec::new();\r\n    for (idx, raw) in text.lines().enumerate() {\r\n        let line = raw.trim_start();\r\n        for prefix in [\"export const \", \"export function \"] {\r\n            if let Some(rest) = line.strip_prefix(prefix) {\r\n                let symbol: String = rest\r\n                    .chars()\r\n                    .take_while(|c| c.is_ascii_alphanumeric() || *c == '_')\r\n                    .collect();\r\n                if !symbol.is_empty() {\r\n                    out.push((idx + 1, symbol));\r\n                }\r\n            }\r\n        }\r\n    }\r\n    out\r\n}\r\n"]
[41.089757, "o", "\u001b[?2004hroot@01f99625b95f:/app# "]
[41.197981, "i", "sed -n '260,520p' /app/src/io.rs\n"]
[41.199302, "o", "sed -n '260,520p' /app/src/io.rs"]
[41.199351, "o", "\r\n\u001b[?2004l\r"]
[41.201429, "o", "\u001b[?2004h"]
[41.201543, "o", "root@01f99625b95f:/app# "]
[41.306291, "i", "sed -n '1,320p' /app/r0/a.rs\n"]
[41.306595, "o", "sed -n '1,320p' /app/r0/a.rs"]
[41.306918, "o", "\r\n\u001b[?2004l\r"]
[41.308363, "o", "use crate::model::{CaseReport, Event, State};\r\nuse crate::r1_b::fold_b;\r\nuse crate::r2_c::emit_c;\r\nuse crate::r3_d::lift_d;\r\nuse crate::r4_e::mote_e;\r\nuse crate::r5_f::cast_f;\r\n\r\npub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {\r\n"]
[41.308402, "o", "    match b.kind.as_str() {\r\n        \"slot\" => {\r\n            if b.left == \"gen\" {\r\n                emit_c(a, &b.left, &b.right)?;\r\n            } else if b.left == \"pkg\" {\r\n"]
[41.308575, "o", "                lift_d(a, &b.left, &b.right)?;\r\n"]
[41.308744, "o", "            } else {\r\n"]
[41.308815, "o", "                fold_b(a, &b.left, &b.right)?;\r\n            }\r\n        }\r\n        \"query\" => {\r\n            let item = mote_e(a, &b.right, true);\r\n            let (item, note) = cast_f(a, item, true);\r\n            c.observations.push(crate::model::Observation { label: b.left.clone(), ..item });\r\n            if let Some(note) = note {\r\n                c.stale.push(note);\r\n            }\r\n        }\r\n        \"miss\" => {\r\n            let item = mote_e(a, &b.right, false);\r\n            let (item, note) = cast_f(a, item, false);\r\n            c.observations.push(crate::model::Observation { label: b.left.clone(), ..item });\r\n            if let Some(note) = note {\r\n                c.stale.push(note);\r\n            }\r\n        }\r\n        other => return Err(format!(\"unknown trace row {other}\")),\r\n    }\r\n    Ok(())\r\n"]
[41.309006, "o", "}\r\n"]
[41.309176, "o", "\u001b[?2004hroot@01f99625b95f:/app# "]
[41.422112, "i", "sed -n '1,320p' /app/r1/b.rs\n"]
[41.422506, "o", "sed -n '1,320p' /app/r1/b.rs\r\n\u001b[?2004l\r"]
[41.424289, "o", "use crate::io::{app_path, collect_entries};\r\nuse crate::model::State;\r\n\r\npub fn fold_b(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let root = app_path(c);\r\n    a.active.insert(b.to_string(), root);\r\n    let mut found = collect_entries(a, b, c, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n"]
[41.424348, "o", "}\r\n"]
[41.424522, "o", "\u001b[?2004h"]
[41.424597, "o", "root@01f99625b95f:/app# "]
[41.542993, "i", "sed -n '1,320p' /app/r2/c.rs\n"]
[41.5433, "o", "sed -n '1,320p' /app/r2/c.rs\r\n"]
[41.54357, "o", "\u001b[?2004l\r"]
[41.544775, "o", "use crate::io::{app_path, collect_entries};\r\n"]
[41.545148, "o", "use crate::model::State;\r\n\r\npub fn emit_c(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let root = app_path(c);\r\n    a.active.insert(b.to_string(), root);\r\n    let mut found = collect_entries(a, b, c, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n}\r\n"]
[41.545195, "o", "\u001b[?2004hroot@01f99625b95f:/app# "]
[41.662577, "i", "for t in /app/traces/*.trace; do echo \"--- $t\"; sed -n '1,200p' \"$t\"; done\n"]
[41.663143, "o", "for t in /app/traces/*.trace; do echo \"--- $t\"; sed -n '1,200p' \"$t\"; done\r\n"]
[41.663491, "o", "\u001b[?2004l\r--- /app/traces/alpha.trace\r\n"]
[41.66466, "o", "slot app fixtures/alpha/ws-old\r\nquery alpha_before Widget\r\nslot app fixtures/alpha/ws-new\r\nquery alpha_after Widget\r\n"]
[41.664905, "o", "--- /app/traces/beta.trace\r\n"]
[41.666055, "o", "slot gen fixtures/beta/gen-v1\r\n"]
[41.666246, "o", "query beta_before Client\r\nslot gen fixtures/beta/gen-v2\r\nquery beta_after Client\r\n"]
[41.666406, "o", "--- /app/traces/delta.trace\r\n"]
[41.667485, "o", "slot app fixtures/delta/app-old\r\nslot gen fixtures/delta/gen-v1\r\nquery delta_client_before DeltaClient\r\nquery delta_widget_before DeltaWidget\r\nslot app fixtures/delta/app-new\r\nquery delta_client_after_app DeltaClient\r\nquery delta_widget_after_app DeltaWidget\r\nslot gen fixtures/delta/gen-v2\r\nquery delta_client_after_gen DeltaClient\r\n"]
[41.667572, "o", "query delta_widget_after_gen DeltaWidget\r\n"]
[41.667675, "o", "--- /app/traces/epsilon.trace\r\n"]
