[111.32682, "i", "cat > /app/r5/f.rs <<'EOF'\nuse crate::model::{Observation, State};\n\npub fn cast_f(\n    _a: &State,\n    label: &str,\n    obs: Observation,\n    expect_found: bool,\n) -> (Observation, Option<String>) {\n    if expect_found {\n        if obs.found && obs.fresh {\n            (obs, None)\n        } else {\n            (obs, Some(label.to_string()))\n        }\n    } else {\n        // For misses we only record staleness when the harness incorrectly reports a symbol.\n        if obs.found {\n            (obs, Some(label.to_string()))\n        } else {\n            (obs, None)\n        }\n    }\n}\nEOF\n"]
[111.327065, "o", "cat > /app/r5/f.rs <<'EOF'\r\n\u001b[?2004l\r"]
[111.327283, "o", "\u001b[?2004h> "]
