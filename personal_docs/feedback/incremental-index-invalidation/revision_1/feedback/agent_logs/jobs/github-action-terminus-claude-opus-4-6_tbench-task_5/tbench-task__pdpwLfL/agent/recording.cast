[19.995693, "o", "cat /app/traces/zeta.trace\r\n\u001b[?2004l\r"]
[19.996802, "o", "slot app fixtures/zeta/app-old\r\nslot pkg fixtures/zeta/alias-a\r\nquery zeta_bridge_before Bridge\r\nquery zeta_widget_before Widget\r\nslot pkg fixtures/zeta/alias-b\r\nquery zeta_bridge_after_pkg Bridge\r\nquery zeta_widget_after_pkg Widget\r\nslot app fixtures/zeta/app-new\r\nquery zeta_widget_after_app Widget\r\nquery zeta_bridge_after_app Bridge\r\n"]
[19.996945, "o", "\u001b[?2004hroot@a163f2145a00:/app# "]
[26.291494, "i", "cat /app/r0/a.rs\n"]
[26.291756, "o", "cat /app/r0/a.rs\r\n\u001b[?2004l\r"]
[26.292547, "o", "use crate::model::{CaseReport, Event, State};\r\nuse crate::r1_b::fold_b;\r\nuse crate::r2_c::emit_c;\r\nuse crate::r3_d::lift_d;\r\nuse crate::r4_e::mote_e;\r\nuse crate::r5_f::cast_f;\r\n\r\npub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {\r\n    match b.kind.as_str() {\r\n        \"slot\" => {\r\n            if b.left == \"gen\" {\r\n                emit_c(a, &b.left, &b.right)?;\r\n            } else if b.left == \"pkg\" {\r\n                lift_d(a, &b.left, &b.right)?;\r\n            } else {\r\n                fold_b(a, &b.left, &b.right)?;\r\n            }\r\n        }\r\n        \"query\" => {\r\n            let item = mote_e(a, &b.right, true);\r\n            let (item, note) = cast_f(a, item, true);\r\n            c.observations.push(crate::model::Observation { label: b.left.clone(), ..item });\r\n            if let Some(note) = note {\r\n                c.stale.push(note);\r\n            }\r\n        }\r\n        \"miss\" => {\r\n            let item = mote_e(a, &b.right, false);\r\n            let (item, note) = cast_f(a, item, false);\r\n            c.observations.push(crate::model::Observation { label: b.left.clone(), ..item });\r\n            if let Some(note) = note {\r\n                c.stale.push(note);\r\n            }\r\n        }\r\n        other => return Err(format!(\"unknown trace row {other}\")),\r\n    }\r\n    Ok(())\r\n}\r\n"]
[26.293056, "o", "\u001b[?2004h"]
[26.294564, "o", "root@a163f2145a00:/app# "]
[26.399611, "i", "cat /app/r1/b.rs\n"]
[26.400495, "o", "cat /app/r1/b.rs\r\n\u001b[?2004l\r"]
[26.402007, "o", "use crate::io::{app_path, collect_entries};\r\nuse crate::model::State;\r\n\r\npub fn fold_b(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let root = app_path(c);\r\n    a.active.insert(b.to_string(), root);\r\n    let mut found = collect_entries(a, b, c, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n}\r\n"]
[26.402197, "o", "\u001b[?2004hroot@a163f2145a00:/app# "]
[26.507625, "i", "cat /app/r2/c.rs\n"]
[26.50793, "o", "cat /app/r2/c.rs\r\n\u001b[?2004l\r"]
[26.509401, "o", "use crate::io::{app_path, collect_entries};\r\nuse crate::model::State;\r\n\r\npub fn emit_c(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let root = app_path(c);\r\n    a.active.insert(b.to_string(), root);\r\n    let mut found = collect_entries(a, b, c, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n}\r\n"]
[26.509483, "o", "\u001b[?2004hroot@a163f2145a00:/app# "]
[26.627417, "i", "cat /app/r3/d.rs\n"]
[26.627955, "o", "cat /app/r3/d.rs\r\n\u001b[?2004l\r"]
[26.628831, "o", "use crate::io::{app_path, collect_entries, resolve_target_root};\r\nuse crate::model::State;\r\n\r\npub fn lift_d(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n    a.epoch += 1;\r\n    let shown = app_path(c);\r\n    let actual = resolve_target_root(c)?;\r\n    a.active.insert(b.to_string(), shown);\r\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\r\n    a.entries.append(&mut found);\r\n    Ok(())\r\n}\r\n"]
[26.629236, "o", "\u001b[?2004h"]
[26.629267, "o", "root@a163f2145a00:/app# "]
[26.751271, "i", "cat /app/r4/e.rs\n"]
[26.751815, "o", "cat /app/r4/e.rs\r\n\u001b[?2004l\r"]
[26.752326, "o", "use crate::model::{Observation, State};\r\n\r\npub fn mote_e(a: &mut State, b: &str, c: bool) -> Observation {\r\n    if let Some(entry) = a.entries.iter().find(|entry| entry.symbol == b) {\r\n        let reused = a.last_seen.get(b).map(|old| *old == entry.handle).unwrap_or(false);\r\n        a.last_seen.insert(b.to_string(), entry.handle);\r\n        let fresh = a\r\n            .active\r\n            .get(&entry.slot)\r\n            .map(|root| entry.path.starts_with(root))\r\n            .unwrap_or(false);\r\n        Observation {\r\n            label: String::new(),\r\n            symbol: b.to_string(),\r\n            found: true,\r\n            path: entry.path.clone(),\r\n            source: entry.source.clone(),\r\n            line: entry.line,\r\n            epoch: entry.epoch,\r\n            reused,\r\n            fresh,\r\n        }\r\n    } else {\r\n        Observation::missing(b, b, a.epoch, !c)\r\n    }\r\n}\r\n"]
[26.752749, "o", "\u001b[?2004hroot@a163f2145a00:/app# "]
[26.871574, "i", "cat /app/r5/f.rs\n"]
[26.872263, "o", "cat /app/r5/f.rs\r\n\u001b[?2004l\r"]
[26.873076, "o", "use crate::model::{Observation, State};\r\n\r\npub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\r\n    if c {\r\n        if b.found && b.fresh {\r\n            (b, None)\r\n        } else {\r\n            let label = b.label.clone();\r\n            (b, Some(label))\r\n        }\r\n    } else if b.found && b.path.starts_with(\"/app/\") {\r\n        (b, None)\r\n    } else {\r\n        (b, None)\r\n    }\r\n}\r\n\u001b[?2004hroot@a163f2145a00:/app# "]
[26.9791, "i", "cat /app/r6/g.rs\n"]
[26.979692, "o", "cat /app/r6/g.rs\r\n\u001b[?2004l\r"]
[26.980646, "o", "use std::collections::BTreeMap;\r\n\r\npub fn phase_g(rows: &[(&str, usize)]) -> BTreeMap<String, usize> {\r\n    let mut out = BTreeMap::new();\r\n    for (key, value) in rows {\r\n        *out.entry((*key).to_string()).or_insert(0) += *value;\r\n    }\r\n    out\r\n}\r\n\u001b[?2004hroot@a163f2145a00:/app# "]
[27.095767, "i", "cat /app/r7/h.rs\n"]
[27.096043, "o", "cat /app/r7/h.rs\r\n\u001b[?2004l\r"]
[27.097008, "o", "use std::path::{Path, PathBuf};\r\n\r\npub fn lift_h(base: &Path, value: &str) -> PathBuf {\r\n    let candidate = PathBuf::from(value);\r\n    if candidate.is_absolute() {\r\n        candidate\r\n    } else {\r\n        base.join(candidate)\r\n    }\r\n}\r\n"]
[27.097301, "o", "\u001b[?2004hroot@a163f2145a00:/app# "]
[27.20398, "i", "cat /app/r8/i.rs\n"]
[27.204322, "o", "cat /app/r8/i.rs\r\n\u001b[?2004l\r"]
[27.205124, "o", "pub fn turn_i(values: &[String]) -> Vec<String> {\r\n    let mut out = values.to_vec();\r\n    out.sort();\r\n    out.dedup();\r\n    out\r\n}\r\n"]
[27.205273, "o", "\u001b[?2004hroot@a163f2145a00:/app# "]
