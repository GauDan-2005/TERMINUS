[9.012692, "o", "cat /app/Cargo.toml\r\n\u001b[?2004l\r"]
[9.014507, "o", "[package]\r\nname = \"incremental-index-invalidation\"\r\nversion = \"0.1.0\"\r\nedition = \"2021\"\r\n\r\n[lib]\r\nname = \"idxlab\"\r\npath = \"src/lib.rs\"\r\n\r\n[[bin]]\r\nname = \"idxlab\"\r\npath = \"src/main.rs\"\r\n\u001b[?2004hroot@d4a05a58442d:/app# "]
[14.026916, "i", "cat /app/src/main.rs\n"]
[14.02747, "o", "cat /app/src/main.rs\r\n\u001b[?2004l\r"]
[14.02903, "o", "use std::env;\r\nuse std::path::PathBuf;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().skip(1).collect();\r\n    if args.len() < 2 {\r\n        eprintln!(\"usage: idxlab <report> <trace> [trace ...]\");\r\n        std::process::exit(2);\r\n    }\r\n    let out = PathBuf::from(&args[0]);\r\n    let traces: Vec<PathBuf> = args[1..].iter().map(PathBuf::from).collect();\r\n    if let Err(err) = idxlab::runner::run_all(&out, &traces) {\r\n        eprintln!(\"{err}\");\r\n        std::process::exit(1);\r\n    }\r\n}\r\n\u001b[?2004hroot@d4a05a58442d:/app# "]
[14.16719, "i", "cat /app/src/lib.rs\n"]
[14.168075, "o", "cat /app/src/lib.rs\r\n\u001b[?2004l\r"]
[14.16869, "o", "pub mod io;\r\npub mod model;\r\npub mod report;\r\npub mod runner;\r\n\r\n#[path = \"../r0/a.rs\"]\r\npub mod r0_a;\r\n#[path = \"../r1/b.rs\"]\r\npub mod r1_b;\r\n#[path = \"../r2/c.rs\"]\r\npub mod r2_c;\r\n#[path = \"../r3/d.rs\"]\r\npub mod r3_d;\r\n#[path = \"../r4/e.rs\"]\r\npub mod r4_e;\r\n#[path = \"../r5/f.rs\"]\r\npub mod r5_f;\r\n#[path = \"../r6/g.rs\"]\r\npub mod r6_g;\r\n#[path = \"../r7/h.rs\"]\r\npub mod r7_h;\r\n#[path = \"../r8/i.rs\"]\r\npub mod r8_i;\r\n"]
[14.169012, "o", "\u001b[?2004hroot@d4a05a58442d:/app# "]
[14.303372, "i", "cat /app/src/model.rs\n"]
[14.303935, "o", "cat /app/src/model.rs\r\n\u001b[?2004l\r"]
[14.305295, "o", "use std::collections::BTreeMap;\r\n\r\n#[derive(Clone, Debug)]\r\npub struct Entry {\r\n    pub slot: String,\r\n    pub symbol: String,\r\n    pub path: String,\r\n    pub source: String,\r\n    pub line: usize,\r\n    pub epoch: u64,\r\n    pub handle: u64,\r\n}\r\n\r\n#[derive(Clone, Debug)]\r\npub struct Event {\r\n    pub kind: String,\r\n    pub left: String,\r\n    pub right: String,\r\n}\r\n\r\n#[derive(Clone, Debug)]\r\npub struct Observation {\r\n    pub label: String,\r\n    pub symbol: String,\r\n    pub found: bool,\r\n    pub path: String,\r\n    pub source: String,\r\n    pub line: usize,\r\n    pub epoch: u64,\r\n    pub reused: bool,\r\n    pub fresh: bool,\r\n}\r\n\r\n#[derive(Clone, Debug)]\r\npub struct CaseReport {\r\n    pub name: String,\r\n    pub ok: bool,\r\n    pub observations: Vec<Observation>,\r\n    pub stale: Vec<String>,\r\n}\r\n\r\n#[derive(Debug)]\r\npub struct State {\r\n    pub entries: Vec<Entry>,\r\n    pub active: BTreeMap<String, String>,\r\n    pub handles: BTreeMap<String, u64>,\r\n    pub last_seen: BTreeMap<String, u64>,\r\n    pub next_handle: u64,\r\n    pub epoch: u64,\r\n}\r\n\r\nimpl State {\r\n    pub fn new() -> Self {\r\n        Self {\r\n            entries: Vec::new(),\r\n            active: BTreeMap::new(),\r\n            handles: BTreeMap::new(),\r\n            last_seen: BTreeMap::new(),\r\n            next_handle: 1,\r\n            epoch: 0,\r\n        }\r\n    }\r\n\r\n    pub fn key_for(slot: &str, path: &str, symbol: &str) -> String {\r\n        format!(\"{slot}|{path}|{symbol}\")\r\n    }\r\n\r\n    pub fn handle_for(&mut self, slot: &str, path: &str, symbol: &str) -> u64 {\r\n        let key = Self::key_for(slot, path, symbol);\r\n        if let Some(value) = self.handles.get(&key) {\r\n            *value\r\n        } else {\r\n            let value = self.next_handle;\r\n            self.next_handle += 1;\r\n            self.handles.insert(key, value);\r\n            value\r\n        }\r\n    }\r\n}\r\n\r\nimpl Observation {\r\n    pub fn missing(label: &str, symbol: &str, epoch: u64, fresh: bool) -> Self {\r\n        Self {\r\n            label: label.to_string(),\r\n            symbol: symbol.to_string(),\r\n            found: false,\r\n            path: String::new(),\r\n            source: String::new(),\r\n            line: 0,\r\n            epoch,\r\n            reused: false,\r\n            fresh,\r\n        }\r\n    }\r\n}\r\n"]
[14.306178, "o", "\u001b[?2004h"]
