[14.369493, "o", "[package]\r\nname = \"incremental-index-invalidation\"\r\nversion = \"0.1.0\"\r\nedition = \"2021\"\r\n\r\n[lib]\r\nname = \"idxlab\"\r\npath = \"src/lib.rs\"\r\n\r\n[[bin]]\r\nname = \"idxlab\"\r\npath = \"src/main.rs\"\r\n"]
[14.369792, "o", "\u001b[?2004hroot@f8417155424a:/app# "]
[14.500732, "i", "cat /app/src/main.rs\n"]
[14.501327, "o", "cat /app/src/main.rs\r\n\u001b[?2004l\r"]
[14.502795, "o", "use std::env;\r\nuse std::path::PathBuf;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().skip(1).collect();\r\n    if args.len() < 2 {\r\n        eprintln!(\"usage: idxlab <report> <trace> [trace ...]\");\r\n        std::process::exit(2);\r\n    }\r\n    let out = PathBuf::from(&args[0]);\r\n    let traces: Vec<PathBuf> = args[1..].iter().map(PathBuf::from).collect();\r\n    if let Err(err) = idxlab::runner::run_all(&out, &traces) {\r\n        eprintln!(\"{err}\");\r\n        std::process::exit(1);\r\n    }\r\n}\r\n"]
