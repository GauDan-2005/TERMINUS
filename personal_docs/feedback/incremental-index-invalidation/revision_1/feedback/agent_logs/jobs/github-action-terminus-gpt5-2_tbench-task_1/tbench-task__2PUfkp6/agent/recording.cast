[387.175622, "o", "pub fn emit_c(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n\u001b[?2004l\r\u001b[?2004h>     a.epoch += 1;\r\n\u001b[?2004l\r\u001b[?2004h>     let root = resolve_fixture_root(c);\r\n\u001b[?2004l\r\u001b[?2004h>     a.active.insert(b.to_string(), root.clone());\r\n\u001b[?2004l\r\u001b[?2004h>     let mut found = collect_entries(a, b, &root, a.epoch)?;\r\n\u001b[?2004l\r\u001b[?2004h>     a.entries.append(&mut found);\r\n\u001b[?2004l\r\u001b[?2004h>     Ok(())\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[387.178627, "o", "\u001b[?2004hroot@f75739620649:/app# "]
[388.176921, "i", "cat > /app/r3/d.rs <<'EOF'\nuse crate::io::{collect_entries, resolve_fixture_root, resolve_target_root};\nuse crate::model::State;\n\npub fn lift_d(a: &mut State, b: &str, c: &str) -> Result<(), String> {\n    a.epoch += 1;\n\n    // `pkg` roots are aliases that can point at different targets via\n    // `link.target`. Resolve to the actual target and use that for freshness.\n    let shown = resolve_fixture_root(c);\n    let actual = resolve_target_root(&shown)?;\n\n    a.active.insert(b.to_string(), actual.clone());\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\n    a.entries.append(&mut found);\n    Ok(())\n}\nEOF\n"]
