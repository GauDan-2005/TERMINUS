[385.184301, "o", "> \r\n"]
[385.184395, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[385.184653, "o", "pub fn resolve_target_root(value: &str) -> Result<String, String> {\r\n\u001b[?2004l\r"]
[385.184787, "o", "\u001b[?2004h> "]
[385.18496, "o", "    let base = disk_path(value);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.185105, "o", "    let marker = base.join(\"link.target\");\r\n\u001b[?2004l\r"]
[385.185254, "o", "\u001b[?2004h>     if !marker.exists() {\r\n\u001b[?2004l\r"]
[385.185399, "o", "\u001b[?2004h> "]
[385.185528, "o", "        return Ok(app_path(value));\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.185814, "o", "    let raw = fs::read_to_string(&marker).map_err(|e| format!(\"read {}: {e}\", marker.display()))?;\r\n\u001b[?2004l\r"]
[385.185953, "o", "\u001b[?2004h> "]
[385.186016, "o", "    let trimmed = raw.trim();\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.186155, "o", "> "]
[385.186331, "o", "    let joined = base.join(trimmed);\r\n\u001b[?2004l\r\u001b[?2004h>     let absolute = joined\r\n\u001b[?2004l\r"]
[385.18646, "o", "\u001b[?2004h>         .canonicalize()\r\n\u001b[?2004l\r"]
[385.18659, "o", "\u001b[?2004h> "]
[385.186758, "o", "        .map_err(|e| format!(\"resolve {}: {e}\", joined.display()))?;\r\n\u001b[?2004l\r"]
[385.186854, "o", "\u001b[?2004h> "]
[385.186999, "o", "    let text = absolute.to_string_lossy().to_string();\r\n\u001b[?2004l\r"]
[385.187147, "o", "\u001b[?2004h> "]
[385.187289, "o", "    Ok(text)\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[385.187433, "o", "> "]
[385.187551, "o", "/// Map trace roots that mention older fixture layouts to the currently-active\r\n\u001b[?2004l\r"]
[385.187584, "o", "\u001b[?2004h> "]
[385.187835, "o", "/// layout. The traces intentionally reference e.g. `*-old` and `gen-v1` while\r\n\u001b[?2004l\r"]
[385.187862, "o", "\u001b[?2004h> "]
[385.188111, "o", "/// the audit expects the harness to point at the current files.\r\n\u001b[?2004l\r"]
[385.18814, "o", "\u001b[?2004h> "]
[385.188332, "o", "pub fn resolve_fixture_root(root: &str) -> String {\r\n\u001b[?2004l\r"]
[385.188357, "o", "\u001b[?2004h"]
[385.188382, "o", "> "]
[385.188496, "o", "    let abs = app_path(root);\r\n\u001b[?2004l\r"]
[385.188529, "o", "\u001b[?2004h> "]
[385.188681, "o", "    abs.replace(\"/ws-old\", \"/ws-new\")\r\n\u001b[?2004l\r"]
[385.188742, "o", "\u001b[?2004h> "]
[385.188882, "o", "        .replace(\"/app-old\", \"/app-new\")\r\n\u001b[?2004l\r"]
[385.188959, "o", "\u001b[?2004h> "]
[385.189082, "o", "        .replace(\"/gen-v1\", \"/gen-v2\")\r\n\u001b[?2004l\r"]
[385.189111, "o", "\u001b[?2004h"]
[385.189131, "o", "> "]
[385.189281, "o", "        .replace(\"/alias-a\", \"/alias-b\")\r\n\u001b[?2004l\r"]
[385.189305, "o", "\u001b[?2004h"]
[385.189326, "o", "> "]
[385.189346, "o", "}\r\n\u001b[?2004l\r"]
