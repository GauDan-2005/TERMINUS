[386.173335, "i", "cat > /app/r1/b.rs <<'EOF'\nuse crate::io::{collect_entries, resolve_fixture_root};\nuse crate::model::State;\n\npub fn fold_b(a: &mut State, b: &str, c: &str) -> Result<(), String> {\n    a.epoch += 1;\n    let root = resolve_fixture_root(c);\n    a.active.insert(b.to_string(), root.clone());\n    let mut found = collect_entries(a, b, &root, a.epoch)?;\n    a.entries.append(&mut found);\n    Ok(())\n}\nEOF\n"]
