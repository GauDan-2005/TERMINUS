[734.428561, "i", "python3 - <<'PY'\nimport json\nobj=json.load(open('/app/output/index-report.json'))\nfor case in obj['cases']:\n    for o in case['observations']:\n        assert o['symbol'], (case['name'], o)\n        if o['found']:\n            assert o['line']>0\n            assert o['path'].startswith('/app/')\n            assert o['source'].startswith('/app/')\n        else:\n            assert o['line']==0\n            assert o['path']=='' and o['source']==''\nprint('SANITY OK')\nPY\n"]
