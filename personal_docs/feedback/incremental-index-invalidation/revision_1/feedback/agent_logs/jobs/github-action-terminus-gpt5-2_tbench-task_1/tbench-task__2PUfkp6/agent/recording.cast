[541.808659, "i", "python3 - <<'PY'\nimport pathlib, re\nfor v in ['gen-v1','gen-v2']:\n    root=pathlib.Path('/app/fixtures/epsilon')/v\n    print('==',root)\n    for p in sorted(root.rglob('*.ts')):\n        txt=p.read_text()\n        syms=[]\n        for i,line in enumerate(txt.splitlines(),1):\n            m=re.match(r'\\s*export (?:const|function)\\s+([A-Za-z0-9_]+)', line)\n            if m: syms.append((m.group(1),i))\n        if syms:\n            print(p, syms)\nPY\n"]
