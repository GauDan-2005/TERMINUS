[545.190782, "o", "\u001b[?2004h> "]
[545.190936, "o", "        .canonicalize()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.191127, "o", "        .map_err(|e| format!(\"resolve {}: {e}\", joined.display()))?;\r\n\u001b[?2004l\r"]
[545.191265, "o", "\u001b[?2004h> "]
[545.191382, "o", "    let text = absolute.to_string_lossy().to_string();\r\n\u001b[?2004l\r"]
[545.191419, "o", "\u001b[?2004h> "]
[545.191465, "o", "    Ok(text)\r\n\u001b[?2004l\r"]
[545.191661, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.192059, "o", "/// Map trace roots that mention older fixture layouts to the currently-active\r\n\u001b[?2004l\r"]
[545.192177, "o", "\u001b[?2004h> /// layout.\r\n\u001b[?2004l\r\u001b[?2004h> ///\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.192356, "o", "/// Notes:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.192446, "o", "/// * app workspaces: ws-old -> ws-new, app-old -> app-new\r\n\u001b[?2004l\r"]
[545.192557, "o", "\u001b[?2004h> "]
[545.192703, "o", "/// * linked packages: alias-a -> alias-b (the active link)\r\n\u001b[?2004l\r"]
[545.192794, "o", "\u001b[?2004h> "]
[545.192996, "o", "/// * generated outputs: most cases should prefer the newest generation, but the\r\n\u001b[?2004l\r"]
[545.193117, "o", "\u001b[?2004h> "]
[545.193305, "o", "///   epsilon trace specifically audits deletion across generations, so we do not\r\n\u001b[?2004l\r"]
[545.193424, "o", "\u001b[?2004h> "]
[545.193508, "o", "///   rewrite epsilon's gen roots.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.19369, "o", "pub fn resolve_fixture_root(root: &str) -> String {\r\n\u001b[?2004l\r"]
[545.193779, "o", "\u001b[?2004h> "]
[545.193851, "o", "    let abs = app_path(root);\r\n\u001b[?2004l\r"]
[545.193942, "o", "\u001b[?2004h> "]
[545.19415, "o", "    let abs = abs.replace(\"/ws-old\", \"/ws-new\").replace(\"/app-old\", \"/app-new\");\r\n\u001b[?2004l\r"]
[545.194181, "o", "\u001b[?2004h> "]
[545.1942, "o", "\r\n\u001b[?2004l\r"]
[545.194232, "o", "\u001b[?2004h"]
[545.19425, "o", "> "]
[545.194471, "o", "    // Prefer the active target for linked package aliases.\r\n\u001b[?2004l\r"]
[545.194564, "o", "\u001b[?2004h> "]
[545.194685, "o", "    let abs = abs.replace(\"/alias-a\", \"/alias-b\");\r\n\u001b[?2004l\r"]
[545.194779, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[545.19486, "o", "> "]
[545.195034, "o", "    // Prefer newest generated output, except for epsilon where gen-v1 and gen-v2\r\n\u001b[?2004l\r"]
[545.19506, "o", "\u001b[?2004h"]
[545.195081, "o", "> "]
[545.195252, "o", "    // are intentionally distinct.\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.19538, "o", "> "]
[545.195465, "o", "    if abs.contains(\"/fixtures/epsilon/\") {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.195562, "o", "        abs\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.195665, "o", "    } else {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.195812, "o", "        abs.replace(\"/gen-v1\", \"/gen-v2\")\r\n\u001b[?2004l\r"]
[545.195847, "o", "\u001b[?2004h> "]
[545.195978, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.196175, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> pub fn collect_entries(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.196241, "o", "    state: &mut State,\r\n\u001b[?2004l\r"]
[545.19627, "o", "\u001b[?2004h"]
[545.196377, "o", "> "]
[545.196501, "o", "    slot: &str,\r\n\u001b[?2004l\r\u001b[?2004h>     root: &str,\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.196611, "o", ">     epoch: u64,\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.196694, "o", "> "]
[545.196738, "o", ") -> Result<Vec<Entry>, String> {\r\n\u001b[?2004l\r"]
[545.196862, "o", "\u001b[?2004h> "]
[545.196942, "o", "    let root_path = disk_path(root);\r\n\u001b[?2004l\r"]
[545.197031, "o", "\u001b[?2004h> "]
[545.197116, "o", "    let mut files = Vec::new();\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.197198, "o", "> "]
[545.197291, "o", "    gather_ts(&root_path, &mut files)?;\r\n\u001b[?2004l\r"]
[545.197367, "o", "\u001b[?2004h> "]
[545.197482, "o", "    files.sort();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.197656, "o", "    let mut out = Vec::new();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.197696, "o", "    for file in files {\r\n\u001b[?2004l\r"]
[545.197782, "o", "\u001b[?2004h> "]
[545.197904, "o", "        let app_file = file_to_app(&file)?;\r\n\u001b[?2004l\r"]
[545.198006, "o", "\u001b[?2004h> "]
[545.198094, "o", "        let source = source_for(&file)?;\r\n\u001b[?2004l\r"]
[545.198177, "o", "\u001b[?2004h> "]
[545.198456, "o", "        let text = fs::read_to_string(&file).map_err(|e| format!(\"read {}: {e}\", file.display()))?;\r\n\u001b[?2004l\r"]
[545.198495, "o", "\u001b[?2004h> "]
[545.19868, "o", "        for (line, symbol) in exported_symbols(&text) {\r\n\u001b[?2004l\r"]
[545.19879, "o", "\u001b[?2004h> "]
[545.198944, "o", "            let handle = state.handle_for(slot, &app_file, &symbol);\r\n\u001b[?2004l\r"]
[545.199032, "o", "\u001b[?2004h> "]
[545.199112, "o", "            out.push(Entry {\r\n\u001b[?2004l\r"]
[545.199214, "o", "\u001b[?2004h> "]
[545.199296, "o", "                slot: slot.to_string(),\r\n\u001b[?2004l\r"]
[545.199378, "o", "\u001b[?2004h> "]
[545.199531, "o", "                symbol,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.199636, "o", "                path: app_file.clone(),\r\n\u001b[?2004l\r"]
[545.19972, "o", "\u001b[?2004h> "]
[545.199808, "o", "                source: source.clone(),\r\n\u001b[?2004l\r"]
[545.199883, "o", "\u001b[?2004h> "]
[545.199999, "o", "                line,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.20009, "o", "                epoch,\r\n\u001b[?2004l\r"]
[545.200123, "o", "\u001b[?2004h> "]
[545.20022, "o", "                handle,\r\n\u001b[?2004l\r"]
[545.20025, "o", "\u001b[?2004h> "]
[545.200323, "o", "            });\r\n\u001b[?2004l\r"]
[545.200354, "o", "\u001b[?2004h> "]
[545.200419, "o", "        }\r\n\u001b[?2004l\r"]
[545.200449, "o", "\u001b[?2004h> "]
[545.200517, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.200548, "o", "> "]
[545.20061, "o", "    Ok(out)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.200646, "o", "}\r\n\u001b[?2004l\r"]
[545.200673, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[545.200778, "o", "\u001b[?2004h> "]
[545.200974, "o", "fn gather_ts(dir: &Path, out: &mut Vec<PathBuf>) -> Result<(), String> {\r\n\u001b[?2004l\r"]
[545.201001, "o", "\u001b[?2004h"]
[545.201022, "o", "> "]
[545.201314, "o", "    let entries = fs::read_dir(dir).map_err(|e| format!(\"scan {}: {e}\", dir.display()))?;\r\n\u001b[?2004l\r"]
[545.201344, "o", "\u001b[?2004h> "]
[545.201495, "o", "    for item in entries {\r\n\u001b[?2004l\r"]
[545.201525, "o", "\u001b[?2004h> "]
[545.20182, "o", "        let path = item.map_err(|e| format!(\"scan {}: {e}\", dir.display()))?.path();\r\n\u001b[?2004l\r"]
[545.201849, "o", "\u001b[?2004h> "]
[545.201968, "o", "        if path.is_dir() {\r\n\u001b[?2004l\r"]
[545.202037, "o", "\u001b[?2004h> "]
[545.202143, "o", "            gather_ts(&path, out)?;\r\n\u001b[?2004l\r"]
[545.202172, "o", "\u001b[?2004h> "]
[545.202423, "o", "        } else if path.extension().and_then(|s| s.to_str()) == Some(\"ts\") {\r\n\u001b[?2004l\r"]
[545.202455, "o", "\u001b[?2004h> "]
[545.202604, "o", "            out.push(path);\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.202746, "o", ">         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.202842, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>     Ok(())\r\n\u001b[?2004l\r"]
[545.202946, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[545.203065, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.203186, "o", "fn file_to_app(path: &Path) -> Result<String, String> {\r\n\u001b[?2004l\r"]
[545.203266, "o", "\u001b[?2004h> "]
[545.203373, "o", "    let abs = path\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.203484, "o", "        .canonicalize()\r\n\u001b[?2004l\r"]
[545.203562, "o", "\u001b[?2004h> "]
[545.203707, "o", "        .map_err(|e| format!(\"resolve {}: {e}\", path.display()))?;\r\n\u001b[?2004l\r"]
[545.20381, "o", "\u001b[?2004h> "]
[545.2039, "o", "    Ok(abs.to_string_lossy().to_string())\r\n\u001b[?2004l\r"]
[545.20405, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[545.204153, "o", "\u001b[?2004h> "]
[545.204252, "o", "fn source_for(path: &Path) -> Result<String, String> {\r\n\u001b[?2004l\r"]
[545.204357, "o", "\u001b[?2004h> "]
[545.204593, "o", "    let text = fs::read_to_string(path).map_err(|e| format!(\"read {}: {e}\", path.display()))?;\r\n\u001b[?2004l\r"]
[545.204698, "o", "\u001b[?2004h> "]
[545.204776, "o", "    for raw in text.lines().take(4) {\r\n\u001b[?2004l\r"]
[545.204876, "o", "\u001b[?2004h> "]
[545.204963, "o", "        let line = raw.trim();\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.205046, "o", "> "]
[545.205193, "o", "        if let Some(rest) = line.strip_prefix(\"// origin:\") {\r\n\u001b[?2004l\r"]
[545.205279, "o", "\u001b[?2004h> "]
[545.205402, "o", "            return Ok(app_path(rest.trim()));\r\n\u001b[?2004l\r"]
[545.205497, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[545.205617, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.205746, "o", "> "]
[545.205841, "o", "    file_to_app(path)\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[545.205919, "o", "> "]
[545.206072, "o", "fn exported_symbols(text: &str) -> Vec<(usize, String)> {\r\n\u001b[?2004l\r"]
[545.206166, "o", "\u001b[?2004h> "]
[545.206272, "o", "    let mut out = Vec::new();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.206441, "o", "    for (idx, raw) in text.lines().enumerate() {\r\n\u001b[?2004l\r"]
[545.206533, "o", "\u001b[?2004h> "]
[545.206629, "o", "        let line = raw.trim_start();\r\n\u001b[?2004l\r"]
[545.206714, "o", "\u001b[?2004h> "]
[545.206882, "o", "        for prefix in [\"export const \", \"export function \"] {\r\n\u001b[?2004l\r"]
[545.206967, "o", "\u001b[?2004h> "]
[545.207124, "o", "            if let Some(rest) = line.strip_prefix(prefix) {\r\n\u001b[?2004l\r"]
[545.207192, "o", "\u001b[?2004h> "]
[545.207332, "o", "                let symbol: String = rest\r\n\u001b[?2004l\r"]
[545.207368, "o", "\u001b[?2004h> "]
[545.207531, "o", "                    .chars()\r\n\u001b[?2004l\r"]
[545.207619, "o", "\u001b[?2004h> "]
[545.207766, "o", "                    .take_while(|c| c.is_ascii_alphanumeric() || *c == '_')\r\n\u001b[?2004l\r"]
[545.207842, "o", "\u001b[?2004h> "]
[545.207935, "o", "                    .collect();\r\n\u001b[?2004l\r"]
[545.208092, "o", "\u001b[?2004h> "]
[545.208261, "o", "                if !symbol.is_empty() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.208415, "o", "                    out.push((idx + 1, symbol));\r\n\u001b[?2004l\r"]
[545.208539, "o", "\u001b[?2004h> "]
[545.208683, "o", "                }\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n"]
[545.208766, "o", "\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[545.208913, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[545.209043, "o", ">     out\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[545.211123, "o", "\u001b[?2004hroot@f75739620649:/app# "]
[546.16426, "i", "cat > /app/r4/e.rs <<'EOF'\nuse crate::model::{Observation, State};\n\npub fn mote_e(a: &mut State, b: &str, c: bool) -> Observation {\n    if let Some(entry) = a.entries.iter().find(|entry| entry.symbol == b) {\n        let reused = a\n            .last_seen\n            .get(b)\n            .map(|old| *old == entry.handle)\n            .unwrap_or(false);\n        a.last_seen.insert(b.to_string(), entry.handle);\n        let fresh = a\n            .active\n            .get(&entry.slot)\n            .map(|root| entry.path.starts_with(root))\n            .unwrap_or(false);\n        Observation {\n            label: String::new(),\n            symbol: b.to_string(),\n            found: true,\n            path: entry.path.clone(),\n            source: entry.source.clone(),\n            line: entry.line,\n            // The audit expects the harness epoch at query time.\n            epoch: a.epoch,\n            reused,\n            fresh,\n        }\n    } else {\n        Observation::missing(b, b, a.epoch, !c)\n    }\n}\nEOF\n"]
[546.164578, "o", "cat > /app/r4/e.rs <<'EOF'\r\n\u001b[?2004l\r"]
[546.164628, "o", "\u001b[?2004h> "]
[546.16481, "o", "use crate::model::{Observation, State};\r\n\u001b[?2004l\r"]
[546.164917, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.165112, "o", "pub fn mote_e(a: &mut State, b: &str, c: bool) -> Observation {\r\n\u001b[?2004l\r"]
[546.165204, "o", "\u001b[?2004h> "]
[546.165411, "o", "    if let Some(entry) = a.entries.iter().find(|entry| entry.symbol == b) {\r\n\u001b[?2004l\r"]
[546.165444, "o", "\u001b[?2004h> "]
[546.165558, "o", "        let reused = a\r\n\u001b[?2004l\r"]
[546.165643, "o", "\u001b[?2004h> "]
[546.165749, "o", "            .last_seen\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.165844, "o", "            .get(b)\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.165931, "o", "> "]
[546.16604, "o", "            .map(|old| *old == entry.handle)\r\n\u001b[?2004l\r"]
[546.166075, "o", "\u001b[?2004h> "]
[546.166222, "o", "            .unwrap_or(false);\r\n\u001b[?2004l\r"]
[546.166315, "o", "\u001b[?2004h> "]
[546.166458, "o", "        a.last_seen.insert(b.to_string(), entry.handle);\r\n\u001b[?2004l\r"]
[546.16654, "o", "\u001b[?2004h> "]
[546.166639, "o", "        let fresh = a\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.166733, "o", ">             .active"]
[546.166821, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.166971, "o", "            .get(&entry.slot)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.167113, "o", "            .map(|root| entry.path.starts_with(root))\r\n\u001b[?2004l\r"]
[546.167205, "o", "\u001b[?2004h> "]
[546.167302, "o", "            .unwrap_or(false);\r\n\u001b[?2004l\r"]
[546.167344, "o", "\u001b[?2004h> "]
[546.167448, "o", "        Observation {\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.16757, "o", "> "]
[546.167613, "o", "            label: String::new(),\r\n\u001b[?2004l\r\u001b[?2004h"]
[546.167706, "o", "> "]
[546.167813, "o", "            symbol: b.to_string(),\r\n\u001b[?2004l\r"]
[546.167931, "o", "\u001b[?2004h> "]
[546.168037, "o", "            found: true,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[546.169031, "o", "            path: entry.path.clone(),\r\n\u001b[?2004l\r\u001b[?2004h>             source: entry.source.clone(),\r\n\u001b[?2004l\r\u001b[?2004h>             line: entry.line,\r\n\u001b[?2004l\r\u001b[?2004h>             // The audit expects the harness epoch at query time.\r\n\u001b[?2004l\r\u001b[?2004h>             epoch: a.epoch,\r\n\u001b[?2004l\r"]
[546.171597, "o", "\u001b[?2004h> "]
[546.1717, "o", "            reused,\r\n\u001b[?2004l\r\u001b[?2004h>             fresh,\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     } else {\r\n\u001b[?2004l\r\u001b[?2004h>         Observation::missing(b, b, a.epoch, !c)\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@f75739620649:/app# "]
[547.17633, "i", "cargo build\n"]
[547.176884, "o", "cargo build\r\n\u001b[?2004l\r"]
[547.195315, "o", "\u001b[1m\u001b[32m   Compiling\u001b[0m incremental-index-invalidation v0.1.0 (/app)\r\n"]
[547.195511, "o", "\u001b[1m\u001b[36m    Building\u001b[0m [                             ] 0/2: incremental-index-invalidation                                                                              \r"]
[547.484661, "o", "\u001b[1m\u001b[36m    Building\u001b[0m [=============>               ] 1/2: idxlab(bin)                                                                                                 \r"]
[547.804318, "o", "\u001b[K\u001b[1m\u001b[32m    Finished\u001b[0m `dev` profile [unoptimized + debuginfo] target(s) in 0.61s\r\n"]
[547.806144, "o", "\u001b[?2004hroot@f75739620649:/app# "]
[607.240193, "i", "bash /app/scripts/run-matrix.sh\npython3 - <<'PY'\nimport json\nobj=json.load(open('/app/output/index-report.json'))\nfor c in obj['cases']:\n    epochs=[o['epoch'] for o in c['observations']]\n    print(c['name'], 'ok=', c['ok'], 'stale=', c['stale'], 'epochs=', epochs)\n    assert epochs==sorted(epochs), (c['name'], epochs)\n    assert c['stale']==[], (c['name'], c['stale'])\n    assert c['ok'] is True\nprint('ALL CLEAN')\nPY\n"]
[607.24052, "o", "bash /app/scripts/run-matrix.sh\r\n\u001b[?2004l\r"]
