[149.746017, "o", "pub fn emit_c(a: &mut State, b: &str, c: &str) -> Result<(), String> {\r\n"]
[149.746131, "o", "    a.epoch += 1;\r\n"]
[149.746236, "o", "    let root = app_path(c);\r\n"]
