[385.173557, "o", "> "]
[385.174343, "o", "    let text = fs::read_to_string(path).map_err(|e| format!(\"read {}: {e}\", path.display()))?;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.174587, "o", "    let mut out = Vec::new();\r\n\u001b[?2004l\r"]
[385.174689, "o", "\u001b[?2004h"]
[385.174711, "o", "> "]
[385.175153, "o", "    for (idx, raw) in text.lines().enumerate() {\r\n\u001b[?2004l\r"]
[385.175191, "o", "\u001b[?2004h> "]
[385.175611, "o", "        let line = raw.trim();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.175809, "o", "        if line.is_empty() || line.starts_with('#') {\r\n\u001b[?2004l\r"]
[385.175834, "o", "\u001b[?2004h"]
[385.175854, "o", "> "]
[385.176036, "o", "            continue;\r\n\u001b[?2004l\r"]
[385.176069, "o", "\u001b[?2004h> "]
[385.176195, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.176643, "o", "        let parts: Vec<&str> = line.split_whitespace().collect();\r\n\u001b[?2004l\r"]
[385.176789, "o", "\u001b[?2004h> "]
[385.176886, "o", "        if parts.len() < 3 {\r\n\u001b[?2004l\r"]
[385.176968, "o", "\u001b[?2004h> "]
[385.177436, "o", "            return Err(format!(\"{}:{}: expected 3 fields\", path.display(), idx + 1));\r\n\u001b[?2004l\r"]
[385.177525, "o", "\u001b[?2004h> "]
[385.177619, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.177799, "o", "        out.push(Event {\r\n\u001b[?2004l\r"]
[385.177885, "o", "\u001b[?2004h> "]
[385.178114, "o", "            kind: parts[0].to_string(),\r\n\u001b[?2004l\r"]
[385.178195, "o", "\u001b[?2004h> "]
[385.178438, "o", "            left: parts[1].to_string(),\r\n\u001b[?2004l\r"]
[385.178473, "o", "\u001b[?2004h> "]
[385.178707, "o", "            right: parts[2].to_string(),\r\n\u001b[?2004l\r"]
[385.178734, "o", "\u001b[?2004h> "]
[385.178836, "o", "        });\r\n\u001b[?2004l\r"]
[385.178867, "o", "\u001b[?2004h"]
[385.17889, "o", "> "]
[385.178916, "o", "    }\r\n\u001b[?2004l\r"]
[385.179009, "o", "\u001b[?2004h> "]
[385.17904, "o", "    Ok(out)\r\n"]
[385.179063, "o", "\u001b[?2004l\r"]
[385.179166, "o", "\u001b[?2004h"]
[385.179261, "o", "> "]
[385.179319, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[385.179372, "o", "> "]
[385.179666, "o", "pub fn disk_path(value: &str) -> PathBuf {\r\n\u001b[?2004l\r"]
[385.179812, "o", "\u001b[?2004h> "]
[385.179955, "o", "    if value.starts_with(\"/app/\") {\r\n\u001b[?2004l\r"]
[385.180139, "o", "\u001b[?2004h> "]
[385.180238, "o", "        PathBuf::from(value)\r\n\u001b[?2004l\r"]
[385.180274, "o", "\u001b[?2004h> "]
[385.180637, "o", "    } else if let Some(rest) = value.strip_prefix(\"app/\") {\r\n\u001b[?2004l\r"]
[385.180672, "o", "\u001b[?2004h> "]
[385.180923, "o", "        PathBuf::from(\"/app\").join(rest)\r\n\u001b[?2004l\r"]
[385.180951, "o", "\u001b[?2004h"]
[385.18106, "o", "> "]
[385.181179, "o", "    } else if value == \"/app\" {\r\n\u001b[?2004l\r"]
[385.181207, "o", "\u001b[?2004h> "]
[385.181405, "o", "        PathBuf::from(\"/app\")\r\n\u001b[?2004l\r"]
[385.181431, "o", "\u001b[?2004h> "]
[385.181544, "o", "    } else {\r\n\u001b[?2004l\r"]
[385.18157, "o", "\u001b[?2004h"]
[385.181591, "o", "> "]
[385.181853, "o", "        PathBuf::from(\"/app\").join(value)\r\n\u001b[?2004l\r"]
[385.181878, "o", "\u001b[?2004h"]
[385.181896, "o", "> "]
[385.182006, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.182075, "o", "> }"]
[385.18215, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.182224, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.182483, "o", "pub fn app_path(value: &str) -> String {\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.182549, "o", "> "]
[385.182687, "o", "    if value.starts_with(\"/app/\") {\r\n\u001b[?2004l\r"]
[385.182718, "o", "\u001b[?2004h> "]
[385.182842, "o", "        value.to_string()\r\n\u001b[?2004l\r"]
[385.182871, "o", "\u001b[?2004h> "]
[385.183123, "o", "    } else if let Some(rest) = value.strip_prefix(\"app/\") {\r\n\u001b[?2004l\r"]
[385.183281, "o", "\u001b[?2004h>         format!(\"/app/{rest}\")\r\n\u001b[?2004l\r"]
[385.183455, "o", "\u001b[?2004h> "]
[385.183493, "o", "    } else if value == \"/app\" {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.183595, "o", "        \"/app\".to_string()\r\n\u001b[?2004l\r"]
[385.183618, "o", "\u001b[?2004h"]
[385.183684, "o", "> "]
[385.183768, "o", "    } else {\r\n\u001b[?2004l\r"]
[385.183852, "o", "\u001b[?2004h> "]
[385.183916, "o", "        format!(\"/app/{value}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.183993, "o", "    }"]
[385.184077, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
