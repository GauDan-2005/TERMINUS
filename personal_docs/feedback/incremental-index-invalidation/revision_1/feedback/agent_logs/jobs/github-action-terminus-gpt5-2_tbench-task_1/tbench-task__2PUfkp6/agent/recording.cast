[385.189387, "o", "> \r\n\u001b[?2004l\r"]
[385.189476, "o", "\u001b[?2004h> "]
[385.189561, "o", "pub fn collect_entries(\r\n\u001b[?2004l\r"]
[385.189588, "o", "\u001b[?2004h"]
[385.18968, "o", "> "]
[385.189778, "o", "    state: &mut State,\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.189845, "o", ">     slot: &str,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.190012, "o", "    root: &str,\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.190164, "o", ">     epoch: u64,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.190308, "o", ") -> Result<Vec<Entry>, String> {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.190387, "o", "    let root_path = disk_path(root);\r\n\u001b[?2004l\r"]
[385.190424, "o", "\u001b[?2004h> "]
[385.190538, "o", "    let mut files = Vec::new();\r\n\u001b[?2004l\r"]
[385.190582, "o", "\u001b[?2004h> "]
[385.19073, "o", "    gather_ts(&root_path, &mut files)?;\r\n\u001b[?2004l\r"]
[385.190788, "o", "\u001b[?2004h> "]
[385.190841, "o", "    files.sort();\r\n\u001b[?2004l\r"]
[385.190951, "o", "\u001b[?2004h"]
[385.191057, "o", "> "]
[385.191163, "o", "    let mut out = Vec::new();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.191258, "o", "    for file in files {\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.191413, "o", "> "]
[385.191543, "o", "        let app_file = file_to_app(&file)?;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.19163, "o", "        let source = source_for(&file)?;\r\n\u001b[?2004l\r"]
[385.191694, "o", "\u001b[?2004h> "]
[385.191989, "o", "        let text = fs::read_to_string(&file).map_err(|e| format!(\"read {}: {e}\", file.display()))?;\r\n\u001b[?2004l\r"]
[385.192206, "o", "\u001b[?2004h> "]
[385.192295, "o", "        for (line, symbol) in exported_symbols(&text) {\r\n\u001b[?2004l\r"]
[385.192394, "o", "\u001b[?2004h> "]
[385.192575, "o", "            let handle = state.handle_for(slot, &app_file, &symbol);\r\n\u001b[?2004l\r"]
[385.192686, "o", "\u001b[?2004h> "]
[385.192756, "o", "            out.push(Entry {\r\n\u001b[?2004l\r"]
[385.192839, "o", "\u001b[?2004h> "]
[385.192986, "o", "                slot: slot.to_string(),\r\n\u001b[?2004l\r"]
[385.193112, "o", "\u001b[?2004h> "]
[385.193195, "o", "                symbol,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.193303, "o", "                path: app_file.clone(),\r\n\u001b[?2004l\r"]
[385.193332, "o", "\u001b[?2004h> "]
[385.193472, "o", "                source: source.clone(),\r\n\u001b[?2004l\r"]
[385.193501, "o", "\u001b[?2004h> "]
[385.193617, "o", "                line,\r\n\u001b[?2004l\r"]
[385.193695, "o", "\u001b[?2004h> "]
[385.193758, "o", "                epoch,\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.193826, "o", "> "]
[385.193903, "o", "                handle,\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.193973, "o", "> "]
[385.194001, "o", "            });\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.194068, "o", "> "]
[385.194121, "o", "        }\r\n\u001b[?2004l\r"]
[385.194168, "o", "\u001b[?2004h> "]
[385.194216, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.19432, "o", "> "]
[385.194346, "o", "    Ok(out)\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[385.194366, "o", "\u001b[?2004h"]
[385.194446, "o", "> \r\n"]
[385.194497, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[385.194731, "o", "fn gather_ts(dir: &Path, out: &mut Vec<PathBuf>) -> Result<(), String> {\r\n\u001b[?2004l\r"]
[385.194827, "o", "\u001b[?2004h> "]
[385.195044, "o", "    let entries = fs::read_dir(dir).map_err(|e| format!(\"scan {}: {e}\", dir.display()))?;\r\n\u001b[?2004l\r"]
[385.195081, "o", "\u001b[?2004h> "]
[385.195186, "o", "    for item in entries {\r\n\u001b[?2004l\r"]
[385.19522, "o", "\u001b[?2004h> "]
[385.195314, "o", "        let path = item\r\n\u001b[?2004l\r"]
[385.195341, "o", "\u001b[?2004h"]
[385.195362, "o", "> "]
[385.195584, "o", "            .map_err(|e| format!(\"scan {}: {e}\", dir.display()))?\r\n\u001b[?2004l\r"]
[385.195612, "o", "\u001b[?2004h> "]
[385.195708, "o", "            .path();\r\n\u001b[?2004l\r"]
[385.195738, "o", "\u001b[?2004h"]
[385.195761, "o", "> "]
[385.195863, "o", "        if path.is_dir() {\r\n\u001b[?2004l\r"]
[385.195888, "o", "\u001b[?2004h"]
[385.19591, "o", "> "]
[385.196065, "o", "            gather_ts(&path, out)?;\r\n\u001b[?2004l\r"]
[385.196095, "o", "\u001b[?2004h> "]
[385.196354, "o", "        } else if path.extension().and_then(|s| s.to_str()) == Some(\"ts\") {\r\n\u001b[?2004l\r"]
[385.196382, "o", "\u001b[?2004h"]
[385.196404, "o", "> "]
[385.196503, "o", "            out.push(path);\r\n\u001b[?2004l\r"]
[385.196532, "o", "\u001b[?2004h"]
[385.196553, "o", "> "]
[385.196633, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.196659, "o", ">     }\r\n"]
[385.196681, "o", "\u001b[?2004l\r"]
[385.196782, "o", "\u001b[?2004h>     Ok(())\r\n\u001b[?2004l\r"]
[385.196816, "o", "\u001b[?2004h> }"]
[385.196847, "o", "\r\n\u001b[?2004l\r"]
[385.196932, "o", "\u001b[?2004h> "]
[385.196993, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.19719, "o", "fn file_to_app(path: &Path) -> Result<String, String> {\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.197339, "o", "> "]
[385.197462, "o", "    let abs = path\r\n\u001b[?2004l\r\u001b[?2004h>         .canonicalize()\r\n\u001b[?2004l\r"]
[385.197574, "o", "\u001b[?2004h> "]
[385.197713, "o", "        .map_err(|e| format!(\"resolve {}: {e}\", path.display()))?;\r\n\u001b[?2004l\r"]
[385.197797, "o", "\u001b[?2004h> "]
[385.197911, "o", "    Ok(abs.to_string_lossy().to_string())\r\n\u001b[?2004l\r"]
[385.198026, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.198109, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.19825, "o", "fn source_for(path: &Path) -> Result<String, String> {\r\n\u001b[?2004l\r"]
[385.198392, "o", "\u001b[?2004h> "]
[385.198593, "o", "    let text = fs::read_to_string(path).map_err(|e| format!(\"read {}: {e}\", path.display()))?;\r\n\u001b[?2004l\r"]
[385.198684, "o", "\u001b[?2004h> "]
[385.198786, "o", "    for raw in text.lines().take(4) {\r\n\u001b[?2004l\r"]
[385.198873, "o", "\u001b[?2004h> "]
[385.198986, "o", "        let line = raw.trim();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.199171, "o", "        if let Some(rest) = line.strip_prefix(\"// origin:\") {\r\n\u001b[?2004l\r"]
[385.199277, "o", "\u001b[?2004h> "]
[385.199385, "o", "            return Ok(app_path(rest.trim()));\r\n\u001b[?2004l\r"]
[385.199491, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h"]
[385.199583, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.199664, "o", "    file_to_app(path)\r\n\u001b[?2004l\r"]
[385.199767, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[385.19985, "o", "\u001b[?2004h> "]
[385.200108, "o", "fn exported_symbols(text: &str) -> Vec<(usize, String)> {\r\n\u001b[?2004l\r"]
[385.200232, "o", "\u001b[?2004h>     let mut out = Vec::new();\r\n\u001b[?2004l\r"]
[385.200343, "o", "\u001b[?2004h> "]
[385.200505, "o", "    for (idx, raw) in text.lines().enumerate() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[385.2006, "o", "        let line = raw.trim_start();\r\n\u001b[?2004l\r"]
[385.200702, "o", "\u001b[?2004h> "]
[385.200842, "o", "        for prefix in [\"export const \", \"export function \"] {\r\n\u001b[?2004l\r"]
[385.20091, "o", "\u001b[?2004h> "]
[385.201099, "o", "            if let Some(rest) = line.strip_prefix(prefix) {\r\n\u001b[?2004l\r"]
[385.201181, "o", "\u001b[?2004h> "]
[385.201293, "o", "                let symbol: String = rest\r\n\u001b[?2004l\r"]
[385.201414, "o", "\u001b[?2004h> "]
[385.201513, "o", "                    .chars()\r\n\u001b[?2004l\r"]
[385.201614, "o", "\u001b[?2004h> "]
[385.201761, "o", "                    .take_while(|c| c.is_ascii_alphanumeric() || *c == '_')\r\n\u001b[?2004l\r"]
