[?2004l[?2004h> 
[?2004l[?2004h> fn better(a: &Entry, b: &Entry) -> bool {
[?2004l[?2004h>     (a.epoch, &a.path, a.line) > (b.epoch, &b.path, b.line)
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> pub fn mote_e(state: &mut State, symbol: &str, expect_found: bool) -> Observation {
[?2004l[?2004h>     // Find the definition that would be visible *now* after preceding edits.
[?2004l[?2004h>     // Restrict to currently-active slot roots and pick the newest entry.
[?2004l[?2004h>     let mut best: Option<Entry> = None;
[?2004l[?2004h>     for entry in &state.entries {
[?2004l[?2004h>         if entry.symbol != symbol {
[?2004l[?2004h>             continue;
[?2004l[?2004h>         }
[?2004l[?2004h>         let Some(root) = state.active.get(&entry.slot) else {
[?2004l[?2004h>             continue;
[?2004l[?2004h>         };
[?2004l[?2004h>         if !entry.path.starts_with(root) {
[?2004l[?2004h>             continue;
[?2004l[?2004h>         }
[?2004l[?2004h>         match &best {
[?2004l[?2004h>             None => best = Some(entry.clone()),
[?2004l[?2004h>             Some(prev) => {
[?2004l[?2004h>                 if better(entry, prev) {
[?2004l[?2004h>                     best = Some(entry.clone());
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     if let Some(entry) = best {
[?2004l[?2004h>         let reused = state
[?2004l[?2004h>             .last_seen
[?2004l[?2004h>             .get(symbol)
[?2004l[?2004h>             .map(|old| *old == entry.handle)
[?2004l[?2004h>             .unwrap_or(false);
[?2004l[?2004h>         state.last_seen.insert(symbol.to_string(), entry.handle);
[?2004l[?2004h>         Observation {
[?2004l[?2004h>             label: String::new(),
[?2004l[?2004h>             symbol: symbol.to_string(),
[?2004l[?2004h>             found: true,
[?2004l[?2004h>             path: entry.path,
[?2004l[?2004h>             source: entry.source,
[?2004l[?2004h>             line: entry.line,
[?2004l[?2004h>             // Epoch is the harness epoch at query time.
[?2004l[?2004h>             epoch: state.epoch,
[?2004l[?2004h>             reused,
[?2004l[?2004h>             // By construction this is the visible, current definition.
[?2004l[?2004h>             fresh: true,
[?2004l[?2004h>         }
[?2004l[?2004h>     } else {
[?2004l[?2004h>         // For queries this is stale; for misses it's fresh.
[?2004l[?2004h>         Observation::missing("", symbol, state.epoch, !expect_found)
[?2004l[?2004h>     }
[?2004l[?2004h> }
[?2004l[?2004h> EOF
