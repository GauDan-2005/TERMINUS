[519.254021, "o", "\u001b[?2004h"]
[519.254044, "o", "> "]
[519.25426, "o", "            // Epoch is the harness epoch at query time.\r\n\u001b[?2004l\r"]
[519.254287, "o", "\u001b[?2004h"]
[519.254309, "o", "> "]
