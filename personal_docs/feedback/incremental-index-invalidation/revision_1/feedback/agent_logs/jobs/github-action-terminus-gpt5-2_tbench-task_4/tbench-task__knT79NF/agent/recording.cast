[519.251506, "o", "\u001b[?2004h"]
[519.251531, "o", "> "]
[519.251761, "o", "            .map(|old| *old == entry.handle)\r\n\u001b[?2004l\r"]
[519.251852, "o", "\u001b[?2004h"]
[519.251875, "o", "> "]
[519.252055, "o", "            .unwrap_or(false);\r\n\u001b[?2004l\r"]
[519.252131, "o", "\u001b[?2004h"]
[519.252155, "o", "> "]
[519.252496, "o", "        state.last_seen.insert(symbol.to_string(), entry.handle);\r\n\u001b[?2004l\r"]
[519.252612, "o", "\u001b[?2004h> "]
[519.25272, "o", "        Observation {\r\n\u001b[?2004l\r"]
[519.252744, "o", "\u001b[?2004h"]
[519.252832, "o", "> "]
