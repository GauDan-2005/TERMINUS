[326.829798, "i", "cat > /app/r4/e.rs <<'EOF'\nuse crate::model::{Observation, State};\n\npub fn mote_e(a: &mut State, b: &str, c: bool) -> Observation {\n    // Find the definition that would be visible *now* after preceding edits.\n    // Restrict to currently-active slot roots and pick the newest entry.\n    let mut best = None;\n    for entry in &a.entries {\n        if entry.symbol != b {\n            continue;\n        }\n        let Some(root) = a.active.get(&entry.slot) else {\n            continue;\n        };\n        if !entry.path.starts_with(root) {\n            continue;\n        }\n        let replace = match &best {\n            None => true,\n            Some(prev) => (entry.epoch, &entry.path, entry.line) > (prev.epoch, &prev.path, prev.line),\n        };\n        if replace {\n            best = Some(entry.clone());\n        }\n    }\n\n    if let Some(entry) = best {\n        let reused = a\n            .last_seen\n            .get(b)\n            .map(|old| *old == entry.handle)\n            .unwrap_or(false);\n        a.last_seen.insert(b.to_string(), entry.handle);\n        Observation {\n            label: String::new(),\n            symbol: b.to_string(),\n            found: true,\n            path: entry.path,\n            source: entry.source,\n            line: entry.line,\n            // Epoch is the harness epoch at query time.\n            epoch: a.epoch,\n            reused,\n            // By construction this is the visible, current definition.\n            fresh: true,\n        }\n    } else {\n        // For queries (c=true) this is stale; for misses (c=false) this is fresh.\n        Observation::missing(\"\", b, a.epoch, !c)\n    }\n}\nEOF\n"]
