[89.843615, "o", "            .map(|root| entry.path.starts_with(root))\r\n            .unwrap_or(false);\r\n        Observation {\r\n            label: String::new(),\r\n            symbol: b.to_string(),\r\n            found: true,\r\n            path: entry.path.clone(),\r\n            source: entry.source.clone(),\r\n            line: entry.line,\r\n            epoch: entry.epoch,\r\n            reused,\r\n            fresh,\r\n        }\r\n    } else {\r\n        Observation::missing(b, b, a.epoch, !c)\r\n    }\r\n}\r\n"]
