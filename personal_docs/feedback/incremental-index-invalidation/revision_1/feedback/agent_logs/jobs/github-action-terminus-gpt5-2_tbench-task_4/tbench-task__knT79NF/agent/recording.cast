[639.564916, "i", "python3 - <<'PY'\nimport json\np='/app/output/index-report.json'\nwith open(p) as f:\n    data=json.load(f)\nbad=[]\nfor c in data['cases']:\n    if (not c['ok']) or c['stale']:\n        bad.append((c['name'], c['ok'], c['stale']))\nprint('bad', len(bad))\nfor name, ok, stale in bad:\n    print(name, ok, stale)\nPY\n"]
