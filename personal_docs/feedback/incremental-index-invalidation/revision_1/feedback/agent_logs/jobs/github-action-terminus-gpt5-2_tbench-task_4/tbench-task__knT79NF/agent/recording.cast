[519.241865, "i", "cat > /app/r4/e.rs <<'EOF'\nuse crate::model::{Entry, Observation, State};\n\nfn better(a: &Entry, b: &Entry) -> bool {\n    (a.epoch, &a.path, a.line) > (b.epoch, &b.path, b.line)\n}\n\npub fn mote_e(state: &mut State, symbol: &str, expect_found: bool) -> Observation {\n    // Find the definition that would be visible *now* after preceding edits.\n    // Restrict to currently-active slot roots and pick the newest entry.\n    let mut best: Option<Entry> = None;\n    for entry in &state.entries {\n        if entry.symbol != symbol {\n            continue;\n        }\n        let Some(root) = state.active.get(&entry.slot) else {\n            continue;\n        };\n        if !entry.path.starts_with(root) {\n            continue;\n        }\n        match &best {\n            None => best = Some(entry.clone()),\n            Some(prev) => {\n                if better(entry, prev) {\n                    best = Some(entry.clone());\n                }\n            }\n        }\n    }\n\n    if let Some(entry) = best {\n        let reused = state\n            .last_seen\n            .get(symbol)\n            .map(|old| *old == entry.handle)\n            .unwrap_or(false);\n        state.last_seen.insert(symbol.to_string(), entry.handle);\n        Observation {\n            label: String::new(),\n            symbol: symbol.to_string(),\n            found: true,\n            path: entry.path,\n            source: entry.source,\n            line: entry.line,\n            // Epoch is the harness epoch at query time.\n            epoch: state.epoch,\n            reused,\n            // By construction this is the visible, current definition.\n            fresh: true,\n        }\n    } else {\n        // For queries this is stale; for misses it's fresh.\n        Observation::missing(\"\", symbol, state.epoch, !expect_found)\n    }\n}\nEOF\n"]
