[130.260707, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: r3/d.rs\n@@\n pub fn lift_d(a: &mut State, b: &str, c: &str) -> Result<(), String> {\n     a.epoch += 1;\n-    let shown = app_path(c);\n     let actual = resolve_target_root(c)?;\n-    a.active.insert(b.to_string(), shown);\n+    // For linked-package slots, follow the active target. Queries should resolve\n+    // to the currently linked package contents, not the alias path.\n+    a.active.insert(b.to_string(), actual.clone());\n     let mut found = collect_entries(a, b, &actual, a.epoch)?;\n     a.entries.append(&mut found);\n     Ok(())\n }\n*** End Patch\nPATCH\n"]
