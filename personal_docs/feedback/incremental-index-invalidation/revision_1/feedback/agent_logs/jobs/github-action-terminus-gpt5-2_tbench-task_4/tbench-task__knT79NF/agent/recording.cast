[80.393303, "o", "sed -n '1,200p' /app/src/main.rs\r\n\u001b[?2004l\r"]
[80.394502, "o", "use std::env;\r\nuse std::path::PathBuf;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().skip(1).collect();\r\n    if args.len() < 2 {\r\n        eprintln!(\"usage: idxlab <report> <trace> [trace ...]\");\r\n        std::process::exit(2);\r\n    }\r\n    let out = PathBuf::from(&args[0]);\r\n    let traces: Vec<PathBuf> = args[1..].iter().map(PathBuf::from).collect();\r\n    if let Err(err) = idxlab::runner::run_all(&out, &traces) {\r\n        eprintln!(\"{err}\");\r\n        std::process::exit(1);\r\n"]
[80.394547, "o", "    }\r\n}\r\n"]
[80.394736, "o", "\u001b[?2004h"]
[80.394932, "o", "root@cf8c7351aaa9:/app# "]
[80.517344, "i", "sed -n '1,260p' /app/src/lib.rs\n"]
[80.517716, "o", "sed -n '1,260p' /app/src/lib.rs\r\n\u001b[?2004l\r"]
[80.519037, "o", "pub mod io;\r\npub mod model;\r\npub mod report;\r\npub mod runner;\r\n\r\n#[path = \"../r0/a.rs\"]\r\npub mod r0_a;\r\n#[path = \"../r1/b.rs\"]\r\npub mod r1_b;\r\n#[path = \"../r2/c.rs\"]\r\npub mod r2_c;\r\n#[path = \"../r3/d.rs\"]\r\npub mod r3_d;\r\n#[path = \"../r4/e.rs\"]\r\npub mod r4_e;\r\n#[path = \"../r5/f.rs\"]\r\npub mod r5_f;\r\n#[path = \"../r6/g.rs\"]\r\npub mod r6_g;\r\n#[path = \"../r7/h.rs\"]\r\npub mod r7_h;\r\n#[path = \"../r8/i.rs\"]\r\npub mod r8_i;\r\n"]
[80.519251, "o", "\u001b[?2004h"]
[80.519455, "o", "root@cf8c7351aaa9:/app# "]
[80.649529, "i", "sed -n '1,260p' /app/src/runner.rs\n"]
[80.651433, "o", "sed -n '1,260p' /app/src/runner.rs"]
[80.651755, "o", "\r\n\u001b[?2004l\r"]
[80.652898, "o", "use crate::io::read_trace;\r\nuse crate::model::{CaseReport, State};\r\nuse crate::report::write_report;\r\nuse crate::r0_a::phase_a;\r\nuse std::path::{Path, PathBuf};\r\n\r\npub fn run_all(out: &Path, traces: &[PathBuf]) -> Result<(), String> {\r\n    let mut cases = Vec::new();\r\n"]
[80.653056, "o", "    for trace in traces {\r\n        cases.push(run_one(trace)?);\r\n    }\r\n    write_report(out, &cases)\r\n}\r\n\r\nfn run_one(trace: &Path) -> Result<CaseReport, String> {\r\n    let name = trace\r\n        .file_stem()\r\n        .and_then(|s| s.to_str())\r\n        .ok_or_else(|| format!(\"trace name: {}\", trace.display()))?\r\n        .to_string();\r\n    let events = read_trace(trace)?;\r\n    let mut state = State::new();\r\n    let mut case = CaseReport {\r\n        name,\r\n        ok: true,\r\n        observations: Vec::new(),\r\n        stale: Vec::new(),\r\n    };\r\n    for event in events {\r\n        phase_a(&mut state, &event, &mut case)?;\r\n    }\r\n    case.ok = case.stale.is_empty();\r\n    Ok(case)\r\n}\r\n"]
[80.653211, "o", "\u001b[?2004hroot@cf8c7351aaa9:/app# "]
[80.773462, "i", "sed -n '1,320p' /app/src/report.rs\n"]
[80.773815, "o", "sed -n '1,320p' /app/src/report.rs\r\n\u001b[?2004l\r"]
[80.775254, "o", "use crate::model::{CaseReport, Observation};\r\nuse std::fs;\r\nuse std::path::Path;\r\n\r\npub fn write_report(out: &Path, cases: &[CaseReport]) -> Result<(), String> {\r\n    if let Some(parent) = out.parent() {\r\n        fs::create_dir_all(parent).map_err(|e| format!(\"create {}: {e}\", parent.display()))?;\r\n    }\r\n    let mut text = String::new();\r\n    text.push_str(\"{\\n  \\\"cases\\\": [\\n\");\r\n    for (idx, case) in cases.iter().enumerate() {\r\n        if idx > 0 {\r\n            text.push_str(\",\\n\");\r\n        }\r\n        text.push_str(&case_json(case));\r\n    }\r\n    text.push_str(\"\\n  ]\\n}\\n\");\r\n    fs::write(out, text).map_err(|e| format!(\"write {}: {e}\", out.display()))\r\n}\r\n\r\nfn case_json(case: &CaseReport) -> String {\r\n    let mut text = String::new();\r\n    text.push_str(\"    {\\n\");\r\n    text.push_str(&format!(\"      \\\"name\\\": {},\\n\", quoted(&case.name)));\r\n    text.push_str(&format!(\"      \\\"ok\\\": {},\\n\", bool_text(case.ok)));\r\n    text.push_str(\"      \\\"observations\\\": [\\n\");\r\n    for (idx, obs) in case.observations.iter().enumerate() {\r\n        if idx > 0 {\r\n            text.push_str(\",\\n\");\r\n        }\r\n        text.push_str(&observation_json(obs));\r\n    }\r\n    text.push_str(\"\\n      ],\\n\");\r\n    text.push_str(\"      \\\"stale\\\": [\");\r\n    for (idx, item) in case.stale.iter().enumerate() {\r\n        if idx > 0 {\r\n            text.push_str(\", \");\r\n        }\r\n"]
[80.775484, "o", "        text.push_str(&quoted(item));\r\n    }\r\n    text.push_str(\"]\\n\");\r\n    text.push_str(\"    }\");\r\n    text\r\n}\r\n\r\nfn observation_json(obs: &Observation) -> String {\r\n    format!(\r\n        \"        {{\\\"label\\\": {}, \\\"symbol\\\": {}, \\\"found\\\": {}, \\\"path\\\": {}, \\\"source\\\": {}, \\\"line\\\": {}, \\\"epoch\\\": {}, \\\"reused\\\": {}, \\\"fresh\\\": {}}}\",\r\n        quoted(&obs.label),\r\n        quoted(&obs.symbol),\r\n        bool_text(obs.found),\r\n        quoted(&obs.path),\r\n        quoted(&obs.source),\r\n        obs.line,\r\n        obs.epoch,\r\n        bool_text(obs.reused),\r\n        bool_text(obs.fresh),\r\n    )\r\n}\r\n\r\nfn bool_text(value: bool) -> &'static str {\r\n    if value {\r\n        \"true\"\r\n    } else {\r\n        \"false\"\r\n    }\r\n}\r\n\r\nfn quoted(value: &str) -> String {\r\n    let mut out = String::from(\"\\\"\");\r\n    for ch in value.chars() {\r\n        match ch {\r\n            '\\\\' => out.push_str(\"\\\\\\\\\"),\r\n            '\"' => out.push_str(\"\\\\\\\"\"),\r\n            '\\n' => out.push_str(\"\\\\n\"),\r\n            '\\r' => out.push_str(\"\\\\r\"),\r\n            '\\t' => out.push_str(\"\\\\t\"),\r\n            _ => out.push(ch),\r\n        }\r\n    }\r\n    out.push('\"');\r\n    out\r\n}\r\n"]
