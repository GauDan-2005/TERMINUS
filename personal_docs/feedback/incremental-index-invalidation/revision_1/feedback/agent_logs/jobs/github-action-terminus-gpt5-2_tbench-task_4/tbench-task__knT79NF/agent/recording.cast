[80.897257, "o", "#[derive(Clone, Debug)]\r\npub struct Event {\r\n    pub kind: String,\r\n    pub left: String,\r\n    pub right: String,\r\n}\r\n\r\n#[derive(Clone, Debug)]\r\npub struct Observation {\r\n    pub label: String,\r\n    pub symbol: String,\r\n    pub found: bool,\r\n    pub path: String,\r\n    pub source: String,\r\n    pub line: usize,\r\n    pub epoch: u64,\r\n    pub reused: bool,\r\n    pub fresh: bool,\r\n}\r\n\r\n"]
[80.897281, "o", "#[derive(Clone, Debug)]\r\npub struct CaseReport {\r\n    pub name: String,\r\n    pub ok: bool,\r\n    pub observations: Vec<Observation>,\r\n    pub stale: Vec<String>,\r\n"]
[80.89731, "o", "}\r\n\r\n#[derive(Debug)]\r\npub struct State {\r\n    pub entries: Vec<Entry>,\r\n    pub active: BTreeMap<String, String>,\r\n    pub handles: BTreeMap<String, u64>,\r\n    pub last_seen: BTreeMap<String, u64>,\r\n    pub next_handle: u64,\r\n"]
[80.897335, "o", "    pub epoch: u64,\r\n}\r\n\r\nimpl State {\r\n    pub fn new() -> Self {\r\n        Self {\r\n            entries: Vec::new(),\r\n"]
[80.897374, "o", "            active: BTreeMap::new(),\r\n            handles: BTreeMap::new(),\r\n            last_seen: BTreeMap::new(),\r\n            next_handle: 1,\r\n            epoch: 0,\r\n"]
[80.897398, "o", "        }\r\n    }\r\n\r\n    pub fn key_for(slot: &str, path: &str, symbol: &str) -> String {\r\n        format!(\"{slot}|{path}|{symbol}\")\r\n    }\r\n\r\n    pub fn handle_for(&mut self, slot: &str, path: &str, symbol: &str) -> u64 {\r\n        let key = Self::key_for(slot, path, symbol);\r\n        if let Some(value) = self.handles.get(&key) {\r\n"]
[80.89742, "o", "            *value\r\n        } else {\r\n            let value = self.next_handle;\r\n            self.next_handle += 1;\r\n            self.handles.insert(key, value);\r\n            value\r\n"]
[80.897471, "o", "        }\r\n    }\r\n}\r\n\r\nimpl Observation {\r\n    pub fn missing(label: &str, symbol: &str, epoch: u64, fresh: bool) -> Self {\r\n        Self {\r\n"]
[80.897497, "o", "            label: label.to_string(),\r\n            symbol: symbol.to_string(),\r\n            found: false,\r\n            path: String::new(),\r\n            source: String::new(),\r\n            line: 0,\r\n            epoch,\r\n            reused: false,\r\n            fresh,\r\n        }\r\n    }\r\n}\r\n"]
