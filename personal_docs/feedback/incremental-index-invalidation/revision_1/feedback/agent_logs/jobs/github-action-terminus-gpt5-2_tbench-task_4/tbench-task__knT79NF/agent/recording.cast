[326.836925, "o", "> "]
[326.837117, "o", "            .map(|old| *old == entry.handle)\r\n\u001b[?2004l\r"]
[326.837158, "o", "\u001b[?2004h> "]
[326.837341, "o", "            .unwrap_or(false);"]
[326.837458, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[326.837585, "o", "> "]
[326.837755, "o", "        a.last_seen.insert(b.to_string(), entry.handle);\r\n\u001b[?2004l\r"]
[326.837805, "o", "\u001b[?2004h> "]
[326.838005, "o", "        Observation {\r\n\u001b[?2004l\r\u001b[?2004h>             label: String::new(),\r\n"]
[326.838048, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[326.838234, "o", "            symbol: b.to_string(),\r\n\u001b[?2004l\r"]
[326.838375, "o", "\u001b[?2004h>             found: true,\r\n\u001b[?2004l\r\u001b[?2004h"]
[326.83852, "o", ">             path: entry.path,\r\n\u001b[?2004l\r"]
[326.838638, "o", "\u001b[?2004h>             source: entry.source,\r\n\u001b[?2004l\r"]
[326.838675, "o", "\u001b[?2004h> "]
[326.838846, "o", "            line: entry.line,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[326.839052, "o", "            // Epoch is the harness epoch at query time.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[326.839142, "o", "            epoch: a.epoch,\r\n\u001b[?2004l\r"]
[326.839234, "o", "\u001b[?2004h> "]
[326.839364, "o", "            reused,\r\n\u001b[?2004l\r\u001b[?2004h"]
[326.839411, "o", "> "]
[326.839551, "o", "            // By construction this is the visible, current definition.\r\n\u001b[?2004l\r"]
[326.839587, "o", "\u001b[?2004h> "]
[326.839674, "o", "            fresh: true,\r\n\u001b[?2004l\r"]
[326.839763, "o", "\u001b[?2004h> "]
[326.839808, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[326.839973, "o", "    } else {\r\n\u001b[?2004l\r"]
[326.840014, "o", "\u001b[?2004h> "]
[326.840175, "o", "        // For queries (c=true) this is stale; for misses (c=false) this is fresh.\r\n\u001b[?2004l\r"]
[326.840206, "o", "\u001b[?2004h> "]
[326.840444, "o", "        Observation::missing(\"\", b, a.epoch, !c)\r\n\u001b[?2004l\r"]
[326.840512, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[326.840566, "o", "> EOF\r\n\u001b[?2004l\r"]
[326.84204, "o", "\u001b[?2004hroot@cf8c7351aaa9:/app# "]
[326.953483, "i", "cat > /app/r5/f.rs <<'EOF'\nuse crate::model::{Observation, State};\n\npub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\n    // c=true means the trace expects the symbol to be found (query).\n    // c=false means the trace expects the symbol to be absent (miss).\n    if c {\n        if b.found {\n            if b.fresh {\n                (b, None)\n            } else {\n                (b, Some(format!(\"stale: {} resolved to non-current definition\", b.symbol)))\n            }\n        } else {\n            (b, Some(format!(\"stale: {} was not found\", b.symbol)))\n        }\n    } else if b.found {\n        (b, Some(format!(\"stale: {} was found but should be missing\", b.symbol)))\n    } else {\n        (b, None)\n    }\n}\nEOF\n"]
[326.953811, "o", "cat > /app/r5/f.rs <<'EOF'\r\n\u001b[?2004l\r"]
[326.953857, "o", "\u001b[?2004h"]
[326.953883, "o", "> "]
[326.954282, "o", "use crate::model::{Observation, State};\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[326.957994, "o", "pub fn cast_f(_a: &State, b: Observation, c: bool) -> (Observation, Option<String>) {\r\n\u001b[?2004l\r\u001b[?2004h>     // c=true means the trace expects the symbol to be found (query).\r\n\u001b[?2004l\r\u001b[?2004h>     // c=false means the trace expects the symbol to be absent (miss).\r\n\u001b[?2004l\r\u001b[?2004h>     if c {\r\n\u001b[?2004l\r\u001b[?2004h>         if b.found {\r\n\u001b[?2004l\r\u001b[?2004h>             if b.fresh {\r\n\u001b[?2004l\r\u001b[?2004h>                 (b, None)\r\n\u001b[?2004l\r\u001b[?2004h>             } else {\r\n\u001b[?2004l\r\u001b[?2004h>                 (b, Some(format!(\"stale: {} resolved to non-current definition\", b.symbol)))\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>         } else {\r\n\u001b[?2004l\r\u001b[?2004h>             (b, Some(format!(\"stale: {} was not found\", b.symbol)))\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     } else if b.found {\r\n\u001b[?2004l\r\u001b[?2004h>         (b, Some(format!(\"stale: {} was found but should be missing\", b.symbol)))\r\n\u001b[?2004l\r\u001b[?2004h>     } else {\r\n\u001b[?2004l\r\u001b[?2004h>         (b, None)\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
