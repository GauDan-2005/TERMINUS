[326.693768, "i", "cat > /app/r3/d.rs <<'EOF'\nuse crate::io::{collect_entries, resolve_target_root};\nuse crate::model::State;\n\npub fn lift_d(a: &mut State, b: &str, c: &str) -> Result<(), String> {\n    a.epoch += 1;\n    let actual = resolve_target_root(c)?;\n    // Follow the active target for linked-package slots.\n    a.active.insert(b.to_string(), actual.clone());\n    let mut found = collect_entries(a, b, &actual, a.epoch)?;\n    a.entries.append(&mut found);\n    Ok(())\n}\nEOF\n"]
[326.694477, "o", "cat > /app/r3/d.rs <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> use crate::io::{collect_entries, resolve_target_root};\r\n\u001b[?2004l\r\u001b[?2004h> "]
