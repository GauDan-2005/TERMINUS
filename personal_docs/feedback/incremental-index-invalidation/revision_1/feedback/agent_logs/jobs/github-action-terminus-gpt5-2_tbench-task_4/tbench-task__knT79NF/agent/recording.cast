[519.257454, "o", "\u001b[?2004hroot@cf8c7351aaa9:/app# "]
[519.37347, "i", "cat > /app/r5/f.rs <<'EOF'\nuse crate::model::{Observation, State};\n\npub fn cast_f(_a: &State, obs: Observation, expect_found: bool) -> (Observation, Option<String>) {\n    if expect_found {\n        if obs.found {\n            if obs.fresh {\n                (obs, None)\n            } else {\n                let sym = obs.symbol.clone();\n                (obs, Some(format!(\"stale: {} resolved to non-current definition\", sym)))\n            }\n        } else {\n            let sym = obs.symbol.clone();\n            (obs, Some(format!(\"stale: {} was not found\", sym)))\n        }\n    } else {\n        if obs.found {\n            let sym = obs.symbol.clone();\n            (obs, Some(format!(\"stale: {} was found but should be missing\", sym)))\n        } else {\n            (obs, None)\n        }\n    }\n}\nEOF\n"]
