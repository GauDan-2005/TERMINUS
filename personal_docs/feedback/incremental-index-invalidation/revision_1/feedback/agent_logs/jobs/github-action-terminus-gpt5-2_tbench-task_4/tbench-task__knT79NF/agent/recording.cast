[97.320619, "o", "use std::path::{Path, PathBuf};\r\n\r\npub fn lift_h(base: &Path, value: &str) -> PathBuf {\r\n    let candidate = PathBuf::from(value);\r\n    if candidate.is_absolute() {\r\n        candidate\r\n    } else {\r\n        base.join(candidate)\r\n    }\r\n}\r\n"]
[97.320856, "o", "\u001b[?2004hroot@cf8c7351aaa9:/app# "]
