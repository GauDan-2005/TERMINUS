[519.254933, "o", "\u001b[?2004h"]
[519.254958, "o", "> "]
[519.255054, "o", "            fresh: true,\r\n\u001b[?2004l\r"]
[519.25508, "o", "\u001b[?2004h"]
[519.255104, "o", "> "]
[519.255186, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[519.255239, "o", "    } else {\r\n\u001b[?2004l\r"]
[519.255267, "o", "\u001b[?2004h> "]
