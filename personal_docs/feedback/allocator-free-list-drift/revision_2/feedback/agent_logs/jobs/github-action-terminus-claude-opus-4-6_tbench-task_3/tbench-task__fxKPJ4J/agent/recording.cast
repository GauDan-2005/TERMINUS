[608.226335, "o", "    return ftr[0];\r\n\u001b[?2004l\r"]
[608.228094, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@9bc1d408efaf:/app# "]
[608.354168, "i", "cat > /app/move_d/move.c << 'EOF'\n#include <stddef.h>\n#include <string.h>\n\nint xc2(void *a, void *b, size_t c) {\n    memcpy(a, b, c);\n    return (int)c;\n}\nEOF\n"]
[608.357429, "o", "cat > /app/move_d/move.c << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include <stddef.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include <string.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> int xc2(void *a, void *b, size_t c) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[608.357495, "o", ">     memcpy(a, b, c);\r\n\u001b[?2004l\r\u001b[?2004h>     return (int)c;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@9bc1d408efaf:/app# "]
[608.470336, "i", "cat > /app/acct_e/acct.c << 'EOF'\n#include \"../include/stats.h\"\n\n#include <stddef.h>\n#include <sys/types.h>\n\nvoid xd3(Stats *a, ssize_t b) {\n    if (b > 0) {\n        a->allocated += (size_t)b;\n    } else {\n        a->allocated -= (size_t)(-b);\n    }\n    if (a->allocated > a->peak) {\n        a->peak = a->allocated;\n    }\n}\nEOF\n"]
[608.470682, "o", "cat > /app/acct_e/acct.c << 'EOF'\r\n\u001b[?2004l\r"]
