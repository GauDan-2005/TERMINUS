[638.056696, "o", "\u001b[?2004h"]
[638.056719, "o", "> "]
[638.056867, "o", "    return total;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[638.056955, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[638.057005, "o", "\u001b[?2004h> "]
[638.057199, "o", "int run_case(const Plan *plan, const char *out_dir, CaseResult *res) {\r\n\u001b[?2004l\r"]
[638.057268, "o", "\u001b[?2004h> "]
[638.057328, "o", "    Arena arena;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[638.057396, "o", "    int seq = 0;\r\n\u001b[?2004l\r\u001b[?2004h"]
[638.057445, "o", "> "]
[638.058076, "o", "    memset(res, 0, sizeof(*res));\r\n\u001b[?2004l\r\u001b[?2004h"]
[638.058178, "o", ">     strncpy(res->name, plan->name, sizeof(res->name) - 1);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[638.058441, "o", "    snprintf(res->ledger_path, sizeof(res->ledger_path), \"%s/%s.ledger.jsonl\", out_dir, plan->name);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[638.058477, "o", "    arena_init(&arena);\r\n\u001b[?2004l\r\u001b[?2004h"]
[638.058582, "o", "> "]
[638.058687, "o", "    for (int i = 0; i < plan->op_count; i++) {\r\n\u001b[?2004l\r"]
[638.058734, "o", "\u001b[?2004h> "]
[638.058949, "o", "        const PlanOp *op = &plan->ops[i];\r\n\u001b[?2004l\r"]
[638.060158, "o", "\u001b[?2004h>         StepRec *st = &res->steps[res->step_count++];\r\n\u001b[?2004l\r\u001b[?2004h>         st->seq = seq++;\r\n\u001b[?2004l\r\u001b[?2004h>         st->index = op->index;\r\n\u001b[?2004l\r\u001b[?2004h>         st->size = op->size;\r\n\u001b[?2004l\r\u001b[?2004h>         st->result_index = -1;\r\n\u001b[?2004l\r\u001b[?2004h>         if (op->kind == OP_ALLOC) {\r\n\u001b[?2004l\r\u001b[?2004h>             strncpy(st->op, \"alloc\", sizeof(st->op) - 1);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[638.060401, "o", "            st->result_index = arena_slot_alloc(&arena, op->size);\r\n\u001b[?2004l\r"]
[638.060446, "o", "\u001b[?2004h> "]
[638.060621, "o", "        } else if (op->kind == OP_FREE) {"]
[638.061095, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>             strncpy(st->op, \"free\", sizeof(st->op) - 1);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[638.061223, "o", "            st->result_index = arena_slot_free(&arena, op->index);\r\n\u001b[?2004l\r"]
[638.061258, "o", "\u001b[?2004h> "]
[638.061457, "o", "        } else if (op->kind == OP_REALLOC) {\r\n\u001b[?2004l\r"]
[638.061494, "o", "\u001b[?2004h> "]
[638.061726, "o", "            strncpy(st->op, \"realloc\", sizeof(st->op) - 1);\r\n\u001b[?2004l\r"]
[638.06176, "o", "\u001b[?2004h> "]
[638.062077, "o", "            st->result_index = arena_slot_realloc(&arena, op->index, op->size);\r\n\u001b[?2004l\r"]
[638.062198, "o", "\u001b[?2004h> "]
[638.062267, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[638.06238, "o", "        st->heap_sig = arena_heap_sig(&arena);\r\n\u001b[?2004l\r"]
[638.062484, "o", "\u001b[?2004h> "]
[638.062615, "o", "        st->fl_count = arena_fl_count(&arena);\r\n\u001b[?2004l\r"]
[638.062722, "o", "\u001b[?2004h> "]
[638.062817, "o", "        st->fl_sig = arena_fl_sig(&arena);\r\n\u001b[?2004l\r"]
[638.062854, "o", "\u001b[?2004h> "]
[638.063064, "o", "        st->byte_total = compute_byte_total(&arena);\r\n\u001b[?2004l\r\u001b[?2004h"]
[638.063098, "o", ">     }\r\n\u001b[?2004l\r"]
[638.063175, "o", "\u001b[?2004h> "]
[638.063362, "o", "    res->heap_sig = arena_heap_sig(&arena);\r\n\u001b[?2004l\r"]
[638.063396, "o", "\u001b[?2004h> "]
[638.063585, "o", "    res->fl_count = arena_fl_count(&arena);\r\n\u001b[?2004l\r"]
[638.063617, "o", "\u001b[?2004h> "]
[638.063802, "o", "    res->fl_sig = arena_fl_sig(&arena);\r\n\u001b[?2004l\r"]
[638.063833, "o", "\u001b[?2004h> "]
[638.064036, "o", "    res->byte_total = compute_byte_total(&arena);\r\n\u001b[?2004l\r"]
[638.064152, "o", "\u001b[?2004h> "]
[638.064198, "o", "    res->ok = 1;\r\n\u001b[?2004l\r"]
[638.064224, "o", "\u001b[?2004h"]
[638.064248, "o", "> "]
[638.064363, "o", "    return 0;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[638.064392, "o", "}\r\n\u001b[?2004l\r"]
[638.064479, "o", "\u001b[?2004h"]
[638.064504, "o", "> EOF"]
[638.064533, "o", "\r\n\u001b[?2004l\r"]
