[40.643632, "o", "#include <stdio.h>\r\n\r\nvoid mirror_line(const char *label, int v) {\r\n    fprintf(stderr, \"[diag] %s=%d\\n\", label, v);\r\n}\r\n"]
[40.643848, "o", "\u001b[?2004hroot@9bc1d408efaf:/app# "]
