[32.062772, "o", "#include \"../include/plan.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\nint plan_load(const char *path, Plan *out) {\r\n    FILE *fp = fopen(path, \"r\");\r\n    char line[256];\r\n    if (!fp) {\r\n        return -1;\r\n    }\r\n    memset(out, 0, sizeof(*out));\r\n    {\r\n        const char *slash = strrchr(path, '/');\r\n        const char *base = slash ? slash + 1 : path;\r\n"]
[32.062836, "o", "        strncpy(out->name, base, sizeof(out->name) - 1);\r\n        char *dot = strchr(out->name, '.');\r\n        if (dot) {\r\n            *dot = '\\0';\r\n        }\r\n    }\r\n    while (fgets(line, sizeof(line), fp)) {\r\n        char op[32];\r\n        size_t sz = 0;\r\n        int idx = 0;\r\n        int nidx = 0;\r\n        if (line[0] == '#' || line[0] == '\\n') {\r\n            continue;\r\n        }\r\n"]
[32.06289, "o", "        if (sscanf(line, \"ALLOC %zu\", &sz) == 1) {\r\n            PlanOp *p = &out->ops[out->op_count++];\r\n            p->kind = OP_ALLOC;\r\n            p->size = sz;\r\n            p->index = -1;\r\n"]
[32.062914, "o", "        } else if (sscanf(line, \"FREE %d\", &idx) == 1) {\r\n            PlanOp *p = &out->ops[out->op_count++];\r\n            p->kind = OP_FREE;\r\n            p->index = idx;\r\n        } else if (sscanf(line, \"REALLOC %d %zu\", &idx, &sz) == 2) {\r\n            PlanOp *p = &out->ops[out->op_count++];\r\n            p->kind = OP_REALLOC;\r\n            p->index = idx;\r\n"]
[32.06345, "o", "            p->size = sz;\r\n        } else if (sscanf(line, \"%31s %d %zu %d\", op, &idx, &sz, &nidx) >= 2) {\r\n            (void)op;\r\n            (void)nidx;\r\n        }\r\n    }\r\n    fclose(fp);\r\n    return 0;\r\n}\r\n\u001b[?2004hroot@40caee248a2f:/app# "]
[32.175796, "i", "sed -n '1,220p' /app/include/plan.h\n"]
[32.176525, "o", "sed -n '1,220p' /app/include/plan.h\r\n\u001b[?2004l\r"]
[32.177799, "o", "#ifndef PLAN_H\r\n#define PLAN_H\r\n\r\n#include <stddef.h>\r\n\r\n#define MAX_OPS 128\r\n\r\ntypedef enum {\r\n    OP_ALLOC = 1,\r\n    OP_FREE = 2,\r\n    OP_REALLOC = 3\r\n} OpKind;\r\n\r\ntypedef struct PlanOp {\r\n"]
[32.179447, "o", "    OpKind kind;\r\n    size_t size;\r\n    int index;\r\n    int new_index;\r\n} PlanOp;\r\n\r\ntypedef struct Plan {\r\n    char name[32];\r\n    PlanOp ops[MAX_OPS];\r\n    int op_count;\r\n} Plan;\r\n\r\nint plan_load(const char *path, Plan *out);\r\n\r\n#endif\r\n\u001b[?2004hroot@40caee248a2f:/app# "]
