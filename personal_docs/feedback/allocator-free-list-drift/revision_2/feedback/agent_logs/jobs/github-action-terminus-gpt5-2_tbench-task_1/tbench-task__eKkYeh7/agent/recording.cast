[41.794294, "i", "python3 - <<'PY'\nimport json,glob,os\nfrom pathlib import Path\n\naudit='/app/output/alloc-audit.json'\nobj=json.load(open(audit))\nreq_step=['seq','op','index','size','result_index','heap_sig','fl_count','fl_sig','byte_total']\nreq_case=['name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger']\n\nok=True\nfor case in obj['cases']:\n    for k in req_case:\n        if k not in case:\n            print('MISSING case field',case.get('name'),k); ok=False\n    steps=case['steps']\n    for s in steps:\n        for k in req_step:\n            if k not in s:\n                print('MISSING step field',case['name'],s.get('seq'),k); ok=False\n    if steps:\n        last=steps[-1]\n        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n            if case[k]!=last[k]:\n                print('TALLY MISMATCH',case['name'],k,case[k],last[k]); ok=False\n    led=case['ledger']\n    if not os.path.exists(led):\n        print('MISSING ledger file',case['name'],led); ok=False\n    else:\n        with open(led) as f:\n            for i,line in enumerate(f):\n                rec=json.loads(line)\n                for k in req_step:\n                    if k not in rec:\n                        print('MISSING ledger field',case['name'],'line',i,k); ok=False\n                if i>200: break\n\nprint('VALID' if ok else 'INVALID')\nPY\n"]
