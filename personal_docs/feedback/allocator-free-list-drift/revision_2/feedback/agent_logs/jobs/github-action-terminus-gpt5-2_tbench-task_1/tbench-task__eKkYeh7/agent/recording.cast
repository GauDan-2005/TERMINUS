[28.925654, "i", "python3 - <<'PY'\nimport json,sys,os\np='/app/output/alloc-audit.json'\nif not os.path.exists(p):\n    print('NOFILE')\n    sys.exit(0)\nobj=json.load(open(p))\nprint('top_keys',list(obj.keys()))\nprint('cases_len',len(obj.get('cases',[])))\nprint('case_names',[c.get('name') for c in obj.get('cases',[])])\nfor i,c in enumerate(obj.get('cases',[])):\n    missing=[k for k in ['name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'] if k not in c]\n    if missing:\n        print('case',i,'missing',missing)\nPY\n"]
