[499.478407, "i", "cat > /app/move_d/move.c << 'EOF'\n#include <stddef.h>\n#include <string.h>\n\nint xc2(void *a, void *b, size_t c) {\n    unsigned char *dst = (unsigned char *)a;\n    unsigned char *src = (unsigned char *)b;\n    memcpy(dst, src, c);\n    return (int)c;\n}\nEOF\n"]
