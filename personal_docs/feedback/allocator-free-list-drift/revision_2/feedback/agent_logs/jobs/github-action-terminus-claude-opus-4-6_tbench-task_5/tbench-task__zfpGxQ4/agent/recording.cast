[536.952206, "o", "    if (next_off >= a->used) {\r\n\u001b[?2004l\r"]
[536.952282, "o", "\u001b[?2004h> "]
[536.952383, "o", "        return -1;\r\n\u001b[?2004l\r"]
[536.952418, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[536.952548, "o", "    nb.base = oldb->base;\r\n\u001b[?2004l\r"]
[536.952666, "o", "\u001b[?2004h> "]
[536.952704, "o", "    nb.off = next_off;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[536.952797, "o", "    if (z_is_flag(&nb)) {\r\n\u001b[?2004l\r"]
[536.952867, "o", "\u001b[?2004h> "]
[536.95295, "o", "        return -1;\r\n\u001b[?2004l\r\u001b[?2004h"]
[536.953037, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[536.953142, "o", "    ntotal = tag_read_size(&nb);\r\n\u001b[?2004l\r"]
[536.953227, "o", "\u001b[?2004h> "]
[536.953319, "o", "    if (old_total + ntotal < need) {\r\n\u001b[?2004l\r"]
[536.953346, "o", "\u001b[?2004h"]
[536.95337, "o", "> "]
[536.953478, "o", "        return -1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[536.95358, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[536.953673, "o", "    list_remove(a, &nb);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[536.953789, "o", "    *merged_out = old_total + ntotal;\r\n\u001b[?2004l\r"]
[536.953832, "o", "\u001b[?2004h> "]
[536.953938, "o", "    xa0(oldb, *merged_out);\r\n\u001b[?2004l\r"]
[536.954022, "o", "\u001b[?2004h> "]
[536.954145, "o", "    z_set_flag(oldb, 1);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[536.954257, "o", "    return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
