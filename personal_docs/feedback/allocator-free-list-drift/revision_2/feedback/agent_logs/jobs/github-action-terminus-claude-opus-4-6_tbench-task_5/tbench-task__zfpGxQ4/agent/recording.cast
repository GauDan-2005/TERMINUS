[67.705875, "o", "#ifndef ACCT_H\r\n#define ACCT_H\r\n\r\n#include \"../include/stats.h\"\r\n\r\n#include <sys/types.h>\r\n\r\nvoid xd3(Stats *a, ssize_t b);\r\n\r\n#endif\r\n"]
[67.706125, "o", "\u001b[?2004h"]
[67.706313, "o", "root@e737066adb7a:/app# "]
[67.813393, "i", "cat /app/read_f/parse.c\n"]
[67.814097, "o", "cat /app/read_f/parse.c\r\n\u001b[?2004l\r"]
[67.814934, "o", "#include \"../include/plan.h\"\r\n\r\n#include <stdio.h>\r\n#include <string.h>\r\n\r\nint plan_load(const char *path, Plan *out) {\r\n    FILE *fp = fopen(path, \"r\");\r\n    char line[256];\r\n    if (!fp) {\r\n        return -1;\r\n    }\r\n    memset(out, 0, sizeof(*out));\r\n    {\r\n        const char *slash = strrchr(path, '/');\r\n        const char *base = slash ? slash + 1 : path;\r\n        strncpy(out->name, base, sizeof(out->name) - 1);\r\n        char *dot = strchr(out->name, '.');\r\n        if (dot) {\r\n            *dot = '\\0';\r\n        }\r\n    }\r\n    while (fgets(line, sizeof(line), fp)) {\r\n        char op[32];\r\n        size_t sz = 0;\r\n        int idx = 0;\r\n        int nidx = 0;\r\n        if (line[0] == '#' || line[0] == '\\n') {\r\n            continue;\r\n        }\r\n        if (sscanf(line, \"ALLOC %zu\", &sz) == 1) {\r\n            PlanOp *p = &out->ops[out->op_count++];\r\n            p->kind = OP_ALLOC;\r\n            p->size = sz;\r\n            p->index = -1;\r\n        } else if (sscanf(line, \"FREE %d\", &idx) == 1) {\r\n            PlanOp *p = &out->ops[out->op_count++];\r\n            p->kind = OP_FREE;\r\n            p->index = idx;\r\n        } else if (sscanf(line, \"REALLOC %d %zu\", &idx, &sz) == 2) {\r\n            PlanOp *p = &out->ops[out->op_count++];\r\n            p->kind = OP_REALLOC;\r\n            p->index = idx;\r\n            p->size = sz;\r\n        } else if (sscanf(line, \"%31s %d %zu %d\", op, &idx, &sz, &nidx) >= 2) {\r\n            (void)op;\r\n            (void)nidx;\r\n        }\r\n    }\r\n    fclose(fp);\r\n    return 0;\r\n}\r\n"]
[67.816022, "o", "\u001b[?2004hroot@e737066adb7a:/app# "]
[67.9301, "i", "cat /app/spill_i/spill.c\n"]
[67.930407, "o", "cat /app/spill_i/spill.c\r\n"]
[67.930611, "o", "\u001b[?2004l\r"]
[67.931733, "o", "#include <stddef.h>\r\n\r\nsize_t spill_bucket(size_t v) {\r\n    size_t b = 1;\r\n    while (b < v) {\r\n        b <<= 1;\r\n    }\r\n    return b;\r\n}\r\n"]
