[34.819296, "o", "#ifndef MOVE_H\r\n#define MOVE_H\r\n\r\n#include <stddef.h>\r\n\r\nint xc2(void *a, void *b, size_t c);\r\n\r\n#endif\r\n"]
[34.821215, "o", "\u001b[?2004hroot@e737066adb7a:/app# "]
[67.589477, "i", "cat /app/acct_e/acct.c\n"]
[67.589783, "o", "cat /app/acct_e/acct.c\r\n\u001b[?2004l\r"]
[67.590667, "o", "#include \"../include/stats.h\"\r\n\r\n#include <stddef.h>\r\n#include <sys/types.h>\r\n\r\nvoid xd3(Stats *a, ssize_t b) {\r\n    if (b > 0) {\r\n        a->allocated += (size_t)b + 8;\r\n    } else {\r\n        a->allocated -= (size_t)(-b);\r\n    }\r\n    if (a->allocated > a->peak) {\r\n        a->peak = a->allocated;\r\n    }\r\n}\r\n"]
[67.591086, "o", "\u001b[?2004hroot@e737066adb7a:/app# "]
