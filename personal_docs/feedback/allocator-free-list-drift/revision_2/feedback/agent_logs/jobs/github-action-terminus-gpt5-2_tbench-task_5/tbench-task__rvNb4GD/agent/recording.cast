[60.839905, "o", "src/arena_core.c:8:size_t arena_heap_sig(const Arena *a) {\r\nsrc/arena_core.c:27:size_t arena_fl_sig(const Arena *a) {\r\nsrc/arena_core.c:38:int arena_fl_count(const Arena *a) {\r\ninclude/arena.h:31:size_t arena_heap_sig(const Arena *a);\r\ninclude/arena.h:32:size_t arena_fl_sig(const Arena *a);\r\ninclude/arena.h:33:int arena_fl_count(const Arena *a);\r\ninclude/report.h:17:    size_t heap_sig;\r\ninclude/report.h:18:    int fl_count;\r\ninclude/report.h:19:    size_t fl_sig;\r\ninclude/report.h:20:    size_t byte_total;\r\ninclude/report.h:28:    size_t heap_sig;\r\ninclude/report.h:29:    int fl_count;\r\ninclude/report.h:30:    size_t fl_sig;\r\ninclude/report.h:31:    size_t byte_total;\r\n\u001b[?2004hroot@167e824d180e:/app# "]
