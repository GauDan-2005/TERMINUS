[301.046419, "o", "#include \"../include/arena.h\"\r\n"]
[301.046624, "o", "#include \"../list_b/list.h\"\r\n"]
[301.046861, "o", "#include \"../move_d/move.h\"\r\n#include \"../pool_a/tag.h\"\r\n#include \"../split_c/split.h\"\r\n\r\nint arena_slot_alloc(Arena *a, size_t req);\r\nint arena_slot_free(Arena *a, int idx);\r\n\r\nint arena_slot_realloc(Arena *a, int idx, size_t req) {\r\n    if (idx < 0 || idx >= a->slot_count || !a->slot_live[idx]) {\r\n"]
[301.047039, "o", "        return -1;\r\n    }\r\n    Block oldb;\r\n    size_t old_pay;\r\n"]
[301.047301, "o", "    size_t need;\r\n    oldb.base = a->mem;\r\n    oldb.off = (size_t)((unsigned char *)a->slots[idx] - a->mem - HDR_SIZE);\r\n    old_pay = a->slot_payload[idx];\r\n    need = blk_align(req + HDR_SIZE + FTR_SIZE);\r\n    if (need <= tag_read_size(&oldb)) {\r\n        return split_realloc_inplace(a, &oldb, idx, req);\r\n    }\r\n    if (split_grow_inplace(a, &oldb, idx, req, need) >= 0) {\r\n        return idx;\r\n    }\r\n    {\r\n        int nidx = arena_slot_alloc(a, req);\r\n        if (nidx < 0) {\r\n            return -1;\r\n        }\r\n        xc2(a->slots[nidx], a->slots[idx], old_pay);\r\n        arena_slot_free(a, idx);\r\n        return nidx;\r\n    }\r\n}\r\n"]
[301.047374, "o", "\u001b[?2004hroot@167e824d180e:/app# "]
[301.157484, "i", "perl -0777 -i -pe 's/\\{\\n        int nidx = arena_slot_alloc\\(a, req\\);\\n        if \\(nidx < 0\\) \\{\\n            return -1;\\n        \\}\\n        xc2\\(a->slots\\[nidx\\], a->slots\\[idx\\], old_pay\\);\\n        arena_slot_free\\(a, idx\\);\\n        return nidx;\\n    \\}/\\{\\n        int nidx = arena_slot_alloc(a, req);\\n        if (nidx < 0) {\\n            return -1;\\n        }\\n        xc2(a->slots[nidx], a->slots[idx], old_pay);\\n\\n        // Free the old block at idx (this also marks slot_live[idx]=0).\\n        arena_slot_free(a, idx);\\n\\n        // Preserve the original handle (idx) even if we moved.\n        a->slots[idx] = a->slots[nidx];\\n        a->slot_payload[idx] = req;\\n        a->slot_live[idx] = 1;\\n\\n        // Neutralize the temporary slot handle nidx; do not free its block (now owned by idx).\\n        a->slots[nidx] = NULL;\\n        a->slot_payload[nidx] = 0;\\n        a->slot_live[nidx] = 0;\\n\\n        return idx;\\n    \\}/s' src/reloc_ops.c\n"]
[301.159878, "o", "perl -0777 -i -pe 's/\\{\\n        int nidx = arena_slot_alloc\\(a, req\\);\\n        if \\(nidx < 0\\) \\{\\n            return -1;\\n        \\}\\n        xc2\\(a->slots\\[nidx\\], a->slots\\[idx\\], old_pay\\);\\n        arena_slot_free\\(a, idx\\);\\n        return nidx;\\n    \\}/\\{\\n        int nidx = arena_slot_alloc(a, req);\\n        if (nidx < 0) {\\n            return -1;\\n        }\\n        xc2(a->slots[nidx], a->slots[idx], old_pay);\\n\\n        // Free the old block at idx (this also marks slot_live[idx]=0).\\n        arena_slot_free(a, idx);\\n\\n        // Preserve the original handle (idx) even if we moved.\r\n\u001b[?2004l\r"]
[301.160019, "o", "\u001b[?2004h> "]
[301.161265, "o", "        a->slots[idx] = a->slots[nidx];\\n        a->slot_payload[idx] = req;\\n        a->slot_live[idx] = 1;\\n\\n        // Neutralize the temporary slot handle nidx; do not free its block (now owned by idx).\\n        a->slots[nidx] = NULL;\\n        a->slot_payload[nidx] = 0;\\n        a->slot_live[nidx] = 0;\\n\\n        return idx;\\n    \\}/s' src/reloc_ops.c\r\n\u001b[?2004l\r"]
