[60.374395, "i", "sed -n '1,240p' src/init_heap.c\n"]
[60.37486, "o", "sed -n '1,240p' src/init_heap.c\r\n\u001b[?2004l\r"]
[60.37632, "o", "#include \"../include/arena.h\"\r\n#include \"../list_b/list.h\"\r\n#include \"../pool_a/tag.h\"\r\n\r\n#include <string.h>\r\n\r\nvoid arena_init(Arena *a) {\r\n    Block h;\r\n    size_t i;\r\n    memset(a, 0, sizeof(*a));\r\n    for (i = 0; i < FL_MAP_SZ; i++) {\r\n        a->fl_link_next[i] = FL_END;\r\n        a->fl_link_prev[i] = FL_END;\r\n    }\r\n"]
[60.376502, "o", "    a->used = HEAP_BYTES;\r\n    h.base = a->mem;\r\n    h.off = 0;\r\n    xa0(&h, HEAP_BYTES);\r\n    z_set_flag(&h, 0);\r\n    a->head = h;\r\n    a->fl_head.base = h.base;\r\n    a->fl_head.off = FL_END;\r\n    xb1(a, &h);\r\n}\r\n"]
[60.376612, "o", "\u001b[?2004hroot@167e824d180e:/app# "]
[60.486356, "i", "sed -n '1,260p' include/arena.h\n"]
