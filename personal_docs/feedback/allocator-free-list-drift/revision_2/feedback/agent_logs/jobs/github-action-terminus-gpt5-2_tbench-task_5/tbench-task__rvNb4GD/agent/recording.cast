[282.036928, "i", "sed -n '1,260p' list_b/list.c\n"]
[282.0374, "o", "sed -n '1,260p' list_b/list.c\r\n\u001b[?2004l\r"]
[282.038918, "o", "#include \"../include/arena.h\"\r\n#include \"../pool_a/tag.h\"\r\n\r\n#include <stddef.h>\r\n#include <string.h>\r\n\r\nstatic size_t fl_ix(size_t off) {\r\n    return off >> 3;\r\n}\r\n\r\n"]
[282.038977, "o", "static void fl_clear(Arena *a, size_t off) {\r\n    size_t ix = fl_ix(off);\r\n    a->fl_link_next[ix] = FL_END;\r\n    a->fl_link_prev[ix] = FL_END;\r\n}\r\n\r\nvoid xb1(Arena *a, Block *b) {\r\n    size_t off = b->off;\r\n    size_t ix = fl_ix(off);\r\n    size_t old = a->fl_head.off;\r\n    a->fl_link_next[ix] = old;\r\n    a->fl_link_prev[ix] = FL_END;\r\n    if (old != FL_END) {\r\n        a->fl_link_prev[fl_ix(old)] = off;\r\n"]
[282.03908, "o", "    }\r\n    a->fl_head.base = b->base;\r\n    a->fl_head.off = off;\r\n}\r\n\r\nvoid list_remove(Arena *a, Block *b) {\r\n    size_t off = b->off;\r\n"]
[282.039158, "o", "    size_t ix = fl_ix(off);\r\n    size_t nxt = a->fl_link_next[ix];\r\n    size_t prv = a->fl_link_prev[ix];\r\n    if (nxt != FL_END) {\r\n        a->fl_link_prev[fl_ix(nxt)] = prv;\r\n    } else if (a->fl_head.off == off) {\r\n        a->fl_head.off = FL_END;\r\n    }\r\n    if (prv != FL_END) {\r\n        a->fl_link_next[fl_ix(prv)] = nxt;\r\n    } else {\r\n"]
[282.039233, "o", "        a->fl_head.off = nxt;\r\n    }\r\n    fl_clear(a, off);\r\n}\r\n\r\nvoid list_coalesce(Arena *a, Block *b) {\r\n    size_t total = tag_read_size(b);\r\n    size_t off = b->off + total;\r\n    if (off < a->used) {\r\n        Block nb = {b->base, off};\r\n        if (!z_is_flag(&nb)) {\r\n            list_remove(a, &nb);\r\n            total += tag_read_size(&nb);\r\n            xa0(b, total);\r\n            off = b->off + total;\r\n        }\r\n    }\r\n    xb1(a, b);\r\n}\r\n\r\nint q8f_blk(Arena *a, Block *oldb, size_t need, size_t *merged_out) {\r\n    size_t old_total = tag_read_size(oldb);\r\n"]
[282.039255, "o", "    size_t next_off = oldb->off + old_total;\r\n    size_t ntotal;\r\n    Block nb;\r\n    if (next_off >= a->used) {\r\n        return -1;\r\n    }\r\n    nb.base = oldb->base;\r\n    nb.off = next_off;\r\n"]
[282.039278, "o", "    if (z_is_flag(&nb)) {\r\n        return -1;\r\n    }\r\n    ntotal = tag_read_size(&nb);\r\n    if (old_total + ntotal < need) {\r\n        return -1;\r\n    }\r\n    list_remove(a, &nb);\r\n    *merged_out = old_total + ntotal;\r\n"]
[282.039303, "o", "    xa0(oldb, *merged_out);\r\n    z_set_flag(oldb, 1);\r\n    return 0;\r\n}\r\n"]
[282.039532, "o", "\u001b[?2004h"]
[282.039666, "o", "root@167e824d180e:/app# "]
[282.16046, "i", "sed -n '1,320p' split_c/split.c\n"]
[282.160795, "o", "sed -n '1,320p' split_c/split.c\r\n\u001b[?2004l\r"]
[282.161636, "o", "#include \"../include/arena.h\"\r\n#include \"../list_b/list.h\"\r\n#include \"../pool_a/tag.h\"\r\n\r\n#include <stddef.h>\r\n\r\nstatic int on_fl(Arena *a, size_t off) {\r\n    size_t ix = off >> 3;\r\n    return a->fl_head.off == off || a->fl_link_prev[ix] != FL_END || a->fl_link_next[ix] != FL_END;\r\n}\r\n\r\nBlock *mark_c(Arena *a, Block *b, size_t c) {\r\n    size_t total = tag_read_size(b);\r\n    size_t need = blk_align(c + HDR_SIZE + FTR_SIZE);\r\n"]
[282.161698, "o", "    if (total < need + MIN_BLK) {\r\n        return NULL;\r\n    }\r\n    size_t rem = total - need;\r\n    if (on_fl(a, b->off)) {\r\n        list_remove(a, b);\r\n    }\r\n    xa0(b, need);\r\n    z_set_flag(b, 1);\r\n    Block tail;\r\n    tail.base = b->base;\r\n    tail.off = b->off + need;\r\n    xa0(&tail, rem);\r\n    z_set_flag(&tail, 0);\r\n    xb1(a, &tail);\r\n    return NULL;\r\n}\r\n"]
[282.161958, "o", "\u001b[?2004h"]
