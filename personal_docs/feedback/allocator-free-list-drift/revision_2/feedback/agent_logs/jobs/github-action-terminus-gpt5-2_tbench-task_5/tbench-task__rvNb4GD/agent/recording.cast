[60.139427, "o", "sed -n '1,260p' src/free_ops.c"]
[60.140007, "o", "\r\n\u001b[?2004l\r"]
[60.141428, "o", "#include \"../include/arena.h\"\r\n#include \"../acct_e/acct.h\"\r\n#include \"../list_b/list.h\"\r\n#include \"../pool_a/tag.h\"\r\n\r\n#include <string.h>\r\n\r\nint arena_slot_free(Arena *a, int idx) {\r\n    if (idx < 0 || idx >= a->slot_count || !a->slot_live[idx]) {\r\n        return -1;\r\n    }\r\n    Block b;\r\n    b.base = a->mem;\r\n    b.off = (size_t)((unsigned char *)a->slots[idx] - a->mem - HDR_SIZE);\r\n    size_t total = tag_read_size(&b);\r\n    z_set_flag(&b, 0);\r\n    xd3(&a->stats, -(ssize_t)total);\r\n    a->stats.live_blocks--;\r\n    a->slot_live[idx] = 0;\r\n    list_coalesce(a, &b);\r\n    return 0;\r\n}\r\n"]
[60.142244, "o", "\u001b[?2004hroot@167e824d180e:/app# "]
[60.249948, "i", "sed -n '1,320p' src/arena_core.c\n"]
[60.250232, "o", "sed -n '1,320p' src/arena_core.c\r\n"]
[60.250283, "o", "\u001b[?2004l\r"]
[60.251412, "o", "#include \"../include/arena.h\"\r\n#include \"../pool_a/tag.h\"\r\n\r\nstatic size_t fl_ix(size_t off) {\r\n    return off >> 3;\r\n}\r\n\r\nsize_t arena_heap_sig(const Arena *a) {\r\n"]
[60.251474, "o", "    size_t sig = 0;\r\n    size_t off = 0;\r\n    while (off < a->used) {\r\n        Block b;\r\n        b.base = (unsigned char *)a->mem;\r\n        b.off = off;\r\n        size_t total = tag_read_size(&b);\r\n        if (total == 0) {\r\n            break;\r\n        }\r\n        if (z_is_flag(&b)) {\r\n            sig += total * 17;\r\n        }\r\n        off += total;\r\n    }\r\n"]
[60.251551, "o", "    return sig;\r\n}\r\n\r\nsize_t arena_fl_sig(const Arena *a) {\r\n    size_t sig = 0;\r\n    size_t cur = a->fl_head.off;\r\n    while (cur != FL_END) {\r\n        Block b = {(unsigned char *)a->mem, cur};\r\n        sig += tag_read_size(&b);\r\n        cur = a->fl_link_next[fl_ix(cur)];\r\n    }\r\n    return sig;\r\n}\r\n\r\nint arena_fl_count(const Arena *a) {\r\n    int c = 0;\r\n    size_t cur = a->fl_head.off;\r\n    while (cur != FL_END) {\r\n        c++;\r\n        cur = a->fl_link_next[fl_ix(cur)];\r\n    }\r\n"]
[60.251579, "o", "    return c;\r\n}\r\n"]
