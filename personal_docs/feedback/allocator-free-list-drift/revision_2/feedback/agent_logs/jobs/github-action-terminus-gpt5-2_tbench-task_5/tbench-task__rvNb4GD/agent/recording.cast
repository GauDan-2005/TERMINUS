[60.595344, "o", "\r\n\u001b[?2004l\r"]
[60.59684, "o", "#ifndef BLOCK_H\r\n#define BLOCK_H\r\n\r\n#include <stddef.h>\r\n\r\n#define HDR_SIZE 16\r\n#define FTR_SIZE 8\r\n#define FL_END ((size_t)-1)\r\n#define MIN_BLK 40\r\n#define ALIGN 8\r\n\r\ntypedef struct Block {\r\n"]
[60.597008, "o", "    unsigned char *base;\r\n    size_t off;\r\n} Block;\r\n\r\nstatic inline size_t blk_align(size_t n) {\r\n    return (n + (ALIGN - 1)) & ~(size_t)(ALIGN - 1);\r\n}\r\n\r\n#endif\r\n"]
[60.597232, "o", "\u001b[?2004hroot@167e824d180e:/app# "]
