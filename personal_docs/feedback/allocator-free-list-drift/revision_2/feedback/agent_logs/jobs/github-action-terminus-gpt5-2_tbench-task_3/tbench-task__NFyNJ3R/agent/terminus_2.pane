void arena_init(Arena *a) {
    Block h;
    size_t i;
    memset(a, 0, sizeof(*a));
    for (i = 0; i < FL_MAP_SZ; i++) {
        a->fl_link_next[i] = FL_END;
        a->fl_link_prev[i] = FL_END;
