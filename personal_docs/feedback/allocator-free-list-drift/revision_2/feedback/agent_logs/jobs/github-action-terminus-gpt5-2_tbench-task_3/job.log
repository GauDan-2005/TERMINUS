Sending keys: ['cat > /app/src/reloc_ops.c <<\'EOF\'\n#include "../include/arena.h"\n#include "../list_b/list.h"\n#include "../move_d/move.h"\n#include "../pool_a/tag.h"\n#include "../split_c/split.h"\n\nint arena_slot_alloc(Arena *a, size_t req);\n\nstatic void free_block_for_ptr(Arena *a, void *p) {\n    Block b;\n    b.base = a->mem;\n    b.off = (size_t)((unsigned char *)p - a->mem - HDR_SIZE);\n    z_set_flag(&b, 0);\n    list_coalesce(a, &b);\n}\n\nint arena_slot_realloc(Arena *a, int idx, size_t req) {\n    if (idx < 0 || idx >= a->slot_count || !a->slot_live[idx]) {\n        return -1;\n    }\n\n    Block oldb;\n    size_t old_pay = a->slot_payload[idx];\n    size_t need = blk_align(req + HDR_SIZE + FTR_SIZE);\n\n    oldb.base = a->mem;\n    oldb.off = (size_t)((unsigned char *)a->slots[idx] - a->mem - HDR_SIZE);\n\n    // In-place shrink.\n    if (need <= tag_read_size(&oldb)) {\n        (void)split_realloc_inplace(a, &oldb, idx, req);\n        return idx;\n    }\n\n    // In-place grow by merging neighbor if possible.\n    if (split_grow_inplace(a, &oldb, idx, req, need) >= 0) {\n        return idx;\n    }\n\n    // Move: keep the same logical slot index.\n    {\n        void *old_ptr = a->slots[idx];\n        int nidx = arena_slot_alloc(a, req);\n        if (nidx < 0) {\n            return -1;\n        }\n\n        // Copy old payload into new block.\n        xc2(a->slots[nidx], old_ptr, old_pay);\n\n        // Adopt the new block into the original slot.\n        a->slots[idx] = a->slots[nidx];\n        a->slot_payload[idx] = req;\n\n        // Fix payload accounting: alloc added +req; we still need to remove old_pay\n        // for the freed old block (and ensure we don\'t keep temp slot accounting).\n        a->stats.allocated -= old_pay;\n\n        // Drop the temporary slot bookkeeping without freeing its block.\n        a->slot_live[nidx] = 0;\n        a->slot_payload[nidx] = 0;\n        a->slots[nidx] = NULL;\n        a->stats.live_blocks--;\n\n        // Now actually free the old block in the heap.\n        free_block_for_ptr(a, old_ptr);\n\n        return idx;\n    }\n}\nEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
