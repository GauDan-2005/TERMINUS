Sending keys: ['cat > /app/src/slot_split.c <<\'EOF\'\n#include "../include/arena.h"\n#include "../list_b/list.h"\n#include "../pool_a/tag.h"\n#include "../split_c/split.h"\n\nstatic void adjust_payload(Arena *a, int idx, size_t req) {\n    size_t old = a->slot_payload[idx];\n    a->slot_payload[idx] = req;\n    if (req > old) {\n        a->stats.allocated += (req - old);\n    } else {\n        a->stats.allocated -= (old - req);\n    }\n    if (a->stats.allocated > a->stats.peak) {\n        a->stats.peak = a->stats.allocated;\n    }\n}\n\nint split_realloc_inplace(Arena *a, Block *oldb, int idx, size_t req) {\n    size_t old_total = tag_read_size(oldb);\n    size_t need = blk_align(req + HDR_SIZE + FTR_SIZE);\n\n    // If we can\'t split, just update the tracked payload size.\n    if (old_total < need + MIN_BLK) {\n        adjust_payload(a, idx, req);\n        return idx;\n    }\n\n    // Split the block in-place to create a new free tail.\n    z_set_flag(oldb, 0);\n    list_coalesce(a, oldb);\n    mark_c(a, oldb, req);\n\n    adjust_payload(a, idx, req);\n    return idx;\n}\n\nint split_grow_inplace(Arena *a, Block *oldb, int idx, size_t req, size_t need) {\n    size_t merged;\n\n    if (q8f_blk(a, oldb, need, &merged) != 0) {\n        return -1;\n    }\n\n    if (merged >= need + MIN_BLK) {\n        // Consume merged region and split remainder.\n        z_set_flag(oldb, 0);\n        list_coalesce(a, oldb);\n        mark_c(a, oldb, req);\n    } else {\n        // Consume entire merged region.\n        if (on_fl(a, oldb->off)) {\n            list_remove(a, oldb);\n        }\n        xa0(oldb, merged);\n        z_set_flag(oldb, 1);\n    }\n\n    adjust_payload(a, idx, req);\n    return idx;\n}\n\nvoid slot_take_split(Arena *a, Block *fit, size_t req, size_t need) {\n    (void)need;\n    mark_c(a, fit, req);\n}\nEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
