[68.661875, "o", "sed -n '1,260p' /app/acct_e/acct.c\r\n\u001b[?2004l\r"]
[68.662967, "o", "#include \"../include/stats.h\"\r\n\r\n#include <stddef.h>\r\n#include <sys/types.h>\r\n\r\nvoid xd3(Stats *a, ssize_t b) {\r\n    if (b > 0) {\r\n"]
