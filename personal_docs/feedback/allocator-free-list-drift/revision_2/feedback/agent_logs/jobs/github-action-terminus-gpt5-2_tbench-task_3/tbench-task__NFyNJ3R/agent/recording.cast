[87.063851, "o", "#include \"../include/arena.h\"\r\n#include \"../list_b/list.h\"\r\n#include \"../pool_a/tag.h\"\r\n\r\n#include <stddef.h>\r\n\r\n"]
[87.063888, "o", "static int on_fl(Arena *a, size_t off) {\r\n    size_t ix = off >> 3;\r\n    return a->fl_head.off == off || a->fl_link_prev[ix] != FL_END || a->fl_link_next[ix] != FL_END;\r\n}\r\n\r\nBlock *mark_c(Arena *a, Block *b, size_t c) {\r\n    size_t total = tag_read_size(b);\r\n    size_t need = blk_align(c + HDR_SIZE + FTR_SIZE);\r\n    if (total < need + MIN_BLK) {\r\n        return NULL;\r\n    }\r\n    size_t rem = total - need;\r\n    if (on_fl(a, b->off)) {\r\n        list_remove(a, b);\r\n    }\r\n    xa0(b, need);"]
[87.063912, "o", "\r\n    z_set_flag(b, 1);\r\n    Block tail;\r\n    tail.base = b->base;\r\n    tail.off = b->off + need;\r\n    xa0(&tail, rem);\r\n"]
[87.063934, "o", "    z_set_flag(&tail, 0);\r\n    xb1(a, &tail);\r\n    return NULL;\r\n}\r\n"]
[87.064224, "o", "\u001b[?2004hroot@ae6ae9e1ef3c:/app# "]
