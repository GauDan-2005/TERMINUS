[235.950158, "i", "python3 - <<'PY'\nimport json\np='/app/output/alloc-audit.json'\nobj=json.load(open(p))\nassert list(obj)==['cases']\norder=[c['name'] for c in obj['cases']]\nprint('order',order)\nassert order==['cedar','jade','slate','coral','onyx','pearl']\nreq_case_keys={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nreq_step_keys={'seq','op','index','size','result_index','heap_sig','fl_count','fl_sig','byte_total'}\nfor c in obj['cases']:\n    assert req_case_keys.issubset(c.keys())\n    steps=c['steps']\n    for i,st in enumerate(steps):\n        assert req_step_keys.issubset(st.keys())\n        assert st['seq']==i\n    # top-level tallies must equal last step tallies\n    last=steps[-1]\n    for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n        assert c[k]==last[k], (c['name'],k,c[k],last[k])\nprint('ok')\nPY\n"]
