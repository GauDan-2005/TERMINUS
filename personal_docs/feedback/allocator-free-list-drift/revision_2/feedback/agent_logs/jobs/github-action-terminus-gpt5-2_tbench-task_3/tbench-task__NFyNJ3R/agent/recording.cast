[319.189901, "i", "python3 - <<'PY'\nimport json, os\nm=json.load(open('/app/output/alloc-audit.json'))\nfor c in m['cases']:\n    led=c['ledger']\n    assert os.path.exists(led), led\n    with open(led) as f:\n        line=f.readline().strip()\n        obj=json.loads(line)\n        for k in ['seq','op','index','size','result_index','heap_sig','fl_count','fl_sig','byte_total']:\n            assert k in obj, (c['name'],k)\nprint('ledgers ok')\nPY\n"]
