[10.663786, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nCASE=\"${1:?case name required}\"\r\nmkdir -p \"${APP_ROOT}/output\"\r\n\"${APP_ROOT}/bin/allocctl\" one \"${CASE}\"\r\n\u001b[?2004hroot@ae6ae9e1ef3c:/app# "]
