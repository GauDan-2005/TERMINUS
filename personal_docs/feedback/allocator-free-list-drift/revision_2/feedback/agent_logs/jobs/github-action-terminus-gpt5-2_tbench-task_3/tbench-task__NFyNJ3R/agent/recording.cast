[203.950245, "o", "\u001b[?2004h> "]
[203.950327, "o", "    if (req > old) {\r\n\u001b[?2004l\r"]
[203.950358, "o", "\u001b[?2004h"]
[203.95049, "o", "> "]
[203.950639, "o", "        a->stats.allocated += (req - old);\r\n\u001b[?2004l\r"]
[203.950731, "o", "\u001b[?2004h>     } else {\r\n\u001b[?2004l\r"]
[203.950833, "o", "\u001b[?2004h> "]
[203.950928, "o", "        a->stats.allocated -= (old - req);\r\n\u001b[?2004l\r"]
[203.95106, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[203.951167, "o", "\u001b[?2004h> "]
[203.951244, "o", "    if (a->stats.allocated > a->stats.peak) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.951314, "o", "> "]
[203.951465, "o", "        a->stats.peak = a->stats.allocated;\r\n\u001b[?2004l\r"]
[203.951534, "o", "\u001b[?2004h> "]
[203.95159, "o", "    }\r\n\u001b[?2004l\r"]
[203.951691, "o", "\u001b[?2004h> "]
[203.951756, "o", "}\r\n\u001b[?2004l\r"]
[203.951815, "o", "\u001b[?2004h> "]
[203.95189, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.952091, "o", "int split_realloc_inplace(Arena *a, Block *oldb, int idx, size_t req) {\r\n\u001b[?2004l\r"]
[203.952115, "o", "\u001b[?2004h"]
[203.952133, "o", "> "]
[203.95227, "o", "    size_t old_total = tag_read_size(oldb);\r\n\u001b[?2004l\r"]
[203.952292, "o", "\u001b[?2004h"]
[203.952308, "o", "> "]
[203.952488, "o", "    size_t need = blk_align(req + HDR_SIZE + FTR_SIZE);\r\n\u001b[?2004l\r"]
[203.95251, "o", "\u001b[?2004h"]
[203.952528, "o", "> \r\n\u001b[?2004l\r"]
[203.952607, "o", "\u001b[?2004h> "]
[203.952852, "o", "    // If we can't split, just update the tracked payload size.\r\n\u001b[?2004l\r"]
[203.952923, "o", "\u001b[?2004h> "]
[203.953064, "o", "    if (old_total < need + MIN_BLK) {\r\n\u001b[?2004l\r"]
[203.953123, "o", "\u001b[?2004h"]
[203.95319, "o", "> "]
[203.953321, "o", "        adjust_payload(a, idx, req);\r\n\u001b[?2004l\r"]
[203.953345, "o", "\u001b[?2004h"]
[203.953367, "o", "> "]
[203.953462, "o", "        return idx;\r\n\u001b[?2004l\r"]
[203.95349, "o", "\u001b[?2004h> "]
[203.953614, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.953641, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.953812, "o", "    // Split the block in-place to create a new free tail.\r\n\u001b[?2004l\r"]
[203.95387, "o", "\u001b[?2004h> "]
[203.953968, "o", "    z_set_flag(oldb, 0);\r\n\u001b[?2004l\r"]
[203.954014, "o", "\u001b[?2004h> "]
[203.954126, "o", "    list_coalesce(a, oldb);\r\n\u001b[?2004l\r"]
[203.954152, "o", "\u001b[?2004h> "]
[203.954249, "o", "    mark_c(a, oldb, req);\r\n\u001b[?2004l\r"]
[203.954277, "o", "\u001b[?2004h"]
[203.954296, "o", "> \r\n\u001b[?2004l\r"]
[203.954402, "o", "\u001b[?2004h> "]
[203.954492, "o", "    adjust_payload(a, idx, req);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.954599, "o", "    return idx;\r\n\u001b[?2004l\r"]
[203.95463, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[203.954732, "o", "\u001b[?2004h> \r\n"]
[203.95486, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[203.954994, "o", "int split_grow_inplace(Arena *a, Block *oldb, int idx, size_t req, size_t need) {\r\n\u001b[?2004l\r"]
[203.955057, "o", "\u001b[?2004h> "]
[203.955084, "o", "    size_t merged;\r\n\u001b[?2004l\r"]
[203.955105, "o", "\u001b[?2004h"]
[203.955125, "o", "> \r\n\u001b[?2004l\r"]
[203.955144, "o", "\u001b[?2004h"]
[203.955167, "o", "> "]
[203.955333, "o", "    if (q8f_blk(a, oldb, need, &merged) != 0) {\r\n\u001b[?2004l\r"]
[203.955362, "o", "\u001b[?2004h> "]
[203.955443, "o", "        return -1;\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.955468, "o", ">     }"]
[203.955493, "o", "\r\n\u001b[?2004l\r"]
[203.955641, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.95576, "o", "    if (merged >= need + MIN_BLK) {\r\n\u001b[?2004l\r"]
[203.955793, "o", "\u001b[?2004h> "]
[203.955969, "o", "        // Consume merged region and split remainder.\r\n\u001b[?2004l\r"]
[203.956025, "o", "\u001b[?2004h> "]
[203.956106, "o", "        z_set_flag(oldb, 0);\r\n\u001b[?2004l\r"]
[203.95613, "o", "\u001b[?2004h"]
[203.956154, "o", "> "]
[203.95626, "o", "        list_coalesce(a, oldb);\r\n\u001b[?2004l\r"]
[203.956289, "o", "\u001b[?2004h"]
[203.956313, "o", "> "]
[203.956416, "o", "        mark_c(a, oldb, req);\r\n\u001b[?2004l\r"]
[203.956444, "o", "\u001b[?2004h"]
[203.956465, "o", "> "]
[203.956534, "o", "    } else {\r\n\u001b[?2004l\r"]
[203.956556, "o", "\u001b[?2004h> "]
[203.956703, "o", "        // Consume entire merged region.\r\n\u001b[?2004l\r"]
[203.956776, "o", "\u001b[?2004h> "]
[203.956906, "o", "        if (on_fl(a, oldb->off)) {\r\n\u001b[?2004l\r"]
[203.95693, "o", "\u001b[?2004h"]
[203.956949, "o", "> "]
[203.957077, "o", "            list_remove(a, oldb);\r\n\u001b[?2004l\r"]
[203.957178, "o", "\u001b[?2004h> "]
[203.957277, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.957373, "o", "        xa0(oldb, merged);\r\n\u001b[?2004l\r"]
[203.957465, "o", "\u001b[?2004h> "]
[203.957554, "o", "        z_set_flag(oldb, 1);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.957584, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[203.957655, "o", "\u001b[?2004h"]
[203.957682, "o", "> "]
[203.957823, "o", "    adjust_payload(a, idx, req);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.957864, "o", "    return idx;\r\n\u001b[?2004l\r"]
[203.957989, "o", "\u001b[?2004h"]
