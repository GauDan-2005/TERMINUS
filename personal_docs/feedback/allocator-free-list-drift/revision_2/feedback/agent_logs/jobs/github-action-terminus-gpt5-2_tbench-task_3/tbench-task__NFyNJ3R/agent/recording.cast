[260.742072, "i", "cat > /app/src/slot_split.c <<'EOF'\n#include \"../include/arena.h\"\n#include \"../list_b/list.h\"\n#include \"../pool_a/tag.h\"\n#include \"../split_c/split.h\"\n\nstatic void adjust_payload(Arena *a, int idx, size_t req) {\n    size_t old = a->slot_payload[idx];\n    a->slot_payload[idx] = req;\n    if (req > old) a->stats.allocated += (req - old);\n    else a->stats.allocated -= (old - req);\n    if (a->stats.allocated > a->stats.peak) a->stats.peak = a->stats.allocated;\n}\n\nint split_realloc_inplace(Arena *a, Block *oldb, int idx, size_t req) {\n    size_t old_total = tag_read_size(oldb);\n    size_t need = blk_align(req + HDR_SIZE + FTR_SIZE);\n\n    if (old_total < need + MIN_BLK) {\n        adjust_payload(a, idx, req);\n        return idx;\n    }\n\n    // Turn the whole block into free, coalesce (no-op for allocated neighbors), then split.\n    z_set_flag(oldb, 0);\n    list_coalesce(a, oldb);\n    mark_c(a, oldb, req);\n\n    adjust_payload(a, idx, req);\n    return idx;\n}\n\nint split_grow_inplace(Arena *a, Block *oldb, int idx, size_t req, size_t need) {\n    size_t merged;\n\n    if (q8f_blk(a, oldb, need, &merged) != 0) {\n        return -1;\n    }\n\n    // q8f_blk has ensured we can grow by absorbing adjacent free space.\n    // Ensure the header reflects the merged extent and mark allocated.\n    xa0(oldb, merged);\n    z_set_flag(oldb, 1);\n\n    // If there is enough remainder, split and return tail to free list.\n    if (merged >= need + MIN_BLK) {\n        mark_c(a, oldb, req);\n    }\n\n    adjust_payload(a, idx, req);\n    return idx;\n}\n\nvoid slot_take_split(Arena *a, Block *fit, size_t req, size_t need) {\n    (void)need;\n    mark_c(a, fit, req);\n}\nEOF\n"]
