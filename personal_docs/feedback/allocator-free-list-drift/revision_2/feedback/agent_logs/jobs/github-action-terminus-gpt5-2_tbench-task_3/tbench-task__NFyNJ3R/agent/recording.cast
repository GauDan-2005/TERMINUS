[60.639967, "o", "#include \"../list_b/list.h\"\r\n"]
[60.640022, "o", "#include \"../pool_a/tag.h\"\r\n"]
[60.640076, "o", "\r\n"]
[60.640128, "o", "#include <string.h>\r\n"]
[60.640189, "o", "\r\n"]
[60.640317, "o", "int arena_slot_free(Arena *a, int idx) {\r\n"]
[60.640512, "o", "    if (idx < 0 || idx >= a->slot_count || !a->slot_live[idx]) {\r\n        return -1;\r\n    }\r\n    Block b;\r\n    b.base = a->mem;\r\n    b.off = (size_t)((unsigned char *)a->slots[idx] - a->mem - HDR_SIZE);\r\n    size_t total = tag_read_size(&b);\r\n    z_set_flag(&b, 0);\r\n    xd3(&a->stats, -(ssize_t)total);\r\n    a->stats.live_blocks--;\r\n    a->slot_live[idx] = 0;\r\n    list_coalesce(a, &b);\r\n    return 0;\r\n}\r\n"]
[60.64056, "o", "\u001b[?2004hroot@ae6ae9e1ef3c:/app# "]
[60.761938, "i", "sed -n '1,260p' /app/src/reloc_ops.c\n"]
