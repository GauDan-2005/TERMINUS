[156.23851, "i", "perl -0777 -i -pe 's/#include \"\\.\\.\\/acct_e\\/acct\\.h\"\\n//sg; s/\\n\\s*z_set_flag\\(oldb, 0\\);\\n\\s*xd3\\(&a->stats, -\\(ssize_t\\)old_total\\);\\n\\s*mark_c\\(a, oldb, req\\);\\n\\s*xd3\\(&a->stats, \\(ssize_t\\)need\\);\\n\\s*a->slot_payload\\[idx\\] = req;/\\n    // Update payload accounting by delta; heap bookkeeping is handled by mark_c\\/coalesce.\\n    {\\n        size_t old_pay = a->slot_payload[idx];\\n        a->slot_payload[idx] = req;\\n        if (req > old_pay) a->stats.allocated += (req - old_pay);\\n        else a->stats.allocated -= (old_pay - req);\\n        if (a->stats.allocated > a->stats.peak) a->stats.peak = a->stats.allocated;\\n    }/sg; s/\\n\\s*xd3\\(&a->stats, \\(ssize_t\\)ntotal\\);\\n/\\n/sg; s/\\n\\s*z_set_flag\\(oldb, 0\\);\\n\\s*xd3\\(&a->stats, -\\(ssize_t\\)merged\\);\\n\\s*mark_c\\(a, oldb, req\\);\\n\\s*xd3\\(&a->stats, \\(ssize_t\\)need\\);/\\n        mark_c(a, oldb, req);/sg; s/\\n\\s*a->slot_payload\\[idx\\] = req;\\n\\s*return idx;/\\n    {\\n        size_t old_pay = a->slot_payload[idx];\\n        a->slot_payload[idx] = req;\\n        if (req > old_pay) a->stats.allocated += (req - old_pay);\\n        else a->stats.allocated -= (old_pay - req);\\n        if (a->stats.allocated > a->stats.peak) a->stats.peak = a->stats.allocated;\\n    }\\n    return idx;/sg; s/\\n\\s*xd3\\(&a->stats, \\(ssize_t\\)need\\);\\n/\\n    // alloc path accounts payload in alloc_ops.c\\n/sg' /app/src/slot_split.c\n"]
[156.243258, "o", "perl -0777 -i -pe 's/#include \"\\.\\.\\/acct_e\\/acct\\.h\"\\n//sg; s/\\n\\s*z_set_flag\\(oldb, 0\\);\\n\\s*xd3\\(&a->stats, -\\(ssize_t\\)old_total\\);\\n\\s*mark_c\\(a, oldb, req\\);\\n\\s*xd3\\(&a->stats, \\(ssize_t\\)need\\);\\n\\s*a->slot_payload\\[idx\\] = req;/\\n    // Update payload accounting by delta; heap bookkeeping is handled by mark_c\\/coalesce.\\n    {\\n        size_t old_pay = a->slot_payload[idx];\\n        a->slot_payload[idx] = req;\\n        if (req > old_pay) a->stats.allocated += (req - old_pay);\\n        else a->stats.allocated -= (old_pay - req);\\n        if (a->stats.allocated > a->stats.peak) a->stats.peak = a->stats.allocated;\\n    }/sg; s/\\n\\s*xd3\\(&a->stats, \\(ssize_t\\)ntotal\\);\\n/\\n/sg; s/\\n\\s*z_set_flag\\(oldb, 0\\);\\n\\s*xd3\\(&a->stats, -\\(ssize_t\\)merged\\);\\n\\s*mark_c\\(a, oldb, req\\);\\n\\s*xd3\\(&a->stats, \\(ssize_t\\)need\\);/\\n        mark_c(a, oldb, req);/sg; s/\\n\\s*a->slot_payload\\[idx\\] = req;\\n\\s*return idx;/\\n    {\\n        size_t old_pay = a->slot_payload[idx];\\n        a->slot_payload[idx] = req;\\n        if (req > old_pay) a->stats.allocated += (req - old_pay);\\n        else a->stats.allocated -= (old_pay - req);\\n        if (a->stats.allocated > a->stats.peak) a->stats.peak = a->stats.allocated;\\n    }\\n    return idx;/sg; s/\\n\\s*xd3\\(&a->stats, \\(ssize_t\\)need\\);\\n/\\n    // alloc path accounts payload in alloc_ops.c\\n/sg' /app/src/slot_split.c\r\n\u001b[?2004l\r"]
