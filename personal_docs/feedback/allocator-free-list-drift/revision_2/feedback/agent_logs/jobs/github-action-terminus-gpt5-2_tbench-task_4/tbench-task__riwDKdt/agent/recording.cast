[34.932381, "i", "python3 - <<'PY'\nimport json,sys\np='/app/output/alloc-audit.json'\nobj=json.load(open(p))\nprint('top keys',sorted(obj.keys()))\ncases=obj.get('cases')\nprint('cases',len(cases))\nprint('order',[c.get('name') for c in cases])\nneed_case={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nneed_step={'seq','op','index','size','result_index','heap_sig','fl_count','fl_sig','byte_total'}\nfor c in cases:\n    miss=need_case-set(c)\n    if miss: print('CASE missing',c.get('name'),miss)\n    steps=c.get('steps',[])\n    if not steps:\n        print('no steps',c.get('name')); continue\n    # check step fields and monotonic seq\n    for i,s in enumerate(steps):\n        m=need_step-set(s)\n        if m:\n            print('STEP missing',c.get('name'),i,m)\n            break\n        if s['seq']!=i:\n            print('seq mismatch',c.get('name'),i,'got',s['seq']);break\n    last=steps[-1]\n    for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n        if c.get(k)!=last.get(k):\n            print('summary!=last',c.get('name'),k,c.get(k),last.get(k))\nprint('done')\nPY\n"]
