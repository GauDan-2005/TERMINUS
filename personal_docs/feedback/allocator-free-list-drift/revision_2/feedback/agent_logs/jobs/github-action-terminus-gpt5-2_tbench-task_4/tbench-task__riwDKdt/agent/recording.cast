[35.939552, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\nobj=json.load(open('/app/output/alloc-audit.json'))\nfor c in obj['cases']:\n    lp=Path(c['ledger'])\n    if not lp.exists():\n        print('missing ledger',c['name'],lp); continue\n    rows=[]\n    for line in lp.read_text().splitlines():\n        rows.append(json.loads(line))\n    if len(rows)!=len(c['steps']):\n        print('ledger len mismatch',c['name'],len(rows),len(c['steps']))\n    # ensure required fields present in ledger rows\n    need={'seq','op','index','size','result_index','heap_sig','fl_count','fl_sig','byte_total'}\n    for i,r in enumerate(rows[:5]):\n        pass\n    for i,r in enumerate(rows):\n        m=need-set(r)\n        if m:\n            print('ledger missing fields',c['name'],i,m);break\n        if r['seq']!=i:\n            print('ledger seq mismatch',c['name'],i,'got',r['seq']);break\nprint('ledger check done')\nPY\n"]
