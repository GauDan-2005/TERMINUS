[81.876754, "i", "python3 - <<'PY'\nimport json, pathlib\np=pathlib.Path('output')\nfor f in sorted(p.glob('*-audit.json')):\n    obj=json.loads(f.read_text())\n    led=obj.get('ledger')\n    ok=isinstance(led,str) and led and pathlib.Path(led).is_file()\n    print(f.name, 'ledger_ok=' , ok, 'ledger=', repr(led))\nPY\n"]
