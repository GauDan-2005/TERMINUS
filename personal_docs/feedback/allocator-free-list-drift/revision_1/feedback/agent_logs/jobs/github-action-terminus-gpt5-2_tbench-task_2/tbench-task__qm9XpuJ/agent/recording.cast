[56.964167, "i", "python3 - <<'PY'\nimport json, pathlib, sys\nnames=['cedar','jade','slate','coral','onyx','pearl']\nreq={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nreq_step={'op','heap_sig','fl_count','fl_sig','byte_total'}\nerrs=[]\nfor n in names:\n    p=pathlib.Path('output')/f'{n}-audit.json'\n    if not p.exists():\n        errs.append((n,'missing_audit',str(p)))\n        continue\n    obj=json.loads(p.read_text())\n    miss=req-set(obj)\n    if miss:\n        errs.append((n,'missing_keys',sorted(miss)))\n    if obj.get('name')!=n:\n        errs.append((n,'name_mismatch',obj.get('name')))\n    steps=obj.get('steps',[])\n    for i,s in enumerate(steps):\n        miss=req_step-set(s)\n        if miss:\n            errs.append((n,f'missing_step_keys@{i}',sorted(miss)))\n    led=pathlib.Path(obj.get('ledger',''))\n    if not led.exists():\n        errs.append((n,'missing_ledger',str(led)))\n    else:\n        lines=sum(1 for _ in led.open('r'))\n        if lines!=len(steps):\n            errs.append((n,'ledger_len_mismatch',{'steps':len(steps),'ledger_lines':lines,'path':str(led)}))\nprint('errors',len(errs))\nfor e in errs:\n    print('ERR',e)\nsys.exit(1 if errs else 0)\nPY\n"]
[56.964483, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
