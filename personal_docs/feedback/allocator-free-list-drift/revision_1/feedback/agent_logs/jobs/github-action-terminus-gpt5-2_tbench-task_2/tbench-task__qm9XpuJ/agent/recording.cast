[166.100135, "i", "python3 - <<'PY'\nimport json, pathlib, sys\nnames=['cedar','jade','slate','coral','onyx','pearl']\nreq_case={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nreq_step={'seq','op','index','size','result_index','heap_sig','fl_count','fl_sig','byte_total'}\nerrs=[]\nfor n in names:\n    p=pathlib.Path('output')/f'{n}-audit.json'\n    if not p.exists():\n        errs.append((n,'missing_audit'))\n        continue\n    obj=json.loads(p.read_text())\n    if 'cases' not in obj or not isinstance(obj['cases'], list) or len(obj['cases'])!=1:\n        errs.append((n,'bad_top_level'))\n        continue\n    c=obj['cases'][0]\n    miss=req_case-set(c)\n    if miss:\n        errs.append((n,'missing_case_keys',sorted(miss)))\n    if c.get('name')!=n:\n        errs.append((n,'name_mismatch',c.get('name')))\n    led=c.get('ledger')\n    if not (isinstance(led,str) and led):\n        errs.append((n,'bad_ledger_field',led))\n    else:\n        lp=pathlib.Path(led)\n        if not lp.is_file():\n            errs.append((n,'ledger_not_file',led))\n    steps=c.get('steps',[])\n    for i,s in enumerate(steps):\n        miss=req_step-set(s)\n        if miss:\n            errs.append((n,f'missing_step_keys@{i}',sorted(miss)))\n    if isinstance(led,str) and led and pathlib.Path(led).is_file():\n        lines=sum(1 for _ in open(led,'r'))\n        if lines!=len(steps):\n            errs.append((n,'ledger_len_mismatch',{'steps':len(steps),'ledger_lines':lines}))\nprint('errors',len(errs))\nfor e in errs[:50]:\n    print('ERR',e)\nsys.exit(1 if errs else 0)\nPY\n"]
[166.100454, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
