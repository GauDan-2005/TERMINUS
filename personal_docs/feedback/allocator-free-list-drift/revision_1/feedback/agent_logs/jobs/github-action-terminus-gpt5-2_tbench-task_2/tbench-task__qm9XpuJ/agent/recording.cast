[46.007941, "o", "\u001b[?2004hroot@334dfe1f3bf9:/app# "]
[46.964347, "i", "python3 - <<'PY'\nimport json, pathlib, sys\nobj=json.loads(pathlib.Path('output/alloc-audit.json').read_text())\nreq_case={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nreq_step={'op','heap_sig','fl_count','fl_sig','byte_total'}\nerrs=[]\nfor c in obj.get('cases',[]):\n    miss=req_case-set(c)\n    if miss: errs.append((c.get('name'), 'missing_case_keys', sorted(miss)))\n    steps=c.get('steps',[])\n    for i,s in enumerate(steps):\n        miss=req_step-set(s)\n        if miss: errs.append((c.get('name'), f'missing_step_keys@{i}', sorted(miss)))\n    led=pathlib.Path(c.get('ledger',''))\n    if not led.exists():\n        errs.append((c.get('name'),'missing_ledger',str(led)))\n    else:\n        n=sum(1 for _ in led.open('r'))\n        if n!=len(steps):\n            errs.append((c.get('name'),'ledger_len_mismatch',{'steps':len(steps),'ledger_lines':n,'path':str(led)}))\nprint('errors',len(errs))\nfor e in errs[:50]:\n    print('ERR',e)\nsys.exit(1 if errs else 0)\nPY\n"]
[46.964815, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h"]
