[46.003711, "o", "top_keys ['cases']\r\ncases 6\r\ncedar ok= True steps= 5 ledger= /app/output/cedar.ledger.jsonl\r\njade ok= True steps= 8 ledger= /app/output/jade.ledger.jsonl\r\nslate ok= True steps= 7 ledger= /app/output/slate.ledger.jsonl\r\n"]
