Sending keys: ["python3 - <<'PY'\nimport json, pathlib\nroot=pathlib.Path('/app/output')\nREQ_CASE_KEYS={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nREQ_STEP_KEYS={'op','heap_sig','fl_count','fl_sig','byte_total'}\nerrs=[]\nfor name in ['cedar','jade','slate','coral','onyx','pearl']:\n    p=root/f'{name}-audit.json'\n    if not p.exists():\n        errs.append((name,'missing audit file'))\n        continue\n    obj=json.loads(p.read_text())\n    if not isinstance(obj, dict) or 'cases' in obj:\n        errs.append((name,f'wrong top-level shape keys={list(obj) if isinstance(obj,dict) else type(obj)}'))\n        continue\n    miss=REQ_CASE_KEYS-set(obj.keys())\n    if miss:\n        errs.append((name,f'missing keys {sorted(miss)}'))\n        continue\n    ledger=obj['ledger']\n    lp=pathlib.Path(ledger) if str(ledger).startswith('/') else (root/ledger)\n    if not lp.exists():\n        errs.append((name,f'ledger missing {lp}'))\n        continue\n    steps=obj['steps']\n    lines=lp.read_text().splitlines()\n    if len(steps)!=len(lines):\n        errs.append((name,f'steps {len(steps)} != ledger lines {len(lines)}'))\n        continue\n    for i,s in enumerate(steps):\n        m=REQ_STEP_KEYS-set(s.keys())\n        if m:\n            errs.append((name,f'step {i} missing keys {sorted(m)}'))\n            break\n        row=json.loads(lines[i])\n        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n            if row.get(k)!=s.get(k):\n                errs.append((name,f'mismatch step {i} {k}: step={s.get(k)} ledger={row.get(k)}'))\n                break\n        else:\n            continue\n        break\n    if steps:\n        last=steps[-1]\n        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n            if obj.get(k)!=last.get(k):\n                errs.append((name,f'summary {k} != last step'))\n                break\nprint('errors',len(errs))\nfor e in errs:\n    print('ERR',*e)\nPY\n"] min_timeout_sec: 1.0 max_