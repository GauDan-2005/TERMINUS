[138.396986, "o", "\u001b[?2004l\r\u001b[?2004h>     write_case_top(fp, res);\r\n\u001b[?2004l\r\u001b[?2004h>     fclose(fp);\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> int emit_matrix(const CaseResult *cases, int count, const char *audit_path) {\r\n\u001b[?2004l\r\u001b[?2004h>     FILE *fp = fopen(audit_path, \"w\");\r\n\u001b[?2004l\r\u001b[?2004h>     if (!fp) {\r\n\u001b[?2004l\r\u001b[?2004h>         return -1;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     fprintf(fp, \"{\\n  \\\"cases\\\": [\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < count; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         write_case_matrix(fp, &cases[i], i + 1 == count);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     fprintf(fp, \"  ]\\n}\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     fclose(fp);\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
