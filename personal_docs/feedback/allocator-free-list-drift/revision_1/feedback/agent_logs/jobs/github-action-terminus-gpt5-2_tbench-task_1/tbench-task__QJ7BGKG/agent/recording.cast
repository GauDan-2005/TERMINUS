[56.426992, "i", "python3 - <<'PY'\nimport json, difflib\nimport pathlib\nj1=json.loads(pathlib.Path('/tmp/alloc-audit.1.json').read_text())\nj2=json.loads(pathlib.Path('/tmp/alloc-audit.2.json').read_text())\n# compare canonical strings for readable diff head\ns1=json.dumps(j1, sort_keys=True, indent=2)\ns2=json.dumps(j2, sort_keys=True, indent=2)\nd=list(difflib.unified_diff(s1.splitlines(), s2.splitlines(), lineterm=''))\nprint('\\n'.join(d[:120]))\nprint('diff_lines',len(d))\nPY\n"]
