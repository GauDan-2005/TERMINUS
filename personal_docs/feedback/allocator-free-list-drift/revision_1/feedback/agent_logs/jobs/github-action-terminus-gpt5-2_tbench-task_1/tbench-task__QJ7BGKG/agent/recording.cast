[138.389634, "o", "\u001b[?2004h"]
[138.389735, "o", "> "]
[138.389901, "o", "                st->byte_total);\r\n\u001b[?2004l\r"]
[138.389998, "o", "\u001b[?2004h"]
[138.390104, "o", "> "]
[138.390268, "o", "        if (i + 1 < res->step_count) {\r\n\u001b[?2004l\r"]
[138.390316, "o", "\u001b[?2004h> "]
