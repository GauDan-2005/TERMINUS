[46.201048, "o", "\u001b[?2004hroot@c1b30d754223:/app# "]
[47.162668, "i", "python3 - <<'PY'\nimport json, pathlib\nREQ_CASE_KEYS={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nREQ_STEP_KEYS={'op','heap_sig','fl_count','fl_sig','byte_total'}\nroot=pathlib.Path('/app/output')\nobj=json.loads((root/'alloc-audit.json').read_text())\nerrs=[]\nfor case in obj.get('cases',[]):\n    missing=REQ_CASE_KEYS-set(case.keys())\n    if missing:\n        errs.append((case.get('name'),f'missing case keys {sorted(missing)}'))\n        continue\n    ledger_path=root/case['ledger'] if not str(case['ledger']).startswith('/') else pathlib.Path(case['ledger'])\n    if not ledger_path.exists():\n        errs.append((case['name'],f'ledger missing {ledger_path}'))\n        continue\n    steps=case['steps']\n    ledger_lines=ledger_path.read_text().splitlines()\n    if len(steps)!=len(ledger_lines):\n        errs.append((case['name'],f'steps ({len(steps)}) != ledger lines ({len(ledger_lines)})'))\n    # check step keys and that ledger row surfaces match step surfaces\n    for i,s in enumerate(steps):\n        m=REQ_STEP_KEYS-set(s.keys())\n        if m:\n            errs.append((case['name'],f'step {i} missing keys {sorted(m)}'))\n            break\n        try:\n            row=json.loads(ledger_lines[i])\n        except Exception as e:\n            errs.append((case['name'],f'bad ledger json line {i}: {e}'))\n            break\n        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n            if row.get(k)!=s.get(k):\n                errs.append((case['name'],f'mismatch at step {i} field {k}: step={s.get(k)} ledger={row.get(k)}'))\n                break\n        else:\n            continue\n        break\n    # final step should match case summary surfaces\n    if steps:\n        last=steps[-1]\n        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n            if last.get(k)!=case.get(k):\n                errs.append((case['name'],f'case summary {k} != last step: case={case.get(k)} last={last.get(k)}'))\n                break\nprint('errors',len(errs))\nfor e in errs[:50]:\n    print('ERR',e[0],e[1])\nPY\n"]
