[144.514026, "o", "\u001b[?2004hroot@c1b30d754223:/app# "]
[147.506243, "i", "python3 - <<'PY'\nimport json, pathlib\nroot=pathlib.Path('/app/output')\nREQ_CASE_KEYS={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nREQ_STEP_KEYS={'op','heap_sig','fl_count','fl_sig','byte_total'}\nerrs=[]\nfor name in ['cedar','jade','slate','coral','onyx','pearl']:\n    p=root/f'{name}-audit.json'\n    if not p.exists():\n        errs.append((name,'missing audit file'))\n        continue\n    obj=json.loads(p.read_text())\n    if not isinstance(obj, dict) or 'cases' in obj:\n        errs.append((name,f'wrong top-level shape keys={list(obj) if isinstance(obj,dict) else type(obj)}'))\n        continue\n    miss=REQ_CASE_KEYS-set(obj.keys())\n    if miss:\n        errs.append((name,f'missing keys {sorted(miss)}'))\n        continue\n    ledger=obj['ledger']\n    lp=pathlib.Path(ledger) if str(ledger).startswith('/') else (root/ledger)\n    if not lp.exists():\n        errs.append((name,f'ledger missing {lp}'))\n        continue\n    steps=obj['steps']\n    lines=lp.read_text().splitlines()\n    if len(steps)!=len(lines):\n        errs.append((name,f'steps {len(steps)} != ledger lines {len(lines)}'))\n        continue\n    for i,s in enumerate(steps):\n        m=REQ_STEP_KEYS-set(s.keys())\n        if m:\n            errs.append((name,f'step {i} missing keys {sorted(m)}'))\n            break\n        row=json.loads(lines[i])\n        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n            if row.get(k)!=s.get(k):\n                errs.append((name,f'mismatch step {i} {k}: step={s.get(k)} ledger={row.get(k)}'))\n                break\n        else:\n            continue\n        break\n    if steps:\n        last=steps[-1]\n        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n            if obj.get(k)!=last.get(k):\n                errs.append((name,f'summary {k} != last step'))\n                break\nprint('errors',len(errs))\nfor e in errs:\n    print('ERR',*e)\nPY\n"]
[147.50672, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json, pathlib\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.506901, "o", "root=pathlib.Path('/app/output')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.507288, "o", "REQ_CASE_KEYS={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\r\n\u001b[?2004l\r"]
[147.507358, "o", "\u001b[?2004h> "]
[147.507734, "o", "REQ_STEP_KEYS={'op','heap_sig','fl_count','fl_sig','byte_total'}\r\n\u001b[?2004l\r\u001b[?2004h> errs=[]\r\n\u001b[?2004l\r"]
[147.507841, "o", "\u001b[?2004h"]
[147.507878, "o", "> "]
[147.508082, "o", "for name in ['cedar','jade','slate','coral','onyx','pearl']:\r\n\u001b[?2004l\r"]
[147.508147, "o", "\u001b[?2004h> "]
[147.508251, "o", "    p=root/f'{name}-audit.json'\r\n\u001b[?2004l\r"]
[147.508315, "o", "\u001b[?2004h> "]
[147.508392, "o", "    if not p.exists():\r\n\u001b[?2004l\r"]
[147.508461, "o", "\u001b[?2004h> "]
[147.508623, "o", "        errs.append((name,'missing audit file'))\r\n\u001b[?2004l\r"]
[147.508687, "o", "\u001b[?2004h> "]
[147.508752, "o", "        continue\r\n\u001b[?2004l\r"]
[147.508806, "o", "\u001b[?2004h> "]
[147.508913, "o", "    obj=json.loads(p.read_text())\r\n\u001b[?2004l\r"]
[147.509005, "o", "\u001b[?2004h> "]
[147.509151, "o", "    if not isinstance(obj, dict) or 'cases' in obj:\r\n\u001b[?2004l\r"]
[147.509212, "o", "\u001b[?2004h> "]
[147.509598, "o", "        errs.append((name,f'wrong top-level shape keys={list(obj) if isinstance(obj,dict) else type(obj)}'))\r\n\u001b[?2004l\r"]
[147.509662, "o", "\u001b[?2004h> "]
[147.509725, "o", "        continue\r\n\u001b[?2004l\r"]
[147.509784, "o", "\u001b[?2004h> "]
[147.509914, "o", "    miss=REQ_CASE_KEYS-set(obj.keys())\r\n\u001b[?2004l\r"]
[147.509994, "o", "\u001b[?2004h> "]
[147.510062, "o", "    if miss:\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.510255, "o", "> "]
[147.510391, "o", "        errs.append((name,f'missing keys {sorted(miss)}'))\r\n\u001b[?2004l\r"]
[147.510423, "o", "\u001b[?2004h"]
[147.510446, "o", "> "]
[147.510839, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h>     ledger=obj['ledger']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.510997, "o", "    lp=pathlib.Path(ledger) if str(ledger).startswith('/') else (root/ledger)\r\n\u001b[?2004l\r"]
[147.511079, "o", "\u001b[?2004h> "]
[147.51114, "o", "    if not lp.exists():\r\n\u001b[?2004l\r"]
[147.511207, "o", "\u001b[?2004h"]
[147.511279, "o", "> "]
[147.511374, "o", "        errs.append((name,f'ledger missing {lp}'))\r\n\u001b[?2004l\r"]
[147.511401, "o", "\u001b[?2004h> "]
[147.511499, "o", "        continue\r\n\u001b[?2004l\r"]
[147.511526, "o", "\u001b[?2004h> "]
[147.511637, "o", "    steps=obj['steps']\r\n\u001b[?2004l\r"]
[147.511721, "o", "\u001b[?2004h> "]
[147.511842, "o", "    lines=lp.read_text().splitlines()\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.511927, "o", "> "]
[147.511997, "o", "    if len(steps)!=len(lines):\r\n\u001b[?2004l\r"]
[147.512541, "o", "\u001b[?2004h>         errs.append((name,f'steps {len(steps)} != ledger lines {len(lines)}'))\r\n\u001b[?2004l\r\u001b[?2004h>         continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.512648, "o", "    for i,s in enumerate(steps):\r\n\u001b[?2004l\r"]
[147.512678, "o", "\u001b[?2004h> "]
[147.512822, "o", "        m=REQ_STEP_KEYS-set(s.keys())\r\n\u001b[?2004l\r"]
[147.512852, "o", "\u001b[?2004h> "]
[147.512978, "o", "        if m:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.51316, "o", "            errs.append((name,f'step {i} missing keys {sorted(m)}'))\r\n\u001b[?2004l\r"]
[147.513192, "o", "\u001b[?2004h> "]
[147.51331, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.513444, "o", "        row=json.loads(lines[i])\r\n\u001b[?2004l\r"]
[147.513561, "o", "\u001b[?2004h> "]
[147.513678, "o", "        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\r\n\u001b[?2004l\r"]
[147.513703, "o", "\u001b[?2004h> "]
[147.513837, "o", "            if row.get(k)!=s.get(k):\r\n\u001b[?2004l\r"]
[147.513863, "o", "\u001b[?2004h"]
[147.51388, "o", "> "]
[147.514189, "o", "                errs.append((name,f'mismatch step {i} {k}: step={s.get(k)} ledger={row.get(k)}'))\r\n\u001b[?2004l\r"]
[147.514221, "o", "\u001b[?2004h> "]
[147.514332, "o", "                break\r\n\u001b[?2004l\r"]
[147.514425, "o", "\u001b[?2004h> "]
[147.514531, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r"]
[147.514568, "o", "\u001b[?2004h> "]
[147.514668, "o", "        break\r\n\u001b[?2004l\r"]
[147.514754, "o", "\u001b[?2004h> "]
[147.514854, "o", "    if steps:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.514924, "o", "        last=steps[-1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.515006, "o", "> "]
[147.515157, "o", "        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\r\n\u001b[?2004l\r"]
[147.515278, "o", "\u001b[?2004h> "]
[147.515361, "o", "            if obj.get(k)!=last.get(k):\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.515388, "o", "> "]
[147.5156, "o", "                errs.append((name,f'summary {k} != last step'))\r\n\u001b[?2004l\r"]
[147.515628, "o", "\u001b[?2004h> "]
[147.515733, "o", "                break\r\n\u001b[?2004l\r"]
[147.515801, "o", "\u001b[?2004h> "]
[147.515947, "o", "print('errors',len(errs))\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.516059, "o", "> for e in errs:\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.516167, "o", ">     print('ERR',*e)\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.516261, "o", "> PY\r\n\u001b[?2004l\r"]
[147.539993, "o", "errors 0\r\n"]
[147.543562, "o", "\u001b[?2004hroot@c1b30d754223:/app# "]
