[138.386355, "o", "> "]
[138.388356, "o", "    esc(fp, res->ledger_path);\r\n\u001b[?2004l\r\u001b[?2004h>     fprintf(fp, \",\\n  \\\"steps\\\": [\\n\");\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < res->step_count; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         const StepRec *st = &res->steps[i];\r\n\u001b[?2004l\r\u001b[?2004h>         fprintf(fp, \"    {\\\"seq\\\": %d, \\\"op\\\": \", st->seq);\r\n\u001b[?2004l\r\u001b[?2004h>         esc(fp, st->op);\r\n\u001b[?2004l\r\u001b[?2004h>         fprintf(fp,\r\n\u001b[?2004l\r\u001b[?2004h>                 \", \\\"index\\\": %d, \\\"size\\\": %zu, \\\"result_index\\\": %d, \\\"heap_sig\\\": %zu, \"\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.388469, "o", "> "]
