[131.836045, "o", "#include <stddef.h>\r\n\r\nsize_t spill_bucket(size_t v) {\r\n    size_t b = 1;\r\n    while (b < v) {\r\n        b <<= 1;\r\n    }\r\n    return b;\r\n}\r\n"]
