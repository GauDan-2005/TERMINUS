[95.038501, "o", "#include <stddef.h>\r\n#include <string.h>\r\n\r\nint xc2(void *a, void *b, size_t c) {\r\n    unsigned char *dst = (unsigned char *)a;\r\n    unsigned char *src = (unsigned char *)b;\r\n    size_t n = c / 2;\r\n    if (n == 0 && c > 0) {\r\n        n = 1;\r\n    }\r\n    memcpy(dst, src, n);\r\n    return (int)n;\r\n}\r\n"]
[95.038803, "o", "\u001b[?2004hroot@ca01a171e8aa:/app# "]
