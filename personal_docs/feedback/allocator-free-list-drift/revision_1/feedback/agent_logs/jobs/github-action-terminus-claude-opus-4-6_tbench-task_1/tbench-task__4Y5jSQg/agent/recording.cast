[273.005766, "i", "cat > /app/move_d/move.c << 'EOF'\n#include <stddef.h>\n#include <string.h>\n\nint xc2(void *a, void *b, size_t c) {\n    unsigned char *dst = (unsigned char *)a;\n    unsigned char *src = (unsigned char *)b;\n    size_t n = c;\n    if (n == 0) {\n        return 0;\n    }\n    memcpy(dst, src, n);\n    return (int)n;\n}\nEOF\n"]
