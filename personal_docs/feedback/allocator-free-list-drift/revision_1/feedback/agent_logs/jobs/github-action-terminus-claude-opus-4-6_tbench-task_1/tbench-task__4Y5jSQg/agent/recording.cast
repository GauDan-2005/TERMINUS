[8.663637, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nCASE=\"${1:?case name required}\"\r\nmkdir -p \"${APP_ROOT}/output\"\r\n\"${APP_ROOT}/bin/allocctl\" one \"${CASE}\"\r\n"]
[8.663904, "o", "\u001b[?2004h"]
[8.664025, "o", "root@ca01a171e8aa:/app# "]
[15.737733, "i", "cat /app/docs/layout.md\n"]
[15.738137, "o", "cat /app/docs/layout.md\r\n\u001b[?2004l\r"]
[15.739259, "o", "# Layout\r\n\r\nInternal modules are grouped by responsibility: tag maintenance, intrusive list wiring, block division, relocation copies, tally updates, plan ingestion, and report emission. The driver coordinates a single arena per scenario run.\r\n"]
[15.739408, "o", "\u001b[?2004h"]
[15.739441, "o", "root@ca01a171e8aa:/app# "]
[15.849443, "i", "cat /app/docs/operations.md\n"]
[15.849704, "o", "cat /app/docs/operations.md\r\n\u001b[?2004l\r"]
[15.850583, "o", "# Operations\r\n\r\nThe control binary supports `matrix` and `one <scenario>` modes. Matrix mode writes the combined audit under the output directory configured at build time.\r\n\r\nScenario scripts live under `data/cases/` as line-oriented operation lists.\r\n"]
[15.852184, "o", "\u001b[?2004h"]
[15.852286, "o", "root@ca01a171e8aa:/app# "]
[15.957232, "i", "cat /app/include/arena.h\n"]
[15.958354, "o", "cat /app/include/arena.h\r\n\u001b[?2004l\r"]
[15.958964, "o", "#ifndef ARENA_H\r\n#define ARENA_H\r\n\r\n#include \"block.h\"\r\n#include \"stats.h\"\r\n\r\n#include <stddef.h>\r\n\r\n#define HEAP_BYTES 65536\r\n#define MAX_SLOTS 64\r\n#define FL_MAP_SZ (HEAP_BYTES / 8)\r\n\r\ntypedef struct Arena {\r\n    unsigned char mem[HEAP_BYTES];\r\n    size_t used;\r\n    Block head;\r\n    Block fl_head;\r\n    size_t fl_link_next[FL_MAP_SZ];\r\n    size_t fl_link_prev[FL_MAP_SZ];\r\n    void *slots[MAX_SLOTS];\r\n    size_t slot_payload[MAX_SLOTS];\r\n    int slot_live[MAX_SLOTS];\r\n    int slot_count;\r\n    Stats stats;\r\n} Arena;\r\n\r\nvoid arena_init(Arena *a);\r\nint arena_slot_alloc(Arena *a, size_t req);\r\nint arena_slot_free(Arena *a, int idx);\r\nint arena_slot_realloc(Arena *a, int idx, size_t req);\r\nsize_t arena_heap_sig(const Arena *a);\r\nsize_t arena_fl_sig(const Arena *a);\r\nint arena_fl_count(const Arena *a);\r\n\r\n#endif\r\n"]
[15.959201, "o", "\u001b[?2004hroot@ca01a171e8aa:/app# "]
[16.081802, "i", "cat /app/include/block.h\n"]
[16.082128, "o", "cat /app/include/block.h\r\n\u001b[?2004l\r"]
[16.082899, "o", "#ifndef BLOCK_H\r\n#define BLOCK_H\r\n\r\n#include <stddef.h>\r\n\r\n#define HDR_SIZE 16\r\n#define FTR_SIZE 8\r\n#define FL_END ((size_t)-1)\r\n#define MIN_BLK 40\r\n#define ALIGN 8\r\n\r\ntypedef struct Block {\r\n    unsigned char *base;\r\n    size_t off;\r\n} Block;\r\n\r\nstatic inline size_t blk_align(size_t n) {\r\n    return (n + (ALIGN - 1)) & ~(size_t)(ALIGN - 1);\r\n}\r\n\r\n#endif\r\n"]
[16.083041, "o", "\u001b[?2004h"]
[16.083171, "o", "root@ca01a171e8aa:/app# "]
[16.189784, "i", "cat /app/include/plan.h\n"]
[16.190251, "o", "cat /app/include/plan.h\r\n\u001b[?2004l\r"]
[16.191265, "o", "#ifndef PLAN_H\r\n#define PLAN_H\r\n\r\n#include <stddef.h>\r\n\r\n#define MAX_OPS 128\r\n\r\ntypedef enum {\r\n    OP_ALLOC = 1,\r\n    OP_FREE = 2,\r\n    OP_REALLOC = 3\r\n} OpKind;\r\n\r\ntypedef struct PlanOp {\r\n    OpKind kind;\r\n    size_t size;\r\n    int index;\r\n    int new_index;\r\n} PlanOp;\r\n\r\ntypedef struct Plan {\r\n    char name[32];\r\n    PlanOp ops[MAX_OPS];\r\n    int op_count;\r\n} Plan;\r\n\r\nint plan_load(const char *path, Plan *out);\r\n\r\n#endif\r\n"]
[16.191415, "o", "\u001b[?2004h"]
[16.191522, "o", "root@ca01a171e8aa:/app# "]
[16.293393, "i", "cat /app/include/report.h\n"]
[16.293612, "o", "cat /app/include/report.h\r\n\u001b[?2004l\r"]
[16.294497, "o", "#ifndef REPORT_H\r\n#define REPORT_H\r\n\r\n#include \"arena.h\"\r\n#include \"plan.h\"\r\n\r\n#include <stddef.h>\r\n\r\n#define MAX_STEPS 128\r\n\r\ntypedef struct StepRec {\r\n    int seq;\r\n    char op[16];\r\n    int index;\r\n    size_t size;\r\n    int result_index;\r\n    size_t heap_sig;\r\n    int fl_count;\r\n    size_t fl_sig;\r\n    size_t byte_total;\r\n} StepRec;\r\n\r\ntypedef struct CaseResult {\r\n    char name[32];\r\n    int ok;\r\n    StepRec steps[MAX_STEPS];\r\n    int step_count;\r\n    size_t heap_sig;\r\n    int fl_count;\r\n    size_t fl_sig;\r\n    size_t byte_total;\r\n    char ledger_path[256];\r\n} CaseResult;\r\n\r\nint run_case(const Plan *plan, const char *out_dir, CaseResult *res);\r\nint emit_e(const CaseResult *res, const char *audit_path);\r\nint emit_matrix(const CaseResult *cases, int count, const char *audit_path);\r\n\r\n#endif\r\n"]
[16.295337, "o", "\u001b[?2004hroot@ca01a171e8aa:/app# "]
[16.40571, "i", "cat /app/include/stats.h\n"]
[16.406186, "o", "cat /app/include/stats.h\r\n\u001b[?2004l\r"]
[16.409142, "o", "#ifndef STATS_H\r\n#define STATS_H\r\n\r\n#include <stddef.h>\r\n\r\ntypedef struct Stats {\r\n    size_t allocated;\r\n    size_t peak;\r\n    size_t live_blocks;\r\n} Stats;\r\n\r\n#endif\r\n"]
