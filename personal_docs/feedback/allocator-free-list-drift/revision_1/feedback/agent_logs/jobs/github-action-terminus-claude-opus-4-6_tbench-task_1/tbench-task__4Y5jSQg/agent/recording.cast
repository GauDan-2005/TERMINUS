[8.549392, "o", "#!/bin/bash\r\nset -euo pipefail\r\nAPP_ROOT=\"${APP_ROOT:-/app}\"\r\nOUT=\"${APP_ROOT}/output\"\r\nmkdir -p \"${OUT}\"\r\nbash \"${APP_ROOT}/scripts/clean-room.sh\"\r\n\"${APP_ROOT}/bin/allocctl\" matrix\r\n"]
[8.549554, "o", "\u001b[?2004hroot@ca01a171e8aa:/app# "]
[8.661862, "i", "cat /app/scripts/run-one.sh\n"]
