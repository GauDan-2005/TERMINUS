[287.84542, "i", "python3 << 'EOF'\nimport json\n\nmatrix = json.load(open('/app/output/alloc-audit.json'))\nfor case in matrix['cases']:\n    name = case['name']\n    single = json.load(open(f'/app/output/{name}-audit.json'))\n    assert single['cases'][0] == case, f\"{name}: MISMATCH between matrix and single\"\n    print(f\"{name}: single matches matrix\")\n\nprint(\"\\nAll cases match!\")\nEOF\n"]
