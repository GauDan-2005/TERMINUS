[226.789909, "i", "cat > /app/acct_e/acct.c << 'EOF'\n#include \"../include/stats.h\"\n\n#include <stddef.h>\n#include <sys/types.h>\n\nvoid xd3(Stats *a, ssize_t b) {\n    if (b > 0) {\n        a->allocated += (size_t)b;\n    } else {\n        a->allocated -= (size_t)(-b);\n    }\n    if (a->allocated > a->peak) {\n        a->peak = a->allocated;\n    }\n}\nEOF\n"]
