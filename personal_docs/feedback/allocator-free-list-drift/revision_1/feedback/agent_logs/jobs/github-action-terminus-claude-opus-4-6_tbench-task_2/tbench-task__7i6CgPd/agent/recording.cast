[227.293177, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> int xc2(void *a, void *b, size_t c) {\r\n\u001b[?2004l\r\u001b[?2004h>     unsigned char *dst = (unsigned char *)a;\r\n\u001b[?2004l\r\u001b[?2004h>     unsigned char *src = (unsigned char *)b;\r\n\u001b[?2004l\r\u001b[?2004h>     size_t n = c;\r\n\u001b[?2004l\r\u001b[?2004h>     if (n == 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         return 0;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     memcpy(dst, src, n);\r\n\u001b[?2004l\r\u001b[?2004h>     return (int)n;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@9147ef5e1606:/app# "]
[227.802407, "i", "cat > /app/list_b/list.c << 'EOF'\n#include \"../include/arena.h\"\n#include \"../pool_a/tag.h\"\n\n#include <stddef.h>\n#include <string.h>\n\nstatic size_t fl_ix(size_t off) {\n    return off >> 3;\n}\n\nstatic void fl_clear(Arena *a, size_t off) {\n    size_t ix = fl_ix(off);\n    a->fl_link_next[ix] = FL_END;\n    a->fl_link_prev[ix] = FL_END;\n}\n\nvoid xb1(Arena *a, Block *b) {\n    size_t off = b->off;\n    size_t ix = fl_ix(off);\n    size_t old = a->fl_head.off;\n    a->fl_link_next[ix] = old;\n    a->fl_link_prev[ix] = FL_END;\n    if (old != FL_END) {\n        a->fl_link_prev[fl_ix(old)] = off;\n    }\n    a->fl_head.base = b->base;\n    a->fl_head.off = off;\n}\n\nvoid list_remove(Arena *a, Block *b) {\n    size_t off = b->off;\n    size_t ix = fl_ix(off);\n    size_t nxt = a->fl_link_next[ix];\n    size_t prv = a->fl_link_prev[ix];\n    if (nxt != FL_END) {\n        a->fl_link_prev[fl_ix(nxt)] = prv;\n    }\n    if (prv != FL_END) {\n        a->fl_link_next[fl_ix(prv)] = nxt;\n    } else {\n        a->fl_head.off = nxt;\n    }\n    fl_clear(a, off);\n}\n\nvoid list_coalesce(Arena *a, Block *b) {\n    size_t total = tag_read_size(b);\n    size_t off;\n\n    /* Merge with next neighbor if free */\n    off = b->off + total;\n    if (off < a->used) {\n        Block nb = {b->base, off};\n        if (!z_is_flag(&nb)) {\n            list_remove(a, &nb);\n            total += tag_read_size(&nb);\n            xa0(b, total);\n        }\n    }\n\n    /* Merge with previous neighbor if free */\n    if (b->off > 0) {\n        size_t *prev_ftr = (size_t *)(void *)(b->base + b->off - FTR_SIZE);\n        size_t prev_total = prev_ftr[0];\n        if (prev_total > 0 && prev_total <= b->off) {\n            Block pb = {b->base, b->off - prev_total};\n            if (!z_is_flag(&pb)) {\n                list_remove(a, &pb);\n                total += prev_total;\n                pb.off = b->off - prev_total;\n                xa0(&pb, total);\n                *b = pb;\n            }\n        }\n    }\n\n    xb1(a, b);\n}\n\nint q8f_blk(Arena *a, Block *oldb, size_t need, size_t *merged_out) {\n    size_t old_total = tag_read_size(oldb);\n    size_t next_off = oldb->off + old_total;\n    size_t ntotal;\n    Block nb;\n    if (next_off >= a->used) {\n        return -1;\n    }\n    nb.base = oldb->base;\n    nb.off = next_off;\n    if (z_is_flag(&nb)) {\n        return -1;\n    }\n    ntotal = tag_read_size(&nb);\n    if (old_total + ntotal < need) {\n        return -1;\n    }\n    list_remove(a, &nb);\n    *merged_out = old_total + ntotal;\n    xa0(oldb, *merged_out);\n    z_set_flag(oldb, 1);\n    return 0;\n}\nEOF\n"]
