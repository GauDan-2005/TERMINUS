[281.842713, "i", "python3 << 'EOF'\nimport json\n\n# Check ledger consistency for all cases\nmatrix = json.load(open('/app/output/alloc-audit.json'))\nfor case in matrix['cases']:\n    name = case['name']\n    ledger_path = case['ledger']\n    with open(ledger_path) as f:\n        ledger_rows = [json.loads(line) for line in f if line.strip()]\n    steps = case['steps']\n    assert len(ledger_rows) == len(steps), f\"{name}: ledger count mismatch {len(ledger_rows)} vs {len(steps)}\"\n    for i, (lr, st) in enumerate(zip(ledger_rows, steps)):\n        for key in lr:\n            assert lr[key] == st[key], f\"{name} step {i} key {key}: ledger={lr[key]} vs step={st[key]}\"\n    print(f\"{name}: ledger consistent ({len(steps)} steps)\")\n\nprint(\"\\nAll ledgers consistent!\")\nEOF\n"]
[281.843015, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.843233, "o", "> import json"]
[281.843315, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[281.843788, "o", "> "]
[281.845162, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
