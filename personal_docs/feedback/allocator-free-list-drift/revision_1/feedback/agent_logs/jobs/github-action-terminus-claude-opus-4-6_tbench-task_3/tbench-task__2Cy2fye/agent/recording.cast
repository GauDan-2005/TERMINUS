[506.796608, "i", "python3 -c \"\nimport json\nwith open('/app/output/alloc-audit.json') as f:\n    d = json.load(f)\ncases = d['cases']\nnames = [c['name'] for c in cases]\nexpected = ['cedar','jade','slate','coral','onyx','pearl']\nassert set(names) == set(expected), f'Missing cases: {set(expected)-set(names)}'\nfor c in cases:\n    assert c['ok'] == True, f'{c[\"name\"]} not ok'\n    assert 'steps' in c and len(c['steps']) > 0\n    assert 'heap_sig' in c\n    assert 'fl_count' in c\n    assert 'fl_sig' in c\n    assert 'byte_total' in c\n    assert 'ledger' in c\n    assert c['ledger'].endswith('.ledger.jsonl')\nprint(f'All {len(cases)} cases valid with ok=true')\n\" 2>&1\n"]
[506.797266, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h"]
[506.797618, "o", "> import json\r\n\u001b[?2004l\r\u001b[?2004h> "]
[506.798021, "o", "with open('/app/output/alloc-audit.json') as f:"]
[506.798538, "o", "\r\n"]
[506.798668, "o", "\u001b[?2004l\r"]
[506.79882, "o", "\u001b[?2004h"]
[506.798924, "o", "> "]
[506.799594, "o", "    d = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> cases = d['cases']\r\n\u001b[?2004l\r\u001b[?2004h> names = [c['name'] for c in cases]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[506.799944, "o", "expected = ['cedar','jade','slate','coral','onyx','pearl']\r\n\u001b[?2004l\r"]
[506.799984, "o", "\u001b[?2004h> "]
[506.800385, "o", "assert set(names) == set(expected), f'Missing cases: {set(expected)-set(names)}'\r\n\u001b[?2004l\r"]
[506.800419, "o", "\u001b[?2004h"]
[506.800442, "o", "> "]
[506.800499, "o", "for c in cases:\r\n\u001b[?2004l\r"]
[506.800522, "o", "\u001b[?2004h"]
[506.800544, "o", "> "]
[506.80072, "o", "    assert c['ok'] == True, f'{c[\"name\"]} not ok'\r\n\u001b[?2004l\r"]
[506.800755, "o", "\u001b[?2004h"]
[506.80078, "o", "> "]
[506.801129, "o", "    assert 'steps' in c and len(c['steps']) > 0\r\n\u001b[?2004l\r\u001b[?2004h>     assert 'heap_sig' in c\r\n\u001b[?2004l\r\u001b[?2004h> "]
[506.801293, "o", "    assert 'fl_count' in c\r\n\u001b[?2004l\r\u001b[?2004h> "]
[506.801384, "o", "    assert 'fl_sig' in c\r\n\u001b[?2004l\r"]
[506.801421, "o", "\u001b[?2004h> "]
[506.801554, "o", "    assert 'byte_total' in c\r\n\u001b[?2004l\r"]
[506.801583, "o", "\u001b[?2004h> "]
[506.801676, "o", "    assert 'ledger' in c\r\n\u001b[?2004l\r"]
[506.801709, "o", "\u001b[?2004h"]
[506.801729, "o", "> "]
[506.801877, "o", "    assert c['ledger'].endswith('.ledger.jsonl')\r\n\u001b[?2004l\r"]
[506.801912, "o", "\u001b[?2004h"]
[506.801933, "o", "> "]
[506.802093, "o", "print(f'All {len(cases)} cases valid with ok=true')\r\n\u001b[?2004l\r"]
[506.802133, "o", "\u001b[?2004h> "]
[506.802171, "o", "\" 2>&1\r\n\u001b[?2004l\r"]
[506.821148, "o", "All 6 cases valid with ok=true\r\n"]
[506.82428, "o", "\u001b[?2004hroot@091939ae3883:/app# "]
