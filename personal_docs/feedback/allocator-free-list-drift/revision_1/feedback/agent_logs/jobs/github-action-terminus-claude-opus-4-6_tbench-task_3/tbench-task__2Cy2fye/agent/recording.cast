[422.450454, "o", "int q8f_blk(Arena *a, Block *oldb, size_t need, size_t *merged_out) {\r\n\u001b[?2004l\r"]
[422.450527, "o", "\u001b[?2004h> "]
[422.450663, "o", "    size_t old_total = tag_read_size(oldb);\r\n\u001b[?2004l\r"]
[422.450744, "o", "\u001b[?2004h> "]
[422.450868, "o", "    size_t next_off = oldb->off + old_total;\r\n\u001b[?2004l\r"]
[422.450968, "o", "\u001b[?2004h> "]
[422.451055, "o", "    size_t ntotal;\r\n\u001b[?2004l\r\u001b[?2004h"]
[422.451145, "o", ">     Block nb;\r\n\u001b[?2004l\r"]
[422.451203, "o", "\u001b[?2004h> "]
[422.45128, "o", "    if (next_off >= a->used) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[422.45136, "o", "> "]
[422.451537, "o", "        return -1;\r\n\u001b[?2004l\r"]
[422.451624, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[422.451713, "o", "    nb.base = oldb->base;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[422.45186, "o", "    nb.off = next_off;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[422.45201, "o", "    if (z_is_flag(&nb)) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[422.452118, "o", "        return -1;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[422.45236, "o", "    ntotal = tag_read_size(&nb);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[422.452458, "o", "    if (old_total + ntotal < need) {\r\n\u001b[?2004l\r"]
[422.452559, "o", "\u001b[?2004h> "]
[422.452692, "o", "        return -1;\r\n\u001b[?2004l\r"]
[422.452836, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[422.452959, "o", "    list_remove(a, &nb);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[422.453106, "o", "    *merged_out = old_total + ntotal;\r\n\u001b[?2004l\r"]
[422.453248, "o", "\u001b[?2004h>     xa0(oldb, *merged_out);\r\n\u001b[?2004l\r"]
[422.453401, "o", "\u001b[?2004h>     z_set_flag(oldb, 1);\r\n\u001b[?2004l\r"]
[422.453574, "o", "\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n"]
