[102.260421, "o", "cat /app/list_b/list.h\r\n\u001b[?2004l\r"]
[102.262037, "o", "#ifndef LIST_H\r\n#define LIST_H\r\n\r\n#include \"../include/arena.h\"\r\n#include \"../include/block.h\"\r\n\r\nvoid xb1(Arena *a, Block *b);\r\nvoid list_remove(Arena *a, Block *b);\r\nvoid list_coalesce(Arena *a, Block *b);\r\nint q8f_blk(Arena *a, Block *oldb, size_t need, size_t *merged_out);\r\n\r\n#endif\r\n"]
[102.262752, "o", "\u001b[?2004hroot@091939ae3883:/app# "]
[102.380106, "i", "cat /app/acct_e/acct.c\n"]
[102.380549, "o", "cat /app/acct_e/acct.c\r\n\u001b[?2004l\r"]
[102.381585, "o", "#include \"../include/stats.h\"\r\n\r\n#include <stddef.h>\r\n#include <sys/types.h>\r\n\r\nvoid xd3(Stats *a, ssize_t b) {\r\n    if (b > 0) {\r\n        a->allocated += (size_t)b + 8;\r\n    } else {\r\n        a->allocated -= (size_t)(-b);\r\n    }\r\n    if (a->allocated > a->peak) {\r\n        a->peak = a->allocated;\r\n    }\r\n}\r\n"]
[102.381781, "o", "\u001b[?2004h"]
