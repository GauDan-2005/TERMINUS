[131.630323, "i", "python3 - <<'PY'\nimport json, os\np='/app/output/alloc-audit.json'\nwith open(p) as f: data=json.load(f)\nassert isinstance(data, dict)\nassert 'cases' in data and isinstance(data['cases'], list)\nprint('cases:', [c.get('name') for c in data['cases']])\nreq_case={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nreq_step={'seq','op','index','size','result_index','heap_sig','fl_count','fl_sig','byte_total'}\nmissing=[]\nfor c in data['cases']:\n    mc=sorted(req_case - set(c))\n    if mc: missing.append((c.get('name'), 'case', mc))\n    if not isinstance(c.get('steps'), list):\n        missing.append((c.get('name'), 'steps_not_list', []));\n        continue\n    for i,s in enumerate(c['steps']):\n        ms=sorted(req_step - set(s))\n        if ms:\n            missing.append((c.get('name'), f'step[{i}]', ms))\n            break\n    led=c.get('ledger')\n    if isinstance(led,str):\n        if not os.path.exists(led):\n            missing.append((c.get('name'), 'ledger_missing', [led]))\n    else:\n        missing.append((c.get('name'), 'ledger_not_str', []))\nprint('missing:', missing)\nPY\n"]
