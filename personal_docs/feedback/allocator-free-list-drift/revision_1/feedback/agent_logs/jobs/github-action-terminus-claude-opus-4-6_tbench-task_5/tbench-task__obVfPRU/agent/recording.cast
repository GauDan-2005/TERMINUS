[340.135625, "i", "cat > /app/move_d/move.c << 'EOF'\n#include <stddef.h>\n#include <string.h>\n\nint xc2(void *a, void *b, size_t c) {\n    unsigned char *dst = (unsigned char *)a;\n    unsigned char *src = (unsigned char *)b;\n    if (c > 0) {\n        memcpy(dst, src, c);\n    }\n    return (int)c;\n}\nEOF\n"]
