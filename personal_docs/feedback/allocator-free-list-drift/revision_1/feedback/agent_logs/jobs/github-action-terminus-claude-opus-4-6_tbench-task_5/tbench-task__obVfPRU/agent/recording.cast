[180.040459, "o", "#include \"../include/stats.h\"\r\n\r\n#include <stddef.h>\r\n#include <sys/types.h>\r\n\r\nvoid xd3(Stats *a, ssize_t b) {\r\n    if (b > 0) {\r\n        a->allocated += (size_t)b + 8;\r\n    } else {\r\n        a->allocated -= (size_t)(-b);\r\n    }\r\n    if (a->allocated > a->peak) {\r\n        a->peak = a->allocated;\r\n    }\r\n}\r\n"]
[180.040707, "o", "\u001b[?2004hroot@78e85912348b:/app# "]
