[87.790156, "o", "# Replace emit_e body\r\n\u001b[?2004l\r\u001b[?2004h"]
[87.790257, "o", "> import re\r\n\u001b[?2004l\r\u001b[?2004h> "]
[87.790519, "o", "pat=re.compile(r'int emit_e\\(const CaseResult \\*res, const char \\*audit_path\\) \\{.*?\\n\\}\\n', re.S)\r\n\u001b[?2004l\r"]
