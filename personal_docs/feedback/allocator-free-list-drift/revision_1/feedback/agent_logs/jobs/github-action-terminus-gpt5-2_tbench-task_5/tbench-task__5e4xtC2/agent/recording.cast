[25.281287, "i", "python3 - <<'PY'\nimport json,os\nfrom pathlib import Path\np='/app/output/alloc-audit.json'\ndata=json.load(open(p))\nfor c in data['cases']:\n    ledger=Path(c['ledger'])\n    steps=c['steps']\n    if not ledger.exists():\n        print('MISSING LEDGER',c['name'],ledger)\n        continue\n    rows=[json.loads(line) for line in ledger.read_text().splitlines() if line.strip()]\n    if len(rows)!=len(steps):\n        print('LEN MISMATCH',c['name'],'steps',len(steps),'rows',len(rows))\n        continue\n    for s,r in zip(steps,rows):\n        if s['seq']!=r.get('seq'):\n            print('SEQ MISMATCH',c['name'],s['seq'],r.get('seq'))\n            break\n        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n            if s[k]!=r.get(k):\n                print('TALLY MISMATCH',c['name'],'seq',s['seq'],k,s[k],r.get(k))\n                raise SystemExit\nprint('ledger alignment OK')\nPY\n"]
[25.281574, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
[25.28169, "o", "\u001b[?2004h> "]
[25.281801, "o", "import json,os\r\n\u001b[?2004l\r\u001b[?2004h> "]
