[91.7852, "i", "python3 - <<'PY'\nimport json,glob,os\nreq_case_keys={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nreq_step_keys={'seq','op','index','size','result_index','heap_sig','fl_count','fl_sig','byte_total'}\nfor p in sorted(glob.glob('/app/output/*-audit.json')):\n    data=json.load(open(p))\n    missing=sorted(req_case_keys-set(data.keys()))\n    if missing:\n        print('BAD',p,'missing',missing); continue\n    for s in data['steps']:\n        m=sorted(req_step_keys-set(s.keys()))\n        if m:\n            print('BAD',p,'step',s.get('seq'),'missing',m)\n            break\n    else:\n        print('OK',os.path.basename(p),'steps',len(data['steps']),'ledger',data['ledger'])\nPY\n"]
