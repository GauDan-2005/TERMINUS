[87.791077, "o", "\u001b[?2004h> "]
[87.791215, "o", "    FILE *fp = fopen(audit_path, \"w\");\r\n\u001b[?2004l\r"]
[87.791249, "o", "\u001b[?2004h> "]
[87.791382, "o", "    if (!fp) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[87.791462, "o", "        return -1;\r\n\u001b[?2004l\r\u001b[?2004h"]
[87.791494, "o", "> "]
