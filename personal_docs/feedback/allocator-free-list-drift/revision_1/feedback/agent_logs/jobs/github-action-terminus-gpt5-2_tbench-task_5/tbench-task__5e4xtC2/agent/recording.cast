[24.272963, "i", "python3 - <<'PY'\nimport json\np='/app/output/alloc-audit.json'\ndata=json.load(open(p))\nfor c in data['cases']:\n    steps=c['steps']\n    ok=(c['heap_sig'],c['fl_count'],c['fl_sig'],c['byte_total'])==(steps[-1]['heap_sig'],steps[-1]['fl_count'],steps[-1]['fl_sig'],steps[-1]['byte_total'])\n    if not ok:\n        print('SUMMARY MISMATCH',c['name'])\n        print('case',c['heap_sig'],c['fl_count'],c['fl_sig'],c['byte_total'])\n        print('last',steps[-1]['heap_sig'],steps[-1]['fl_count'],steps[-1]['fl_sig'],steps[-1]['byte_total'])\nPY\n"]
