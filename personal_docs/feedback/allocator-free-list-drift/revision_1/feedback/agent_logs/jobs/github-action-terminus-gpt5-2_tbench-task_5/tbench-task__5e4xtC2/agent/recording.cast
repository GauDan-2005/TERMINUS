[68.312643, "i", "python3 - <<'PY'\nimport json,glob\nfrom pathlib import Path\nfor p in sorted(glob.glob('/app/output/*-audit.json')):\n    data=json.load(open(p))\n    ledger=Path(data['ledger'])\n    steps=data['steps']\n    if not ledger.exists():\n        print('MISSING LEDGER',p,ledger); continue\n    rows=[json.loads(l) for l in ledger.read_text().splitlines() if l.strip()]\n    if len(rows)!=len(steps):\n        print('LEN MISMATCH',p,len(steps),len(rows)); continue\n    for s,r in zip(steps,rows):\n        if s['seq']!=r.get('seq'):\n            print('SEQ MISMATCH',p,s['seq'],r.get('seq'))\n            break\n        for k in ['heap_sig','fl_count','fl_sig','byte_total']:\n            if s[k]!=r.get(k):\n                print('TALLY MISMATCH',p,'seq',s['seq'],k,s[k],r.get(k))\n                raise SystemExit\nprint('per-case ledgers align')\nPY\n"]
