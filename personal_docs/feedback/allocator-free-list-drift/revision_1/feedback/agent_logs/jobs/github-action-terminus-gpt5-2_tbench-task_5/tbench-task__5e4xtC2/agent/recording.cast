[23.273516, "i", "python3 - <<'PY'\nimport json,os\np='/app/output/alloc-audit.json'\ndata=json.load(open(p))\nreq_case_keys={'name','ok','steps','heap_sig','fl_count','fl_sig','byte_total','ledger'}\nreq_step_keys={'seq','op','index','size','result_index','heap_sig','fl_count','fl_sig','byte_total'}\nprint('top keys',data.keys())\nprint('cases',len(data.get('cases',[])))\nmissing=[]\nfor c in data.get('cases',[]):\n    ck=set(c.keys())\n    if not req_case_keys.issubset(ck):\n        missing.append((c.get('name'),sorted(req_case_keys-ck)))\n    for s in c.get('steps',[]):\n        sk=set(s.keys())\n        if not req_step_keys.issubset(sk):\n            print('step missing keys',c.get('name'),s.get('seq'),sorted(req_step_keys-sk))\n            break\nprint('missing case keys',missing)\nprint('names',[c['name'] for c in data['cases']])\nPY\n"]
