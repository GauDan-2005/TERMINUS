[554.795244, "o", "> size_t tag_read_size(const Block *a) {\r\n\u001b[?2004l\r\u001b[?2004h>     size_t *hdr = (size_t *)(void *)(a->base + a->off);\r\n\u001b[?2004l\r\u001b[?2004h>     return hdr[0];\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> int z_is_flag(const Block *a) {\r\n\u001b[?2004l\r\u001b[?2004h>     size_t *hdr = (size_t *)(void *)(a->base + a->off);\r\n\u001b[?2004l\r\u001b[?2004h>     return (int)(hdr[1] & 1);\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void z_set_flag(Block *a, int flag) {\r\n\u001b[?2004l\r\u001b[?2004h>     size_t *hdr = (size_t *)(void *)(a->base + a->off);\r\n\u001b[?2004l\r\u001b[?2004h>     if (flag) {\r\n\u001b[?2004l\r\u001b[?2004h>         hdr[1] |= 1;\r\n\u001b[?2004l\r"]
[554.795283, "o", "\u001b[?2004h> "]
[554.79542, "o", "    } else {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[554.795533, "o", "        hdr[1] &= ~(size_t)1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[554.795649, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[554.795758, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
