[555.046946, "o", "\u001b[?2004h> #include <stddef.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include <sys/types.h>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void xd3(Stats *a, ssize_t b) {\r\n\u001b[?2004l\r\u001b[?2004h>     if (b > 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         a->allocated += (size_t)b;\r\n\u001b[?2004l\r\u001b[?2004h>     } else {\r\n\u001b[?2004l\r\u001b[?2004h>         a->allocated -= (size_t)(-b);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     if (a->allocated > a->peak) {\r\n\u001b[?2004l\r\u001b[?2004h>         a->peak = a->allocated;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
