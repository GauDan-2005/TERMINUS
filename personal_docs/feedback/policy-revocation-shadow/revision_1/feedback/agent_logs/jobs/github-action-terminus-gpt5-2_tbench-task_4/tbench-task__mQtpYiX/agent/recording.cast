[453.003268, "i", "cat > /app/scripts/run-matrix.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\ncd /app\nmkdir -p /app/output\n\nif command -v cargo >/dev/null 2>&1; then\n  runner=(cargo run --offline --quiet --)\nelif [ -x /app/target/debug/pollab ]; then\n  runner=(/app/target/debug/pollab)\nelse\n  echo \"error: neither cargo nor /app/target/debug/pollab is available\" >&2\n  exit 1\nfi\n\n\"${runner[@]}\" \\\n  /app/output/policy-audit.json \\\n  /app/traces/alpha.trace \\\n  /app/traces/beta.trace \\\n  /app/traces/gamma.trace \\\n  /app/traces/delta.trace \\\n  /app/traces/epsilon.trace \\\n  /app/traces/zeta.trace\nEOF\nchmod +x /app/scripts/run-matrix.sh\n"]
