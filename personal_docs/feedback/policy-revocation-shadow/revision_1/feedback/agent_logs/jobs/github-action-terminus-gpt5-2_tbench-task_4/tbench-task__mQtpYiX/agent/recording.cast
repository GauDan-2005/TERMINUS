[453.119687, "i", "cat > /app/scripts/run-one.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\ncd /app\nmkdir -p /app/output\ncase_name=\"${1:-alpha}\"\n\nif command -v cargo >/dev/null 2>&1; then\n  cargo run --offline --quiet -- \"/app/output/policy-audit-${case_name}.json\" \"/app/traces/${case_name}.trace\"\nelif [ -x /app/target/debug/pollab ]; then\n  /app/target/debug/pollab \"/app/output/policy-audit-${case_name}.json\" \"/app/traces/${case_name}.trace\"\nelse\n  echo \"error: neither cargo nor /app/target/debug/pollab is available\" >&2\n  exit 1\nfi\nEOF\nchmod +x /app/scripts/run-one.sh\n"]
