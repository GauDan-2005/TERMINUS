[8.333766, "o", "[package]\r\nname = \"policy-revocation-shadow\"\r\nversion = \"0.1.0\"\r\nedition = \"2021\"\r\n\r\n[lib]\r\nname = \"pollab\"\r\npath = \"src/lib.rs\"\r\n\r\n[[bin]]\r\nname = \"pollab\"\r\npath = \"src/main.rs\"\r\n\r\n[dependencies]\r\nserde = { version = \"1.0.219\", features = [\"derive\"] }\r\nserde_json = \"1.0.140\"\r\n\u001b[?2004hroot@2a225eadb2db:/app# "]
[14.799438, "i", "cat /app/src/main.rs\n"]
[14.799812, "o", "cat /app/src/main.rs\r\n\u001b[?2004l\r"]
[14.800599, "o", "use pollab::runner::run_all;\r\nuse std::env;\r\nuse std::path::PathBuf;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().collect();\r\n    if args.len() < 3 {\r\n        eprintln!(\"usage: pollab <out.json> <trace>...\");\r\n        std::process::exit(2);\r\n    }\r\n    let out = PathBuf::from(&args[1]);\r\n    let traces: Vec<PathBuf> = args[2..].iter().map(PathBuf::from).collect();\r\n    if let Err(err) = run_all(&out, &traces) {\r\n        eprintln!(\"{err}\");\r\n        std::process::exit(1);\r\n    }\r\n}\r\n"]
[14.800938, "o", "\u001b[?2004h"]
