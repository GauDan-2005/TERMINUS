[237.273206, "o", "{\r\n  \"cases\": [\r\n    {\r\n      \"name\": \"alpha\",\r\n      \"ok\": true,\r\n      \"decisions\": [\r\n        {\r\n          \"label\": \"before\",\r\n          \"principal\": \"clerk\",\r\n          \"resource\": \"vault\",\r\n          \"action\": \"read\",\r\n          \"verdict\": \"allow\",\r\n          \"epoch\": 0,\r\n          \"reused\": false,\r\n          \"batch_id\": \"\",\r\n          \"delegated_from\": \"boss\"\r\n        },\r\n        {\r\n          \"label\": \"batch\",\r\n          \"principal\": \"clerk\",\r\n          \"resource\": \"vault\",\r\n          \"action\": \"read\",\r\n          \"verdict\": \"deny\",\r\n          \"epoch\": 1,\r\n          \"reused\": false,\r\n          \"batch_id\": \"b1\",\r\n          \"delegated_from\": \"\"\r\n        },\r\n        {\r\n          \"label\": \"after\",\r\n          \"principal\": \"clerk\",\r\n          \"resource\": \"vault\",\r\n          \"action\": \"read\",\r\n          \"verdict\": \"deny\",\r\n          \"epoch\": 1,\r\n          \"reused\": true,\r\n          \"batch_id\": \"\",\r\n          \"delegated_from\": \"\"\r\n        }\r\n      ],\r\n      \"stale\": []\r\n    },\r\n    {\r\n      \"name\": \"beta\",\r\n    "]
