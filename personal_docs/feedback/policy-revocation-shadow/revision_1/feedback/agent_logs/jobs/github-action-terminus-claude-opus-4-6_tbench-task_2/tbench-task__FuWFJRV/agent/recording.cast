[8.463349, "o", "#!/bin/bash\r\ncd /app\r\nmkdir -p /app/output\r\ncargo run --offline --quiet -- \\\r\n  /app/output/policy-audit.json \\\r\n  /app/traces/alpha.trace \\\r\n  /app/traces/beta.trace \\\r\n  /app/traces/gamma.trace \\\r\n  /app/traces/delta.trace \\\r\n  /app/traces/epsilon.trace \\\r\n  /app/traces/zeta.trace\r\n"]
