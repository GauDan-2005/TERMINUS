[196.472113, "o", "        \"check\" => {\r\n\u001b[?2004l\r"]
[196.472205, "o", "\u001b[?2004h> "]
[196.472464, "o", "            let (subject, object, mode) = split_subject_object_mode(&b.right)?;\r\n\u001b[?2004l\r"]
[196.472496, "o", "\u001b[?2004h> "]
[196.47267, "o", "            let row = if a.group_active.is_empty() {\r\n\u001b[?2004l\r"]
[196.472739, "o", "\u001b[?2004h> "]
[196.472889, "o", "                wrap_g(a, &b.left, &subject, &object, &mode)\r\n\u001b[?2004l\r"]
[196.472971, "o", "\u001b[?2004h> "]
[196.473088, "o", "            } else {\r\n\u001b[?2004l\r"]
[196.473119, "o", "\u001b[?2004h> "]
[196.473317, "o", "                lift_d(a, &b.left, &subject, &object, &mode)\r\n\u001b[?2004l\r"]
[196.473347, "o", "\u001b[?2004h> "]
[196.47343, "o", "            };\r\n\u001b[?2004l\r"]
[196.473454, "o", "\u001b[?2004h> "]
[196.473628, "o", "            let (row, note) = cast_f(a, row, true);\r\n\u001b[?2004l\r"]
[196.473658, "o", "\u001b[?2004h> "]
[196.473791, "o", "            c.decisions.push(row);\r\n\u001b[?2004l\r"]
[196.473815, "o", "\u001b[?2004h> "]
[196.473941, "o", "            if let Some(note) = note {\r\n\u001b[?2004l\r"]
[196.474006, "o", "\u001b[?2004h"]
[196.47406, "o", "> "]
[196.474204, "o", "                c.stale.push(note);\r\n\u001b[?2004l\r"]
[196.474231, "o", "\u001b[?2004h> "]
[196.474321, "o", "            }\r\n\u001b[?2004l\r"]
[196.474383, "o", "\u001b[?2004h> "]
[196.474483, "o", "            Ok(())"]
[196.474556, "o", "\r\n\u001b[?2004l\r"]
[196.474642, "o", "\u001b[?2004h"]
[196.474733, "o", "> "]
[196.474852, "o", "        }\r\n\u001b[?2004l\r"]
[196.474927, "o", "\u001b[?2004h> "]
[196.475068, "o", "        other => Err(format!(\"unknown trace row {other}\")),\r\n\u001b[?2004l\r"]
[196.475166, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[196.475254, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[196.475295, "o", "> "]
[196.475554, "o", "fn wrap_g(a: &mut State, label: &str, subject: &str, object: &str, mode: &str) -> Decision {\r\n\u001b[?2004l\r"]
[196.475616, "o", "\u001b[?2004h> "]
[196.475669, "o", "    use crate::k4_e::mote_e;\r\n\u001b[?2004l\r"]
[196.475745, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[196.475868, "o", "    let tick = a.tick_for(subject);\r\n\u001b[?2004l\r"]
[196.475937, "o", "\u001b[?2004h> "]
[196.476072, "o", "    let (outcome, via) = mote_e(a, subject, object, mode);\r\n\u001b[?2004l\r"]
[196.476141, "o", "\u001b[?2004h> "]
[196.476333, "o", "    let mut row = Decision::blank(label, subject, object, mode, tick);\r\n\u001b[?2004l\r"]
[196.476388, "o", "\u001b[?2004h> "]
[196.47643, "o", "    row.outcome = outcome;\r\n\u001b[?2004l\r"]
[196.476488, "o", "\u001b[?2004h> "]
[196.476535, "o", "    row.via = via;\r\n\u001b[?2004l\r"]
[196.476605, "o", "\u001b[?2004h>     row\r\n"]
[196.476627, "o", "\u001b[?2004l\r"]
[196.476651, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[196.476826, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[196.477652, "o", "\u001b[?2004hroot@232ce2a98209:/app# "]
[196.576542, "i", "cat > /app/k3/d.rs << 'EOF'\nuse crate::k4_e::mote_e;\nuse crate::model::{Decision, State};\n\npub fn lift_d(a: &mut State, b: &str, c: &str, d: &str, e: &str) -> Decision {\n    let slot = State::track_key(c, d, e);\n    let tick = a.tick_for(c);\n    if let Some(outcome) = a.group_slot.get(&slot) {\n        let via = if outcome == \"allow\" {\n            mote_e(a, c, d, e).1\n        } else {\n            String::new()\n        };\n        let mut row = Decision::blank(b, c, d, e, tick);\n        row.outcome = outcome.clone();\n        row.group = a.group_active.clone();\n        row.via = via;\n        return row;\n    }\n    let (outcome, via) = mote_e(a, c, d, e);\n    a.group_slot.insert(slot, outcome.clone());\n    let mut row = Decision::blank(b, c, d, e, tick);\n    row.outcome = outcome;\n    row.group = a.group_active.clone();\n    row.via = via;\n    row\n}\nEOF\n"]
