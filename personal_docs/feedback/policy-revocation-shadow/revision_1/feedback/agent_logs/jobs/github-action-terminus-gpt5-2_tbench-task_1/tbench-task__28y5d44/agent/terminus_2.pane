[?2004l[?2004h>     if d['batch_id'] and d['label'] not in ('batch','a','b'):
[?2004l[?2004h>       print('UNEXPECTED_BATCH_ID',c['name'],d)
[?2004l[?2004h>     # delegated_from must be empty on denies
[?2004l[?2004h>     if d['verdict']!='allow' and d['delegated_from']:
[?2004l[?2004h>       print('DELEGATED_FROM_ON_DENY',c['name'],d)
[?2004l[?2004h> print('done')
[?2004l[?2004h> PY
[?2004ldone
