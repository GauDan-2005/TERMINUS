Sending keys: ['cat > /app/k4/e.rs <<\'EOF\'\nuse crate::model::State;\n\n// Evaluate access for (subject, object, mode).\n//\n// Returns (verdict, delegated_from).\n// delegated_from is the immediate grantor of `subject` when the allow is inherited,\n// and empty for direct allows and all denies.\npub fn mote_e(a: &State, subject: &str, object: &str, mode: &str) -> (String, String) {\n    // Walk from the requesting subject toward grantors.\n    // If any subject along the walk is blocked/revoked, the delegated path is denied.\n    let mut current = subject.to_string();\n\n    loop {\n        if a.blocked.contains(&current) {\n            return ("deny".to_string(), String::new());\n        }\n\n        if a\n            .direct\n            .contains(&(current.clone(), object.to_string(), mode.to_string()))\n        {\n            // Direct grant to the requesting subject => no delegation.\n            if current == subject {\n                return ("allow".to_string(), String::new());\n            }\n            // Inherited allow: report the immediate grantor of the requesting subject.\n            let delegated_from = a\n                .chain\n                .get(subject)\n                .cloned()\n                .unwrap_or_default();\n            return ("allow".to_string(), delegated_from);\n        }\n\n        match a.chain.get(&current) {\n            Some(parent) => current = parent.clone(),\n            None => return ("deny".to_string(), String::new()),\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > /app/k0/a.rs <<\'EOF\'\nuse crate::io::split_subject_object_mode;\nuse crate::k1_b::fold_b;\nuse crate::k3_d::lift_d;\nuse crate::k5_f::cast_f;\nuse crate::model::{CaseReport, Decision, Event, State};\n\npub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {\n    match b.kind.as_str() {\n        "grant" => {\n            let (object, mode) = b\n                .right\n                .split_once(\'/\')\n                .ok_or_else(|| format!("bad grant row {}", b.right))?;\n            a.direct\n                .insert((b.left.clone(), object.to_string(), mode.to_string()));\n            a.clock += 1;\n            Ok(())\n        }\n        "delegate" => {\n            a.chain.insert(b.right.clone(), b.left.clone());\n            a.clock += 1;\n            Ok(())\n        }\n        "revoke" => fold_b(a, &b.left),\n        "batch" => {\n            a.group_active = b.left.clone();\n            a.group_slot.clear();\n            a.clock += 1;\n            Ok(())\n        }\n        "end" => {\n            a.group_active.clear();\n            a.group_slot.clear();\n            a.clock += 1;\n            Ok(())\n        }\n        "check" => {\n            let (subject, object, mode) = split_subject_object_mode(&b.right)?;\n            let row = if a.group_active.is_empty() {\n                wrap_g(a, &b.left, &subject, &object, &mode)\n            } else {\n                lift_d(a, &b.left, &subject, &object, &mode)\n            };\n            let (row, note) = cast_f(a, row, true);\n            c.decisions.push(row);\n            if let Some(note) = note {\n                c.stale.push(note);\n            }\n            // Each evaluated check advances the evaluation epoch.\n            a.clock += 1;\n            Ok(())\n        }\n        other => Err(format!("unknown trace row {other}")),\n    }\n}\n\nfn wrap_g(a: &mut State, label: &str, subject: &str, object: &str, mode: &str) -> Decision {\n    use crate::k2_c::emit_c;\n    use crate::k4_e::mote_e;\n\n    // Epochs are case-global and monotonically increase as the trace is evaluated.\n    let tick = a.clock;\n\n    if let Some(outcome) = emit_c(a, subject, object, mode) {\n        let via = if outcome == "allow" {\n            mote_e(a, subject, object, mode).1\n        } else {\n            String::new()\n        };\n        let mut row = Decision::blank(label, subject, object, mode, tick);\n        row.outcome = outcome;\n        row.via = via;\n        return row;\n    }\n\n    let (outcome, via) = mote_e(a, subject, object, mode);\n    a.store\n        .insert(crate::model::State::slot_key(object, mode), outcome.clone());\n    let mut row = Decision::blank(label, subject, object, mode, tick);\n    row.outcome = outcome;\n    row.via = via;\n    row\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > /app/k3/d.rs <<\'EOF\'\nuse crate::k4_e::mote_e;\nuse crate::model::{Decision, State};\n\npub fn lift_d(a: &mut State, b: &str, c: &str, d: &str, e: &str) -> Decision {\n    let slot = State::slot_key(d, e);\n\n    // Epochs are case-global and monotonically increase as the trace is evaluated.\n    let tick = a.clock;\n\n    if let Some(outcome) = a.group_slot.get(&slot) {\n        let via = if outcome == "allow" {\n            mote_e(a, c, d, e).1\n        } else {\n            String::new()\n        };\n        let mut row = Decision::blank(b, c, d, e, tick);\n        row.outcome = outcome.clone();\n        row.group = a.group_active.clone();\n        row.via = via;\n        return row;\n    }\n\n    let (outcome, via) = mote_e(a, c, d, e);\n    a.group_slot.insert(slot, outcome.clone());\n    let mut row = Decision::blank(b, c, d, e, tick);\n    row.outcome = outcome;\n    row.group = a.group_active.clone();\n    row.via = via;\n    row\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
