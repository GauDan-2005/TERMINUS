[502.479085, "o", "\r\n/app/k6:\r\n"]
[502.479116, "o", "total 4\r\ndrwxr-xr-x  2 root root  18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root 107 May 25 11:26 g.rs\r\n"]
[502.479231, "o", "\r\n/app/k7:\r\ntotal 4\r\ndrwxr-xr-x  2 root root  18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root  72 May 25 11:26 h.rs\r\n\r\n/app/k8:\r\ntotal 4\r\n"]
[502.479248, "o", "drwxr-xr-x  2 root root  18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root  86 May 25 11:26 i.rs\r\n"]
