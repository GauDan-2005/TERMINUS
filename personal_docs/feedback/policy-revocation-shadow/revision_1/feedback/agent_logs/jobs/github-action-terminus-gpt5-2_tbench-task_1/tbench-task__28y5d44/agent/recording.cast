[520.831651, "o", "use crate::io::split_subject_object_mode;\r\nuse crate::k1_b::fold_b;\r\nuse crate::k3_d::lift_d;\r\nuse crate::k5_f::cast_f;\r\nuse crate::model::{CaseReport, Decision, Event, State};\r\n\r\n"]
[520.831677, "o", "pub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {\r\n    match b.kind.as_str() {\r\n        \"grant\" => {\r\n            let (object, mode) = b\r\n                .right\r\n                .split_once('/')\r\n                .ok_or_else(|| format!(\"bad grant row {}\", b.right))?;\r\n            a.direct\r\n                .insert((b.left.clone(), object.to_string(), mode.to_string()));\r\n"]
[520.831688, "o", "            a.clock += 1;\r\n"]
[520.831697, "o", "            Ok(())\r\n        }\r\n        \"delegate\" => {\r\n"]
[520.831715, "o", "            a.chain.insert(b.right.clone(), b.left.clone());\r\n            a.clock += 1;\r\n            Ok(())\r\n        }\r\n"]
[520.831725, "o", "        \"revoke\" => fold_b(a, &b.left),\r\n        \"batch\" => {\r\n            a.group_active = b.left.clone();\r\n            a.group_slot.clear();\r\n            Ok(())\r\n"]
[520.831737, "o", "        }\r\n        \"end\" => {\r\n"]
[520.831746, "o", "            a.group_active.clear();\r\n            a.group_slot.clear();\r\n            Ok(())\r\n        }\r\n        \"check\" => {\r\n"]
[520.831754, "o", "            let (subject, object, mode) = split_subject_object_mode(&b.right)?;\r\n            let row = if a.group_active.is_empty() {\r\n"]
[520.831765, "o", "                wrap_g(a, &b.left, &subject, &object, &mode)\r\n            } else {\r\n                lift_d(a, &b.left, &subject, &object, &mode)\r\n            };"]
[520.831776, "o", "\r\n            let (row, note) = cast_f(a, row, true);\r\n            c.decisions.push(row);\r\n            if let Some(note) = note {"]
[520.831784, "o", "\r\n                c.stale.push(note);\r\n"]
[520.831794, "o", "            }\r\n            Ok(())\r\n        }\r\n        other => Err(format!(\"unknown trace row {other}\")),"]
[520.831805, "o", "\r\n    }\r\n"]
[520.831819, "o", "}\r\n\r\nfn wrap_g(a: &mut State, label: &str, subject: &str, object: &str, mode: &str) -> Decision {\r\n    use crate::k2_c::emit_c;\r\n    use crate::k4_e::mote_e;\r\n\r\n"]
[520.83183, "o", "    let tick = a.tick_for(subject);\r\n    if let Some(outcome) = emit_c(a, subject, object, mode) {\r\n        let via = if outcome == \"allow\" {\r\n"]
[520.831841, "o", "            mote_e(a, subject, object, mode).1\r\n"]
[520.831854, "o", "        } else {\r\n            String::new()\r\n        };\r\n        let mut row = Decision::blank(label, subject, object, mode, tick);\r\n        row.outcome = outcome;\r\n        row.via = via;\r\n"]
[520.831862, "o", "        return row;\r\n    }\r\n    let (outcome, via) = mote_e(a, subject, object, mode);\r\n"]
[520.831872, "o", "    a.store.insert(\r\n"]
[520.831881, "o", "        crate::model::State::slot_key(object, mode),\r\n        outcome.clone(),\r\n    );\r\n"]
[520.831892, "o", "    let mut row = Decision::blank(label, subject, object, mode, tick);\r\n    row.outcome = outcome;\r\n    row.via = via;\r\n"]
[520.831903, "o", "    row\r\n}\r\n"]
