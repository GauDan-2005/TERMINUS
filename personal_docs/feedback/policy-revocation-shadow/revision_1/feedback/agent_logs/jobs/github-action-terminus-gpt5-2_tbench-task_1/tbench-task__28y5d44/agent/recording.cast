[499.274206, "o", "alpha ok= True decisions= 3 stale= []\r\nbeta ok= True decisions= 2 stale= []\r\ngamma ok= True decisions= 1 stale= []\r\ndelta ok= True decisions= 2 stale= []\r\nepsilon ok= True decisions= 1 stale= []\r\n"]
[499.274327, "o", "zeta ok= True decisions= 2 stale= []\r\n"]
