[502.588417, "o", "for d in /app/k0 /app/k1 /app/k2 /app/k3 /app/k4 /app/k5 /app/k6 /app/k7 /app/k8; do echo \"=== $d\"; ls -la \"$d\"; sed -n '1,220p' \"$d\"/*.rs; done\r\n\u001b[?2004l\r"]
[502.588544, "o", "=== /app/k0\r\n"]
[502.589788, "o", "total 4\r\ndrwxr-xr-x  2 root root   18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root  245 May 25 11:30 ..\r\n-rw-r--r--  1 root root 2479 May 25 11:26 a.rs\r\n"]
[502.590701, "o", "use crate::io::split_subject_object_mode;\r\nuse crate::k1_b::fold_b;\r\nuse crate::k3_d::lift_d;\r\nuse crate::k5_f::cast_f;\r\n"]
[502.590726, "o", "use crate::model::{CaseReport, Decision, Event, State};\r\n\r\npub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {\r\n    match b.kind.as_str() {\r\n        \"grant\" => {\r\n            let (object, mode) = b\r\n                .right\r\n                .split_once('/')\r\n"]
[502.590743, "o", "                .ok_or_else(|| format!(\"bad grant row {}\", b.right))?;\r\n            a.direct\r\n                .insert((b.left.clone(), object.to_string(), mode.to_string()));\r\n            a.clock += 1;\r\n            Ok(())\r\n"]
[502.590752, "o", "        }\r\n        \"delegate\" => {\r\n            a.chain.insert(b.right.clone(), b.left.clone());\r\n            a.clock += 1;\r\n            Ok(())\r\n        }\r\n"]
[502.590763, "o", "        \"revoke\" => fold_b(a, &b.left),\r\n        \"batch\" => {\r\n            a.group_active = b.left.clone();\r\n"]
[502.590772, "o", "            a.group_slot.clear();\r\n            Ok(())\r\n"]
[502.590782, "o", "        }\r\n        \"end\" => {\r\n"]
[502.590793, "o", "            a.group_active.clear();\r\n            a.group_slot.clear();\r\n            Ok(())\r\n        }\r\n"]
[502.590802, "o", "        \"check\" => {\r\n            let (subject, object, mode) = split_subject_object_mode(&b.right)?;\r\n"]
[502.590811, "o", "            let row = if a.group_active.is_empty() {\r\n                wrap_g(a, &b.left, &subject, &object, &mode)\r\n            } else {\r\n"]
[502.590819, "o", "                lift_d(a, &b.left, &subject, &object, &mode)\r\n            };\r\n"]
[502.590826, "o", "            let (row, note) = cast_f(a, row, true);\r\n            c.decisions.push(row);\r\n"]
[502.590837, "o", "            if let Some(note) = note {\r\n                c.stale.push(note);\r\n            }\r\n"]
[502.590849, "o", "            Ok(())\r\n        }\r\n"]
[502.590858, "o", "        other => Err(format!(\"unknown trace row {other}\")),\r\n    }\r\n"]
[502.590868, "o", "}\r\n\r\nfn wrap_g(a: &mut State, label: &str, subject: &str, object: &str, mode: &str) -> Decision {\r\n"]
[502.590884, "o", "    use crate::k2_c::emit_c;\r\n    use crate::k4_e::mote_e;\r\n\r\n"]
[502.590897, "o", "    let tick = a.tick_for(subject);\r\n    if let Some(outcome) = emit_c(a, subject, object, mode) {\r\n        let via = if outcome == \"allow\" {\r\n"]
[502.590908, "o", "            mote_e(a, subject, object, mode).1\r\n        } else {\r\n            String::new()\r\n"]
[502.590917, "o", "        };\r\n        let mut row = Decision::blank(label, subject, object, mode, tick);\r\n"]
[502.590926, "o", "        row.outcome = outcome;\r\n"]
[502.590937, "o", "        row.via = via;\r\n        return row;\r\n    }\r\n"]
[502.590945, "o", "    let (outcome, via) = mote_e(a, subject, object, mode);\r\n    a.store.insert(\r\n"]
[502.590955, "o", "        crate::model::State::slot_key(object, mode),\r\n        outcome.clone(),\r\n    );\r\n"]
[502.590967, "o", "    let mut row = Decision::blank(label, subject, object, mode, tick);\r\n    row.outcome = outcome;\r\n"]
[502.590979, "o", "    row.via = via;\r\n    row\r\n}\r\n"]
[502.591365, "o", "=== /app/k1\r\n"]
[502.593072, "o", "total 4\r\ndrwxr-xr-x  2 root root  18 May 25 11:26 .\r\n"]
[502.593097, "o", "drwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root 231 May 25 11:26 b.rs\r\n"]
[502.593958, "o", "use crate::model::State;\r\n\r\npub fn fold_b(a: &mut State, b: &str) -> Result<(), String> {\r\n    let next = a.tick_for(b) + 1;\r\n    a.ticks.insert(b.to_string(), next);\r\n    a.blocked.insert(b.to_string());\r\n    a.clock += 1;\r\n    Ok(())\r\n"]
[502.594028, "o", "}\r\n"]
[502.594119, "o", "=== /app/k2\r\n"]
[502.594871, "o", "total 4\r\n"]
[502.594944, "o", "drwxr-xr-x  2 root root  18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root 169 May 25 11:26 c.rs\r\n"]
[502.595826, "o", "use crate::model::State;\r\n\r\npub fn emit_c(a: &State, _b: &str, c: &str, d: &str) -> Option<String> {\r\n    let key = State::slot_key(c, d);\r\n    a.store.get(&key).cloned()\r\n"]
[502.595904, "o", "}\r\n"]
[502.595986, "o", "=== /app/k3\r\n"]
[502.596735, "o", "total 4\r\n"]
[502.596811, "o", "drwxr-xr-x  2 root root  18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root 821 May 25 11:26 d.rs\r\n"]
[502.59756, "o", "use crate::k4_e::mote_e;\r\nuse crate::model::{Decision, State};\r\n\r\npub fn lift_d(a: &mut State, b: &str, c: &str, d: &str, e: &str) -> Decision {\r\n    let slot = State::slot_key(d, e);\r\n"]
[502.597583, "o", "    let tick = a.tick_for(c);\r\n  if let Some(outcome) = a.group_slot.get(&slot) {\r\n        let via = if outcome == \"allow\" {\r\n            mote_e(a, c, d, e).1\r\n        } else {\r\n            String::new()\r\n        };\r\n"]
[502.597596, "o", "        let mut row = Decision::blank(b, c, d, e, tick);\r\n        row.outcome = outcome.clone();\r\n        row.group = a.group_active.clone();\r\n        row.via = via;\r\n"]
[502.597606, "o", "        return row;\r\n    }\r\n    let (outcome, via) = mote_e(a, c, d, e);\r\n    a.group_slot.insert(slot, outcome.clone());\r\n"]
[502.597616, "o", "    let mut row = Decision::blank(b, c, d, e, tick);\r\n    row.outcome = outcome;\r\n"]
[502.597625, "o", "    row.group = a.group_active.clone();\r\n    row.via = via;\r\n    row\r\n"]
[502.597637, "o", "}\r\n"]
[502.597774, "o", "=== /app/k4\r\n"]
[502.59857, "o", "total 4\r\n"]
[502.5986, "o", "drwxr-xr-x  2 root root  18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root 711 May 25 11:26 e.rs\r\n"]
[502.599451, "o", "use crate::model::State;\r\n\r\npub fn mote_e(a: &State, b: &str, c: &str, d: &str) -> (String, String) {\r\n    let mut current = b.to_string();\r\n    loop {\r\n        if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {\r\n"]
[502.599532, "o", "            if a.blocked.contains(b) {\r\n                return (\"deny\".to_string(), String::new());\r\n            }\r\n            let via = if current == b {\r\n                String::new()\r\n            } else {\r\n                current.clone()\r\n"]
[502.599647, "o", "            };\r\n            return (\"allow\".to_string(), via);\r\n        }\r\n        match a.chain.get(&current) {\r\n            Some(parent) => current = parent.clone(),\r\n            None => return (\"deny\".to_string(), String::new()),\r\n        }\r\n    }\r\n}\r\n"]
[502.599758, "o", "=== /app/k5\r\n"]
[502.600508, "o", "total 4\r\n"]
[502.600564, "o", "drwxr-xr-x  2 root root  18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root 563 May 25 11:26 f.rs\r\n"]
[502.601346, "o", "use crate::model::{Decision, State};\r\n\r\npub fn cast_f(a: &mut State, mut b: Decision, _c: bool) -> (Decision, Option<String>) {\r\n    let track = State::track_key(&b.subject, &b.object, &b.mode);\r\n    let reused = a\r\n        .seen\r\n"]
[502.601367, "o", "        .get(&track)\r\n        .map(|old| old == &b.outcome)\r\n        .unwrap_or(false);\r\n    b.reused = reused;\r\n"]
[502.601436, "o", "    a.seen.insert(track, b.outcome.clone());\r\n    if b.outcome == \"allow\" && a.blocked.contains(&b.subject) && !b.via.is_empty() {\r\n        let note = b.label.clone();\r\n        (b, Some(note))\r\n    } else {\r\n        (b, None)\r\n    }\r\n}\r\n"]
[502.601671, "o", "=== /app/k6\r\n"]
[502.602339, "o", "total 4\r\n"]
[502.602364, "o", "drwxr-xr-x  2 root root  18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root 107 May 25 11:26 g.rs\r\n"]
[502.603208, "o", "use crate::model::State;\r\n\r\npub fn tally_g(_a: &State, rows: usize) -> String {\r\n    format!(\"rows={rows}\")\r\n}\r\n"]
[502.603349, "o", "=== /app/k7\r\n"]
[502.604097, "o", "total 4\r\n"]
[502.604174, "o", "drwxr-xr-x  2 root root  18 May 25 11:26 .\r\ndrwxr-xr-x 18 root root 245 May 25 11:30 ..\r\n-rw-r--r--  1 root root  72 May 25 11:26 h.rs\r\n"]
[502.60505, "o", "pub fn hint_h(label: &str) -> String {\r\n    label.to_ascii_lowercase()\r\n}\r\n"]
[502.605178, "o", "=== /app/k8\r\n"]
[502.605904, "o", "total 4\r\n"]
