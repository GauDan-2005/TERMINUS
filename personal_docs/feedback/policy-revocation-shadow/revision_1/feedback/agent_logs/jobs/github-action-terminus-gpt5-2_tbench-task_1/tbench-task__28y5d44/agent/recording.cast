[682.764243, "i", "python3 - <<'PY'\nimport json\nobj=json.load(open('/app/output/policy-audit.json'))\nfor c in obj['cases']:\n  for d in c['decisions']:\n    # batch_id should be nonempty iff label came from grouped check; in this lab group_active drives it.\n    if d['batch_id'] and d['label'] not in ('batch','a','b'):\n      print('UNEXPECTED_BATCH_ID',c['name'],d)\n    # delegated_from must be empty on denies\n    if d['verdict']!='allow' and d['delegated_from']:\n      print('DELEGATED_FROM_ON_DENY',c['name'],d)\nprint('done')\nPY\n"]
