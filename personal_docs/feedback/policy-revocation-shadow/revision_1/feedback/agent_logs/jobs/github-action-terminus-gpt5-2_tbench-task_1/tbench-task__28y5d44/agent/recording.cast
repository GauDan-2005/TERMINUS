[457.620636, "o", "sed -n '1,200p' /app/src/main.rs\r\n\u001b[?2004l\r"]
[457.622158, "o", "use pollab::runner::run_all;\r\nuse std::env;\r\nuse std::path::PathBuf;\r\n"]
[457.622258, "o", "\r\n"]
[457.622321, "o", "fn main() {\r\n"]
[457.622377, "o", "    let args: Vec<String> = env::args().collect();\r\n"]
[457.622434, "o", "    if args.len() < 3 {\r\n"]
[457.622486, "o", "        eprintln!(\"usage: pollab <out.json> <trace>...\");\r\n"]
[457.622539, "o", "        std::process::exit(2);\r\n"]
[457.6226, "o", "    }\r\n"]
[457.622657, "o", "    let out = PathBuf::from(&args[1]);\r\n"]
[457.622708, "o", "    let traces: Vec<PathBuf> = args[2..].iter().map(PathBuf::from).collect();\r\n"]
[457.622767, "o", "    if let Err(err) = run_all(&out, &traces) {\r\n"]
[457.622825, "o", "        eprintln!(\"{err}\");\r\n"]
[457.622878, "o", "        std::process::exit(1);\r\n"]
[457.622927, "o", "    }\r\n"]
[457.622976, "o", "}\r\n"]
