[500.261037, "i", "python3 - <<'PY'\nimport json\nobj=json.load(open('/app/output/policy-audit.json'))\nfor c in obj['cases']:\n  epochs=[d['epoch'] for d in c['decisions']]\n  nondec=all(epochs[i]<=epochs[i+1] for i in range(len(epochs)-1))\n  bad=[(i,epochs[i],epochs[i+1]) for i in range(len(epochs)-1) if epochs[i]>epochs[i+1]]\n  if not nondec:\n    print('EPOCH_DECREASE',c['name'],bad)\n  # delegated_from should be empty if verdict row is direct; we don't know direct vs delegated,\n  # but we can flag suspicious: delegated_from set while label indicates a direct check.\n  sus=[d for d in c['decisions'] if d.get('delegated_from') and d.get('batch_id','')=='']\n  if sus:\n    print('HAS_DELEGATED_FROM_OUTSIDE_BATCH',c['name'],[(d['label'],d['principal'],d['delegated_from']) for d in sus])\nPY\n"]
[500.261352, "o", "python3 - <<'PY'"]
