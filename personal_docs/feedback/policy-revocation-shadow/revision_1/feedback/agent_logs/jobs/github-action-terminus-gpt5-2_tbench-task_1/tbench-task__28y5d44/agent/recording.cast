[500.282071, "o", "HAS_DELEGATED_FROM_OUTSIDE_BATCH alpha [('before', 'clerk', 'boss')]\r\nHAS_DELEGATED_FROM_OUTSIDE_BATCH epsilon [('check', 'leaf', 'root')]\r\n"]
[500.282152, "o", "EPOCH_DECREASE zeta [(0, 1, 0)]\r\n"]
