[680.759894, "i", "python3 - <<'PY'\nimport json\nobj=json.load(open('/app/output/policy-audit.json'))\n# basic shape\nassert list(obj.keys())==['cases']\nfor c in obj['cases']:\n  assert set(c.keys())=={'name','ok','decisions','stale'}\n  if c['stale']:\n    print('STALE_NOT_EMPTY',c['name'],c['stale'])\n  if c['ok'] != (len(c['stale'])==0):\n    print('OK_MISMATCH',c['name'],c['ok'],c['stale'])\n  # epoch nondecreasing\n  epochs=[d['epoch'] for d in c['decisions']]\n  if any(epochs[i]>epochs[i+1] for i in range(len(epochs)-1)):\n    print('EPOCH_DECREASE',c['name'],epochs)\n  for d in c['decisions']:\n    need={'label','principal','resource','action','verdict','epoch','reused','batch_id','delegated_from'}\n    if set(d.keys())!=need:\n      print('DECISION_KEYS',c['name'],d.keys())\nprint('done')\nPY\n"]
[680.761489, "o", "python3 - <<'PY'"]
