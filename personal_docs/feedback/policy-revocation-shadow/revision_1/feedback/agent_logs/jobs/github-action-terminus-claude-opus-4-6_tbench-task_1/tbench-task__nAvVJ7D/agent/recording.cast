[238.605838, "o", "\u001b[?2004h"]
[238.605899, "o", "> "]
[238.606018, "o", "    match b.kind.as_str() {\r\n\u001b[?2004l\r"]
[238.606379, "o", "\u001b[?2004h>         \"grant\" => {\r\n\u001b[?2004l\r\u001b[?2004h>             let (object, mode) = b\r\n\u001b[?2004l\r\u001b[?2004h> "]
