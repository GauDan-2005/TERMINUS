[238.60796, "o", "> "]
[238.608065, "o", "            a.clock += 1;\r\n\u001b[?2004l\r"]
[238.608112, "o", "\u001b[?2004h> "]
[238.608193, "o", "            Ok(())\r\n\u001b[?2004l\r"]
