[?2004l[?2004h> use crate::model::State;
[?2004l[?2004h> 
[?2004l[?2004h> // Returns (verdict, delegated_from).
[?2004l[?2004h> //
[?2004l[?2004h> // Delegation semantics:
[?2004l[?2004h> // - Evaluate from the requesting subject toward grantors by following `chain`.
[?2004l[?2004h> // - If any subject along that walk is blocked/revoked, inherited access must deny.
[?2004l[?2004h> // - A blocked/revoked subject never receives allow on delegated paths.
[?2004l[?2004h> // - delegated_from is empty for direct rows; otherwise it is the grantor that holds
[?2004l[?2004h> //   the direct grant.
[?2004l[?2004h> pub fn mote_e(a: &State, b: &str, c: &str, d: &str) -> (String, String) {
[?2004l[?2004h>     let mut current = b.to_string();
[?2004l[?2004h>     let mut first = true;
[?2004l[?2004h> 
[?2004l[?2004h>     loop {
[?2004l[?2004h>         // If any subject on the walk is blocked/revoked, delegated paths are denied.
[?2004l[?2004h>         // This includes the requester.
[?2004l[?2004h>         if a.blocked.contains(&current) {
[?2004l[?2004h>             return ("deny".to_string(), String::new());
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {
[?2004l[?2004h>             // Found a direct grant at `current`. If it's the requester, this is direct.
[?2004l[?2004h>             // If it's an ancestor, this is inherited and delegated_from must be that grantor.
[?2004l[?2004h>             let via = if first { String::new() } else { current.clone() };
[?2004l[?2004h>             return ("allow".to_string(), via);
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         match a.chain.get(&current) {
[?2004l[?2004h>             Some(parent) => {
[?2004l[?2004h>                 current = parent.clone();
[?2004l[?2004h>                 first = false;
[?2004l[?2004h>             }
[?2004l[?2004h>             None => return ("deny".to_string(), String::new()),
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> }
[?2004l[?2004h> EOF
