[?2004h> use crate::io::split_subject_object_mode;
[?2004l[?2004h> use crate::k1_b::fold_b;
[?2004l[?2004h> use crate::k3_d::lift_d;
[?2004l[?2004h> use crate::k5_f::cast_f;
[?2004l[?2004h> use crate::model::{CaseReport, Decision, Event, State};
[?2004l[?2004h> 
[?2004l[?2004h> pub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {
[?2004l[?2004h>     match b.kind.as_str() {
[?2004l[?2004h>         "grant" => {
[?2004l[?2004h>             let (object, mode) = b
[?2004l[?2004h>                 .right
[?2004l[?2004h>                 .split_once('/')
[?2004l[?2004h>                 .ok_or_else(|| format!("bad grant row {}", b.right))?;
[?2004l[?2004h>             a.direct
[?2004l[?2004h>                 .insert((b.left.clone(), object.to_string(), mode.to_string()));
[?2004l[?2004h>             a.clock += 1;
[?2004l[?2004h>             Ok(())
[?2004l[?2004h>         }
[?2004l[?2004h>         "delegate" => {
[?2004l[?2004h>             a.chain.insert(b.right.clone(), b.left.clone());
[?2004l[?2004h>             a.clock += 1;
[?2004l[?2004h>             Ok(())
[?2004l[?2004h>         }
[?2004l[?2004h>         "revoke" => fold_b(a, &b.left),
[?2004l[?2004h>         "batch" => {
[?2004l[?2004h>             a.group_active = b.left.clone();
[?2004l[?2004h>             a.group_slot.clear();
[?2004l[?2004h>             a.clock += 1;
[?2004l[?2004h>             Ok(())
[?2004l[?2004h>         }
[?2004l[?2004h>         "end" => {
[?2004l[?2004h>             a.group_active.clear();
[?2004l[?2004h>             a.group_slot.clear();
[?2004l[?2004h>             a.clock += 1;
[?2004l[?2004h>             Ok(())
[?2004l[?2004h>         }
[?2004l[?2004h>         "check" => {
[?2004l[?2004h>             // Advance the evaluation epoch. This guarantees nondecreasing epochs within a case,
[?2004l[?2004h>             // while still being tied to the state at evaluation time.
[?2004l[?2004h>             a.clock += 1;
[?2004l[?2004h>             let epoch = a.clock;
[?2004l[?2004h> 
[?2004l[?2004h>             let (subject, object, mode) = split_subject_object_mode(&b.right)?;
[?2004l[?2004h>             let row = if a.group_active.is_empty() {
[?2004l[?2004h>                 wrap_g(a, &b.left, &subject, &object, &mode, epoch)
[?2004l[?2004h>             } else {
[?2004l[?2004h>                 lift_d(a, &b.left, &subject, &object, &mode, epoch)
[?2004l[?2004h>             };
[?2004l[?2004h>             let (row, note) = cast_f(a, row, true);
[?2004l[?2004h>             c.decisions.push(row);
[?2004l[?2004h>             if let Some(note) = note {
[?2004l[?2004h>                 c.stale.push(note);
[?2004l[?2004h>             }
[?2004l[?2004h>             Ok(())
[?2004l[?2004h>         }
[?2004l[?2004h>         other => Err(format!("unknown trace row {other}")),
[?2004l[?2004h>     }
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> fn wrap_g(
[?2004l[?2004h>     a: &mut State,
[?2004l[?2004h>     label: &str,
[?2004l[?2004h>     subject: &str,
[?2004l[?2004h>     object: &str,
[?2004l[?2004h>     mode: &str,
