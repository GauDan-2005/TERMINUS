[?2004l[?2004h> use crate::model::{Decision, State};
[?2004l[?2004h> 
[?2004l[?2004h> pub fn cast_f(a: &mut State, mut b: Decision, _c: bool) -> (Decision, Option<String>) {
[?2004l[?2004h>     // Reuse only when the subject is stable (epoch unchanged).
[?2004l[?2004h>     let track = State::track_key(&b.subject, &b.object, &b.mode);
[?2004l[?2004h>     let key = format!("{track}|{}", b.tick);
[?2004l[?2004h> 
[?2004l[?2004h>     let reused = a
[?2004l[?2004h>         .seen
[?2004l[?2004h>         .get(&key)
[?2004l[?2004h>         .map(|old| old == &b.outcome)
[?2004l[?2004h>         .unwrap_or(false);
[?2004l[?2004h> 
[?2004l[?2004h>     b.reused = reused;
[?2004l[?2004h>     a.seen.insert(key, b.outcome.clone());
[?2004l[?2004h> 
[?2004l[?2004h>     // With correct mote_e semantics, we should not be producing "allow" for blocked
[?2004l[?2004h>     // subjects via delegation. Keep stale empty.
[?2004l[?2004h>     (b, None)
[?2004l[?2004h> }
