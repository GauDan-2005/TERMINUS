[203.996278, "i", "cat > /app/scripts/run-matrix.sh <<'EOF'\n#!/bin/bash\nset -euo pipefail\n\ncd /app\nmkdir -p /app/output\n\nOUT=/app/output/policy-audit.json\nTRACES=(\n  /app/traces/alpha.trace\n  /app/traces/beta.trace\n  /app/traces/gamma.trace\n  /app/traces/delta.trace\n  /app/traces/epsilon.trace\n  /app/traces/zeta.trace\n)\n\nBIN=/app/target/debug/pollab\n\nif command -v cargo >/dev/null 2>&1; then\n  cargo run --offline --quiet -- \"$OUT\" \"${TRACES[@]}\"\nelif [ -x \"$BIN\" ]; then\n  \"$BIN\" \"$OUT\" \"${TRACES[@]}\"\nelse\n  echo \"error: cargo not available and $BIN is missing/unexecutable\" >&2\n  exit 1\nfi\nEOF\n"]
