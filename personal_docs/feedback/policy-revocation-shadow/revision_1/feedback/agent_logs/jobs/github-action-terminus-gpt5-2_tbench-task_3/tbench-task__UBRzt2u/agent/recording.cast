[327.540766, "i", "python3 - <<'PY'\nimport json, pathlib\np=pathlib.Path('/app/output/policy-audit.json')\nd=json.loads(p.read_text())\nassert 'cases' in d\nbad=[]\nfor case in d['cases']:\n    if case.get('stale') not in ([], None) and len(case['stale'])!=0:\n        bad.append((case['name'],'stale',case['stale']))\n    last_epoch=-1\n    for row in case['decisions']:\n        for k in ['label','principal','resource','action','verdict','epoch','reused','batch_id','delegated_from']:\n            if k not in row:\n                bad.append((case['name'],'missing',k,row))\n        if row['epoch']<last_epoch:\n            bad.append((case['name'],'epoch_decreased',last_epoch,row['epoch'],row['label']))\n        last_epoch=row['epoch']\n        if row['batch_id']==None or row['delegated_from']==None:\n            bad.append((case['name'],'null_fields',row))\nprint('cases',len(d['cases']))\nprint('problems',len(bad))\nfor b in bad[:50]:\n    print('BAD',b)\nPY\n"]
