[345.092739, "i", "cat > /app/k3/d.rs <<'EOF'\nuse crate::k4_e::mote_e;\nuse crate::model::{Decision, State};\n\npub fn lift_d(a: &mut State, b: &str, c: &str, d: &str, e: &str, epoch: u64) -> Decision {\n    let slot = State::slot_key(c, d, e);\n\n    if let Some(outcome) = a.group_slot.get(&slot) {\n        let via = if outcome == \"allow\" {\n            mote_e(a, c, d, e).1\n        } else {\n            String::new()\n        };\n        let mut row = Decision::blank(b, c, d, e, epoch);\n        row.outcome = outcome.clone();\n        row.group = a.group_active.clone();\n        row.via = via;\n        return row;\n    }\n\n    let (outcome, via) = mote_e(a, c, d, e);\n    a.group_slot.insert(slot, outcome.clone());\n    let mut row = Decision::blank(b, c, d, e, epoch);\n    row.outcome = outcome;\n    row.group = a.group_active.clone();\n    row.via = via;\n    row\n}\nEOF\n"]
[345.099098, "o", "cat > /app/k3/d.rs <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> use crate::k4_e::mote_e;\r\n\u001b[?2004l\r\u001b[?2004h> use crate::model::{Decision, State};\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> pub fn lift_d(a: &mut State, b: &str, c: &str, d: &str, e: &str, epoch: u64) -> Decision {\r\n\u001b[?2004l\r\u001b[?2004h>     let slot = State::slot_key(c, d, e);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if let Some(outcome) = a.group_slot.get(&slot) {\r\n\u001b[?2004l\r\u001b[?2004h>         let via = if outcome == \"allow\" {\r\n\u001b[?2004l\r\u001b[?2004h>             mote_e(a, c, d, e).1\r\n\u001b[?2004l\r\u001b[?2004h>         } else {\r\n\u001b[?2004l\r\u001b[?2004h>             String::new()\r\n\u001b[?2004l\r\u001b[?2004h>         };\r\n\u001b[?2004l\r\u001b[?2004h>         let mut row = Decision::blank(b, c, d, e, epoch);\r\n\u001b[?2004l\r\u001b[?2004h>         row.outcome = outcome.clone();\r\n\u001b[?2004l\r\u001b[?2004h>         row.group = a.group_active.clone();\r\n\u001b[?2004l\r\u001b[?2004h>         row.via = via;\r\n\u001b[?2004l\r\u001b[?2004h>         return row;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     let (outcome, via) = mot"]
