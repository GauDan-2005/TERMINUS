[310.79253, "o", "bytes 3661\r\n"]
[310.79267, "o", "\r\nCASE alpha ok True stale []\r\nbefore clerk vault read allow epoch 0 reused False batch  via boss\r\nbatch clerk vault read deny epoch 1 reused False batch b1 via \r\nafter clerk vault read allow epoch 1 reused False batch  via \r\n"]
[310.79269, "o", "\r\nCASE gamma ok True stale []\r\nbatch intern vault write deny epoch 0 reused False batch b1 via \r\n"]
[310.792741, "o", "\r\nCASE epsilon ok True stale []\r\ncheck leaf api invoke deny epoch 0 reused False batch  via \r\n\r\nCASE zeta ok True stale []\r\na alpha secret read deny epoch 1 reused False batch mix via \r\n"]
[310.792756, "o", "b beta secret read allow epoch 0 reused False batch mix via \r\n"]
