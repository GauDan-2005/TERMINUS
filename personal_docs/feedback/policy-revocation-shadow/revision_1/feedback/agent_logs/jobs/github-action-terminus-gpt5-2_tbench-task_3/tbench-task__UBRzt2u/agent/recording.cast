[260.359906, "i", "cat > /app/k5/f.rs <<'EOF'\nuse crate::model::{Decision, State};\n\npub fn cast_f(a: &mut State, mut b: Decision, _c: bool) -> (Decision, Option<String>) {\n    // Reuse only when the subject is stable (epoch unchanged).\n    let track = State::track_key(&b.subject, &b.object, &b.mode);\n    let key = format!(\"{track}|{}\", b.tick);\n\n    let reused = a\n        .seen\n        .get(&key)\n        .map(|old| old == &b.outcome)\n        .unwrap_or(false);\n\n    b.reused = reused;\n    a.seen.insert(key, b.outcome.clone());\n\n    // With correct mote_e semantics, we should not be producing \"allow\" for blocked\n    // subjects via delegation. Keep stale empty.\n    (b, None)\n}\nEOF\n"]
