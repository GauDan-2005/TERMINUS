[192.661122, "o", "use pollab::runner::run_all;\r\nuse std::env;\r\nuse std::path::PathBuf;\r\n\r\nfn main() {\r\n    let args: Vec<String> = env::args().collect();\r\n    if args.len() < 3 {\r\n"]
[192.661278, "o", "        eprintln!(\"usage: pollab <out.json> <trace>...\");\r\n        std::process::exit(2);\r\n    }\r\n"]
[192.661301, "o", "    let out = PathBuf::from(&args[1]);\r\n    let traces: Vec<PathBuf> = args[2..].iter().map(PathBuf::from).collect();\r\n    if let Err(err) = run_all(&out, &traces) {\r\n        eprintln!(\"{err}\");\r\n        std::process::exit(1);\r\n    }\r\n}\r\n"]
[192.661666, "o", "\u001b[?2004hroot@27e9125e8859:/app# "]
