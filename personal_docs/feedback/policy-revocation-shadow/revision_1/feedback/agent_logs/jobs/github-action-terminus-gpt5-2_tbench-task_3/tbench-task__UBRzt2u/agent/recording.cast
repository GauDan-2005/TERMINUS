[219.159232, "o", "use crate::model::CaseReport;\r\nuse serde::Serialize;\r\nuse std::fs;\r\nuse std::path::Path;\r\n\r\n#[derive(Serialize)]\r\nstruct RowOut {\r\n    label: String,\r\n    principal: String,\r\n    resource: String,\r\n    action: String,\r\n    verdict: String,\r\n    epoch: u64,\r\n    reused: bool,\r\n    batch_id: String,\r\n    delegated_from: String,\r\n}\r\n\r\n#[derive(Serialize)]\r\nstruct CaseOut {\r\n    name: String,\r\n    ok: bool,\r\n    decisions: Vec<RowOut>,\r\n    stale: Vec<String>,\r\n}\r\n\r\n#[derive(Serialize)]\r\nstruct RootOut {\r\n    cases: Vec<CaseOut>,\r\n}\r\n\r\npub fn write_report(path: &Path, cases: &[CaseReport]) -> Result<(), String> {\r\n    if let Some(parent) = path.parent() {\r\n        fs::create_dir_all(parent).map_err(|e| format!(\"mkdir {}: {e}\", parent.display()))?;\r\n    }\r\n    let payload = RootOut {\r\n        cases: cases\r\n            .iter()\r\n            .map(|case| CaseOut {\r\n                name: case.name.clone(),\r\n                ok: case.ok,\r\n                stale: case.stale.clone(),\r\n                decisions: case\r\n      "]
[219.159326, "o", "              .decisions\r\n                    .iter()\r\n                    .map(|row| RowOut {\r\n                        label: row.label.clone(),\r\n                        principal: row.subject.clone(),\r\n                        resource: row.object.clone(),\r\n                        action: row.mode.clone(),\r\n                        verdict: row.outcome.clone(),\r\n                        epoch: row.tick,\r\n                        reused: row.reused,\r\n                        batch_id: row.group.clone(),\r\n                        delegated_from: row.via.clone(),\r\n                    })\r\n                    .collect(),\r\n            })\r\n            .collect(),\r\n    };\r\n    let text = serde_json::to_string_pretty(&payload).map_err(|e| e.to_string())?;\r\n    fs::write(path, text).map_err(|e| format!(\"write {}: {e}\", path.display()))\r\n}\r\n\u001b[?2004hroot@27e9125e8859:/app# "]
[219.280425, "i", "sed -n '1,260p' /app/src/runner.rs\n"]
[219.281289, "o", "sed -n '1,260p' /app/src/runner.rs\r\n\u001b[?2004l\r"]
[219.282892, "o", "use crate::io::read_trace;\r\nuse crate::k0_a::phase_a;\r\nuse crate::model::{CaseReport, State};\r\nuse crate::report::write_report;\r\nuse std::path::{Path, PathBuf};\r\n\r\n"]
[219.283141, "o", "pub fn run_all(out: &Path, traces: &[PathBuf]) -> Result<(), String> {\r\n    let mut cases = Vec::new();\r\n    for trace in traces {\r\n        cases.push(run_one(trace)?);\r\n    }\r\n    write_report(out, &cases)\r\n}\r\n\r\nfn run_one(trace: &Path) -> Result<CaseReport, String> {\r\n    let name = trace\r\n        .file_stem()\r\n        .and_then(|s| s.to_str())\r\n        .ok_or_else(|| format!(\"trace name: {}\", trace.display()))?\r\n        .to_string();\r\n    let events = read_trace(trace)?;\r\n    let mut state = State::new();\r\n    let mut case = CaseReport {\r\n        name,\r\n        ok: true,\r\n        decisions: Vec::new(),\r\n        stale: Vec::new(),\r\n    };\r\n    for event in events {\r\n        phase_a(&mut state, &event, &mut case)?;\r\n    }\r\n    case.ok = case.stale.is_empty();\r\n    Ok(case)\r\n}\r\n"]
[219.283355, "o", "\u001b[?2004h"]
[219.283509, "o", "root@27e9125e8859:/app# "]
[219.409514, "i", "sed -n '1,260p' /app/src/model.rs\n"]
[219.409882, "o", "sed -n '1,260p' /app/src/model.rs\r\n"]
[219.410897, "o", "\u001b[?2004l\r"]
[219.413127, "o", "use std::collections::{BTreeMap, BTreeSet};\r\n\r\n#[derive(Clone, Debug)]\r\npub struct Event {\r\n    pub kind: String,\r\n    pub left: String,\r\n    pub right: String,\r\n}\r\n\r\n#[derive(Clone, Debug)]\r\npub struct Decision {\r\n"]
[219.413157, "o", "    pub label: String,\r\n    pub subject: String,\r\n    pub object: String,\r\n    pub mode: String,\r\n    pub outcome: String,\r\n    pub tick: u64,\r\n    pub reused: bool,\r\n    pub group: String,\r\n    pub via: String,\r\n}\r\n\r\n#[derive(Clone, Debug)]"]
[219.413172, "o", "\r\npub struct CaseReport {\r\n    pub name: String,\r\n    pub ok: bool,\r\n    pub decisions: Vec<Decision>,\r\n    pub stale: Vec<String>,"]
[219.413185, "o", "\r\n}\r\n"]
[219.413194, "o", "\r\n#[derive(Debug)]\r\npub struct State {\r\n    pub direct: BTreeSet<(String, String, String)>,\r\n"]
[219.413203, "o", "    pub chain: BTreeMap<String, String>,\r\n    pub ticks: BTreeMap<String, u64>,\r\n    pub blocked: BTreeSet<String>,\r\n"]
[219.413215, "o", "    pub store: BTreeMap<String, String>,\r\n    pub group_slot: BTreeMap<String, String>,\r\n    pub group_active: String,\r\n"]
[219.413224, "o", "    pub seen: BTreeMap<String, String>,\r\n    pub clock: u64,\r\n}\r\n"]
[219.413234, "o", "\r\nimpl State {\r\n    pub fn new() -> Self {\r\n"]
[219.413245, "o", "        Self {\r\n            direct: BTreeSet::new(),\r\n            chain: BTreeMap::new(),\r\n"]
[219.413257, "o", "            ticks: BTreeMap::new(),\r\n            blocked: BTreeSet::new(),\r\n            store: BTreeMap::new(),\r\n"]
[219.41327, "o", "            group_slot: BTreeMap::new(),\r\n            group_active: String::new(),\r\n            seen: BTreeMap::new(),\r\n            clock: 0,\r\n"]
[219.413279, "o", "        }\r\n    }\r\n\r\n"]
[219.413508, "o", "    pub fn tick_for(&self, subject: &str) -> u64 {\r\n        *self.ticks.get(subject).unwrap_or(&0)\r\n    }\r\n"]
[219.413548, "o", "\r\n    pub fn slot_key(object: &str, mode: &str) -> String {\r\n        format!(\"{object}|{mode}\")\r\n    }\r\n\r\n    pub fn track_key(subject: &str, object: &str, mode: &str) -> String {\r\n        format!(\"{subject}|{object}|{mode}\")\r\n    }\r\n}\r\n\r\nimpl Decision {\r\n    pub fn blank(label: &str, subject: &str, object: &str, mode: &str, tick: u64) -> Self {\r\n        Self {\r\n            label: label.to_string(),\r\n            subject: subject.to_string(),\r\n            object: object.to_string(),\r\n            mode: mode.to_string(),\r\n            outcome: String::new(),\r\n            tick,\r\n            reused: false,\r\n            group: String::new(),\r\n            via: String::new(),\r\n        }\r\n    }\r\n}\r\n"]
[219.41364, "o", "\u001b[?2004h"]
[219.413691, "o", "root@27e9125e8859:/app# "]
[227.372379, "i", "for f in /app/k0/a.rs /app/k1/b.rs /app/k2/c.rs /app/k3/d.rs /app/k4/e.rs /app/k5/f.rs /app/k6/g.rs /app/k7/h.rs /app/k8/i.rs; do echo \"===== $f\"; sed -n '1,220p' \"$f\"; done\n"]
[227.373221, "o", "for f in /app/k0/a.rs /app/k1/b.rs /app/k2/c.rs /app/k3/d.rs /app/k4/e.rs /app/k5/f.rs /app/k6/g.rs /app/k7/h.rs /app/k8/i.rs; do echo \"===== $f\"; sed -n '1,220p' \"$f\"; done\r\n\u001b[?2004l\r"]
[227.373299, "o", "===== /app/k0/a.rs\r\n"]
[227.374936, "o", "use crate::io::split_subject_object_mode;\r\nuse crate::k1_b::fold_b;\r\nuse crate::k3_d::lift_d;\r\nuse crate::k5_f::cast_f;\r\nuse crate::model::{CaseReport, Decision, Event, State};\r\n\r\n"]
[227.374965, "o", "pub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {\r\n    match b.kind.as_str() {\r\n        \"grant\" => {\r\n            let (object, mode) = b\r\n                .right\r\n                .split_once('/')\r\n                .ok_or_else(|| format!(\"bad grant row {}\", b.right))?;\r\n            a.direct\r\n                .insert((b.left.clone(), object.to_string(), mode.to_string()));\r\n            a.clock += 1;\r\n            Ok(())\r\n        }\r\n        \"delegate\" => {\r\n            a.chain.insert(b.right.clone(), b.left.clone());\r\n            a.clock += 1;\r\n            Ok(())\r\n        }\r\n        \"revoke\" => fold_b(a, &b.left),\r\n"]
[227.374974, "o", "        \"batch\" => {\r\n            a.group_active = b.left.clone();\r\n            a.group_slot.clear();"]
[227.374988, "o", "\r\n            Ok(())\r\n        }\r\n"]
[227.375037, "o", "        \"end\" => {\r\n            a.group_active.clear();\r\n            a.group_slot.clear();\r\n            Ok(())\r\n        }\r\n        \"check\" => {\r\n            let (subject, object, mode) = split_subject_object_mode(&b.right)?;\r\n            let row = if a.group_active.is_empty() {\r\n                wrap_g(a, &b.left, &subject, &object, &mode)\r\n"]
[227.375048, "o", "            } else {\r\n                lift_d(a, &b.left, &subject, &object, &mode)\r\n            };\r\n            let (row, note) = cast_f(a, row, true);\r\n"]
[227.375057, "o", "            c.decisions.push(row);\r\n            if let Some(note) = note {\r\n                c.stale.push(note);\r\n"]
[227.375065, "o", "            }\r\n            Ok(())\r\n        }\r\n"]
[227.375074, "o", "        other => Err(format!(\"unknown trace row {other}\")),\r\n    }\r\n}\r\n"]
[227.375086, "o", "\r\nfn wrap_g(a: &mut State, label: &str, subject: &str, object: &str, mode: &str) -> Decision {\r\n"]
[227.375095, "o", "    use crate::k2_c::emit_c;\r\n    use crate::k4_e::mote_e;\r\n\r\n    let tick = a.tick_for(subject);\r\n"]
[227.375378, "o", "    if let Some(outcome) = emit_c(a, subject, object, mode) {\r\n        let via = if outcome == \"allow\" {\r\n            mote_e(a, subject, object, mode).1\r\n        } else {\r\n            String::new()\r\n        };\r\n        let mut row = Decision::blank(label, subject, object, mode, tick);\r\n        row.outcome = outcome;\r\n        row.via = via;\r\n        return row;\r\n    }\r\n    let (outcome, via) = mote_e(a, subject, object, mode);\r\n    a.store.insert(\r\n        crate::model::State::slot_key(object, mode),\r\n        outcome.clone(),\r\n    );\r\n    let mut row = Decision::blank(label, subject, object, mode, tick);\r\n    row.outcome = outcome;\r\n    row.via = via;\r\n    row\r\n}\r\n===== /app/k1/b.rs\r\n"]
[227.376508, "o", "use crate::model::State;\r\n\r\npub fn fold_b(a: &mut State, b: &str) -> Result<(), String> {\r\n    let next = a.tick_for(b) + 1;\r\n    a.ticks.insert(b.to_string(), next);\r\n    a.blocked.insert(b.to_string());\r\n    a.clock += 1;\r\n    Ok(())\r\n}\r\n"]
[227.376653, "o", "===== /app/k2/c.rs\r\n"]
[227.37743, "o", "use crate::model::State;\r\n\r\npub fn emit_c(a: &State, _b: &str, c: &str, d: &str) -> Option<String> {\r\n    let key = State::slot_key(c, d);\r\n    a.store.get(&key).cloned()\r\n}\r\n"]
[227.377589, "o", "===== /app/k3/d.rs\r\n"]
[227.378482, "o", "use crate::k4_e::mote_e;\r\nuse crate::model::{Decision, State};\r\n\r\npub fn lift_d(a: &mut State, b: &str, c: &str, d: &str, e: &str) -> Decision {\r\n    let slot = State::slot_key(d, e);\r\n    let tick = a.tick_for(c);\r\n  if let Some(outcome) = a.group_slot.get(&slot) {\r\n        let via = if outcome == \"allow\" {\r\n            mote_e(a, c, d, e).1\r\n        } else {\r\n            String::new()\r\n        };\r\n        let mut row = Decision::blank(b, c, d, e, tick);\r\n        row.outcome = outcome.clone();\r\n        row.group = a.group_active.clone();\r\n        row.via = via;\r\n        return row;\r\n    }\r\n    let (outcome, via) = mote_e(a, c, d, e);\r\n    a.group_slot.insert(slot, outcome.clone());\r\n    let mut row = Decision::blank(b, c, d, e, tick);\r\n    row.outcome = outcome;\r\n    row.group = a.group_active.clone();\r\n"]
[227.378636, "o", "    row.via = via;\r\n    row\r\n}\r\n"]
[227.378763, "o", "===== /app/k4/e.rs\r\n"]
[227.37958, "o", "use crate::model::State;\r\n\r\npub fn mote_e(a: &State, b: &str, c: &str, d: &str) -> (String, String) {\r\n    let mut current = b.to_string();\r\n    loop {\r\n        if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {\r\n"]
[227.37967, "o", "            if a.blocked.contains(b) {\r\n                return (\"deny\".to_string(), String::new());\r\n            }\r\n            let via = if current == b {\r\n                String::new()\r\n"]
[227.379808, "o", "            } else {\r\n                current.clone()\r\n            };\r\n            return (\"allow\".to_string(), via);\r\n        }\r\n        match a.chain.get(&current) {\r\n            Some(parent) => current = parent.clone(),\r\n            None => return (\"deny\".to_string(), String::new()),\r\n        }\r\n    }\r\n}\r\n"]
[227.380042, "o", "===== /app/k5/f.rs\r\n"]
[227.380586, "o", "use crate::model::{Decision, State};\r\n\r\npub fn cast_f(a: &mut State, mut b: Decision, _c: bool) -> (Decision, Option<String>) {\r\n    let track = State::track_key(&b.subject, &b.object, &b.mode);\r\n"]
[227.380684, "o", "    let reused = a\r\n        .seen\r\n        .get(&track)\r\n        .map(|old| old == &b.outcome)\r\n        .unwrap_or(false);\r\n    b.reused = reused;\r\n    a.seen.insert(track, b.outcome.clone());\r\n    if b.outcome == \"allow\" && a.blocked.contains(&b.subject) && !b.via.is_empty() {\r\n        let note = b.label.clone();\r\n"]
[227.380708, "o", "        (b, Some(note))\r\n    } else {\r\n        (b, None)\r\n    }\r\n}\r\n"]
[227.380802, "o", "===== /app/k6/g.rs\r\n"]
[227.381477, "o", "use crate::model::State;\r\n\r\npub fn tally_g(_a: &State, rows: usize) -> String {\r\n    format!(\"rows={rows}\")\r\n}\r\n"]
[227.381609, "o", "===== /app/k7/h.rs\r\n"]
[227.382281, "o", "pub fn hint_h(label: &str) -> String {\r\n    label.to_ascii_lowercase()\r\n}\r\n"]
[227.382415, "o", "===== /app/k8/i.rs\r\n"]
[227.383102, "o", "pub fn order_i(left: &str, right: &str) -> std::cmp::Ordering {\r\n    left.cmp(right)\r\n}\r\n"]
[227.383245, "o", "\u001b[?2004h"]
