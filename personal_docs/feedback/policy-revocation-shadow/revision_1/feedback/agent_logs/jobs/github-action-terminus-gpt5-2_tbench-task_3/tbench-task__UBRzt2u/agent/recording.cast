[380.332757, "i", "python3 - <<'PY'\nimport json, pathlib\np=pathlib.Path('/app/output/policy-audit.json')\nd=json.loads(p.read_text())\nbad=[]\nfor case in d['cases']:\n    last=-1\n    for row in case['decisions']:\n        if row['epoch']<last:\n            bad.append((case['name'],last,row['epoch'],row['label']))\n        last=row['epoch']\nprint('epoch_decreases',bad)\nPY\n"]
