[?2004l[?2004h> use crate::model::State;
[?2004l[?2004h> 
[?2004l[?2004h> pub fn mote_e(a: &State, b: &str, c: &str, d: &str) -> (String, String) {
[?2004l[?2004h>     // Walk the delegation chain from the requesting subject toward grantors.
[?2004l[?2004h>     // If any subject along the walk is blocked/revoked, deny delegated access.
[?2004l[?2004h>     let mut current = b.to_string();
[?2004l[?2004h>     let mut saw_blocked = false;
[?2004l[?2004h> 
[?2004l[?2004h>     loop {
[?2004l[?2004h>         if a.blocked.contains(&current) {
[?2004l[?2004h>             saw_blocked = true;
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {
[?2004l[?2004h>             if saw_blocked {
[?2004l[?2004h>                 return ("deny".to_string(), String::new());
[?2004l[?2004h>             }
[?2004l[?2004h>             // delegated_from should name the grantor (the subject with the direct grant).
[?2004l[?2004h>             let delegated_from = if current == b {
[?2004l[?2004h>                 String::new()
[?2004l[?2004h>             } else {
[?2004l[?2004h>                 current.clone()
[?2004l[?2004h>             };
[?2004l[?2004h>             return ("allow".to_string(), delegated_from);
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         match a.chain.get(&current) {
[?2004l[?2004h>             Some(parent) => current = parent.clone(),
[?2004l[?2004h>             None => return ("deny".to_string(), String::new()),
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> }
