[613.082379, "o", "        outcome.clone(),\r\n    );\r\n    let mut row = Decision::blank(label, subject, object, mode, tick);\r\n"]
[613.082389, "o", "    row.outcome = outcome;\r\n    row.via = via;\r\n    row\r\n"]
[613.0824, "o", "}\r\n"]
