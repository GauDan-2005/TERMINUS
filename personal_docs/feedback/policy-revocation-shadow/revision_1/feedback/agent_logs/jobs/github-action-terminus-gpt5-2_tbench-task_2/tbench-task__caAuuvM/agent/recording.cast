[760.969078, "i", "cat > /app/k5/f.rs <<'EOF'\nuse crate::model::{Decision, State};\n\npub fn cast_f(a: &mut State, mut b: Decision, _c: bool) -> (Decision, Option<String>) {\n    let track = State::track_key(&b.subject, &b.object, &b.mode);\n\n    // Only mark a decision as reused when the subject epoch is unchanged and\n    // the outcome is the same as the last equivalent check.\n    let reused = a\n        .seen\n        .get(&track)\n        .map(|(old_tick, old_outcome)| *old_tick == b.tick && old_outcome == &b.outcome)\n        .unwrap_or(false);\n\n    b.reused = reused;\n    a.seen.insert(track, (b.tick, b.outcome.clone()));\n\n    if b.outcome == \"allow\" && a.blocked.contains(&b.subject) && !b.via.is_empty() {\n        let note = b.label.clone();\n        (b, Some(note))\n    } else {\n        (b, None)\n    }\n}\nEOF\n"]
