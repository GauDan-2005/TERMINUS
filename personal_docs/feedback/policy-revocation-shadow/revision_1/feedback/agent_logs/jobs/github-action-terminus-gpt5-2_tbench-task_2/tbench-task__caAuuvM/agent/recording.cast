[618.312251, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: k0/a.rs\n@@\n use crate::k1_b::fold_b;\n use crate::k2_c::emit_c;\n use crate::k3_d::lift_d;\n use crate::k5_f::cast_f;\n use crate::model::{CaseReport, Event, State};\n@@\n pub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {\n     match b.kind.as_str() {\n@@\n         \"batch\" => {\n             a.group_active = b.left.clone();\n+            // Group cache is scoped to a batch. New batch => clear.\n+            a.group_slot.clear();\n             Ok(())\n         }\n         \"end\" => {\n             a.group_active.clear();\n+            a.group_slot.clear();\n             Ok(())\n         }\n*** End Patch\nPATCH\n"]
