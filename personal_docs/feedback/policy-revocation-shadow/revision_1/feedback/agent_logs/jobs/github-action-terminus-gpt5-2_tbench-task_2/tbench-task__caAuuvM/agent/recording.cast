[616.328562, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: k4/e.rs\n@@\n pub fn mote_e(a: &State, b: &str, c: &str, d: &str) -> (String, String) {\n-    let mut current = b.to_string();\n-    loop {\n-        if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {\n-            if a.blocked.contains(b) {\n-                return (\"deny\".to_string(), String::new());\n-            }\n-            let via = if current == b {\n-                String::new()\n-            } else {\n-                current.clone()\n-            };\n-            return (\"allow\".to_string(), via);\n-        }\n-        match a.chain.get(&current) {\n-            Some(parent) => current = parent.clone(),\n-            None => return (\"deny\".to_string(), String::new()),\n-        }\n-    }\n+    // Walk the delegation chain from the requesting subject toward grantors.\n+    // Any blocked/revoked subject encountered along this walk (including the\n+    // requester and any intermediates/grantors) causes delegated access to deny.\n+    let mut cu"]
[616.328757, "i", "rrent = b.to_string();\n+    let mut saw_blocked = false;\n+    loop {\n+        if a.blocked.contains(&current) {\n+            saw_blocked = true;\n+        }\n+\n+        if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {\n+            if saw_blocked {\n+                return (\"deny\".to_string(), String::new());\n+            }\n+            // delegated_from should name the grantor (the subject with the direct grant).\n+            let delegated_from = if current == b { String::new() } else { current.clone() };\n+            return (\"allow\".to_string(), delegated_from);\n+        }\n+\n+        match a.chain.get(&current) {\n+            Some(parent) => current = parent.clone(),\n+            None => return (\"deny\".to_string(), String::new()),\n+        }\n+    }\n }\n*** End Patch\nPATCH\n"]
