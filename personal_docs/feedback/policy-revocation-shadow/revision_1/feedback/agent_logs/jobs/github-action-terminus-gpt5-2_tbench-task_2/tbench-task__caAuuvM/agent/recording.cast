[1021.055969, "i", "python3 - <<'PY'\nimport json\nwith open('/app/output/policy-audit.json') as f: data=json.load(f)\nfor name in ['alpha','zeta']:\n    c=next(x for x in data['cases'] if x['name']==name)\n    print('---', name)\n    epochs=[d['epoch'] for d in c['decisions']]\n    print('epochs', epochs, 'nondecreasing', all(epochs[i]<=epochs[i+1] for i in range(len(epochs)-1)))\n    for d in c['decisions']:\n        print(' ', d['label'], d['principal'], d['verdict'], 'epoch', d['epoch'], 'batch', repr(d['batch_id']), 'deleg', repr(d['delegated_from']))\nPY\n"]
