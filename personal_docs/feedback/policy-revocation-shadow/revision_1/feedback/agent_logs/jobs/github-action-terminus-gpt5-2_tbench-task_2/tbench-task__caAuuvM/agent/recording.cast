[958.771851, "i", "cat > /app/k2/c.rs <<'EOF'\nuse crate::model::State;\n\npub fn emit_c(a: &State, b: &str, c: &str, d: &str) -> Option<String> {\n    let key = State::track_key(b, c, d);\n    a.store.get(&key).cloned()\n}\nEOF\n"]
