[959.888457, "i", "perl -0777 -i -pe 's/\\\"grant\\\" => \\{([\\s\\S]*?)a\\.clock \\+= 1;\\n            Ok\\(\\(\\)\\)\\n        \\}/\"grant\" => {$1a.store.clear();\\n            a.group_slot.clear();\\n            a.seen.clear();\\n            a.clock += 1;\\n            Ok(())\\n        }/m; s/\\\"delegate\\\" => \\{([\\s\\S]*?)a\\.clock \\+= 1;\\n            Ok\\(\\(\\)\\)\\n        \\}/\"delegate\" => {$1a.store.clear();\\n            a.group_slot.clear();\\n            a.seen.clear();\\n            a.clock += 1;\\n            Ok(())\\n        }/m; s/\\\"check\\\" => \\{/\"check\" => {\\n            a.clock += 1;\\n            a.store.clear();/m' /app/k0/a.rs\n"]
[959.891753, "o", "perl -0777 -i -pe 's/\\\"grant\\\" => \\{([\\s\\S]*?)a\\.clock \\+= 1;\\n            Ok\\(\\(\\)\\)\\n        \\}/\"grant\" => {$1a.store.clear();\\n            a.group_slot.clear();\\n            a.seen.clear();\\n            a.clock += 1;\\n            Ok(())\\n        }/m; s/\\\"delegate\\\" => \\{([\\s\\S]*?)a\\.clock \\+= 1;\\n            Ok\\(\\(\\)\\)\\n        \\}/\"delegate\" => {$1a.store.clear();\\n            a.group_slot.clear();\\n            a.seen.clear();\\n            a.clock += 1;\\n            Ok(())\\n        }/m; s/\\\"check\\\" => \\{/\"check\" => {\\n            a.clock += 1;\\n            a.store.clear();/m' /app/k0/a.rs\r\n\u001b[?2004l\r"]
[959.892703, "o", "\u001b[?2004hroot@1dff0ae3ab5d:/app# "]
[960.884596, "i", "sed -n '1,220p' /app/k0/a.rs\n"]
[960.884902, "o", "sed -n '1,220p' /app/k0/a.rs\r\n\u001b[?2004l\r"]
[960.889382, "o", "use crate::io::split_subject_object_mode;\r\nuse crate::k1_b::fold_b;\r\nuse crate::k3_d::lift_d;\r\nuse crate::k5_f::cast_f;\r\nuse crate::model::{CaseReport, Decision, Event, State};\r\n"]
[960.889481, "o", "\r\npub fn phase_a(a: &mut State, b: &Event, c: &mut CaseReport) -> Result<(), String> {\r\n    match b.kind.as_str() {\r\n        \"grant\" => {\r\n            let (object, mode) = b\r\n                .right\r\n                .split_once('/')\r\n                .ok_or_else(|| format!(\"bad grant row {}\", b.right))?;\r\n"]
[960.889544, "o", "            a.direct\r\n"]
[960.889604, "o", "                .insert((b.left.clone(), object.to_string(), mode.to_string()));\r\n"]
[960.889656, "o", "            a.store.clear();\r\n            a.group_slot.clear();\r\n            a.seen.clear();\r\n            a.clock += 1;\r\n            Ok(())\r\n        }\r\n"]
[960.889682, "o", "        \"delegate\" => {\r\n            a.chain.insert(b.right.clone(), b.left.clone());\r\n"]
[960.889727, "o", "            a.store.clear();\r\n            a.group_slot.clear();\r\n            a.seen.clear();\r\n            a.clock += 1;\r\n            Ok(())\r\n        }\r\n        \"revoke\" => fold_b(a, &b.left),\r\n        \"batch\" => {\r\n            a.group_active = b.left.clone();\r\n            a.group_slot.clear();\r\n            Ok(())\r\n"]
[960.88977, "o", "        }\r\n        \"end\" => {\r\n            a.group_active.clear();\r\n            a.group_slot.clear();\r\n            Ok(())\r\n        }\r\n        \"check\" => {\r\n            a.clock += 1;\r\n            a.store.clear();\r\n            let (subject, object, mode) = split_subject_object_mode(&b.right)?;\r\n            let row = if a.group_active.is_empty() {\r\n                wrap_g(a, &b.left, &subject, &object, &mode)\r\n            } else {\r\n                lift_d(a, &b.left, &subject, &object, &mode)\r\n            };\r\n"]
[960.889805, "o", "            let (row, note) = cast_f(a, row, true);\r\n            c.decisions.push(row);\r\n            if let Some(note) = note {\r\n                c.stale.push(note);\r\n            }\r\n            Ok(())\r\n        }\r\n        other => Err(format!(\"unknown trace row {other}\")),\r\n    }\r\n}\r\n"]
[960.88984, "o", "\r\nfn wrap_g(a: &mut State, label: &str, subject: &str, object: &str, mode: &str) -> Decision {\r\n    use crate::k2_c::emit_c;\r\n    use crate::k4_e::mote_e;\r\n\r\n    let tick = a.clock;\r\n    if let Some(outcome) = emit_c(a, subject, object, mode) {\r\n        let via = if outcome == \"allow\" {\r\n            mote_e(a, subject, object, mode).1\r\n        } else {\r\n"]
[960.889977, "o", "            String::new()\r\n        };\r\n        let mut row = Decision::blank(label, subject, object, mode, tick);\r\n        row.outcome = outcome;\r\n        row.via = via;\r\n        return row;\r\n    }\r\n    let (outcome, via) = mote_e(a, subject, object, mode);\r\n    a.store.insert(\r\n        crate::model::State::track_key(subject, object, mode),\r\n        outcome.clone(),\r\n    );\r\n    let mut row = Decision::blank(label, subject, object, mode, tick);\r\n    row.outcome = outcome;\r\n    row.via = via;\r\n    row\r\n}\r\n"]
