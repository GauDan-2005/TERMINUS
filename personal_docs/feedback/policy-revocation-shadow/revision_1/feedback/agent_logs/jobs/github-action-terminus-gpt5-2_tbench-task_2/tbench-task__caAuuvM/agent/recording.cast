[882.151484, "o", "  solo intern vault/read deny epoch 0 batch '' deleg '' reused True\r\n--- gamma ok True stale []\r\n  batch intern vault/write deny epoch 0 batch 'b1' deleg '' reused False\r\n"]
[882.151529, "o", "--- delta ok True stale []\r\n  first alice logs/read allow epoch 0 batch '' deleg '' reused False\r\n  second alice logs/read allow epoch 0 batch '' deleg '' reused True\r\n--- epsilon ok True stale []\r\n  check leaf api/invoke deny epoch 0 batch '' deleg '' reused False\r\n"]
[882.151545, "o", "--- zeta ok True stale []\r\n  a alpha secret/read deny epoch 1 batch 'mix' deleg '' reused False\r\n"]
