[528.809055, "o", "use crate::k4_e::mote_e;\r\nuse crate::model::{Decision, State};\r\n\r\npub fn lift_d(a: &mut State, b: &str, c: &str, d: &str, e: &str) -> Decision {\r\n    let slot = State::slot_key(d, e);\r\n"]
[528.80908, "o", "    let tick = a.tick_for(c);\r\n  if let Some(outcome) = a.group_slot.get(&slot) {\r\n        let via = if outcome == \"allow\" {\r\n            mote_e(a, c, d, e).1\r\n        } else {\r\n            String::new()\r\n        };\r\n"]
[528.809093, "o", "        let mut row = Decision::blank(b, c, d, e, tick);\r\n        row.outcome = outcome.clone();\r\n"]
[528.809101, "o", "        row.group = a.group_active.clone();\r\n        row.via = via;\r\n        return row;\r\n    }\r\n    let (outcome, via) = mote_e(a, c, d, e);\r\n"]
[528.809113, "o", "    a.group_slot.insert(slot, outcome.clone());\r\n    let mut row = Decision::blank(b, c, d, e, tick);\r\n"]
[528.809124, "o", "    row.outcome = outcome;\r\n    row.group = a.group_active.clone();\r\n    row.via = via;\r\n    row\r\n}\r\n"]
