[882.131994, "i", "python3 - <<'PY'\nimport json\nwith open('/app/output/policy-audit.json') as f:\n    data=json.load(f)\nfor name in ['alpha','beta','gamma','delta','epsilon','zeta']:\n    c=next(x for x in data['cases'] if x['name']==name)\n    print('---', name, 'ok', c['ok'], 'stale', c['stale'])\n    for d in c['decisions']:\n        print(' ', d['label'], d['principal'], d['resource']+'/'+d['action'], d['verdict'], 'epoch', d['epoch'], 'batch', repr(d['batch_id']), 'deleg', repr(d['delegated_from']), 'reused', d['reused'])\nPY\n"]
