[679.38019, "i", "export PATH=/usr/local/cargo/bin:$PATH\nbash /app/scripts/run-matrix.sh\nsha256sum /app/output/policy-audit.json\npython3 - <<'PY'\nimport json\nfrom pprint import pprint\nwith open('/app/output/policy-audit.json') as f: data=json.load(f)\nfor name in ['alpha','gamma','epsilon','zeta']:\n    c=next(x for x in data['cases'] if x['name']==name)\n    print('---', name)\n    for d in c['decisions']:\n        print(d['label'], d['principal'], d['resource'], d['action'], d['verdict'], 'epoch', d['epoch'], 'batch', repr(d['batch_id']), 'deleg_from', repr(d['delegated_from']), 'reused', d['reused'])\nPY\n"]
[679.38057, "o", "export PATH=/usr/local/cargo/bin:$PATH\r\n\u001b[?2004l\r"]
