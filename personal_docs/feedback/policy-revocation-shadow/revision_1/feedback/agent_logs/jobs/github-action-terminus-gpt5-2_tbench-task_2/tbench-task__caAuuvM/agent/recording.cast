[679.419829, "o", "\u001b[?2004h"]
[679.419841, "o", "> "]
[679.419976, "o", "for name in ['alpha','gamma','epsilon','zeta']:\r\n\u001b[?2004l\r"]
[679.420024, "o", "\u001b[?2004h> "]
[679.420194, "o", "    c=next(x for x in data['cases'] if x['name']==name)\r\n\u001b[?2004l\r"]
[679.420226, "o", "\u001b[?2004h"]
[679.420239, "o", "> "]
[679.420316, "o", "    print('---', name)\r\n\u001b[?2004l\r"]
[679.42037, "o", "\u001b[?2004h> "]
[679.42046, "o", "    for d in c['decisions']:\r\n\u001b[?2004l\r"]
[679.420491, "o", "\u001b[?2004h"]
[679.420522, "o", "> "]
[679.421063, "o", "        print(d['label'], d['principal'], d['resource'], d['action'], d['verdict'], 'epoch', d['epoch'], 'batch', repr(d['batch_id']), 'deleg_from', repr(d['delegated_from']), 'reused', d['reused'])\r\n\u001b[?2004l\r"]
[679.421124, "o", "\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
[679.443804, "o", "--- alpha\r\nbefore clerk vault read allow epoch 0 batch '' deleg_from 'boss' reused False\r\n"]
[679.443901, "o", "batch clerk vault read deny epoch 1 batch 'b1' deleg_from '' reused False\r\nafter clerk vault read allow epoch 1 batch '' deleg_from '' reused False\r\n--- gamma\r\n"]
[679.443969, "o", "batch intern vault write allow epoch 0 batch 'b1' deleg_from 'boss' reused False\r\n--- epsilon\r\ncheck leaf api invoke allow epoch 0 batch '' deleg_from 'root' reused False\r\n--- zeta\r\na alpha secret read deny epoch 1 batch 'mix' deleg_from '' reused False\r\nb beta secret read deny epoch 0 batch 'mix' deleg_from '' reused False\r\n"]
[679.448192, "o", "\u001b[?2004h"]
