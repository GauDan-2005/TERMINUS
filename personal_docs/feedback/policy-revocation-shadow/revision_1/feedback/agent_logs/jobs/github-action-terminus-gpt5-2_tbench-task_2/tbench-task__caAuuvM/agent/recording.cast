[882.151349, "o", "--- alpha ok True stale []\r\n  before clerk vault/read allow epoch 0 batch '' deleg 'boss' reused False\r\n  batch clerk vault/read deny epoch 1 batch 'b1' deleg '' reused False\r\n"]
