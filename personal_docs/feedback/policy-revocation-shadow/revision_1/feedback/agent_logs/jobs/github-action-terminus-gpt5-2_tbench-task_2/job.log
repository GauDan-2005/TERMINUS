Sending keys: ['cat > /app/src/model.rs <<\'EOF\'\nuse std::collections::{BTreeMap, BTreeSet};\n\n#[derive(Clone, Debug)]\npub struct Event {\n    pub kind: String,\n    pub left: String,\n    pub right: String,\n}\n\n#[derive(Clone, Debug)]\npub struct Decision {\n    pub label: String,\n    pub subject: String,\n    pub object: String,\n    pub mode: String,\n    pub outcome: String,\n    pub tick: u64,\n    pub reused: bool,\n    pub group: String,\n    pub via: String,\n}\n\n#[derive(Clone, Debug)]\npub struct CaseReport {\n    pub name: String,\n    pub ok: bool,\n    pub decisions: Vec<Decision>,\n    pub stale: Vec<String>,\n}\n\n#[derive(Debug)]\npub struct State {\n    pub direct: BTreeSet<(String, String, String)>,\n    pub chain: BTreeMap<String, String>,\n    pub ticks: BTreeMap<String, u64>,\n    pub blocked: BTreeSet<String>,\n    pub store: BTreeMap<String, String>,\n\n    // Cache of grouped-check outcomes within the currently active batch.\n    // Keyed by (subject, object, mode) so principals do not leak into each other.\n    pub group_slot: BTreeMap<String, String>,\n    pub group_active: String,\n\n    // Reuse tracking: last (tick, outcome) observed for a given check key.\n    pub seen: BTreeMap<String, (u64, String)>,\n\n    pub clock: u64,\n}\n\nimpl State {\n    pub fn new() -> Self {\n        Self {\n            direct: BTreeSet::new(),\n            chain: BTreeMap::new(),\n            ticks: BTreeMap::new(),\n            blocked: BTreeSet::new(),\n            store: BTreeMap::new(),\n            group_slot: BTreeMap::new(),\n            group_active: String::new(),\n            seen: BTreeMap::new(),\n            clock: 0,\n        }\n    }\n\n    pub fn tick_for(&self, subject: &str) -> u64 {\n        *self.ticks.get(subject).unwrap_or(&0)\n    }\n\n    pub fn slot_key(object: &str, mode: &str) -> String {\n        format!("{object}|{mode}")\n    }\n\n    pub fn track_key(subject: &str, object: &str, mode: &str) -> String {\n        format!("{subject}|{object}|{mode}")\n    }\n}\n\nimpl Decision {\n    pub fn blank(label: &str, subject: &str, object: &str, mode: &str, tick: u64) -> Self {\n        Self {\n            label: label.to_string(),\n            subject: subject.to_string(),\n            object: object.to_string(),\n            mode: mode.to_string(),\n            outcome: String::new(),\n            tick,\n            reused: false,\n            group: String::new(),\n            via: String::new(),\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > /app/k3/d.rs <<\'EOF\'\nuse crate::k4_e::mote_e;\nuse crate::model::{Decision, State};\n\npub fn lift_d(a: &mut State, b: &str, c: &str, d: &str, e: &str) -> Decision {\n    // Grouped replay caches must not cross principals.\n    let slot = State::track_key(c, d, e);\n    let tick = a.tick_for(c);\n\n    if let Some(outcome) = a.group_slot.get(&slot) {\n        let via = if outcome == "allow" {\n            mote_e(a, c, d, e).1\n        } else {\n            String::new()\n        };\n        let mut row = Decision::blank(b, c, d, e, tick);\n        row.outcome = outcome.clone();\n        row.group = a.group_active.clone();\n        row.via = via;\n        return row;\n    }\n\n    let (outcome, via) = mote_e(a, c, d, e);\n    a.group_slot.insert(slot, outcome.clone());\n    let mut row = Decision::blank(b, c, d, e, tick);\n    row.outcome = outcome;\n    row.group = a.group_active.clone();\n    row.via = via;\n    row\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > /app/k4/e.rs <<\'EOF\'\nuse crate::model::State;\n\npub fn mote_e(a: &State, b: &str, c: &str, d: &str) -> (String, String) {\n    // Walk the delegation chain from the requesting subject toward grantors.\n    // If any subject along the walk is blocked/revoked, deny delegated access.\n    let mut current = b.to_string();\n    let mut saw_blocked = false;\n\n    loop {\n        if a.blocked.contains(&current) {\n            saw_blocked = true;\n        }\n\n        if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {\n            if saw_blocked {\n                return ("deny".to_string(), String::new());\n            }\n            // delegated_from should name the grantor (the subject with the direct grant).\n            let delegated_from = if current == b {\n                String::new()\n            } else {\n                current.clone()\n            };\n            return ("allow".to_string(), delegated_from);\n        }\n\n        match a.chain.get(&current) {\n            Some(parent) => current = parent.clone(),\n            None => return ("deny".to_string(), String::new()),\n        }\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > /app/k5/f.rs <<\'EOF\'\nuse crate::model::{Decision, State};\n\npub fn cast_f(a: &mut State, mut b: Decision, _c: bool) -> (Decision, Option<String>) {\n    let track = State::track_key(&b.subject, &b.object, &b.mode);\n\n    // Only mark a decision as reused when the subject epoch is unchanged and\n    // the outcome is the same as the last equivalent check.\n    let reused = a\n        .seen\n        .get(&track)\n        .map(|(old_tick, old_outcome)| *old_tick == b.tick && old_outcome == &b.outcome)\n        .unwrap_or(false);\n\n    b.reused = reused;\n    a.seen.insert(track, (b.tick, b.outcome.clone()));\n\n    if b.outcome == "allow" && a.blocked.contains(&b.subject) && !b.via.is_empty() {\n        let note = b.label.clone();\n        (b, Some(note))\n    } else {\n        (b, None)\n    }\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
