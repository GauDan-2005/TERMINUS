[?2004l[?2004h> use crate::model::State;
[?2004l[?2004h> 
[?2004l[?2004h> pub fn mote_e(a: &State, b: &str, c: &str, d: &str) -> (String, String) {
[?2004l[?2004h>     // Walk from requesting subject toward grantors following the delegation chain.
[?2004l[?2004h>     // If any subject along this walk is blocked/revoked, delegated access denies.
[?2004l[?2004h>     let mut current = b.to_string();
[?2004l[?2004h>     let mut path: Vec<String> = vec![current.clone()];
[?2004l[?2004h> 
[?2004l[?2004h>     loop {
[?2004l[?2004h>         if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {
[?2004l[?2004h>             let delegated = current != b;
[?2004l[?2004h>             if delegated {
[?2004l[?2004h>                 // Deny if any subject along the delegation chain is blocked/revoked.
[?2004l[?2004h>                 if path.iter().any(|s| a.blocked.contains(s)) {
[?2004l[?2004h>                     return ("deny".to_string(), String::new());
[?2004l[?2004h>                 }
[?2004l[?2004h>                 // blocked/revoked subjects never receive allow on delegated paths.
[?2004l[?2004h>                 if a.blocked.contains(b) {
[?2004l[?2004h>                     return ("deny".to_string(), String::new());
[?2004l[?2004h>                 }
[?2004l[?2004h>                 // delegated_from = grantor (the subject holding the direct grant)
[?2004l[?2004h>                 return ("allow".to_string(), current);
[?2004l[?2004h>             }
[?2004l[?2004h> 
[?2004l[?2004h>             // Direct grant.
[?2004l[?2004h>             return ("allow".to_string(), String::new());
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         match a.chain.get(&current) {
[?2004l[?2004h>             Some(parent) => {
[?2004l[?2004h>                 current = parent.clone();
[?2004l[?2004h>                 path.push(current.clone());
[?2004l[?2004h>             }
[?2004l[?2004h>             None => return ("deny".to_string(), String::new()),
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> }
[?2004l[?2004h> RS
