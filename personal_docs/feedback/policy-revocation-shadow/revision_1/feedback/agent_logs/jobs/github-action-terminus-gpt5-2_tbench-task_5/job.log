l Decision {\n    pub fn blank(label: &str, subject: &str, object: &str, mode: &str, tick: u64) -> Self {\n        Self {\n            label: label.to_string(),\n            subject: subject.to_string(),\n            object: object.to_string(),\n            mode: mode.to_string(),\n            outcome: String::new(),\n            tick,\n            reused: false,\n            group: String::new(),\n            via: String::new(),\n        }\n    }\n}\nRS\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
