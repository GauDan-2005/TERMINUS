[467.602586, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: k3/d.rs\n@@\n pub fn lift_d(a: &mut State, b: &str, c: &str, d: &str, e: &str) -> Decision {\n-    let slot = State::slot_key(d, e);\n+    let slot = State::slot_key(c, d, e);\n     let tick = a.tick_for(c);\n-  if let Some(outcome) = a.group_slot.get(&slot) {\n-        let via = if outcome == \"allow\" {\n-            mote_e(a, c, d, e).1\n-        } else {\n-            String::new()\n-        };\n+    if let Some(outcome) = a.group_slot.get(&slot) {\n+        // For grouped checks, equivalent (principal,resource,action) within the same\n+        // active batch are reused.\n+        let via = if outcome == \"allow\" { mote_e(a, c, d, e).1 } else { String::new() };\n         let mut row = Decision::blank(b, c, d, e, tick);\n         row.outcome = outcome.clone();\n         row.group = a.group_active.clone();\n         row.via = via;\n+        row.reused = true;\n         return row;\n     }\n*** End Patch\nPATCH\n"]
