[547.414505, "i", "cat > /app/k2/c.rs <<'RS'\nuse crate::model::State;\n\npub fn emit_c(a: &State, b: &str, c: &str, d: &str) -> Option<String> {\n    let key = State::slot_key(b, c, d);\n    a.store.get(&key).cloned()\n}\nRS\n"]
[547.414657, "o", "cat > /app/k2/c.rs <<'RS'\r\n"]
[547.414675, "o", "\u001b[?2004l\r"]
[547.415053, "o", "\u001b[?2004h"]
[547.416172, "o", "> use crate::model::State;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> pub fn emit_c(a: &State, b: &str, c: &str, d: &str) -> Option<String> {\r\n\u001b[?2004l\r\u001b[?2004h>     let key = State::slot_key(b, c, d);\r\n\u001b[?2004l\r"]
[547.416484, "o", "\u001b[?2004h> "]
[547.416601, "o", "    a.store.get(&key).cloned()\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> RS\r\n\u001b[?2004l\r"]
