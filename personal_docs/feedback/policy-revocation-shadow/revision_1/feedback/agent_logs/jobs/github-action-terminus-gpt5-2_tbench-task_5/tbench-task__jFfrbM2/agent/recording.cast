[628.496657, "o", "    41\t    pub clock: u64,\r\n    42\t}\r\n    43\t\r\n    44\timpl State {\r\n    45\t    pub fn new() -> Self {\r\n    46\t        Self {\r\n    47\t            direct: BTreeSet::new(),\r\n    48\t            chain: BTreeMap::new(),\r\n    49\t            ticks: BTreeMap::new(),\r\n    50\t            blocked: BTreeSet::new(),\r\n    51\t            store: BTreeMap::new(),\r\n    52\t            group_slot: BTreeMap::new(),\r\n    53\t            group_active: String::new(),\r\n    54\t            seen: BTreeMap::new(),\r\n    55\t            clock: 0,\r\n    56\t        }\r\n    57\t    }\r\n    58\t\r\n    59\t    pub fn tick_for(&self, subject: &str) -> u64 {\r\n    60\t        *self.ticks.get(subject).unwrap_or(&0)\r\n    61\t    }\r\n    62\t\r\n    63\t    pub fn slot_key(object: &str, mode: &str) -> String {\r\n    64\t        format!(\"{object}|pub fn slot_key(subject: &str, object: &str, mode: &str) -> String {\r\n    65\t        format!(\"{subject}|{object}|{mode}\")\r\n    66\t    }\r\n    67\t\r\n    68\t    pub fn track_key(subject: &str, object: &str, mode: &str) -> String {\r"]
[628.496682, "o", "\n    69\t        format!(\"{subject}|{object}|{mode}\")\r\n    70\t    }\r\n    71\t}\r\n    72\t\r\n    73\timpl Decision {\r\n    74\t    pub fn blank(label: &str, subject: &str, object: &str, mode: &str, tick: u64) -> Self {\r\n    75\t        Self {\r\n    76\t            label: label.to_string(),\r\n    77\t            subject: subject.to_string(),\r\n    78\t            object: object.to_string(),\r\n    79\t            mode: mode.to_string(),\r\n    80\t            outcome: String::new(),\r\n    81\t            tick,\r\n    82\t            reused: false,\r\n    83\t            group: String::new(),\r\n    84\t            via: String::new(),\r\n    85\t        }\r\n    86\t    }\r\n    87\t}\r\n"]
