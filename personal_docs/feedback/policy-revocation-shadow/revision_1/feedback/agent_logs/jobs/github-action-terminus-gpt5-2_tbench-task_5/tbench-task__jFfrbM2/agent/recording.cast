[468.587063, "i", "ath.iter().any(|s| a.blocked.contains(s)) {\n+                    return (\"deny\".to_string(), String::new());\n+                }\n+                // blocked/revoked subjects never receive allow on delegated paths.\n+                if a.blocked.contains(b) {\n+                    return (\"deny\".to_string(), String::new());\n+                }\n+                // delegated_from should name the grantor.\n+                return (\"allow\".to_string(), current.clone());\n+            }\n+            // Direct grant: subject status does not affect direct row in this lab.\n+            return (\"allow\".to_string(), String::new());\n         }\n         match a.chain.get(&current) {\n-            Some(parent) => current = parent.clone(),\n+            Some(parent) => {\n+                current = parent.clone();\n+                path.push(current.clone());\n+            }\n             None => return (\"deny\".to_string(), String::new()),\n         }\n     }\n }\n*** End Patch\nPATCH\n"]
