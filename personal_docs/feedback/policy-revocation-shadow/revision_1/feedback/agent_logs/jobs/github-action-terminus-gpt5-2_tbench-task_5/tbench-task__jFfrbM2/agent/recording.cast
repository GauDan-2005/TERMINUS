[628.615121, "o", "\r\n\u001b[?2004l\r"]
[628.616762, "o", "     1\tuse crate::model::State;\r\n     2\t\r\n     3\tpub fn mote_e(a: &State, b: &str, c: &str, d: &str) -> (String, String) {\r\n     4\t    // Walk from requesting subject toward grantors following the delegation chain.\r\n"]
[628.616787, "o", "     5\t    // If any subject along this walk is blocked/revoked, delegated access denies.\r\n     6\t    let mut current = b.to_string();\r\n     7\t    let mut path: Vec<String> = vec![current.clone()];\r\n     8\t\r\n     9\t    loop {\r\n    10\t        if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {\r\n    11\t            let delegated = current != b;\r\n    12\t            if delegated {\r\n    13\t                if path.iter().any(|s| a.blocked.contains(s)) {\r\n"]
[628.616801, "o", "    14\t                    return (\"deny\".to_string(), String::new());\r\n    15\t                }\r\n    16\t                if a.blocked.contains(b) {\r\n    17\t                    return (\"deny\".to_string(), String::new());\r\n"]
[628.61681, "o", "    18\t                }\r\n    19\t                // delegated_from = grantor\r\n"]
[628.616818, "o", "    20\t                return (\"allow\".to_string(), current.clone());\r\n    21\t            }\r\n    22\t            // Direct grant\r\n"]
[628.616831, "o", "    23\t            return (\"allow\".to_string(), String::new());\r\n    24\t        }\r\n    25\t\r\n"]
[628.616839, "o", "    26\t        match a.chain.get(&current) {\r\n    27\t            Some(parent) => {\r\n    28\t                current = parent.clone();\r\n"]
[628.616848, "o", "    29\t                path.push(current.clone());\r\n    30\t            }\r\n    31\t            None => return (\"deny\".to_string(), String::new()),\r\n"]
[628.616864, "o", "    32\t        }\r\n    33\t    }\r\n    34\t}\r\n"]
