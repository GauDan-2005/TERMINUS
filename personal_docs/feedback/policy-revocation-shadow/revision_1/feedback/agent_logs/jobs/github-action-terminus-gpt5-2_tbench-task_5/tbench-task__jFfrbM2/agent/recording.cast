[547.68325, "i", "cat > /app/k4/e.rs <<'RS'\nuse crate::model::State;\n\npub fn mote_e(a: &State, b: &str, c: &str, d: &str) -> (String, String) {\n    // Walk from requesting subject toward grantors following the delegation chain.\n    // If any subject along this walk is blocked/revoked, delegated access denies.\n    let mut current = b.to_string();\n    let mut path: Vec<String> = vec![current.clone()];\n\n    loop {\n        if a.direct.contains(&(current.clone(), c.to_string(), d.to_string())) {\n            let delegated = current != b;\n            if delegated {\n                if path.iter().any(|s| a.blocked.contains(s)) {\n                    return (\"deny\".to_string(), String::new());\n                }\n                if a.blocked.contains(b) {\n                    return (\"deny\".to_string(), String::new());\n                }\n                // delegated_from = grantor\n                return (\"allow\".to_string(), current.clone());\n            }\n            // Direct grant\n            return (\"allow\".to_string(), String::new());\n"]
[547.683443, "i", "        }\n\n        match a.chain.get(&current) {\n            Some(parent) => {\n                current = parent.clone();\n                path.push(current.clone());\n            }\n            None => return (\"deny\".to_string(), String::new()),\n        }\n    }\n}\nRS\n"]
[547.683467, "o", "cat > /app/k4/e.rs <<'RS'\r\n\u001b[?2004l\r"]
[547.683512, "o", "        }\r\n\r\n        match a.chain.get(&current) {\r\n            Some(parent) => {\r\n                current = parent.clone();\r\n                path.push(current.clone());\r\n            }\r\n            None => return (\"deny\".to_string(), String::new()),\r\n        }\r\n    }\r\n}\r\nRS\r\n"]
