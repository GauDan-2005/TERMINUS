[464.590083, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: src/io.rs\n@@\n pub fn split_subject_object_mode(value: &str) -> Result<(String, String, String), String> {\n@@\n }\n+\n+pub fn split_object_mode(value: &str) -> Result<(String, String), String> {\n+    let (object, mode) = value\n+        .split_once('/')\n+        .ok_or_else(|| format!(\"bad object/mode {value}\"))?;\n+    Ok((object.to_string(), mode.to_string()))\n+}\n*** End Patch\nPATCH\n"]
