[628.496008, "o", "     1\tuse std::collections::{BTreeMap, BTreeSet};\r\n     2\t\r\n     3\t#[derive(Clone, Debug)]\r\n     4\tpub struct Event {\r\n     5\t    pub kind: String,\r\n     6\t    pub left: String,\r\n     7\t    pub right: String,\r\n     8\t}\r\n     9\t\r\n    10\t#[derive(Clone, Debug)]\r\n"]
[628.496038, "o", "    11\tpub struct Decision {\r\n    12\t    pub label: String,\r\n    13\t    pub subject: String,\r\n    14\t    pub object: String,\r\n    15\t    pub mode: String,\r\n    16\t    pub outcome: String,\r\n    17\t    pub tick: u64,\r\n    18\t    pub reused: bool,\r\n    19\t"]
