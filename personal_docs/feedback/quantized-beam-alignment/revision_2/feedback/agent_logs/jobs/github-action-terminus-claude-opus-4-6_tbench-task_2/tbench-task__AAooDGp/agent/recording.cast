[77.084113, "i", "cat > /app/cmd/align/main.go << 'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc matchEntry(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\tbu"]
[77.084388, "i", "f, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Report rows are the same as raw rows (one per case, same order)\n\treportRows := make([]entry, len(raw.Raw))\n\tcopy(reportRows, raw.Raw)\n\n\tagree := true\n\n\t// Check if report.json already exists; compare old report vs incoming raw\n\tif oldBuf, err := os.ReadFile(os.Args[2]); err == nil {\n\t\tvar oldDoc finalDoc\n\t\tif err := json.Unmarshal(oldBuf, &oldDoc); err == nil {\n\t\t\t// Build map of old report rows by case name\n\t\t\toldByCase := map[string]entry{}\n\t\t\tfor _, row := range oldDoc.Rows {\n\t\t\t\toldByCase[row.Case] = row\n\t\t\t}\n\t\t\t// Compare each incoming raw row against old report row\n\t\t\tfor _, rawRow := range raw.Raw {\n\t\t\t\toldRow, exists := oldByCase[rawRow.Case]\n\t\t\t\tif !exists || !matchEntry(rawRow, oldRow) {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\t// Also check counts match\n\t\t\tif len(oldDoc.Rows) != len(raw.Raw) {\n\t\t\t\tagree = false\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false"]
