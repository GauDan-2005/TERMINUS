[77.084587, "i", "\n\t\t}\n\t}\n\t// If no existing report.json, agree is based on report rows matching raw\n\t// Since report rows ARE the raw rows, agree stays true in that case\n\n\tdoc := finalDoc{\n\t\tRows: reportRows,\n\t\tSummary: map[string]any{\n\t\t\t\"total\": len(reportRows),\n\t\t\t\"agree\": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
