[106.833592, "o", "\u001b[?2004h> '''\r\n\u001b[?2004l\r\u001b[?2004h"]
[106.833653, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[106.83381, "o", "with open('/app/cmd/align/main.go', 'wb') as f:\r\n\u001b[?2004l\r"]
[106.833892, "o", "\u001b[?2004h"]
[106.833967, "o", ">     f.write(content)\r\n\u001b[?2004l\r"]
