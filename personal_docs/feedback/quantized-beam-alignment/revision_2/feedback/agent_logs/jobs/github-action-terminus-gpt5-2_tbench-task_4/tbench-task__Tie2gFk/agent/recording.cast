[37.269681, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: tools/run_local.sh\n@@\n #!/bin/bash\n set -euo pipefail\n-cargo --version\n+# Ensure typical Rust install locations are on PATH in non-login shells.\n+if ! command -v cargo >/dev/null 2>&1; then\n+  if [ -d \"${HOME:-/root}/.cargo/bin\" ]; then\n+    export PATH=\"${HOME:-/root}/.cargo/bin:${PATH}\"\n+  fi\n+fi\n+\n+cargo --version\n mkdir -p /app/output /app/bin\n cargo build --release --quiet --manifest-path /app/Cargo.toml\n /app/target/release/local-infer-sandbox /app/output/raw.json\n go build -o /app/bin/align /app/cmd/align/main.go\n /app/bin/align /app/output/raw.json /app/output/report.json\n*** End Patch\nPATCH\n"]
