[158.678241, "o", "    if 'summary' in j:\r\n\u001b[?2004l\r"]
[158.678369, "o", "\u001b[?2004h> "]
[158.678446, "o", "        print('summary:', j['summary'])\r\n\u001b[?2004l\r"]
[158.678472, "o", "\u001b[?2004h"]
[158.678547, "o", "> PY\r\n\u001b[?2004l\r"]
[158.693846, "o", "\r\n /app/output/raw.json\r\nkeys: ['raw']\r\n"]
[158.69388, "o", "raw len: 6\r\nfirst raw row keys: ['case', 'grouped', 'order_used', 'packed', 'produced', 'reuse', 'selected', 'slot_trace']\r\n"]
[158.693988, "o", "\r\n /app/output/report.json\r\nkeys: ['rows', 'summary']\r\nrows len: 6\r\nfirst report row keys: ['case', 'grouped', 'order_used', 'packed', 'produced', 'reuse', 'slot_trace']\r\nsummary: {'agree': True, 'total': 6}\r\n"]
[158.69668, "o", "\u001b[?2004h"]
[158.696762, "o", "root@97d4c5b2e7fd:/app# "]
[167.449425, "i", "sed -n '1,220p' /app/src/main.rs\n"]
[167.450021, "o", "sed -n '1,220p' /app/src/main.rs\r\n\u001b[?2004l\r"]
[167.452833, "o", "mod a0;\r\nmod b1;\r\nmod c2;\r\nmod d3;\r\nmod e4;\r\nmod f5;\r\nmod g6;\r\n\r\nuse std::env;\r\n"]
[167.452866, "o", "use std::fs;\r\n\r\nstruct Case {\r\n    name: &'static str,\r\n    packed: bool,\r\n    group: bool,\r\n    reuse: bool,\r\n    seq: Vec<usize>,\r\n    rows: Vec<Vec<i32>>,\r\n}\r\n\r\nfn cases() -> Vec<Case> {\r\n    vec![\r\n"]
[167.452879, "o", "        Case { name: \"alpha\", packed: false, group: true, reuse: false, seq: vec![0, 1], rows: vec![vec![21, 10, 4], vec![15, 8, 6]] },\r\n        Case { name: \"beta\", packed: true, group: false, reuse: false, seq: vec![0], rows: vec![vec![10, 4, 1]] },\r\n"]
[167.452892, "o", "        Case { name: \"gamma\", packed: true, group: true, reuse: false, seq: vec![0, 1], rows: vec![vec![8, 3, 2], vec![6, 5, 1]] },\r\n        Case { name: \"delta\", packed: true, group: true, reuse: false, seq: vec![1, 0], rows: vec![vec![7, 4, 2], vec![5, 6, 3]] },\r\n"]
[167.45292, "o", "        Case { name: \"epsilon\", packed: true, group: true, reuse: true, seq: vec![1, 0, 2], rows: vec![vec![4, 7, 2], vec![9, 2, 3], vec![3, 8, 1]] },\r\n        Case { name: \"zeta\", packed: false, group: true, reuse: true, seq: vec![2, 0, 1], rows: vec![vec![12, 9, 5], vec![18, 4, 7], vec![10, 6, 8]] },\r\n    ]\r\n}\r\n"]
[167.452981, "o", "\r\nfn token(sum: i32, slot: usize, packed: bool, group: bool, reuse: bool) -> i32 {\r\n    let mut v = sum + (slot as i32) * 7;\r\n    if packed { v += 3; }\r\n    if group { v += 5; }\r\n"]
[167.452991, "o", "    if reuse { v += 11; }\r\n    v.rem_euclid(101)\r\n}\r\n\r\n"]
[167.453001, "o", "fn render_nums(a: &[i32]) -> String {\r\n    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\")\r\n}\r\n"]
[167.453011, "o", "\r\nfn render_usize(a: &[usize]) -> String {\r\n    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\")\r\n"]
[167.453021, "o", "}\r\n\r\nfn run_one(c: &Case) -> String {\r\n"]
[167.453029, "o", "    let meta = a0::A0::new();\r\n    let mut h = b1::B0::new(c.rows.len());\r\n"]
[167.453037, "o", "    let mut local = c2::C0::new(c.rows.len().max(1));\r\n    let moved = b1::bx(&mut h, &c.seq);\r\n"]
[167.453045, "o", "    let base_rows: Vec<Vec<i32>> = c.rows.iter().enumerate().map(|(i, row)| {\r\n        if c.packed { a0::ax(&meta, row, i) } else { row.clone() }\r\n"]
[167.453053, "o", "    }).collect();\r\n    let chosen = d3::dx(&(0..base_rows.len()).map(|i| i as i32).collect::<Vec<_>>(), &c.seq);\r\n"]
[167.453061, "o", "    let mut vals = Vec::new();\r\n    let mut trace = Vec::new();\r\n"]
[167.453074, "o", "    for (pos, src) in c.seq.iter().enumerate() {\r\n        let handle = moved[pos];\r\n        let acc = c2::cx(&mut local, handle, &base_rows[*src]);\r\n"]
[167.453084, "o", "        vals.push(token(acc, handle, c.packed, c.group, c.reuse));\r\n        trace.push(handle);\r\n    }\r\n"]
[167.453094, "o", "    let mut sink = e4::E0::new();\r\n    e4::ex(&mut sink, c.name, &vals, &trace);\r\n    let _display = f5::view(&vals);\r\n"]
[167.453104, "o", "    let _shape = g6::describe(&trace);\r\n    format!(\"{{\\\"case\\\":\\\"{}\\\",\\\"produced\\\":[{}],\\\"slot_trace\\\":[{}],\\\"order_used\\\":[{}],\\\"packed\\\":{},\\\"grouped\\\":{},\\\"reuse\\\":{},\\\"selected\\\":[{}]}}\",\r\n        c.name, render_nums(&vals), render_usize(&trace), render_usize(&c.seq), c.packed, c.group, c.reuse, render_nums(&chosen))\r\n"]
[167.453113, "o", "}\r\n\r\n"]
[167.453123, "o", "fn main() {\r\n    let args: Vec<String> = env::args().collect();\r\n"]
[167.453148, "o", "    let out = args.get(1).cloned().unwrap_or_else(|| \"/app/output/raw.json\".to_string());\r\n    let rows = cases().iter().map(run_one).collect::<Vec<_>>().join(\",\");\r\n    let body = format!(\"{{\\\"raw\\\":[{}]}}\\n\", rows);\r\n    if let Some(parent) = std::path::Path::new(&out).parent() {\r\n        fs::create_dir_all(parent).unwrap();\r\n    }\r\n    fs::write(out, body).unwrap();\r\n}\r\n"]
[167.453369, "o", "\u001b[?2004hroot@97d4c5b2e7fd:/app# "]
[167.561281, "i", "for f in /app/src/*/mod.rs; do echo \"\\n==== $f ====\"; sed -n '1,260p' \"$f\"; done\n"]
[167.561751, "o", "for f in /app/src/*/mod.rs; do echo \"\\n==== $f ====\"; sed -n '1,260p' \"$f\"; done"]
[167.561799, "o", "\r\n"]
[167.561825, "o", "\u001b[?2004l\r"]
[167.561996, "o", "\\n==== /app/src/a0/mod.rs ====\r\n"]
[167.563409, "o", "pub struct A0 {\r\n    pub s: Vec<i32>,\r\n    pub z: Vec<i32>,\r\n}\r\n\r\nimpl A0 {\r\n    pub fn new() -> Self {\r\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\r\n    }\r\n}\r\n\r\n"]
[167.563438, "o", "pub fn ax(a: &A0, b: &[i32], c: usize) -> Vec<i32> {\r\n    let k = c % a.s.len();\r\n    b.iter().map(|v| v * a.s[k] + a.z[k]).collect()\r\n}\r\n\r\npub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\r\n    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()\r\n"]
[167.56345, "o", "}\r\n"]
[167.563625, "o", "\\n==== /app/src/b1/mod.rs ====\r\n"]
[167.564488, "o", "pub struct B0 {\r\n    pub v: Vec<usize>,\r\n}\r\n\r\nimpl B0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: (0..n).collect() }\r\n"]
[167.564518, "o", "    }\r\n}\r\n\r\npub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {\r\n    let out = b.to_vec();\r\n    if a.v.len() == b.len() {\r\n        a.v.sort();\r\n    }\r\n    out\r\n}\r\n"]
[167.564706, "o", "\\n==== /app/src/c2/mod.rs ====\r\n"]
[167.56584, "o", "pub struct C0 {\r\n    pub v: Vec<i32>,\r\n}\r\n\r\nimpl C0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: vec![0; n] }\r\n"]
[167.565871, "o", "    }\r\n}\r\n\r\npub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {\r\n    let value: i32 = c.iter().sum();\r\n    let k = b % a.v.len();\r\n    a.v[k] += value;\r\n    a.v[k]\r\n}\r\n"]
[167.566011, "o", "\\n==== /app/src/d3/mod.rs ====\r\n"]
[167.566726, "o", "pub fn dx(a: &[i32], b: &[usize]) -> Vec<i32> {\r\n    b.iter().map(|i| a[*i]).collect()\r\n}\r\n\r\npub fn tag(a: &str, b: usize) -> String {\r\n    format!(\"{}:{}\", a, b)\r\n"]
[167.566853, "o", "}\r\n"]
[167.566919, "o", "\\n==== /app/src/e4/mod.rs ====\r\n"]
[167.567601, "o", "pub struct E0 {\r\n    pub v: Vec<String>,\r\n}\r\n\r\n"]
[167.567697, "o", "impl E0 {\r\n    pub fn new() -> Self {\r\n        Self { v: Vec::new() }\r\n    }\r\n}\r\n\r\npub fn ex(a: &mut E0, b: &str, c: &[i32], d: &[usize]) {\r\n    let vals = c.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\");\r\n    let hs = d.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\");\r\n    a.v.push(format!(\"{{\\\"case\\\":\\\"{}\\\",\\\"produced\\\":[{}],\\\"slot_trace\\\":[{}]}}\", b, vals, hs));\r\n}\r\n"]
[167.567808, "o", "\\n==== /app/src/f5/mod.rs ====\r\n"]
[167.568497, "o", "pub fn view(a: &[i32]) -> String {\r\n    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\"|\")\r\n}\r\n\r\npub fn lens(a: &[i32]) -> usize {\r\n    a.len()\r\n}\r\n"]
[167.56864, "o", "\\n==== /app/src/g6/mod.rs ====\r\n"]
[167.569356, "o", "pub fn arrange(a: &[usize]) -> Vec<usize> {\r\n    let mut x = a.to_vec();\r\n    x.sort();\r\n    x\r\n}\r\n\r\n"]
[167.569422, "o", "pub fn describe(a: &[usize]) -> String {\r\n    arrange(a).iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\"-\")\r\n}\r\n"]
[167.569571, "o", "\u001b[?2004h"]
[167.569648, "o", "root@97d4c5b2e7fd:/app# "]
[168.566891, "i", "sed -n '1,260p' /app/cmd/align/main.go\n"]
[168.567187, "o", "sed -n '1,260p' /app/cmd/align/main.go\r\n\u001b[?2004l\r"]
[168.569161, "o", "package main\r\n\r\nimport (\r\n    \"encoding/json\"\r\n    \"os\"\r\n    \"sort\"\r\n)\r\n\r\ntype entry struct {\r\n    Case      string `json:\"case\"`\r\n    Produced  []int  `json:\"produced\"`\r\n    Trace     []int  `json:\"slot_trace\"`\r\n    OrderUsed []int  `json:\"order_used\"`\r\n    Packed    bool   `json:\"packed\"`\r\n    Grouped   bool   `json:\"grouped\"`\r\n    Reuse     bool   `json:\"reuse\"`\r\n}\r\n\r\ntype rawDoc struct {\r\n    Raw []entry `json:\"raw\"`\r\n}\r\n\r\ntype finalDoc struct {\r\n    Rows    []entry        `json:\"rows\"`\r\n    Summary map[string]any `json:\"summary\"`\r\n}\r\n\r\nfunc fold(a []entry) []entry {\r\n    seen := map[byte]entry{}\r\n    for _, row := range a {\r\n        key := row.Case[0]\r\n        seen[key] = row\r\n    }\r\n    out := make([]entry, 0, len(seen))\r\n    for _, row := range seen {\r\n        out = append(out, row)\r\n    }\r\n    sort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\r\n    return out\r\n}\r\n\r\nfunc main() {\r\n    if len(os.Args) != 3 {\r\n        panic(\"usage: align raw final\")\r\n    }\r\n    buf, err := os.ReadF"]
[168.569191, "o", "ile(os.Args[1])\r\n    if err != nil {\r\n        panic(err)\r\n    }\r\n    var raw rawDoc\r\n    if err := json.Unmarshal(buf, &raw); err != nil {\r\n        panic(err)\r\n    }\r\n    rows := fold(raw.Raw)\r\n    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": len(rows) == len(raw.Raw)}}\r\n    out, err := json.MarshalIndent(doc, \"\", \"  \")\r\n    if err != nil {\r\n        panic(err)\r\n    }\r\n    if err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\r\n        panic(err)\r\n    }\r\n}\r\n\u001b[?2004hroot@97d4c5b2e7fd:/app# "]
[168.686087, "i", "sed -n '1,320p' /app/internal/collate/table.go\n"]
[168.68638, "o", "sed -n '1,320p' /app/internal/collate/table.go"]
[168.686469, "o", "\r\n"]
[168.68649, "o", "\u001b[?2004l\r"]
[168.687629, "o", "package collate\r\n"]
[168.687939, "o", "\r\nimport \"strings\"\r\n\r\nfunc Mix(a string) string {\r\n    return strings.TrimSpace(a)\r\n}\r\n\r\nfunc Keep(a []string) []string {\r\n    out := append([]string{}, a...)\r\n    return out\r\n}\r\n\u001b[?2004h"]
[168.68817, "o", "root@97d4c5b2e7fd:/app# "]
