[190.43079, "i", "cat > /app/cmd/align/main.go <<'EOF'\npackage main\n\nimport (\n    \"encoding/json\"\n    \"os\"\n    \"sort\"\n)\n\ntype entry struct {\n    Case      string `json:\"case\"`\n    Produced  []int  `json:\"produced\"`\n    Trace     []int  `json:\"slot_trace\"`\n    OrderUsed []int  `json:\"order_used\"`\n    Packed    bool   `json:\"packed\"`\n    Grouped   bool   `json:\"grouped\"`\n    Reuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n    Raw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n    Rows    []entry        `json:\"rows\"`\n    Summary map[string]any `json:\"summary\"`\n}\n\nfunc equalInts(a, b []int) bool {\n    if len(a) != len(b) {\n        return false\n    }\n    for i := range a {\n        if a[i] != b[i] {\n            return false\n        }\n    }\n    return true\n}\n\n// Match on the six required fields.\nfunc equivalent(a, b entry) bool {\n    return a.Case == b.Case &&\n        equalInts(a.Produced, b.Produced) &&\n        equalInts(a.Trace, b.Trace) &&\n        equalInts(a.OrderUsed, b.OrderUsed) &&\n        a.Packed == b.Packed &&\n     "]
[190.430926, "i", "   a.Grouped == b.Grouped &&\n        a.Reuse == b.Reuse\n}\n\nfunc indexByCase(rows []entry) map[string]entry {\n    m := make(map[string]entry, len(rows))\n    for _, r := range rows {\n        m[r.Case] = r\n    }\n    return m\n}\n\nfunc agreeByCase(raw []entry, reportRows []entry) bool {\n    rm := indexByCase(reportRows)\n    if len(rm) != len(reportRows) {\n        // duplicate case names in report\n        return false\n    }\n    for _, r := range raw {\n        rr, ok := rm[r.Case]\n        if !ok {\n            return false\n        }\n        if !equivalent(r, rr) {\n            return false\n        }\n    }\n    return true\n}\n\nfunc main() {\n    if len(os.Args) != 3 {\n        panic(\"usage: align raw final\")\n    }\n\n    rawPath := os.Args[1]\n    finalPath := os.Args[2]\n\n    buf, err := os.ReadFile(rawPath)\n    if err != nil {\n        panic(err)\n    }\n    var raw rawDoc\n    if err := json.Unmarshal(buf, &raw); err != nil {\n        panic(err)\n    }\n\n    // One row per built-in case: keep all raw rows (no dropping/merging).\n   "]
[190.43094, "i", " rows := append([]entry{}, raw.Raw...)\n    sort.Slice(rows, func(i, j int) bool { return rows[i].Case < rows[j].Case })\n\n    // agree requires:\n    //  (1) rows we are writing match incoming raw on the six fields per case name\n    //  (2) if replacing an existing report.json, prior report rows must also match incoming raw\n    agree := agreeByCase(raw.Raw, rows)\n\n    if priorBuf, err := os.ReadFile(finalPath); err == nil {\n        var prior finalDoc\n        if err := json.Unmarshal(priorBuf, &prior); err == nil {\n            if !agreeByCase(raw.Raw, prior.Rows) {\n                agree = false\n            }\n        } else {\n            // If prior report exists but is unreadable, treat as mismatch.\n            agree = false\n        }\n    }\n\n    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(raw.Raw), \"agree\": agree}}\n    out, err := json.MarshalIndent(doc, \"\", \"  \")\n    if err != nil {\n        panic(err)\n    }\n    if err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\n      "]
[190.430986, "o", "cat > /app/cmd/align/main.go <<'EOF'"]
[190.431022, "i", "  panic(err)\n    }\n}\nEOF\n"]
