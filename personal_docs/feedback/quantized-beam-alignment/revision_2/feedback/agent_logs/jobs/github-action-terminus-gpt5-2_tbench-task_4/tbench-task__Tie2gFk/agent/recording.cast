[220.5543, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nprint('raw len', len(raw))\nprint('rep len', len(rep['rows']))\nprint('agree', rep['summary'].get('agree'))\n# verify per-case equality on required fields\nneed=['produced','slot_trace','order_used','packed','grouped','reuse']\nrm={r['case']:r for r in raw}\nok=True\nfor r in rep['rows']:\n    rr=rm.get(r['case'])\n    if rr is None:\n        ok=False; print('missing raw for', r['case']); continue\n    for k in need:\n        if r[k]!=rr[k]:\n            ok=False\n            print('mismatch', r['case'], k, r[k], rr[k])\nprint('field_match', ok)\nPY\n"]
