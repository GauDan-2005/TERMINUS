[190.318085, "i", "cat > /app/src/a0/mod.rs <<'EOF'\npub struct A0 {\n    pub s: Vec<i32>,\n    pub z: Vec<i32>,\n}\n\nimpl A0 {\n    pub fn new() -> Self {\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\n    }\n}\n\n// Packed path transform: each column position gets its own scale and bias.\npub fn ax(a: &A0, b: &[i32], _row: usize) -> Vec<i32> {\n    b.iter()\n        .enumerate()\n        .map(|(i, v)| {\n            let k = i % a.s.len();\n            v * a.s[k] + a.z[k]\n        })\n        .collect()\n}\n\npub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\n    b.iter()\n        .enumerate()\n        .map(|(i, v)| {\n            let k = i % a.s.len();\n            v * a.s[k] + a.z[k]\n        })\n        .collect()\n}\nEOF\n"]
