Sending keys: ['cat > /app/cmd/align/main.go <<\'GO\'\npackage main\n\nimport (\n    "encoding/json"\n    "errors"\n    "os"\n)\n\ntype entry struct {\n    Case      string `json:"case"`\n    Produced  []int  `json:"produced"`\n    Trace     []int  `json:"slot_trace"`\n    OrderUsed []int  `json:"order_used"`\n    Packed    bool   `json:"packed"`\n    Grouped   bool   `json:"grouped"`\n    Reuse     bool   `json:"reuse"`\n}\n\ntype rawDoc struct {\n    Raw []entry `json:"raw"`\n}\n\ntype finalDoc struct {\n    Rows    []entry        `json:"rows"`\n    Summary map[string]any `json:"summary"`\n}\n\ntype priorDoc struct {\n    Rows    []entry        `json:"rows"`\n    Summary map[string]any `json:"summary"`\n}\n\nfunc equalEntry(a, b entry) bool {\n    if a.Case != b.Case || a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\n        return false\n    }\n    if len(a.Produced) != len(b.Produced) || len(a.Trace) != len(b.Trace) || len(a.OrderUsed) != len(b.OrderUsed) {\n        return false\n    }\n    for i := range a.Produced {\n        if a.Produced[i] != b.Produced[i] {\n            return false\n        }\n    }\n    for i := range a.Trace {\n        if a.Trace[i] != b.Trace[i] {\n            return false\n        }\n    }\n    for i := range a.OrderUsed {\n        if a.OrderUsed[i] != b.OrderUsed[i] {\n            return false\n        }\n    }\n    return true\n}\n\nfunc indexByCase(rows []entry) (map[string]entry, error) {\n    m := make(map[string]entry, len(rows))\n    for _, r := range rows {\n        if r.Case == "" {\n            return nil, errors.New("empty case name")\n        }\n        if _, ok := m[r.Case]; ok {\n            return nil, errors.New("duplicate case: " + r.Case)\n        }\n        m[r.Case] = r\n    }\n    return m, nil\n}\n\nfunc loadPrior(path string) (*priorDoc, error) {\n    buf, err := os.ReadFile(path)\n    if err != nil {\n        if os.IsNotExist(err) {\n            return nil, nil\n        }\n        return nil, err\n    }\n    var p priorDoc\n    if err := json.Unmarshal(buf, &p); err != nil {\n        // If prior exists but is unreadable, treat as disagreement.\n        return &priorDoc{}, nil\n    }\n    return &p, nil\n}\n\nfunc main() {\n    if len(os.Args) != 3 {\n        panic("usage: align raw final")\n    }\n    rawPath := os.Args[1]\n    finalPath := os.Args[2]\n\n    // Read incoming raw.\n    buf, err := os.ReadFile(rawPath)\n    if err != nil {\n        panic(err)\n    }\n    var raw rawDoc\n    if err := json.Unmarshal(buf, &raw); err != nil {\n        panic(err)\n    }\n\n    // New report rows: same shape/order as raw (one per built-in case entry).\n    // Also ensures Produced in report is exactly raw.Produced.\n    rows := make([]entry, len(raw.Raw))\n    copy(rows, raw.Raw)\n\n    // Compare new rows vs incoming raw by case name (should match exactly).\n    // This is defensive: if future collation mutates rows, we still enforce.\n    agree := true\n    rawByCase, err := indexByCase(raw.Raw)\n    if err != nil {\n        agree = false\n    }\n    rowsByCase, err := indexByCase(rows)\n    if err != nil {\n        agree = false\n    }\n    if agree {\n        for caseName, rr := range rawByCase {\n            fr, ok := rowsByCase[caseName]\n            if !ok || !equalEntry(rr, fr) {\n                agree = false\n                break\n            }\n        }\n    }\n\n    // If replacing an existing report.json, compare prior rows against *incoming raw*.\n    prior, err := loadPrior(finalPath)\n    if err != nil {\n        panic(err)\n    }\n    if prior != nil {\n        priorByCase, err := indexByCase(prior.Rows)\n        if err != nil {\n            agree = false\n        } else if agree {\n            for caseName, rr := range rawByCase {\n                pr, ok := priorByCase[caseName]\n                if !ok || !equalEntry(rr, pr) {\n                    agree = false\n                    break\n                }\n            }\n        } else {\n            // already false\n        }\n    }\n\n    doc := finalDoc{Rows: rows, Summary: map[string]any{"total": len(rows), "agree": agree}}\n    out, err := json.MarshalIndent(doc, "", "  ")\n    if err != nil {\n        panic(err)\n    }\n    if err := os.WriteFile(finalPath, append(out, \'\\n\'), 0o644); err != nil {\n        panic(err)\n    }\n}\nGO\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
