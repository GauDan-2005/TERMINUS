[147.003666, "i", "cat > /app/src/a0/mod.rs <<'RS'\npub struct A0 {\n    pub s: Vec<i32>,\n    pub z: Vec<i32>,\n}\n\nimpl A0 {\n    pub fn new() -> Self {\n        Self {\n            s: vec![2, 3, 5],\n            z: vec![1, -1, 2],\n        }\n    }\n}\n\n// Packed path transform.\n// Each column position gets its own scale and bias (not one shared scale across the whole row).\npub fn ax(a: &A0, b: &[i32], _row_idx: usize) -> Vec<i32> {\n    let sl = a.s.len().max(1);\n    let zl = a.z.len().max(1);\n    b.iter()\n        .enumerate()\n        .map(|(i, v)| v * a.s[i%sl] + a.z[i%zl])\n        .collect()\n}\nRS\n"]
