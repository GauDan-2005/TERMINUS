[188.027178, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))\nrep=json.load(open('/app/output/report.json'))\nprint('raw keys',raw.keys())\nprint('report keys',rep.keys())\nprint('raw rows',len(raw['raw']))\nprint('report rows',len(rep['rows']))\nprint('summary',rep['summary'])\n# quick per-case check produced equality\nrm={r['case']:r for r in raw['raw']}\npm={r['case']:r for r in rep['rows']}\nmiss=set(rm)-set(pm)\nextra=set(pm)-set(rm)\nprint('missing',miss,'extra',extra)\nfor k in sorted(rm):\n  ok = all(rm[k][f]==pm[k][f] for f in ['produced','slot_trace','order_used','packed','grouped','reuse'])\n  print(k,'match' if ok else 'MISMATCH')\nPY\n"]
