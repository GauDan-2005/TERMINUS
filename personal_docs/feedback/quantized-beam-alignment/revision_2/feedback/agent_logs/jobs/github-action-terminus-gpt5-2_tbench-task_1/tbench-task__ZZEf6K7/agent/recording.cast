[130.81685, "o", "pub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {\r\n    let value: i32 = c.iter().sum();\r\n    let k = b % a.v.len();\r\n    a.v[k] += value;\r\n    a.v[k]\r\n"]
[130.816945, "o", "}\r\n"]
