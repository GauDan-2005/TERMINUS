[86.925851, "o", "pub struct A0 {\r\n    pub s: Vec<i32>,\r\n    pub z: Vec<i32>,\r\n}\r\n\r\nimpl A0 {\r\n    pub fn new() -> Self {\r\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\r\n    }\r\n}\r\n\r\npub fn ax(a: &A0, b: &[i32], c: usize) -> Vec<i32> {\r\n    let k = c % a.s.len();\r\n    b.iter().map(|v| v * a.s[k] + a.z[k]).collect()\r\n}\r\n\r\n"]
[86.925886, "o", "pub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\r\n    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()\r\n}\r\n"]
[86.926326, "o", "/app/src/b1/mod.rs\r\n"]
[86.927553, "o", "pub struct B0 {\r\n    pub v: Vec<usize>,\r\n}\r\n\r\nimpl B0 {\r\n    pub fn new(n: usize) -> Self {"]
[86.927583, "o", "\r\n        Self { v: (0..n).collect() }\r\n    }\r\n}\r\n\r\npub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {\r\n    let out = b.to_vec();\r\n    if a.v.len() == b.len() {\r\n        a.v.sort();\r\n"]
