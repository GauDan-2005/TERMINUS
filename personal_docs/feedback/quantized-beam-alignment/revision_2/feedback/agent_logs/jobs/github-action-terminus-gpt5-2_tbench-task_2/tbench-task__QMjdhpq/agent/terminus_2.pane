[?2004l#!/bin/bash
set -euo pipefail

# Ensure Rust toolchain is on PATH (runtime ships rustup toolchain but PATH may omit it).
if [ -d /usr/local/rustup/toolchains ]; then
  tc="$(ls -1 /usr/local/rustup/toolchains | head -n 1)"
  if [ -n "${tc}" ] && [ -d "/usr/local/rustup/toolchains/${tc}/bin" ]; then
    export PATH="/usr/local/rustup/toolchains/${tc}/bin:${PATH}"
  fi
fi

cargo --version
mkdir -p /app/output /app/bin

# Rust stage (must use release binary for raw output)
cargo build --release --quiet --manifest-path /app/Cargo.toml
/app/target/release/local-infer-sandbox /app/output/raw.json

# Go collation stage
go build -o /app/bin/align /app/cmd/align/main.go
/app/bin/align /app/output/raw.json /app/output/report.json
