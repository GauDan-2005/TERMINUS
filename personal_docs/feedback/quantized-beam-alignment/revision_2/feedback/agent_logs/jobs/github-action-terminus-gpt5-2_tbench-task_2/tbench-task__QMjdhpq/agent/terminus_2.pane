    pub v: Vec<usize>,
}

impl B0 {
    pub fn new(n: usize) -> Self {
        Self { v: (0..n).collect() }
    }
}

pub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {
    let out = b.to_vec();
    if a.v.len() == b.len() {
        a.v.sort();
    }
    out
}
[?2004hroot@0a0216085fbe:/app# sed -n '1,240p' /app/src/c2/mod.rs
[?2004lpub struct C0 {
    pub v: Vec<i32>,
}

impl C0 {
    pub fn new(n: usize) -> Self {
        Self { v: vec![0; n] }
    }
}

pub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {
    let value: i32 = c.iter().sum();
    let k = b % a.v.len();
    a.v[k] += value;
    a.v[k]
}
