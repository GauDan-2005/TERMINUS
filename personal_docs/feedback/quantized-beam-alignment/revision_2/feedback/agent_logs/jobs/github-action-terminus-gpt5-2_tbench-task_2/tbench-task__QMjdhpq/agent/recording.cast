[156.589451, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nfields=['produced','slot_trace','order_used','packed','grouped','reuse']\nbyraw={r['case']:r for r in raw}\nbyrep={r['case']:r for r in rep['rows']}\nmiss=[]; diffs=[]\nfor name in sorted(byraw):\n    if name not in byrep:\n        miss.append(name)\n        continue\n    for f in fields:\n        if byraw[name][f]!=byrep[name][f]:\n            diffs.append((name,f,byraw[name][f],byrep[name][f]))\nprint('summary',rep['summary'])\nprint('missing',miss)\nprint('diff_count',len(diffs))\nif diffs:\n    print('first_diff',diffs[0])\nPY\n"]
