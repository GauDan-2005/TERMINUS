[119.773216, "i", "sed -n '1,200p' /app/src/a0/mod.rs\n"]
[119.77386, "o", "sed -n '1,200p' /app/src/a0/mod.rs\r\n\u001b[?2004l\r"]
[119.775522, "o", "pub struct A0 {\r\n"]
[119.775712, "o", "    pub s: Vec<i32>,\r\n    pub z: Vec<i32>,\r\n}\r\n\r\nimpl A0 {\r\n    pub fn new() -> Self {\r\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\r\n    }\r\n}\r\n\r\npub fn ax(a: &A0, b: &[i32], c: usize) -> Vec<i32> {\r\n    let k = c % a.s.len();\r\n    b.iter().map(|v| v * a.s[k] + a.z[k]).collect()\r\n"]
[119.775752, "o", "}\r\n\r\npub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\r\n    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()\r\n}\r\n"]
[119.77593, "o", "\u001b[?2004hroot@0a0216085fbe:/app# "]
[119.892024, "i", "sed -n '1,220p' /app/src/b1/mod.rs\n"]
[119.893037, "o", "sed -n '1,220p' /app/src/b1/mod.rs"]
[119.893089, "o", "\r\n"]
[119.893343, "o", "\u001b[?2004l\r"]
[119.894639, "o", "pub struct B0 {\r\n    pub v: Vec<usize>,\r\n}\r\n\r\n"]
[119.894695, "o", "impl B0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: (0..n).collect() }\r\n    }\r\n}\r\n\r\npub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {\r\n    let out = b.to_vec();\r\n    if a.v.len() == b.len() {\r\n        a.v.sort();\r\n"]
[119.894713, "o", "    }\r\n    out\r\n}\r\n"]
[119.894895, "o", "\u001b[?2004h"]
[119.894953, "o", "root@0a0216085fbe:/app# "]
[120.029172, "i", "sed -n '1,240p' /app/src/c2/mod.rs\n"]
[120.029365, "o", "sed -n '1,240p' /app/src/c2/mod.rs\r\n"]
[120.029977, "o", "\u001b[?2004l\r"]
[120.031596, "o", "pub struct C0 {\r\n"]
[120.031761, "o", "    pub v: Vec<i32>,\r\n}\r\n\r\nimpl C0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: vec![0; n] }\r\n    }\r\n"]
[120.031976, "o", "}\r\n\r\npub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {\r\n    let value: i32 = c.iter().sum();\r\n    let k = b % a.v.len();\r\n    a.v[k] += value;\r\n    a.v[k]\r\n}\r\n"]
