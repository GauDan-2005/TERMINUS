[121.274828, "i", "cat > /app/cmd/align/main.go <<'GO'\npackage main\n\nimport (\n    \"encoding/json\"\n    \"fmt\"\n    \"os\"\n    \"strings\"\n)\n\ntype entry struct {\n    Case      string `json:\"case\"`\n    Produced  []int  `json:\"produced\"`\n    Trace     []int  `json:\"slot_trace\"`\n    OrderUsed []int  `json:\"order_used\"`\n    Packed    bool   `json:\"packed\"`\n    Grouped   bool   `json:\"grouped\"`\n    Reuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n    Raw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n    Rows    []entry        `json:\"rows\"`\n    Summary map[string]any `json:\"summary\"`\n}\n\nfunc loadJSON(path string, dst any) error {\n    buf, err := os.ReadFile(path)\n    if err != nil {\n        return err\n    }\n    return json.Unmarshal(buf, dst)\n}\n\nfunc loadSets(path string) ([]string, error) {\n    buf, err := os.ReadFile(path)\n    if err != nil {\n        return nil, err\n    }\n    lines := strings.Split(string(buf), \"\\n\")\n    out := make([]string, 0, len(lines))\n    for _, ln := range lines {\n        ln = strings.TrimSpace(ln)\n        i"]
[121.274982, "i", "f ln == \"\" {\n            continue\n        }\n        out = append(out, ln)\n    }\n    return out, nil\n}\n\nfunc keyByCase(rows []entry) map[string]entry {\n    m := make(map[string]entry, len(rows))\n    for _, r := range rows {\n        m[r.Case] = r\n    }\n    return m\n}\n\nfunc eqEntry(a, b entry) bool {\n    if a.Case != b.Case || a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\n        return false\n    }\n    if len(a.Produced) != len(b.Produced) || len(a.Trace) != len(b.Trace) || len(a.OrderUsed) != len(b.OrderUsed) {\n        return false\n    }\n    for i := range a.Produced {\n        if a.Produced[i] != b.Produced[i] {\n            return false\n        }\n    }\n    for i := range a.Trace {\n        if a.Trace[i] != b.Trace[i] {\n            return false\n        }\n    }\n    for i := range a.OrderUsed {\n        if a.OrderUsed[i] != b.OrderUsed[i] {\n            return false\n        }\n    }\n    return true\n}\n\nfunc main() {\n    if len(os.Args) != 3 {\n        panic(\"usage: align raw final\")\n    }\n\n    r"]
[121.275445, "o", "cat > /app/cmd/align/main.go <<'GO'\r\n\u001b[?2004l\r\u001b[?2004h> package main\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> import (\r\n\u001b[?2004l\r\u001b[?2004h>     \"encoding/json\"\r\n\u001b[?2004l\r"]
[121.275469, "i", "awPath := os.Args[1]\n    outPath := os.Args[2]\n\n    var raw rawDoc\n    if err := loadJSON(rawPath, &raw); err != nil {\n        panic(err)\n    }\n\n    // Produce final rows deterministically: one row per built-in case in sets.txt.\n    // The report row shape matches raw entry and produced MUST equal raw produced.\n    sets, err := loadSets(\"/app/config/sets.txt\")\n    if err != nil {\n        panic(err)\n    }\n    rawBy := keyByCase(raw.Raw)\n\n    rows := make([]entry, 0, len(sets))\n    for _, name := range sets {\n        r, ok := rawBy[name]\n        if !ok {\n            // Do not silently drop: missing cases should break agreement.\n            continue\n        }\n        rows = append(rows, r)\n    }\n\n    // Agreement checks:\n    // 1) new report rows vs incoming raw rows (per case, on the six fields).\n    // 2) if prior report exists at outPath, compare its rows vs incoming raw rows too;\n    //    any mismatch forces agree=false even if new rows match.\n    agree := true\n\n    // Ensure we cover all cases exactly once"]
[121.275481, "o", "\u001b[?2004h"]
[121.275489, "i", ".\n    if len(rows) != len(sets) || len(raw.Raw) != len(sets) {\n        agree = false\n    }\n\n    // Compare new rows to incoming raw by case.\n    newBy := keyByCase(rows)\n    for _, name := range sets {\n        ra, okA := rawBy[name]\n        rb, okB := newBy[name]\n        if !okA || !okB {\n            agree = false\n            continue\n        }\n        if !eqEntry(ra, rb) {\n            agree = false\n        }\n    }\n\n    // Compare prior report (if any) to incoming raw by case.\n    var prior finalDoc\n    if err := loadJSON(outPath, &prior); err == nil {\n        priorBy := keyByCase(prior.Rows)\n        for _, name := range sets {\n            ra, okA := rawBy[name]\n            rp, okP := priorBy[name]\n            if !okA || !okP {\n                agree = false\n                continue\n            }\n            if !eqEntry(ra, rp) {\n                agree = false\n            }\n        }\n    }\n\n    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(sets), \"agree\": agree}}\n    out, err := json.MarshalI"]
[121.275507, "o", "> "]
[121.275523, "i", "ndent(doc, \"\", \"  \")\n    if err != nil {\n        panic(err)\n    }\n    if err := os.WriteFile(outPath, append(out, '\\n'), 0o644); err != nil {\n        panic(err)\n    }\n\n    _ = fmt.Sprintf(\"\")\n}\nGO\n"]
