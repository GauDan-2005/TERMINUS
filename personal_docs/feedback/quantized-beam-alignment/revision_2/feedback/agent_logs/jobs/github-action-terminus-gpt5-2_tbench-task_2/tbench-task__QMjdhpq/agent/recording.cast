[138.123479, "o", "import json\r\n\u001b[?2004l\r\u001b[?2004h> p='/app/output/report.json'\r\n\u001b[?2004l\r\u001b[?2004h> d=json.load(open(p))\r\n\u001b[?2004l\r\u001b[?2004h> # corrupt one value deterministically\r\n\u001b[?2004l\r\u001b[?2004h> for r in d['rows']:\r\n\u001b[?2004l\r\u001b[?2004h>     if r['case']=='beta':\r\n\u001b[?2004l\r\u001b[?2004h>         r['produced'][0]=(r['produced'][0]+1)%101\r\n\u001b[?2004l\r\u001b[?2004h>         break\r\n\u001b[?2004l\r\u001b[?2004h> open(p,'w').write(json.dumps(d,indent=2)+\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> print('corrupted beta produced in report.json')\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
[138.139244, "o", "corrupted beta produced in report.json\r\n"]
