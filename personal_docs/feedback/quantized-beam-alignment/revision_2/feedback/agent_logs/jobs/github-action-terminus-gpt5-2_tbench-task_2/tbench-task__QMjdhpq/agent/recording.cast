[122.525012, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nprint('rows',len(rep['rows']),'summary',rep['summary'])\nfields=['produced','slot_trace','order_used','packed','grouped','reuse']\nbyraw={r['case']:r for r in raw}\nbyrep={r['case']:r for r in rep['rows']}\nmiss=[]; diffs=[]\nfor k,v in byraw.items():\n    if k not in byrep: miss.append(k); continue\n    for f in fields:\n        if byrep[k].get(f)!=v.get(f):\n            diffs.append((k,f,byrep[k].get(f),v.get(f)))\nprint('missing',miss)\nprint('diffs',diffs[:5])\nPY\n"]
