[137.125521, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nprint('summary',rep['summary'])\nfields=['produced','slot_trace','order_used','packed','grouped','reuse']\nbyraw={r['case']:r for r in raw}\nbyrep={r['case']:r for r in rep['rows']}\nfor name in sorted(byraw):\n    diffs=[f for f in fields if byraw[name][f]!=byrep[name][f]]\n    if diffs:\n        print('DIFF',name,diffs)\nprint('packed produced:',{r['case']:r['produced'] for r in raw if r['packed']})\nPY\n"]
