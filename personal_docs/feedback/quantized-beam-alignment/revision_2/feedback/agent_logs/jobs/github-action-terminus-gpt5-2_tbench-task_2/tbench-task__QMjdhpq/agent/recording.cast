[67.30967, "i", "cat > /app/tools/run_local.sh <<'SH'\n#!/bin/bash\nset -euo pipefail\n\n# Ensure Rust toolchain is on PATH (runtime ships rustup toolchain but PATH may omit it).\nif [ -d /usr/local/rustup/toolchains ]; then\n  tc=\"$(ls -1 /usr/local/rustup/toolchains | head -n 1)\"\n  if [ -n \"${tc}\" ] && [ -d \"/usr/local/rustup/toolchains/${tc}/bin\" ]; then\n    export PATH=\"/usr/local/rustup/toolchains/${tc}/bin:${PATH}\"\n  fi\nfi\n\ncargo --version\nmkdir -p /app/output /app/bin\n\n# Rust stage (must use release binary for raw output)\ncargo build --release --quiet --manifest-path /app/Cargo.toml\n/app/target/release/local-infer-sandbox /app/output/raw.json\n\n# Go collation stage\ngo build -o /app/bin/align /app/cmd/align/main.go\n/app/bin/align /app/output/raw.json /app/output/report.json\nSH\nchmod +x /app/tools/run_local.sh\n"]
