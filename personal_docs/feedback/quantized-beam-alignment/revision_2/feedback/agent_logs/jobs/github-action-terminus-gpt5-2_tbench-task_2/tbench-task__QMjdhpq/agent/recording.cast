[94.764753, "i", "sed -n '1,200p' /app/cmd/align/main.go\n"]
[94.765869, "o", "sed -n '1,200p' /app/cmd/align/main.go\r\n\u001b[?2004l\r"]
[94.767087, "o", "package main\r\n\r\nimport (\r\n    \"encoding/json\"\r\n    \"os\""]
[94.767119, "o", "\r\n    \"sort\"\r\n)\r\n\r\ntype entry struct {\r\n    Case      string `json:\"case\"`\r\n    Produced  []int  `json:\"produced\"`\r\n    Trace     []int  `json:\"slot_trace\"`\r\n    OrderUsed []int  `json:\"order_used\"`\r\n    Packed    bool   `json:\"packed\"`\r\n    Grouped   bool   `json:\"grouped\"`\r\n    Reuse     bool   `json:\"reuse\"`\r\n}\r\n"]
[94.767133, "o", "\r\ntype rawDoc struct {\r\n    Raw []entry `json:\"raw\"`\r\n}\r\n\r\n"]
[94.767144, "o", "type finalDoc struct {\r\n    Rows    []entry        `json:\"rows\"`\r\n    Summary map[string]any `json:\"summary\"`\r\n}\r\n\r\n"]
[94.767157, "o", "func fold(a []entry) []entry {\r\n    seen := map[byte]entry{}\r\n    for _, row := range a {\r\n"]
[94.767166, "o", "        key := row.Case[0]\r\n        seen[key] = row\r\n    }\r\n    out := make([]entry, 0, len(seen))\r\n    for _, row := range seen {\r\n"]
[94.767179, "o", "        out = append(out, row)\r\n    }\r\n    sort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\r\n    return out\r\n"]
[94.767192, "o", "}\r\n\r\nfunc main() {\r\n    if len(os.Args) != 3 {\r\n"]
[94.767201, "o", "        panic(\"usage: align raw final\")\r\n    }\r\n    buf, err := os.ReadFile(os.Args[1])\r\n"]
[94.76721, "o", "    if err != nil {\r\n        panic(err)\r\n    }\r\n"]
[94.767218, "o", "    var raw rawDoc\r\n    if err := json.Unmarshal(buf, &raw); err != nil {\r\n        panic(err)\r\n"]
[94.767234, "o", "    }\r\n    rows := fold(raw.Raw)\r\n    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": len(rows) == len(raw.Raw)}}\r\n    out, err := json.MarshalIndent(doc, \"\", \"  \")\r\n"]
[94.767246, "o", "    if err != nil {\r\n        panic(err)\r\n    }\r\n    if err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\r\n        panic(err)"]
[94.767257, "o", "\r\n    }\r\n}\r\n"]
[94.767492, "o", "\u001b[?2004hroot@0a0216085fbe:/app# "]
[94.880406, "i", "sed -n '1,260p' /app/internal/collate/table.go\n"]
[94.880853, "o", "sed -n '1,260p' /app/internal/collate/table.go\r\n\u001b[?2004l\r"]
[94.882232, "o", "package collate\r\n\r\nimport \"strings\"\r\n\r\nfunc Mix(a string) string {\r\n    return strings.TrimSpace(a)\r\n}\r\n\r\nfunc Keep(a []string) []string {\r\n    out := append([]string{}, a...)\r\n"]
[94.882257, "o", "    return out\r\n}\r\n"]
[94.882487, "o", "\u001b[?2004h"]
