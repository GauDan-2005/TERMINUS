[93.769947, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))['rows']\nbyname_raw={r['case']:r for r in raw}\nbyname_rep={r['case']:r for r in rep}\nfields=['produced','slot_trace','order_used','packed','grouped','reuse']\nall_names=sorted(set(byname_raw)|set(byname_rep))\nfor n in all_names:\n    if n not in byname_raw or n not in byname_rep:\n        print('missing',n,'raw' if n not in byname_raw else '', 'rep' if n not in byname_rep else '')\n        continue\n    diffs=[f for f in fields if byname_raw[n].get(f)!=byname_rep[n].get(f)]\n    if diffs:\n        print('DIFF',n,diffs)\nPY\n"]
