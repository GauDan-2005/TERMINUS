[15.259861, "o", "cat /app/src/b1/mod.rs\r\n\u001b[?2004l\r"]
[15.261586, "o", "pub struct B0 {\r\n    pub v: Vec<usize>,\r\n}\r\n\r\nimpl B0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: (0..n).collect() }\r\n    }\r\n}\r\n\r\npub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {\r\n    let out = b.to_vec();\r\n    if a.v.len() == b.len() {\r\n        a.v.sort();\r\n    }\r\n    out\r\n}\r\n"]
[15.261817, "o", "\u001b[?2004hroot@144d824ac141:/app# "]
