Sending keys: ['cat > /app/cmd/align/main.go << \'EOF\'\npackage main\n\nimport (\n\t"encoding/json"\n\t"os"\n\t"reflect"\n)\n\ntype entry struct {\n\tCase      string `json:"case"`\n\tProduced  []int  `json:"produced"`\n\tTrace     []int  `json:"slot_trace"`\n\tOrderUsed []int  `json:"order_used"`\n\tPacked    bool   `json:"packed"`\n\tGrouped   bool   `json:"grouped"`\n\tReuse     bool   `json:"reuse"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:"raw"`\n}\n\ntype finalDoc struct {\n\tRows    []entry `json:"rows"`\n\tSummary summary `json:"summary"`\n}\n\ntype summary struct {\n\tTotal int  `json:"total"`\n\tAgree bool `json:"agree"`\n}\n\nfunc matches(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic("usage: align raw final")\n\t}\n\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Build report rows as copies of raw rows\n\treportRows := make([]entry, len(raw.Raw))\n\tcopy(reportRows, raw.Raw)\n\n\t// Check agreement\n\tagree := true\n\n\t// If a prior report.json exists, compare incoming raw against stored report\n\toutPath := os.Args[2]\n\tif priorBuf, err := os.ReadFile(outPath); err == nil {\n\t\tvar prior finalDoc\n\t\tif err := json.Unmarshal(priorBuf, &prior); err == nil {\n\t\t\t// Build map of prior report rows by case name\n\t\t\tpriorMap := map[string]entry{}\n\t\t\tfor _, row := range prior.Rows {\n\t\t\t\tpriorMap[row.Case] = row\n\t\t\t}\n\t\t\t// Compare each raw row