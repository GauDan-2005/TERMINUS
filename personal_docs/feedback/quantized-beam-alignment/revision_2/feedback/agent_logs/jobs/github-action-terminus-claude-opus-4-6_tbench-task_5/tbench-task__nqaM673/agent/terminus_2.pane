pub fn ex(a: &mut E0, b: &str, c: &[i32], d: &[usize]) {
    let vals = c.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(",");
    let hs = d.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(",");
