[?2004lpub struct A0 {
    pub s: Vec<i32>,
    pub z: Vec<i32>,
}

impl A0 {
    pub fn new() -> Self {
        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }
    }
}

pub fn ax(a: &A0, b: &[i32], c: usize) -> Vec<i32> {
    let k = c % a.s.len();
    b.iter().map(|v| v * a.s[k] + a.z[k]).collect()
}

pub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {
    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()
}
[?2004hroot@8bc3e3c76449:/app# cat /app/src/b1/mod.rs
[?2004lpub struct B0 {
    pub v: Vec<usize>,
}

impl B0 {
    pub fn new(n: usize) -> Self {
        Self { v: (0..n).collect() }
    }
}

pub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {
    let out = b.to_vec();
    if a.v.len() == b.len() {
        a.v.sort();
    }
    out
}
[?2004hroot@8bc3e3c76449:/app# cat /app/src/c2/mod.rs
[?2004lpub struct C0 {
    pub v: Vec<i32>,
}

impl C0 {
    pub fn new(n: usize) -> Self {
        Self { v: vec![0; n] }
    }
}

pub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {
    let value: i32 = c.iter().sum();
    let k = b % a.v.len();
    a.v[k] += value;
    a.v[k]
}
