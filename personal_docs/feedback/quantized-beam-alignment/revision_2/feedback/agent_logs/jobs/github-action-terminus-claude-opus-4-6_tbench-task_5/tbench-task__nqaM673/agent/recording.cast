[84.20198, "i", "cat > /app/cmd/align/main.go << 'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc matches(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\tbuf, "]
[84.202028, "i", "err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Report rows are the raw rows directly\n\trows := raw.Raw\n\n\t// Determine agreement\n\tagree := true\n\n\t// Check if existing report.json exists\n\treportPath := os.Args[2]\n\tif existingBuf, err := os.ReadFile(reportPath); err == nil {\n\t\tvar existing finalDoc\n\t\tif err := json.Unmarshal(existingBuf, &existing); err == nil {\n\t\t\t// Compare incoming raw rows against existing report rows\n\t\t\tif len(raw.Raw) != len(existing.Rows) {\n\t\t\t\tagree = false\n\t\t\t} else {\n\t\t\t\t// Build map of existing rows by case name\n\t\t\t\texMap := make(map[string]entry)\n\t\t\t\tfor _, r := range existing.Rows {\n\t\t\t\t\texMap[r.Case] = r\n\t\t\t\t}\n\t\t\t\tfor _, r := range raw.Raw {\n\t\t\t\t\tex, ok := exMap[r.Case]\n\t\t\t\t\tif !ok || !matches(r, ex) {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t}\n\t// If no existing file, raw rows match report rows (they're the same), agree=true\n\n\tdoc := fin"]
[84.202041, "i", "alDoc{\n\t\tRows: rows,\n\t\tSummary: map[string]any{\n\t\t\t\"total\": len(rows),\n\t\t\t\"agree\": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(reportPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
