[153.795808, "o", "pub struct A0 {\r\n    pub s: Vec<i32>,\r\n    pub z: Vec<i32>,\r\n}\r\n\r\nimpl A0 {\r\n    pub fn new() -> Self {\r\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\r\n    }\r\n}\r\n\r\npub fn ax(a: &A0, b: &[i32], _c: usize) -> Vec<i32> {\r\n    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()\r\n}\r\n\r\npub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\r\n    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()\r\n}\r\n"]
