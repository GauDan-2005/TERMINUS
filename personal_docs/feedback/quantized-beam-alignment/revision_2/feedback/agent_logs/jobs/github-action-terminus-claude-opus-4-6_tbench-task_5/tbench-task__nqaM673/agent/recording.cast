[31.628804, "o", "# Architecture notes\r\n\r\nThe Rust side keeps compact scenario data and emits raw rows with produced values and handle traces. The Go side performs light collation for the final operator document. The data files provide stable input cases for local runs.\r\n"]
[31.62899, "o", "\u001b[?2004hroot@8bc3e3c76449:/app# "]
[31.742739, "i", "cat /app/docs/operations.md\n"]
[31.743001, "o", "cat /app/docs/operations.md\r\n\u001b[?2004l\r"]
[31.743339, "o", "# Operations\r\n\r\nUse `/app/tools/run_local.sh` inside the container to refresh `/app/output/raw.json` and `/app/output/report.json`. The runner is self-contained and does not contact external services.\r\n\r\nPacked integer rows expand with per-column scales `[2, 3, 5]` and biases `[1, -1, 2]` before downstream token derivation. Each column index picks its own scale and bias pair.\r\n"]
[31.7435, "o", "\u001b[?2004h"]
