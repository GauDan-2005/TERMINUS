    }
}

pub fn ax(a: &A0, b: &[i32], c: usize) -> Vec<i32> {
    let k = c % a.s.len();
    b.iter().map(|v| v * a.s[k] + a.z[k]).collect()
}

pub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {
    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()
}
