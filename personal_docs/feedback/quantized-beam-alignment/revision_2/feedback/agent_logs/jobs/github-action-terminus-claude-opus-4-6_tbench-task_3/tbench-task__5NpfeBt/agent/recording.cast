[148.784089, "i", "python3 -c \"\nimport os\ncontent = '''package main\n\nimport (\n\\t\"encoding/json\"\n\\t\"os\"\n)\n\ntype entry struct {\n\\tCase      string `+\"`\"+`json:\"case\"`+\"`\"+` \n\\tProduced  []int  `+\"`\"+`json:\"produced\"`+\"`\"+`\n\\tTrace     []int  `+\"`\"+`json:\"slot_trace\"`+\"`\"+`\n\\tOrderUsed []int  `+\"`\"+`json:\"order_used\"`+\"`\"+`\n\\tPacked    bool   `+\"`\"+`json:\"packed\"`+\"`\"+`\n\\tGrouped   bool   `+\"`\"+`json:\"grouped\"`+\"`\"+`\n\\tReuse     bool   `+\"`\"+`json:\"reuse\"`+\"`\"+`\n}\n\ntype rawDoc struct {\n\\tRaw []entry `+\"`\"+`json:\"raw\"`+\"`\"+`\n}\n\ntype finalDoc struct {\n\\tRows    []entry        `+\"`\"+`json:\"rows\"`+\"`\"+`\n\\tSummary map[string]any `+\"`\"+`json:\"summary\"`+\"`\"+`\n}\n\nfunc sliceEqInt(a, b []int) bool {\n\\tif len(a) != len(b) {\n\\t\\treturn false\n\\t}\n\\tfor i := range a {\n\\t\\tif a[i] != b[i] {\n\\t\\t\\treturn false\n\\t\\t}\n\\t}\n\\treturn true\n}\n\nfunc entriesMatch(a, b entry) bool {\n\\tif a.Case != b.Case {\n\\t\\treturn false\n\\t}\n\\tif !sliceEqInt(a.Produced, b.Produced) {\n\\t\\treturn false\n\\t}\n\\tif !sliceEqInt(a.Trace, b.Trace) {\n\\t\\treturn false\n\\t}\n\\tif !sli"]
[148.784138, "i", "ceEqInt(a.OrderUsed, b.OrderUsed) {\n\\t\\treturn false\n\\t}\n\\tif a.Packed != b.Packed {\n\\t\\treturn false\n\\t}\n\\tif a.Grouped != b.Grouped {\n\\t\\treturn false\n\\t}\n\\tif a.Reuse != b.Reuse {\n\\t\\treturn false\n\\t}\n\\treturn true\n}\n\nfunc main() {\n\\tif len(os.Args) != 3 {\n\\t\\tpanic(\"usage: align raw final\")\n\\t}\n\\tbuf, err := os.ReadFile(os.Args[1])\n\\tif err != nil {\n\\t\\tpanic(err)\n\\t}\n\\tvar raw rawDoc\n\\tif err := json.Unmarshal(buf, &raw); err != nil {\n\\t\\tpanic(err)\n\\t}\n\n\\treportRows := make([]entry, len(raw.Raw))\n\\tcopy(reportRows, raw.Raw)\n\n\\tagree := true\n\n\\treportPath := os.Args[2]\n\\tif oldBuf, err := os.ReadFile(reportPath); err == nil {\n\\t\\tvar oldDoc finalDoc\n\\t\\tif err := json.Unmarshal(oldBuf, &oldDoc); err == nil {\n\\t\\t\\toldMap := make(map[string]entry)\n\\t\\t\\tfor _, r := range oldDoc.Rows {\n\\t\\t\\t\\toldMap[r.Case] = r\n\\t\\t\\t}\n\\t\\t\\tnewMap := make(map[string]entry)\n\\t\\t\\tfor _, r := range raw.Raw {\n\\t\\t\\t\\tnewMap[r.Case] = r\n\\t\\t\\t}\n\\t\\t\\tallCases := make(map[string]bool)\n\\t\\t\\tfor k := range oldMap {\n\\t\\t\\t\\tall"]
[148.784156, "i", "Cases[k] = true\n\\t\\t\\t}\n\\t\\t\\tfor k := range newMap {\n\\t\\t\\t\\tallCases[k] = true\n\\t\\t\\t}\n\\t\\t\\tfor c := range allCases {\n\\t\\t\\t\\toldEntry, oldOk := oldMap[c]\n\\t\\t\\t\\tnewEntry, newOk := newMap[c]\n\\t\\t\\t\\tif !oldOk || !newOk {\n\\t\\t\\t\\t\\tagree = false\n\\t\\t\\t\\t\\tbreak\n\\t\\t\\t\\t}\n\\t\\t\\t\\tif !entriesMatch(oldEntry, newEntry) {\n\\t\\t\\t\\t\\tagree = false\n\\t\\t\\t\\t\\tbreak\n\\t\\t\\t\\t}\n\\t\\t\\t}\n\\t\\t} else {\n\\t\\t\\tagree = false\n\\t\\t}\n\\t}\n\n\\tdoc := finalDoc{\n\\t\\tRows: reportRows,\n\\t\\tSummary: map[string]any{\n\\t\\t\\t\"total\": len(reportRows),\n\\t\\t\\t\"agree\": agree,\n\\t\\t},\n\\t}\n\\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\\tif err != nil {\n\\t\\tpanic(err)\n\\t}\n\\tif err := os.WriteFile(reportPath, append(out, 10), 0o644); err != nil {\n\\t\\tpanic(err)\n\\t}\n}\n'''\nos.makedirs(os.path.dirname('/app/cmd/align/main.go'), exist_ok=True)\nwith open('/app/cmd/align/main.go', 'w') as f:\n    f.write(content)\nprint('done')\n\"\n"]
