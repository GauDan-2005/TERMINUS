[15.416934, "o", "pub struct B0 {\r\n    pub v: Vec<usize>,\r\n}\r\n\r\nimpl B0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: (0..n).collect() }\r\n    }\r\n}\r\n\r\npub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {\r\n    let out = b.to_vec();\r\n    if a.v.len() == b.len() {\r\n        a.v.sort();\r\n    }\r\n    out\r\n}\r\n\u001b[?2004hroot@eaa8ba81e60c:/app# "]
[15.529113, "i", "cat /app/src/c2/mod.rs\n"]
[15.529368, "o", "cat /app/src/c2/mod.rs\r\n\u001b[?2004l\r"]
[15.530785, "o", "pub struct C0 {\r\n    pub v: Vec<i32>,\r\n}\r\n\r\nimpl C0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: vec![0; n] }\r\n    }\r\n}\r\n\r\npub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {\r\n    let value: i32 = c.iter().sum();\r\n    let k = b % a.v.len();\r\n    a.v[k] += value;\r\n    a.v[k]\r\n}\r\n"]
[15.530968, "o", "\u001b[?2004h"]
