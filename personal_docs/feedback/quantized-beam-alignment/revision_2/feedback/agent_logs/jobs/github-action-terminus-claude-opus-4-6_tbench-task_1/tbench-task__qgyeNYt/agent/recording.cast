[107.296176, "i", "cat > /app/cmd/align/main.go << 'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n\t\"sort\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc entriesMatch(a, b entry) bool {\n\treturn a.Case == b.Case &&\n\t\treflect.DeepEqual(a.Produced, b.Produced) &&\n\t\treflect.DeepEqual(a.Trace, b.Trace) &&\n\t\treflect.DeepEqual(a.OrderUsed, b.OrderUsed) &&\n\t\ta.Packed == b.Packed &&\n\t\ta.Grouped == b.Grouped &&\n\t\ta.Reuse == b.Reuse\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\t"]
[107.296553, "i", "panic(err)\n\t}\n\n\t// New report rows come directly from raw\n\trows := make([]entry, len(raw.Raw))\n\tcopy(rows, raw.Raw)\n\tsort.Slice(rows, func(i, j int) bool { return rows[i].Case < rows[j].Case })\n\n\tagree := true\n\n\t// Check if prior report exists and compare\n\tif priorBuf, rerr := os.ReadFile(os.Args[2]); rerr == nil {\n\t\tvar prior finalDoc\n\t\tif jerr := json.Unmarshal(priorBuf, &prior); jerr == nil {\n\t\t\t// Build map of prior rows by case name\n\t\t\tpriorMap := map[string]entry{}\n\t\t\tfor _, r := range prior.Rows {\n\t\t\t\tpriorMap[r.Case] = r\n\t\t\t}\n\t\t\t// Build map of raw rows by case name\n\t\t\trawMap := map[string]entry{}\n\t\t\tfor _, r := range raw.Raw {\n\t\t\t\trawMap[r.Case] = r\n\t\t\t}\n\t\t\t// Collect all case names from both sets\n\t\t\tallCases := map[string]bool{}\n\t\t\tfor _, r := range raw.Raw {\n\t\t\t\tallCases[r.Case] = true\n\t\t\t}\n\t\t\tfor _, r := range prior.Rows {\n\t\t\t\tallCases[r.Case] = true\n\t\t\t}\n\t\t\t// Compare incoming raw against prior report per case\n\t\t\tfor c := range allCases {\n\t\t\t\tpr, pOk := priorMap[c]\n\t\t\t\trr, rOk := rawMap[c]\n\t\t\t\tif"]
[107.297973, "o", "cat > /app/cmd/align/main.go << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> package main\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> import (\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\"encoding/json\"\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\"os\"\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\"reflect\"\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\"sort\"\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> type entry struct {\r\n\u001b[?2004l\r\u001b[?2004h> \u0007Case      string `json:\"case\"`\r\n\u001b[?2004l\r\u001b[?2004h> \u0007"]
[107.298, "i", " !pOk || !rOk || !entriesMatch(pr, rr) {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t}\n\t// If no prior report exists, agree stays true (report rows == raw rows)\n\n\tdoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": agree}}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
