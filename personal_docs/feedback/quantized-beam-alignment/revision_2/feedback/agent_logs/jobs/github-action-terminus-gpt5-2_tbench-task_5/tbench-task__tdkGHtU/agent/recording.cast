[219.244159, "i", "cat > /app/tools/run_local.sh <<'SH'\n#!/bin/bash\nset -euo pipefail\n\nmkdir -p /app/output /app/bin\n\nBIN=/app/target/release/local-infer-sandbox\n\nif command -v cargo >/dev/null 2>&1; then\n  cargo --version\n  cargo build --release --quiet --manifest-path /app/Cargo.toml\nelif [[ ! -x \"$BIN\" ]]; then\n  echo \"cargo not found and $BIN does not exist; cannot build required Rust release binary\" >&2\n  exit 1\nfi\n\n\"$BIN\" /app/output/raw.json\n\ngo build -o /app/bin/align /app/cmd/align/main.go\n/app/bin/align /app/output/raw.json /app/output/report.json\nSH\nchmod +x /app/tools/run_local.sh\n"]
