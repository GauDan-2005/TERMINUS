[277.065025, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))\nrep=json.load(open('/app/output/report.json'))\nprint('raw_len', len(raw['raw']))\nprint('report_len', len(rep['rows']))\nprint('summary', rep['summary'])\nraw_by={e['case']:e for e in raw['raw']}\nok=True\nfor e in rep['rows']:\n    r=raw_by.get(e['case'])\n    if not r or any(e[k]!=r[k] for k in ['produced','slot_trace','order_used','packed','grouped','reuse']):\n        ok=False\nprint('rows_match_raw', ok)\nPY\n"]
