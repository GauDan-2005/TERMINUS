[246.425486, "i", "cat > /app/cmd/align/main.go <<'GO'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"os\"\n\t\"sort\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc indexByCase(a []entry) map[string]entry {\n\tm := make(map[string]entry, len(a))\n\tfor _, r := range a {\n\t\tm[r.Case] = r\n\t}\n\treturn m\n}\n\nfunc equalRow(a, b entry) bool {\n\tif a.Case != b.Case || a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\tif len(a.Produced) != len(b.Produced) || len(a.Trace) != len(b.Trace) || len(a.OrderUsed) != len(b.OrderUsed) {\n\t\treturn false\n\t}\n\tfor i := range a.Produced {\n\t\tif a.Produced[i] != b.Produced[i] {\n\t\t\treturn fals"]
[246.42567, "i", "e\n\t\t}\n\t}\n\tfor i := range a.Trace {\n\t\tif a.Trace[i] != b.Trace[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\tfor i := range a.OrderUsed {\n\t\tif a.OrderUsed[i] != b.OrderUsed[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc loadFinal(path string) (finalDoc, error) {\n\tvar doc finalDoc\n\tbuf, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn doc, err\n\t}\n\tif err := json.Unmarshal(buf, &doc); err != nil {\n\t\treturn doc, err\n\t}\n\treturn doc, nil\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\trawPath := os.Args[1]\n\tfinalPath := os.Args[2]\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// One report row per raw row; deterministic ordering.\n\trows := make([]entry, 0, len(raw.Raw))\n\trows = append(rows, raw.Raw...)\n\tsort.Slice(rows, func(i, j int) bool { return rows[i].Case < rows[j].Case })\n\n\trawByCase := indexByCase(raw.Raw)\n\n\tagree := true\n\n\t// If overwriting an existing report.json, compare *prior* rep"]
[246.425693, "i", "ort rows\n\t// against incoming raw rows across: produced, slot_trace, order_used,\n\t// packed, grouped, reuse (keyed by case name).\n\tif prior, err := loadFinal(finalPath); err == nil {\n\t\tpriorByCase := indexByCase(prior.Rows)\n\t\tif len(priorByCase) != len(rawByCase) {\n\t\t\tagree = false\n\t\t} else {\n\t\t\tfor k, r := range rawByCase {\n\t\t\t\tp, ok := priorByCase[k]\n\t\t\t\tif !ok || !equalRow(r, p) {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t} else if !errors.Is(err, os.ErrNotExist) {\n\t\tpanic(err)\n\t}\n\n\t// Also require newly written report rows match incoming raw rows.\n\tif len(rows) != len(raw.Raw) {\n\t\tagree = false\n\t} else {\n\t\tfor _, rr := range rows {\n\t\t\tr, ok := rawByCase[rr.Case]\n\t\t\tif !ok || !equalRow(r, rr) {\n\t\t\t\tagree = false\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tdoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(raw.Raw), \"agree\": agree}}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGO\n"]
