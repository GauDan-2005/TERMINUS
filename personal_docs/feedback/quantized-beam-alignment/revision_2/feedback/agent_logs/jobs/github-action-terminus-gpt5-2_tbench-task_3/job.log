Sending keys: ['cat > /app/cmd/align/main.go <<\'GO\'\npackage main\n\nimport (\n\t"encoding/json"\n\t"os"\n)\n\ntype entry struct {\n\tCase      string `json:"case"`\n\tProduced  []int  `json:"produced"`\n\tTrace     []int  `json:"slot_trace"`\n\tOrderUsed []int  `json:"order_used"`\n\tPacked    bool   `json:"packed"`\n\tGrouped   bool   `json:"grouped"`\n\tReuse     bool   `json:"reuse"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:"raw"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:"rows"`\n\tSummary map[string]any `json:"summary"`\n}\n\nfunc equalInts(a, b []int) bool {\n\tif len(a) != len(b) {\n\t\treturn false\n\t}\n\tfor i := range a {\n\t\tif a[i] != b[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\n// Compare only the six required fields (plus case name identity via map key).\nfunc equalSix(a, b entry) bool {\n\treturn equalInts(a.Produced, b.Produced) &&\n\t\tequalInts(a.Trace, b.Trace) &&\n\t\tequalInts(a.OrderUsed, b.OrderUsed) &&\n\t\ta.Packed == b.Packed &&\n\t\ta.Grouped == b.Grouped &&\n\t\ta.Reuse == b.Reuse\n}\n\nfunc toMap(rows []entry) map[string]entry {\n\tm := make(map[string]entry, len(rows))\n\tfor _, r := range rows {\n\t\tm[r.Case] = r\n\t}\n\treturn m\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic("usage: align raw final")\n\t}\n\trawPath := os.Args[1]\n\tfinalPath := os.Args[2]\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// New report rows must mirror raw 1:1 (no dropping, no merging).\n\trows := make([]entry, len(raw.Raw))\n\tcopy(rows, raw.Raw)\n\n\trawByCase := toMap(raw.Raw)\n\treportByCase := toMap(rows)\n\n\tagree := true\n\t// Check new report matches incoming raw for every case across the six fields.\n\tif len(reportByCase) != len(rawByCase) {\n\t\tagree = false\n\t}\n\tfor name, rr := range rawByCase {\n\t\trp, ok := reportByCase[name]\n\t\tif !ok || !equalSix(rr, rp) {\n\t\t\tagree = false\n\t\t}\n\t}\n\n\t// If an existing report.json is being replaced, compare its stored rows to incoming raw.\n\tif oldBuf, err := os.ReadFile(finalPath); err == nil {\n\t\tvar old finalDoc\n\t\tif err := json.Unmarshal(oldBuf, &old); err == nil {\n\t\t\toldByCase := toMap(old.Rows)\n\t\t\tif len(oldByCase) != len(rawByCase) {\n\t\t\t\tagree = false\n\t\t\t}\n\t\t\tfor name, rr := range rawByCase {\n\t\t\t\top, ok := oldByCase[name]\n\t\t\t\tif !ok || !equalSix(rr, op) {\n\t\t\t\t\tagree = false\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\t// Unparseable prior report means we cannot claim agreement.\n\t\t\tagree = false\n\t\t}\n\t}\n\n\tdoc := finalDoc{Rows: rows, Summary: map[string]any{"total": len(raw.Raw), "agree": agree}}\n\tout, err := json.MarshalIndent(doc, "", "  ")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, \'\\n\'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGO\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
