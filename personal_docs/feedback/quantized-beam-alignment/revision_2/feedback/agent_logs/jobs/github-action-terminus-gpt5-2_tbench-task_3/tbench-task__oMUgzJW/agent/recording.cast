[308.695302, "i", "cat > /app/src/a0/mod.rs <<'RS'\npub struct A0 {\n    pub s: Vec<i32>,\n    pub z: Vec<i32>,\n}\n\nimpl A0 {\n    pub fn new() -> Self {\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\n    }\n}\n\n// Packed path: each column position in a row must receive its own scale and bias.\npub fn ax(a: &A0, b: &[i32], _row_idx: usize) -> Vec<i32> {\n    let n = a.s.len().min(a.z.len());\n    b.iter()\n        .enumerate()\n        .map(|(i, v)| {\n            let k = if n == 0 { 0 } else { i % n };\n            v * a.s[k] + a.z[k]\n        })\n        .collect()\n}\n\n// Backwards-compatible helper.\npub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\n    ax(a, b, 0)\n}\nRS\n"]
