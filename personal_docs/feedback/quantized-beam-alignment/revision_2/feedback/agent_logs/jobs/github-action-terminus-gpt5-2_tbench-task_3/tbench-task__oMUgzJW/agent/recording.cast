[369.010349, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nrawm={r['case']:r for r in raw}\nrepm={r['case']:r for r in rep['rows']}\nfields=['produced','slot_trace','order_used','packed','grouped','reuse']\nok=True\nfor name,r in rawm.items():\n    if name not in repm:\n        print('missing in report',name); ok=False; continue\n    for f in fields:\n        if r[f]!=repm[name][f]:\n            print('mismatch',name,f,r[f],repm[name][f]); ok=False\nprint('summary',rep.get('summary'))\nprint('case_count_raw',len(raw),'case_count_report',len(rep['rows']),'match',ok)\nprint('produced_by_case', {k: rawm[k]['produced'] for k in sorted(rawm)})\nPY\n"]
[369.010652, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h"]
