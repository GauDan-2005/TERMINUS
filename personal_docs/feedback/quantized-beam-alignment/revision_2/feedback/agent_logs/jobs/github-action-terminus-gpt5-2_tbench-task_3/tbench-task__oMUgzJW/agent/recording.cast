[268.151149, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nrawm={r['case']:r for r in raw}\nrepm={r['case']:r for r in rep['rows']}\nfields=['produced','slot_trace','order_used','packed','grouped','reuse']\nmiss=[]\nfor k in rawm:\n    if k not in repm:\n        miss.append(k)\n        continue\n    for f in fields:\n        if rawm[k][f]!=repm[k][f]:\n            print('mismatch',k,f,rawm[k][f],repm[k][f])\n            break\nprint('raw',len(raw),'report',len(rep['rows']),'missing',miss,'summary',rep.get('summary'))\nPY\n"]
