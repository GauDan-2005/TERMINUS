Sending keys: ['cat > /app/cmd/align/main.go <<\'GO\'\npackage main\n\nimport (\n    "encoding/json"\n    "os"\n    "reflect"\n    "sort"\n)\n\ntype entry struct {\n    Case      string `json:"case"`\n    Produced  []int  `json:"produced"`\n    Trace     []int  `json:"slot_trace"`\n    OrderUsed []int  `json:"order_used"`\n    Packed    bool   `json:"packed"`\n    Grouped   bool   `json:"grouped"`\n    Reuse     bool   `json:"reuse"`\n}\n\ntype rawDoc struct {\n    Raw []entry `json:"raw"`\n}\n\ntype finalDoc struct {\n    Rows    []entry        `json:"rows"`\n    Summary map[string]any `json:"summary"`\n}\n\nfunc sortByCase(a []entry) {\n    sort.Slice(a, func(i, j int) bool { return a[i].Case < a[j].Case })\n}\n\nfunc toMap(a []entry) map[string]entry {\n    m := make(map[string]entry, len(a))\n    for _, r := range a {\n        m[r.Case] = r\n    }\n    return m\n}\n\nfunc sameSix(a, b entry) bool {\n    if a.Case != b.Case {\n        return false\n    }\n    if a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\n        return false\n    }\n    if !reflect.DeepEqual(a.Produced, b.Produced) {\n        return false\n    }\n    if !reflect.DeepEqual(a.Trace, b.Trace) {\n        return false\n    }\n    if !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n        return false\n    }\n    return true\n}\n\nfunc agreeOnAll(raw []entry, report []entry) bool {\n    if len(raw) != len(report) {\n        return false\n    }\n    rm := toMap(raw)\n    pm := toMap(report)\n    if len(rm) != len(raw) || len(pm) != len(report) {\n        // duplicates by case name present\n        return false\n    }\n    for name, r := range rm {\n        p, ok := pm[name]\n        if !ok {\n            return false\n        }\n        if !sameSix(r, p) {\n            return false\n        }\n    }\n    // also ensure no extras in report\n    for name := range pm {\n        if _, ok := rm[name]; !ok {\n            return false\n        }\n    }\n    return true\n}\n\nfunc readJSON(path string, v any) error {\n    b, err := os.ReadFile(path)\n    if err != nil {\n        return err\n    }\n    return json.Unmarshal(b, v)\n}\n\nfunc main() {\n    if len(os.Args) != 3 {\n        panic("usage: align raw final")\n    }\n    rawPath := os.Args[1]\n    finalPath := os.Args[2]\n\n    var raw rawDoc\n    if err := readJSON(rawPath, &raw); err != nil {\n        panic(err)\n    }\n\n    // rows are the raw entries (1 per built-in case), sorted deterministically.\n    rows := append([]entry(nil), raw.Raw...)\n    sortByCase(rows)\n\n    agree := agreeOnAll(raw.Raw, rows)\n\n    // Additional requirement: when replacing an existing finalPath, compare\n    // incoming raw rows against the report rows already stored there.\n    if _, err := os.Stat(finalPath); err == nil {\n        var prior finalDoc\n        if err := readJSON(finalPath, &prior); err != nil {\n            // If prior is unreadable, must not claim agreement.\n            agree = false\n        } else {\n            if !agreeOnAll(raw.Raw, prior.Rows) {\n                agree = false\n            }\n        }\n    }\n\n    doc := finalDoc{Rows: rows, Summary: map[string]any{"total": len(raw.Raw), "agree": agree}}\n    out, err := json.MarshalIndent(doc, "", "  ")\n    if err != nil {\n        panic(err)\n    }\n    if err := os.WriteFile(finalPath, append(out, \'\\n\'), 0o644); err != nil {\n        panic(err)\n    }\n}\nGO\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
