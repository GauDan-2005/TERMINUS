[210.562556, "o", "    pm := toMap(report)\r\n\u001b[?2004l\r"]
[210.562581, "o", "\u001b[?2004h"]
[210.562593, "o", "> "]
[210.562779, "o", "    if len(rm) != len(raw) || len(pm) != len(report) {\r\n\u001b[?2004l\r"]
[210.562858, "o", "\u001b[?2004h"]
[210.562915, "o", "> "]
[210.562976, "o", "        // duplicates by case name present\r\n\u001b[?2004l\r"]
[210.563048, "o", "\u001b[?2004h> "]
[210.56312, "o", "        return false\r\n\u001b[?2004l\r"]
[210.563148, "o", "\u001b[?2004h> "]
[210.563232, "o", "    }\r\n\u001b[?2004l\r"]
[210.563258, "o", "\u001b[?2004h> "]
[210.563357, "o", "    for name, r := range rm {\r\n\u001b[?2004l\r"]
[210.563375, "o", "\u001b[?2004h"]
[210.563385, "o", "> "]
[210.563495, "o", "        p, ok := pm[name]\r\n\u001b[?2004l\r"]
[210.56357, "o", "\u001b[?2004h> "]
[210.563648, "o", "        if !ok {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[210.563741, "o", "            return false\r\n\u001b[?2004l\r"]
[210.563765, "o", "\u001b[?2004h> "]
[210.563817, "o", "        }\r\n\u001b[?2004l\r"]
[210.563871, "o", "\u001b[?2004h"]
[210.563889, "o", "> "]
[210.563965, "o", "        if !sameSix(r, p) {\r\n\u001b[?2004l\r"]
[210.56403, "o", "\u001b[?2004h"]
[210.564051, "o", "> "]
[210.564109, "o", "            return false\r\n\u001b[?2004l\r"]
[210.564156, "o", "\u001b[?2004h"]
[210.56421, "o", ">         }\r\n\u001b[?2004l\r"]
[210.564233, "o", "\u001b[?2004h> "]
[210.564259, "o", "    }\r\n\u001b[?2004l\r"]
[210.5643, "o", "\u001b[?2004h"]
[210.564344, "o", "> "]
[210.564477, "o", "    // also ensure no extras in report\r\n\u001b[?2004l\r"]
[210.56453, "o", "\u001b[?2004h"]
[210.564564, "o", "> "]
[210.564623, "o", "    for name := range pm {\r\n\u001b[?2004l\r"]
[210.564672, "o", "\u001b[?2004h> "]
[210.564873, "o", "        if _, ok := rm[name]; !ok {\r\n\u001b[?2004l\r"]
[210.564994, "o", "\u001b[?2004h> "]
[210.565139, "o", "            return false\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h"]
[210.565274, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[210.565373, "o", "    return true\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[210.565488, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[210.565619, "o", "func readJSON(path string, v any) error {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[210.565723, "o", "    b, err := os.ReadFile(path)\r\n\u001b[?2004l\r"]
[210.56584, "o", "\u001b[?2004h> "]
[210.565965, "o", "    if err != nil {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[210.566072, "o", "        return err\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[210.566158, "o", "> "]
[210.566232, "o", "    return json.Unmarshal(b, v)\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[210.566342, "o", "\u001b[?2004h"]
[210.566492, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> func main() {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[210.566638, "o", "    if len(os.Args) != 3 {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[210.566751, "o", "        panic(\"usage: align raw final\")\r\n\u001b[?2004l\r"]
[210.566893, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[210.566991, "o", "    rawPath := os.Args[1]\r\n\u001b[?2004l\r"]
[210.56708, "o", "\u001b[?2004h> "]
[210.567191, "o", "    finalPath := os.Args[2]\r\n\u001b[?2004l\r"]
[210.567325, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     var raw rawDoc\r\n\u001b[?2004l\r\u001b[?2004h"]
[210.567431, "o", "> "]
[210.567543, "o", "    if err := readJSON(rawPath, &raw); err != nil {\r\n\u001b[?2004l\r"]
[210.567671, "o", "\u001b[?2004h>         panic(err)\r\n\u001b[?2004l\r"]
[210.567755, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[210.567917, "o", "\u001b[?2004h> "]
[210.56809, "o", "    // rows are the raw entries (1 per built-in case), sorted deterministically.\r\n\u001b[?2004l\r"]
[210.568116, "o", "\u001b[?2004h> "]
[210.568298, "o", "    rows := append([]entry(nil), raw.Raw...)\r\n\u001b[?2004l\r"]
[210.568356, "o", "\u001b[?2004h> "]
[210.568452, "o", "    sortByCase(rows)\r\n\u001b[?2004l\r\u001b[?2004h"]
[210.568544, "o", "> \r\n\u001b[?2004l\r"]
[210.568657, "o", "\u001b[?2004h> "]
[210.568867, "o", "    agree := agreeOnAll(raw.Raw, rows)\r\n\u001b[?2004l\r"]
[210.568892, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[210.568978, "o", "\u001b[?2004h> "]
[210.56929, "o", "    // Additional requirement: when replacing an existing finalPath, compare\r\n\u001b[?2004l\r"]
[210.569316, "o", "\u001b[?2004h> "]
[210.569604, "o", "    // incoming raw rows against the report rows already stored there.\r\n\u001b[?2004l\r"]
[210.569629, "o", "\u001b[?2004h> "]
[210.569835, "o", "    if _, err := os.Stat(finalPath); err == nil {\r\n\u001b[?2004l\r"]
[210.569894, "o", "\u001b[?2004h> "]
[210.570026, "o", "        var prior finalDoc\r\n\u001b[?2004l\r"]
[210.57005, "o", "\u001b[?2004h"]
[210.570151, "o", "> "]
[210.570407, "o", "        if err := readJSON(finalPath, &prior); err != nil {\r\n\u001b[?2004l\r"]
[210.570434, "o", "\u001b[?2004h"]
[210.570448, "o", "> "]
[210.570681, "o", "            // If prior is unreadable, must not claim agreement.\r\n\u001b[?2004l\r"]
[210.570706, "o", "\u001b[?2004h> "]
[210.570823, "o", "            agree = false\r\n"]
[210.570841, "o", "\u001b[?2004l\r"]
[210.570928, "o", "\u001b[?2004h"]
[210.570972, "o", "> "]
[210.571088, "o", "        } else {\r\n\u001b[?2004l\r"]
[210.571135, "o", "\u001b[?2004h> "]
[210.571332, "o", "            if !agreeOnAll(raw.Raw, prior.Rows) {\r\n\u001b[?2004l\r"]
[210.571374, "o", "\u001b[?2004h> "]
[210.571563, "o", "                agree = false\r\n\u001b[?2004l\r"]
[210.571606, "o", "\u001b[?2004h> "]
[210.571738, "o", "            }\r\n\u001b[?2004l\r"]
[210.571759, "o", "\u001b[?2004h"]
[210.571842, "o", "> "]
[210.571922, "o", "        }\r\n\u001b[?2004l\r"]
[210.572011, "o", "\u001b[?2004h"]
[210.572066, "o", "> "]
[210.572166, "o", "    }\r\n\u001b[?2004l\r"]
[210.572255, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[210.572293, "o", "\u001b[?2004h> "]
[210.572663, "o", "    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(raw.Raw), \"agree\": agree}}\r\n\u001b[?2004l\r"]
[210.572688, "o", "\u001b[?2004h"]
[210.573921, "o", "> "]
[210.573996, "o", "    out, err := json.MarshalIndent(doc, \"\", \"  \")\r\n\u001b[?2004l\r\u001b[?2004h>     if err != nil {\r\n\u001b[?2004l\r\u001b[?2004h>         panic(err)\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     if err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\r\n\u001b[?2004l\r\u001b[?2004h>         panic(err)\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> GO\r\n\u001b[?2004l\r"]
