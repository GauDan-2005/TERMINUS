[481.852944, "o", "> raw=json.load(open('/app/output/raw.json'))\r\n\u001b[?2004l\r\u001b[?2004h> rep=json.load(open('/app/output/report.json'))\r\n\u001b[?2004l\r\u001b[?2004h> req={'case','produced','slot_trace','order_used','packed','grouped','reuse'}\r\n\u001b[?2004l\r"]
[481.85327, "o", "\u001b[?2004h> extras=[]\r\n\u001b[?2004l\r"]
[481.853359, "o", "\u001b[?2004h> for r in raw['raw']:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[481.853441, "o", "    e=set(r)-req\r\n\u001b[?2004l\r\u001b[?2004h"]
[481.853453, "o", "> "]
[481.853629, "o", "    if e: extras.append((r.get('case'),sorted(e)))\r\n\u001b[?2004l\r"]
[481.85369, "o", "\u001b[?2004h"]
[481.853707, "o", "> "]
[481.853779, "o", "print('raw extras', extras)\r\n\u001b[?2004l\r"]
[481.853861, "o", "\u001b[?2004h"]
[481.853882, "o", "> "]
[481.854002, "o", "rawm={r['case']:r for r in raw['raw']}\r\n\u001b[?2004l\r\u001b[?2004h"]
[481.854023, "o", "> "]
[481.854226, "o", "repm={r['case']:r for r in rep['rows']}\r\n\u001b[?2004l\r\u001b[?2004h"]
[481.854307, "o", "> "]
[481.85457, "o", "fields=['produced','slot_trace','order_used','packed','grouped','reuse']\r\n\u001b[?2004l\r"]
[481.85464, "o", "\u001b[?2004h> bad=[]\r\n\u001b[?2004l\r"]
[481.8547, "o", "\u001b[?2004h> "]
[481.854793, "o", "for k,v in rawm.items():\r\n\u001b[?2004l\r"]
[481.854871, "o", "\u001b[?2004h> "]
[481.854892, "o", "    rv=repm.get(k)\r\n\u001b[?2004l\r"]
[481.854948, "o", "\u001b[?2004h> "]
[481.854999, "o", "    if not rv:\r\n\u001b[?2004l\r"]
[481.855037, "o", "\u001b[?2004h> "]
[481.855208, "o", "        bad.append((k,'missing_report',None,None))\r\n\u001b[?2004l\r"]
[481.855288, "o", "\u001b[?2004h> "]
[481.855375, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[481.855424, "o", "> "]
[481.855464, "o", "    for f in fields:\r\n\u001b[?2004l\r"]
[481.8555, "o", "\u001b[?2004h"]
[481.855517, "o", "> "]
[481.855757, "o", "        if rv[f]!=v[f]:"]
[481.855836, "o", "\r\n"]
[481.855941, "o", "\u001b[?2004l\r"]
[481.855965, "o", "\u001b[?2004h> "]
[481.856503, "o", "            bad.append((k,f,v[f],rv[f]))\r\n\u001b[?2004l\r\u001b[?2004h> for k in repm:\r\n\u001b[?2004l\r\u001b[?2004h>     if k not in rawm:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[481.856587, "o", "        bad.append((k,'extra_report',None,None))"]
[481.856632, "o", "\r\n\u001b[?2004l\r"]
[481.85665, "o", "\u001b[?2004h> "]
[481.85676, "o", "print('row mismatches', bad)\r\n"]
[481.856779, "o", "\u001b[?2004l\r"]
[481.856875, "o", "\u001b[?2004h"]
[481.85699, "o", "> "]
[481.857072, "o", "print('summary', rep['summary'])\r\n\u001b[?2004l\r"]
[481.857147, "o", "\u001b[?2004h"]
[481.857236, "o", "> "]
