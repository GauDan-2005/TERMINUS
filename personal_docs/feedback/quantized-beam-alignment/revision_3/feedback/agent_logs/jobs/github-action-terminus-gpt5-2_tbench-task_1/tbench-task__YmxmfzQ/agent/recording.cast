[334.143112, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))\nrep=json.load(open('/app/output/report.json'))\nreq={'case','produced','slot_trace','order_used','packed','grouped','reuse'}\nextras=[]\nfor r in raw['raw']:\n    e=set(r)-req\n    if e: extras.append((r.get('case'),sorted(e)))\nprint('raw extras', extras)\n# compare report vs raw on six fields by case name\nrawm={r['case']:r for r in raw['raw']}\nrepm={r['case']:r for r in rep['rows']}\nmiss=set(rawm)-set(repm)\nextra=set(repm)-set(rawm)\nprint('missing', miss, 'extra', extra)\nfields=['produced','slot_trace','order_used','packed','grouped','reuse']\nbad=[]\nfor k,v in rawm.items():\n    rv=repm.get(k)\n    if not rv: continue\n    for f in fields:\n        if rv[f]!=v[f]:\n            bad.append((k,f,v[f],rv[f]))\nprint('mismatches', bad)\nprint('summary', rep['summary'])\nPY\n"]
