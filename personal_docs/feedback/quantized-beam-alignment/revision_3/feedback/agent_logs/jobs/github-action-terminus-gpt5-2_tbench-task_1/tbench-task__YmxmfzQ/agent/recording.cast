[242.694926, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))\nrep=json.load(open('/app/output/report.json'))\nprint('raw keys', raw.keys())\nprint('report keys', rep.keys())\n# ensure raw rows have only required keys\nreq={'case','produced','slot_trace','order_used','packed','grouped','reuse'}\nextra=[]\nfor r in raw['raw']:\n    extra_keys=set(r)-req\n    if extra_keys:\n        extra.append((r['case'],sorted(extra_keys)))\nprint('raw extras', extra)\nprint('counts', len(raw['raw']), len(rep['rows']), 'summary', rep['summary'])\nPY\n"]
