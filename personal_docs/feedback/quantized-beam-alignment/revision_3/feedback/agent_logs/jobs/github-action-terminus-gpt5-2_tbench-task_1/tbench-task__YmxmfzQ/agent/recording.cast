[283.747397, "o", "\r\n\u001b[?2004l\r"]
[283.749855, "o", "    40\tfn render_nums(a: &[i32]) -> String {\r\n    41\t    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\")\r\n    42\t}\r\n    43\t\r\n    44\tfn render_usize(a: &[usize]) -> String {\r\n    45\t    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\")\r\n"]
[283.749886, "o", "    46\t}\r\n    47\t\r\n    48\tfn run_one(c: &Case) -> String {\r\n    49\t    let meta = a0::A0::new();\r\n    50\t    let mut h = b1::B0::new(c.rows.len());\r\n    51\t    let mut local = c2::C0::new(c.rows.len().max(1));\r\n    52\t    let moved = b1::bx(&mut h, &c.seq);\r\n"]
[283.749918, "o", "    53\t    let base_rows: Vec<Vec<i32>> = c.rows.iter().enumerate().map(|(i, row)| {\r\n    54\t        if c.packed { a0::ax(&meta, row, i) } else { row.clone() }\r\n    55\t    }).collect();\r\n    56\t    let chosen = d3::dx(&(0..base_rows.len()).map(|i| i as i32).collect::<Vec<_>>(), &c.seq);\r\n    57\t    let mut vals = Vec::new();\r\n    58\t    let mut trace = Vec::new();\r\n"]
[283.74994, "o", "    59\t    for (pos, src) in c.seq.iter().enumerate() {\r\n    60\t        let handle = moved[pos];\r\n    61\t        let acc = c2::cx(&mut local, handle, &base_rows[*src]);\r\n"]
[283.749958, "o", "    62\t        vals.push(token(acc, handle, c.packed, c.group, c.reuse));\r\n    63\t        trace.push(handle);\r\n    64\t    }\r\n"]
[283.749995, "o", "    65\t    let mut sink = e4::E0::new();\r\n    66\t    e4::ex(&mut sink, c.name, &vals, &trace);\r\n    67\t    let _display = f5::view(&vals);\r\n    68\t    let _shape = g6::describe(&trace);\r\n"]
[283.750035, "o", "    69\t    format!(\"{{\\\"case\\\":\\\"{}\\\",\\\"produced\\\":[{}],\\\"slot_trace\\\":[{}],\\\"order_used\\\":[{}],\\\"packed\\\":{},\\\"grouped\\\":{},\\\"reuse\\\":{},\\\"selected\\\":[{}]}}\",\r\n    70\t        c.name, render_nums(&vals), render_usize(&trace), render_usize(&c.seq), c.packed, c.group, c.reuse, render_nums(&chosen))\r\n    71\t}\r\n    72\t\r\n    73\tfn main() {\r\n    74\t    let args: Vec<String> = env::args().collect();\r\n    75\t    let out = args.get(1).cloned().unwrap_or_else(|| \"/app/output/raw.json\".to_string());\r\n    76\t    let rows = cases().iter().map(run_one).collect::<Vec<_>>().join(\",\");\r\n    77\t    let body = format!(\"{{\\\"raw\\\":[{}]}}\\n\", rows);\r\n"]
[283.750154, "o", "    78\t    if let Some(parent) = std::path::Path::new(&out).parent() {\r\n    79\t        fs::create_dir_all(parent).unwrap();\r\n    80\t    }\r\n    81\t    fs::write(out, body).unwrap();\r\n    82\t}\r\n"]
