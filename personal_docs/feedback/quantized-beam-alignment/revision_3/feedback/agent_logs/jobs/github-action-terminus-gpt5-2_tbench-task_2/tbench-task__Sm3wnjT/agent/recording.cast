[539.523565, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nneed=['produced','slot_trace','order_used','packed','grouped','reuse']\nraw_by={r['case']:r for r in raw}\nrep_by={r['case']:r for r in rep['rows']}\nmm=[]\nfor k in sorted(raw_by):\n  if k not in rep_by:\n    mm.append((k,'missing'))\n    continue\n  for f in need:\n    if raw_by[k].get(f)!=rep_by[k].get(f):\n      mm.append((k,f,raw_by[k].get(f),rep_by[k].get(f)))\nextra=sorted(set(rep_by)-set(raw_by))\nprint('mismatches', mm)\nprint('extra', extra)\nprint('summary', rep['summary'])\nPY\n"]
