[454.003297, "o", "/app/internal/collate/table.go\r\n"]
[454.004128, "o", "package collate\r\n\r\nimport \"strings\"\r\n\r\nfunc Mix(a string) string {\r\n    return strings.TrimSpace(a)\r\n}\r\n\r\nfunc Keep(a []string) []string {\r\n    out := append([]string{}, a...)\r\n    return out\r\n}\r\n"]
[454.004453, "o", "\u001b[?2004h"]
[454.004549, "o", "root@6d5b7e92f9ee:/app# "]
[476.996042, "i", "cat > /app/cmd/align/main.go <<'GO'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"sort\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc eqEntry(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\tif len(a.Produced) != len(b.Produced) || len(a.Trace) != len(b.Trace) || len(a.OrderUsed) != len(b.OrderUsed) {\n\t\treturn false\n\t}\n\tfor i := range a.Produced {\n\t\tif a.Produced[i] != b.Produced[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\tfor i := range a.Trace {\n\t\tif a.Trace[i] != b.Trace[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\tfor i := range a.OrderUsed {\n\t\tif a.Or"]
[476.996102, "o", "cat > /app/cmd/align/main.go <<'GO'"]
[476.996124, "i", "derUsed[i] != b.OrderUsed[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\trawPath := os.Args[1]\n\tfinalPath := os.Args[2]\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Preserve one row per case; do not merge rows from different requests.\n\trows := make([]entry, 0, len(raw.Raw))\n\tseen := map[string]bool{}\n\tfor _, r := range raw.Raw {\n\t\tif seen[r.Case] {\n\t\t\t// Duplicate case name in raw: keep both rows in output by disambiguating via no-op?\n\t\t\t// Requirement expects one row per built-in case; duplicates indicate a runner issue.\n\t\t\t// We'll still append to avoid dropping data, but agree will be forced false.\n\t\t}\n\t\tseen[r.Case] = true\n\t\trows = append(rows, r)\n\t}\n\t// Deterministic output ordering.\n\tsort.SliceStable(rows, func(i, j int) bool { return rows[i].Case < rows[j].Case })\n\n\t// Load prior report (if any) for required comparison se"]
[476.996138, "i", "mantics.\n\tvar prior *finalDoc\n\tif b, err := os.ReadFile(finalPath); err == nil {\n\t\tvar d finalDoc\n\t\tif err := json.Unmarshal(b, &d); err == nil {\n\t\t\tprior = &d\n\t\t}\n\t}\n\n\tagree := true\n\n\t// raw vs generated report comparison (must match on required fields).\n\tgenBy := map[string]entry{}\n\tfor _, r := range rows {\n\t\tgenBy[r.Case] = r\n\t}\n\trawBy := map[string]entry{}\n\tfor _, r := range raw.Raw {\n\t\trawBy[r.Case] = r\n\t\tif g, ok := genBy[r.Case]; !ok || !eqEntry(r, g) {\n\t\t\tagree = false\n\t\t}\n\t}\n\tif len(genBy) != len(rawBy) {\n\t\tagree = false\n\t}\n\n\t// raw vs prior report comparison (when replacing existing report.json).\n\tif prior != nil {\n\t\tpriorBy := map[string]entry{}\n\t\tfor _, r := range prior.Rows {\n\t\t\tpriorBy[r.Case] = r\n\t\t}\n\t\tfor name, rr := range rawBy {\n\t\t\tpr, ok := priorBy[name]\n\t\t\tif !ok || !eqEntry(rr, pr) {\n\t\t\t\tagree = false\n\t\t\t}\n\t\t}\n\t\tif len(priorBy) != len(rawBy) {\n\t\t\tagree = false\n\t\t}\n\t}\n\n\tdoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(raw.Raw), \"agree\": agree}}\n\tout, err := json.MarshalInde"]
[476.996309, "i", "nt(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGO\n"]
