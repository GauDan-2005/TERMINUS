[451.770956, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nrows=rep['rows']\nneed=['produced','slot_trace','order_used','packed','grouped','reuse']\nraw_by={r['case']:r for r in raw}\nrep_by={r['case']:r for r in rows}\nmissing=set(raw_by)-set(rep_by)\nextra=set(rep_by)-set(raw_by)\nprint('missing in report', sorted(missing))\nprint('extra in report', sorted(extra))\nmm=[]\nfor k in sorted(set(raw_by)&set(rep_by)):\n  for f in need:\n    if raw_by[k].get(f)!=rep_by[k].get(f):\n      mm.append((k,f,raw_by[k].get(f),rep_by[k].get(f)))\nif mm:\n  print('MISMATCHES:')\n  for m in mm: print(m)\nelse:\n  print('all rows match on required fields')\nprint('summary.agree', rep.get('summary',{}).get('agree'))\nPY\n"]
