[265.176208, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nneed=['produced','slot_trace','order_used','packed','grouped','reuse']\nraw_by={r['case']:{k:r.get(k) for k in need} for r in raw}\nrep_by={r['case']:{k:r.get(k) for k in need} for r in rep['rows']}\nmis=[]\nfor c in sorted(set(raw_by)|set(rep_by)):\n    if c not in raw_by or c not in rep_by:\n        mis.append((c,'missing'))\n        continue\n    for k in need:\n        if raw_by[c][k]!=rep_by[c][k]:\n            mis.append((c,k,raw_by[c][k],rep_by[c][k]))\n            break\nprint('mismatches',mis)\nprint('summary',rep['summary'])\nPY\n"]
