[204.72034, "i", "python3 - <<'PY'\nimport json\nfrom collections import OrderedDict\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nrows=rep['rows']\nneed=['produced','slot_trace','order_used','packed','grouped','reuse']\nraw_by={r['case']:{k:r.get(k) for k in need} for r in raw}\nrep_by={r['case']:{k:r.get(k) for k in need} for r in rows}\nall_cases=sorted(set(raw_by)|set(rep_by))\nmis=[]\nfor c in all_cases:\n    if c not in raw_by or c not in rep_by:\n        mis.append((c,'missing'))\n        continue\n    for k in need:\n        if raw_by[c].get(k)!=rep_by[c].get(k):\n            mis.append((c,k,raw_by[c].get(k),rep_by[c].get(k)))\n            break\nprint('cases',all_cases)\nprint('mismatches',len(mis))\nfor m in mis[:50]:\n    print(m)\nprint('report.summary',rep.get('summary'))\nPY\n"]
