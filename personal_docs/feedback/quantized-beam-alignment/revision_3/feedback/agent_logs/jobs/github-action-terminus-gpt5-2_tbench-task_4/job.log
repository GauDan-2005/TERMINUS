Sending keys: ['cat > /app/cmd/align/main.go <<\'EOF\'\npackage main\n\nimport (\n\t"bytes"\n\t"encoding/json"\n\t"errors"\n\t"os"\n\t"reflect"\n\t"sort"\n\t"strings"\n)\n\ntype entry struct {\n\tCase      string `json:"case"`\n\tProduced  []int  `json:"produced"`\n\tTrace     []int  `json:"slot_trace"`\n\tOrderUsed []int  `json:"order_used"`\n\tPacked    bool   `json:"packed"`\n\tGrouped   bool   `json:"grouped"`\n\tReuse     bool   `json:"reuse"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:"raw"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:"rows"`\n\tSummary map[string]any `json:"summary"`\n}\n\nfunc readBuiltins(path string) ([]string, error) {\n\tb, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tlines := strings.Split(string(b), "\\n")\n\tout := make([]string, 0, len(lines))\n\tfor _, ln := range lines {\n\t\tln = strings.TrimSpace(ln)\n\t\tif ln == "" {\n\t\t\tcontinue\n\t\t}\n\t\tout = append(out, ln)\n\t}\n\treturn out, nil\n}\n\nfunc norm(e entry) entry {\n\t// normalize nil vs empty slices for stable comparisons\n\tif e.Produced == nil {\n\t\te.Produced = []int{}\n\t}\n\tif e.Trace == nil {\n\t\te.Trace = []int{}\n\t}\n\tif e.OrderUsed == nil {\n\t\te.OrderUsed = []int{}\n\t}\n\treturn e\n}\n\nfunc sameSix(a, b entry) bool {\n\ta = norm(a)\n\tb = norm(b)\n\treturn reflect.DeepEqual(a.Produced, b.Produced) &&\n\t\treflect.DeepEqual(a.Trace, b.Trace) &&\n\t\treflect.DeepEqual(a.OrderUsed, b.OrderUsed) &&\n\t\ta.Packed == b.Packed &&\n\t\ta.Grouped == b.Grouped &&\n\t\ta.Reuse == b.Reuse\n}\n\nfunc mapByCase(rows []entry) (map[string]entry, map[string]int) {\n\tm := map[string]entry{}\n\tcnt := map[string]int{}\n\tfor _, r := range rows {\n\t\tcnt[r.Case]++\n\t\tm[r.Case] = r // last wins for determinism\n\t}\n\treturn m, cnt\n}\n\nfunc loadReport(path string) (*finalDoc, error) {\n\tb, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tvar d finalDoc\n\tdec := json.NewDecoder(bytes.NewReader(b))\n\tdec.DisallowUnknownFields()\n\tif err := dec.Decode(&d); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &d, nil\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic("usage: align raw final")\n\t}\n\trawPath := os.Args[1]\n\tfinalPath := os.Args[2]\n\n\tbuiltins, err := readBuiltins("/app/config/sets.txt")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\trawBy, rawCnt := mapByCase(raw.Raw)\n\n\tagree := true\n\n\t// Duplicates in raw imply multiple requests collapsed; we still emit one row per case\n\t// (the last one deterministically) but cannot claim agreement.\n\tfor _, c := range builtins {\n\t\tif rawCnt[c] != 1 {\n\t\t\tagree = false\n\t\t}\n\t}\n\tfor c, n := range rawCnt {\n\t\tif n != 1 {\n\t\t\tagree = false\n\t\t}\n\t\t_ = c\n\t}\n\n\t// Ensure all built-in cases are present.\n\tfor _, c := range builtins {\n\t\tif _, ok := rawBy[c]; !ok {\n\t\t\tagree = false\n\t\t}\n\t}\n\n\t// Build rows in deterministic order: builtins order (then any extras sorted).\n\trows := make([]entry, 0, len(rawBy))\n\tseen := map[string]bool{}\n\tfor _, c := range builtins {\n\t\tif r, ok := rawBy[c]; ok {\n\t\t\trows = append(rows, r)\n\t\t\tseen[c] = true\n\t\t}\n\t}\n\textra := make([]string, 0)\n\tfor c := range rawBy {\n\t\tif !seen[c] {\n\t\t\textra = append(extra, c)\n\t\t}\n\t}\n\tsort.Strings(extra)\n\tfor _, c := range extra {\n\t\tagree = false // extras not in built-in list\n\t\trows = append(rows, rawBy[c])\n\t}\n\n\t// Verify new rows match raw on the six required fields by case.\n\tfor _, r := range rows {\n\t\tif rr, ok := rawBy[r.Case]; !ok || !sameSix(r, rr) {\n\t\t\tagree = false\n\t\t}\n\t}\n\n\t// Compare against prior report.json if it exists.\n\tif prior, err := loadReport(finalPath); err == nil {\n\t\tpriorBy, priorCnt := mapByCase(prior.Rows)\n\t\t// Missing/extra/duplicate rows in prior means disagreement.\n\t\tfor _, c := range builtins {\n\t\t\tif priorCnt[c] != 1 {\n\t\t\t\tagree = false\n\t\t\t}\n\t\t\tpr, okP := priorBy[c]\n\t\t\trr, okR := rawBy[c]\n\t\t\tif !okP || !okR || !sameSix(pr, rr) {\n\t\t\t\tagree = false\n\t\t\t}\n\t\t}\n\t\tfor c, n := range priorCnt {\n\t\t\tif n != 1 {\n\t\t\t\tagree = false\n\t\t\t}\n\t\t\tif !contains(builtins, c) {\n\t\t\t\tagree = false\n\t\t\t}\n\t\t}\n\t} else if !errors.Is(err, os.ErrNotExist) {\n\t\t// unreadable prior report: cannot claim agreement\n\t\tagree = false\n\t}\n\n\tdoc := finalDoc{\n\t\tRows: rows,\n\t\tSummary: map[string]any{\n\t\t\t"total": len(builtins),\n\t\t\t"agree": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, "", "  ")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, \'\\n\'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\n\nfunc contains(a []string, s string) bool {\n\tfor _, x := range a {\n\t\tif x == s {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
