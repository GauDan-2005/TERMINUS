[315.34512, "o", "    for (pos, src) in c.seq.iter().enumerate() {\r\n\u001b[?2004l\r"]
[315.345165, "o", "\u001b[?2004h"]
[315.34521, "o", "> "]
[315.345299, "o", "        let handle = moved[pos];\r\n\u001b[?2004l\r"]
[315.345361, "o", "\u001b[?2004h> "]
[315.34555, "o", "        let acc = c2::cx(&mut local, handle, &base_rows[*src]);\r\n\u001b[?2004l\r"]
[315.345594, "o", "\u001b[?2004h"]
[315.345639, "o", "> "]
[315.345832, "o", "        vals.push(token(acc, handle, c.packed, c.group, c.reuse));\r\n\u001b[?2004l\r"]
[315.345917, "o", "\u001b[?2004h> "]
[315.345972, "o", "        trace.push(handle);\r\n\u001b[?2004l\r"]
[315.346058, "o", "\u001b[?2004h> "]
[315.346103, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[315.346215, "o", "    let mut sink = e4::E0::new();\r\n\u001b[?2004l\r"]
[315.346298, "o", "\u001b[?2004h> "]
[315.346405, "o", "    e4::ex(&mut sink, c.name, &vals, &trace);\r\n\u001b[?2004l\r"]
[315.346466, "o", "\u001b[?2004h"]
[315.346488, "o", "> "]
[315.346597, "o", "    let _display = f5::view(&vals);\r\n\u001b[?2004l\r"]
[315.346636, "o", "\u001b[?2004h"]
[315.346676, "o", "> "]
[315.346807, "o", "    let _shape = g6::describe(&trace);\r\n\u001b[?2004l\r"]
[315.346892, "o", "\u001b[?2004h> "]
[315.347302, "o", "    format!(\"{{\\\"case\\\":\\\"{}\\\",\\\"produced\\\":[{}],\\\"slot_trace\\\":[{}],\\\"order_used\\\":[{}],\\\"packed\\\":{},\\\"grouped\\\":{},\\\"reuse\\\":{}}}\",\r\n\u001b[?2004l\r"]
[315.347338, "o", "\u001b[?2004h"]
[315.34741, "o", "> "]
[315.347677, "o", "        c.name, render_nums(&vals), render_usize(&trace), render_usize(&c.seq), c.packed, c.group, c.reuse)\r\n\u001b[?2004l\r"]
[315.347702, "o", "\u001b[?2004h"]
[315.347714, "o", "> "]
[315.347726, "o", "}\r\n\u001b[?2004l\r"]
[315.347828, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[315.34788, "o", "fn main() {\r\n\u001b[?2004l\r"]
[315.347899, "o", "\u001b[?2004h"]
[315.347914, "o", "> "]
[315.348088, "o", "    let args: Vec<String> = env::args().collect();\r\n\u001b[?2004l\r"]
[315.348158, "o", "\u001b[?2004h> "]
[315.348422, "o", "    let out = args.get(1).cloned().unwrap_or_else(|| \"/app/output/raw.json\".to_string());\r\n\u001b[?2004l\r"]
[315.348489, "o", "\u001b[?2004h"]
[315.348568, "o", "> "]
[315.348719, "o", "    let rows = cases().iter().map(run_one).collect::<Vec<_>>().join(\",\");\r\n\u001b[?2004l\r"]
[315.348751, "o", "\u001b[?2004h> "]
[315.34892, "o", "    let body = format!(\"{{\\\"raw\\\":[{}]}}\\n\", rows);\r\n\u001b[?2004l\r"]
[315.348986, "o", "\u001b[?2004h> "]
[315.349178, "o", "    if let Some(parent) = std::path::Path::new(&out).parent() {\r\n\u001b[?2004l\r"]
[315.349205, "o", "\u001b[?2004h> "]
[315.349361, "o", "        fs::create_dir_all(parent).unwrap();\r\n\u001b[?2004l\r"]
[315.349462, "o", "\u001b[?2004h> "]
[315.349535, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[315.349613, "o", "    fs::write(out, body).unwrap();\r\n\u001b[?2004l\r"]
[315.349681, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[315.349755, "o", "\u001b[?2004h> EOF\r\n"]
[315.349825, "o", "\u001b[?2004l\r"]
[315.352314, "o", "\u001b[?2004hroot@6709ecd2162e:/app# "]
[315.839565, "i", "cat > /app/cmd/align/main.go << 'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc intsEqual(a, b []int) bool {\n\tif len(a) != len(b) {\n\t\treturn false\n\t}\n\tfor i := range a {\n\t\tif a[i] != b[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc entriesMatch(a, b entry) bool {\n\tif !intsEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !intsEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !intsEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}"]
[315.839801, "i", "\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\n\t// Read raw.json\n\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Read existing report.json if present\n\tvar oldReport *finalDoc\n\tif obuf, err := os.ReadFile(os.Args[2]); err == nil {\n\t\tvar od finalDoc\n\t\tif err := json.Unmarshal(obuf, &od); err == nil {\n\t\t\toldReport = &od\n\t\t}\n\t}\n\n\t// Build new report rows - same as raw rows in same order\n\tnewRows := make([]entry, len(raw.Raw))\n\tcopy(newRows, raw.Raw)\n\n\t// Build index of raw by case name\n\trawByCase := map[string]entry{}\n\tfor _, r := range raw.Raw {\n\t\trawByCase[r.Case] = r\n\t}\n\n\t// Check agreement: every report row must match its raw counterpart\n\tagree := true\n\n\t// Check new rows vs raw (should match since we copied, but verify structure)\n\tfor _, row := range newRows {\n\t\trawRow, ok := rawByCase[row.Case]\n\t\tif !ok {\n\t\t\tagree = false\n\t\t\tbreak\n\t\t}\n\t\tif !entriesMatch(row, rawRow) {\n"]
[315.83995, "i", "\t\t\tagree = false\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// If old report existed, check old report rows against incoming raw\n\tif oldReport != nil && agree {\n\t\tfor _, oldRow := range oldReport.Rows {\n\t\t\trawRow, ok := rawByCase[oldRow.Case]\n\t\t\tif !ok {\n\t\t\t\tagree = false\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tif !entriesMatch(oldRow, rawRow) {\n\t\t\t\tagree = false\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\t// Also check that old report had same number of rows\n\t\tif len(oldReport.Rows) != len(raw.Raw) {\n\t\t\tagree = false\n\t\t}\n\t}\n\n\tdoc := finalDoc{\n\t\tRows: newRows,\n\t\tSummary: map[string]any{\n\t\t\t\"total\": len(newRows),\n\t\t\t\"agree\": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
