s {\n\t\t\t\t\texistingByCase[row.Case] = row\n\t\t\t\t}\n\t\t\t\tfor _, rawRow := range raw.Raw {\n\t\t\t\t\texRow, ok := existingByCase[rawRow.Case]\n\t\t\t\t\tif !ok || !entriesMatch(exRow, rawRow) {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdoc := finalDoc{\n\t\tRows: reportRows,\n\t\tSummary: map[string]any{"total": len(reportRows), "agree": agree},\n\t}\n\tout, err := json.MarshalIndent(doc, "", "  ")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, \'\\n\'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
