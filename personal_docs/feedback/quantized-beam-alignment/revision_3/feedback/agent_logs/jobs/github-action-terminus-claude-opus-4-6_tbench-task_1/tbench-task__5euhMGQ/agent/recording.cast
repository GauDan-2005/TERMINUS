[324.991564, "i", "cat /app/cmd/align/main.go\n"]
[324.992319, "o", "cat /app/cmd/align/main.go\r\n\u001b[?2004l\r"]
[324.993085, "o", "package main\r\n\r\nimport (\r\n\"encoding/json\"\r\n\"os\"\r\n\"reflect\"\r\n)\r\n\r\ntype entry struct {\r\nCase      string `json:\"case\"`\r\nProduced  []int  `json:\"produced\"`\r\nTrace     []int  `json:\"slot_trace\"`\r\nOrderUsed []int  `json:\"order_used\"`\r\nPacked    bool   `json:\"packed\"`\r\nGrouped   bool   `json:\"grouped\"`\r\nReuse     bool   `json:\"reuse\"`\r\n}\r\n\r\ntype rawDoc struct {\r\nRaw []entry `json:\"raw\"`\r\n}\r\n\r\ntype finalDoc struct {\r\nRows    []entry        `json:\"rows\"`\r\nSummary map[string]any `json:\"summary\"`\r\n}\r\n\r\nfunc entriesMatch(a, b entry) bool {\r\nif a.Case != b.Case {\r\nreturn false\r\n}\r\n"]
[324.99311, "o", "if !reflect.DeepEqual(a.Produced, b.Produced) {\r\nreturn false\r\n}\r\nif !reflect.DeepEqual(a.Trace, b.Trace) {\r\nreturn false\r\n}\r\nif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\r\nreturn false\r\n}\r\nif a.Packed != b.Packed {\r\nreturn false\r\n}\r\nif a.Grouped != b.Grouped {\r\nreturn false\r\n}\r\nif a.Reuse != b.Reuse {\r\nreturn false\r\n}\r\nreturn true\r\n}\r\n\r\nfunc main() {\r\nif len(os.Args) != 3 {\r\npanic(\"usage: align raw final\")\r\n}\r\nbuf, err := os.ReadFile(os.Args[1])\r\nif err != nil {\r\n"]
[324.993121, "o", "panic(err)\r\n}\r\nvar raw rawDoc\r\nif err := json.Unmarshal(buf, &raw); err != nil {\r\npanic(err)\r\n}\r\n\r\n// The report rows are the same as raw rows (same order, same fields)\r\nreportRows := make([]entry, len(raw.Raw))\r\ncopy(reportRows, raw.Raw)\r\n\r\n// Check if there's an existing report.json to compare against\r\nagree := true\r\nexistingBuf, err := os.ReadFile(os.Args[2])\r\nif err == nil {\r\nvar existing finalDoc\r\nif err := json.Unmarshal(existingBuf, &existing); err == nil {\r\n// Compare existing report rows against incoming raw rows\r\nif len(existing.Rows) != len(raw.Raw) {\r\nagree = false\r\n} else {\r\n// Build map of existing rows by case name\r\nexistingByCase := map[string]entry{}\r\nfor _, row := range existing.Rows {\r\nexistingByCase[row.Case] = row\r\n}\r\nfor _, rawRow := range raw.Raw {\r\nexRow, ok := existingByCase[rawRow.Case]\r\nif !ok || !entriesMatch(exRow, rawRow) {\r\nagree = false\r\nbreak\r\n}\r\n}\r\n}\r\n}\r\n}\r\n\r\ndoc := finalDoc{\r\nRows: reportRows,\r\nSummary: map[string]any{\"total\": len(reportRows), \"agree\": agree},\r\n}\r\nout, err :"]
[324.993205, "o", "= json.MarshalIndent(doc, \"\", \"  \")\r\nif err != nil {\r\npanic(err)\r\n}\r\nif err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\r\npanic(err)\r\n}\r\n}\r\n"]
