[162.967298, "o", "cat /app/src/a0/mod.rs\r\n\u001b[?2004l\r"]
[162.968241, "o", "pub struct A0 {\r\n    pub s: Vec<i32>,\r\n    pub z: Vec<i32>,\r\n}\r\n\r\nimpl A0 {\r\n    pub fn new() -> Self {\r\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\r\n    }\r\n}\r\n\r\npub fn ax(a: &A0, b: &[i32], c: usize) -> Vec<i32> {\r\n    let k = c % a.s.len();\r\n    b.iter().map(|v| v * a.s[k] + a.z[k]).collect()\r\n}\r\n\r\npub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\r\n    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()\r\n}\r\n"]
[162.968548, "o", "\u001b[?2004h"]
[162.96865, "o", "root@2bdda0d97a28:/app# "]
[163.091256, "i", "cat /app/src/b1/mod.rs\n"]
[163.091426, "o", "cat /app/src/b1/mod.rs\r\n\u001b[?2004l\r"]
[163.092507, "o", "pub struct B0 {\r\n    pub v: Vec<usize>,\r\n}\r\n\r\nimpl B0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: (0..n).collect() }\r\n    }\r\n}\r\n\r\npub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {\r\n    let out = b.to_vec();\r\n    if a.v.len() == b.len() {\r\n        a.v.sort();\r\n    }\r\n    out\r\n}\r\n"]
[163.092654, "o", "\u001b[?2004h"]
[163.092711, "o", "root@2bdda0d97a28:/app# "]
[163.206771, "i", "cat /app/src/c2/mod.rs\n"]
[163.206968, "o", "cat /app/src/c2/mod.rs"]
[163.207264, "o", "\r\n\u001b[?2004l\r"]
[163.209062, "o", "pub struct C0 {\r\n    pub v: Vec<i32>,\r\n}\r\n\r\nimpl C0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: vec![0; n] }\r\n    }\r\n}\r\n\r\npub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {\r\n    let value: i32 = c.iter().sum();\r\n    let k = b % a.v.len();\r\n    a.v[k] += value;\r\n    a.v[k]\r\n}\r\n"]
[163.209286, "o", "\u001b[?2004hroot@2bdda0d97a28:/app# "]
[163.322901, "i", "cat /app/src/d3/mod.rs\n"]
[163.323152, "o", "cat /app/src/d3/mod.rs\r\n\u001b[?2004l\r"]
[163.323812, "o", "pub fn dx(a: &[i32], b: &[usize]) -> Vec<i32> {\r\n    b.iter().map(|i| a[*i]).collect()\r\n}\r\n\r\npub fn tag(a: &str, b: usize) -> String {\r\n    format!(\"{}:{}\", a, b)\r\n}\r\n"]
[163.324009, "o", "\u001b[?2004hroot@2bdda0d97a28:/app# "]
