[179.233312, "o", "pub fn arrange(a: &[usize]) -> Vec<usize> {\r\n    let mut x = a.to_vec();\r\n    x.sort();\r\n    x\r\n}\r\n\r\npub fn describe(a: &[usize]) -> String {\r\n    arrange(a).iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\"-\")\r\n}\r\n"]
