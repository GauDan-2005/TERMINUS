[324.503783, "i", "cat > /app/cmd/align/main.go << 'GOEOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n\t\"sort\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc entriesMatch(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw fi"]
[324.504037, "i", "nal\")\n\t}\n\trawPath := os.Args[1]\n\tfinalPath := os.Args[2]\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Build report rows from raw (one per case, sorted by case name)\n\tbyCase := map[string]entry{}\n\tfor _, r := range raw.Raw {\n\t\tbyCase[r.Case] = r\n\t}\n\trows := make([]entry, 0, len(byCase))\n\tfor _, r := range byCase {\n\t\trows = append(rows, r)\n\t}\n\tsort.Slice(rows, func(i, j int) bool { return rows[i].Case < rows[j].Case })\n\n\t// Read existing report if present\n\tvar priorRows []entry\n\tif priorBuf, err := os.ReadFile(finalPath); err == nil {\n\t\tvar prior finalDoc\n\t\tif err := json.Unmarshal(priorBuf, &prior); err == nil {\n\t\t\tpriorRows = prior.Rows\n\t\t}\n\t}\n\n\t// Build index of raw rows by case name\n\trawByCase := map[string]entry{}\n\tfor _, r := range raw.Raw {\n\t\trawByCase[r.Case] = r\n\t}\n\n\t// Determine agree: every report row must match its raw counterpart\n\tagree := true\n\n\t// Check new rows against raw\n\tif len(rows)"]
[324.504073, "o", "cat > /app/cmd/align/main.go << 'GOEOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[324.505166, "i", " != len(raw.Raw) {\n\t\tagree = false\n\t} else {\n\t\tfor _, row := range rows {\n\t\t\trawEntry, ok := rawByCase[row.Case]\n\t\t\tif !ok || !entriesMatch(row, rawEntry) {\n\t\t\t\tagree = false\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\t// If prior report exists, check prior rows against raw\n\tif agree && priorRows != nil {\n\t\tif len(priorRows) != len(raw.Raw) {\n\t\t\tagree = false\n\t\t} else {\n\t\t\tpriorByCase := map[string]entry{}\n\t\t\tfor _, r := range priorRows {\n\t\t\t\tpriorByCase[r.Case] = r\n\t\t\t}\n\t\t\tfor _, rawEntry := range raw.Raw {\n\t\t\t\tpriorEntry, ok := priorByCase[rawEntry.Case]\n\t\t\t\tif !ok || !entriesMatch(priorEntry, rawEntry) {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdoc := finalDoc{\n\t\tRows:    rows,\n\t\tSummary: map[string]any{\"total\": len(rows), \"agree\": agree},\n\t}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGOEOF\n"]
