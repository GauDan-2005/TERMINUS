[179.108452, "o", "pub fn view(a: &[i32]) -> String {\r\n    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\"|\")\r\n}\r\n\r\npub fn lens(a: &[i32]) -> usize {\r\n    a.len()\r\n}\r\n"]
[179.108549, "o", "\u001b[?2004h"]
