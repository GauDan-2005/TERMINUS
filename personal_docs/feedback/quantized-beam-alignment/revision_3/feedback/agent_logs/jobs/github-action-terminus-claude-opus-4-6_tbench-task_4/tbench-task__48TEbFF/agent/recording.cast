[267.422884, "o", "cat /app/docs/architecture.md\r\n\u001b[?2004l\r"]
[267.42416, "o", "# Architecture notes\r\n\r\nThe Rust side keeps compact scenario data and emits raw rows with produced values and handle traces. The Go side performs light collation for the final operator document. The data files provide stable input cases for local runs.\r\n"]
[267.424894, "o", "\u001b[?2004hroot@e7a8cfbce7ce:/app# "]
[267.538685, "i", "cat /app/docs/operations.md\n"]
[267.540625, "o", "cat /app/docs/operations.md\r\n\u001b[?2004l\r"]
[267.541416, "o", "# Operations\r\n\r\nUse `/app/tools/run_local.sh` inside the container to refresh `/app/output/raw.json` and `/app/output/report.json`. The runner is self-contained and does not contact external services.\r\n"]
[267.541557, "o", "\u001b[?2004h"]
[267.541573, "o", "root@e7a8cfbce7ce:/app# "]
[324.39905, "i", "cat > /app/tools/run_local.sh << 'EOF'\n#!/bin/bash\nset -euo pipefail\nexport PATH=\"/usr/local/cargo/bin:$PATH\"\ncargo --version\nmkdir -p /app/output /app/bin\ncargo build --release --quiet --manifest-path /app/Cargo.toml\n/app/target/release/local-infer-sandbox /app/output/raw.json\ngo build -o /app/bin/align /app/cmd/align/main.go\n/app/bin/align /app/output/raw.json /app/output/report.json\nEOF\n"]
