[?2004lpub fn dx(a: &[i32], b: &[usize]) -> Vec<i32> {
    b.iter().map(|i| a[*i]).collect()
}

pub fn tag(a: &str, b: usize) -> String {
    format!("{}:{}", a, b)
}
[?2004hroot@28810f663357:/app# cat /app/src/e4/mod.rs
