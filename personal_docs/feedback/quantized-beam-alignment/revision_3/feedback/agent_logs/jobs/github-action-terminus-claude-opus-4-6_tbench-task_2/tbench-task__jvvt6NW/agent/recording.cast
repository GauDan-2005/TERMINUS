[21.338676, "o", "pub struct C0 {\r\n    pub v: Vec<i32>,\r\n}\r\n\r\nimpl C0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: vec![0; n] }\r\n    }\r\n}\r\n\r\npub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {\r\n    let value: i32 = c.iter().sum();\r\n    let k = b % a.v.len();\r\n    a.v[k] += value;\r\n    a.v[k]\r\n}\r\n\u001b[?2004hroot@28810f663357:/app# "]
