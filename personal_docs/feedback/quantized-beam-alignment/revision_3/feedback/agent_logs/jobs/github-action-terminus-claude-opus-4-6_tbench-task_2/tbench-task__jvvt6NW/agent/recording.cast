[321.166111, "i", "cat > /app/cmd/align/main.go << 'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc fieldsMatch(a, b entry) bool {\n\treturn a.Case == b.Case &&\n\t\treflect.DeepEqual(a.Produced, b.Produced) &&\n\t\treflect.DeepEqual(a.Trace, b.Trace) &&\n\t\treflect.DeepEqual(a.OrderUsed, b.OrderUsed) &&\n\t\ta.Packed == b.Packed &&\n\t\ta.Grouped == b.Grouped &&\n\t\ta.Reuse == b.Reuse\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err"]
[321.166298, "i", ")\n\t}\n\n\t// Build new report rows from raw (preserve order, copy 6 fields)\n\trows := make([]entry, len(raw.Raw))\n\tfor i, r := range raw.Raw {\n\t\trows[i] = entry{\n\t\t\tCase:      r.Case,\n\t\t\tProduced:  r.Produced,\n\t\t\tTrace:     r.Trace,\n\t\t\tOrderUsed: r.OrderUsed,\n\t\t\tPacked:    r.Packed,\n\t\t\tGrouped:   r.Grouped,\n\t\t\tReuse:     r.Reuse,\n\t\t}\n\t}\n\n\tagree := true\n\n\t// If existing report.json exists, compare its rows against incoming raw\n\tif oldBuf, err := os.ReadFile(os.Args[2]); err == nil {\n\t\tvar oldDoc finalDoc\n\t\tif err := json.Unmarshal(oldBuf, &oldDoc); err == nil {\n\t\t\t// Build map of old report rows by case name\n\t\t\toldMap := make(map[string]entry)\n\t\t\tfor _, r := range oldDoc.Rows {\n\t\t\t\toldMap[r.Case] = r\n\t\t\t}\n\t\t\tif len(oldDoc.Rows) != len(raw.Raw) {\n\t\t\t\tagree = false\n\t\t\t} else {\n\t\t\t\tfor _, r := range raw.Raw {\n\t\t\t\t\toldRow, ok := oldMap[r.Case]\n\t\t\t\t\tif !ok || !fieldsMatch(oldRow, entry{\n\t\t\t\t\t\tCase:      r.Case,\n\t\t\t\t\t\tProduced:  r.Produced,\n\t\t\t\t\t\tTrace:     r.Trace,\n\t\t\t\t\t\tOrderUsed: r.OrderUsed,\n\t\t\t\t\t\tPacked:    r.Packe"]
[321.166369, "o", "cat > /app/cmd/align/main.go << 'EOF'\r\n\u001b[?2004l\r"]
[321.16643, "i", "d,\n\t\t\t\t\t\tGrouped:   r.Grouped,\n\t\t\t\t\t\tReuse:     r.Reuse,\n\t\t\t\t\t}) {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t}\n\t// If no old report exists, agree stays true (new rows match raw by construction)\n\n\tdoc := finalDoc{\n\t\tRows:    rows,\n\t\tSummary: map[string]any{\"total\": len(rows), \"agree\": agree},\n\t}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
