  let _chosen = d3::dx(&(0..base_rows.len()).map(|i| i as i32).collect::<Vec<_>>(), &c.seq);\n    let mut vals = Vec::new();\n    let mut trace = Vec::new();\n    for (pos, src) in c.seq.iter().enumerate() {\n        let handle = moved[pos];\n        let acc = c2::cx(&mut local, handle, &base_rows[*src]);\n        vals.push(token(acc, handle, c.packed, c.group, c.reuse));\n        trace.push(handle);\n    }\n    let mut sink = e4::E0::new();\n    e4::ex(&mut sink, c.name, &vals, &trace);\n    let _display = f5::view(&vals);\n    let _shape = g6::describe(&trace);\n    format!("{{\\"case\\":\\"{}\\",\\"produced\\":[{}],\\"slot_trace\\":[{}],\\"order_used\\":[{}],\\"packed\\":{},\\"grouped\\":{},\\"reuse\\":{}}}",\n        c.name, render_nums(&vals), render_usize(&trace), render_usize(&c.seq), c.packed, c.group, c.reuse)\n}\n\nfn main() {\n    let args: Vec<String> = env::args().collect();\n    let out = args.get(1).cloned().unwrap_or_else(|| "/app/output/raw.json".to_string());\n    let rows = cases().iter().map(run_one).collect::<Vec<_>>().join(",");\n    let body = format!("{{\\"raw\\":[{}]}}\\n", rows);\n    if let Some(parent) = std::path::Path::new(&out).parent() {\n        fs::create_dir_all(parent).unwrap();\n    }\n    fs::write(out, body).unwrap();\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > /app/cmd/align/main.go << \'EOF\'\npackage main\n\nimport (\n\t"encoding/json"\n\t"os"\n\t"reflect"\n)\n\ntype entry struct {\n\tCase      string `json:"case"`\n\tProduced  []int  `json:"produced"`\n\tTrace     []int  `json:"slot_trace"`\n\tOrderUsed []int  `json:"order_used"`\n\tPacked    bool   `json:"packed"`\n\tGrouped   bool   `json:"grouped"`\n\tReuse     bool   `json:"reuse"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:"raw"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:"rows"`\n\tSummary map[string]any `json:"summary"`\n}\n\nfunc entriesMatch(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc computeAgree(rawRows []entry, priorRows []entry) bool {\n\t// Build maps by case name for both\n\trawMap := make(map[string]entry)\n\tfor _, r := range rawRows {\n\t\trawMap[r.Case] = r\n\t}\n\tpriorMap := make(map[string]entry)\n\tfor _, r := range priorRows {\n\t\tpriorMap[r.Case] = r\n\t}\n\t// Check all cases in raw exist in prior and match\n\tif len(rawMap) != len(priorMap) {\n\t\treturn false\n\t}\n\tfor name, rawEntry := range rawMap {\n\t\tpriorEntry, ok := priorMap[name]\n\t\tif !ok {\n\t\t\treturn false\n\t\t}\n\t\tif !entriesMatch(rawEntry, priorEntry) {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic("usage: align raw final")\n\t}\n\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// The report rows are exactly the raw rows (same order, same content)\n\treportRows := raw.Raw\n\n\t// Check if a prior report exists\n\tagree := true\n\tpriorBuf, err := os.ReadFile(os.Args[2])\n\tif err == nil {\n\t\t// Prior report exists - compare its rows against incoming raw\n\t\tvar prior finalDoc\n\t\tif err := json.Unmarshal(priorBuf, &prior); err == nil {\n\t\t\tagree = computeAgree(raw.Raw, prior.Rows)\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t}\n\t// If no prior report, new report rows == raw rows, so agree = true\n\n\tdoc := finalDoc{\n\t\tRows: reportRows,\n\t\tSummary: map[string]any{\n\t\t\t"total": len(reportRows),\n\t\t\t"agree": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, "", "  ")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, \'\\n\'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
