Sending keys: ['cat > /app/cmd/align/main.go <<\'GO\'\npackage main\n\nimport (\n\t"encoding/json"\n\t"errors"\n\t"fmt"\n\t"os"\n\t"sort"\n)\n\ntype entry struct {\n\tCase      string `json:"case"`\n\tProduced  []int  `json:"produced"`\n\tTrace     []int  `json:"slot_trace"`\n\tOrderUsed []int  `json:"order_used"`\n\tPacked    bool   `json:"packed"`\n\tGrouped   bool   `json:"grouped"`\n\tReuse     bool   `json:"reuse"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:"raw"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:"rows"`\n\tSummary map[string]any `json:"summary"`\n}\n\nfunc equalInts(a, b []int) bool {\n\tif len(a) != len(b) {\n\t\treturn false\n\t}\n\tfor i := range a {\n\t\tif a[i] != b[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc equalEntryOnSpecFields(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\treturn equalInts(a.Produced, b.Produced) &&\n\t\tequalInts(a.Trace, b.Trace) &&\n\t\tequalInts(a.OrderUsed, b.OrderUsed) &&\n\t\ta.Packed == b.Packed &&\n\t\ta.Grouped == b.Grouped &&\n\t\ta.Reuse == b.Reuse\n}\n\nfunc rowsToMap(rows []entry) (map[string]entry, error) {\n\tm := make(map[string]entry, len(rows))\n\tfor _, r := range rows {\n\t\tif r.Case == "" {\n\t\t\treturn nil, errors.New("empty case name")\n\t\t}\n\t\tif _, ok := m[r.Case]; ok {\n\t\t\treturn nil, fmt.Errorf("duplicate case in rows: %q", r.Case)\n\t\t}\n\t\tm[r.Case] = r\n\t}\n\treturn m, nil\n}\n\nfunc sortedByCase(rows []entry) []entry {\n\tout := append([]entry(nil), rows...)\n\tsort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\n\treturn out\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic("usage: align raw final")\n\t}\n\trawPath := os.Args[1]\n\tfinalPath := os.Args[2]\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// New rows are a stable per-case view of raw, with no folding/merging.\n\trowsNew := sortedByCase(raw.Raw)\n\n\trawMap, err := rowsToMap(raw.Raw)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tnewMap, err := rowsToMap(rowsNew)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Compare raw vs new rows.\n\tagree := true\n\tif len(rawMap) != len(newMap) {\n\t\tagree = false\n\t}\n\tfor c, rr := range rawMap {\n\t\tnr, ok := newMap[c]\n\t\tif !ok || !equalEntryOnSpecFields(rr, nr) {\n\t\t\tagree = false\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Also compare against prior report.json at finalPath, if it exists.\n\tif prevBuf, err := os.ReadFile(finalPath); err == nil {\n\t\tvar prev finalDoc\n\t\tif err := json.Unmarshal(prevBuf, &prev); err != nil {\n\t\t\tagree = false\n\t\t} else {\n\t\t\tprevMap, err := rowsToMap(prev.Rows)\n\t\t\tif err != nil {\n\t\t\t\tagree = false\n\t\t\t} else {\n\t\t\t\tif len(prevMap) != len(newMap) {\n\t\t\t\t\tagree = false\n\t\t\t\t} else {\n\t\t\t\t\tfor c, pr := range prevMap {\n\t\t\t\t\t\tnr, ok := newMap[c]\n\t\t\t\t\t\tif !ok || !equalEntryOnSpecFields(pr, nr) {\n\t\t\t\t\t\t\tagree = false\n\t\t\t\t\t\t\tbreak\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t} else if !errors.Is(err, os.ErrNotExist) {\n\t\t// Can\'t read prior report for reasons other than not-exist => not in agreement.\n\t\tagree = false\n\t}\n\n\tdoc := finalDoc{\n\t\tRows: rowsNew,\n\t\tSummary: map[string]any{\n\t\t\t"total": len(raw.Raw),\n\t\t\t"agree": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, "", "  ")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, \'\\n\'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGO\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
