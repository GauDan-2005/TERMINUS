[344.750644, "o", "package collate\r\n\r\nimport \"strings\"\r\n\r\nfunc Mix(a string) string {\r\n    return strings.TrimSpace(a)\r\n}\r\n\r\nfunc Keep(a []string) []string {\r\n    out := append([]string{}, a...)\r\n    return out\r\n"]
[344.750674, "o", "}\r\n"]
