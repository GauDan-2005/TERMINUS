[324.386043, "o", "raw row keys: ['case', 'grouped', 'order_used', 'packed', 'produced', 'reuse', 'selected', 'slot_trace']\r\nrep row keys: ['case', 'grouped', 'order_used', 'packed', 'produced', 'reuse', 'slot_trace']\r\n"]
