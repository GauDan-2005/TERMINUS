[203.151438, "i", "cat > /app/tools/run_local.sh <<'SH'\n#!/bin/bash\nset -euo pipefail\n\n# Ensure Rust toolchain is on PATH in this sandbox.\n# rustup is installed under /usr/local; cargo/rustc live under the toolchain bin.\nexport PATH=\"/usr/local/cargo/bin:$PATH\"\nif ! command -v cargo >/dev/null 2>&1; then\n  tc_bin=\"$(ls -d /usr/local/rustup/toolchains/*/bin 2>/dev/null | head -n1 || true)\"\n  if [ -n \"${tc_bin}\" ]; then\n    export PATH=\"${tc_bin}:$PATH\"\n  fi\nfi\n\ncargo --version\nmkdir -p /app/output /app/bin\ncargo build --release --quiet --manifest-path /app/Cargo.toml\n/app/target/release/local-infer-sandbox /app/output/raw.json\n\ngo build -o /app/bin/align /app/cmd/align/main.go\n/app/bin/align /app/output/raw.json /app/output/report.json\nSH\nchmod +x /app/tools/run_local.sh\n"]
