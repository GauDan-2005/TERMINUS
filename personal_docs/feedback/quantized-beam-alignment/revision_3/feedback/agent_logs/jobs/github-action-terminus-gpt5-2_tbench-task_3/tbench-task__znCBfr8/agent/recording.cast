[35.01548, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: tools/run_local.sh\n@@\n #!/bin/bash\n set -euo pipefail\n+\n+# Ensure Rust toolchain is available in non-interactive environments.\n+if ! command -v cargo >/dev/null 2>&1; then\n+  if [ -f \"$HOME/.cargo/env\" ]; then\n+    # shellcheck disable=SC1090\n+    source \"$HOME/.cargo/env\"\n+  fi\n+fi\n+\n+# Common fallback locations for cargo.\n+if ! command -v cargo >/dev/null 2>&1; then\n+  for d in /root/.cargo/bin /usr/local/cargo/bin /opt/rust/bin; do\n+    if [ -x \"$d/cargo\" ]; then\n+      export PATH=\"$d:$PATH\"\n+      break\n+    fi\n+  done\n+fi\n+\n cargo --version\n mkdir -p /app/output /app/bin\n cargo build --release --quiet --manifest-path /app/Cargo.toml\n /app/target/release/local-infer-sandbox /app/output/raw.json\n go build -o /app/bin/align /app/cmd/align/main.go\n /app/bin/align /app/output/raw.json /app/output/report.json\n*** End Patch\nPATCH\n"]
[35.016181, "o", "apply_patch<<'PATCH'"]
