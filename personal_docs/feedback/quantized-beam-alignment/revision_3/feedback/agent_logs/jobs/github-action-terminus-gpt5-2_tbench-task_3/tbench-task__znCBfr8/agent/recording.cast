[402.063428, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))\nrep=json.load(open('/app/output/report.json'))\nprint('summary',rep.get('summary'))\nrawm={r['case']:{k:r[k] for k in ['produced','slot_trace','order_used','packed','grouped','reuse']} for r in raw['raw']}\nrepm={r['case']:{k:r[k] for k in ['produced','slot_trace','order_used','packed','grouped','reuse']} for r in rep['rows']}\nprint('case_counts',len(rawm),len(repm))\nprint('case_set_match',set(rawm)==set(repm))\nbad=[]\nfor c in sorted(rawm):\n    if rawm[c]!=repm.get(c):\n        bad.append(c)\nprint('mismatches',bad)\nPY\n"]
