[292.168647, "i", "err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// new report rows derived from raw, one per case name.\n\trawMap := byCase(raw.Raw)\n\tnewRows := sortedRows(rawMap)\n\n\tagree := true\n\n\t// (1) New report rows must match incoming raw for each case on the required fields.\n\t// Since we derive from raw, this is structurally true; still enforce and also enforce no missing/extra.\n\tif len(newRows) != len(rawMap) {\n\t\tagree = false\n\t}\n\tfor c, r := range rawMap {\n\t\tif !sameFields(r, rawMap[c]) { // self-check; placeholder to keep logic obvious\n\t\t\tagree = false\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// (2) When replacing an existing report.json, compare prior rows vs new rows.\n\tpriorMap, priorExists, err := loadPrior(finalPath)\n\tif err != nil {\n\t\t// If prior exists but is unreadable, treat as disagreement.\n\t\tagree = false\n\t} else if priorExists {\n\t\t// Any mismatch across case-level entries or missing/extra cases => disagree.\n\t\tif len(priorMap) != len(rawMap) {\n\t\t\tagree = false\n\t\t}\n\t\tfor c, newRow := ra"]
[292.168913, "i", "nge rawMap {\n\t\t\toldRow, ok := priorMap[c]\n\t\t\tif !ok || !sameFields(oldRow, newRow) {\n\t\t\t\tagree = false\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif agree {\n\t\t\tfor c := range priorMap {\n\t\t\t\tif _, ok := rawMap[c]; !ok {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdoc := finalDoc{Rows: newRows, Summary: map[string]any{\"total\": len(newRows), \"agree\": agree}}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGO\n"]
