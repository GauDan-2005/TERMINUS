[363.435453, "i", "sed -n '1,220p' /app/cmd/align/main.go\n"]
[363.435763, "o", "sed -n '1,220p' /app/cmd/align/main.go"]
[363.435798, "o", "\r\n"]
[363.435837, "o", "\u001b[?2004l\r"]
[363.437221, "o", "package main\r\n\r\nimport (\r\n\t\"encoding/json\"\r\n\t\"errors\"\r\n"]
[363.43748, "o", "\t\"os\"\r\n\t\"sort\"\r\n)\r\n\r\ntype entry struct {\r\n\tCase      string `json:\"case\"`\r\n\tProduced  []int  `json:\"produced\"`\r\n\tTrace     []int  `json:\"slot_trace\"`\r\n\tOrderUsed []int  `json:\"order_used\"`\r\n\tPacked    bool   `json:\"packed\"`\r\n\tGrouped   bool   `json:\"grouped\"`\r\n\tReuse     bool   `json:\"reuse\"`\r\n}\r\n\r\ntype rawDoc struct {\r\n\tRaw []entry `json:\"raw\"`\r\n}\r\n\r\ntype finalDoc struct {\r\n\tRows    []entry        `json:\"rows\"`\r\n\tSummary map[string]any `json:\"summary\"`\r\n}\r\n\r\n// keep one row per case name (full string). If duplicates exist, last wins.\r\nfunc byCase(rows []entry) map[string]entry {\r\n\tm := make(map[string]entry, len(rows))\r\n\tfor _, r := range rows {\r\n\t\tm[r.Case] = r\r\n\t}\r\n\treturn m\r\n}\r\n\r\nfunc sortedRows(m map[string]entry) []entry {\r\n\tout := make([]entry, 0, len(m))\r\n\tfor _, r := range m {\r\n\t\tout = append(out, r)\r\n\t}\r\n\tsort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\r\n\treturn out\r\n}\r\n\r\nfunc sameFields(a, b entry) bool {\r\n\tif a.Case != b.Case || a.Packed != b.Packed || a.Grouped != b.Group"]
[363.437532, "o", "ed || a.Reuse != b.Reuse {\r\n\t\treturn false\r\n\t}\r\n\tif len(a.Produced) != len(b.Produced) || len(a.Trace) != len(b.Trace) || len(a.OrderUsed) != len(b.OrderUsed) {\r\n\t\treturn false\r\n\t}\r\n\tfor i := range a.Produced {\r\n\t\tif a.Produced[i] != b.Produced[i] {\r\n\t\t\treturn false\r\n\t\t}\r\n\t}\r\n\tfor i := range a.Trace {\r\n\t\tif a.Trace[i] != b.Trace[i] {\r\n\t\t\treturn false\r\n\t\t}\r\n\t}\r\n\tfor i := range a.OrderUsed {\r\n\t\tif a.OrderUsed[i] != b.OrderUsed[i] {\r\n\t\t\treturn false\r\n\t\t}\r\n\t}\r\n\treturn true\r\n}\r\n\r\nfunc loadPrior(path string) (map[string]entry, bool, error) {\r\n\tbuf, err := os.ReadFile(path)\r\n"]
[363.437667, "o", "\tif err != nil {\r\n\t\tif errors.Is(err, os.ErrNotExist) {\r\n\t\t\treturn nil, false, nil\r\n\t\t}\r\n\t\treturn nil, false, err\r\n"]
[363.437703, "o", "\t}\r\n\tvar doc finalDoc\r\n\tif err := json.Unmarshal(buf, &doc); err != nil {\r\n\t\treturn nil, true, err\r\n\t}\r\n\treturn byCase(doc.Rows), true, nil\r\n}\r\n\r\nfunc main() {\r\n\tif len(os.Args) != 3 {\r\n\t\tpanic(\"usage: align raw final\")\r\n\t}\r\n\trawPath := os.Args[1]\r\n\tfinalPath := os.Args[2]\r\n\r\n\tbuf, err := os.ReadFile(rawPath)\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\tvar raw rawDoc\r\n\tif err := json.Unmarshal(buf, &raw); err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\r\n\t// new report rows derived from raw, one per case name.\r\n\trawMap := byCase(raw.Raw)\r\n\tnewRows := sortedRows(rawMap)\r\n\r\n\tagree := true\r\n\r\n\t// (1) New report rows must match incoming raw for each case on the required fields.\r\n\t// Since we derive from raw, this is structurally true; still enforce and also enforce no missing/extra.\r\n"]
[363.437784, "o", "\tif len(newRows) != len(rawMap) {\r\n\t\tagree = false\r\n\t}\r\n\tfor c, r := range rawMap {\r\n\t\tif !sameFields(r, rawMap[c]) { // self-check; placeholder to keep logic obvious\r\n\t\t\tagree = false\r\n\t\t\tbreak\r\n\t\t}\r\n\t}\r\n\r\n\t// (2) When replacing an existing report.json, compare prior rows vs new rows.\r\n\tpriorMap, priorExists, err := loadPrior(finalPath)\r\n\tif err != nil {\r\n\t\t// If prior exists but is unreadable, treat as disagreement.\r\n\t\tagree = false\r\n\t} else if priorExists {\r\n\t\t// Any mismatch across case-level entries or missing/extra cases => disagree.\r\n\t\tif len(priorMap) != len(rawMap) {\r\n"]
[363.437873, "o", "\t\t\tagree = false\r\n\t\t}\r\n\t\tfor c, newRow := range rawMap {\r\n\t\t\toldRow, ok := priorMap[c]\r\n\t\t\tif !ok || !sameFields(oldRow, newRow) {\r\n\t\t\t\tagree = false\r\n\t\t\t\tbreak\r\n\t\t\t}\r\n\t\t}\r\n\t\tif agree {\r\n\t\t\tfor c := range priorMap {\r\n\t\t\t\tif _, ok := rawMap[c]; !ok {\r\n\t\t\t\t\tagree = false\r\n\t\t\t\t\tbreak\r\n\t\t\t\t}\r\n"]
[363.437899, "o", "\t\t\t}\r\n\t\t}\r\n\t}\r\n\r\n\tdoc := finalDoc{Rows: newRows, Summary: map[string]any{\"total\": len(newRows), \"agree\": agree}}\r\n"]
[363.437921, "o", "\tout, err := json.MarshalIndent(doc, \"\", \"  \")\r\n"]
[363.437931, "o", "\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n"]
[363.437945, "o", "\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n}\r\n"]
