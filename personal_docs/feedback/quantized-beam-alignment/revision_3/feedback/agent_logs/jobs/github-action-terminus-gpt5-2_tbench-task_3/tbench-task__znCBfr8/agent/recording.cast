[240.555969, "i", "sed -n '1,200p' /app/cmd/align/main.go\n"]
[240.556631, "o", "sed -n '1,200p' /app/cmd/align/main.go"]
[240.556832, "o", "\r\n"]
[240.557063, "o", "\u001b[?2004l\r"]
[240.558287, "o", "package main\r\n\r\nimport (\r\n    \"encoding/json\"\r\n    \"os\"\r\n    \"sort\"\r\n)\r\n\r\ntype entry struct {\r\n    Case      string `json:\"case\"`\r\n    Produced  []int  `json:\"produced\"`\r\n"]
[240.558328, "o", "    Trace     []int  `json:\"slot_trace\"`\r\n    OrderUsed []int  `json:\"order_used\"`\r\n    Packed    bool   `json:\"packed\"`\r\n    Grouped   bool   `json:\"grouped\"`\r\n    Reuse     bool   `json:\"reuse\"`\r\n}\r\n\r\ntype rawDoc struct {\r\n    Raw []entry `json:\"raw\"`\r\n}\r\n\r\n"]
[240.558345, "o", "type finalDoc struct {\r\n    Rows    []entry        `json:\"rows\"`\r\n    Summary map[string]any `json:\"summary\"`\r\n}\r\n\r\n"]
[240.558361, "o", "func fold(a []entry) []entry {\r\n    seen := map[byte]entry{}\r\n    for _, row := range a {\r\n"]
[240.558369, "o", "        key := row.Case[0]\r\n        seen[key] = row\r\n    }\r\n"]
[240.558384, "o", "    out := make([]entry, 0, len(seen))\r\n    for _, row := range seen {\r\n        out = append(out, row)\r\n"]
[240.558396, "o", "    }\r\n    sort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\r\n    return out\r\n}\r\n"]
[240.558408, "o", "\r\nfunc main() {\r\n    if len(os.Args) != 3 {\r\n"]
[240.558417, "o", "        panic(\"usage: align raw final\")\r\n    }\r\n    buf, err := os.ReadFile(os.Args[1])\r\n"]
[240.558426, "o", "    if err != nil {\r\n        panic(err)\r\n    }\r\n"]
[240.558441, "o", "    var raw rawDoc\r\n    if err := json.Unmarshal(buf, &raw); err != nil {\r\n        panic(err)\r\n    }\r\n"]
[240.558457, "o", "    rows := fold(raw.Raw)\r\n    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": len(rows) == len(raw.Raw)}}\r\n    out, err := json.MarshalIndent(doc, \"\", \"  \")\r\n"]
[240.558466, "o", "    if err != nil {\r\n        panic(err)\r\n    }\r\n"]
[240.558479, "o", "    if err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\r\n        panic(err)\r\n    }\r\n"]
[240.558491, "o", "}\r\n"]
