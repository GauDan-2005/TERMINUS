sting.Rows)\n\t\t\trawMap := buildMap(raw.Raw)\n\n\t\t\t// Check all cases in raw against existing\n\t\t\tfor caseName, rawEntry := range rawMap {\n\t\t\t\tif existingEntry, ok := existingMap[caseName]; ok {\n\t\t\t\t\tif !entriesMatch(rawEntry, existingEntry) {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\t// Also check if existing has cases not in raw\n\t\t\tif agree {\n\t\t\t\tfor caseName := range existingMap {\n\t\t\t\t\tif _, ok := rawMap[caseName]; !ok {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t}\n\t// If no existing report.json, agree stays true (new report rows = raw rows, they match)\n\n\tdoc := finalDoc{\n\t\tRows: reportRows,\n\t\tSummary: map[string]any{\n\t\t\t"total": len(reportRows),\n\t\t\t"agree": agree,\n\t\t},\n\t}\n\n\tout, err := json.MarshalIndent(doc, "", "  ")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, \'\\n\'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
