[217.009449, "i", "cat > /app/cmd/align/main.go << 'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc entriesMatch(a, b entry) bool {\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc buildMap(rows []entry) map[string]entry {\n\tm := make(map[string]entry)\n\tfor _, r := range rows {\n\t\tm[r.Case] = r"]
[217.010055, "i", "\n\t}\n\treturn m\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\trawPath := os.Args[1]\n\tfinalPath := os.Args[2]\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Report rows are the same as raw rows\n\treportRows := make([]entry, len(raw.Raw))\n\tcopy(reportRows, raw.Raw)\n\n\t// Compute agree: compare incoming raw against existing report.json if present\n\tagree := true\n\n\t// Check if existing report.json exists\n\tif existingBuf, err := os.ReadFile(finalPath); err == nil {\n\t\tvar existing finalDoc\n\t\tif err := json.Unmarshal(existingBuf, &existing); err == nil {\n\t\t\t// Compare existing report rows against incoming raw rows by case name\n\t\t\texistingMap := buildMap(existing.Rows)\n\t\t\trawMap := buildMap(raw.Raw)\n\n\t\t\t// Check all cases in raw against existing\n\t\t\tfor caseName, rawEntry := range rawMap {\n\t\t\t\tif existingEntry, ok := existingMap[caseName]; ok {\n\t\t\t\t\tif !entriesMatch(rawEntry, existin"]
[217.010164, "o", "cat > /app/cmd/align/main.go << 'EOF'\r\n\u001b[?2004l\r"]
[217.010255, "i", "gEntry) {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\t// Also check if existing has cases not in raw\n\t\t\tif agree {\n\t\t\t\tfor caseName := range existingMap {\n\t\t\t\t\tif _, ok := rawMap[caseName]; !ok {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t}\n\t// If no existing report.json, agree stays true (new report rows = raw rows, they match)\n\n\tdoc := finalDoc{\n\t\tRows: reportRows,\n\t\tSummary: map[string]any{\n\t\t\t\"total\": len(reportRows),\n\t\t\t\"agree\": agree,\n\t\t},\n\t}\n\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
[217.010455, "o", "gEntry) {\r\n\t\t\t\t\t\tagree = false\r\n\t\t\t\t\t\tbreak\r\n\t\t\t\t\t}\r\n\t\t\t\t} else {\r\n\t\t\t\t\tagree = false\r\n\t\t\t\t\tbreak\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t// Also check if existing has cases not in raw\r\n\t\t\tif agree {\r\n\t\t\t\tfor caseName := range existingMap {\r\n\t\t\t\t\tif _, ok := rawMap[caseName]; !ok {\r\n\t\t\t\t\t\tagree = false\r\n\t\t\t\t\t\tbreak\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t} else {\r\n\t\t\tagree = false\r\n\t\t}\r\n\t}\r\n\t// If no existing report.json, agree stays true (new report rows = raw rows, they match)\r\n\r\n\tdoc := finalDoc{\r\n\t\tRows: reportRows,\r\n\t\tSummary: map[string]any{\r\n\t\t\t\"total\": len(reportRows),\r\n\t\t\t\"agree\": agree,\r\n\t\t},\r\n\t}\r\n\r\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n}\r\nEOF\r\n"]
