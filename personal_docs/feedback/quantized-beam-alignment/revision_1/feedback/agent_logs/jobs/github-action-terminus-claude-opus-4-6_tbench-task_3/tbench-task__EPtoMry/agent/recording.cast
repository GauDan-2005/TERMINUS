[463.856597, "i", "python3 -c \"\nimport json\nraw = json.load(open('/app/output/raw.json'))\nreport = json.load(open('/app/output/report.json'))\nprint('raw count:', len(raw['raw']))\nprint('report count:', len(report['rows']))\nfor r, rp in zip(raw['raw'], report['rows']):\n    assert r['case'] == rp['case']\n    assert r['produced'] == rp['produced']\n    assert r['slot_trace'] == rp['slot_trace']\n    assert r['order_used'] == rp['order_used']\n    assert r['packed'] == rp['packed']\n    assert r['grouped'] == rp['grouped']\n    assert r['reuse'] == rp['reuse']\nprint('All assertions pass')\n\"\n"]
