[99.057913, "i", "cat > /app/cmd/rawgen/main.go <<'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"path/filepath\"\n)\n\ntype caseDef struct {\n\tName   string\n\tPacked bool\n\tGroup  bool\n\tReuse  bool\n\tSeq    []int\n\tRows   [][]int\n}\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\nfunc cases() []caseDef {\n\treturn []caseDef{\n\t\t{Name: \"alpha\", Packed: false, Group: true, Reuse: false, Seq: []int{0, 1}, Rows: [][]int{{21, 10, 4}, {15, 8, 6}}},\n\t\t{Name: \"beta\", Packed: true, Group: false, Reuse: false, Seq: []int{0}, Rows: [][]int{{10, 4, 1}}},\n\t\t{Name: \"gamma\", Packed: true, Group: true, Reuse: false, Seq: []int{0, 1}, Rows: [][]int{{8, 3, 2}, {6, 5, 1}}},\n\t\t{Name: \"delta\", Packed: true, Group: true, Reuse: false, Seq: []int{1, 0}, Rows: [][]int{{7, 4, 2}, {5, 6, 3}}"]
[99.058063, "i", "},\n\t\t{Name: \"epsilon\", Packed: true, Group: true, Reuse: true, Seq: []int{1, 0, 2}, Rows: [][]int{{4, 7, 2}, {9, 2, 3}, {3, 8, 1}}},\n\t\t{Name: \"zeta\", Packed: false, Group: true, Reuse: true, Seq: []int{2, 0, 1}, Rows: [][]int{{12, 9, 5}, {18, 4, 7}, {10, 6, 8}}},\n\t}\n}\n\n// Mirrors the Rust token() logic.\nfunc token(sum int, slot int, packed, group, reuse bool) int {\n\tv := sum + slot*7\n\tif packed {\n\t\tv += 3\n\t}\n\tif group {\n\t\tv += 5\n\t}\n\tif reuse {\n\t\tv += 11\n\t}\n\tv %= 101\n\tif v < 0 {\n\t\tv += 101\n\t}\n\treturn v\n}\n\n// Rust toolchain isn't available here; this Go generator is the deterministic\n// replacement for producing /app/output/raw.json.\nfunc runOne(c caseDef) entry {\n\tproduced := make([]int, 0, len(c.Seq))\n\ttrace := make([]int, 0, len(c.Seq))\n\tfor pos := range c.Seq {\n\t\tsrc := c.Seq[pos]\n\t\thandle := c.Seq[pos]\n\t\trow := c.Rows[src]\n\t\tacc := 0\n\t\tfor _, x := range row {\n\t\t\tacc += x\n\t\t}\n\t\tacc += handle\n\t\tproduced = append(produced, token(acc, handle, c.Packed, c.Group, c.Reuse))\n\t\ttrace = append(trace, handle)\n\t}\n\tret"]
[99.058137, "i", "urn entry{\n\t\tCase:      c.Name,\n\t\tProduced:  produced,\n\t\tTrace:     trace,\n\t\tOrderUsed: append([]int{}, c.Seq...),\n\t\tPacked:    c.Packed,\n\t\tGrouped:   c.Group,\n\t\tReuse:     c.Reuse,\n\t}\n}\n\nfunc main() {\n\tout := \"/app/output/raw.json\"\n\tif len(os.Args) >= 2 {\n\t\tout = os.Args[1]\n\t}\n\trows := make([]entry, 0, len(cases()))\n\tfor _, c := range cases() {\n\t\trows = append(rows, runOne(c))\n\t}\n\tdoc := rawDoc{Raw: rows}\n\tbuf, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.MkdirAll(filepath.Dir(out), 0o755); err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(out, append(buf, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
