[109.553102, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\nraw=json.loads(Path('/app/output/raw.json').read_text())\nrep=json.loads(Path('/app/output/report.json').read_text())\nprint('raw rows',len(raw['raw']))\nprint('report rows',len(rep['rows']))\nprint('summary',rep['summary'])\nkeys=['produced','slot_trace','order_used','packed','grouped','reuse']\nrm={r['case']:r for r in raw['raw']}\npm={r['case']:r for r in rep['rows']}\nmiss=set(rm)-set(pm)\nextra=set(pm)-set(rm)\nprint('missing',miss,'extra',extra)\nok=True\nfor c in sorted(rm):\n  for k in keys:\n    if rm[c][k]!=pm[c][k]:\n      ok=False\n      print('mismatch',c,k,rm[c][k],pm[c][k])\nprint('six-field match',ok)\nPY\n"]
