[62.422612, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: cmd/align/main.go\n@@\n package main\n \n import (\n     \"encoding/json\"\n+    \"errors\"\n     \"os\"\n-    \"sort\"\n+    \"reflect\"\n )\n@@\n type finalDoc struct {\n     Rows    []entry        `json:\"rows\"`\n     Summary map[string]any `json:\"summary\"`\n }\n \n-func fold(a []entry) []entry {\n-    seen := map[byte]entry{}\n-    for _, row := range a {\n-        key := row.Case[0]\n-        seen[key] = row\n-    }\n-    out := make([]entry, 0, len(seen))\n-    for _, row := range seen {\n-        out = append(out, row)\n-    }\n-    sort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\n-    return out\n+func indexByCase(rows []entry) (map[string]entry, error) {\n+    m := make(map[string]entry, len(rows))\n+    for _, r := range rows {\n+        if r.Case == \"\" {\n+            return nil, errors.New(\"row missing case\")\n+        }\n+        if _, exists := m[r.Case]; exists {\n+            return nil, errors.New(\"duplicate case: \" + r.Case)\n+        }\n+        m[r.Case] = r"]
[62.422675, "i", "\n+    }\n+    return m, nil\n+}\n+\n+func eqSix(a, b entry) bool {\n+    if a.Case != b.Case {\n+        return false\n+    }\n+    if !reflect.DeepEqual(a.Produced, b.Produced) {\n+        return false\n+    }\n+    if !reflect.DeepEqual(a.Trace, b.Trace) {\n+        return false\n+    }\n+    if !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n+        return false\n+    }\n+    if a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\n+        return false\n+    }\n+    return true\n+}\n+\n+// agree is true iff every case in raw has a corresponding report row matching\n+// on produced, slot_trace, order_used, packed, grouped, reuse.\n+func agreeRawVsRows(raw []entry, rows []entry) (bool, error) {\n+    rawBy, err := indexByCase(raw)\n+    if err != nil {\n+        return false, err\n+    }\n+    rowsBy, err := indexByCase(rows)\n+    if err != nil {\n+        return false, err\n+    }\n+    if len(rawBy) != len(rowsBy) {\n+        return false, nil\n+    }\n+    for k, rr := range rawBy {\n+        fr, ok := rowsBy[k]\n+        "]
[62.42269, "i", "if !ok {\n+            return false, nil\n+        }\n+        if !eqSix(rr, fr) {\n+            return false, nil\n+        }\n+    }\n+    return true, nil\n }\n \n func main() {\n     if len(os.Args) != 3 {\n         panic(\"usage: align raw final\")\n@@\n     var raw rawDoc\n     if err := json.Unmarshal(buf, &raw); err != nil {\n         panic(err)\n     }\n-    rows := fold(raw.Raw)\n-    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": len(rows) == len(raw.Raw)}}\n+\n+    // Do not drop or merge cases; report rows must cover exactly the raw rows.\n+    rows := append([]entry{}, raw.Raw...)\n+\n+    // If a prior report exists at the output path, we must compare its rows\n+    // against incoming raw; any mismatch forces agree=false.\n+    priorAgree := true\n+    if prev, err := os.ReadFile(os.Args[2]); err == nil {\n+        var prior finalDoc\n+        if err := json.Unmarshal(prev, &prior); err == nil {\n+            ok, err := agreeRawVsRows(raw.Raw, prior.Rows)\n+            if err != nil {\n+      "]
[62.422704, "i", "          priorAgree = false\n+            } else {\n+                priorAgree = ok\n+            }\n+        } else {\n+            priorAgree = false\n+        }\n+    }\n+\n+    nowAgree, err := agreeRawVsRows(raw.Raw, rows)\n+    if err != nil {\n+        panic(err)\n+    }\n+\n+    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(raw.Raw), \"agree\": (nowAgree && priorAgree)}}\n     out, err := json.MarshalIndent(doc, \"\", \"  \")\n     if err != nil {\n         panic(err)\n     }\n*** End Patch\nPATCH\n"]
