[99.181927, "i", "cat > /app/cmd/align/main.go <<'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"os\"\n\t\"reflect\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc indexByCase(rows []entry) (map[string]entry, error) {\n\tm := make(map[string]entry, len(rows))\n\tfor _, r := range rows {\n\t\tif r.Case == \"\" {\n\t\t\treturn nil, errors.New(\"row missing case\")\n\t\t}\n\t\tif _, exists := m[r.Case]; exists {\n\t\t\treturn nil, errors.New(\"duplicate case: \" + r.Case)\n\t\t}\n\t\tm[r.Case] = r\n\t}\n\treturn m, nil\n}\n\nfunc eqSix(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.T"]
[99.182287, "i", "race, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\n// agree is true iff every case in raw has a corresponding report row matching\n// on produced, slot_trace, order_used, packed, grouped, reuse.\nfunc agreeRawVsRows(raw []entry, rows []entry) (bool, error) {\n\trawBy, err := indexByCase(raw)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\trowsBy, err := indexByCase(rows)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\tif len(rawBy) != len(rowsBy) {\n\t\treturn false, nil\n\t}\n\tfor k, rr := range rawBy {\n\t\tfr, ok := rowsBy[k]\n\t\tif !ok {\n\t\t\treturn false, nil\n\t\t}\n\t\tif !eqSix(rr, fr) {\n\t\t\treturn false, nil\n\t\t}\n\t}\n\treturn true, nil\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Do not drop ca"]
[99.182334, "o", "cat > /app/cmd/align/main.go <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> package main\r\n\u001b[?2004l\r"]
[99.182436, "i", "ses or merge rows from different requests.\n\trows := append([]entry{}, raw.Raw...)\n\n\t// Compare against prior stored report.json if it exists; any mismatch forces agree=false.\n\tpriorAgree := true\n\tif prev, err := os.ReadFile(os.Args[2]); err == nil {\n\t\tvar prior finalDoc\n\t\tif err := json.Unmarshal(prev, &prior); err == nil {\n\t\t\tok, err := agreeRawVsRows(raw.Raw, prior.Rows)\n\t\t\tif err != nil {\n\t\t\t\tpriorAgree = false\n\t\t\t} else {\n\t\t\t\tpriorAgree = ok\n\t\t\t}\n\t\t} else {\n\t\t\tpriorAgree = false\n\t\t}\n\t}\n\n\tnowAgree, err := agreeRawVsRows(raw.Raw, rows)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\tdoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(raw.Raw), \"agree\": (nowAgree && priorAgree)}}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
