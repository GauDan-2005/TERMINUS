]string{parts[0], line})\n\t}\n\tif err := s.Err(); err != nil {\n\t\treturn nil, err\n\t}\n\treturn out, nil\n}\n\nfunc cases(fullNames map[string]string) ([]Case, error) {\n\tget := func(base string) (string, error) {\n\t\tv, ok := fullNames[base]\n\t\tif !ok {\n\t\t\treturn "", fmt.Errorf("missing case mapping for %q in sets.txt", base)\n\t\t}\n\t\treturn v, nil\n\t}\n\talpha, err := get("alpha")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tbeta, err := get("beta")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tgamma, err := get("gamma")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdelta, err := get("delta")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tepsilon, err := get("epsilon")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tzeta, err := get("zeta")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn []Case{\n\t\t{BaseName: "alpha", FullName: alpha, Packed: false, Grouped: true, Reuse: false, Seq: []int{0, 1}, Rows: [][]int{{21, 10, 4}, {15, 8, 6}}},\n\t\t{BaseName: "beta", FullName: beta, Packed: true, Grouped: false, Reuse: false, Seq: []int{0}, Rows: [][]int{{10, 4, 1}}},\n\t\t{BaseName: "gamma", FullName: gamma, Packed: true, Grouped: true, Reuse: false, Seq: []int{0, 1}, Rows: [][]int{{8, 3, 2}, {6, 5, 1}}},\n\t\t{BaseName: "delta", FullName: delta, Packed: true, Grouped: true, Reuse: false, Seq: []int{1, 0}, Rows: [][]int{{7, 4, 2}, {5, 6, 3}}},\n\t\t{BaseName: "epsilon", FullName: epsilon, Packed: true, Grouped: true, Reuse: true, Seq: []int{1, 0, 2}, Rows: [][]int{{4, 7, 2}, {9, 2, 3}, {3, 8, 1}}},\n\t\t{BaseName: "zeta", FullName: zeta, Packed: false, Grouped: true, Reuse: true, Seq: []int{2, 0, 1}, Rows: [][]int{{12, 9, 5}, {18, 4, 7}, {10, 6, 8}}},\n\t}, nil\n}\n\nfunc runOne(c Case) entry {\n\tmeta := newA0()\n\tlocal := newC0(len(c.Rows))\n\n\tbaseRows := make([][]int, 0, len(c.Rows))\n\tfor i, row := range c.Rows {\n\t\tif c.Packed {\n\t\t\tbaseRows = append(baseRows, ax(meta, row, i))\n\t\t} else {\n\t\t\tcp := append([]int(nil), row...)\n\t\t\tbaseRows = append(baseRows, cp)\n\t\t}\n\t}\n\n\tvals := make([]int, 0, len(c.Seq))\n\ttrace := make([]int, 0, len(c.Seq))\n\tfor pos, src := range c.Seq {\n\t\t_ = pos // Rust has a "moved" handle identical to seq for our purposes.\n\t\thandle := src\n\t\tacc := cx(local, handle, baseRows[src])\n\t\tvals = append(vals, token(acc, handle, c.Packed, c.Grouped, c.Reuse))\n\t\ttrace = append(trace, handle)\n\t}\n\n\treturn entry{\n\t\tCase:      c.FullName,\n\t\tProduced:  vals,\n\t\tTrace:     trace,\n\t\tOrderUsed: append([]int(nil), c.Seq...),\n\t\tPacked:    c.Packed,\n\t\tGrouped:   c.Grouped,\n\t\tReuse:     c.Reuse,\n\t}\n}\n\nfunc main() {\n\tout := "/app/output/raw.json"\n\tif len(os.Args) >= 2 {\n\t\tout = os.Args[1]\n\t}\n\n\tpairs, err := parseSets("/app/config/sets.txt")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tfull := make(map[string]string, len(pairs))\n\torder := make([]string, 0, len(pairs))\n\tfor _, p := range pairs {\n\t\tfull[p[0]] = p[1]\n\t\torder = append(order, p[0])\n\t}\n\tcs, err := cases(full)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tbyBase := make(map[string]Case, len(cs))\n\tfor _, c := range cs {\n\t\tbyBase[c.BaseName] = c\n\t}\n\n\trows := make([]entry, 0, len(order))\n\tfor _, base := range order {\n\t\tc, ok := byBase[base]\n\t\tif !ok {\n\t\t\tpanic(errors.New("unknown base case in sets.txt: " + base))\n\t\t}\n\t\trows = append(rows, runOne(c))\n\t}\n\n\tdoc := rawDoc{Raw: rows}\n\tbuf, err := json.MarshalIndent(doc, "", "  ")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\tif err := os.MkdirAll(filepath.Dir(out), 0o755); err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(out, append(buf, \'\\n\'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n\n\t_ = strconv.IntSize // keep strconv imported if future changes; harmless.\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
