[135.027671, "o", "\u0007rows := make([]entry, 0, len(order))\r\n\u001b[?2004l\r\u001b[?2004h> \u0007for _, base := range order {\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nCargo.lock  Cargo.toml  bin/        cmd/        config/     data/       docs/       go.mod      go.sum      internal/   output/     src/        tools/\r\n> c, ok := byBase[base]\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nCargo.lock  Cargo.toml  bin/        cmd/        config/     data/       docs/       go.mod      go.sum      internal/   output/     src/        tools/\r\n> if !ok {\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nCargo.lock  Cargo.toml  bin/        cmd/        config/     data/       docs/       go.mod      go.sum      internal/   output/     src/        tools/\r\n> \r\nCargo.lock  Cargo.toml  bin/        cmd/        config/     data/       docs/       go.mod      go.sum      internal/   output/     src/        tools/\r\n> panic(errors.New(\"unknown base case in sets.txt: \" + base))\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nCargo.lock  Cargo.toml  bin/        cmd/        config/     data/       docs/       go.mod      go.sum      internal/   output/     src"]
[135.02951, "o", "/        tools/\r\n> }\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nCargo.lock  Cargo.toml  bin/        cmd/        config/     data/       docs/       go.mod      go.sum      internal/   output/     src/        tools/\r\n> rows = append(rows, runOne(c))\r\n\u001b[?2004l\r\u001b[?2004h> \u0007}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \u0007doc := rawDoc{Raw: rows}\r\n\u001b[?2004l\r\u001b[?2004h> \u0007buf, err := json.MarshalIndent(doc, \"\", \"  \")\r\n\u001b[?2004l\r\u001b[?2004h> \u0007if err != nil {\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nCargo.lock  Cargo.toml  bin/        cmd/        config/     data/       docs/       go.mod      go.sum      internal/   output/     src/        tools/\r\n> panic(err)\r\n\u001b[?2004l\r\u001b[?2004h> \u0007}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \u0007if err := os.MkdirAll(filepath.Dir(out), 0o755); err != nil {\r\n\u001b[?2004l\r\u001b[?2004h> \u0007\r\nCargo.lock  Cargo.toml  bin/        cmd/        config/     data/       docs/       go.mod      go.sum      internal/   output/     src/        tools/\r\n> panic(err)\r\n\u001b[?2004l\r\u001b[?2004h> \u0007}\r\n\u001b[?2004l\r\u001b[?2004h> \u0007if err := os.WriteFile(out, append(buf, '\\n'), 0o644);"]
