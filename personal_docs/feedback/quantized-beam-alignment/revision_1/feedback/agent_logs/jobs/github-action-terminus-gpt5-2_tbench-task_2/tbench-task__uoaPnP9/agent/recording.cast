[69.132445, "o", "package main\r\n\r\nimport (\r\n\t\"encoding/json\"\r\n\t\"os\"\r\n\t\"sort\"\r\n)\r\n\r\ntype entry struct {\r\n\tCase      string `json:\"case\"`\r\n\tProduced  []int  `json:\"produced\"`\r\n"]
[69.13247, "o", "\tTrace     []int  `json:\"slot_trace\"`\r\n\tOrderUsed []int  `json:\"order_used\"`\r\n\tPacked    bool   `json:\"packed\"`\r\n\tGrouped   bool   `json:\"grouped\"`\r\n\tReuse     bool   `json:\"reuse\"`\r\n}\r\n\r\ntype rawDoc struct {\r\n\tRaw []entry `json:\"raw\"`\r\n"]
[69.132481, "o", "}\r\n\r\ntype finalDoc struct {\r\n\tRows    []entry        `json:\"rows\"`\r\n\tSummary map[string]any `json:\"summary\"`\r\n"]
[69.132493, "o", "}\r\n\r\nfunc fold(a []entry) []entry {\r\n\tseen := map[byte]entry{}\r\n"]
[69.132504, "o", "\tfor _, row := range a {\r\n\t\tkey := row.Case[0]\r\n\t\tseen[key] = row\r\n"]
[69.132519, "o", "\t}\r\n\tout := make([]entry, 0, len(seen))\r\n\tfor _, row := range seen {\r\n\t"]
[69.132528, "o", "\tout = append(out, row)\r\n\t}\r\n\tsort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\r\n"]
[69.132538, "o", "\treturn out\r\n}\r\n\r\n"]
[69.132547, "o", "func main() {\r\n\tif len(os.Args) != 3 {\r\n\t\tpanic(\"usage: align raw final\")\r\n\t"]
[69.13256, "o", "}\r\n\tbuf, err := os.ReadFile(os.Args[1])\r\n\tif err != nil {\r\n"]
[69.132574, "o", "\t\tpanic(err)\r\n\t}\r\n\tvar raw rawDoc\r\n\tif err := json.Unmarshal(buf, &raw); err != nil {\r\n"]
[69.132585, "o", "\t\tpanic(err)\r\n\t}\r\n\trows := fold(raw.Raw)\r\n"]
[69.132596, "o", "\tdoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": len(rows) == len(raw.Raw)}}\r\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n"]
[69.132604, "o", "\tif err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n"]
[69.132615, "o", "}\r\n"]
[69.132821, "o", "\u001b[?2004h"]
[69.132947, "o", "root@0a5f9d5f839a:/app# "]
[84.303209, "i", "cat > /app/cmd/align/main.go <<'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"os\"\n\t\"sort\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc toMap(rows []entry) (map[string]entry, error) {\n\tm := make(map[string]entry, len(rows))\n\tfor _, r := range rows {\n\t\tif r.Case == \"\" {\n\t\t\treturn nil, errors.New(\"row missing case name\")\n\t\t}\n\t\tif _, ok := m[r.Case]; ok {\n\t\t\treturn nil, errors.New(\"duplicate case in rows: \" + r.Case)\n\t\t}\n\t\tm[r.Case] = r\n\t}\n\treturn m, nil\n}\n\nfunc equalInts(a, b []int) bool {\n\tif len(a) != len(b) {\n\t\treturn false\n\t}\n\tfor i := range a {\n\t\tif a[i] != b[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\n// matchesSpec"]
[84.303266, "o", "cat > /app/cmd/align/main.go <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> package main\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[84.303285, "i", " checks equality across the six required fields.\nfunc matchesSpec(a, b entry) bool {\n\treturn a.Case == b.Case &&\n\t\tequalInts(a.Produced, b.Produced) &&\n\t\tequalInts(a.Trace, b.Trace) &&\n\t\tequalInts(a.OrderUsed, b.OrderUsed) &&\n\t\ta.Packed == b.Packed &&\n\t\ta.Grouped == b.Grouped &&\n\t\ta.Reuse == b.Reuse\n}\n\nfunc sortedCases(m map[string]entry) []string {\n\tcases := make([]string, 0, len(m))\n\tfor k := range m {\n\t\tcases = append(cases, k)\n\t}\n\tsort.Strings(cases)\n\treturn cases\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\n\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Collation stage: keep exactly one row per case name; do not drop/merge.\n\trawMap, err := toMap(raw.Raw)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Deterministic local report rows: stable ordering of the raw rows.\n\tcases := sortedCases(rawMap)\n\trows := make([]entry, 0, len(cases))\n\tfor _, c := range cases {\n\t\trows = app"]
[84.303306, "i", "end(rows, rawMap[c])\n\t}\n\n\t// agree iff every report row matches its raw counterpart across the six required fields,\n\t// and overwriting an existing report.json only keeps agree=true if the prior report rows\n\t// also match the incoming raw rows across those same fields.\n\tagree := true\n\n\trepMap, err := toMap(rows)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif len(repMap) != len(rawMap) {\n\t\tagree = false\n\t}\n\tfor c, rr := range rawMap {\n\t\tfr, ok := repMap[c]\n\t\tif !ok || !matchesSpec(rr, fr) {\n\t\t\tagree = false\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif prevBuf, err := os.ReadFile(os.Args[2]); err == nil {\n\t\tvar prev finalDoc\n\t\tif err := json.Unmarshal(prevBuf, &prev); err == nil {\n\t\t\tprevMap, err := toMap(prev.Rows)\n\t\t\tif err != nil {\n\t\t\t\tagree = false\n\t\t\t} else {\n\t\t\t\tif len(prevMap) != len(rawMap) {\n\t\t\t\t\tagree = false\n\t\t\t\t}\n\t\t\t\tfor c, rr := range rawMap {\n\t\t\t\t\tpr, ok := prevMap[c]\n\t\t\t\t\tif !ok || !matchesSpec(rr, pr) {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\t// If existing report.json is unreadable, do not claim agreemen"]
[84.303324, "i", "t.\n\t\t\tagree = false\n\t\t}\n\t}\n\n\tdoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": agree}}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
