[169.234419, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))\nprint('agree:', rep['summary']['agree'], 'total:', rep['summary']['total'])\nrm={r['case']:r for r in raw}\npm={r['case']:r for r in rep['rows']}\nwant={'produced','slot_trace','order_used','packed','grouped','reuse'}\nmissing=set(rm)-set(pm)\nextra=set(pm)-set(rm)\nprint('missing',missing,'extra',extra)\nok=True\nfor k in sorted(rm):\n    a=rm[k]; b=pm.get(k)\n    if b is None:\n        ok=False; continue\n    for f in want:\n        if a[f]!=b[f]:\n            print('mismatch',k,f,a[f],b[f])\n            ok=False\nprint('all_match:', ok)\nPY\n"]
