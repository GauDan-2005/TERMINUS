[62.123989, "i", "c := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": len(rows) == len(raw.Raw)}}\n+\n+    // Collation stage: keep one row per built-in case name.\n+    // Do not drop/merge: require unique case names.\n+    rawMap, err := toMap(raw.Raw)\n+    if err != nil {\n+        panic(err)\n+    }\n+\n+    // For deterministic local behavior, the report rows are a stable ordering of the raw rows.\n+    // (Collation logic may evolve, but produced/trace/order/flags must match raw per-case.)\n+    cases := sortedCases(rawMap)\n+    rows := make([]entry, 0, len(cases))\n+    for _, c := range cases {\n+        rows = append(rows, rawMap[c])\n+    }\n+\n+    // agree iff every report row matches its raw counterpart across the six required fields,\n+    // AND (if overwriting an existing report.json) the prior report rows also match incoming raw.\n+    agree := true\n+    // Compare newly generated rows to incoming raw.\n+    repMap, err := toMap(rows)\n+    if err != nil {\n+        panic(err)\n+    }\n+    if len(repMap)"]
