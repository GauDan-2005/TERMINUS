[23.37335, "o", "\r\n"]
[23.373505, "o", "\u001b[?2004l\r"]
[23.37507, "o", "pub fn view(a: &[i32]) -> String {\r\n    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\"|\")\r\n}\r\n\r\npub fn lens(a: &[i32]) -> usize {\r\n    a.len()\r\n}\r\n"]
