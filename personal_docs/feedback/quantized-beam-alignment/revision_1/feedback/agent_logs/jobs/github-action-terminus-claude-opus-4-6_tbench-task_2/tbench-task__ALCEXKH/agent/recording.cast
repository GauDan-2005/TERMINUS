[23.163481, "o", "pub fn dx(a: &[i32], b: &[usize]) -> Vec<i32> {\r\n    b.iter().map(|i| a[*i]).collect()\r\n}\r\n\r\npub fn tag(a: &str, b: usize) -> String {\r\n    format!(\"{}:{}\", a, b)\r\n}\r\n\u001b[?2004hroot@e8dd6ba0c3d8:/app# "]
[23.27001, "i", "cat /app/src/e4/mod.rs\n"]
[23.270179, "o", "cat /app/src/e4/mod.rs"]
[23.270294, "o", "\r\n\u001b[?2004l\r"]
[23.271164, "o", "pub struct E0 {\r\n    pub v: Vec<String>,\r\n}\r\n\r\nimpl E0 {\r\n    pub fn new() -> Self {\r\n        Self { v: Vec::new() }\r\n    }\r\n}\r\n\r\npub fn ex(a: &mut E0, b: &str, c: &[i32], d: &[usize]) {\r\n    let vals = c.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\");\r\n    let hs = d.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\");\r\n    a.v.push(format!(\"{{\\\"case\\\":\\\"{}\\\",\\\"produced\\\":[{}],\\\"slot_trace\\\":[{}]}}\", b, vals, hs));\r\n}\r\n"]
[23.271571, "o", "\u001b[?2004hroot@e8dd6ba0c3d8:/app# "]
