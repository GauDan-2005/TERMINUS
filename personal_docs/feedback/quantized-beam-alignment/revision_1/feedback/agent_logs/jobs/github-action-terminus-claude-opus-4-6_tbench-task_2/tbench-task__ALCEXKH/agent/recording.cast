[301.127319, "i", "cat > /app/cmd/align/main.go << 'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc matchEntry(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\tra"]
[301.127484, "o", "cat > /app/cmd/align/main.go << 'EOF'"]
[301.127559, "i", "wPath := os.Args[1]\n\tfinalPath := os.Args[2]\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// New report rows are exactly the raw rows\n\tnewRows := make([]entry, len(raw.Raw))\n\tcopy(newRows, raw.Raw)\n\n\tagree := true\n\n\t// If existing report.json exists, compare its rows against new raw rows\n\tif oldBuf, err := os.ReadFile(finalPath); err == nil {\n\t\tvar oldDoc finalDoc\n\t\tif err := json.Unmarshal(oldBuf, &oldDoc); err == nil {\n\t\t\t// Build map of old report rows by case name\n\t\t\toldMap := make(map[string]entry)\n\t\t\tfor _, row := range oldDoc.Rows {\n\t\t\t\toldMap[row.Case] = row\n\t\t\t}\n\t\t\t// Build map of new raw rows by case name\n\t\t\trawMap := make(map[string]entry)\n\t\t\tfor _, row := range raw.Raw {\n\t\t\t\trawMap[row.Case] = row\n\t\t\t}\n\t\t\t// Check that old report had same cases and matching fields\n\t\t\tif len(oldDoc.Rows) != len(raw.Raw) {\n\t\t\t\tagree = false\n\t\t\t} else {\n\t\t\t\tfor _, rawRow := range raw.Raw {\n\t\t\t\t\toldRow, ok := ol"]
[301.127604, "i", "dMap[rawRow.Case]\n\t\t\t\t\tif !ok || !matchEntry(oldRow, rawRow) {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t}\n\t// If no existing report.json, new rows == raw rows, so agree stays true\n\n\tdoc := finalDoc{\n\t\tRows: newRows,\n\t\tSummary: map[string]any{\n\t\t\t\"total\": len(newRows),\n\t\t\t\"agree\": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
