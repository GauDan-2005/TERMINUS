[16.239195, "o", "pub fn dx(a: &[i32], b: &[usize]) -> Vec<i32> {\r\n    b.iter().map(|i| a[*i]).collect()\r\n}\r\n\r\npub fn tag(a: &str, b: usize) -> String {\r\n    format!(\"{}:{}\", a, b)\r\n}\r\n"]
[16.239309, "o", "\u001b[?2004hroot@519702dcd9db:/app# "]
