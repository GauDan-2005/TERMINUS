[183.75366, "i", "cat > /app/tools/run_local.sh << 'EOF'\n#!/bin/bash\nset -euo pipefail\nexport PATH=\"/usr/local/cargo/bin:$PATH\"\nmkdir -p /app/output /app/bin\ncargo build --release --quiet --manifest-path /app/Cargo.toml\n/app/target/release/local-infer-sandbox /app/output/raw.json\ngo build -o /app/bin/align /app/cmd/align/main.go\n/app/bin/align /app/output/raw.json /app/output/report.json\nEOF\nchmod +x /app/tools/run_local.sh\n"]
[183.753802, "o", "cat > /app/tools/run_local.sh << 'EOF'"]
[183.75394, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[183.754024, "o", "#!/bin/bash\r\n\u001b[?2004l\r\u001b[?2004h"]
[183.754042, "o", "> "]
[183.75419, "o", "set -euo pipefail\r\n\u001b[?2004l\r\u001b[?2004h> "]
[183.754398, "o", "export PATH=\"/usr/local/cargo/bin:$PATH\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[183.754499, "o", "mkdir -p /app/output /app/bin\r\n\u001b[?2004l\r\u001b[?2004h> "]
[183.754699, "o", "cargo build --release --quiet --manifest-path /app/Cargo.toml\r\n\u001b[?2004l\r"]
[183.758384, "o", "\u001b[?2004h> "]
[183.758601, "o", "/app/target/release/local-infer-sandbox /app/output/raw.json\r\n\u001b[?2004l\r\u001b[?2004h> go build -o /app/bin/align /app/cmd/align/main.go\r\n\u001b[?2004l\r\u001b[?2004h> /app/bin/align /app/output/raw.json /app/output/report.json\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[183.759586, "o", "\u001b[?2004hroot@519702dcd9db:/app# chmod +x /app/tools/run_local.sh\r\n\u001b[?2004l\r"]
[183.760304, "o", "\u001b[?2004hroot@519702dcd9db:/app# "]
[183.86616, "i", "cat > /app/cmd/align/main.go << 'GOEOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc matches(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\tbuf"]
[183.866225, "i", ", err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// New report rows are the raw rows directly\n\tnewRows := raw.Raw\n\n\t// Check if existing report.json exists\n\tagree := true\n\treportPath := os.Args[2]\n\tif oldBuf, err := os.ReadFile(reportPath); err == nil {\n\t\tvar oldReport finalDoc\n\t\tif err := json.Unmarshal(oldBuf, &oldReport); err == nil {\n\t\t\t// Build map of old report rows by case name\n\t\t\toldMap := make(map[string]entry)\n\t\t\tfor _, row := range oldReport.Rows {\n\t\t\t\toldMap[row.Case] = row\n\t\t\t}\n\t\t\t// Compare old report rows against incoming raw rows\n\t\t\t// Any case-level mismatch means agree = false\n\t\t\trawMap := make(map[string]entry)\n\t\t\tfor _, row := range raw.Raw {\n\t\t\t\trawMap[row.Case] = row\n\t\t\t}\n\t\t\t// Check all raw cases exist in old report and match\n\t\t\tfor caseName, rawRow := range rawMap {\n\t\t\t\toldRow, exists := oldMap[caseName]\n\t\t\t\tif !exists || !matches(rawRow, oldRow) {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t"]
[183.866257, "i", "\t\t}\n\t\t\t// Check all old report cases exist in raw\n\t\t\tif agree {\n\t\t\t\tfor caseName := range oldMap {\n\t\t\t\t\tif _, exists := rawMap[caseName]; !exists {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t} else {\n\t\t// No existing report - new report rows match raw by construction\n\t\t// Verify explicitly\n\t\tfor i, row := range newRows {\n\t\t\tif i >= len(raw.Raw) || !matches(row, raw.Raw[i]) {\n\t\t\t\tagree = false\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif len(newRows) != len(raw.Raw) {\n\t\t\tagree = false\n\t\t}\n\t}\n\n\tdoc := finalDoc{\n\t\tRows: newRows,\n\t\tSummary: map[string]any{\n\t\t\t\"total\": len(newRows),\n\t\t\t\"agree\": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(reportPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGOEOF\n"]
