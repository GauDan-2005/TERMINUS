[15.873138, "i", "cat /app/src/a0/mod.rs\n"]
[15.873479, "o", "cat /app/src/a0/mod.rs\r\n\u001b[?2004l\r"]
[15.874252, "o", "pub struct A0 {\r\n    pub s: Vec<i32>,\r\n    pub z: Vec<i32>,\r\n}\r\n\r\nimpl A0 {\r\n    pub fn new() -> Self {\r\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\r\n    }\r\n}\r\n\r\npub fn ax(a: &A0, b: &[i32], c: usize) -> Vec<i32> {\r\n    let k = c % a.s.len();\r\n    b.iter().map(|v| v * a.s[k] + a.z[k]).collect()\r\n}\r\n\r\npub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\r\n    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()\r\n}\r\n"]
[15.874627, "o", "\u001b[?2004hroot@519702dcd9db:/app# "]
[15.989751, "i", "cat /app/src/b1/mod.rs\n"]
[15.989922, "o", "cat /app/src/b1/mod.rs"]
[15.990291, "o", "\r\n\u001b[?2004l\r"]
[15.991501, "o", "pub struct B0 {\r\n    pub v: Vec<usize>,\r\n}\r\n\r\nimpl B0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: (0..n).collect() }\r\n    }\r\n}\r\n\r\npub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {\r\n    let out = b.to_vec();\r\n    if a.v.len() == b.len() {\r\n        a.v.sort();\r\n    }\r\n    out\r\n}\r\n"]
[15.991784, "o", "\u001b[?2004h"]
[15.991912, "o", "root@519702dcd9db:/app# "]
[16.108877, "i", "cat /app/src/c2/mod.rs\n"]
[16.109275, "o", "cat /app/src/c2/mod.rs"]
[16.109318, "o", "\r\n\u001b[?2004l\r"]
[16.110477, "o", "pub struct C0 {\r\n    pub v: Vec<i32>,\r\n}\r\n\r\nimpl C0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: vec![0; n] }\r\n    }\r\n}\r\n\r\npub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {\r\n    let value: i32 = c.iter().sum();\r\n    let k = b % a.v.len();\r\n    a.v[k] += value;\r\n    a.v[k]\r\n}\r\n"]
[16.110631, "o", "\u001b[?2004h"]
[16.110683, "o", "root@519702dcd9db:/app# "]
