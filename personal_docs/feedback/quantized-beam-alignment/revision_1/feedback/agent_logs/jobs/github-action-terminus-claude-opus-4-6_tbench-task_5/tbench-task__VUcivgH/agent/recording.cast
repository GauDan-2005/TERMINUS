[16.490022, "o", "cat /app/src/f5/mod.rs\r\n\u001b[?2004l\r"]
[16.493196, "o", "pub fn view(a: &[i32]) -> String {\r\n    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\"|\")\r\n}\r\n\r\npub fn lens(a: &[i32]) -> usize {\r\n    a.len()\r\n}\r\n"]
[16.493358, "o", "\u001b[?2004h"]
