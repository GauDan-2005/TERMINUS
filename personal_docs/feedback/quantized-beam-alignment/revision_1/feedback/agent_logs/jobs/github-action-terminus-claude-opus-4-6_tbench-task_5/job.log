Sending keys: ['cat > /app/cmd/align/main.go << \'GOEOF\'\npackage main\n\nimport (\n\t"encoding/json"\n\t"os"\n\t"reflect"\n)\n\ntype entry struct {\n\tCase      string `json:"case"`\n\tProduced  []int  `json:"produced"`\n\tTrace     []int  `json:"slot_trace"`\n\tOrderUsed []int  `json:"order_used"`\n\tPacked    bool   `json:"packed"`\n\tGrouped   bool   `json:"grouped"`\n\tReuse     bool   `json:"reuse"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:"raw"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:"rows"`\n\tSummary map[string]any `json:"summary"`\n}\n\nfunc matches(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic("usage: align raw final")\n\t}\n\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// New report rows are the raw rows directly\n\tnewRows := raw.Raw\n\n\t// Check if existing report.json exists\n\tagree := true\n\treportPath := os.Args[2]\n\tif oldBuf, err := os.ReadFile(reportPath); err == nil {\n\t\tvar oldReport finalDoc\n\t\tif err := json.Unmarshal(oldBuf, &oldReport); err == nil {\n\t\t\t// Build map of old report rows by case name\n\t\t\toldMap := make(map[string]entry)\n\t\t\tfor _, row := range oldReport.Rows {\n\t\t\t\toldMap[row.Case] = row\n\t\t\t}\n\t\t\t// Compare old report rows against incoming raw rows\n\t\t\t// Any case-level mismatch means agree = false\n\t\t\trawMap := make(map[string]entry)\n\t\t\tfor _, row := range raw.Raw {\n\t\t\t\trawMap[row.Case] = row\n\t\t\t}\n\t\t\t// Check all raw cases exist in old report and match\n\t\t\tfor caseName, rawRow := range rawMap {\n\t\t\t\toldRow, exists := oldMap[caseName]\n\t\t\t\tif !exists || !matches(rawRow, oldRow) {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\t// Check all old report cases exist in raw\n\t\t\tif agree {\n\t\t\t\tfor caseName := range oldMap {\n\t\t\t\t\tif _, exists := rawMap[caseName]; !exists {\n\t\t\t\t\t\tagree = false\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t} else {\n\t\t// No existing report - new report rows match raw by construction\n\t\t// Verify explicitly\n\t\tfor i, row := range newRows {\n\t\t\tif i >= len(raw.Raw) || !matches(row, raw.Raw[i]) {\n\t\t\t\tagree = false\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif len(newRows) != len(raw.Raw) {\n\t\t\tagree = false\n\t\t}\n\t}\n\n\tdoc := finalDoc{\n\t\tRows: newRows,\n\t\tSummary: map[string]any{\n\t\t\t"total": len(newRows),\n\t\t\t"agree": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, "", "  ")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(reportPath, append(out, \'\\n\'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGOEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
