n"\n+  if len(os.Args) >= 2 {\n+    out = os.Args[1]\n+  }\n+\n+  rows := make([]entry, 0, len(cases()))\n+  for _, c := range cases() {\n+    rows = append(rows, runOne(c))\n+  }\n+\n+  doc := rawDoc{Raw: rows}\n+  buf, err := json.MarshalIndent(doc, "", "  ")\n+  if err != nil {\n+    panic(err)\n+  }\n+  if err := os.MkdirAll(filepath.Dir(out), 0o755); err != nil {\n+    panic(err)\n+  }\n+  if err := os.WriteFile(out, append(buf, \'\\n\'), 0o644); err != nil {\n+    panic(err)\n+  }\n+  fmt.Fprint(os.Stderr, "")\n+}\n+\n*** End Patch\nPATCH\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
