func bx(a *B0, b []int) []int {
	out := append([]int{}, b...)
	if len(a.v) == len(b) {
		sort.Ints(a.v)
	}
	return out
}

type C0 struct{ v []int }

func newC0(n int) *C0 { return &C0{v: make([]int, n)} }

func cx(a *C0, b int, c []int) int {
	value := 0
	for _, x := range c {
		value += x
	}
	k := b % len(a.v)
	a.v[k] += value
	return a.v[k]
}

func dx(a []int, b []int) []int {
	out := make([]int, 0, len(b))
	for _, i := range b {
		out = append(out, a[i])
	}
	return out
}

func token(sum int, slot int, packed bool, group bool, reuse bool) int {
	v := sum + slot*7
	if packed {
		v += 3
	}
	if group {
		v += 5
	}
	if reuse {
		v += 11
	}
	v %= 101
	if v < 0 {
		v += 101
	}
	return v
}

func cases() []Case {
	return []Case{
		{name: "alpha", packed: false, group: true, reuse: false, seq: []int{0, 1}, rows: [][]int{{21, 10, 4}, {15, 8, 6}}},
		{name: "beta", packed: true, group: false, reuse: false, seq: []int{0}, rows: [][]int{{10, 4, 1}}},
		{name: "gamma", packed: true, group: true, reuse: false, seq: []int{0, 1}, rows: [][]int{{8, 3, 2}, {6, 5, 1}}},
		{name: "delta", packed: true, group: true, reuse: false, seq: []int{1, 0}, rows: [][]int{{7, 4, 2}, {5, 6, 3}}},
		{name: "epsilon", packed: true, group: true, reuse: true, seq: []int{1, 0, 2}, rows: [][]int{{4, 7, 2}, {9, 2, 3}, {3, 8, 1}}},
		{name: "zeta", packed: false, group: true, reuse: true, seq: []int{2, 0, 1}, rows: [][]int{{12, 9, 5}, {18, 4, 7}, {10, 6, 8}}},
	}
}

func max(a, b int) int {
	if a > b {
		return a
	}
	return b
}

func runOne(c Case) entry {
	meta := newA0()
	h := newB0(len(c.rows))
	local := newC0(max(len(c.rows), 1))
	moved := bx(h, c.seq)

	baseRows := make([][]int, len(c.rows))
	for i, row := range c.rows {
		if c.packed {
			baseRows[i] = ax(meta, row, i)
		} else {
			baseRows[i] = append([]int{}, row...)
		}
	}

	ids := make([]int, len(baseRows))
	for i := range ids {
		ids[i] = i
	}
	_ = dx(ids, c.seq) // Rust computes "selected" but it is not required in raw.json.

	vals := make([]int, 0, len(c.seq))
	trace := make([]int, 0, len(c.seq))
	for pos, src := range c.seq {
		handle := moved[pos]
		acc := cx(local, handle, baseRows[src])
		vals = append(vals, token(acc, handle, c.packed, c.group, c.reuse))
		trace = append(trace, handle)
	}

	return entry{
		Case:      c.name,
		Produced:  vals,
		Trace:     trace,
		OrderUsed: append([]int{}, c.seq...),
		Packed:    c.packed,
		Grouped:   c.group,
		Reuse:     c.reuse,
	}
}

func main() {
	out := "/app/output/raw.json"
	if len(os.Args) >= 2 {
		out = os.Args[1]
	}

	rows := make([]entry, 0, len(cases()))
	for _, c := range cases() {
		rows = append(rows, runOne(c))
	}

	doc := rawDoc{Raw: rows}
	buf, err := json.MarshalIndent(doc, "", "  ")
	if err != nil {
		panic(err)
	}
	if err := os.MkdirAll(filepath.Dir(out), 0o755); err != nil {
		panic(err)
	}
	if err := os.WriteFile(out, append(buf, '\n'), 0o644); err != nil {
		panic(err)
	}
}
