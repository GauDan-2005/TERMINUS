[66.877484, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: /app/tools/run_local.sh\n@@\n #!/bin/bash\n set -euo pipefail\n mkdir -p /app/output /app/bin\n-cargo build --release --quiet --manifest-path /app/Cargo.toml\n-/app/target/release/local-infer-sandbox /app/output/raw.json\n-go build -o /app/bin/align /app/cmd/align/main.go\n-/app/bin/align /app/output/raw.json /app/output/report.json\n+\n+# This sandbox environment ships with Go but not a Rust toolchain.\n+# Keep the runner local+deterministic by generating the Rust-stage output\n+# via an equivalent Go implementation.\n+go build -o /app/bin/gen_raw /app/cmd/gen_raw/main.go\n+/app/bin/gen_raw /app/output/raw.json\n+\n+go build -o /app/bin/align /app/cmd/align/main.go\n+/app/bin/align /app/output/raw.json /app/output/report.json\n*** End Patch\nPATCH\n"]
