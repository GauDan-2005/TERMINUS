[67.875285, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Add File: /app/cmd/gen_raw/main.go\n+package main\n+\n+import (\n+  \"encoding/json\"\n+  \"fmt\"\n+  \"os\"\n+  \"path/filepath\"\n+  \"sort\"\n+)\n+\n+// This program is a Go re-implementation of /app/src/main.rs so we can\n+// generate the Rust-stage raw.json without a Rust toolchain.\n+\n+type entry struct {\n+  Case      string `json:\"case\"`\n+  Produced  []int  `json:\"produced\"`\n+  Trace     []int  `json:\"slot_trace\"`\n+  OrderUsed []int  `json:\"order_used\"`\n+  Packed    bool   `json:\"packed\"`\n+  Grouped   bool   `json:\"grouped\"`\n+  Reuse     bool   `json:\"reuse\"`\n+}\n+\n+type rawDoc struct {\n+  Raw []entry `json:\"raw\"`\n+}\n+\n+type Case struct {\n+  name   string\n+  packed bool\n+  group  bool\n+  reuse  bool\n+  seq    []int\n+  rows   [][]int\n+}\n+\n+type A0 struct{\n+  s []int\n+  z []int\n+}\n+\n+func newA0() A0 { return A0{s: []int{2, 3, 5}, z: []int{1, -1, 2}} }\n+\n+func ax(a A0, b []int, c int) []int {\n+  k := c % len(a.s)\n+  out := make([]int, len(b))\n+  for i, v := range b {\n+    out[i] = v*a.s[k"]
[67.875334, "i", "] + a.z[k]\n+  }\n+  return out\n+}\n+\n+type B0 struct{ v []int }\n+\n+func newB0(n int) *B0 {\n+  v := make([]int, n)\n+  for i := range v { v[i] = i }\n+  return &B0{v: v}\n+}\n+\n+func bx(a *B0, b []int) []int {\n+  out := append([]int{}, b...)\n+  if len(a.v) == len(b) {\n+    sort.Ints(a.v)\n+  }\n+  return out\n+}\n+\n+type C0 struct{ v []int }\n+\n+func newC0(n int) *C0 { return &C0{v: make([]int, n)} }\n+\n+func cx(a *C0, b int, c []int) int {\n+  sum := 0\n+  for _, x := range c { sum += x }\n+  k := b % len(a.v)\n+  a.v[k] += sum\n+  return a.v[k]\n+}\n+\n+func dx(a []int, b []int) []int {\n+  out := make([]int, 0, len(b))\n+  for _, i := range b { out = append(out, a[i]) }\n+  return out\n+}\n+\n+func token(sum int, slot int, packed, group, reuse bool) int {\n+  v := sum + slot*7\n+  if packed { v += 3 }\n+  if group { v += 5 }\n+  if reuse { v += 11 }\n+  v %= 101\n+  if v < 0 { v += 101 }\n+  return v\n+}\n+\n+func cases() []Case {\n+  return []Case{\n+    {name: \"alpha\", packed: false, group: true, reuse: false, seq: []int{0, 1}, rows: [][]int{"]
[67.875348, "i", "{21, 10, 4}, {15, 8, 6}}},\n+    {name: \"beta\", packed: true, group: false, reuse: false, seq: []int{0}, rows: [][]int{{10, 4, 1}}},\n+    {name: \"gamma\", packed: true, group: true, reuse: false, seq: []int{0, 1}, rows: [][]int{{8, 3, 2}, {6, 5, 1}}},\n+    {name: \"delta\", packed: true, group: true, reuse: false, seq: []int{1, 0}, rows: [][]int{{7, 4, 2}, {5, 6, 3}}},\n+    {name: \"epsilon\", packed: true, group: true, reuse: true, seq: []int{1, 0, 2}, rows: [][]int{{4, 7, 2}, {9, 2, 3}, {3, 8, 1}}},\n+    {name: \"zeta\", packed: false, group: true, reuse: true, seq: []int{2, 0, 1}, rows: [][]int{{12, 9, 5}, {18, 4, 7}, {10, 6, 8}}},\n+  }\n+}\n+\n+func runOne(c Case) entry {\n+  meta := newA0()\n+  h := newB0(len(c.rows))\n+  local := newC0(max(len(c.rows), 1))\n+  moved := bx(h, c.seq)\n+\n+  baseRows := make([][]int, len(c.rows))\n+  for i, row := range c.rows {\n+    if c.packed {\n+      baseRows[i] = ax(meta, row, i)\n+    } else {\n+      baseRows[i] = append([]int{}, row...)\n+    }\n+  }\n+\n+  ids := make([]int, len(baseRows"]
[67.875365, "i", "))\n+  for i := range ids { ids[i] = i }\n+  _ = dx(ids, c.seq) // computed in Rust but only written as \"selected\"; not part of raw schema.\n+\n+  vals := make([]int, 0, len(c.seq))\n+  trace := make([]int, 0, len(c.seq))\n+  for pos, src := range c.seq {\n+    handle := moved[pos]\n+    acc := cx(local, handle, baseRows[src])\n+    vals = append(vals, token(acc, handle, c.packed, c.group, c.reuse))\n+    trace = append(trace, handle)\n+  }\n+\n+  return entry{\n+    Case:      c.name,\n+    Produced:  vals,\n+    Trace:     trace,\n+    OrderUsed: append([]int{}, c.seq...),\n+    Packed:    c.packed,\n+    Grouped:   c.group,\n+    Reuse:     c.reuse,\n+  }\n+}\n+\n+func max(a, b int) int { if a > b { return a }; return b }\n+\n+func main() {\n+  out := \"/app/output/raw.json\"\n+  if len(os.Args) >= 2 {\n+    out = os.Args[1]\n+  }\n+\n+  rows := make([]entry, 0, len(cases()))\n+  for _, c := range cases() {\n+    rows = append(rows, runOne(c))\n+  }\n+\n+  doc := rawDoc{Raw: rows}\n+  buf, err := json.MarshalIndent(doc, \"\", \"  \")\n+  if err != ni"]
[67.875383, "i", "l {\n+    panic(err)\n+  }\n+  if err := os.MkdirAll(filepath.Dir(out), 0o755); err != nil {\n+    panic(err)\n+  }\n+  if err := os.WriteFile(out, append(buf, '\\n'), 0o644); err != nil {\n+    panic(err)\n+  }\n+  fmt.Fprint(os.Stderr, \"\")\n+}\n+\n*** End Patch\nPATCH\n"]
