[33.953551, "i", "for f in /app/src/*/mod.rs; do echo \"--- $f\"; sed -n '1,240p' \"$f\"; done\n"]
[33.955168, "o", "for f in /app/src/*/mod.rs; do echo \"--- $f\"; sed -n '1,240p' \"$f\"; done\r\n\u001b[?2004l\r"]
[33.955793, "o", "--- /app/src/a0/mod.rs\r\n"]
[33.957662, "o", "pub struct A0 {\r\n    pub s: Vec<i32>,\r\n    pub z: Vec<i32>,\r\n}\r\n\r\nimpl A0 {\r\n"]
[33.957685, "o", "    pub fn new() -> Self {\r\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\r\n    }\r\n}\r\n\r\npub fn ax(a: &A0, b: &[i32], c: usize) -> Vec<i32> {\r\n    let k = c % a.s.len();\r\n    b.iter().map(|v| v * a.s[k] + a.z[k]).collect()\r\n"]
[33.957704, "o", "}\r\n\r\npub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\r\n"]
[33.957716, "o", "    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()\r\n}\r\n"]
[33.958016, "o", "--- /app/src/b1/mod.rs\r\n"]
[33.959041, "o", "pub struct B0 {\r\n    pub v: Vec<usize>,\r\n}\r\n\r\nimpl B0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: (0..n).collect() }\r\n    }\r\n}\r\n\r\npub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {\r\n    let out = b.to_vec();\r\n"]
[33.959074, "o", "    if a.v.len() == b.len() {\r\n        a.v.sort();\r\n    }\r\n    out\r\n}\r\n"]
[33.959234, "o", "--- /app/src/c2/mod.rs\r\n"]
[33.96024, "o", "pub struct C0 {\r\n    pub v: Vec<i32>,\r\n}\r\n\r\nimpl C0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: vec![0; n] }\r\n    }\r\n}\r\n\r\npub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {\r\n    let value: i32 = c.iter().sum();\r\n    let k = b % a.v.len();\r\n    a.v[k] += value;\r\n    a.v[k]\r\n}\r\n"]
[33.960402, "o", "--- /app/src/d3/mod.rs\r\n"]
[33.961516, "o", "pub fn dx(a: &[i32], b: &[usize]) -> Vec<i32> {\r\n    b.iter().map(|i| a[*i]).collect()\r\n}\r\n\r\npub fn tag(a: &str, b: usize) -> String {\r\n    format!(\"{}:{}\", a, b)\r\n}\r\n"]
[33.961684, "o", "--- /app/src/e4/mod.rs\r\n"]
[33.962697, "o", "pub struct E0 {\r\n    pub v: Vec<String>,\r\n}\r\n\r\nimpl E0 {\r\n    pub fn new() -> Self {\r\n        Self { v: Vec::new() }\r\n    }\r\n}\r\n\r\npub fn ex(a: &mut E0, b: &str, c: &[i32], d: &[usize]) {\r\n    let vals = c.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\");\r\n    let hs = d.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\");\r\n"]
[33.962846, "o", "    a.v.push(format!(\"{{\\\"case\\\":\\\"{}\\\",\\\"produced\\\":[{}],\\\"slot_trace\\\":[{}]}}\", b, vals, hs));\r\n}\r\n"]
[33.962936, "o", "--- /app/src/f5/mod.rs\r\n"]
[33.963894, "o", "pub fn view(a: &[i32]) -> String {\r\n    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\"|\")\r\n}\r\n"]
[33.963935, "o", "\r\npub fn lens(a: &[i32]) -> usize {\r\n    a.len()\r\n}\r\n"]
[33.964121, "o", "--- /app/src/g6/mod.rs\r\n"]
[33.964959, "o", "pub fn arrange(a: &[usize]) -> Vec<usize> {\r\n    let mut x = a.to_vec();\r\n    x.sort();\r\n    x\r\n}\r\n\r\n"]
[33.965047, "o", "pub fn describe(a: &[usize]) -> String {\r\n    arrange(a).iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\"-\")\r\n}\r\n"]
