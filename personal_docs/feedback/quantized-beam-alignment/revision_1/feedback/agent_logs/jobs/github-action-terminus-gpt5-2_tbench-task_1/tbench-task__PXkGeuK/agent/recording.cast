[122.747099, "i", "cat > /app/cmd/align/main.go <<'GO'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"os\"\n\t\"sort\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc keyByCase(rows []entry) map[string]entry {\n\tm := make(map[string]entry, len(rows))\n\tfor _, r := range rows {\n\t\tm[r.Case] = r\n\t}\n\treturn m\n}\n\n// equalRow compares the six required fields (+case name).\nfunc equalRow(a, b entry) bool {\n\tif a.Case != b.Case || a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\tif len(a.Produced) != len(b.Produced) || len(a.Trace) != len(b.Trace) || len(a.OrderUsed) != len(b.OrderUsed) {\n\t\treturn false\n\t}\n\tfor i := range"]
[122.747324, "i", " a.Produced {\n\t\tif a.Produced[i] != b.Produced[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\tfor i := range a.Trace {\n\t\tif a.Trace[i] != b.Trace[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\tfor i := range a.OrderUsed {\n\t\tif a.OrderUsed[i] != b.OrderUsed[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc readFinal(path string) (finalDoc, error) {\n\tbuf, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn finalDoc{}, err\n\t}\n\tvar doc finalDoc\n\tif err := json.Unmarshal(buf, &doc); err != nil {\n\t\treturn finalDoc{}, err\n\t}\n\tif doc.Rows == nil {\n\t\treturn finalDoc{}, errors.New(\"final doc missing rows\")\n\t}\n\treturn doc, nil\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\trawPath := os.Args[1]\n\tfinalPath := os.Args[2]\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Report rows must cover the full case set; do not drop/merge.\n\trows := append([]entry{}, raw.Raw...)\n\tsort.Slice(rows, func(i, j int) bool { return rows[i].C"]
[122.747354, "o", "cat > /app/cmd/align/main.go <<'GO'"]
[122.747365, "i", "ase < rows[j].Case })\n\n\tagree := true\n\trawByCase := keyByCase(raw.Raw)\n\n\t// If a prior report exists at finalPath, agreement requires that it matches\n\t// incoming raw on the required fields for every case.\n\tif prior, err := readFinal(finalPath); err == nil {\n\t\tpriorByCase := keyByCase(prior.Rows)\n\t\tif len(priorByCase) != len(rawByCase) {\n\t\t\tagree = false\n\t\t} else {\n\t\t\tfor name, rr := range rawByCase {\n\t\t\t\tpr, ok := priorByCase[name]\n\t\t\t\tif !ok || !equalRow(rr, pr) {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(raw.Raw), \"agree\": agree}}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGO\n"]
