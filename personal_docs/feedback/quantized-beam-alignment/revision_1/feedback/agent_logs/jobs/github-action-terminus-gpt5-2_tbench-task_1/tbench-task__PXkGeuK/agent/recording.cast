[136.874568, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))\nrep=json.load(open('/app/output/report.json'))\nraw_by={r['case']:r for r in raw['raw']}\nrep_by={r['case']:r for r in rep['rows']}\nfields=['produced','slot_trace','order_used','packed','grouped','reuse']\nok=True\nfor k,v in raw_by.items():\n    if k not in rep_by:\n        print('missing in report',k); ok=False; continue\n    for f in fields:\n        if rep_by[k].get(f)!=v.get(f):\n            print('mismatch',k,f,rep_by[k].get(f),v.get(f)); ok=False\nfor k in rep_by:\n    if k not in raw_by:\n        print('extra in report',k); ok=False\nprint('row_match=',ok)\nprint('summary=',rep.get('summary'))\nPY\n"]
