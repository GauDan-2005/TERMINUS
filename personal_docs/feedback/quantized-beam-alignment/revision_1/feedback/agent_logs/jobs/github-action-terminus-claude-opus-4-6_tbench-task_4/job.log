try)\n\t\t\tfor _, r := range raw.Raw {\n\t\t\t\trawByCase[r.Case] = r\n\t\t\t}\n\t\t\t// Check every case: old report row must match raw row\n\t\t\t// All cases from both sets must be checked\n\t\t\tallCases := make(map[string]bool)\n\t\t\tfor _, r := range oldReport.Rows {\n\t\t\t\tallCases[r.Case] = true\n\t\t\t}\n\t\t\tfor _, r := range raw.Raw {\n\t\t\t\tallCases[r.Case] = true\n\t\t\t}\n\t\t\tfor c := range allCases {\n\t\t\t\toldRow, oldOk := oldByCase[c]\n\t\t\t\trawRow, rawOk := rawByCase[c]\n\t\t\t\tif !oldOk || !rawOk {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t\tif !fieldsMatch(oldRow, rawRow) {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t}\n\t// If no existing report, agree defaults to true (new report rows = raw rows, trivially match)\n\n\tdoc := finalDoc{\n\t\tRows:    newRows,\n\t\tSummary: map[string]any{"total": len(newRows), "agree": agree},\n\t}\n\tout, err := json.MarshalIndent(doc, "", "  ")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, \'\\n\'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGOEOF\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
