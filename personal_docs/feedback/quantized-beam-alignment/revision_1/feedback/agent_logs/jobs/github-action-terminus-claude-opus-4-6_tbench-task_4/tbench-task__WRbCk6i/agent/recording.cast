[212.879043, "o", "\u001b[?2004hroot@c1515ada6a18:/app# "]
[213.182184, "i", "cat > /app/cmd/align/main.go << 'GOEOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc fieldsMatch(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n"]
[213.182556, "i", "\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// New report rows come directly from raw, one per case, same order\n\tnewRows := raw.Raw\n\n\t// Determine agree: compare against existing report.json if present\n\tagree := true\n\texistingBuf, err := os.ReadFile(os.Args[2])\n\tif err == nil {\n\t\t// Existing report found - compare old report rows against incoming raw\n\t\tvar oldReport finalDoc\n\t\tif err := json.Unmarshal(existingBuf, &oldReport); err == nil {\n\t\t\t// Build map of old report rows by case name\n\t\t\toldByCase := make(map[string]entry)\n\t\t\tfor _, r := range oldReport.Rows {\n\t\t\t\toldByCase[r.Case] = r\n\t\t\t}\n\t\t\t// Build map of raw rows by case name\n\t\t\trawByCase := make(map[string]entry)\n\t\t\tfor _, r := range raw.Raw {\n\t\t\t\trawByCase[r.Case] = r\n\t\t\t}\n\t\t\t// Check every case: old report row must match raw row\n\t\t\t// All cases from both sets must be checked\n\t\t\tallCases := make(map[string]bool)\n\t\t\tfor _, r := range oldRepor"]
[213.182769, "o", "cat > /app/cmd/align/main.go << 'GOEOF'\r\n\u001b[?2004l\r\u001b[?2004h> package main\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[213.182793, "i", "t.Rows {\n\t\t\t\tallCases[r.Case] = true\n\t\t\t}\n\t\t\tfor _, r := range raw.Raw {\n\t\t\t\tallCases[r.Case] = true\n\t\t\t}\n\t\t\tfor c := range allCases {\n\t\t\t\toldRow, oldOk := oldByCase[c]\n\t\t\t\trawRow, rawOk := rawByCase[c]\n\t\t\t\tif !oldOk || !rawOk {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t\tif !fieldsMatch(oldRow, rawRow) {\n\t\t\t\t\tagree = false\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tagree = false\n\t\t}\n\t}\n\t// If no existing report, agree defaults to true (new report rows = raw rows, trivially match)\n\n\tdoc := finalDoc{\n\t\tRows:    newRows,\n\t\tSummary: map[string]any{\"total\": len(newRows), \"agree\": agree},\n\t}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nGOEOF\n"]
