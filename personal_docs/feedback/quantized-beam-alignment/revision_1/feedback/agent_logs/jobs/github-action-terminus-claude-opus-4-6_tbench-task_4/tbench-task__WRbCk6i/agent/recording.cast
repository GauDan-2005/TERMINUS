[213.483126, "o", "\r\n\u001b[?2004l\r"]
[213.483204, "o", "\u001b[?2004h> "]
[213.483321, "o", "fn render_usize(a: &[usize]) -> String {\r\n\u001b[?2004l\r"]
[213.483387, "o", "\u001b[?2004h> "]
[213.483589, "o", "    a.iter().map(|x| x.to_string()).collect::<Vec<_>>().join(\",\")\r\n\u001b[?2004l\r"]
[213.483629, "o", "\u001b[?2004h"]
[213.483648, "o", "> }\r\n"]
[213.48366, "o", "\u001b[?2004l\r"]
[213.483672, "o", "\u001b[?2004h"]
[213.483769, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[213.4838, "o", "> "]
[213.483868, "o", "fn run_one(c: &Case) -> String {\r\n\u001b[?2004l\r"]
[213.483889, "o", "\u001b[?2004h"]
[213.483975, "o", "> "]
[213.484031, "o", "    let meta = a0::A0::new();\r\n\u001b[?2004l\r"]
[213.484108, "o", "\u001b[?2004h> "]
[213.48422, "o", "    let mut h = b1::B0::new(c.rows.len());\r\n\u001b[?2004l\r"]
[213.484267, "o", "\u001b[?2004h> "]
[213.484431, "o", "    let mut local = c2::C0::new(c.rows.len().max(1));\r\n\u001b[?2004l\r"]
[213.484496, "o", "\u001b[?2004h> "]
[213.484607, "o", "    let moved = b1::bx(&mut h, &c.seq);\r\n\u001b[?2004l\r"]
[213.484677, "o", "\u001b[?2004h> "]
[213.484886, "o", "    let base_rows: Vec<Vec<i32>> = c.rows.iter().enumerate().map(|(i, row)| {\r\n\u001b[?2004l\r"]
[213.484943, "o", "\u001b[?2004h> "]
[213.485151, "o", "        if c.packed { a0::ax(&meta, row, i) } else { row.clone() }\r\n\u001b[?2004l\r"]
[213.485222, "o", "\u001b[?2004h> "]
[213.485304, "o", "    }).collect();\r\n\u001b[?2004l\r"]
[213.485366, "o", "\u001b[?2004h> "]
[213.485642, "o", "    let _chosen = d3::dx(&(0..base_rows.len()).map(|i| i as i32).collect::<Vec<_>>(), &c.seq);\r\n\u001b[?2004l\r"]
[213.485717, "o", "\u001b[?2004h> "]
[213.485807, "o", "    let mut vals = Vec::new();\r\n\u001b[?2004l\r"]
[213.485829, "o", "\u001b[?2004h> "]
[213.485943, "o", "    let mut trace = Vec::new();\r\n\u001b[?2004l\r"]
[213.485985, "o", "\u001b[?2004h"]
[213.486051, "o", "> "]
[213.486205, "o", "    for (pos, src) in c.seq.iter().enumerate() {\r\n\u001b[?2004l\r"]
[213.486245, "o", "\u001b[?2004h"]
[213.486287, "o", "> "]
[213.486408, "o", "        let handle = moved[pos];\r\n\u001b[?2004l\r"]
[213.486472, "o", "\u001b[?2004h> "]
[213.486711, "o", "        let acc = c2::cx(&mut local, handle, &base_rows[*src]);\r\n"]
[213.48677, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[213.486976, "o", "        vals.push(token(acc, handle, c.packed, c.group, c.reuse));\r\n\u001b[?2004l\r"]
[213.487008, "o", "\u001b[?2004h"]
[213.487021, "o", "> "]
[213.487127, "o", "        trace.push(handle);\r\n"]
[213.487172, "o", "\u001b[?2004l\r\u001b[?2004h"]
[213.487219, "o", "> "]
[213.48725, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.487269, "o", "> "]
[213.487381, "o", "    let mut sink = e4::E0::new();\r\n\u001b[?2004l\r"]
[213.487443, "o", "\u001b[?2004h> "]
[213.48761, "o", "    e4::ex(&mut sink, c.name, &vals, &trace);\r\n\u001b[?2004l\r"]
[213.487671, "o", "\u001b[?2004h> "]
[213.487773, "o", "    let _display = f5::view(&vals);\r\n\u001b[?2004l\r"]
[213.487822, "o", "\u001b[?2004h"]
[213.487839, "o", "> "]
[213.48797, "o", "    let _shape = g6::describe(&trace);\r\n\u001b[?2004l\r"]
[213.488015, "o", "\u001b[?2004h"]
[213.488032, "o", "> "]
[213.488418, "o", "    format!(\"{{\\\"case\\\":\\\"{}\\\",\\\"produced\\\":[{}],\\\"slot_trace\\\":[{}],\\\"order_used\\\":[{}],\\\"packed\\\":{},\\\"grouped\\\":{},\\\"reuse\\\":{}}}\",\r\n\u001b[?2004l\r"]
[213.488463, "o", "\u001b[?2004h"]
[213.488479, "o", "> "]
[213.488803, "o", "        c.name, render_nums(&vals), render_usize(&trace), render_usize(&c.seq), c.packed, c.group, c.reuse)\r\n\u001b[?2004l\r"]
[213.488842, "o", "\u001b[?2004h> "]
[213.488902, "o", "}\r\n\u001b[?2004l\r"]
[213.48898, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[213.489002, "o", "\u001b[?2004h> fn main() {\r\n\u001b[?2004l\r"]
[213.489061, "o", "\u001b[?2004h"]
[213.489077, "o", "> "]
[213.489235, "o", "    let args: Vec<String> = env::args().collect();\r\n\u001b[?2004l\r"]
[213.489285, "o", "\u001b[?2004h"]
[213.489304, "o", "> "]
[213.48958, "o", "    let out = args.get(1).cloned().unwrap_or_else(|| \"/app/output/raw.json\".to_string());\r\n\u001b[?2004l\r"]
[213.48962, "o", "\u001b[?2004h> "]
[213.489857, "o", "    let rows = cases().iter().map(run_one).collect::<Vec<_>>().join(\",\");\r\n\u001b[?2004l\r"]
[213.489904, "o", "\u001b[?2004h"]
[213.489921, "o", "> "]
[213.490087, "o", "    let body = format!(\"{{\\\"raw\\\":[{}]}}\\n\", rows);\r\n\u001b[?2004l\r"]
[213.490133, "o", "\u001b[?2004h> "]
[213.49033, "o", "    if let Some(parent) = std::path::Path::new(&out).parent() {\r\n\u001b[?2004l\r"]
[213.490418, "o", "\u001b[?2004h> "]
[213.490558, "o", "        fs::create_dir_all(parent).unwrap();\r\n\u001b[?2004l\r"]
[213.490625, "o", "\u001b[?2004h>     }\r\n"]
[213.490642, "o", "\u001b[?2004l\r"]
[213.490692, "o", "\u001b[?2004h> "]
[213.490835, "o", "    fs::write(out, body).unwrap();\r\n\u001b[?2004l\r"]
[213.490927, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[213.490991, "o", "\u001b[?2004h> RSEOF\r\n\u001b[?2004l\r"]
[213.491947, "o", "\u001b[?2004hroot@c1515ada6a18:/app# "]
