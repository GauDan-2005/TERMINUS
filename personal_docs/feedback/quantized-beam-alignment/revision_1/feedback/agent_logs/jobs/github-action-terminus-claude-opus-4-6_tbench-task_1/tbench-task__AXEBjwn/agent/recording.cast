[228.849713, "i", "cat > /app/cmd/align/main.go << 'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"reflect\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc entriesMatch(a, b entry) bool {\n\tif !reflect.DeepEqual(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !reflect.DeepEqual(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed {\n\t\treturn false\n\t}\n\tif a.Grouped != b.Grouped {\n\t\treturn false\n\t}\n\tif a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc computeAgree(rawRows []entry, reportRows []entry) bool {\n\tif len(rawRows) != len(reportRows) {\n\t\treturn false\n\t}"]
[228.849952, "i", "\n\t// Build map by case name for report rows\n\treportMap := make(map[string]entry)\n\tfor _, r := range reportRows {\n\t\treportMap[r.Case] = r\n\t}\n\tfor _, raw := range rawRows {\n\t\trep, ok := reportMap[raw.Case]\n\t\tif !ok {\n\t\t\treturn false\n\t\t}\n\t\tif !entriesMatch(raw, rep) {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\tbuf, err := os.ReadFile(os.Args[1])\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Report rows are direct copies of raw rows\n\tnewRows := make([]entry, len(raw.Raw))\n\tcopy(newRows, raw.Raw)\n\n\tagree := true\n\n\t// If report.json already exists, compare incoming raw against prior report\n\treportPath := os.Args[2]\n\tif priorBuf, err := os.ReadFile(reportPath); err == nil {\n\t\tvar prior finalDoc\n\t\tif err := json.Unmarshal(priorBuf, &prior); err == nil {\n\t\t\t// Compare raw rows against prior report rows\n\t\t\tif !computeAgree(raw.Raw, prior.Rows) {\n\t\t\t\tagree = false\n\t\t\t}\n\t\t} el"]
[228.850072, "i", "se {\n\t\t\tagree = false\n\t\t}\n\t}\n\n\t// Also verify new report rows match raw (should always be true since they're copies)\n\tif agree {\n\t\tagree = computeAgree(raw.Raw, newRows)\n\t}\n\n\tdoc := finalDoc{\n\t\tRows: newRows,\n\t\tSummary: map[string]any{\n\t\t\t\"total\": len(newRows),\n\t\t\t\"agree\": agree,\n\t\t},\n\t}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.WriteFile(reportPath, append(out, '\\n'), 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
[228.850209, "o", "cat > /app/cmd/align/main.go << 'EOF'"]
