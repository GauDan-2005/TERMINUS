[178.860615, "o", "{\"raw\":[{\"case\":\"alpha\",\"produced\":[40,41],\"slot_trace\":[0,1],\"order_used\":[0,1],\"packed\":false,\"grouped\":true,\"reuse\":false,\"selected\":[0,1]},{\"case\":\"beta\",\"produced\":[36],\"slot_trace\":[0],\"order_used\":[0],\"packed\":true,\"grouped\":false,\"reuse\":false,\"selected\":[0]},{\"case\":\"gamma\",\"produced\":[37,48],\"slot_trace\":[0,1],\"order_used\":[0,1],\"packed\":true,\"grouped\":true,\"reuse\":false,\"selected\":[0,1]},{\"case\":\"delta\",\"produced\":[54,37],\"slot_trace\":[1,0],\"order_used\":[1,0],\"packed\":true,\"grouped\":true,\"reuse\":false,\"selected\":[1,0]},{\"case\":\"epsilon\",\"produced\":[65,48,99],\"slot_trace\":[1,0,2],\"order_used\":[1,0,2],\"packed\":true,\"grouped\":true,\"reuse\":true,\"selected\":[1,0,2]},{\"case\":\"zeta\",\"produced\":[54,42,52],\"slot_trace\":[2,0,1],\"order_used\":[2,0,1],\"packed\":false,\"grouped\":true,\"reuse\":true,\"selected\":[2,0,1]}]}\r\n"]
