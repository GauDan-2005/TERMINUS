Sending keys: ['apply_patch<<\'PATCH\'\n*** Begin Patch\n*** Add File: cmd/align/main.go\n+package main\n+\n+import (\n+  "bytes"\n+  "encoding/json"\n+  "errors"\n+  "os"\n+  "path/filepath"\n+  "sort"\n+)\n+\n+type entry struct {\n+  Case      string `json:"case"`\n+  Produced  []int  `json:"produced"`\n+  Trace     []int  `json:"slot_trace"`\n+  OrderUsed []int  `json:"order_used"`\n+  Packed    bool   `json:"packed"`\n+  Grouped   bool   `json:"grouped"`\n+  Reuse     bool   `json:"reuse"`\n+}\n+\n+type rawDoc struct {\n+  Raw []entry `json:"raw"`\n+}\n+\n+type finalDoc struct {\n+  Rows    []entry        `json:"rows"`\n+  Summary map[string]any `json:"summary"`\n+}\n+\n+func readJSONFile[T any](path string, out *T) error {\n+  b, err := os.ReadFile(path)\n+  if err != nil {\n+    return err\n+  }\n+  dec := json.NewDecoder(bytes.NewReader(b))\n+  dec.DisallowUnknownFields()\n+  return dec.Decode(out)\n+}\n+\n+func toMap(rows []entry) (map[string]entry, error) {\n+  m := make(map[string]entry, len(rows))\n+  for _, r := range rows {\n+    if r.Case == "" {\n+      return nil, errors.New("row missing case")\n+    }\n+    if _, ok := m[r.Case]; ok {\n+      return nil, errors.New("duplicate case: " + r.Case)\n+    }\n+    m[r.Case] = r\n+  }\n+  return m, nil\n+}\n+\n+func eqSlice(a, b []int) bool {\n+  if len(a) != len(b) {\n+    return false\n+  }\n+  for i := range a {\n+    if a[i] != b[i] {\n+      return false\n+    }\n+  }\n+  return true\n+}\n+\n+// Compare across the six required fields.\n+func sameSix(a, b entry) bool {\n+  return a.Case == b.Case &&\n+    eqSlice(a.Produced, b.Produced) &&\n+    eqSlice(a.Trace, b.Trace) &&\n+    eqSlice(a.OrderUsed, b.OrderUsed) &&\n+    a.Packed == b.Packed &&\n+    a.Grouped == b.Grouped &&\n+    a.Reuse == b.Reuse\n+}\n+\n+func main() {\n+  if len(os.Args) != 3 {\n+    panic("usage: align raw final")\n+  }\n+  rawPath := os.Args[1]\n+  finalPath := os.Args[2]\n+\n+  // Load incoming raw.\n+  var raw rawDoc\n+  if err := readJSONFile(rawPath, &raw); err != nil {\n+    panic(err)\n+  }\n+  rawMap, err := toMap(raw.Raw)\n+  if err != nil {\n+    panic(err)\n+  }\n+\n+  // Build rows: one per raw entry, sorted by case.\n+  rows := make([]entry, 0, len(raw.Raw))\n+  for _, r := range raw.Raw {\n+    rows = append(rows, r)\n+  }\n+  sort.Slice(rows, func(i, j int) bool { return rows[i].Case < rows[j].Case })\n+\n+  // agree is true iff:\n+  // 1) new report rows match raw across the six fields for each case name.\n+  // 2) if an old report exists at finalPath, it matches the newly generated\n+  //    report rows across the six fields for each case name.\n+  agree := true\n+\n+  // (1) Compare new rows to raw.\n+  if len(rows) != len(rawMap) {\n+    agree = false\n+  }\n+  for _, r := range rows {\n+    rr, ok := rawMap[r.Case]\n+    if !ok || !sameSix(r, rr) {\n+      agree = false\n+      break\n+    }\n+  }\n+\n+  // (2) Compare against prior report, if present.\n+  if _, err := os.Stat(finalPath); err == nil {\n+    var prior finalDoc\n+    if err := readJSONFile(finalPath, &prior); err == nil {\n+      priorMap, err := toMap(prior.Rows)\n+      if err != nil {\n+        agree = false\n+      } else {\n+        newMap, _ := toMap(rows)\n+        if len(priorMap) != len(newMap) {\n+          agree = false\n+        } else {\n+          for name, pr := range priorMap {\n+            nr, ok := newMap[name]\n+            if !ok || !sameSix(pr, nr) {\n+              agree = false\n+              break\n+            }\n+          }\n+        }\n+      }\n+    } else {\n+      // If we can\'t stat for reasons other than not-exist, fail hard.\n+      panic(err)\n+    }\n+  }\n+\n+  doc := finalDoc{\n+    Rows:    rows,\n+    Summary: map[string]any{"total": len(rows), "agree": agree},\n+  }\n+  out, err := json.MarshalIndent(doc, "", "  ")\n+  if err != nil {\n+    panic(err)\n+  }\n+  if err := os.MkdirAll(filepath.Dir(finalPath), 0o755); err != nil {\n+    panic(err)\n+  }\n+  if err := os.WriteFile(finalPath, append(out, \'\\n\'), 0o644); err != nil {\n+    panic(err)\n+  }\n+}\n+\n*** End Patch\nPATCH\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
