[132.127879, "o", "#!/bin/bash\r\nset -euo pipefail\r\n\r\nmkdir -p /app/output /app/bin\r\n\r\n# Rust toolchain isn't available in this sandbox image; generate the Rust-stage\r\n# raw.json via a deterministic Go equivalent.\r\ngo build -o /app/bin/localinfer /app/cmd/localinfer/main.go\r\n/app/bin/localinfer /app/output/raw.json\r\n\r\n# Collate raw -> report.\r\ngo build -o /app/bin/align /app/cmd/align/main.go\r\n/app/bin/align /app/output/raw.json /app/output/report.json\r\n\u001b[?2004hroot@dbc8229de6ff:/app# sed -n '1,240p' /app/cmd/align/main.go\r\n\u001b[?2004l\rpackage main\r\n\r\nimport (\r\n\t\"bytes\"\r\n\t\"encoding/json\"\r\n\t\"errors\"\r\n\t\"os\"\r\n\t\"path/filepath\"\r\n\t\"sort\"\r\n)\r\n\r\ntype entry struct {\r\n\tCase      string `json:\"case\"`\r\n\tProduced  []int  `json:\"produced\"`\r\n\tTrace     []int  `json:\"slot_trace\"`\r\n\tOrderUsed []int  `json:\"order_used\"`\r\n\tPacked    bool   `json:\"packed\"`\r\n\tGrouped   bool   `json:\"grouped\"`\r\n\tReuse     bool   `json:\"reuse\"`\r\n}\r\n\r\ntype rawDoc struct {\r\n\tRaw []entry `json:\"raw\"`\r\n}\r\n\r\ntype finalDoc struct {\r\n\tRows    []entry        `json:\"rows\"`\r\n\tSumm"]
[132.127951, "o", "ary map[string]any `json:\"summary\"`\r\n}\r\n\r\nfunc readJSONFile[T any](path string, out *T) error {\r\n\tb, err := os.ReadFile(path)\r\n\tif err != nil {\r\n\t\treturn err\r\n\t}\r\n\tdec := json.NewDecoder(bytes.NewReader(b))\r\n\tdec.DisallowUnknownFields()\r\n\treturn dec.Decode(out)\r\n}\r\n\r\nfunc toMap(rows []entry) (map[string]entry, error) {\r\n\tm := make(map[string]entry, len(rows))\r\n\tfor _, r := range rows {\r\n\t\tif r.Case == \"\" {\r\n\t\t\treturn nil, errors.New(\"row missing case\")\r\n\t\t}\r\n\t\tif _, ok := m[r.Case]; ok {\r\n\t\t\treturn nil, errors.New(\"duplicate case: \" + r.Case)\r\n\t\t}\r\n\t\tm[r.Case] = r\r\n\t}\r\n\treturn m, nil\r\n}\r\n\r\nfunc eqSlice(a, b []int) bool {\r\n\tif len(a) != len(b) {\r\n\t\treturn false\r\n\t}\r\n\tfor i := range a {\r\n\t\tif a[i] != b[i] {\r\n\t\t\treturn false\r\n\t\t}\r\n\t}\r\n\treturn true\r\n}\r\n\r\n// sameSix compares the six required fields, keyed by case name.\r\nfunc sameSix(a, b entry) bool {\r\n\treturn a.Case == b.Case &&\r\n\t\teqSlice(a.Produced, b.Produced) &&\r\n\t\teqSlice(a.Trace, b.Trace) &&\r\n\t\teqSlice(a.OrderUsed, b.OrderUsed) &&\r\n\t\ta.Packed == b.Packed &&"]
[132.128001, "o", "\r\n\t\ta.Grouped == b.Grouped &&\r\n\t\ta.Reuse == b.Reuse\r\n}\r\n\r\nfunc main() {\r\n\tif len(os.Args) != 3 {\r\n\t\tpanic(\"usage: align raw final\")\r\n\t}\r\n\trawPath := os.Args[1]\r\n\tfinalPath := os.Args[2]\r\n\r\n\t// Load incoming raw.\r\n\tvar raw rawDoc\r\n\tif err := readJSONFile(rawPath, &raw); err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\trawMap, err := toMap(raw.Raw)\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\r\n\t// Produce one report row per raw row, sorted. (No folding/dropping.)\r\n\trows := make([]entry, 0, len(raw.Raw))\r\n\trows = append(rows, raw.Raw...)\r\n\tsort.Slice(rows, func(i, j int) bool { return rows[i].Case < rows[j].Case })\r\n\r\n\tagree := true\r\n\r\n\t// Compare new report rows vs incoming raw rows.\r\n\tnewMap, err := toMap(rows)\r\n\tif err != nil {\r\n\t\tagree = false\r\n\t} else {\r\n\t\tif len(newMap) != len(rawMap) {\r\n\t\t\tagree = false\r\n\t\t}\r\n\t\tfor name, rr := range rawMap {\r\n\t\t\tnr, ok := newMap[name]\r\n\t\t\tif !ok || !sameSix(nr, rr) {\r\n\t\t\t\tagree = false\r\n\t\t\t\tbreak\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\r\n\t// If replacing an existing report.json, compare prior report rows to newly\r\n\t//"]
[132.128017, "o", " generated report rows across those six fields.\r\n\tif _, err := os.Stat(finalPath); err == nil {\r\n\t\tvar prior finalDoc\r\n\t\tif err := readJSONFile(finalPath, &prior); err != nil {\r\n\t\t\tagree = false\r\n\t\t} else {\r\n\t\t\tpriorMap, err := toMap(prior.Rows)\r\n\t\t\tif err != nil {\r\n\t\t\t\tagree = false\r\n\t\t\t} else if len(priorMap) != len(newMap) {\r\n\t\t\t\tagree = false\r\n\t\t\t} else {\r\n\t\t\t\tfor name, pr := range priorMap {\r\n\t\t\t\t\tnr, ok := newMap[name]\r\n\t\t\t\t\tif !ok || !sameSix(pr, nr) {\r\n\t\t\t\t\t\tagree = false\r\n\t\t\t\t\t\tbreak\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\r\n\tdoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": agree}}\r\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\tif err := os.MkdirAll(filepath.Dir(finalPath), 0o755); err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\tif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n}\r\n\u001b[?2004hroot@dbc8229de6ff:/app# "]
