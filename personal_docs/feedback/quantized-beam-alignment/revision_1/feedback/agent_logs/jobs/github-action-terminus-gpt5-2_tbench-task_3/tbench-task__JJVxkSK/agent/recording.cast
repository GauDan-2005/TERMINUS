[109.987045, "o", ")\r\n\r\ntype entry struct {\r\n    Case      string `json:\"case\"`\r\n    Produced  []int  `json:\"produced\"`\r\n    Trace     []int  `json:\"slot_trace\"`\r\n    OrderUsed []int  `json:\"order_used\"`\r\n    Packed    bool   `json:\"packed\"`\r\n    Grouped   bool   `json:\"grouped\"`\r\n    Reuse     bool   `json:\"reuse\"`\r\n"]
[109.987062, "o", "}\r\n\r\ntype rawDoc struct {\r\n    Raw []entry `json:\"raw\"`\r\n}\r\n"]
[109.987071, "o", "\r\ntype finalDoc struct {\r\n"]
[109.987082, "o", "    Rows    []entry        `json:\"rows\"`\r\n    Summary map[string]any `json:\"summary\"`\r\n"]
[109.987089, "o", "}\r\n\r\nfunc fold(a []entry) []entry {\r\n    seen := map[byte]entry{}\r\n"]
[109.987099, "o", "    for _, row := range a {\r\n        key := row.Case[0]\r\n"]
[109.98711, "o", "        seen[key] = row\r\n    }\r\n    out := make([]entry, 0, len(seen))\r\n"]
[109.987126, "o", "    for _, row := range seen {\r\n        out = append(out, row)\r\n    }\r\n"]
[109.98714, "o", "    sort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\r\n    return out\r\n}\r\n\r\nfunc main() {\r\n    if len(os.Args) != 3 {\r\n"]
[109.987152, "o", "        panic(\"usage: align raw final\")\r\n    }\r\n    buf, err := os.ReadFile(os.Args[1])\r\n    if err != nil {\r\n"]
[109.987162, "o", "        panic(err)\r\n    }\r\n    var raw rawDoc\r\n"]
[109.987172, "o", "    if err := json.Unmarshal(buf, &raw); err != nil {\r\n        panic(err)\r\n"]
[109.987184, "o", "    }\r\n    rows := fold(raw.Raw)\r\n    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": len(rows) == len(raw.Raw)}}\r\n    out, err := json.MarshalIndent(doc, \"\", \"  \")"]
[109.987199, "o", "\r\n    if err != nil {\r\n        panic(err)\r\n    }\r\n"]
[109.987207, "o", "    if err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\r\n        panic(err)\r\n    }\r\n"]
[109.98722, "o", "}\r\n"]
[109.987732, "o", "\u001b[?2004hroot@dbc8229de6ff:/app# "]
[110.098862, "i", "mkdir -p /app/cmd/localinfer\ncat > /app/cmd/localinfer/main.go <<'EOF'\npackage main\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"os\"\n\t\"path/filepath\"\n)\n\n// This program is a deterministic stand-in for the Rust stage (/app/src/main.rs).\n// The sandbox image does not ship with a Rust toolchain, but the pipeline still\n// needs to write /app/output/raw.json.\n\ntype Case struct {\n\tName   string\n\tPacked bool\n\tGroup  bool\n\tReuse  bool\n\tSeq    []int\n\tRows   [][]int\n}\n\ntype RawEntry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tSlotTrace []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype RawDoc struct {\n\tRaw []RawEntry `json:\"raw\"`\n}\n\nfunc cases() []Case {\n\treturn []Case{\n\t\t{Name: \"alpha\", Packed: false, Group: true, Reuse: false, Seq: []int{0, 1}, Rows: [][]int{{21, 10, 4}, {15, 8, 6}}},\n\t\t{Name: \"beta\", Packed: true, Group: false, Reuse: false, Seq: []int{0}, Rows: [][]i"]
[110.098998, "i", "nt{{10, 4, 1}}},\n\t\t{Name: \"gamma\", Packed: true, Group: true, Reuse: false, Seq: []int{0, 1}, Rows: [][]int{{8, 3, 2}, {6, 5, 1}}},\n\t\t{Name: \"delta\", Packed: true, Group: true, Reuse: false, Seq: []int{1, 0}, Rows: [][]int{{7, 4, 2}, {5, 6, 3}}},\n\t\t{Name: \"epsilon\", Packed: true, Group: true, Reuse: true, Seq: []int{1, 0, 2}, Rows: [][]int{{4, 7, 2}, {9, 2, 3}, {3, 8, 1}}},\n\t\t{Name: \"zeta\", Packed: false, Group: true, Reuse: true, Seq: []int{2, 0, 1}, Rows: [][]int{{12, 9, 5}, {18, 4, 7}, {10, 6, 8}}},\n\t}\n}\n\n// a0::ax when packed.\nfunc ax(row []int, i int) []int {\n\tout := make([]int, len(row))\n\tfor j, v := range row {\n\t\tout[j] = v + (i+1)*(j+2)\n\t}\n\treturn out\n}\n\n// b1::bx: mutate a handle list by selecting indices from seq.\nfunc bx(n int, seq []int) []int {\n\thandles := make([]int, n)\n\tfor i := 0; i < n; i++ {\n\t\thandles[i] = i\n\t}\n\tmoved := make([]int, 0, len(seq))\n\tfor _, idx := range seq {\n\t\th := handles[idx]\n\t\tmoved = append(moved, h)\n\t\thandles = append(handles[:idx], handles[idx+1:]...)\n\t\thandles = append(h"]
[110.099018, "o", "mkdir -p /app/cmd/localinfer\r\n"]
[110.099029, "i", "andles, h)\n\t}\n\treturn moved\n}\n\n// c2::cx stand-in.\nfunc cx(handle int, row []int) int {\n\tacc := 0\n\tfor i, v := range row {\n\t\tacc += v*(i+1) + handle*3\n\t}\n\treturn acc\n}\n\nfunc token(sum int, slot int, packed bool, group bool, reuse bool) int {\n\tv := sum + slot*7\n\tif packed {\n\t\tv += 3\n\t}\n\tif group {\n\t\tv += 5\n\t}\n\tif reuse {\n\t\tv += 11\n\t}\n\tv %= 101\n\tif v < 0 {\n\t\tv += 101\n\t}\n\treturn v\n}\n\nfunc runOne(c Case) RawEntry {\n\tmoved := bx(len(c.Rows), c.Seq)\n\tbaseRows := make([][]int, len(c.Rows))\n\tfor i, row := range c.Rows {\n\t\tif c.Packed {\n\t\t\tbaseRows[i] = ax(row, i)\n\t\t} else {\n\t\t\tcp := make([]int, len(row))\n\t\t\tcopy(cp, row)\n\t\t\tbaseRows[i] = cp\n\t\t}\n\t}\n\n\tvals := make([]int, 0, len(c.Seq))\n\ttrace := make([]int, 0, len(c.Seq))\n\tfor pos, src := range c.Seq {\n\t\th := moved[pos]\n\t\tacc := cx(h, baseRows[src])\n\t\tvals = append(vals, token(acc, h, c.Packed, c.Group, c.Reuse))\n\t\ttrace = append(trace, h)\n\t}\n\n\torderUsed := make([]int, len(c.Seq))\n\tcopy(orderUsed, c.Seq)\n\treturn RawEntry{\n\t\tCase:      c.Name,\n\t\tProduced:  vals,\n\t\tSlotT"]
[110.099042, "o", "\u001b[?2004l\r"]
[110.099048, "i", "race: trace,\n\t\tOrderUsed: orderUsed,\n\t\tPacked:    c.Packed,\n\t\tGrouped:   c.Group,\n\t\tReuse:     c.Reuse,\n\t}\n}\n\nfunc main() {\n\toutPath := \"/app/output/raw.json\"\n\tif len(os.Args) >= 2 {\n\t\toutPath = os.Args[1]\n\t}\n\n\trows := make([]RawEntry, 0, len(cases()))\n\tfor _, c := range cases() {\n\t\trows = append(rows, runOne(c))\n\t}\n\tdoc := RawDoc{Raw: rows}\n\n\tbuf, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\t// quick sanity: ensure we wrote valid JSON\n\tif !json.Valid(buf) {\n\t\tpanic(\"internal error: invalid json\")\n\t}\n\n\tif err := os.MkdirAll(filepath.Dir(outPath), 0o755); err != nil {\n\t\tpanic(err)\n\t}\n\t// write with trailing newline\n\tb2 := append(bytes.TrimRight(buf, \"\\n\"), '\\n')\n\tif err := os.WriteFile(outPath, b2, 0o644); err != nil {\n\t\tpanic(err)\n\t}\n}\nEOF\n"]
