[142.245117, "i", "python3 - <<'PY'\nimport json\np='/app/output/report.json'\nd=json.load(open(p))\n# flip one produced token for alpha to force a prior mismatch\nfor r in d['rows']:\n  if r['case']=='alpha' and r['produced']:\n    r['produced'][0] = (r['produced'][0] + 1) % 101\n    break\njson.dump(d, open(p,'w'), indent=2)\nopen(p,'a').write('\\n')\nprint('tampered prior report.json')\nPY\n"]
