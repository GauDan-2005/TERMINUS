[123.360028, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))\nrep=json.load(open('/app/output/report.json'))\nprint('raw keys',raw.keys(),'raw rows',len(raw['raw']))\nprint('rep keys',rep.keys(),'rep rows',len(rep['rows']),'summary',rep['summary'])\n# verify case-level equality across required fields\nreq=('produced','slot_trace','order_used','packed','grouped','reuse')\nrm={r['case']:r for r in raw['raw']}\nok=True\nfor r in rep['rows']:\n  rr=rm.get(r['case'])\n  if not rr:\n    ok=False; print('missing in raw',r['case']); continue\n  for k in req:\n    if r[k]!=rr[k]:\n      ok=False; print('mismatch',r['case'],k,r[k],rr[k])\nprint('field_match',ok)\nPY\n"]
