  return &C0{v: make([]int, n)}\n}\n\n// Rust c2::cx\nfunc (c *C0) cx(b int, row []int) int {\n  sum := 0\n  for _, x := range row {\n    sum += x\n  }\n  k := b % len(c.v)\n  c.v[k] += sum\n  return c.v[k]\n}\n\n// Rust token\nfunc token(sum int, slot int, packed bool, group bool, reuse bool) int {\n  v := sum + slot*7\n  if packed {\n    v += 3\n  }\n  if group {\n    v += 5\n  }\n  if reuse {\n    v += 11\n  }\n  v %= 101\n  if v < 0 {\n    v += 101\n  }\n  return v\n}\n\nfunc max(a, b int) int {\n  if a > b {\n    return a\n  }\n  return b\n}\n\nfunc runOne(c Case) entry {\n  h := len(c.Rows)\n  moved := bx(h, c.Seq)\n  local := newC0(max(h, 1))\n\n  baseRows := make([][]int, len(c.Rows))\n  for i, row := range c.Rows {\n    if c.Packed {\n      baseRows[i] = ax(row, i)\n    } else {\n      baseRows[i] = append([]int(nil), row...)\n    }\n  }\n\n  idx := make([]int, len(baseRows))\n  for i := range baseRows {\n    idx[i] = i\n  }\n  chosen := make([]int, 0, len(c.Seq))\n  for _, si := range c.Seq {\n    chosen = append(chosen, idx[si])\n  }\n\n  vals := make([]int, 0, len(c.Seq))\n  trace := make([]int, 0, len(c.Seq))\n  for pos, src := range c.Seq {\n    handle := moved[pos]\n    acc := local.cx(handle, baseRows[src])\n    vals = append(vals, token(acc, handle, c.Packed, c.Group, c.Reuse))\n    trace = append(trace, handle)\n  }\n\n  return entry{\n    Case:      c.Name,\n    Produced:  vals,\n    Trace:     trace,\n    OrderUsed: append([]int(nil), c.Seq...),\n    Packed:    c.Packed,\n    Grouped:   c.Group,\n    Reuse:     c.Reuse,\n    Selected:  chosen,\n  }\n}\n\nfunc main() {\n  out := "/app/output/raw.json"\n  if len(os.Args) > 1 {\n    out = os.Args[1]\n  }\n\n  cs := cases()\n  rows := make([]entry, 0, len(cs))\n  for _, c := range cs {\n    rows = append(rows, runOne(c))\n  }\n  sort.Slice(rows, func(i, j int) bool { return rows[i].Case < rows[j].Case })\n\n  doc := rawDoc{Raw: rows}\n  buf, err := json.MarshalIndent(doc, "", "  ")\n  if err != nil {\n    panic(err)\n  }\n  if err := os.MkdirAll(filepath.Dir(out), 0o755); err != nil {\n    panic(err)\n  }\n  if err := os.WriteFile(out, append(buf, \'\\n\'), 0o644); err != nil {\n    panic(err)\n  }\n  fmt.Fprintln(os.Stderr, "wrote", out)\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
