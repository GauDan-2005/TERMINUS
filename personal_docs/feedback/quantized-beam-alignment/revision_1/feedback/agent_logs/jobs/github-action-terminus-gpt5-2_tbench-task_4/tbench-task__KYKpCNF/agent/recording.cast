[112.618345, "o", "\u001b[?2004hroot@805b9b4a7de5:/app# "]
[112.731923, "i", "find /app/src -maxdepth 3 -type f -name '*.rs' -print | sort\n"]
[112.732482, "o", "find /app/src -maxdepth 3 -type f -name '*.rs' -print | sort\r\n\u001b[?2004l\r"]
[112.734216, "o", "/app/src/a0/mod.rs\r\n/app/src/b1/mod.rs\r\n/app/src/c2/mod.rs\r\n/app/src/d3/mod.rs\r\n/app/src/e4/mod.rs\r\n/app/src/f5/mod.rs\r\n/app/src/g6/mod.rs\r\n/app/src/main.rs\r\n"]
[112.735819, "o", "\u001b[?2004h"]
[112.735845, "o", "root@805b9b4a7de5:/app# "]
[112.859853, "i", "for f in /app/src/*/mod.rs; do echo \"--- $f\"; sed -n '1,220p' \"$f\"; done\n"]
[112.860158, "o", "for f in /app/src/*/mod.rs; do echo \"--- $f\"; sed -n '1,220p' \"$f\"; done\r\n"]
[112.860189, "o", "\u001b[?2004l\r"]
[112.860392, "o", "--- /app/src/a0/mod.rs\r\n"]
[112.862743, "o", "pub struct A0 {\r\n    pub s: Vec<i32>,\r\n    pub z: Vec<i32>,\r\n}\r\n\r\nimpl A0 {\r\n    pub fn new() -> Self {\r\n        Self { s: vec![2, 3, 5], z: vec![1, -1, 2] }\r\n    }\r\n}\r\n\r\npub fn ax(a: &A0, b: &[i32], c: usize) -> Vec<i32> {\r\n    let k = c % a.s.len();\r\n    b.iter().map(|v| v * a.s[k] + a.z[k]).collect()\r\n}\r\n"]
[112.862932, "o", "\r\npub fn ax_ref(a: &A0, b: &[i32]) -> Vec<i32> {\r\n    b.iter().enumerate().map(|(i, v)| v * a.s[i] + a.z[i]).collect()\r\n}\r\n"]
[112.863139, "o", "--- /app/src/b1/mod.rs\r\n"]
[112.863963, "o", "pub struct B0 {\r\n    pub v: Vec<usize>,\r\n}\r\n\r\nimpl B0 {\r\n"]
[112.863989, "o", "    pub fn new(n: usize) -> Self {\r\n        Self { v: (0..n).collect() }\r\n    }\r\n}\r\n\r\npub fn bx(a: &mut B0, b: &[usize]) -> Vec<usize> {\r\n    let out = b.to_vec();\r\n    if a.v.len() == b.len() {\r\n"]
[112.864001, "o", "        a.v.sort();\r\n    }\r\n    out\r\n}\r\n"]
[112.864162, "o", "--- /app/src/c2/mod.rs\r\n"]
[112.865018, "o", "pub struct C0 {\r\n    pub v: Vec<i32>,\r\n}\r\n\r\n"]
[112.865034, "o", "impl C0 {\r\n    pub fn new(n: usize) -> Self {\r\n        Self { v: vec![0; n] }\r\n    }\r\n}\r\n\r\npub fn cx(a: &mut C0, b: usize, c: &[i32]) -> i32 {\r\n    let value: i32 = c.iter().sum();\r\n"]
[112.865049, "o", "    let k = b % a.v.len();\r\n    a.v[k] += value;\r\n    a.v[k]\r\n"]
[112.865059, "o", "}\r\n"]
[112.866246, "o", "--- /app/src/d3/mod.rs\r\n"]
[112.867018, "o", "pub fn dx(a: &[i32], b: &[usize]) -> Vec<i32> {\r\n    b.iter().map(|i| a[*i]).collect()\r\n}\r\n\r\npub fn tag(a: &str, b: usize) -> String {\r\n    format!(\"{}:{}\", a, b)\r\n"]
