[214.436029, "i", "python3 - <<'PY'\nimport json\np='/app/output/report.json'\nd=json.load(open(p))\n# corrupt one field deterministically\nif d['rows']:\n    d['rows'][0]['produced'][0] = (d['rows'][0]['produced'][0] + 1) % 101\nopen(p,'w').write(json.dumps(d,indent=2)+\"\\n\")\nprint('corrupted',d['rows'][0]['case'])\nPY\n"]
