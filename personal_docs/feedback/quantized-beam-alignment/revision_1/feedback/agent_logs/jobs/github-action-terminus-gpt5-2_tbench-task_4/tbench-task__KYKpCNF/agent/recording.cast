[200.372409, "i", "ls -la /app/output && echo '---' && python3 - <<'PY'\nimport json,sys\nraw=json.load(open('/app/output/raw.json'))\nrep=json.load(open('/app/output/report.json'))\nprint('raw_len',len(raw.get('raw',[])))\nprint('report_len',len(rep.get('rows',[])))\nprint('agree',rep.get('summary',{}).get('agree'))\nprint('total',rep.get('summary',{}).get('total'))\nprint('raw_cases',sorted([r['case'] for r in raw['raw']]))\nprint('rep_cases',sorted([r['case'] for r in rep['rows']]))\nPY\n"]
