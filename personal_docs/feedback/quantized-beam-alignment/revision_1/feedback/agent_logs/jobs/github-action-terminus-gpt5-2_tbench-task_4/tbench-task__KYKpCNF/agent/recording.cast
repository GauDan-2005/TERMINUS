[200.373823, "o", "\u001b[?2004h> "]
[200.37765, "o", "print('report_len',len(rep.get('rows',[])))\r\n\u001b[?2004l\r\u001b[?2004h> print('agree',rep.get('summary',{}).get('agree'))\r\n\u001b[?2004l\r\u001b[?2004h> print('total',rep.get('summary',{}).get('total'))\r\n\u001b[?2004l\r\u001b[?2004h> print('raw_cases',sorted([r['case'] for r in raw['raw']]))\r\n\u001b[?2004l\r\u001b[?2004h> print('rep_cases',sorted([r['case'] for r in rep['rows']]))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\rtotal 8\r\ndrwxr-xr-x  2 root root   41 May 25 16:03 .\r\ndrwxr-xr-x 11 root root  184 May 25 16:00 ..\r\n-rw-r--r--  1 root root 1912 May 25 16:03 raw.json\r\n-rw-r--r--  1 root root 1656 May 25 16:03 report.json\r\n---\r\n"]
[200.393642, "o", "raw_len 6\r\nreport_len 6\r\nagree True\r\ntotal 6\r\n"]
[200.393675, "o", "raw_cases ['alpha', 'beta', 'delta', 'epsilon', 'gamma', 'zeta']\r\nrep_cases ['alpha', 'beta', 'delta', 'epsilon', 'gamma', 'zeta']\r\n"]
[200.396557, "o", "\u001b[?2004hroot@805b9b4a7de5:/app# "]
[211.312258, "i", "go build -o /app/bin/align /app/cmd/align/main.go\n"]
[211.312503, "o", "go build -o /app/bin/align /app/cmd/align/main.go\r\n\u001b[?2004l\r"]
[211.354226, "o", "\u001b[?2004hroot@805b9b4a7de5:/app# "]
[213.319994, "i", "sed -n '1,240p' /app/cmd/align/main.go\n"]
[213.320404, "o", "sed -n '1,240p' /app/cmd/align/main.go\r\n\u001b[?2004l\r"]
[213.321723, "o", "package main\r\n\r\nimport (\r\n\"encoding/json\"\r\n\"errors\"\r\n\"os\"\r\n\"path/filepath\"\r\n"]
[213.321769, "o", "\"sort\"\r\n)\r\n"]
[213.321893, "o", "\r\n"]
[213.321939, "o", "type entry struct {\r\nCase      string `json:\"case\"`\r\nProduced  []int  `json:\"produced\"`\r\n"]
[213.321954, "o", "Trace     []int  `json:\"slot_trace\"`\r\nOrderUsed []int  `json:\"order_used\"`\r\nPacked    bool   `json:\"packed\"`\r\nGrouped   bool   `json:\"grouped\"`\r\nReuse     bool   `json:\"reuse\"`\r\n"]
[213.322032, "o", "}\r\n\r\ntype rawDoc struct {\r\nRaw []entry `json:\"raw\"`\r\n}\r\n\r\n"]
[213.322067, "o", "type finalDoc struct {\r\nRows    []entry        `json:\"rows\"`\r\nSummary map[string]any `json:\"summary\"`\r\n}\r\n\r\nfunc stableRows(a []entry) []entry {\r\nout := append([]entry(nil), a...)\r\n"]
[213.322094, "o", "sort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\r\n"]
[213.322176, "o", "return out\r\n}\r\n\r\ntype byCase map[string]entry\r\n\r\nfunc indexRows(a []entry) (byCase, error) {\r\nm := make(byCase, len(a))\r\nfor _, r := range a {\r\nif r.Case == \"\" {\r\nreturn nil, errors.New(\"row missing case\")\r\n}\r\nif _, ok := m[r.Case]; ok {\r\nreturn nil, errors.New(\"duplicate case: \" + r.Case)\r\n}\r\nm[r.Case] = r\r\n"]
[213.322189, "o", "}\r\nreturn m, nil\r\n}\r\n\r\nfunc eqSlice(a, b []int) bool {\r\nif len(a) != len(b) {\r\nreturn false\r\n"]
[213.322271, "o", "}\r\nfor i := range a {\r\nif a[i] != b[i] {\r\nreturn false\r\n}\r\n}\r\n"]
[213.322314, "o", "return true\r\n}\r\n\r\nfunc sameSix(a, b entry) bool {\r\nif a.Case != b.Case {\r\nreturn false\r\n}\r\n"]
[213.322342, "o", "if !eqSlice(a.Produced, b.Produced) {\r\nreturn false\r\n}\r\nif !eqSlice(a.Trace, b.Trace) {\r\n"]
[213.322428, "o", "return false\r\n"]
[213.322508, "o", "}\r\nif !eqSlice(a.OrderUsed, b.OrderUsed) {\r\nreturn false\r\n}\r\nif a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\r\nreturn false\r\n}\r\nreturn true\r\n}\r\n\r\nfunc agreeAgainstRaw(raw []entry, rows []entry) (bool, error) {\r\nrawIdx, err := indexRows(raw)\r\nif err != nil {\r\nreturn false, err\r\n}\r\nrowIdx, err := indexRows(rows)\r\nif err != nil {\r\nreturn false, err\r\n}\r\nif len(rawIdx) != len(rowIdx) {\r\nreturn false, nil\r\n}\r\nfor k, rv := range rawIdx {\r\nfv, ok := rowIdx[k]\r\nif !ok {\r\nreturn false, nil\r\n}\r\nif !sameSix(rv, fv) {\r\nreturn false, nil\r\n}\r\n}\r\nreturn true, nil\r\n}\r\n"]
[213.322521, "o", "\r\nfunc main() {\r\nif len(os.Args) != 3 {\r\npanic(\"usage: align raw final\")\r\n}\r\n\r\nrawPath := os.Args[1]\r\nfinalPath := os.Args[2]\r\n\r\nbuf, err := os.ReadFile(rawPath)\r\nif err != nil {\r\npanic(err)\r\n}\r\nvar raw rawDoc\r\nif err := json.Unmarshal(buf, &raw); err != nil {\r\npanic(err)\r\n}\r\n\r\n// rows: 1:1 with raw, sorted deterministically.\r\n"]
[213.322662, "o", "rows := stableRows(raw.Raw)\r\n\r\nagreeNew, err := agreeAgainstRaw(raw.Raw, rows)\r\nif err != nil {\r\npanic(err)\r\n}\r\n\r\n// Any mismatch between prior stored report rows and the incoming raw rows forces agree=false.\r\nagreePrior := true\r\nif oldBuf, err := os.ReadFile(finalPath); err == nil {\r\n"]
[213.32268, "o", "var prior finalDoc\r\nif err := json.Unmarshal(oldBuf, &prior); err == nil {\r\nagreePrior, err = agreeAgainstRaw(raw.Raw, prior.Rows)\r\nif err != nil {\r\nagreePrior = false\r\n}\r\n"]
[213.322762, "o", "} else {\r\nagreePrior = false\r\n}\r\n}\r\n\r\ndoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": (agreeNew && agreePrior)}}\r\nout, err := json.MarshalIndent(doc, \"\", \"  \")\r\n"]
[213.322803, "o", "if err != nil {\r\npanic(err)\r\n}\r\nif err := os.MkdirAll(filepath.Dir(finalPath), 0o755); err != nil {\r\npanic(err)\r\n}\r\nif err := os.WriteFile(finalPath, append(out, '\\n'), 0o644); err != nil {\r\n"]
[213.322832, "o", "panic(err)\r\n"]
[213.322931, "o", "}\r\n"]
[213.323174, "o", "}\r\n"]
[213.323233, "o", "\u001b[?2004hroot@805b9b4a7de5:/app# "]
[213.431928, "i", "python3 - <<'PY'\nimport json\nraw=json.load(open('/app/output/raw.json'))['raw']\nrep=json.load(open('/app/output/report.json'))['rows']\nraw_by={r['case']:r for r in raw}\nrep_by={r['case']:r for r in rep}\nfields=['produced','slot_trace','order_used','packed','grouped','reuse']\nok=True\nfor k,v in raw_by.items():\n    if k not in rep_by:\n        print('missing in report',k); ok=False; continue\n    for f in fields:\n        if rep_by[k].get(f)!=v.get(f):\n            print('mismatch',k,f,'raw=',v.get(f),'rep=',rep_by[k].get(f)); ok=False\nfor k in rep_by:\n    if k not in raw_by:\n        print('extra in report',k); ok=False\nprint('all_match',ok)\nPY\n"]
