[112.391489, "i", "sed -n '1,200p' /app/cmd/align/main.go\n"]
[112.391819, "o", "sed -n '1,200p' /app/cmd/align/main.go"]
[112.392099, "o", "\r\n\u001b[?2004l\r"]
[112.392923, "o", "package main\r\n\r\nimport (\r\n    \"encoding/json\"\r\n    \"os\"\r\n    \"sort\"\r\n)\r\n"]
[112.393, "o", "\r\ntype entry struct {\r\n    Case      string `json:\"case\"`\r\n    Produced  []int  `json:\"produced\"`\r\n    Trace     []int  `json:\"slot_trace\"`\r\n    OrderUsed []int  `json:\"order_used\"`\r\n    Packed    bool   `json:\"packed\"`\r\n    Grouped   bool   `json:\"grouped\"`\r\n    Reuse     bool   `json:\"reuse\"`\r\n}\r\n\r\ntype rawDoc struct {\r\n    Raw []entry `json:\"raw\"`\r\n}\r\n\r\ntype finalDoc struct {\r\n    Rows    []entry        `json:\"rows\"`\r\n    Summary map[string]any `json:\"summary\"`\r\n}\r\n\r\nfunc fold(a []entry) []entry {\r\n    seen := map[byte]entry{}\r\n    for _, row := range a {\r\n"]
[112.393051, "o", "        key := row.Case[0]\r\n        seen[key] = row\r\n    }\r\n"]
[112.393068, "o", "    out := make([]entry, 0, len(seen))\r\n    for _, row := range seen {\r\n        out = append(out, row)\r\n    }\r\n    sort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\r\n    return out\r\n}\r\n\r\nfunc main() {\r\n    if len(os.Args) != 3 {\r\n"]
[112.393076, "o", "        panic(\"usage: align raw final\")\r\n    }\r\n"]
[112.393088, "o", "    buf, err := os.ReadFile(os.Args[1])\r\n"]
[112.39311, "o", "    if err != nil {\r\n        panic(err)\r\n    }\r\n    var raw rawDoc\r\n"]
[112.393119, "o", "    if err := json.Unmarshal(buf, &raw); err != nil {\r\n        panic(err)\r\n"]
[112.39313, "o", "    }\r\n    rows := fold(raw.Raw)\r\n"]
[112.393139, "o", "    doc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": len(rows) == len(raw.Raw)}}\r\n"]
[112.393151, "o", "    out, err := json.MarshalIndent(doc, \"\", \"  \")\r\n"]
[112.393159, "o", "    if err != nil {\r\n        panic(err)\r\n"]
[112.39317, "o", "    }\r\n    if err := os.WriteFile(os.Args[2], append(out, '\\n'), 0o644); err != nil {\r\n"]
[112.393294, "o", "        panic(err)\r\n    }\r\n}\r\n"]
[112.393789, "o", "\u001b[?2004hroot@805b9b4a7de5:/app# "]
[112.503731, "i", "sed -n '1,240p' /app/internal/collate/table.go\n"]
[112.503988, "o", "sed -n '1,240p' /app/internal/collate/table.go\r\n\u001b[?2004l\r"]
[112.505247, "o", "package collate\r\n\r\nimport \"strings\"\r\n\r\nfunc Mix(a string) string {\r\n    return strings.TrimSpace(a)\r\n}\r\n\r\nfunc Keep(a []string) []string {\r\n    out := append([]string{}, a...)\r\n    return out\r\n"]
[112.505313, "o", "}\r\n"]
