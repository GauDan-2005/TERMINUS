[194.557484, "i", "cat > /app/cmd/align/main.go <<'EOF'\npackage main\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n)\n\ntype entry struct {\n\tCase      string `json:\"case\"`\n\tProduced  []int  `json:\"produced\"`\n\tTrace     []int  `json:\"slot_trace\"`\n\tOrderUsed []int  `json:\"order_used\"`\n\tPacked    bool   `json:\"packed\"`\n\tGrouped   bool   `json:\"grouped\"`\n\tReuse     bool   `json:\"reuse\"`\n}\n\ntype rawDoc struct {\n\tRaw []entry `json:\"raw\"`\n}\n\ntype finalDoc struct {\n\tRows    []entry        `json:\"rows\"`\n\tSummary map[string]any `json:\"summary\"`\n}\n\nfunc stableRows(a []entry) []entry {\n\tout := append([]entry(nil), a...)\n\tsort.Slice(out, func(i, j int) bool { return out[i].Case < out[j].Case })\n\treturn out\n}\n\ntype byCase map[string]entry\n\nfunc indexRows(a []entry) (byCase, error) {\n\tm := make(byCase, len(a))\n\tfor _, r := range a {\n\t\tif r.Case == \"\" {\n\t\t\treturn nil, errors.New(\"row missing case\")\n\t\t}\n\t\tif _, ok := m[r.Case]; ok {\n\t\t\treturn nil, errors.New(\"duplicate case: \" + r.Case)\n\t\t}\n\t\tm[r.Case] = r\n\t}\n\treturn m, nil\n"]
[194.557769, "i", "}\n\nfunc eqSlice(a, b []int) bool {\n\tif len(a) != len(b) {\n\t\treturn false\n\t}\n\tfor i := range a {\n\t\tif a[i] != b[i] {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc sameSix(a, b entry) bool {\n\tif a.Case != b.Case {\n\t\treturn false\n\t}\n\tif !eqSlice(a.Produced, b.Produced) {\n\t\treturn false\n\t}\n\tif !eqSlice(a.Trace, b.Trace) {\n\t\treturn false\n\t}\n\tif !eqSlice(a.OrderUsed, b.OrderUsed) {\n\t\treturn false\n\t}\n\tif a.Packed != b.Packed || a.Grouped != b.Grouped || a.Reuse != b.Reuse {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc agreeAgainstRaw(raw []entry, rows []entry) (bool, error) {\n\trawIdx, err := indexRows(raw)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\trowIdx, err := indexRows(rows)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\tif len(rawIdx) != len(rowIdx) {\n\t\treturn false, nil\n\t}\n\tfor k, rv := range rawIdx {\n\t\tfv, ok := rowIdx[k]\n\t\tif !ok {\n\t\t\treturn false, nil\n\t\t}\n\t\tif !sameSix(rv, fv) {\n\t\t\treturn false, nil\n\t\t}\n\t}\n\treturn true, nil\n}\n\nfunc main() {\n\tif len(os.Args) != 3 {\n\t\tpanic(\"usage: align raw final\")\n\t}\n\n\trawPath := os.Args[1"]
[194.557857, "o", "cat > /app/cmd/align/main.go <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.557927, "i", "]\n\tfinalPath := os.Args[2]\n\n\tbuf, err := os.ReadFile(rawPath)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tvar raw rawDoc\n\tif err := json.Unmarshal(buf, &raw); err != nil {\n\t\tpanic(err)\n\t}\n\n\t// rows: 1:1 with raw, sorted deterministically.\n\trows := stableRows(raw.Raw)\n\n\tagreeNew, err := agreeAgainstRaw(raw.Raw, rows)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\t// Any mismatch between prior stored report rows and the incoming raw rows forces agree=false.\n\tagreePrior := true\n\tif oldBuf, err := os.ReadFile(finalPath); err == nil {\n\t\tvar prior finalDoc\n\t\tif err := json.Unmarshal(oldBuf, &prior); err == nil {\n\t\t\tagreePrior, err = agreeAgainstRaw(raw.Raw, prior.Rows)\n\t\t\tif err != nil {\n\t\t\t\tagreePrior = false\n\t\t\t}\n\t\t} else {\n\t\t\tagreePrior = false\n\t\t}\n\t}\n\n\tdoc := finalDoc{Rows: rows, Summary: map[string]any{\"total\": len(rows), \"agree\": (agreeNew && agreePrior)}}\n\tout, err := json.MarshalIndent(doc, \"\", \"  \")\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\tif err := os.MkdirAll(filepath.Dir(finalPath), 0o755); err != nil {\n\t\tpanic(err)\n\t}\n\tif err := o"]
