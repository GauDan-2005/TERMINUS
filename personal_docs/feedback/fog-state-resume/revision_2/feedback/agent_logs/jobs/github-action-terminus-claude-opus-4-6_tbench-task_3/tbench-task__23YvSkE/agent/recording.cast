[87.711842, "o", "package g6\r\n\r\nimport \"fmt\"\r\n\r\nfunc PackPreview(grid []string) string {\r\n\tout := \"\"\r\n\tfor _, row := range grid {\r\n\t\tout += row + \"\\n\"\r\n\t}\r\n\treturn fmt.Sprintf(\"%d rows\", len(grid))\r\n}\r\n\r\nfunc Preview(grid []string) string {\r\n\treturn PackPreview(grid)\r\n}\r\n"]
