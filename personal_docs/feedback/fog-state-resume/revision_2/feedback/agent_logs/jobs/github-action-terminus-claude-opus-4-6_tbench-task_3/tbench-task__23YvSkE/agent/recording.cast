[152.922896, "i", "cat > /tmp/sight_fix.py << 'EOF'\nimport re\n\nwith open('/app/internal/vis/sight.go', 'r') as f:\n    content = f.read()\n\n# Replace the broken PlayerSees function\nold = '''func PlayerSees(w *sim.World, x, y int) bool {\n        if !w.InBounds(x, y) {\n                return false\n        }\n        idx := w.Idx(x, y)\n        if idx >= len(w.Seen) || idx >= len(w.Lit) {\n                return false\n        }\n        litIdx := idx\n        }\n        return w.Seen[idx] && w.Lit[litIdx]\n}'''\n\nnew = '''func PlayerSees(w *sim.World, x, y int) bool {\n        if !w.InBounds(x, y) {\n                return false\n        }\n        idx := w.Idx(x, y)\n        if idx >= len(w.Seen) || idx >= len(w.Lit) {\n                return false\n        }\n        return w.Seen[idx] && w.Lit[idx]\n}'''\n\ncontent = content.replace(old, new)\n\nwith open('/app/internal/vis/sight.go', 'w') as f:\n    f.write(content)\n\nprint(\"Done\")\nEOF\npython3 /tmp/sight_fix.py\n"]
