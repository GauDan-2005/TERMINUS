[8.872946, "o", "/app/Makefile\r\n/app/README.md\r\n/app/bin/rogctl\r\n/app/cmd/rogctl/main.go\r\n/app/config/profiles.toml\r\n/app/config/sight.tsv\r\n/app/config/weights.tsv\r\n/app/data/layouts/bishop.map\r\n/app/data/layouts/knight.map\r\n/app/data/layouts/lancer.map\r\n/app/data/layouts/ranger.map\r\n/app/data/layouts/rook.map\r\n/app/data/layouts/sentinel.map\r\n/app/data/layouts/warden.map\r\n/app/data/scenarios.tsv\r\n/app/data/scripts/bishop.tsv\r\n/app/data/scripts/knight.tsv\r\n/app/data/scripts/lancer.tsv\r\n/app/data/scripts/ranger.tsv\r\n/app/data/scripts/rook.tsv\r\n/app/data/scripts/sentinel.tsv\r\n/app/data/scripts/warden.tsv\r\n/app/docs/architecture.md\r\n/app/docs/audit-format.md\r\n/app/docs/operations.md\r\n/app/go.mod\r\n/app/internal/exec/run.go\r\n/app/internal/exec/types.go\r\n/app/internal/g6/render.go\r\n/app/internal/h7/stats.go\r\n/app/internal/mem/cache.go\r\n/app/internal/mod/effect.go\r\n/app/internal/sim/layout.go\r\n/app/internal/sim/profile.go\r\n/app/internal/sim/types.go\r\n/app/internal/sim/world.go\r\n/app/internal/slot/plan.go\r\n/app/internal/store/pack.go\r\n/app/internal/vis/native.go\r\n/app/internal/vis/sight.go\r\n/app/probe/legality.c\r\n/app/probe/legality.h\r\n/app/probe/list.c\r\n/app/scripts/clean-room.sh\r\n/app/scripts/one-case.sh\r\n/app/scripts/run-matrix.sh\r\n"]
