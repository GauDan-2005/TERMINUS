[25.590582, "o", "\u001b[?2004hroot@3c832fb61d9b:/app# "]
[25.701272, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    j=json.load(f)\ncases=j.get('cases',[])\nbad=[c for c in cases if not c.get('ok',False)]\nprint('total',len(cases),'bad',len(bad))\nfor c in bad[:50]:\n    print('---')\n    print('case',c.get('case') or c.get('name') or c.get('id'))\n    print('visibility',c.get('visibility'))\n    for k in ['ok','fresh','resume']:\n        if k in c:\n            print(k, c[k])\n    for k,v in c.items():\n        if isinstance(v,dict) and ('signature' in v or 'illegal' in v or 'moves' in v or 'effects' in v):\n            pass\n    # common fields observed in prior audits\n    for side in ['fresh','resume']:\n        s=c.get(side,{})\n        if isinstance(s,dict):\n            print(side,'illegal',s.get('illegal'),'sig',s.get('signature'))\n            for kk in ['movesResolved','effectsResolved','moves','effects','records','log']:\n                if kk in s:\n                    vv=s[kk]\n                    if isinstance(vv,list):\n                        print(side,kk,'len',len(vv))\n                    else:\n                        print(side,kk,vv)\nPY\n"]
