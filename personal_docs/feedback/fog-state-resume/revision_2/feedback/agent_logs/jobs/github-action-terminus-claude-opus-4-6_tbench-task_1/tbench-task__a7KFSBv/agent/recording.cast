[253.9455, "o", "# Fix SyncBoundary off-by-one: currentTurn + rem - 1 should be currentTurn + rem\r\n\u001b[?2004l\r"]
[253.945541, "o", "\u001b[?2004h> "]
[253.945733, "o", "content = content.replace(\r\n\u001b[?2004l\r"]
[253.945772, "o", "\u001b[?2004h> "]
[253.946129, "o", "    'ID: eff.ID, ExpiryTurn: currentTurn + rem - 1, Active: eff.Active,',\r\n\u001b[?2004l\r"]
[253.946207, "o", "\u001b[?2004h> "]
[253.946529, "o", "    'ID: eff.ID, ExpiryTurn: currentTurn + rem, Active: eff.Active,'\r\n\u001b[?2004l\r"]
[253.946604, "o", "\u001b[?2004h> "]
