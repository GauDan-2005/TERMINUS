[160.962475, "o", "cat /app/internal/store/pack.go\r\n\u001b[?2004l\r"]
[160.963566, "o", "package store\r\n\r\ntype stateX struct {\r\n\tLit  []bool\r\n\tSeen []bool\r\n\tTurn int\r\n}\r\n\r\ntype EffectSnap struct {\r\n\tID         string\r\n\tExpiryTurn int\r\n\tActive     bool\r\n}\r\n\r\ntype HostileSnap struct {\r\n\tID string\r\n\tX  int\r\n\tY  int\r\n}\r\n\r\ntype ItemY struct {\r\n\tLit      []bool\r\n\tSeen     []bool\r\n\tTurn     int\r\n\tObs      map[string]bool\r\n\tEffects  []EffectSnap\r\n\tWidth    int\r\n\tHeight   int\r\n\tPlayerX  int\r\n\tPlayerY  int\r\n\tHostiles []HostileSnap\r\n}\r\n\r\nfunc phase_a(a *stateX, b ItemY) error {\r\n\ta.Lit = append([]bool(nil), b.Lit...)\r\n\ta.Seen = append([]bool(nil), b.Seen...)\r\n\ta.Turn = b.Turn\r\n\treturn nil\r\n}\r\n\r\nfunc PackItem(b ItemY) ItemY {\r\n\tst := &stateX{}\r\n\t_ = phase_a(st, b)\r\n\tout := b\r\n\tout.Seen = append([]bool(nil), st.Seen...)\r\n\tif len(out.Seen) < len(b.Seen) {\r\n\t\tout.Seen = append(out.Seen, make([]bool, len(b.Seen)-len(out.Seen))...)\r\n\t} else if len(out.Seen) > len(b.Seen) {\r\n\t\tout.Seen = out.Seen[:len(b.Seen)]\r\n\t}\r\n\treturn out\r\n}\r\n"]
[160.963887, "o", "\u001b[?2004hroot@c4872d02bf6a:/app# "]
