[38.140803, "o", "package mem\r\n\r\nimport \"fog.local/resume/internal/store\"\r\n\r\ntype CacheX struct {\r\n\tObs     map[string]bool\r\n\tVersion uint64\r\n}\r\n\r\nfunc fold_b(a *CacheX, b store.ItemY) error {\r\n\tif a.Obs == nil {\r\n\t\ta.Obs = map[string]bool{}\r\n\t}\r\n\tif a.Version != 0 && a.Version != uint64(b.Turn) {\r\n\t\tfor key, val := range b.Obs {\r\n\t\t\tif val {\r\n\t\t\t\ta.Obs[key] = true\r\n\t\t\t}\r\n\t\t}\r\n\t\ta.Version = uint64(b.Turn)\r\n\t\treturn nil\r\n\t}\r\n\tfor key, val := range b.Obs {\r\n\t\ta.Obs[key] = val\r\n\t}\r\n\tfor key, val := range a.Obs {\r\n\t\tif !val && b.Obs[key] {\r\n\t\t\ta.Obs[key] = true\r\n\t\t}\r\n\t}\r\n\ta.Version = uint64(b.Turn)\r\n\treturn nil\r\n}\r\n\r\nfunc Merge(a *CacheX, blob store.ItemY) {\r\n\t_ = fold_b(a, blob)\r\n}\r\n\r\nfunc Snapshot(a *CacheX) map[string]bool {\r\n\tout := map[string]bool{}\r\n\tfor k, v := range a.Obs {\r\n\t\tout[k] = v\r\n\t}\r\n\treturn out\r\n}\r\n"]
[38.142243, "o", "\u001b[?2004hroot@575dab423b67:/app# "]
[69.295177, "i", "cat /app/cmd/rogctl/main.go\n"]
[69.295629, "o", "cat /app/cmd/rogctl/main.go\r\n\u001b[?2004l\r"]
[69.297227, "o", "package main\r\n\r\nimport (\r\n\t\"encoding/json\"\r\n\t\"flag\"\r\n\t\"os\"\r\n\t\"path/filepath\"\r\n\t\"sort\"\r\n\r\n\t\"fog.local/resume/internal/exec\"\r\n)\r\n\r\nfunc main() {\r\n\toutPath := flag.String(\"out\", \"/app/output/resume-audit.json\", \"output path\")\r\n\troot := flag.String(\"root\", \"/app\", \"workspace root\")\r\n\toneCase := flag.String(\"case\", \"\", \"single case\")\r\n\tflag.Parse()\r\n\r\n\tnames := exec.AllCases()\r\n\tif *oneCase != \"\" {\r\n\t\tnames = []string{*oneCase}\r\n\t}\r\n\tsort.Strings(names)\r\n\treport := exec.Report{Cases: []exec.CaseResult{}}\r\n\tfor _, name := range names {\r\n\t\tresult, err := exec.RunRow(*root, name)\r\n\t\tif err != nil {\r\n\t\t\tpanic(err)\r\n\t\t}\r\n\t\treport.Cases = append(report.Cases, result)\r\n\t}\r\n\tif err := os.MkdirAll(filepath.Dir(*outPath), 0o755); err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\tencoded, err := json.MarshalIndent(report, \"\", \"  \")\r\n\tif err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n\tif err := os.WriteFile(*outPath, append(encoded, '\\n'), 0o644); err != nil {\r\n\t\tpanic(err)\r\n\t}\r\n}\r\n\u001b[?2004hroot@575dab423b67:/app# "]
[69.412026, "i", "cat /app/internal/g6/render.go\n"]
[69.412388, "o", "cat /app/internal/g6/render.go"]
[69.412819, "o", "\r\n\u001b[?2004l\r"]
[69.413656, "o", "package g6\r\n\r\nimport \"fmt\"\r\n\r\nfunc PackPreview(grid []string) string {\r\n\tout := \"\"\r\n\tfor _, row := range grid {\r\n\t\tout += row + \"\\n\"\r\n\t}\r\n\treturn fmt.Sprintf(\"%d rows\", len(grid))\r\n}\r\n\r\nfunc Preview(grid []string) string {\r\n\treturn PackPreview(grid)\r\n}\r\n"]
[69.415051, "o", "\u001b[?2004hroot@575dab423b67:/app# "]
[69.523593, "i", "cat /app/internal/h7/stats.go\n"]
[69.524124, "o", "cat /app/internal/h7/stats.go\r\n\u001b[?2004l\r"]
[69.525692, "o", "package h7\r\n\r\ntype Counter struct {\r\n\tRuns int\r\n}\r\n\r\ntype BoundaryStat struct {\r\n\tSavedTurn   int\r\n\tCurrentTurn int\r\n\tShift       int\r\n}\r\n\r\nfunc Bump(c *Counter) {\r\n\tc.Runs++\r\n}\r\n\r\nfunc RebaseEpoch(saved, current int) int {\r\n\treturn current - saved\r\n}\r\n\r\nfunc SyncPreview(saved, current int) BoundaryStat {\r\n\treturn BoundaryStat{SavedTurn: saved, CurrentTurn: current, Shift: RebaseEpoch(saved, current)}\r\n}\r\n\u001b[?2004hroot@575dab423b67:/app# "]
[69.639433, "i", "cat /app/probe/legality.c\n"]
[69.639773, "o", "cat /app/probe/legality.c\r\n\u001b[?2004l\r"]
[69.640505, "o", "#include \"legality.h\"\r\n\r\nstatic int abs_i(int v) {\r\n    return v < 0 ? -v : v;\r\n}\r\n\r\nint walk_e(struct qx *a, int x0, int y0, int x1, int y1) {\r\n    if (!a || !a->grid) {\r\n        return 0;\r\n    }\r\n    if (x0 == x1 && y0 == y1) {\r\n        return 1;\r\n    }\r\n    int dx = x1 - x0;\r\n    int dy = y1 - y0;\r\n    int adx = abs_i(dx);\r\n    int ady = abs_i(dy);\r\n    if (adx + ady != 1) {\r\n        if (adx == ady && adx == 1) {\r\n            return 1;\r\n        }\r\n        return 0;\r\n    }\r\n    if (x1 < 0 || y1 < 0 || x1 >= a->width || y1 >= a->height) {\r\n        return 0;\r\n    }\r\n    if (a->grid[y1 * a->width + x1]) {\r\n        return 0;\r\n    }\r\n    return 1;\r\n}\r\n"]
[69.640811, "o", "\u001b[?2004h"]
[69.640898, "o", "root@575dab423b67:/app# "]
[69.747505, "i", "cat /app/probe/legality.h\n"]
[69.748308, "o", "cat /app/probe/legality.h\r\n\u001b[?2004l\r"]
[69.749532, "o", "#ifndef LEGALITY_H\r\n#define LEGALITY_H\r\n\r\nstruct qx {\r\n    int width;\r\n    int height;\r\n    int *grid;\r\n};\r\n\r\nint walk_e(struct qx *a, int x0, int y0, int x1, int y1);\r\n\r\n#endif\r\n"]
[69.749694, "o", "\u001b[?2004hroot@575dab423b67:/app# "]
[69.851778, "i", "cat /app/probe/list.c\n"]
[69.852131, "o", "cat /app/probe/list.c"]
[69.852288, "o", "\r\n\u001b[?2004l\r"]
[69.853325, "o", "#include <stdio.h>\r\n#include \"legality.h\"\r\n\r\nint list_tiles(struct qx *a) {\r\n    if (!a || !a->grid) {\r\n        return 0;\r\n    }\r\n    for (int y = 0; y < a->height; y++) {\r\n        for (int x = 0; x < a->width; x++) {\r\n            if (a->grid[y * a->width + x]) {\r\n                printf(\"%d,%d\\n\", x, y);\r\n            }\r\n        }\r\n    }\r\n    return 0;\r\n}\r\n"]
