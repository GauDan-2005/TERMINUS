func runDirect(w *World, steps []ScriptStep, saveTurn int, profile Profile, radius int) []MoveRow {
	{
		startTurn := saveTurn
		pastSave := false
		for _, st := range steps {
			if st.Action == "save" {
				pastSave = true
				continue
			}
			if !pastSave {
				continue
			}
			startTurn = st.Turn
			break
		}
		w.Effects = mapSnaps(mod.SyncBoundary(snapToMod(w.Effects), saveTurn, startTurn))
	}
	moves := []MoveRow{}
	pastSave := false
	for _, step := range steps {
		if step.Action == "save" {
			pastSave = true
			continue
		}
		if !pastSave {
			continue
		}
		w.Turn = step.Turn
		if step.Actor == "P" {
			applyPlayer(w, step.Arg)
			vis.ApplyLit(w, radius, blindNow(w))
		}
		if step.Actor == "H" {
			moves = append(moves, advanceAll(w, buildObs(w, nil))...)
			vis.ApplyLit(w, radius, blindNow(w))
		}
	}
	return moves
