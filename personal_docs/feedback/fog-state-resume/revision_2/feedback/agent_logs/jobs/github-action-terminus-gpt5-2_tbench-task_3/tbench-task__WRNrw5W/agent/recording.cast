[187.683094, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: internal/exec/run.go\n@@\n func RunRow(root, name string) (CaseResult, error) {\n@@\n \tresumeMoves := runLoaded(wResume, steps, blob, stale, profile, radius)\n@@\n-\tallMoves := append(append([]MoveRow{}, freshMoves...), resumeMoves...)\n+\t// The audit compares fresh vs resume internally, but the case output (and\n+\t// the records/log sidecars) must reflect a single resolved move stream in\n+\t// order, not a concatenation of both paths.\n+\t//\n+\t// Using a single canonical stream also avoids spurious duplicates when the\n+\t// fresh and resumed runs agree (the expected clean state).\n+\tallMoves := append([]MoveRow{}, freshMoves...)\n@@\n-\tfresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\n-\tresume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\n-\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig\n+\tfresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\n+\tresume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\n+\t// A row is only clean if both paths are legal and agree on the move stream,\n+\t// and if the visibility accounting matches.\n+\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig &&\n+\t\tvis.CountSeen(wFresh) == vis.CountSeen(wResume)\n*** End Patch\nPATCH\n"]
