[1027.739297, "o", "193:func runDirect(w *World, steps []ScriptStep, saveTurn int, profile Profile, radius int) []MoveRow {\r\n"]
[1027.741542, "o", "\t\t\tblob = packWorld(w, vis)\r\n\t\t\tbreak\r\n\t\t}\r\n\t\tif step.Actor == \"P\" {\r\n\t\t\tapplyPlayer(w, step.Arg)\r\n\t\t\tvis.ApplyLit(w, radius, blindNow(w))\r\n\t\t\tvisStale = buildObs(w, nil)\r\n\t\t}\r\n\t\tif step.Actor == \"H\" {\r\n\t\t\t// Advance hostiles during the pre-save phase so the packed world\r\n\t\t\t// matches the direct run state at the save boundary.\r\n\t\t\t_ = advanceAll(w, buildObs(w, nil))\r\n\t\t\tvis.ApplyLit(w, radius, blindNow(w))\r\n\t\t}\r\n"]
[1027.741603, "o", "\t}\r\n\treturn blob, visStale\r\n}\r\n\r\nfunc runDirect(w *World, steps []ScriptStep, saveTurn int, profile Profile, radius int) []MoveRow {\r\n\t{\r\n\t\tstartTurn := saveTurn\r\n\t\tpastSave := false\r\n\t\tfor _, st := range steps {\r\n\t\t\tif st.Action == \"save\" {\r\n\t\t\t\tpastSave = true\r\n\t\t\t\tcontinue\r\n\t\t\t}\r\n\t\t\tif !pastSave {\r\n\t\t\t\tcontinue\r\n\t\t\t}\r\n\t\t\tstartTurn = st.Turn\r\n\t\t\tbreak\r\n\t\t}\r\n\t\tw.Effects = mapSnaps(mod.SyncBoundary(snapToMod(w.Effects), saveTurn, startTurn))\r\n\t}\r\n"]
[1027.741692, "o", "\tmoves := []MoveRow{}\r\n\tpastSave := false\r\n\tfor _, step := range steps {\r\n\t\tif step.Action == \"save\" {\r\n\t\t\tpastSave = true\r\n\t\t\tcontinue\r\n\t\t}\r\n\t\tif !pastSave {\r\n\t\t\tcontinue\r\n\t\t}\r\n\t\tw.Turn = step.Turn\r\n\t\tif step.Actor == \"P\" {\r\n\t\t\tapplyPlayer(w, step.Arg)\r\n\t\t\tvis.ApplyLit(w, radius, blindNow(w))\r\n\t\t}\r\n\t\tif step.Actor == \"H\" {\r\n\t\t\tmoves = append(moves, advanceAll(w, buildObs(w, nil))...)\r\n\t\t\tvis.ApplyLit(w, radius, blindNow(w))\r\n\t\t}\r\n\t}\r\n\treturn moves\r\n"]
