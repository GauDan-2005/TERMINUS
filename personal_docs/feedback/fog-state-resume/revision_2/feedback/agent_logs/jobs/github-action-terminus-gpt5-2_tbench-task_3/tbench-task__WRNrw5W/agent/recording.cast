[1285.33867, "i", "python3 - <<'PY'\nimport json, collections\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    d=json.load(f)\nprint('cases', len(d['cases']))\nprint('bad', sum(1 for c in d['cases'] if not c.get('ok')))\nfor c in d['cases']:\n    vis=c.get('visibility',{})\n    if vis.get('fresh_seen')!=vis.get('resume_seen'):\n        print('VIS_MISMATCH', c['name'], vis)\n    moves=c.get('moves',[])\n    key=lambda m:(m.get('turn'),m.get('actor'),m.get('from_x'),m.get('from_y'),m.get('to_x'),m.get('to_y'),m.get('kind'),m.get('legal'))\n    ctr=collections.Counter(key(m) for m in moves)\n    if any(v>1 for v in ctr.values()):\n        print('DUPS_IN_JSON', c['name'], 'total', len(moves), 'unique', len(ctr))\nPY\n"]
