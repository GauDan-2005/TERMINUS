[1156.250687, "o", "sed -n '1,260p' /app/internal/store/pack.go\r\n\u001b[?2004l\r"]
[1156.251604, "o", "package store\r\n\r\ntype stateX struct {\r\n\tLit  []bool\r\n\tSeen []bool\r\n\tTurn int\r\n}\r\n\r\n"]
[1156.251686, "o", "type EffectSnap struct {\r\n\tID         string\r\n\tExpiryTurn int\r\n\tActive     bool\r\n"]
[1156.251961, "o", "}\r\n\r\ntype HostileSnap struct {\r\n\tID string\r\n\tX  int\r\n"]
[1156.252021, "o", "\tY  int\r\n}\r\n\r\ntype ItemY struct {\r\n"]
[1156.252247, "o", "\tLit      []bool\r\n\tSeen     []bool\r\n\tTurn     int\r\n\tObs      map[string]bool\r\n\tEffects  []EffectSnap\r\n\tWidth    int\r\n\tHeight   int\r\n\tPlayerX  int\r\n"]
[1156.25228, "o", "\tPlayerY  int\r\n\tHostiles []HostileSnap\r\n}\r\n\r\n"]
[1156.252517, "o", "func phase_a(a *stateX, b ItemY) error {\r\n"]
[1156.252654, "o", "\ta.Lit = append([]bool(nil), b.Lit...)\r\n\ta.Seen = append([]bool(nil), b.Seen...)\r\n\ta.Turn = b.Turn\r\n\treturn nil\r\n"]
[1156.252817, "o", "}\r\n\r\nfunc PackItem(b ItemY) ItemY {\r\n"]
[1156.253324, "o", "\tst := &stateX{}\r\n\t_ = phase_a(st, b)\r\n\tout := b\r\n\tout.Seen = append([]bool(nil), st.Lit...)\r\n\tif len(out.Seen) < len(b.Seen) {\r\n\t\tout.Seen = append(out.Seen, make([]bool, len(b.Seen)-len(out.Seen))...)\r\n\t} else if len(out.Seen) > len(b.Seen) {\r\n\t\tout.Seen = out.Seen[:len(b.Seen)]\r\n\t}\r\n\treturn out\r\n}\r\n\u001b[?2004hroot@59645c3f7916:/app# "]
[1156.370636, "i", "grep -n \"type ItemY\" -n /app/internal/store/pack.go\n"]
