[146.958869, "i", "python3 - <<'PY'\nimport json, collections\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    d=json.load(f)\nfor c in d['cases']:\n    name=c['name']\n    vis=c.get('visibility',{})\n    if vis.get('fresh_seen')!=vis.get('resume_seen'):\n        print('VIS_MISMATCH', name, vis)\n    moves=c.get('moves',[])\n    # count duplicates by (turn,actor,from,to,kind,legal)\n    key=lambda m:(m.get('turn'),m.get('actor'),m.get('from_x'),m.get('from_y'),m.get('to_x'),m.get('to_y'),m.get('kind'),m.get('legal'))\n    ctr=collections.Counter(key(m) for m in moves)\n    dups=[(k,v) for k,v in ctr.items() if v>1]\n    if dups:\n        print('MOVE_DUPS', name, 'total', len(moves), 'unique', len(ctr))\nPY\n"]
