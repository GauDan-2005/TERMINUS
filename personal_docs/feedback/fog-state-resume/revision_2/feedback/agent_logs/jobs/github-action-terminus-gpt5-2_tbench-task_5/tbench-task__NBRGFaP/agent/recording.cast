[149.759891, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    data=json.load(f)\nfail=[]\nfor c in data['cases']:\n    vis=c.get('visibility',{})\n    if (not c.get('ok')) or c['fresh']['sig']!=c['resume']['sig'] or c['fresh']['illegal']!=0 or c['resume']['illegal']!=0 or vis.get('fresh_seen')!=vis.get('resume_seen'):\n        fail.append(c['name'])\nprint('fail',fail)\nfor c in data['cases']:\n    vis=c.get('visibility',{})\n    print(c['name'], 'ok=',c['ok'],'sig=',c['fresh']['sig'], 'seen=',vis.get('fresh_seen'),vis.get('resume_seen'),'moves=',len(c.get('moves',[])))\nPY\n"]
