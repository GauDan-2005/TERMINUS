[164.615478, "i", "python3 - <<'PY'\nfrom pathlib import Path\np=Path('/app/internal/exec/run.go')\ns=p.read_text()\n# 1) ensure sidecars/moves are fresh-only\ns=s.replace(\n\"\\t\\tallMoves := append(append([]MoveRow{}, freshMoves...), resumeMoves...)\\n\",\n\"\\t\\t// Sidecars should list the resolved moves in order (same list as JSON).\\n\\t\\t// Since fresh/resume must match, write the fresh path only.\\n\\t\\tallMoves := freshMoves\\n\",\n)\n# 2) compute seen and include in ok\ns=s.replace(\n\"\\t\\tfresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\\n\\t\\tresume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\\n\\t\\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig\\n\",\n\"\\t\\tfresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\\n\\t\\tresume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\\n\\t\\tfreshSeen := vis.CountSeen(wFresh)\\n\\t\\tresumeSeen := vis.CountSeen(wResume)\\n\\t\\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig && freshSeen == resumeSeen\\n\",\n)\n# 3) publish fresh moves + reuse seen vars\ns=s.replace(\n\"\\t\\t\\tMoves:      allMoves,\\n\\t\\t\\tVisibility: VisPair{FreshSeen: vis.CountSeen(wFresh), ResumeSeen: vis.CountSeen(wResume)},\\n\",\n\"\\t\\t\\t// Moves are the resolved move list for the case. Fresh and resumed runs\\n\\t\\t\\t// must agree, so we publish the fresh path and validate via signature.\\n\\t\\t\\tMoves:      freshMoves,\\n\\t\\t\\tVisibility: VisPair{FreshSeen: freshSeen, ResumeSeen: resumeSeen},\\n\",\n)\n# sanity check: did we actually change?\nif 'freshSeen := vis.CountSeen(wFresh)' not in s:\n    raise SystemExit('patch failed: ok/seen block not updated')\np.write_text(s)\nprint('patched', p)\nPY\n"]
