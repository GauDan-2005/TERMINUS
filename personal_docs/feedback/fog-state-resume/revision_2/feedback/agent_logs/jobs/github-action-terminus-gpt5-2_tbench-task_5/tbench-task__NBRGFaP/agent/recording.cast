[27.467449, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    data=json.load(f)\ncases=data.get('cases',[])\nprint('cases:',len(cases))\nfail=[]\nfor c in cases:\n    fresh=c.get('fresh',{})\n    resume=c.get('resume',{})\n    ok=c.get('ok')\n    fs=fresh.get('signature')\n    rs=resume.get('signature')\n    fi=fresh.get('illegal')\n    ri=resume.get('illegal')\n    if (ok is not True) or (fs!=rs) or (fi not in (0,None)) or (ri not in (0,None)):\n        fail.append(c.get('case'))\n    print(f\"{c.get('case')}: ok={ok} fresh_sig={fs} resume_sig={rs} fresh_illegal={fi} resume_illegal={ri}\")\nprint('\\nFAIL:',len(fail))\nfor x in fail:\n    print(x)\nPY\n"]
