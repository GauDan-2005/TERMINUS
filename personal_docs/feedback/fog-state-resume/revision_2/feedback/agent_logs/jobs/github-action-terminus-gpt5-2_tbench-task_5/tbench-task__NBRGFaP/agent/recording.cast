[210.887646, "i", "python3 - <<'PY'\nimport json, os\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    data=json.load(f)\nprint('cases',len(data['cases']))\n# verify sidecars line counts match moves length\nbad=[]\nfor c in data['cases']:\n    moves=c.get('moves',[])\n    rec=c.get('records')\n    log=c.get('log')\n    rlines=sum(1 for _ in open(rec)) if rec and os.path.exists(rec) else None\n    llines=sum(1 for _ in open(log)) if log and os.path.exists(log) else None\n    if rlines!=len(moves) or llines!=len(moves):\n        bad.append((c['name'],len(moves),rlines,llines))\nprint('sidecar mismatches:',bad)\n# verify no duplicated move keys\nfrom collections import Counter\nfor c in data['cases']:\n    key=lambda m:(m.get('turn'),m.get('actor'),m.get('from_x'),m.get('from_y'),m.get('to_x'),m.get('to_y'),m.get('kind'))\n    ctr=Counter(key(m) for m in c.get('moves',[]))\n    dups=sum(1 for v in ctr.values() if v>1)\n    if dups:\n        print('dups',c['name'],dups)\n# verify ok implies seen equality\nfor c in data['cases']:\n    vis=c.get('visibility',{})\n    if c.get('ok') and vis.get('fresh_seen')!=vis.get('resume_seen'):\n        print('ok but seen mismatch',c['name'],vis)\nPY\n"]
