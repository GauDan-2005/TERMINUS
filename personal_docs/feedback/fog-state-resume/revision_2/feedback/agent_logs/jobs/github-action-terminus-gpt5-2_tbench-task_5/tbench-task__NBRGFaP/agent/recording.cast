[101.329421, "o", "\tfresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\r\n\tresume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\r\n\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig\r\n\r\n\treturn CaseResult{\r\n\t\tName:       name,\r\n\t\tOK:         ok,\r\n\t\tFresh:      fresh,\r\n\t\tResume:     resume,\r\n"]
