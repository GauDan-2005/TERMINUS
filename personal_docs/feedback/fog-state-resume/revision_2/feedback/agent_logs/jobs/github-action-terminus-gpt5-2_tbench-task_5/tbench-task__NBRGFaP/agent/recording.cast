[198.876313, "i", "python3 - <<'PY'\nfrom pathlib import Path\np=Path('/app/internal/exec/run.go')\nlines=p.read_text().splitlines(True)\n\ndef find_idx(substr):\n    for i,l in enumerate(lines):\n        if substr in l:\n            return i\n    return -1\n\n# Replace the allMoves assignment\ni=find_idx('allMoves := append(append([]MoveRow{}, freshMoves...), resumeMoves...)')\nif i==-1:\n    # maybe already patched or slightly different\n    print('allMoves concat not found')\nelse:\n    indent=lines[i].split('a')[0]  # crude but ok\n    lines[i:i+1]=[\n        '\\t\\t// Sidecars should list the resolved moves in order (same list as JSON).\\n',\n        '\\t\\t// Since fresh/resume must match, write the fresh path only.\\n',\n        '\\t\\tallMoves := freshMoves\\n'\n    ]\n\n# Insert freshSeen/resumeSeen + update ok.\n# Find the ok line and replace it, ensuring we have the summaries above it.\nok_i=find_idx('ok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig')\nif ok_i==-1:\n    print('ok line not found')\nelse:\n    lines[ok_i:ok_i+1]=[\n        '\\t\\tfreshSeen := vis.CountSeen(wFresh)\\n',\n        '\\t\\tresumeSeen := vis.CountSeen(wResume)\\n',\n        '\\t\\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig && freshSeen == resumeSeen\\n'\n    ]\n\n# Update CaseResult fields (Moves/Visibility)\nfor i,l in enumerate(lines):\n    if '\\t\\t\\tMoves:' in l:\n        # replace Moves line\n        if 'allMoves' in l:\n            lines[i:i+1]=[\n                '\\t\\t\\t// Moves are the resolved move list for the case. Fresh and resumed runs\\n',\n                '\\t\\t\\t// must agree, so we publish the fresh path and validate via signature.\\n',\n                '\\t\\t\\tMoves:      freshMoves,\\n'\n            ]\n    if 'Visibility: VisPair{FreshSeen:' in l:\n        lines[i:i+1]=['\\t\\t\\tVisibility: VisPair{FreshSeen: freshSeen, ResumeSeen: resumeSeen},\\n']\n\np.write_text(''.join(lines))\nprint('patched')\nPY\n"]
