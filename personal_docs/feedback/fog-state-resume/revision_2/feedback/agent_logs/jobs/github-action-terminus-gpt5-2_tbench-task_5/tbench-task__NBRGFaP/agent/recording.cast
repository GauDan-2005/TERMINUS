[210.89378, "o", "    key=lambda m:(m.get('turn'),m.get('actor'),m.get('from_x'),m.get('from_y'),m.get('to_x'),m.get('to_y'),m.get('kind'))\r\n\u001b[?2004l\r"]
[210.893805, "o", "\u001b[?2004h"]
[210.893821, "o", "> "]
[210.893978, "o", "    ctr=Counter(key(m) for m in c.get('moves',[]))\r\n\u001b[?2004l\r"]
[210.894001, "o", "\u001b[?2004h"]
[210.894017, "o", "> "]
[210.894159, "o", "    dups=sum(1 for v in ctr.values() if v>1)\r\n\u001b[?2004l\r"]
[210.894182, "o", "\u001b[?2004h"]
[210.894198, "o", "> "]
[210.894267, "o", "    if dups:\r\n\u001b[?2004l\r\u001b[?2004h"]
[210.894328, "o", "> "]
[210.894415, "o", "        print('dups',c['name'],dups)\r\n\u001b[?2004l\r"]
[210.894471, "o", "\u001b[?2004h> "]
[210.894574, "o", "# verify ok implies seen equality\r\n\u001b[?2004l\r"]
[210.894632, "o", "\u001b[?2004h> "]
[210.89471, "o", "for c in data['cases']:\r\n\u001b[?2004l\r"]
[210.894786, "o", "\u001b[?2004h> "]
[210.894854, "o", "    vis=c.get('visibility',{})\r\n\u001b[?2004l\r"]
[210.894878, "o", "\u001b[?2004h"]
[210.894894, "o", "> "]
[210.895108, "o", "    if c.get('ok') and vis.get('fresh_seen')!=vis.get('resume_seen'):\r\n\u001b[?2004l\r"]
[210.895132, "o", "\u001b[?2004h"]
[210.895148, "o", "> "]
[210.895308, "o", "        print('ok but seen mismatch',c['name'],vis)\r\n\u001b[?2004l\r"]
[210.895332, "o", "\u001b[?2004h"]
[210.895353, "o", "> PY\r\n"]
[210.895371, "o", "\u001b[?2004l\r"]
[210.913284, "o", "cases 7\r\n"]
[210.913688, "o", "sidecar mismatches: []\r\n"]
[210.916691, "o", "\u001b[?2004hroot@ccbd9cc473ba:/app# "]
