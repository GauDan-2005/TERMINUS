[51.164074, "i", "python3 - <<'PY'\nimport json, collections\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    data=json.load(f)\nprint('name\\tok\\tfresh_sig\\tresume_sig\\tfresh_illegal\\tresume_illegal\\tfresh_seen\\tresume_seen\\tmoves\\teffects')\nfor c in data['cases']:\n    vis=c.get('visibility',{})\n    print(f\"{c['name']}\\t{c['ok']}\\t{c['fresh']['sig']}\\t{c['resume']['sig']}\\t{c['fresh']['illegal']}\\t{c['resume']['illegal']}\\t{vis.get('fresh_seen')}\\t{vis.get('resume_seen')}\\t{len(c.get('moves',[]))}\\t{len(c.get('effects',[]))}\")\nprint('\\nVisibility mismatches:')\nfor c in data['cases']:\n    vis=c.get('visibility',{})\n    if vis.get('fresh_seen')!=vis.get('resume_seen'):\n        print(c['name'], vis)\nprint('\\nMove duplicates by (turn,actor,from,to,kind):')\nfor c in data['cases']:\n    moves=c.get('moves',[])\n    key=lambda m:(m.get('turn'),m.get('actor'),m.get('from_x'),m.get('from_y'),m.get('to_x'),m.get('to_y'),m.get('kind'))\n    ctr=collections.Counter(key(m) for m in moves)\n    dups=[k for k,v in ctr.items() if v>1]\n    if dups:\n        print(c['name'], 'dups:', len(dups), 'total moves:', len(moves))\nPY\n"]
