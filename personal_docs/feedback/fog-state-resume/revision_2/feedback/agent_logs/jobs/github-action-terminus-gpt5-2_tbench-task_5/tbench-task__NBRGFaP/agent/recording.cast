[113.154121, "o", "package mem\r\n\r\nimport \"fog.local/resume/internal/store\"\r\n\r\ntype CacheX struct {\r\n\tObs     map[string]bool\r\n\tVersion uint64\r\n}\r\n\r\nfunc fold_b(a *CacheX, b store.ItemY) error {\r\n\tif a.Obs == nil {\r\n"]
[113.154157, "o", "\t\ta.Obs = map[string]bool{}\r\n\t}\r\n\tif a.Version != 0 && a.Version != uint64(b.Turn) {\r\n\t\tfor key, val := range b.Obs {\r\n\t\t\tif val {\r\n\t\t\t\ta.Obs[key] = true\r\n\t\t\t}\r\n\t\t}\r\n\t\ta.Version = uint64(b.Turn)\r\n\t\treturn nil\r\n\t}\r\n\tfor key, val := range b.Obs {\r\n"]
[113.154175, "o", "\t\ta.Obs[key] = val\r\n\t}\r\n\tfor key, val := range a.Obs {\r\n"]
[113.154194, "o", "\t\tif !val && b.Obs[key] {\r\n\t\t\ta.Obs[key] = true\r\n\t\t}\r\n\t}\r\n\ta.Version = uint64(b.Turn)\r\n"]
[113.154227, "o", "\treturn nil\r\n}\r\n\r\nfunc Merge(a *CacheX, blob store.ItemY) {\r\n\t_ = fold_b(a, blob)\r\n"]
[113.154255, "o", "}\r\n\r\nfunc Snapshot(a *CacheX) map[string]bool {\r\n\tout := map[string]bool{}\r\n\tfor k, v := range a.Obs {\r\n\t\tout[k] = v\r\n\t}\r\n\treturn out\r\n}\r\n"]
[113.154617, "o", "\u001b[?2004hroot@ccbd9cc473ba:/app# "]
[130.235212, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: internal/store/pack.go\n@@\n package store\n \n-type stateX struct {\n-        Lit  []bool\n-        Seen []bool\n-        Turn int\n-}\n-\n@@\n type ItemY struct {\n@@\n }\n-\n-func phase_a(a *stateX, b ItemY) error {\n-        a.Lit = append([]bool(nil), b.Lit...)\n-        a.Seen = append([]bool(nil), b.Seen...)\n-        a.Turn = b.Turn\n-        return nil\n-}\n-\n func PackItem(b ItemY) ItemY {\n-        st := &stateX{}\n-        _ = phase_a(st, b)\n-        out := b\n-        out.Seen = append([]bool(nil), st.Lit...)\n-        if len(out.Seen) < len(b.Seen) {\n-                out.Seen = append(out.Seen, make([]bool, len(b.Seen)-len(out.Seen))...)\n-        } else if len(out.Seen) > len(b.Seen) {\n-                out.Seen = out.Seen[:len(b.Seen)]\n-        }\n-        return out\n+\t// PackItem is used as the “save blob” passed across the resume boundary.\n+\t// It must preserve all state exactly; in particular Seen must remain the\n+\t// cumulative exploration map, not the current Lit mask.\n+\tout := b\n+\tout.Lit = append([]bool(nil), b.Lit...)\n+\tout.Seen = append([]bool(nil), b.Seen...)\n+\treturn out\n }\n*** End Patch\nPATCH\n"]
