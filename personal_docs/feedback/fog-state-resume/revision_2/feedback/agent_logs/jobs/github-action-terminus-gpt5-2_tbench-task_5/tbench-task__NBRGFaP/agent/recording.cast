[198.756115, "o", "\r\n\u001b[?2004l\r"]
[198.757524, "o", "   240\t\tprofile := ProfileFor(name)\r\n   241\t\tradius, _ := LoadRadius(root, name)\r\n   242\t\tif radius == 0 {\r\n   243\t\t\tradius = profile.Radius\r\n   244\t\t}\r\n"]
[198.757564, "o", "   245\t\tbase, err := LoadLayout(root, name)\r\n   246\t\tif err != nil {\r\n   247\t\t\treturn CaseResult{}, err\r\n   248\t\t}\r\n"]
[198.757762, "o", "   249\t\tsteps, err := LoadScript(root, name)\r\n   250\t\tif err != nil {\r\n   251\t\t\treturn CaseResult{}, err\r\n   252\t\t}\r\n   253\t\r\n   254\t\twFresh := cloneWorld(base)\r\n"]
[198.757838, "o", "   255\t\twFresh.Effects = mapSnaps(mod.Seed(profileToMod(profile), wFresh.Turn))\r\n   256\t\tblob, stale := playUntilSave(wFresh, steps, profile, radius)\r\n   257\t\tfreshMoves := runDirect(wFresh, steps, profile, radius)\r\n   258\t\r\n   259\t\twResume := cloneWorld(base)\r\n   260\t\twResume.Effects = mapSnaps(mod.Seed(profileToMod(profile), wResume.Turn))\r\n   261\t\tplayUntilSave(wResume, steps, profile, radius)\r\n   262\t\tresumeMoves := runLoaded(wResume, steps, blob, stale, profile, radius)\r\n   263\t\r\n"]
[198.758, "o", "   264\t\tfreshIllegal, resumeIllegal := 0, 0\r\n   265\t\tfor _, m := range freshMoves {\r\n   266\t\t\tif !m.Legal {\r\n"]
[198.758038, "o", "   267\t\t\t\tfreshIllegal++\r\n   268\t\t\t}\r\n   269\t\t}\r\n   270\t\tfor _, m := range resumeMoves {\r\n   271\t\t\tif !m.Legal {\r\n   272\t\t\t\tresumeIllegal++\r\n"]
[198.758122, "o", "   273\t\t\t}\r\n   274\t\t}\r\n"]
[198.758463, "o", "   275\t\tallMoves := append(append([]MoveRow{}, freshMoves...), resumeMoves...)\r\n   276\t\tcaseDir := filepath.Join(root, \"workspace\", name)\r\n   277\t\t_ = os.MkdirAll(caseDir, 0o755)\r\n   278\t\trecPath := filepath.Join(caseDir, \"records.jsonl\")\r\n   279\t\tlogPath := filepath.Join(caseDir, \"trace.tsv\")\r\n"]
[198.758589, "o", "   280\t\tflushRows(recPath, logPath, name, allMoves)\r\n   281\t\r\n   282\t\tfresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\r\n   283\t\tresume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\r\n   284\t\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig\r\n   285\t\r\n   286\t\treturn CaseResult{\r\n   287\t\t\tName:       name,\r\n   288\t\t\tOK:         ok,\r\n   289\t\t\tFresh:      fresh,\r\n   290\t\t\tResume:     resume,\r\n   291\t\t\tMoves:      allMoves,\r\n   292\t\t\tVisibility: VisPair{FreshSeen: vis.CountSeen(wFresh), ResumeSeen: vis.CountSeen(wResume)},\r\n   293\t\t\tEffects:    mapRowSnaps(mod.ItemsFor(snapToMod(wResume.Effects), wResume.Turn)),\r\n   294\t\t\tRecords:    recPath,\r\n   295\t\t\tLog:        logPath,\r\n   296\t\t}, nil\r\n   297\t}\r\n   298\t\r\n   299\tfunc flushRows(recPath, logPath, name string, moves []MoveRow) {\r\n   300\t\trec, _ := os.Create(recPath)\r\n   301\t\tdefer rec.Close()\r\n   302\t\tfor _, m := range moves {\r\n   303\t\t\tb, _ := json.Marshal(m)\r\n   304\t\t\t_, _ = rec.Write(append(b, '\\n'))\r\n   305\t\t}\r\n   306\t\tlog, _ := os.Create(logPath)\r\n   307\t\tdefer log.Close()\r\n   308\t\tfor _, m := range moves {\r\n   309\t\t\tfmt.Fprintf(log, \"%s\\t%d\\t%s\\t%d\\t%d\\t%d\\t%d\\t%v\\n\",\r\n   310\t\t\t\tname, m.Turn, m.Actor, m.FromX, m.FromY, m.ToX, m.ToY, m.Legal)\r\n   311\t\t}\r\n   312\t}\r\n"]
