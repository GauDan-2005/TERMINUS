[164.495431, "i", "cat > /app/internal/store/pack.go <<'EOF'\npackage store\n\ntype EffectSnap struct {\n\tID         string\n\tExpiryTurn int\n\tActive     bool\n}\n\ntype HostileSnap struct {\n\tID string\n\tX  int\n\tY  int\n}\n\ntype ItemY struct {\n\tLit      []bool\n\tSeen     []bool\n\tTurn     int\n\tObs      map[string]bool\n\tEffects  []EffectSnap\n\tWidth    int\n\tHeight   int\n\tPlayerX  int\n\tPlayerY  int\n\tHostiles []HostileSnap\n}\n\n// PackItem produces the “save blob” passed across the resume boundary.\n// It must preserve all state exactly.\nfunc PackItem(b ItemY) ItemY {\n\tout := b\n\tout.Lit = append([]bool(nil), b.Lit...)\n\tout.Seen = append([]bool(nil), b.Seen...)\n\treturn out\n}\nEOF\n"]
