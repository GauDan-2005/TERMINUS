[296.12075, "o", "     1\tpackage vis\r\n     2\t\r\n     3\timport \"fog.local/resume/internal/sim\"\r\n     4\t\r\n     5\tfunc ApplyLit(w *sim.World, radius int, blind bool) {\r\n     6\t\tsize := w.Width * w.Height\r\n     7\t\tif len(w.Lit) != size {\r\n     8\t\t\tw.Lit = make([]bool, size)\r\n     9\t\t}\r\n    10\t\tfor i := range w.Lit {\r\n    11\t\t\tw.Lit[i] = false\r\n    12\t\t}\r\n    13\t\tif blind {\r\n    14\t\t\treturn\r\n    15\t\t}\r\n    16\t\ttype point struct{ x, y int }\r\n    17\t\tqueue := []point{{w.PlayerX, w.PlayerY}}\r\n    18\t\tdist := make([]int, size)\r\n    19\t\tfor i := range dist {\r\n    20\t\t\tdist[i] = -1\r\n    21\t\t}\r\n    22\t\tstart := w.Idx(w.PlayerX, w.PlayerY)\r\n    23\t\tdist[start] = 0\r\n    24\t\tw.Lit[start] = true\r\n    25\t\tfor len(queue) > 0 {\r\n    26\t\t\tp := queue[0]\r\n    27\t\t\tqueue = queue[1:]\r\n    28\t\t\td := dist[w.Idx(p.x, p.y)]\r\n    29\t\t\tif d >= radius {\r\n    30\t\t\t\tcontinue\r\n    31\t\t\t}\r\n    32\t\t\tfor _, delta := range [][2]int{{1, 0}, {-1, 0}, {0, 1}, {0, -1}} {\r\n    33\t\t\t\tnx, ny := p.x+delta[0], p.y+delta[1]\r\n    34\t\t\t\tif !w.InBounds(nx, ny) || w.IsWall(nx, ny) {\r\n    35\t\t\t\t\tcontinue\r\n    36\t\t\t\t}\r\n    37\t\t\t\tidx := w.Idx(nx, ny)\r\n    38\t\t\t\tif dist[idx] >= 0 {\r\n    39\t\t\t\t\tcontinue\r\n    40\t\t\t\t}\r\n    41\t\t\t\tdist[idx] = d + 1\r\n    42\t\t\t\tw.Lit[idx] = true\r\n    43\t\t\t\tqueue = append(queue, point{nx, ny})\r\n    44\t\t\t}\r\n    45\t\t}\r\n    46\t\tif len(w.Seen) != size {\r\n    47\t\t\tw.Seen = make([]bool, size)\r\n    48\t\t}\r\n    49\t\tfor i := 0; i < size; i++ {\r\n    50\t\t\tif w.Lit[i] {\r\n    51\t\t\t\tw.Seen[i] = true\r\n    52\t\t\t}\r\n    53\t\t}\r\n    54\t}\r\n    55\t\r\n    56\tfunc CountSeen(w *sim.World) int {\r\n    57\t\tn := 0\r\n    58\t\tfor _, v := range w.Seen {\r\n    59\t\t\tif v {\r\n    60\t\t\t\tn++\r\n    61\t\t\t}\r\n    62\t\t}\r\n    63\t\treturn n\r\n    64\t}\r\n    65\t\r\n    66\tfunc PlayerSees(w *sim.World, x, y int) bool {\r\n    67\t\tif !w.InBounds(x, y) {\r\n    68\t\t\treturn false\r\n    69\t\t}\r\n    70\t\tidx := w.Idx(x, y)\r\n    71\t\tif idx >= len(w.Seen) || idx >= len(w.Lit) {\r\n    72\t\t\treturn false\r\n    73\t\t}\r\n    74\t\tlitIdx := idx\r\n    75\t\treturn w.Seen[idx] && w.Lit[litIdx]\r\n    76\t}\r\n"]
