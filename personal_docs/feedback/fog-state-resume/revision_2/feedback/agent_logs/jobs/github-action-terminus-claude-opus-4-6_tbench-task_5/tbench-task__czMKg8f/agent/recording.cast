[347.032329, "i", "python3 -c \"\nimport json\nd=json.load(open('/app/output/resume-audit.json'))\nfor c in d['cases']:\n    moves_json = c['moves']\n    rec_file = c['records']\n    log_file = c['log']\n    with open(rec_file) as f:\n        rec_moves = [json.loads(l) for l in f if l.strip()]\n    with open(log_file) as f:\n        log_lines = [l.strip() for l in f if l.strip()]\n    match_rec = len(moves_json) == len(rec_moves)\n    match_log = len(moves_json) == len(log_lines)\n    if not match_rec or not match_log:\n        print(f'{c[\\\"name\\\"]}: MISMATCH json={len(moves_json)} rec={len(rec_moves)} log={len(log_lines)}')\n    else:\n        for i,(mj,mr) in enumerate(zip(moves_json, rec_moves)):\n            if mj != mr:\n                print(f'{c[\\\"name\\\"]}: move {i} differs')\n                break\n        else:\n            print(f'{c[\\\"name\\\"]}: sidecars OK ({len(moves_json)} moves)')\n\"\n"]
[347.032742, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h"]
[347.033378, "o", "> import json\r\n\u001b[?2004l\r\u001b[?2004h> d=json.load(open('/app/output/resume-audit.json'))\r\n\u001b[?2004l\r\u001b[?2004h> for c in d['cases']:\r\n\u001b[?2004l\r\u001b[?2004h>     moves_json = c['moves']"]
