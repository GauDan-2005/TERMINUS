Sending keys: ["python3 - <<'PY'\nimport json, os\n\ndef load_jsonl(path):\n    out=[]\n    with open(path) as f:\n        for line in f:\n            line=line.strip()\n            if not line:\n                continue\n            out.append(json.loads(line))\n    return out\n\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    report=json.load(f)\n\ncases=report.get('cases',[])\nproblems=[]\nfor c in cases:\n    name=c.get('name')\n    ok=c.get('ok')\n    fresh=c.get('fresh',{})\n    resume=c.get('resume',{})\n    if ok is not True:\n        problems.append((name,'ok_false'))\n    if fresh.get('illegal')!=0 or resume.get('illegal')!=0:\n        problems.append((name,'illegal',fresh.get('illegal'),resume.get('illegal')))\n    if fresh.get('sig')!=resume.get('sig'):\n        problems.append((name,'sig_mismatch',fresh.get('sig'),resume.get('sig')))\n\n    rec_path=c.get('records')\n    log_path=c.get('log')\n    if not (rec_path and os.path.exists(rec_path)):\n        problems.append((name,'missing_records',rec_path))\n        continue\n    if not (log_path and os.path.exists(log_path)):\n        problems.append((name,'missing_log',log_path))\n\n    moves=c.get('moves',[])\n    recs=load_jsonl(rec_path)\n    # heuristic: many record formats; try to find records with a 'move' object\n    rec_moves=[]\n    for r in recs:\n        if isinstance(r,dict) and 'move' in r and isinstance(r['move'],dict):\n            rec_moves.append(r['move'])\n    if rec_moves:\n        if len(rec_moves)!=len(moves):\n            problems.append((name,'move_count_mismatch',len(moves),len(rec_moves)))\n        else:\n            # compare key fields if present\n            keys_map=[('turn','turn'),('actor','actor'),('from_x','from_x'),('from_y','from_y'),('to_x','to_x'),('to_y','to_y'),('kind','kind')]\n            for i,(m,rm) in enumerate(zip(moves,rec_moves)):\n                for mk,rk in keys_map:\n                    if mk in m and rk in rm and m[mk]!=rm[rk]:\n             