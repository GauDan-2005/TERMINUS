[26.618522, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    data=json.load(f)\nfail=[]\nfor c in data.get('cases',[]):\n    if not c.get('ok',False):\n        fresh=c.get('fresh',{}).get('summary',{})\n        resume=c.get('resume',{}).get('summary',{})\n        fail.append((c.get('case'), fresh.get('illegal'), resume.get('illegal'), fresh.get('signature'), resume.get('signature')))\nprint('fail_count',len(fail))\nfor row in fail[:50]:\n    case, fi, ri, fs, rs = row\n    print(case, 'fresh_illegal=%s'%fi, 'resume_illegal=%s'%ri, 'sig_match=%s'%(fs==rs))\nPY\n"]
