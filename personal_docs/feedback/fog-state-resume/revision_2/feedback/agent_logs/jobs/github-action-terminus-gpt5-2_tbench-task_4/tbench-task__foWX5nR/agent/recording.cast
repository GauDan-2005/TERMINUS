[65.801816, "o", "\u001b[?2004h> "]
[65.802766, "o", "# pretty-print first case (trim large arrays)"]
[65.804243, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> c=dict(cs[0])\r\n\u001b[?2004l\r\u001b[?2004h> for side in ['fresh','resume']:\r\n\u001b[?2004l\r\u001b[?2004h>     if side in c and isinstance(c[side], dict):\r\n\u001b[?2004l\r\u001b[?2004h>         for k,v in list(c[side].items()):\r\n\u001b[?2004l\r\u001b[?2004h>             if isinstance(v,list) and len(v)>10:\r\n\u001b[?2004l\r\u001b[?2004h>                 c[side][k]=v[:3]+['...(%d total)'%len(v)]+v[-3:]\r\n\u001b[?2004l\r\u001b[?2004h> pprint(c)\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
[65.842544, "o", "{'effects': [{'active': False, 'epoch': 3, 'id': 'blind'}],\r\n 'fresh': {'illegal': 0, 'sig': '811c9dc5', 'steps': 0},\r\n 'log': '/app/workspace/bishop/trace.tsv',\r\n 'moves': [],\r\n 'name': 'bishop',\r\n 'ok': True,\r\n "]
[65.842663, "o", "'records': '/app/workspace/bishop/records.jsonl',\r\n 'resume': {'illegal': 0, 'sig': '811c9dc5', 'steps': 0},\r\n 'visibility': {'fresh_seen': 0, 'resume_seen': 0}}\r\n"]
[65.848929, "o", "\u001b[?2004hroot@c6c596d788f9:/app# "]
[77.906727, "i", "python3 - <<'PY'\nimport json, os\n\ndef load_jsonl(path):\n    out=[]\n    with open(path) as f:\n        for line in f:\n            line=line.strip()\n            if not line:\n                continue\n            out.append(json.loads(line))\n    return out\n\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    report=json.load(f)\n\ncases=report.get('cases',[])\nproblems=[]\nfor c in cases:\n    name=c.get('name')\n    ok=c.get('ok')\n    fresh=c.get('fresh',{})\n    resume=c.get('resume',{})\n    if ok is not True:\n        problems.append((name,'ok_false'))\n    if fresh.get('illegal')!=0 or resume.get('illegal')!=0:\n        problems.append((name,'illegal',fresh.get('illegal'),resume.get('illegal')))\n    if fresh.get('sig')!=resume.get('sig'):\n        problems.append((name,'sig_mismatch',fresh.get('sig'),resume.get('sig')))\n\n    rec_path=c.get('records')\n    log_path=c.get('log')\n    if not (rec_path and os.path.exists(rec_path)):\n        problems.append((name,'missing_records',rec_path))\n        continue\n    if not (log_path and os.path.exists(log_path)):\n        problems.append((name,'missing_log',log_path))\n\n    moves=c.get('moves',[])\n    recs=load_jsonl(rec_path)\n    # heuristic: many record formats; try to find records with a 'move' object\n    rec_moves=[]\n    for r in recs:\n        if isinstance(r,dict) and 'move' in r and isinstance(r['move'],dict):\n            rec_moves.append(r['move'])\n    if rec_moves:\n        if len(rec_moves)!=len(moves):\n            problems.append((name,'move_count_mismatch',len(moves),len(rec_moves)))\n        else:\n            # compare key fields if present\n            keys_map=[('turn','turn'),('actor','actor'),('from_x','from_x'),('from_y','from_y'),('to_x','to_x'),('to_y','to_y'),('kind','kind')]\n            for i,(m,rm) in enumerate(zip(moves,rec_moves)):\n                for mk,rk in keys_map:\n                    if mk in m and rk in rm and m[mk]!=rm[rk]:\n                        problems.append((name,'move_order_mismatch',i,mk,m[mk],rm[rk]))\n                        raise StopIteration\n\nprint('case_count',len(cases))\nif problems:\n    print('PROBLEMS',len(problems))\n    for pr in problems[:200]:\n        print(pr)\n    raise SystemExit(1)\nprint('ALL_CHECKS_PASS')\nPY\n"]
