[44.654774, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    d=json.load(f)\ncases=d.get('cases',[])\nprint('case_count',len(cases))\nnot_ok=[c.get('case') for c in cases if not c.get('ok',False)]\nprint('not_ok_count',len(not_ok))\n# extra sanity: signature match and illegal==0 for both paths\nbad=[]\nfor c in cases:\n    fresh=c.get('fresh',{}).get('summary',{})\n    resume=c.get('resume',{}).get('summary',{})\n    if fresh.get('illegal')!=0 or resume.get('illegal')!=0 or fresh.get('signature')!=resume.get('signature'):\n        bad.append((c.get('case'), fresh.get('illegal'), resume.get('illegal'), fresh.get('signature')==resume.get('signature')))\nprint('sanity_bad_count',len(bad))\nfor row in bad[:20]:\n    print(*row)\nPY\n"]
