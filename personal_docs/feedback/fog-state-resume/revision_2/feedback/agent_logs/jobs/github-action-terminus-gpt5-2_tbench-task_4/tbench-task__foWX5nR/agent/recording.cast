[65.798885, "i", "python3 - <<'PY'\nimport json\nfrom pprint import pprint\nwith open('/app/output/resume-audit.json') as f:\n    d=json.load(f)\ncs=d.get('cases',[])\nif not cs:\n    raise SystemExit('no cases')\n# pretty-print first case (trim large arrays)\nc=dict(cs[0])\nfor side in ['fresh','resume']:\n    if side in c and isinstance(c[side], dict):\n        for k,v in list(c[side].items()):\n            if isinstance(v,list) and len(v)>10:\n                c[side][k]=v[:3]+['...(%d total)'%len(v)]+v[-3:]\npprint(c)\nPY\n"]
[65.799567, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> "]
