[11.038654, "i", "cat /app/output/resume-audit.json | python3 - <<'PY'\nimport json,sys\np='/app/output/resume-audit.json'\nwith open(p) as f: d=json.load(f)\ncases=d.get('cases',[])\nbad=[]\nfor i,c in enumerate(cases):\n    if not c.get('ok',False):\n        bad.append((i,c.get('case') or c.get('name') or c.get('id'),c.get('visibility')))\nprint('total',len(cases))\nprint('bad',len(bad))\nfor i,name,vis in bad[:50]:\n    print(i,name,vis)\nPY\n"]
