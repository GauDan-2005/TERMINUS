[20.819909, "i", "python3 - <<'PY'\nimport json\nfrom collections.abc import Mapping, Sequence\np='/app/output/resume-audit.json'\nwith open(p) as f: d=json.load(f)\n\ndef dig_illegal(obj):\n    # find any key named 'illegal' under fresh/resume summaries\n    if isinstance(obj, Mapping):\n        if 'illegal' in obj and isinstance(obj['illegal'], int):\n            return obj['illegal']\n        for v in obj.values():\n            r=dig_illegal(v)\n            if r is not None:\n                return r\n    elif isinstance(obj, Sequence) and not isinstance(obj,(str,bytes)):\n        for v in obj:\n            r=dig_illegal(v)\n            if r is not None:\n                return r\n    return None\n\ndef dig_sig(obj):\n    if isinstance(obj, Mapping):\n        for k in ('signature','sig','hash'):\n            if k in obj and isinstance(obj[k], str):\n                return obj[k]\n        for v in obj.values():\n            r=dig_sig(v)\n            if r is not None:\n                return r\n    elif isinstance(obj, Sequence) and not isinstance(obj,(str,bytes)):\n        for v in obj:\n            r=dig_sig(v)\n            if r is not None:\n                return r\n    return None\n\ncases=d.get('cases',[])\nproblems=[]\nfor c in cases:\n    name=c.get('case') or c.get('name') or c.get('id')\n    if not c.get('ok',False):\n        problems.append((name,'ok=false'))\n        continue\n    fresh=c.get('fresh') or {}\n    resume=c.get('resume') or {}\n    fi=dig_illegal(fresh)\n    ri=dig_illegal(resume)\n    if fi not in (None,0):\n        problems.append((name,f'fresh illegal={fi}'))\n    if ri not in (None,0):\n        problems.append((name,f'resume illegal={ri}'))\n    fs=dig_sig(fresh)\n    rs=dig_sig(resume)\n    if fs is not None and rs is not None and fs!=rs:\n        problems.append((name,f'signature mismatch fresh={fs} resume={rs}'))\n\nprint('cases',len(cases))\nif problems:\n    print('PROBLEMS',len(problems))\n    for n,why in problems:\n        print(n,why)\n    raise SystemExit(1)\nprint('audit looks clean')\nPY\n"]
