[19.143497, "o", "# Grid turn engine\r\n\r\nLocal workspace for scripted grid scenarios. Build with `make build` and drive cases through `scripts/run-matrix.sh`.\r\n"]
[19.14382, "o", "\u001b[?2004hroot@f30385e12b3c:/app# "]
