[56.78632, "o", "cat /app/internal/a0/pack.go\r\n\u001b[?2004l\r"]
[56.787594, "o", "package a0\r\n\r\ntype stateX struct {\r\n\tLit  []bool\r\n\tSeen []bool\r\n\tTurn int\r\n}\r\n\r\ntype EffectSnap struct {\r\n\tID         string\r\n\tExpiryTurn int\r\n\tActive     bool\r\n}\r\n\r\ntype HostileSnap struct {\r\n\tID string\r\n\tX  int\r\n\tY  int\r\n}\r\n\r\ntype ItemY struct {\r\n\tLit      []bool\r\n\tSeen     []bool\r\n\tTurn     int\r\n\tObs      map[string]bool\r\n\tEffects  []EffectSnap\r\n\tWidth    int\r\n\tHeight   int\r\n\tPlayerX  int\r\n\tPlayerY  int\r\n\tHostiles []HostileSnap\r\n}\r\n\r\nfunc phase_a(a *stateX, b ItemY) error {\r\n\ta.Lit = append([]bool(nil), b.Lit...)\r\n\ta.Seen = append([]bool(nil), b.Seen...)\r\n\ta.Turn = b.Turn\r\n\treturn nil\r\n}\r\n\r\nfunc PackItem(b ItemY) ItemY {\r\n\tst := &stateX{}\r\n\t_ = phase_a(st, b)\r\n\tout := b\r\n\tout.Seen = make([]bool, len(b.Seen))\r\n\treturn out\r\n}\r\n\u001b[?2004hroot@f30385e12b3c:/app# "]
[57.294389, "i", "cat /app/internal/b1/cache.go\n"]
