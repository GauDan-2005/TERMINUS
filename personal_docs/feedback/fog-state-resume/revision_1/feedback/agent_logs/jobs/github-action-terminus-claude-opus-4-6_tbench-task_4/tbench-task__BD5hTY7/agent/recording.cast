[107.766995, "o", "cat /app/probe/legality.c\r\n\u001b[?2004l\r"]
[107.767628, "o", "#include \"legality.h\"\r\n\r\nint walk_e(struct qx *a, int x0, int y0, int x1, int y1) {\r\n    if (!a || !a->grid) {\r\n        return 0;\r\n    }\r\n    if (x0 == x1 && y0 == y1) {\r\n        return 1;\r\n    }\r\n    int dx = x1 - x0;\r\n    int dy = y1 - y0;\r\n    if (dx < 0) {\r\n        dx = -dx;\r\n    }\r\n    if (dy < 0) {\r\n        dy = -dy;\r\n    }\r\n    if (dx > 1 || dy > 1) {\r\n        return 1;\r\n    }\r\n    if (a->grid[y1 * a->width + x1]) {\r\n        return 0;\r\n    }\r\n    return 1;\r\n}\r\n"]
[107.768314, "o", "\u001b[?2004hroot@f30385e12b3c:/app# "]
[108.258155, "i", "cat /app/probe/legality.h\n"]
[108.264633, "o", "cat /app/probe/legality.h\r\n\u001b[?2004l\r"]
[108.265493, "o", "#ifndef LEGALITY_H\r\n#define LEGALITY_H\r\n\r\nstruct qx {\r\n    int width;\r\n    int height;\r\n    int *grid;\r\n};\r\n\r\nint walk_e(struct qx *a, int x0, int y0, int x1, int y1);\r\n\r\n#endif\r\n"]
