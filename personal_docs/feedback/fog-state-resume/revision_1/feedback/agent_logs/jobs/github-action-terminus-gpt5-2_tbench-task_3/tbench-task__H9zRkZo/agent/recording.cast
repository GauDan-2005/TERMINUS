[25.87627, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: a=json.load(f)\nprint('cases:', len(a.get('cases',[])))\nfor c in a.get('cases',[]):\n    name=c.get('name')\n    ok=c.get('ok')\n    fresh=c.get('fresh',{})\n    resume=c.get('resume',{})\n    print(f\"{name:9} ok={ok} fresh(illegal={fresh.get('illegal')}, steps={fresh.get('steps')}, sig={fresh.get('sig')}) resume(illegal={resume.get('illegal')}, steps={resume.get('steps')}, sig={resume.get('sig')})\")\nPY\n"]
