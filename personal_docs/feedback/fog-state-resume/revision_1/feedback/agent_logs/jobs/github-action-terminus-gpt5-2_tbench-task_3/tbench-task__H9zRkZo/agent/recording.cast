[26.888566, "i", "python3 - <<'PY'\nimport json, pathlib\np=pathlib.Path('/app/output/resume-audit.json')\na=json.loads(p.read_text())\nfor c in a['cases']:\n    if not c.get('ok') or c.get('fresh',{}).get('illegal') or c.get('resume',{}).get('illegal'):\n        print('\\n==', c['name'], '==')\n        print('ok:', c.get('ok'))\n        print('records:', c.get('records'))\n        print('log:', c.get('log'))\n        print('fresh:', c.get('fresh'))\n        print('resume:', c.get('resume'))\n        print('moves:', len(c.get('moves',[])))\n        bad=[m for m in c.get('moves',[]) if not m.get('legal',True)]\n        print('illegal moves:', len(bad))\n        if bad:\n            print('first illegal:', bad[0])\nPY\n"]
