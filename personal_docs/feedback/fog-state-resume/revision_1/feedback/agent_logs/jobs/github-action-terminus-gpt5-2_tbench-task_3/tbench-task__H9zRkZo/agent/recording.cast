[75.385501, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Update File: internal/f5/run.go\n@@\n-func playUntilSave(w *World, steps []ScriptStep, profile Profile, radius int) (a0.ItemY, bool) {\n+// playUntilSave advances the world until a save/checkpoint is taken.\n+// It returns the packed checkpoint blob, whether it was marked stale, and\n+// the list of hostile move rows produced before the save.\n+func playUntilSave(w *World, steps []ScriptStep, profile Profile, radius int) (a0.ItemY, bool, []MoveRow) {\n         cache := buildObs(w, nil)\n         moves := []MoveRow{}\n         for _, step := range steps {\n@@\n                 if step.Save {\n                         blob := packWorld(w, cache)\n-                        return blob, step.Stale\n+                        return blob, step.Stale, moves\n                 }\n@@\n         }\n-        return packWorld(w, cache), false\n+        return packWorld(w, cache), false, moves\n }\n@@\n-        blob, stale := playUntilSave(wFresh, steps, profile, radius)\n+        blob, stale, preResumeMoves := playUntilSave(wFresh, steps, profile, radius)\n         freshMoves := runDirect(wFresh, steps, profile, radius)\n@@\n-        playUntilSave(wResume, steps, profile, radius)\n-        resumeMoves := runLoaded(wResume, steps, blob, stale, profile, radius)\n+        _, _, _ = playUntilSave(wResume, steps, profile, radius)\n+        postResumeMoves := runLoaded(wResume, steps, blob, stale, profile, radius)\n+        resumeMoves := append(append([]MoveRow{}, preResumeMoves...), postResumeMoves...)\n*** End Patch\nPATCH\n"]
