[26.91679, "o", "\r\n== rook ==\r\nok: False\r\nrecords: /app/workspace/rook/records.jsonl\r\n"]
[26.916843, "o", "log: /app/workspace/rook/trace.tsv\r\nfresh: {'sig': '7d3f56fa', 'illegal': 0, 'steps': 1}\r\nresume: {'sig': '24ebc3c9', 'illegal': 0, 'steps': 1}\r\nmoves: 2\r\nillegal moves: 0\r\n"]
[26.916995, "o", "\r\n== sentinel ==\r\nok: False\r\nrecords: /app/workspace/sentinel/records.jsonl\r\nlog: /app/workspace/sentinel/trace.tsv\r\nfresh: {'sig': '9a98d68', 'illegal': 0, 'steps': 1}\r\nresume: {'sig': '691e8e87', 'illegal': 0, 'steps': 1}\r\nmoves: 2\r\nillegal moves: 0\r\n"]
[26.920584, "o", "\u001b[?2004hroot@ddf480d0dc66:/app# "]
[27.880653, "i", "python3 - <<'PY'\nimport json, pathlib\nfrom itertools import islice\np=pathlib.Path('/app/output/resume-audit.json')\na=json.loads(p.read_text())\nfor c in a['cases']:\n    rec=c.get('records'); log=c.get('log')\n    if not rec or not log: continue\n    recp=pathlib.Path(rec)\n    logp=pathlib.Path(log)\n    if not (recp.exists() and logp.exists()):\n        print(c['name'], 'missing', recp.exists(), logp.exists())\n        continue\n    rec_rows=[json.loads(line) for line in recp.read_text().splitlines() if line.strip()]\n    log_rows=[line.split() for line in logp.read_text().splitlines() if line.strip()]\n    moves=c.get('moves',[])\n    if len(rec_rows)!=len(moves) or len(log_rows)!=len(moves):\n        print(c['name'], 'rowcount mismatch', len(moves), len(rec_rows), len(log_rows))\n        continue\n    # spot-check first differing entry by turn/side/from/to/kind/legal if present\n    def norm_move(m):\n        keys=['turn','side','from','to','kind','legal']\n        out={k:m.get(k) for k in keys}\n        # allow side to be id or object\n        if isinstance(out['side'], dict) and 'id' in out['side']:\n            out['side']=out['side']['id']\n        return out\n    # records may store same structure\n    for i,(m,r) in enumerate(zip(moves,rec_rows)):\n        if norm_move(m)!=norm_move(r):\n            print(c['name'], 'records mismatch at', i)\n            print('move', norm_move(m))\n            print('rec ', norm_move(r))\n            break\nPY\n"]
