/resume-audit.json:128:        \"illegal\": 0,\r\n/app/output/resume-audit.json:140:          \"legal\": true\r\n/app/output/resume-audit.json:150:          \"legal\": true\r\n/app/output/resume-audit.json:153:      \"visibility\": {\r\n/app/output/resume-audit.json:171:        \"sig\": \"811c9dc5\",\r\n/app/output/resume-audit.json:172:        \"illegal\": 0,\r\n/app/output/resume-audit.json:175:      \"re"]
