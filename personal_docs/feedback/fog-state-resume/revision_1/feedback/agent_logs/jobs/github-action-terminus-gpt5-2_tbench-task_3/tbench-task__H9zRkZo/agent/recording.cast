[133.316618, "o", "\u001b[?2004hroot@ddf480d0dc66:/app# "]
[141.380597, "i", "python3 - <<'PY'\nimport json, pathlib\nA=json.load(open('/app/output/resume-audit.json'))\nerrs=0\nfor c in A['cases']:\n    name=c['name']\n    moves=c.get('moves',[])\n    recp=pathlib.Path(c['records'])\n    logp=pathlib.Path(c['log'])\n    rec_lines=[ln for ln in recp.read_text().splitlines() if ln.strip()]\n    log_lines=[ln for ln in logp.read_text().splitlines() if ln.strip()]\n    if len(rec_lines)!=len(moves) or len(log_lines)!=len(moves):\n        print(name,'rowcount mismatch',len(moves),len(rec_lines),len(log_lines))\n        errs+=1\n        continue\n    rec_rows=[json.loads(ln) for ln in rec_lines]\n    def norm(m):\n        return {k:m.get(k) for k in ['turn','actor','from_x','from_y','to_x','to_y','kind','legal']}\n    for i,(m,r) in enumerate(zip(moves,rec_rows)):\n        if norm(m)!=norm(r):\n            print(name,'records content mismatch at',i,'move',norm(m),'rec',norm(r))\n            errs+=1\n            break\n    # log columns: name turn actor from_x from_y to_x to_y legal\n    for i,(m,ln) in enumerate(zip(moves,log_lines)):\n        cols=ln.split('\\t')\n        if len(cols)<8:\n            print(name,'log parse mismatch at',i,ln)\n            errs+=1\n            break\n        got={\n            'turn':int(cols[1]),'actor':cols[2],\n            'from_x':int(cols[3]),'from_y':int(cols[4]),\n            'to_x':int(cols[5]),'to_y':int(cols[6]),\n            'legal': cols[7].strip().lower()=='true'\n        }\n        exp=norm(m)\n        exp.pop('kind',None)\n        if got!=exp:\n            print(name,'log content mismatch at',i,'got',got,'exp',exp)\n            errs+=1\n            break\nprint('OK' if errs==0 else f'FAIL ({errs})')\nPY\n"]
