[68.884543, "o", "package sim\r\n\r\ntype Profile struct {\r\n\tName      string\r\n\tRadius    int\r\n\tBlind     bool\r\n\tDense     bool\r\n"]
[68.884578, "o", "\tEpoch     bool\r\n\tMixed     bool\r\n\tCheckTurn int\r\n}\r\n\r\ntype MoveRow struct {\r\n\tTurn  int    `json:\"turn\"`\r\n\tActor string `json:\"actor\"`\r\n\tFromX int    `json:\"from_x\"`\r\n\tFromY int    `json:\"from_y\"`\r\n\tToX   int    `json:\"to_x\"`\r\n\tToY   int    `json:\"to_y\"`\r\n\tKind  string `json:\"kind\"`\r\n\tLegal bool   `json:\"legal\"`\r\n}\r\n"]
[68.8846, "o", "\r\ntype PathSummary struct {\r\n\tSig     string `json:\"sig\"`\r\n\tIllegal int    `json:\"illegal\"`\r\n\tSteps   int    `json:\"steps\"`\r\n}\r\n\r\n"]
[68.884621, "o", "type VisPair struct {\r\n\tFreshSeen  int `json:\"fresh_seen\"`\r\n\tResumeSeen int `json:\"resume_seen\"`\r\n}\r\n\r\ntype EffectRow struct {\r\n"]
[68.884639, "o", "\tID     string `json:\"id\"`\r\n\tActive bool   `json:\"active\"`\r\n\tEpoch  int    `json:\"epoch\"`\r\n}\r\n\r\ntype CaseResult struct {\r\n"]
[68.88466, "o", "\tName       string      `json:\"name\"`\r\n\tOK         bool        `json:\"ok\"`\r\n\tFresh      PathSummary `json:\"fresh\"`\r\n\tResume     PathSummary `json:\"resume\"`\r\n\tMoves      []MoveRow   `json:\"moves\"`\r\n"]
