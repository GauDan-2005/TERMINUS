[241.682644, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\nprint('all ok:', all(c.get('ok') for c in data.get('cases',[])))\nfor c in data.get('cases',[]):\n    if not c.get('ok'):\n        print('FAIL',c['name'],c['fresh'],c['resume'],c.get('visibility'))\nPY\n"]
