[247.64281, "i", "python3 - <<'PY'\nimport json\n\ndef load(path):\n    with open(path) as f:\n        return json.load(f)\n\nmatrix=load('/app/output/resume-audit.json')\nfor name in ['rook','sentinel']:\n    single=load(f'/app/output/single-{name}.json')['cases'][0]\n    row=next(c for c in matrix['cases'] if c['name']==name)\n    # compare everything except records/log paths (they can be the same, but keep robust)\n    def norm(c):\n        c=dict(c)\n        c.pop('records',None)\n        c.pop('log',None)\n        return c\n    print(name,'matches:', norm(single)==norm(row))\nPY\n"]
[247.643772, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def load(path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[247.649681, "o", "    with open(path) as f:\r\n\u001b[?2004l\r\u001b[?2004h>         return json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> matrix=load('/app/output/resume-audit.json')\r\n\u001b[?2004l\r\u001b[?2004h> for name in ['rook','sentinel']:\r\n\u001b[?2004l\r\u001b[?2004h>     single=load(f'/app/output/single-{name}.json')['cases'][0]\r\n\u001b[?2004l\r\u001b[?2004h>     row=next(c for c in matrix['cases'] if c['name']==name)\r\n\u001b[?2004l\r\u001b[?2004h>     # compare everything except records/log paths (they can be the same, but keep robust)\r\n\u001b[?2004l\r\u001b[?2004h>     def norm(c):\r\n\u001b[?2004l\r\u001b[?2004h>         c=dict(c)\r\n\u001b[?2004l\r\u001b[?2004h>         c.pop('records',None)\r\n\u001b[?2004l\r\u001b[?2004h>         c.pop('log',None)\r\n\u001b[?2004l\r\u001b[?2004h>         return c\r\n\u001b[?2004l\r\u001b[?2004h>     print(name,'matches:', norm(single)==norm(row))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
[247.664488, "o", "rook matches: True\r\n"]
[247.664638, "o", "sentinel matches: True\r\n"]
[247.667487, "o", "\u001b[?2004hroot@6d34054701b6:/app# "]
