[60.908507, "o", "#!/bin/bash\r\nset -euo pipefail\r\nout=\"/app/output/resume-audit.json\"\r\nwork=\"\"\r\none_case=\"\"\r\nwhile [ \"$#\" -gt 0 ]; do\r\n"]
[60.909807, "o", "  case \"$1\" in\r\n    --out) out=\"$2\"; shift 2 ;;\r\n    --work) work=\"$2\"; shift 2 ;;\r\n    --case) one_case=\"$2\"; shift 2 ;;\r\n    *) shift ;;\r\n  esac\r\ndone\r\nmkdir -p \"$(dirname \"$out\")\"\r\nmake -s -C /app build\r\nargs=(\"--out\" \"$out\")\r\nif [ -n \"$work\" ]; then\r\n"]
[60.909865, "o", "  args+=(\"--root\" \"$work\")\r\nfi\r\nif [ -n \"$one_case\" ]; then\r\n  args+=(\"--case\" \"$one_case\")\r\nfi\r\n/app/bin/rogctl \"${args[@]}\"\r\n"]
