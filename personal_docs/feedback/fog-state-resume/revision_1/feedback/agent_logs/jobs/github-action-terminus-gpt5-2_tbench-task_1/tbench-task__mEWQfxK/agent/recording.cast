[230.671293, "i", "python3 - <<'PY'\nimport json\nfor name in ['rook','sentinel']:\n    p=f'/app/output/single-{name}.json'\n    with open(p) as f: data=json.load(f)\n    c=data['cases'][0]\n    print(name,'ok',c['ok'], 'fresh',c['fresh'], 'resume',c['resume'], 'vis',c['visibility'])\nPY\n"]
