[214.655428, "i", "python3 - <<'PY'\nfrom pathlib import Path\np=Path('/app/internal/f5/run.go')\ns=p.read_text()\nstart=s.find('func runLoaded(')\nif start==-1:\n    raise SystemExit('runLoaded not found')\ni=s.find('{', start)\nbrace=0\nj=i\nwhile j < len(s):\n    if s[j]=='{': brace+=1\n    elif s[j]=='}':\n        brace-=1\n        if brace==0:\n            end=j+1\n            break\n    j+=1\nelse:\n    raise SystemExit('could not find end')\nnew='''func runLoaded(w *World, steps []ScriptStep, blob a0.ItemY, stale map[string]bool, profile Profile, radius int) []MoveRow {\n        applyWorld(w, blob)\n        cache := &b1.CacheX{Obs: map[string]bool{}}\n        b1.Merge(cache, blob)\n        merged := b1.Snapshot(cache)\n        for k, v := range stale {\n                merged[k] = v\n        }\n\n        w.Effects = snapFromC2(c2.SyncBoundary(snapToC2(w.Effects), blob.Turn, w.Turn))\n        // Ensure we resume with the same lighting/visibility baseline as a fresh run.\n        e4.ApplyLit(w, radius, blindActive(w))\n\n        // Start from current world-derived observations, then overlay the loaded\n        // (cached) observations from the snapshot/stale map.\n        obs := buildObs(w, nil)\n        for k, v := range merged {\n                if v {\n                        obs[k] = true\n                }\n        }\n\n        // Replay post-save script steps to match the direct path.\n        moves := []MoveRow{}\n        pastSave := false\n        for _, step := range steps {\n                if step.Action == \"save\" {\n                        pastSave = true\n                        continue\n                }\n                if !pastSave {\n                        continue\n                }\n                w.Turn = step.Turn\n                if step.Actor == \"P\" {\n                        applyPlayer(w, step.Arg)\n                        e4.ApplyLit(w, radius, blindActive(w))\n                        obs = buildObs(w, nil)\n                }\n                if step.Actor == \"H\" {\n                        moves = append(moves, advanceAll(w, obs)...)\n                }\n        }\n        return moves\n}'''\np.write_text(s[:start]+new+s[end:])\nprint('rewrote runLoaded')\nPY\n"]
