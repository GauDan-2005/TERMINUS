[176.219559, "i", "python3 - <<'PY'\nfrom pathlib import Path\np=Path('/app/internal/f5/run.go')\ns=p.read_text().splitlines(True)\n# Patch playUntilSave: inject ApplyLit before packing on save\nout=[]\nfor i,line in enumerate(s):\n    out.append(line)\n    if line.strip()==\"if step.Action == \\\"save\\\" {\":\n        # look ahead to ensure we patch only once at correct spot\n        pass\n# do a simpler text replace\ntext=''.join(s)\nneedle='\\t\\tif step.Action == \"save\" {\\n\\t\\t\\tvis := buildObs(w, nil)\\n'\nif needle in text:\n    text=text.replace(needle,'\\t\\tif step.Action == \"save\" {\\n\\t\\t\\t// Ensure snapshot carries the same lighting/visibility baseline as a direct run.\\n\\t\\t\\te4.ApplyLit(w, radius, blindActive(w))\\n\\t\\t\\tvis := buildObs(w, nil)\\n')\nelse:\n    print('playUntilSave needle not found')\n# Patch runLoaded: after SyncBoundary, apply lit; init obs via buildObs then merge stale\nneedle2='\\tw.Effects = snapFromC2(c2.SyncBoundary(snapToC2(w.Effects), blob.Turn, w.Turn))\\n\\n\\t// Resume path should replay the same post-save script steps as the fresh\\n'\nif needle2 in text:\n    text=text.replace(needle2,'\\tw.Effects = snapFromC2(c2.SyncBoundary(snapToC2(w.Effects), blob.Turn, w.Turn))\\n\\t// Recompute lighting after loading so planning/visibility matches fresh runs.\\n\\te4.ApplyLit(w, radius, blindActive(w))\\n\\n\\t// Resume path should replay the same post-save script steps as the fresh\\n')\nelse:\n    print('runLoaded sync needle not found')\nneedle3='\\tpastSave := false\\n\\tobs := merged\\n'\nif needle3 in text:\n    text=text.replace(needle3,'\\tpastSave := false\\n\\tobs := buildObs(w, nil)\\n\\tfor k, v := range merged {\\n\\t\\tif v {\\n\\t\\t\\tobs[k] = true\\n\\t\\t}\\n\\t}\\n')\nelse:\n    print('obs init needle not found')\np.write_text(text)\nprint('patched playUntilSave + runLoaded lit/obs init')\nPY\n"]
