[120.871253, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\nfail=[]\nfor c in data.get('cases',[]):\n    if not c.get('ok'):\n        fail.append((c['name'], c['fresh'], c['resume'], c.get('visibility')))\nprint('failures:', len(fail))\nfor x in fail:\n    print(x)\nPY\n"]
