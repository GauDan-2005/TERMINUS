[29.495233, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\nfor name in ['rook','sentinel']:\n    c=next(x for x in data['cases'] if x['name']==name)\n    print('\\n==',name,'==')\n    print('ok',c['ok'])\n    print('fresh',c['fresh'])\n    print('resume',c['resume'])\n    print('moves:', json.dumps(c.get('moves',[]), indent=2))\nPY\n"]
