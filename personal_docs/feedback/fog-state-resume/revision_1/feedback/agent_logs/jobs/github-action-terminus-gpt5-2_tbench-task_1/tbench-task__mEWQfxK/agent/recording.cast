[30.504272, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\n\ndef load_jsonl(p):\n    rows=[]\n    for line in Path(p).read_text().splitlines():\n        if not line.strip():\n            continue\n        rows.append(json.loads(line))\n    return rows\n\na='/app/output/resume-audit.json'\nwith open(a) as f: data=json.load(f)\nfor name in ['rook','sentinel']:\n    c=next(x for x in data['cases'] if x['name']==name)\n    moves=c.get('moves',[])\n    recp=c['records']\n    logp=c['log']\n    recs=load_jsonl(recp)\n    print('\\n==',name,'==')\n    print('moves',len(moves),'records',len(recs))\n    print('moves==records:', moves==recs)\n    # show log rows count (nonblank)\n    log_lines=[ln for ln in Path(logp).read_text().splitlines() if ln.strip()]\n    print('log rows:', len(log_lines))\n    if moves!=recs:\n        for i,(m,r) in enumerate(zip(moves,recs)):\n            if m!=r:\n                print('first diff at',i)\n                print(' move',m)\n                print(' rec ',r)\n                break\nPY\n"]
