[61.017524, "o", "#!/bin/bash\r\nset -euo pipefail\r\nif [ \"$#\" -lt 1 ]; then\r\n  echo \"usage: one-case.sh <name>\" >&2\r\n  exit 2\r\nfi\r\nname=\"$1\"\r\nout=\"/app/output/single-${name}.json\"\r\nbash /app/scripts/run-matrix.sh --out \"$out\" --case \"$name\"\r\n\u001b[?2004hroot@6d34054701b6:/app# "]
