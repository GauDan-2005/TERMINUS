[19.356582, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\ncases=data.get('cases',[])\nprint('cases:', [c.get('name') for c in cases])\nfor c in cases:\n    name=c.get('name')\n    ok=c.get('ok')\n    fresh=c.get('fresh',{})\n    resume=c.get('resume',{})\n    fi=fresh.get('illegal'); ri=resume.get('illegal')\n    fs=fresh.get('sig'); rs=resume.get('sig')\n    fsteps=fresh.get('steps'); rsteps=resume.get('steps')\n    if not ok or fi or ri or (fs!=rs and fs and rs):\n        print('\\nFAIL:', name)\n        print(' ok:', ok)\n        print(' fresh illegal/steps/sig:', fi, fsteps, fs)\n        print(' resume illegal/steps/sig:', ri, rsteps, rs)\n        print(' records:', c.get('records'))\n        print(' log:', c.get('log'))\n        print(' visibility:', c.get('visibility'))\n        print(' effects:', c.get('effects'))\nPY\n"]
