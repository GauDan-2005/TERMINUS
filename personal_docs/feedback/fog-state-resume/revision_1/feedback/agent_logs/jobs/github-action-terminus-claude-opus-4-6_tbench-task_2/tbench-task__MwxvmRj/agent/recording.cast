[88.836459, "o", "package sim\r\n\r\ntype Hostile struct {\r\n\tID string\r\n\tX  int\r\n\tY  int\r\n}\r\n\r\ntype World struct {\r\n\tWidth   int\r\n\tHeight  int\r\n\tWalls   []bool\r\n\tPlayerX int\r\n\tPlayerY int\r\n\tHostile []Hostile\r\n\tTurn    int\r\n\tSeen    []bool\r\n\tLit     []bool\r\n\tEffects []EffectState\r\n}\r\n\r\ntype EffectState struct {\r\n\tID         string\r\n\tExpiryTurn int\r\n\tActive     bool\r\n}\r\n\r\nfunc (w *World) Idx(x, y int) int {\r\n\treturn y*w.Width + x\r\n}\r\n\r\nfunc (w *World) InBounds(x, y int) bool {\r\n\treturn x >= 0 && y >= 0 && x < w.Width && y < w.Height\r\n}\r\n\r\nfunc (w *World) IsWall(x, y int) bool {\r\n\tif !w.InBounds(x, y) {\r\n\t\treturn true\r\n\t}\r\n\treturn w.Walls[w.Idx(x, y)]\r\n}\r\n\u001b[?2004hroot@26548499ec8e:/app# "]
