[296.823807, "o", "            print(f\"Found at line {i}: {line}\")\r\n\u001b[?2004l\r"]
[296.823835, "o", "\u001b[?2004h> "]
[296.823952, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h"]
