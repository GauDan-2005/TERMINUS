   144	
   145	func applyWorld(w *World, item a0.ItemY) {
   146		w.Width = item.Width
   147		w.Height = item.Height
   148		w.PlayerX = item.PlayerX
   149		w.PlayerY = item.PlayerY
   150		w.Turn = item.Turn
   151		w.Lit = append([]bool(nil), item.Lit...)
   152		w.Seen = append([]bool(nil), item.Seen...)
   153		w.Hostile = make([]Hostile, len(item.Hostiles))
   154		for i, h := range item.Hostiles {
   155			w.Hostile[i] = Hostile{ID: h.ID, X: h.X, Y: h.Y}
   156		}
   157		w.Effects = make([]EffectState, len(item.Effects))
   158		for i, e := range item.Effects {
   159			w.Effects[i] = EffectState{ID: e.ID, ExpiryTurn: e.ExpiryTurn, Active: e.Active}
   160		}
   161	}
   162	
   163	func playUntilSave(w *World, steps []ScriptStep, profile Profile, radius int) (a0.ItemY, map[string]bool) {
   164		visStale := map[string]bool{}
   165		var blob a0.ItemY
   166		for _, step := range steps {
   167			w.Turn = step.Turn
   168			if step.Action == "save" {
   169				vis := buildObs(w, nil)
   170				for k, v := range visStale {
   171					vis[k] = v
   172				}
   173				blob = packWorld(w, vis)
   174				break
   175			}
   176			if step.Actor == "P" {
   177				applyPlayer(w, step.Arg)
   178				e4.ApplyLit(w, radius, blindActive(w))
   179				visStale = buildObs(w, nil)
   180			}
   181		}
   182		return blob, visStale
   183	}
   184	
   185	func runDirect(w *World, steps []ScriptStep, profile Profile, radius int) []MoveRow {
   186		moves := []MoveRow{}
   187		pastSave := false
   188		for _, step := range steps {
   189			if step.Action == "save" {
   190				pastSave = true
   191				continue
   192			}
   193			if !pastSave {
   194				continue
   195			}
   196			w.Turn = step.Turn
   197			if step.Actor == "P" {
   198				applyPlayer(w, step.Arg)
   199				e4.ApplyLit(w, radius, blindActive(w))
   200			}
   201			if step.Actor == "H" {
   202				moves = append(moves, advanceAll(w, buildObs(w, nil))...)
   203			}
   204		}
   205		return moves
   206	}
   207	
   208	func runLoaded(w *World, steps []ScriptStep, blob a0.ItemY, stale map[string]bool, profile Profile, radius int) []MoveRow {
   209		applyWorld(w, blob)
   210		cache := &b1.CacheX{Obs: map[string]bool{}}
   211		b1.Merge(cache, blob)
   212		merged := b1.Snapshot(cache)
   213		for k, v := range stale {
   214			merged[k] = v
   215		}
   216		w.Effects = snapFromC2(c2.SyncBoundary(snapToC2(w.Effects), blob.Turn, w.Turn))
   217		moves := []MoveRow{}
   218		for _, step := range steps {
   219			if step.Action != "save" {
   220				continue
   221			}
   222			w.Turn = step.Turn
   223			e4.ApplyLit(w, radius, blindActive(w))
   224			moves = append(moves, advanceAll(w, merged)...)
   225		}
   226		return moves
   227	}
   228	
   229	func RunRow(root, name string) (CaseResult, error) {
   230		profile := ProfileFor(name)
   231		radius, _ := LoadRadius(root, name)
   232		if radius == 0 {
   233			radius = profile.Radius
   234		}
   235		base, err := LoadLayout(root, name)
   236		if err != nil {
   237			return CaseResult{}, err
   238		}
   239		steps, err := LoadScript(root, name)
   240		if err != nil {
   241			return CaseResult{}, err
   242		}
   243	
   244		wFresh := cloneWorld(base)
   245		wFresh.Effects = snapFromC2(c2.Seed(profileToC2(profile), wFresh.Turn))
   246		blob, stale := playUntilSave(wFresh, steps, profile, radius)
   247		freshMoves := runDirect(wFresh, steps, profile, radius)
   248	
   249		wResume := cloneWorld(base)
   250		wResume.Effects = snapFromC2(c2.Seed(profileToC2(profile), wResume.Turn))
   251		playUntilSave(wResume, steps, profile, radius)
   252		resumeMoves := runLoaded(wResume, steps, blob, stale, profile, radius)
   253	
   254		freshIllegal, resumeIllegal := 0, 0
   255		for _, m := range freshMoves {
   256			if !m.Legal {
   257				freshIllegal++
   258			}
   259		}
   260		for _, m := range resumeMoves {
   261			if !m.Legal {
   262				resumeIllegal++
   263			}
   264		}
   265		allMoves := append(append([]MoveRow{}, freshMoves...), resumeMoves...)
   266		caseDir := filepath.Join(root, "workspace", name)
   267		_ = os.MkdirAll(caseDir, 0o755)
   268		recPath := filepath.Join(caseDir, "records.jsonl")
   269		logPath := filepath.Join(caseDir, "trace.tsv")
   270		flushRows(recPath, logPath, name, allMoves)
   271	
   272		fresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}
   273		resume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}
   274		ok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig
   275	
   276		return CaseResult{
   277			Name:       name,
   278			OK:         ok,
   279			Fresh:      fresh,
   280			Resume:     resume,
   281			Moves:      allMoves,
   282			Visibility: VisPair{FreshSeen: e4.CountSeen(wFresh), ResumeSeen: e4.CountSeen(wResume)},
   283			Effects:    rowsFromC2(c2.ItemsFor(snapToC2(wResume.Effects), wResume.Turn)),
   284			Records:    recPath,
   285			Log:        logPath,
   286		}, nil
   287	}
   288	
   289	func flushRows(recPath, logPath, name string, moves []MoveRow) {
   290		rec, _ := os.Create(recPath)
   291		defer rec.Close()
   292		for _, m := range moves {
   293			b, _ := json.Marshal(m)
   294			_, _ = rec.Write(append(b, '\n'))
   295		}
   296		log, _ := os.Create(logPath)
   297		defer log.Close()
   298		for _, m := range moves {
   299			fmt.Fprintf(log, "%s\t%d\t%s\t%d\t%d\t%d\t%d\t%v\n",
   300				name, m.Turn, m.Actor, m.FromX, m.FromY, m.ToX, m.ToY, m.Legal)
   301		}
   302	}
