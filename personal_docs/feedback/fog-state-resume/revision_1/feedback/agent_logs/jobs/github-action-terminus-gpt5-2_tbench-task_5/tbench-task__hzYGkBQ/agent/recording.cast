[190.985001, "i", "python3 - <<'PY'\nimport json\nwith open('/app/output/resume-audit.json') as f: data=json.load(f)\nfor c in data['cases']:\n    name=c['name']\n    ok=c['ok']\n    fi=c['fresh']['illegal']; ri=c['resume']['illegal']\n    fs=c['fresh']['sig']; rs=c['resume']['sig']\n    vis=c['visibility']\n    print(f\"{name:9} ok={ok} illegal=({fi},{ri}) sig=({fs},{rs}) seen=({vis['fresh_seen']},{vis['resume_seen']}) moves={len(c['moves'])}\")\nPY\n"]
