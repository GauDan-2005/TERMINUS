[132.742761, "o", "   244\t\twFresh := cloneWorld(base)\r\n   245\t\twFresh.Effects = snapFromC2(c2.Seed(profileToC2(profile), wFresh.Turn))\r\n   246\t\tblob, stale := playUntilSave(wFresh, steps, profile, radius)\r\n   247\t\tfreshMoves := runDirect(wFresh, steps, profile, radius)\r\n   248\t\r\n   249\t\twResume := cloneWorld(base)\r\n   250\t\twResume.Effects = snapFromC2(c2.Seed(profileToC2(profile), wResume.Turn))\r\n   251\t\tplayUntilSave(wResume, steps, profile, radius)\r\n   252\t\tresumeMoves := runLoaded(wResume, steps, blob, stale, profile, radius)\r\n   253\t\r\n   254\t\tfreshIllegal, resumeIllegal := 0, 0\r\n   255\t\tfor _, m := range freshMoves {\r\n   256\t\t\tif !m.Legal {\r\n   257\t\t\t\tfreshIllegal++\r\n   258\t\t\t}\r\n   259\t\t}\r\n   260\t\tfor _, m := range resumeMoves {\r\n   261\t\t\tif !m.Legal {\r\n   262\t\t\t\tresumeIllegal++\r\n   263\t\t\t}\r\n   264\t\t}\r\n   265\t\tallMoves := append(append([]MoveRow{}, freshMoves...), resumeMoves...)\r\n   266\t\tcaseDir := filepath.Join(root, \"workspace\", name)\r\n   267\t\t_ = os.MkdirAll(caseDir, 0o755)\r\n   268\t\trecPath := filepath.Join(caseDir, \"records.jsonl\")\r\n   269\t\tlogPath := filepath.Join(caseDir, \"trace.tsv\")\r\n   270\t\tflushRows(recPath, logPath, name, allMoves)\r\n   271\t\r\n   272\t\tfresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\r\n   273\t\tresume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\r\n   274\t\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig\r\n   275\t\r\n   276\t\treturn CaseResult{\r\n   277\t\t\tName:       name,\r\n   278\t\t\tOK:         ok,\r\n   279\t\t\tFresh:      fresh,\r\n   280\t\t\tResume:     resume,\r\n   281\t\t\tMoves:      allMoves,\r\n   282\t\t\tVisibility: VisPair{FreshSeen: e4.CountSeen(wFresh), ResumeSeen: e4.CountSeen(wResume)},\r\n   283\t\t\tEffects:    rowsFromC2(c2.ItemsFor(snapToC2(wResume.Effects), wResume.Turn)),\r\n   284\t\t\tRecords:    recPath,\r\n   285\t\t\tLog:        logPath,\r\n   286\t\t}, nil\r\n   287\t}\r\n   288\t\r\n   289\tfunc flushRows(recPath, logPath, name string, moves []MoveRow) {\r\n   290\t\trec, _ := os.Create(recPath)\r\n   291\t\tdefer rec.Close()\r\n   292\t\tfor _, m := range moves {\r\n   293\t\t\tb, _ := json.Marshal(m)\r\n   294\t\t\t_, _ = rec.Write(append(b, '\\n'))\r\n   295\t\t}\r\n   296\t\tlog, _ := os.Create(logPath)\r\n   297\t\tdefer log.Close()\r\n   298\t\tfor _, m := range moves {\r\n   299\t\t\tfmt.Fprintf(log, \"%s\\t%d\\t%s\\t%d\\t%d\\t%d\\t%d\\t%v\\n\",\r\n   300\t\t\t\tname, m.Turn, m.Actor, m.FromX, m.FromY, m.ToX, m.ToY, m.Legal)\r\n   301\t\t}\r\n   302\t}\r\n"]
