[281.725841, "i", "python3 - <<'PY'\nimport json, itertools\n\ndef load_jsonl(path):\n    out=[]\n    with open(path) as f:\n        for line in f:\n            line=line.strip()\n            if not line: continue\n            out.append(json.loads(line))\n    return out\n\ndef load_tsv(path):\n    out=[]\n    with open(path) as f:\n        for line in f:\n            line=line.strip()\n            if not line: continue\n            cols=line.split()  # case turn actor fx fy tx ty legal\n            case,turn,actor,fx,fy,tx,ty,legal=cols[:8]\n            out.append({\n                'turn':int(turn),'actor':str(actor),'from_x':int(fx),'from_y':int(fy),\n                'to_x':int(tx),'to_y':int(ty),'kind':'step','legal': legal.lower() in ('1','true','t','yes')\n            })\n    return out\n\ndef norm(m):\n    return {\n        'turn':int(m['turn']), 'actor':str(m['actor']),\n        'from_x':int(m['from_x']), 'from_y':int(m['from_y']),\n        'to_x':int(m['to_x']), 'to_y':int(m['to_y']),\n        'kind':m['kind'], 'legal':bool(m['legal'])\n    }\n\nwith open('/app/output/resume-audit.json') as f: data=json.load(f)\nall_ok=True\nfor c in data['cases']:\n    moves=[norm(m) for m in c['moves']]\n    recs=[norm(r) for r in load_jsonl(c['records'])]\n    tsv=load_tsv(c['log'])\n    ok = (moves==recs==tsv)\n    print(f\"{c['name']:9} files_match={ok} rows={len(moves)}\")\n    if not ok:\n        all_ok=False\n        print('  moves:', moves)\n        print('  recs :', recs)\n        print('  tsv  :', tsv)\nprint('ALL_MATCH:', all_ok)\nPY\n"]
