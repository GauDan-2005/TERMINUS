[60.477629, "i", "python3 - <<'PY'\nimport json\n\ndef load_audit_case(name):\n    with open('/app/output/resume-audit.json') as f:\n        data=json.load(f)\n    for c in data['cases']:\n        if c['name']==name:\n            return c\n    raise SystemExit('missing case')\n\ndef load_jsonl(path):\n    rows=[]\n    with open(path) as f:\n        for line in f:\n            line=line.strip()\n            if not line: continue\n            rows.append(json.loads(line))\n    return rows\n\ndef load_tsv(path):\n    rows=[]\n    with open(path) as f:\n        for line in f:\n            line=line.strip()\n            if not line: continue\n            rows.append(line.split())\n    return rows\n\ndef norm_move(m):\n    return {\n        'turn': int(m['turn']),\n        'actor': str(m['actor']),\n        'from_x': int(m['from_x']),\n        'from_y': int(m['from_y']),\n        'to_x': int(m['to_x']),\n        'to_y': int(m['to_y']),\n        'kind': m['kind'],\n        'legal': bool(m['legal']),\n    }\n\ndef norm_tsv(cols):\n    # trace.tsv format: case turn actor from_x from_y to_x to_y legal\n    case,turn,actor,fx,fy,tx,ty,legal = cols[:8]\n    return {\n        'turn':int(turn),'actor':str(actor),'from_x':int(fx),'from_y':int(fy),\n        'to_x':int(tx),'to_y':int(ty),'kind':'step',\n        'legal': legal.lower() in ('1','true','t','yes')\n    }\n\nfor name in ['rook','sentinel']:\n    c=load_audit_case(name)\n    audit=[norm_move(m) for m in c['moves']]\n    recs=[norm_move(r) for r in load_jsonl(c['records'])]\n    tsv=[norm_tsv(r) for r in load_tsv(c['log'])]\n    print('\\n==',name,'==')\n    print('audit==records?', audit==recs)\n    print('audit==tsv?', audit==tsv)\n    if audit!=tsv:\n        print('audit:', audit)\n        print('tsv  :', tsv)\nPY\n"]
