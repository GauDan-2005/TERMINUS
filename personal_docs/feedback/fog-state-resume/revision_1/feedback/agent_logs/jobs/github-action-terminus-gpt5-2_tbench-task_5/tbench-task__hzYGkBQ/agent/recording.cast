[244.876607, "i", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\np=Path('/app/internal/f5/run.go')\ns=p.read_text().splitlines(True)\nout=[]\nfor i,line in enumerate(s):\n    out.append(line)\n    if line.strip()=='applyWorld(w, blob)':\n        out.append('        // Recompute lighting/visibility at the load boundary so planning matches the fresh path.\\n')\n        out.append('        w.Turn = blob.Turn\\n')\n        out.append('        e4.ApplyLit(w, radius, blindActive(w))\\n')\n        \nPath('/app/internal/f5/run.go').write_text(''.join(out))\nprint('inserted ApplyLit after applyWorld')\nPY\n"]
