[26.828784, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    data=json.load(f)\nprint('cases:', len(data.get('cases',[])))\nfor c in data.get('cases',[]):\n    name=c.get('name')\n    ok=c.get('ok')\n    fresh=c.get('fresh',{})\n    resume=c.get('resume',{})\n    fi=fresh.get('illegal')\n    ri=resume.get('illegal')\n    fs=fresh.get('sig')\n    rs=resume.get('sig')\n    print(f\"{name:9} ok={ok} fresh_illegal={fi} resume_illegal={ri} fresh_sig={fs} resume_sig={rs}\")\nPY\n"]
