[98.153197, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: internal/f5/run.go\n@@\n-        allMoves := append(append([]MoveRow{}, freshMoves...), resumeMoves...)\n+        // The audit's Moves/records/log must describe a single resolved move list\n+        // (the same list in the same order) for the scenario.\n+        // Fresh and resume are two execution paths that must reconcile to that list.\n+        //\n+        // Previously we concatenated fresh+resume which masked mismatches and made\n+        // the reported move list diverge from what the per-path signatures covered.\n+        resolvedMoves := append([]MoveRow{}, freshMoves...)\n@@\n-        flushRows(recPath, logPath, name, allMoves)\n+        flushRows(recPath, logPath, name, resolvedMoves)\n@@\n-        fresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\n-        resume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\n-        ok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig\n+        // Signature is over the resolved move list for the path.\n+        // If the two paths resolve the same move list, their signatures must match.\n+        fresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\n+        resume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\n+        ok := freshIllegal == 0 && resumeIllegal == 0 && len(freshMoves) == len(resumeMoves)\n+        if ok {\n+                for i := range freshMoves {\n+                        if freshMoves[i] != resumeMoves[i] {\n+                                ok = false\n+                                break\n+                        }\n+                }\n+        }\n@@\n                 Name:       name,\n                 OK:         ok,\n                 Fresh:      fresh,\n                 Resume:     resume,\n-                Moves:      allMoves,\n+                Moves:      resolvedMoves,\n                 Visibility: VisPair{FreshSeen: e4.CountSeen(wFresh), ResumeSeen: e4.CountSeen(wResume)},\n                 Effects:    rowsFromC2(c2.ItemsFor(snapToC2(wResume.Effects), wResume.Turn)),\n                 Records:    recPath,\n                 Log:        logPath,\n         }, nil\n }\n*** End Patch\nPATCH\n"]
