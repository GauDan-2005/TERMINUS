[49.941228, "i", "python3 - <<'PY'\nimport json\n\ndef load_one(path):\n    with open(path) as f: d=json.load(f)\n    return d['cases'][0]\n\ndef load_matrix(name):\n    with open('/app/output/resume-audit.json') as f: d=json.load(f)\n    for c in d['cases']:\n        if c['name']==name: return c\n\nfor name in ['rook','sentinel']:\n    one=load_one(f'/app/output/single-{name}.json')\n    mat=load_matrix(name)\n    print('\\n==== compare',name,'====')\n    for k in ['ok','fresh','resume','visibility','effects','moves','records','log']:\n        same = one.get(k)==mat.get(k)\n        print(f'{k}:', 'SAME' if same else 'DIFF')\n        if not same:\n            print('  matrix:', mat.get(k))\n            print('  single:', one.get(k))\nPY\n"]
