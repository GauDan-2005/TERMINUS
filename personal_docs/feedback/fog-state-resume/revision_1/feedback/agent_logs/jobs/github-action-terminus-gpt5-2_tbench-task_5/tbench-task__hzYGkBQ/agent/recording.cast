[292.733323, "i", "python3 - <<'PY'\nimport json\nwith open('/app/output/resume-audit.json') as f: mat=json.load(f)\nmat_by={c['name']:c for c in mat['cases']}\nall_same=True\nfor name in ['bishop','knight','lancer','rook','sentinel','warden']:\n    with open(f'/app/output/single-{name}.json') as f: one=json.load(f)['cases'][0]\n    same = (one==mat_by[name])\n    print(f\"{name:9} single_matches_matrix={same}\")\n    if not same:\n        all_same=False\nprint('ALL_SINGLE_MATCH:', all_same)\nPY\n"]
