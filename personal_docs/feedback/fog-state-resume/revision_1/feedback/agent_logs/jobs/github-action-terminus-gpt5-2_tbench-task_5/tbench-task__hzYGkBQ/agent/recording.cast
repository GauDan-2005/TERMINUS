[27.812829, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f:\n    data=json.load(f)\nprint('Failing cases detail:')\nfor c in data.get('cases',[]):\n    fresh=c.get('fresh',{})\n    resume=c.get('resume',{})\n    bad = (not c.get('ok')) or (fresh.get('illegal',0)!=0) or (resume.get('illegal',0)!=0)\n    if bad:\n        print('\\n==', c.get('name'), '==')\n        for k in ['ok','moves','visibility','effects','records','log']:\n            print(k+':', c.get(k))\n        print('fresh:', fresh)\n        print('resume:', resume)\nPY\n"]
