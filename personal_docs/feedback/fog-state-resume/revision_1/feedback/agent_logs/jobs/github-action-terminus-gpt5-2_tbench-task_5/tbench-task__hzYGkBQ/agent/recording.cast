[73.200054, "o", "/app/internal/f5/run.go:18:func sigFor(moves []MoveRow) string {\r\n/app/internal/f5/run.go:272:\tfresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\r\n/app/internal/f5/run.go:273:\tresume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\r\n/app/internal/sim/layout.go:86:\tpath := filepath.Join(root, \"config\", \"sight.tsv\")\r\n/app/internal/sim/types.go:25:\tSig     string `json:\"sig\"`\r\n/app/output/resume-audit.json:7:        \"sig\": \"811c9dc5\",\r\n/app/output/resume-audit.json:12:        \"sig\": \"811c9dc5\",\r\n/app/output/resume-audit.json:35:        \"sig\": \"811c9dc5\",\r\n/app/output/resume-audit.json:40:        \"sig\": \"811c9dc5\",\r\n/app/output/resume-audit.json:57:        \"sig\": \"811c9dc5\",\r\n/app/output/resume-audit.json:62:        \"sig\": \"811c9dc5\",\r\n/app/output/resume-audit.json:79:        \"sig\": \"7d3f56fa\",\r\n/app/output/resume-audit.json:84:        \"sig\": \"24ebc3c9\",\r\n/app/output/resume-audit.json:122:        \"sig\": \"9a98d68\",\r\n/app/output/resume-audit.json:127:        \"sig\": \"691e8e87\",\r\n/app/output/resume-audit.json:171:        \"sig\": \"811c9dc5\",\r\n/app/output/resume-audit.json:176:        \"sig\": \"811c9dc5\",\r\n/app/output/single-rook.json:7:        \"sig\": \"7d3f56fa\",\r\n/app/output/single-rook.json:12:        \"sig\": \"24ebc3c9\",\r\n/app/output/single-sentinel.json:7:        \"sig\": \"9a98d68\",\r\n/app/output/single-sentinel.json:12:        \"sig\": \"691e8e87\",\r\n"]
[73.200434, "o", "\u001b[?2004hroot@81dea2c5d812:/app# "]
[79.840268, "i", "sed -n '1,220p' /app/internal/f5/run.go\n"]
[79.840773, "o", "sed -n '1,220p' /app/internal/f5/run.go"]
[79.840827, "o", "\r\n\u001b[?2004l\r"]
[79.842406, "o", "package f5\r\n\r\nimport (\r\n\t\"encoding/json\"\r\n\t\"fmt\"\r\n\t\"os\"\r\n\t\"path/filepath\"\r\n\t\"strconv\"\r\n\t\"strings\"\r\n\r\n\t\"fog.local/resume/internal/a0\"\r\n\t\"fog.local/resume/internal/b1\"\r\n"]
[79.842449, "o", "\t\"fog.local/resume/internal/c2\"\r\n\t\"fog.local/resume/internal/d3\"\r\n\t\"fog.local/resume/internal/e4\"\r\n)\r\n\r\nfunc sigFor(moves []MoveRow) string {\r\n\tacc := int64(2166136261)\r\n\tfor _, m := range moves {\r\n\t\tacc ^= int64(m.Turn*31 + m.FromX*7 + m.FromY*11 + m.ToX*13 + m.ToY*17)\r\n\t\tfor _, ch := range m.Actor + m.Kind {\r\n\t\t\tacc ^= int64(ch)\r\n\t\t\tacc = (acc * 16777619) & 0x7fffffff\r\n\t\t}\r\n\t}\r\n\treturn fmt.Sprintf(\"%x\", acc)\r\n}\r\n\r\nfunc cloneWorld(w *World) *World {\r\n\tsize := w.Width * w.Height\r\n"]
[79.842469, "o", "\tseen := append([]bool(nil), w.Seen...)\r\n\tlit := append([]bool(nil), w.Lit...)\r\n\tif len(seen) != size {\r\n\t\tseen = make([]bool, size)\r\n\t}\r\n\tif len(lit) != size {\r\n"]
[79.842489, "o", "\t\tlit = make([]bool, size)\r\n\t}\r\n\treturn &World{\r\n\t\tWidth: w.Width, Height: w.Height,\r\n\t\tWalls:   append([]bool(nil), w.Walls...),\r\n\t\tPlayerX: w.PlayerX, PlayerY: w.PlayerY,\r\n"]
[79.84251, "o", "\t\tHostile: append([]Hostile(nil), w.Hostile...),\r\n\t\tTurn:    w.Turn,\r\n\t\tSeen:    seen,\r\n\t\tLit:     lit,\r\n\t\tEffects: append([]EffectState(nil), w.Effects...),\r\n"]
[79.842528, "o", "\t}\r\n}\r\n\r\nfunc applyPlayer(w *World, arg string) {\r\n\tparts := strings.Split(arg, \",\")\r\n"]
[79.842547, "o", "\tif len(parts) != 2 {\r\n\t\treturn\r\n\t}\r\n\tdx, _ := strconv.Atoi(parts[0])\r\n\tdy, _ := strconv.Atoi(parts[1])\r\n"]
[79.842567, "o", "\tnx, ny := w.PlayerX+dx, w.PlayerY+dy\r\n\tif w.InBounds(nx, ny) && !w.IsWall(nx, ny) {\r\n\t\tw.PlayerX, w.PlayerY = nx, ny\r\n\t}\r\n}\r\n\r\n"]
[79.842593, "o", "func buildObs(w *World, extra map[string]bool) map[string]bool {\r\n\tout := map[string]bool{}\r\n\tfor _, h := range w.Hostile {\r\n\t\tkey := fmt.Sprintf(\"%d,%d\", h.X, h.Y)\r\n\t\tif extra != nil && extra[key] {\r\n\t\t\tout[key] = true\r\n"]
[79.842612, "o", "\t\t\tcontinue\r\n\t\t}\r\n\t\tif e4.PlayerSees(w, h.X, h.Y) {\r\n\t\t\tout[key] = true\r\n\t\t}\r\n"]
[79.842631, "o", "\t}\r\n\treturn out\r\n}\r\n\r\nfunc advanceAll(w *World, cache map[string]bool) []MoveRow {\r\n"]
[79.842652, "o", "\trows := []MoveRow{}\r\n\tfor i := range w.Hostile {\r\n\t\trow, ok := d3.PlanSlot(w, cache, i)\r\n\t\tif ok {\r\n\t\t\trows = append(rows, row)\r\n"]
[79.842673, "o", "\t\t}\r\n\t}\r\n\treturn rows\r\n}\r\n\r\n"]
[79.842691, "o", "func blindActive(w *World) bool {\r\n\tfor _, e := range w.Effects {\r\n\t\tif e.ID == \"blind\" && w.Turn < e.ExpiryTurn {\r\n\t\t\treturn true\r\n\t\t}\r\n"]
[79.842711, "o", "\t}\r\n\treturn false\r\n}\r\n\r\nfunc snapToC2(effects []EffectState) []c2.EffectSnap {\r\n\tout := make([]c2.EffectSnap, len(effects))\r\n"]
[79.84273, "o", "\tfor i, e := range effects {\r\n\t\tout[i] = c2.EffectSnap{ID: e.ID, ExpiryTurn: e.ExpiryTurn, Active: e.Active}\r\n\t}\r\n"]
[79.842746, "o", "\treturn out\r\n}\r\n\r\nfunc snapFromC2(snaps []c2.EffectSnap) []EffectState {\r\n\tout := make([]EffectState, len(snaps))\r\n\tfor i, s := range snaps {\r\n\t\tout[i] = EffectState{ID: s.ID, ExpiryTurn: s.ExpiryTurn, Active: s.Active}\r\n"]
[79.842761, "o", "\t}\r\n\treturn out\r\n}\r\n\r\nfunc profileToC2(p Profile) c2.ProfileSnap {\r\n"]
[79.842777, "o", "\treturn c2.ProfileSnap{Blind: p.Blind, Epoch: p.Epoch, CheckTurn: p.CheckTurn}\r\n}\r\n"]
[79.842792, "o", "\r\nfunc rowsFromC2(rows []c2.RowSnap) []EffectRow {\r\n\tout := make([]EffectRow, len(rows))\r\n\tfor i, r := range rows {\r\n\t\tout[i] = EffectRow{ID: r.ID, Active: r.Active, Epoch: r.Epoch}\r\n\t}\r\n\treturn out\r\n"]
[79.842807, "o", "}\r\n\r\nfunc packWorld(w *World, obs map[string]bool) a0.ItemY {\r\n\teffects := make([]a0.EffectSnap, len(w.Effects))\r\n"]
[79.842827, "o", "\tfor i, e := range w.Effects {\r\n\t\teffects[i] = a0.EffectSnap{ID: e.ID, ExpiryTurn: e.ExpiryTurn, Active: e.Active}\r\n\t}\r\n\thostiles := make([]a0.HostileSnap, len(w.Hostile))\r\n"]
[79.842844, "o", "\tfor i, h := range w.Hostile {\r\n\t\thostiles[i] = a0.HostileSnap{ID: h.ID, X: h.X, Y: h.Y}\r\n\t}\r\n\titem := a0.ItemY{\r\n\t\tLit: w.Lit, Seen: w.Seen, Turn: w.Turn, Obs: obs,\r\n"]
[79.842862, "o", "\t\tEffects: effects, Width: w.Width, Height: w.Height,\r\n\t\tPlayerX: w.PlayerX, PlayerY: w.PlayerY, Hostiles: hostiles,\r\n\t}\r\n\treturn a0.PackItem(item)\r\n"]
[79.842881, "o", "}\r\n\r\nfunc applyWorld(w *World, item a0.ItemY) {\r\n\tw.Width = item.Width\r\n\tw.Height = item.Height\r\n"]
[79.842899, "o", "\tw.PlayerX = item.PlayerX\r\n\tw.PlayerY = item.PlayerY\r\n\tw.Turn = item.Turn\r\n\tw.Lit = append([]bool(nil), item.Lit...)\r\n\tw.Seen = append([]bool(nil), item.Seen...)\r\n\tw.Hostile = make([]Hostile, len(item.Hostiles))\r\n"]
[79.842916, "o", "\tfor i, h := range item.Hostiles {\r\n\t\tw.Hostile[i] = Hostile{ID: h.ID, X: h.X, Y: h.Y}\r\n\t}\r\n\tw.Effects = make([]EffectState, len(item.Effects))\r\n\tfor i, e := range item.Effects {"]
[79.842937, "o", "\r\n\t\tw.Effects[i] = EffectState{ID: e.ID, ExpiryTurn: e.ExpiryTurn, Active: e.Active}\r\n\t}\r\n}\r\n\r\n"]
[79.842956, "o", "func playUntilSave(w *World, steps []ScriptStep, profile Profile, radius int) (a0.ItemY, map[string]bool) {\r\n\tvisStale := map[string]bool{}\r\n\tvar blob a0.ItemY\r\n\tfor _, step := range steps {\r\n\t\tw.Turn = step.Turn\r\n"]
[79.842971, "o", "\t\tif step.Action == \"save\" {\r\n\t\t\tvis := buildObs(w, nil)\r\n\t\t\tfor k, v := range visStale {\r\n"]
[79.842991, "o", "\t\t\t\tvis[k] = v\r\n\t\t\t}\r\n\t\t\tblob = packWorld(w, vis)\r\n\t\t\tbreak\r\n"]
[79.84301, "o", "\t\t}\r\n\t\tif step.Actor == \"P\" {\r\n\t\t\tapplyPlayer(w, step.Arg)\r\n\t\t\t"]
[79.843028, "o", "e4.ApplyLit(w, radius, blindActive(w))\r\n\t\t\tvisStale = buildObs(w, nil)\r\n\t\t}\r\n"]
[79.843044, "o", "\t}\r\n\treturn blob, visStale\r\n}\r\n\r\nfunc runDirect(w *World, steps []ScriptStep, profile Profile, radius int) []MoveRow {\r\n\tmoves := []MoveRow{}\r\n\tpastSave := false\r\n"]
[79.843062, "o", "\tfor _, step := range steps {\r\n\t\tif step.Action == \"save\" {\r\n\t\t\tpastSave = true\r\n\t\t"]
[79.843081, "o", "\tcontinue\r\n\t\t}\r\n\t\tif !pastSave {\r\n\t\t\tcontinue\r\n\t\t}\r\n"]
[79.843098, "o", "\t\tw.Turn = step.Turn\r\n\t\tif step.Actor == \"P\" {\r\n\t\t\tapplyPlayer(w, step.Arg)\r\n\t\t\te4.ApplyLit(w, radius, blindActive(w))\r\n\t"]
[79.843114, "o", "\t}\r\n\t\tif step.Actor == \"H\" {\r\n"]
