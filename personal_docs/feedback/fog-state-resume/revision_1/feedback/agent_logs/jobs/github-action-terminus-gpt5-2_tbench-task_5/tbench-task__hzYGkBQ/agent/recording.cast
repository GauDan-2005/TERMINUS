[266.901043, "i", "python3 - <<'PY'\nimport json, itertools\nwith open('/app/output/resume-audit.json') as f: data=json.load(f)\nfor name in ['rook','sentinel']:\n    c=[x for x in data['cases'] if x['name']==name][0]\n    print('\\n==',name,'== ok',c['ok'])\n    print('moves:', c['moves'])\n    print('records:')\n    with open(c['records']) as f:\n        for line in itertools.islice(f,0,5):\n            if line.strip(): print(line.strip())\n    print('log:')\n    with open(c['log']) as f:\n        for line in itertools.islice(f,0,5):\n            if line.strip(): print(line.strip())\nPY\n"]
