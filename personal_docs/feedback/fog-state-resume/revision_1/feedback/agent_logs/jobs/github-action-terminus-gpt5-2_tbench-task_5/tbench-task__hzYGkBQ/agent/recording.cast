[154.873396, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\nfor name in ['rook','sentinel']:\n    c=[x for x in data['cases'] if x['name']==name][0]\n    print('\\n',name,'moves:',c['moves'])\n    # show records/log first lines\n    import itertools\n    print('records:')\n    with open(c['records']) as f:\n        for line in itertools.islice(f,0,5):\n            if line.strip():\n                print(line.strip())\n    print('log:')\n    with open(c['log']) as f:\n        for line in itertools.islice(f,0,5):\n            if line.strip():\n                print(line.strip())\nPY\n"]
