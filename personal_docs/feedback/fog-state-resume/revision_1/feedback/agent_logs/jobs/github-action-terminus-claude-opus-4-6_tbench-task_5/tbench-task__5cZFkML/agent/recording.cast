[144.019538, "i", "python3 -c \"\nimport re\n\nwith open('/app/internal/f5/run.go', 'r') as f:\n    content = f.read()\n\n# Find and replace the runLoaded function body\nold_body = '''\\tmoves := []MoveRow{}\n\\tfor _, step := range steps {\n\\t\\tif step.Action != \\\"save\\\" {\n\\t\\t\\tcontinue\n\\t\\t}\n\\t\\tw.Turn = step.Turn\n\\t\\te4.ApplyLit(w, radius, blindActive(w))\n\\t\\tmoves = append(moves, advanceAll(w, merged)...)\n\\t}'''\n\nnew_body = '''\\tmoves := []MoveRow{}\n\\tpastSave := false\n\\tfor _, step := range steps {\n\\t\\tif step.Action == \\\"save\\\" {\n\\t\\t\\tpastSave = true\n\\t\\t\\tcontinue\n\\t\\t}\n\\t\\tif !pastSave {\n\\t\\t\\tcontinue\n\\t\\t}\n\\t\\tw.Turn = step.Turn\n\\t\\tif step.Actor == \\\"P\\\" {\n\\t\\t\\tapplyPlayer(w, step.Arg)\n\\t\\t\\te4.ApplyLit(w, radius, blindActive(w))\n\\t\\t}\n\\t\\tif step.Actor == \\\"H\\\" {\n\\t\\t\\tmoves = append(moves, advanceAll(w, merged)...)\n\\t\\t}\n\\t}'''\n\nprint('old_body found:', old_body in content)\n\" 2>&1\n"]
