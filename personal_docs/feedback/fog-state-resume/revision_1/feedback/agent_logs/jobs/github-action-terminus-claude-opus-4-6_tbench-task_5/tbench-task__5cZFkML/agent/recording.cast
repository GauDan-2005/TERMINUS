": \"7d3f56fa\",\r\n        \"illegal\": 0,\r\n        \"steps\": 1\r\n      },\r\n      \"resume\": {\r\n        \"sig\": \"24ebc3c9\",\r\n        \"illegal\": 0,\r\n        \"steps\": 1\r\n      },\r\n      \"moves\": [\r\n        {\r\n          \"turn\": 3,\r\n          \"actor\": \"1\",\r\n          \"from_x\": 3,\r\n          \"from_y\": 3,\r\n          \"to_x\": 3,\r\n          \"to_y\": 2,\r\n          \"kind\": \"step\",\r\n          \"legal\": true\r\n        },\r\n        {\r\n          \"turn\": 2,\r\n          \"actor\": \"1\",\r\n          \"from_x\": 3,\r\n          \"from_y\": 3,\r\n          \"to_x\": 3,\r\n          \"to_y\": 2,\r\n          \"kind\": \"step\",\r\n          \"legal\": true\r\n        }\r\n      ],\r\n      \"visibility\": {\r\n        \"fresh_seen\": 9,\r\n        \"resume_seen\": 8\r\n      },\r\n      \"effects\": [],\r\n      \"records\": \"/app/workspace/rook/records.jsonl\",\r\n      \"log\": \"/app/workspace/rook/trace.tsv\"\r\n    },\r\n    {\r\n      \"name\": \"sentinel\",\r\n      \"ok\": false,\r\n      \"fresh\": {\r\n        \"sig\": \"9a98d68\",\r\n        \"illegal\": 0,\r\n        \"steps\": 1\r\n      },\r\n      \"resume\": {\r\n        \"sig\": \"691e8e87\",\r\n        \"illegal\": 0,\r\n        \"steps\": 1\r\n      },\r\n      \"moves\": [\r\n        {\r\n          \"turn\": 5,\r\n          \"actor\": \"1\",\r\n          \"from_x\": 3,\r\n          \"from_y\": 3,\r\n          \"to_x\": 3,\r\n          \"to_y\": 2,\r\n          \"kind\": \"step\",\r\n          \"legal\": true\r\n        },\r\n        {\r\n          \"turn\": 4,\r\n          \"actor\": \"1\",\r\n          \"from_x\": 3,\r\n          \"from_y\": 3,\r\n          \"to_x\": 3,\r\n          \"to_y\": 2,\r\n          \"kind\": \"step\",\r\n          \"legal\": true\r\n        }\r\n      ],\r\n      \"visibility\": {\r\n        \"fresh_seen\": 9,\r\n        \"resume_seen\": 8\r\n      },\r\n      \"effects\": [\r\n        {\r\n          \"id\": \"ward\",