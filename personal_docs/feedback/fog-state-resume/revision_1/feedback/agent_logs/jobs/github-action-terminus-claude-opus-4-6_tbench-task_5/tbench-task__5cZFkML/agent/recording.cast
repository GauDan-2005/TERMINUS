[244.491958, "o", "\r\n\tLit      []bool\r\n\tSeen     []bool\r\n\tTurn     int\r\n\tObs      map[string]bool\r\n\tEffects  []EffectSnap\r\n\tWidth    int\r\n\tHeight   int\r\n\tPlayerX  int\r\n\tPlayerY  int\r\n\tHostiles []HostileSnap\r\n}\r\n\r\nfunc phase_a(a *stateX, b ItemY) error {\r\n\ta.Lit = append([]bool(nil), b.Lit...)\r\n\ta.Seen = append([]bool(nil), b.Seen...)\r\n\ta.Turn = b.Turn\r\n\treturn nil\r\n}\r\n\r\nfunc PackItem(b ItemY) ItemY {\r\n\tst := &stateX{}\r\n\t_ = phase_a(st, b)\r\n\tout := b\r\n\tout.Seen = append([]bool(nil), b.Seen...)\r\n\treturn out\r\n}\r\n"]
