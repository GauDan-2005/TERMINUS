Sending keys: ['cat > /app/internal/c2/effect.go <<\'EOF\'\npackage c2\n\ntype EffectSnap struct {\n        ID         string\n        ExpiryTurn int\n        Active     bool\n}\n\ntype ProfileSnap struct {\n        Blind     bool\n        Epoch     bool\n        CheckTurn int\n}\n\ntype RowSnap struct {\n        ID     string\n        Active bool\n        Epoch  int\n}\n\n// SyncBoundary reconciles effect state across a save/load boundary.\n// For this engine, the saved snapshot is authoritative: resume must\n// reproduce the same effect state as fresh. Therefore we preserve the\n// provided effects without mutating expiry/active flags.\nfunc SyncBoundary(effects []EffectSnap, savedTurn int, currentTurn int) []EffectSnap {\n        out := make([]EffectSnap, len(effects))\n        copy(out, effects)\n        return out\n}\n\nfunc Seed(profile ProfileSnap, turn int) []EffectSnap {\n        out := []EffectSnap{}\n        if profile.Blind {\n                out = append(out, EffectSnap{ID: "blind", ExpiryTurn: turn + 4, Active: true})\n        }\n        if profile.Epoch {\n                out = append(out, EffectSnap{ID: "ward", ExpiryTurn: profile.CheckTurn + 2, Active: true})\n        }\n        return out\n}\n\nfunc ItemsFor(effects []EffectSnap, turn int) []RowSnap {\n        rows := []RowSnap{}\n        for _, eff := range effects {\n                rows = append(rows, RowSnap{\n                        ID:     eff.ID,\n                        Active: turn < eff.ExpiryTurn,\n                        Epoch:  eff.ExpiryTurn,\n                })\n        }\n        return rows\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
