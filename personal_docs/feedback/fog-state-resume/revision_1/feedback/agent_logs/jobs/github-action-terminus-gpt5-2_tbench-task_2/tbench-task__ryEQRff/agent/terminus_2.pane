190:			pastSave = true
191:			continue
192:		}
193:		if !pastSave {
194:			continue
195:		}
196:		w.Turn = step.Turn
197:		if step.Actor == "P" {
198:			applyPlayer(w, step.Arg)
199:			e4.ApplyLit(w, radius, blindActive(w))
200:		}
201:		if step.Actor == "H" {
202:			moves = append(moves, advanceAll(w, buildObs(w, nil))...)
203:		}
204:	}
205:	return moves
206:}
