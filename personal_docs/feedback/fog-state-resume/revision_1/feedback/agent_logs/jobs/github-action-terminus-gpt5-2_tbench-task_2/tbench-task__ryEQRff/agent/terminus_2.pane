208:func runLoaded(w *World, steps []ScriptStep, blob a0.ItemY, stale map[string]bool, profile Profile, radius int) []MoveRow {
209:	applyWorld(w, blob)
210:	cache := &b1.CacheX{Obs: map[string]bool{}}
