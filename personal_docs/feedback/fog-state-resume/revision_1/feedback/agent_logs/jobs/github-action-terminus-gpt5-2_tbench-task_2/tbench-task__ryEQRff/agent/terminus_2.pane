163:func playUntilSave(w *World, steps []ScriptStep, profile Profile, radius int) (a0.ItemY, map[string]bool) {
164:	visStale := map[string]bool{}
165:	var blob a0.ItemY
166:	for _, step := range steps {
167:		w.Turn = step.Turn
168:		if step.Action == "save" {
169:			vis := buildObs(w, nil)
170:			for k, v := range visStale {
171:				vis[k] = v
172:			}
173:			blob = packWorld(w, vis)
174:			break
175:		}
176:		if step.Actor == "P" {
177:			applyPlayer(w, step.Arg)
178:			e4.ApplyLit(w, radius, blindActive(w))
179:			visStale = buildObs(w, nil)
180:		}
181:	}
182:	return blob, visStale
183:}
184:
185:func runDirect(w *World, steps []ScriptStep, profile Profile, radius int) []MoveRow {
186:	moves := []MoveRow{}
