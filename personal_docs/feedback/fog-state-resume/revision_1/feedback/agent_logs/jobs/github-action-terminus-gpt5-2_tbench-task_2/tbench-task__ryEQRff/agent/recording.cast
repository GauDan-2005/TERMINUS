[246.02327, "i", "python3 - <<'PY'\nimport json, pathlib\np='/app/output/resume-audit.json'\ndata=json.load(open(p))\n\ndef load_jsonl(path):\n    rows=[]\n    for ln in pathlib.Path(path).read_text().splitlines():\n        if ln.strip(): rows.append(json.loads(ln))\n    return rows\n\ndef norm(m):\n    return {k:m.get(k) for k in ['turn','actor','from_x','from_y','to_x','to_y','kind','legal']}\n\nfor c in data['cases']:\n    moves=[norm(m) for m in c['moves']]\n    rec=[norm(m) for m in load_jsonl(c['records'])]\n    ok = moves==rec\n    print(c['name'], 'records_match=', ok, 'moves=', len(moves), 'records=', len(rec))\nPY\n"]
[246.026345, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json, pathlib\r\n\u001b[?2004l\r\u001b[?2004h> p='/app/output/resume-audit.json'\r\n\u001b[?2004l\r\u001b[?2004h> data=json.load(open(p))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def load_jsonl(path):\r\n\u001b[?2004l\r\u001b[?2004h>     rows=[]\r\n\u001b[?2004l\r\u001b[?2004h>     for ln in pathlib.Path(path).read_text().splitlines():\r\n\u001b[?2004l\r\u001b[?2004h>         if ln.strip(): rows.append(json.loads(ln))\r\n\u001b[?2004l\r\u001b[?2004h>     return rows\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def norm(m):\r\n\u001b[?2004l\r\u001b[?2004h>     return {k:m.get(k) for k in ['turn','actor','from_x','from_y','to_x','to_y','kind','legal']}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for c in data['cases']:\r\n\u001b[?2004l\r\u001b[?2004h>     moves=[norm(m) for m in c['moves']]\r\n\u001b[?2004l\r\u001b[?2004h>     rec=[norm(m) for m in load_jsonl(c['records'])]\r\n\u001b[?2004l\r\u001b[?2004h>     ok = moves==rec\r\n\u001b[?2004l\r\u001b[?2004h> "]
