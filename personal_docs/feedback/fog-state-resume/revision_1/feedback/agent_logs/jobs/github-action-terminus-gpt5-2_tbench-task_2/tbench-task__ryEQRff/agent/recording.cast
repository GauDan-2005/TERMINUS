[37.499542, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\nfor want in ['rook','sentinel']:\n    c=next(x for x in data['cases'] if x.get('name')==want)\n    print('===', want, '===')\n    print('ok:', c.get('ok'))\n    print('fresh:', c.get('fresh'))\n    print('resume:', c.get('resume'))\n    print('records:', c.get('records'))\n    print('log:', c.get('log'))\n    print('moves:', len(c.get('moves',[])))\nPY\n"]
