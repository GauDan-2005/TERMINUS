[58.898729, "i", "python3 - <<'PY'\nimport json\n\ndef parse_tsv(path):\n    rows=[]\n    with open(path) as f:\n        for ln in f:\n            ln=ln.strip()\n            if not ln: continue\n            parts=ln.split()  # file is whitespace-delimited despite .tsv\n            rows.append(parts)\n    return rows\n\np='/app/output/resume-audit.json'\ndata=json.load(open(p))\nfor want in ['rook','sentinel']:\n    c=next(x for x in data['cases'] if x.get('name')==want)\n    rows=parse_tsv(c['log'])\n    print('===', want, 'trace rows (split) ===')\n    for r in rows:\n        print(r)\nPY\n"]
