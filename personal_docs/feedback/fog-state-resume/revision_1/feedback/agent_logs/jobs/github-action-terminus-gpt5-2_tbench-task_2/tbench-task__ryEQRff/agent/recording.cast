[20.447161, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\nprint('cases:', len(data.get('cases',[])))\nfor c in data.get('cases',[]):\n    name=c.get('name')\n    ok=c.get('ok')\n    fresh=c.get('fresh',{})\n    resume=c.get('resume',{})\n    fi=fresh.get('illegal')\n    ri=resume.get('illegal')\n    fs=fresh.get('sig')\n    rs=resume.get('sig')\n    print(f\"{name:9} ok={ok} fresh.illegal={fi} resume.illegal={ri} sigs_match={fs==rs} fresh.sig={fs} resume.sig={rs}\")\nPY\n"]
