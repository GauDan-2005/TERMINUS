[214.115533, "o", "150:\tw.Turn = item.Turn\r\n151:\tw.Lit = append([]bool(nil), item.Lit...)\r\n152:\tw.Seen = append([]bool(nil), item.Seen...)\r\n153:\tw.Hostile = make([]Hostile, len(item.Hostiles))\r\n154:\tfor i, h := range item.Hostiles {\r\n155:\t\tw.Hostile[i] = Hostile{ID: h.ID, X: h.X, Y: h.Y}\r\n156:\t}\r\n157:\tw.Effects = make([]EffectState, len(item.Effects))\r\n158:\tfor i, e := range item.Effects {\r\n159:\t\tw.Effects[i] = EffectState{ID: e.ID, ExpiryTurn: e.ExpiryTurn, Active: e.Active}\r\n160:\t}\r\n161:}\r\n162:\r\n163:func playUntilSave(w *World, steps []ScriptStep, profile Profile, radius int) (a0.ItemY, map[string]bool) {\r\n164:\tvisStale := map[string]bool{}\r\n165:\tvar blob a0.ItemY\r\n166:\tfor _, step := range steps {\r\n167:\t\tw.Turn = step.Turn\r\n168:\t\tif step.Action == \"save\" {\r\n169:\t\t\tvis := buildObs(w, nil)\r\n170:\t\t\tfor k, v := range visStale {\r\n171:\t\t\t\tvis[k] = v\r\n172:\t\t\t}\r\n173:\t\t\tblob = packWorld(w, vis)\r\n174:\t\t\tbreak\r\n175:\t\t}\r\n176:\t\tif step.Actor == \"P\" {\r\n177:\t\t\tapplyPlayer(w, step.Arg)\r\n178:\t\t\te4.ApplyLit(w, radius, blindActive(w))\r\n179:\t\t\tvisStale = buildObs(w, nil)\r\n180:\t\t}\r\n181:\t}\r\n182:\treturn blob, visStale\r\n183:}\r\n184:\r\n185:func runDirect(w *World, steps []ScriptStep, profile Profile, radius int) []MoveRow {\r\n186:\tmoves := []MoveRow{}\r\n187:\tpastSave := false\r\n188:\tfor _, step := range steps {\r\n189:\t\tif step.Action == \"save\" {\r\n190:\t\t\tpastSave = true\r\n191:\t\t\tcontinue\r\n192:\t\t}\r\n193:\t\tif !pastSave {\r\n194:\t\t\tcontinue\r\n195:\t\t}\r\n196:\t\tw.Turn = step.Turn\r\n197:\t\tif step.Actor == \"P\" {\r\n198:\t\t\tapplyPlayer(w, step.Arg)\r\n199:\t\t\te4.ApplyLit(w, radius, blindActive(w))\r\n200:\t\t}\r\n201:\t\tif step.Actor == \"H\" {\r\n202:\t\t\tmoves = append(moves, advanceAll(w, buildObs(w, nil))...)\r\n203:\t\t}\r\n204:\t}\r\n205:\treturn moves\r\n206:}\r\n207:\r\n208:func runLoaded(w *World, steps []ScriptStep, blob a0.ItemY, stale map[string]bool, profile Profile, radius int) []MoveRow {\r\n209:\tapplyWorld(w, blob)\r\n210:\tcache := &b1.CacheX{Obs: map[string]bool{}}\r\n211:\tb1.Merge(cache, blob)\r\n212:\tmerged := b1.Snapshot(cache)\r\n213:\tfor k, v := range stale {\r\n214:\t\tmerged[k] = v\r\n215:\t}\r\n216:\tw.Effects = snapFromC2(c2.SyncBoundary(snapToC2(w.Effects), blob.Turn, w.Turn))\r\n217:\tmoves := []MoveRow{}\r\n218:\tfor _, step := range steps {\r\n219:\t\tif step.Action != \"save\" {\r\n220:\t\t\tcontinue\r\n221:\t\t}\r\n222:\t\tw.Turn = step.Turn\r\n223:\t\te4.ApplyLit(w, radius, blindActive(w))\r\n224:\t\tmoves = append(moves, advanceAll(w, merged)...)\r\n225:\t}\r\n226:\treturn moves\r\n227:}\r\n228:\r\n229:func RunRow(root, name string) (CaseResult, error) {\r\n230:\tprofile := ProfileFor(name)\r\n231:\tradius, _ := LoadRadius(root, name)\r\n232:\tif radius == 0 {\r\n233:\t\tradius = profile.Radius\r\n234:\t}\r\n235:\tbase, err := LoadLayout(root, name)\r\n236:\tif err != nil {\r\n237:\t\treturn CaseResult{}, err\r\n238:\t}\r\n239:\tsteps, err := LoadScript(root, name)\r\n240:\tif err != nil {\r\n241:\t\treturn CaseResult{}, err\r\n242:\t}\r\n243:\r\n244:\twFresh := cloneWorld(base)\r\n245:\twFresh.Effects = snapFromC2(c2.Seed(profileToC2(profile), wFresh.Turn))\r\n246:\tblob, stale := playUntilSave(wFresh, steps, profile, radius)\r\n247:\tfreshMoves := runDirect(wFresh, steps, profile, radius)\r\n248:\r\n249:\twResume := cloneWorld(base)\r\n250:\twResume.Effects = snapFromC2(c2.Seed(profileToC2(profile), wResume.Turn))\r\n251:\tplayUntilSave(wResume, steps, profile, radius)\r\n252:\tresumeMoves := runLoaded(wResume, steps, blob, stale, profile, radius)\r\n253:\r\n254:\tfreshIllegal, resumeIllegal := 0, 0\r\n255:\tfor _, m := range freshMoves {\r\n256:\t\tif !m.Legal {\r\n257:\t\t\tfreshIllegal++\r\n258:\t\t}\r\n259:\t}\r\n260:\tfor _, m := range resumeMoves {\r\n\u001b[?2004hroot@85b121dde67e:/app# "]
