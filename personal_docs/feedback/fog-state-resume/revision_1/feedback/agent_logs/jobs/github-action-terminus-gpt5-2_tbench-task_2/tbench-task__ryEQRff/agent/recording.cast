[135.541355, "o", "package a0\r\n\r\ntype stateX struct {\r\n\tLit  []bool\r\n\tSeen []bool\r\n\tTurn int\r\n}\r\n\r\ntype EffectSnap struct {\r\n\tID         string\r\n"]
[135.54139, "o", "\tExpiryTurn int\r\n\tActive     bool\r\n}\r\n\r\ntype HostileSnap struct {\r\n\tID string\r\n\tX  int\r\n\tY  int\r\n}\r\n\r\ntype ItemY struct {\r\n\tLit      []bool\r\n\tSeen     []bool\r\n\tTurn     int\r\n\tObs      map[string]bool\r\n\tEffects  []EffectSnap\r\n\tWidth    int\r\n"]
[135.541412, "o", "\tHeight   int\r\n\tPlayerX  int\r\n\tPlayerY  int\r\n\tHostiles []HostileSnap\r\n}\r\n\r\n"]
[135.541434, "o", "func phase_a(a *stateX, b ItemY) error {\r\n\ta.Lit = append([]bool(nil), b.Lit...)\r\n\ta.Seen = append([]bool(nil), b.Seen...)\r\n\ta.Turn = b.Turn\r\n\treturn nil\r\n}\r\n"]
[135.541452, "o", "\r\nfunc PackItem(b ItemY) ItemY {\r\n\tst := &stateX{}\r\n\t_ = phase_a(st, b)\r\n\tout := b\r\n"]
[135.541473, "o", "\tout.Seen = make([]bool, len(b.Seen))\r\n\treturn out\r\n}\r\n"]
[135.541735, "o", "\u001b[?2004hroot@85b121dde67e:/app# "]
[135.659883, "i", "cat > /app/internal/a0/pack.go <<'EOF'\npackage a0\n\ntype stateX struct {\n        Lit  []bool\n        Seen []bool\n        Turn int\n}\n\ntype EffectSnap struct {\n        ID         string\n        ExpiryTurn int\n        Active     bool\n}\n\ntype HostileSnap struct {\n        ID string\n        X  int\n        Y  int\n}\n\ntype ItemY struct {\n        Lit      []bool\n        Seen     []bool\n        Turn     int\n        Obs      map[string]bool\n        Effects  []EffectSnap\n        Width    int\n        Height   int\n        PlayerX  int\n        PlayerY  int\n        Hostiles []HostileSnap\n}\n\nfunc phase_a(a *stateX, b ItemY) error {\n        a.Lit = append([]bool(nil), b.Lit...)\n        a.Seen = append([]bool(nil), b.Seen...)\n        a.Turn = b.Turn\n        return nil\n}\n\nfunc PackItem(b ItemY) ItemY {\n        st := &stateX{}\n        _ = phase_a(st, b)\n\n        // Return a packed snapshot that is safe to persist/resume from.\n        // The resume path expects Seen/Lit contents to be preserved.\n        out := b\n        out.Lit = append([]bool(nil), b.Lit...)\n        out.Seen = append([]bool(nil), b.Seen...)\n        return out\n}\nEOF\n"]
