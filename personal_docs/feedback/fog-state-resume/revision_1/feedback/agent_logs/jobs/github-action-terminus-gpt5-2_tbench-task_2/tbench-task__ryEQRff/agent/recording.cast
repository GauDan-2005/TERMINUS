[78.765044, "o", "package sim\r\n\r\ntype Profile struct {\r\n\tName      string\r\n\tRadius    int\r\n\tBlind     bool\r\n\tDense     bool\r\n\tEpoch     bool\r\n\tMixed     bool\r\n\tCheckTurn int\r\n}\r\n\r\ntype MoveRow struct {\r\n\tTurn  int    `json:\"turn\"`\r\n\tActor string `json:\"actor\"`\r\n\tFromX int    `json:\"from_x\"`\r\n\tFromY int    `json:\"from_y\"`\r\n\tToX   int    `json:\"to_x\"`\r\n\tToY   int    `json:\"to_y\"`\r\n\tKind  string `json:\"kind\"`\r\n\tLegal bool   `json:\"legal\"`\r\n"]
