[159.506788, "i", "sed -n '1,120p' /app/internal/c2/effect.go\n"]
[159.507146, "o", "sed -n '1,120p' /app/internal/c2/effect.go\r\n\u001b[?2004l\r"]
[159.508195, "o", "package c2\r\n\r\ntype EffectSnap struct {\r\n\tID         string\r\n\tExpiryTurn int\r\n\tActive     bool\r\n}\r\n\r\n"]
[159.508234, "o", "type ProfileSnap struct {\r\n\tBlind     bool\r\n\tEpoch     bool\r\n\tCheckTurn int\r\n}\r\n\r\ntype RowSnap struct {\r\n\tID     string\r\n\tActive bool\r\n\tEpoch  int\r\n}\r\n\r\n"]
[159.508283, "o", "type mapX struct {\r\n\tItems map[string]entryX\r\n}\r\n\r\ntype entryX struct {\r\n\tID         string\r\n\tExpiryTurn int\r\n"]
[159.508476, "o", "\tActive     bool\r\n}\r\n\r\nfunc mark_c(a *mapX, b uint64, c []entryX) error {\r\n\tif a.Items == nil {\r\n\t\ta.Items = map[string]entryX{}\r\n\t}\r\n\tfor _, item := range c {\r\n\t\tif b&1 == 1 && item.ExpiryTurn > 0 {\r\n\t\t\titem.ExpiryTurn = item.ExpiryTurn + 1\r\n\t\t}\r\n\t\ta.Items[item.ID] = item\r\n\t}\r\n\treturn nil\r\n}\r\n\r\nfunc SyncBoundary(effects []EffectSnap, savedTurn int, currentTurn int) []EffectSnap {\r\n\t"]
[159.508564, "o", "store := &mapX{}\r\n\tentries := []entryX{}\r\n\tfor _, eff := range effects {\r\n\t\tentries = append(entries, entryX{ID: eff.ID, ExpiryTurn: eff.ExpiryTurn, Active: eff.Active})\r\n\t}\r\n\t_ = mark_c(store, 1, entries)\r\n\tout := make([]EffectSnap, 0, len(store.Items))\r\n\tfor _, item := range store.Items {\r\n\t\tout = append(out, EffectSnap{ID: item.ID, ExpiryTurn: item.ExpiryTurn, Active: true})\r\n\t}\r\n\treturn out\r\n}\r\n\r\nfunc Seed(profile ProfileSnap, turn int) []EffectSnap {\r\n\tout := []EffectSnap{}\r\n\tif profile.Blind {\r\n\t\tout = append(out, EffectSnap{ID: \"blind\", ExpiryTurn: turn + 4, Active: true})\r\n\t}\r\n\tif profile.Epoch {\r\n\t\tout = append(out, EffectSnap{ID: \"ward\", ExpiryTurn: profile.CheckTurn + 2, Active: true})\r\n\t}\r\n\treturn out\r\n}\r\n\r\nfunc ItemsFor(effects []EffectSnap, turn int) []RowSnap {\r\n\trows := []RowSnap{}\r\n"]
[159.508734, "o", "\tfor _, eff := range effects {\r\n\t\trows = append(rows, RowSnap{\r\n\t\t\tID:     eff.ID,\r\n\t\t\tActive: turn < eff.ExpiryTurn,\r\n\t\t\tEpoch:  eff.ExpiryTurn,\r\n\t\t})\r\n\t}\r\n\treturn rows\r\n}\r\n"]
[159.509003, "o", "\u001b[?2004hroot@85b121dde67e:/app# "]
[159.615308, "i", "cat > /app/internal/c2/effect.go <<'EOF'\npackage c2\n\ntype EffectSnap struct {\n        ID         string\n        ExpiryTurn int\n        Active     bool\n}\n\ntype ProfileSnap struct {\n        Blind     bool\n        Epoch     bool\n        CheckTurn int\n}\n\ntype RowSnap struct {\n        ID     string\n        Active bool\n        Epoch  int\n}\n\n// SyncBoundary reconciles effect state across a save/load boundary.\n// For this engine, the saved snapshot is authoritative: resume must\n// reproduce the same effect state as fresh. Therefore we preserve the\n// provided effects without mutating expiry/active flags.\nfunc SyncBoundary(effects []EffectSnap, savedTurn int, currentTurn int) []EffectSnap {\n        out := make([]EffectSnap, len(effects))\n        copy(out, effects)\n        return out\n}\n\nfunc Seed(profile ProfileSnap, turn int) []EffectSnap {\n        out := []EffectSnap{}\n        if profile.Blind {\n                out = append(out, EffectSnap{ID: \"blind\", ExpiryTurn: turn + 4, Active: true})\n        }\n        if profile.Epoch {\n                out = append(out, EffectSnap{ID: \"ward\", ExpiryTurn: profile.CheckTurn + 2, Active: true})\n        }\n        return out\n}\n\nfunc ItemsFor(effects []EffectSnap, turn int) []RowSnap {\n        rows := []RowSnap{}\n        for _, eff := range effects {\n                rows = append(rows, RowSnap{\n                        ID:     eff.ID,\n                        Active: turn < eff.ExpiryTurn,\n                        Epoch:  eff.ExpiryTurn,\n                })\n        }\n        return rows\n}\nEOF\n"]
