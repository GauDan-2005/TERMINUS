[40.507588, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\nfor want in ['rook','sentinel']:\n    c=next(x for x in data['cases'] if x.get('name')==want)\n    print('===', want, 'log head ===')\n    lp=c.get('log')\n    with open(lp) as f:\n        lines=[ln for ln in (x.strip() for x in f) if ln]\n    print('log_rows:', len(lines))\n    for ln in lines[:5]:\n        print(ln)\nPY\n"]
