[39.511065, "i", "python3 - <<'PY'\nimport json, pathlib\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\n\ndef load_jsonl(path):\n    rows=[]\n    for line in pathlib.Path(path).read_text().splitlines():\n        if not line.strip():\n            continue\n        rows.append(json.loads(line))\n    return rows\n\ndef norm_move(m):\n    return {\n        'turn': m.get('turn'),\n        'side': m.get('side'),\n        'from': m.get('from'),\n        'to': m.get('to'),\n        'kind': m.get('kind'),\n        'legal': m.get('legal'),\n    }\n\nfor want in ['rook','sentinel']:\n    c=next(x for x in data['cases'] if x.get('name')==want)\n    moves=[norm_move(m) for m in c.get('moves',[])]\n    rec_path=c.get('records')\n    rec=load_jsonl(rec_path)\n    rec=[norm_move(m) for m in rec]\n    print('===', want, 'records check ===')\n    print('moves:', len(moves), 'records:', len(rec), 'equal:', moves==rec)\n    if moves!=rec:\n        for i,(a,b) in enumerate(zip(moves,rec)):\n            if a!=b:\n                print('first_diff_index', i)\n                print('json :', a)\n                print('jsonl:', b)\n                break\nPY\n"]
