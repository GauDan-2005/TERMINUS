[245.023134, "i", "python3 - <<'PY'\nimport json, pathlib\np='/app/output/resume-audit.json'\ndata=json.load(open(p))\nassert len(data['cases'])==6\nbad=[]\nfor c in data['cases']:\n    if not c['ok'] or c['fresh']['illegal']!=0 or c['resume']['illegal']!=0:\n        bad.append((c['name'],'ok/illegal'))\n    if c['fresh']['sig']!=c['resume']['sig']:\n        bad.append((c['name'],'sig'))\nprint('bad:', bad)\nPY\n"]
