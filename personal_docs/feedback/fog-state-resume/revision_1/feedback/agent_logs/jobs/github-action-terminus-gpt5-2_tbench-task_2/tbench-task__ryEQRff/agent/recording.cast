[56.919795, "o", "{\r\n  \"effects\": [],\r\n  \"fresh\": {\r\n    \"illegal\": 0,\r\n    \"sig\": \"7d3f56fa\",\r\n    \"steps\": 1\r\n  },\r\n  \"log\": \"/app/workspace/rook/trace.tsv\",\r\n  \"moves\": [\r\n    {\r\n      \"actor\": \"1\",\r\n      \"from_x\": 3,\r\n      \"from_y\": 3,\r\n      \"kind\": \"step\",\r\n      \"legal\": true,\r\n      \"to_x\": 3,\r\n      \"to_y\": 2,\r\n      \"turn\": 3\r\n    },\r\n    {\r\n      \"actor\": \"1\",\r\n      \"from_x\": 3,\r\n      \"from_y\": 3,\r\n      \"kind\": \"step\",\r\n      \"legal\": true,\r\n      \"to_x\": 3,\r\n      \"to_y\": 2,\r\n      \"turn\": 2\r\n    }\r\n  ],\r\n  \"name\": \"rook\",\r\n  \"ok\": false,\r\n  \"records\": \"/app/workspace/rook/records.jsonl\",\r\n  \"resume\": {\r\n    \"illegal\": 0,\r\n    \"sig\": \"24ebc3c9\",\r\n    \"steps\": 1\r\n  },\r\n  \"visibility\": {\r\n    \"fresh_seen\": 9,\r\n    \"resume_seen\": 8\r\n  }\r\n}\r\n=== sentinel FULL CASE ===\r\n{\r\n  \"effects\": [\r\n    {\r\n      \"active\": true,\r\n      \"epoch\": 7,\r\n      \"id\": \"ward\"\r\n    }\r\n  ],\r\n  \"fresh\": {\r\n"]
