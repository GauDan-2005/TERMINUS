[46.518913, "i", "python3 - <<'PY'\nimport json\n\ndef load_case(path):\n    with open(path) as f: d=json.load(f)\n    return d['cases'][0]\n\nmatrix=json.load(open('/app/output/resume-audit.json'))\nfor want in ['rook','sentinel']:\n    m=next(x for x in matrix['cases'] if x.get('name')==want)\n    s=load_case(f'/app/output/single-{want}.json')\n    # Compare a focused subset\n    def pick(c):\n        return {\n            'name': c.get('name'),\n            'ok': c.get('ok'),\n            'fresh': c.get('fresh'),\n            'resume': c.get('resume'),\n            'moves': c.get('moves'),\n            'visibility': c.get('visibility'),\n            'effects': c.get('effects'),\n        }\n    same = pick(m)==pick(s)\n    print(want, 'single_matches_matrix:', same)\n    if not same:\n        # find first move diff\n        mm=m.get('moves',[]); ss=s.get('moves',[])\n        if mm!=ss:\n            for i,(a,b) in enumerate(zip(mm,ss)):\n                if a!=b:\n                    print(' first_move_diff', i)\n                    print(' matrix:', a)\n                    print(' single:', b)\n                    break\n        else:\n            print(' moves identical; difference in metadata')\nPY\n"]
