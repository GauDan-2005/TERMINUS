[87.636519, "o", "package a0\r\n\r\ntype stateX struct {\r\n\tLit  []bool\r\n\tSeen []bool\r\n\tTurn int\r\n}\r\n\r\ntype EffectSnap struct {\r\n\tID         string\r\n"]
[87.636556, "o", "\tExpiryTurn int\r\n\tActive     bool\r\n}\r\n\r\ntype HostileSnap struct {\r\n\tID string\r\n\tX  int\r\n\tY  int\r\n}\r\n\r\ntype ItemY struct {\r\n\tLit      []bool\r\n\tSeen     []bool\r\n\tTurn     int\r\n"]
[87.63658, "o", "\tObs      map[string]bool\r\n\tEffects  []EffectSnap\r\n\tWidth    int\r\n\tHeight   int\r\n"]
[87.636603, "o", "\tPlayerX  int\r\n\tPlayerY  int\r\n\tHostiles []HostileSnap\r\n}\r\n\r\nfunc phase_a(a *stateX, b ItemY) error {\r\n"]
[87.63665, "o", "\ta.Lit = append([]bool(nil), b.Lit...)\r\n\ta.Seen = append([]bool(nil), b.Seen...)\r\n\ta.Turn = b.Turn\r\n\treturn nil\r\n}\r\n\r\n"]
[87.636691, "o", "func PackItem(b ItemY) ItemY {\r\n\tst := &stateX{}\r\n\t_ = phase_a(st, b)\r\n\tout := b\r\n\tout.Seen = make([]bool, len(b.Seen))\r\n\treturn out\r\n}\r\n"]
