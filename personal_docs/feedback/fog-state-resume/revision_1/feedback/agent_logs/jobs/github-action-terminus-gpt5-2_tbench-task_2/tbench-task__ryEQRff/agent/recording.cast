[21.451261, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\nbad=[]\nfor c in data.get('cases',[]):\n    name=c.get('name')\n    ok=c.get('ok')\n    fresh=c.get('fresh',{})\n    resume=c.get('resume',{})\n    if not ok or fresh.get('illegal') or resume.get('illegal') or (fresh.get('sig')!=resume.get('sig')):\n        bad.append(name)\nprint('bad_cases:', bad)\nPY\n"]
