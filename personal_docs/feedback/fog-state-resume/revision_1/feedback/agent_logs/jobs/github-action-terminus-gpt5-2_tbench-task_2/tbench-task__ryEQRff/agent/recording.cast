[38.507536, "i", "python3 - <<'PY'\nimport json\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\n\ndef key(m):\n    return (m.get('turn'), m.get('side'), tuple(m.get('from',[])), tuple(m.get('to',[])), m.get('kind'), m.get('legal'))\n\nfor want in ['rook','sentinel']:\n    c=next(x for x in data['cases'] if x.get('name')==want)\n    fresh=c.get('fresh',{}).get('steps',[]) or c.get('fresh',{}).get('moves',[])  # defensive\n    resume=c.get('resume',{}).get('steps',[]) or c.get('resume',{}).get('moves',[])\n    # In this audit format, resolved list is in top-level moves; fresh/resume are summaries only.\n    # So instead compare sig inputs by comparing top-level moves against records/log.\n    print('===', want, '===')\n    print('top-level moves len:', len(c.get('moves',[])))\n    print('fresh.sig:', c['fresh'].get('sig'), 'resume.sig:', c['resume'].get('sig'))\n    # If engine provides separate resolved lists, they might be embedded in effects/records; print hint.\n    if 'fresh_moves' in c or 'resume_moves' in c:\n        print('has embedded fresh/resume moves')\nPY\n"]
[38.508001, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
