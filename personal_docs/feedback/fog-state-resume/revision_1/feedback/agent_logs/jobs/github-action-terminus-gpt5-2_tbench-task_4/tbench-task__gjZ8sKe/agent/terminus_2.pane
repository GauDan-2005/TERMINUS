    27			acc ^= int64(m.FromX*7 + m.FromY*11 + m.ToX*13 + m.ToY*17)
    28			for _, ch := range m.Actor + m.Kind {
    29				acc ^= int64(ch)
    30				acc = (acc * 16777619) & 0x7fffffff
    31			}
    32		}
    33		return fmt.Sprintf("%x", acc)
    34	}
