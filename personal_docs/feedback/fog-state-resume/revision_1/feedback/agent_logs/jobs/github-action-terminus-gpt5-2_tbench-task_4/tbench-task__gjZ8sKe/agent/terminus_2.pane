    20	func sigFor(moves []MoveRow) string {
    21		acc := int64(2166136261)
    22		// Signature is meant to be stable across equivalent fresh vs resume
    23		// execution paths. The internal Turn counter can legitimately differ
    24		// across those paths due to save/load boundaries, so we do not include
    25		// MoveRow.Turn in the signature material.
