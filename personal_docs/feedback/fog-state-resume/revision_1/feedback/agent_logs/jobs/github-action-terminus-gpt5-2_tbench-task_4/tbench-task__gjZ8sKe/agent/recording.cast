[211.353751, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\n\ndef get_case(path,name=None):\n    d=json.loads(Path(path).read_text())\n    if name is None:\n        return d['cases'][0]\n    return next(c for c in d['cases'] if c['name']==name)\n\nmc=get_case('/app/output/resume-audit.json','warden')\nsc=get_case('/app/output/single-warden.json')\nprint('matrix effects:',mc.get('effects'))\nprint('single effects:',sc.get('effects'))\nprint('matrix resume turn:',mc.get('moves')[-1]['turn'] if mc.get('moves') else None)\nprint('single resume turn:',sc.get('moves')[-1]['turn'] if sc.get('moves') else None)\nPY\n"]
