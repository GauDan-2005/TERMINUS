[35.837376, "i", "python3 - <<'PY'\nimport json\n\ndef load_case(path):\n    with open(path) as f: d=json.load(f)\n    return d['cases'][0]\n\nm='/app/output/resume-audit.json'\nwith open(m) as f: md=json.load(f)\nfor name in ['rook','sentinel']:\n    mc=next(x for x in md['cases'] if x['name']==name)\n    sc=load_case(f'/app/output/single-{name}.json')\n    print('\\n== compare',name,'matrix vs single ==')\n    for k in ['ok','fresh','resume','moves','visibility','effects']:\n        same = (mc.get(k)==sc.get(k))\n        print(k,'same' if same else 'DIFF')\nPY\n"]
