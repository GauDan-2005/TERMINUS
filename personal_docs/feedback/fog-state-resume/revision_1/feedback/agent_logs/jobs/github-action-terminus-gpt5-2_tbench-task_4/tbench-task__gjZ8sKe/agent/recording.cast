[283.246452, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\n\ndef load_case(path,name=None):\n    d=json.loads(Path(path).read_text())\n    if name is None:\n        return d['cases'][0]\n    return next(c for c in d['cases'] if c['name']==name)\n\nmc=load_case('/app/output/resume-audit.json','warden')\nsc=load_case('/app/output/single-warden.json')\nprint('matrix effects',mc['effects'])\nprint('single effects',sc['effects'])\nprint('same', mc['effects']==sc['effects'])\nPY\n"]
