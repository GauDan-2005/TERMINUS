[175.008778, "o", "for c in data['cases']:\r\n\u001b[?2004l\r"]
[175.008805, "o", "\u001b[?2004h> "]
[175.008899, "o", "    moves=c['moves']\r\n\u001b[?2004l\r\u001b[?2004h"]
