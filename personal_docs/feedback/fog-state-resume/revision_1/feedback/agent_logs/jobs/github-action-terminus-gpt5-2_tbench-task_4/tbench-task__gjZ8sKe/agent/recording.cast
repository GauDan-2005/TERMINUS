[213.46657, "i", "python3 - <<'PY'\nfrom pathlib import Path\np=Path('/app/internal/f5/run.go')\ns=p.read_text().splitlines(True)\nout=[]\nfor line in s:\n    out.append(line)\n# ensure sort import exists\ntext=''.join(out)\nif '\"sort\"' not in text:\n    text=text.replace('\"strings\"\\n', '\"strings\"\\n\\n\\t\"sort\"\\n')\n# inject sorting before return CaseResult\nmarker='\\treturn CaseResult{\\n'\nidx=text.find(marker)\nif idx==-1:\n    raise SystemExit('return CaseResult marker not found')\n# add code just before return CaseResult{ within RunRow\ninject='\\teffects := rowsFromC2(c2.ItemsFor(snapToC2(wResume.Effects), wResume.Turn))\\n\\tsort.Slice(effects, func(i, j int) bool {\\n\\t\\tif effects[i].ID != effects[j].ID {\\n\\t\\t\\treturn effects[i].ID < effects[j].ID\\n\\t\\t}\\n\\t\\tif effects[i].Epoch != effects[j].Epoch {\\n\\t\\t\\treturn effects[i].Epoch < effects[j].Epoch\\n\\t\\t}\\n\\t\\tif effects[i].Active != effects[j].Active {\\n\\t\\t\\treturn !effects[i].Active && effects[j].Active\\n\\t\\t}\\n\\t\\treturn false\\n\\t})\\n\\n'\n# Only inject if not already present\nif 'effects :=' not in text:\n    text=text[:idx]+inject+text[idx:]\n# replace Effects field to use effects var\ntext=text.replace('\\t\\tEffects:    rowsFromC2(c2.ItemsFor(snapToC2(wResume.Effects), wResume.Turn)),\\n', '\\t\\tEffects:    effects,\\n')\nPath('/app/internal/f5/run.go').write_text(text)\nprint('patched effects ordering')\nPY\n"]
