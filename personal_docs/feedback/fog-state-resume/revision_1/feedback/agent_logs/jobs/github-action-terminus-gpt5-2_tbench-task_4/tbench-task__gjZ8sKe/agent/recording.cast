[175.011221, "o", "\u001b[?2004h"]
[175.011278, "o", "> "]
[175.011414, "o", "            print(' subset',subset)\r\n\u001b[?2004l\r\u001b[?2004h"]
[175.011488, "o", "> "]
[175.011572, "o", "            print(' log   ',log)\r\n\u001b[?2004l\r"]
