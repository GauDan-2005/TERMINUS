[260.225229, "i", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\np=Path('/app/internal/f5/run.go')\nlines=p.read_text().splitlines()\n# Remove any previously injected block starting with a tab then 'effects :=' (note space) if present\nout=[]\nskip=False\nfor ln in lines:\n    if re.match(r'^\\teffects\\s*:=\\s*rowsFromC2\\(', ln):\n        skip=True\n        continue\n    if skip:\n        # stop skipping at blank line after sort.Slice block\n        if ln.strip()=='' :\n            skip=False\n        continue\n    out.append(ln)\ntext='\\n'.join(out)+\"\\n\"\n# Ensure import sort exists\nif '\"sort\"' not in text:\n    text=text.replace('\"strings\"\\n', '\"strings\"\\n\\n\\t\"sort\"\\n')\n\n# Fix RunRow: create effects variable and use it in return\n# Replace the Effects field line to a placeholder if present\ntext=re.sub(r'\\t\\tEffects:\\s*rowsFromC2\\(c2\\.ItemsFor\\(snapToC2\\(wResume\\.Effects\\), wResume\\.Turn\\)\\),\\n', '\\t\\tEffects:    effects,\\n', text)\n\n# Inject effects computation just before 'return CaseResult{' inside RunRow\nneedle='\\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig\\n\\n'\nif needle not in text:\n    raise SystemExit('could not find injection point near ok :=')\nif '\\teffects := rowsFromC2' not in text:\n    inject='\\teffects := rowsFromC2(c2.ItemsFor(snapToC2(wResume.Effects), wResume.Turn))\\n\\tsort.Slice(effects, func(i, j int) bool {\\n\\t\\tif effects[i].ID != effects[j].ID {\\n\\t\\t\\treturn effects[i].ID < effects[j].ID\\n\\t\\t}\\n\\t\\tif effects[i].Epoch != effects[j].Epoch {\\n\\t\\t\\treturn effects[i].Epoch < effects[j].Epoch\\n\\t\\t}\\n\\t\\tif effects[i].Active != effects[j].Active {\\n\\t\\t\\treturn !effects[i].Active && effects[j].Active\\n\\t\\t}\\n\\t\\treturn false\\n\\t})\\n\\n'\n    text=text.replace(needle, needle+inject)\n\np.write_text(text)\nprint('repaired run.go')\nPY\n"]
[260.225949, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> from pathlib import Path\r\n\u001b[?2004l\r\u001b[?2004h> import re\r\n\u001b[?2004l\r\u001b[?2004h> p=Path('/app/internal/f5/run.go')"]
