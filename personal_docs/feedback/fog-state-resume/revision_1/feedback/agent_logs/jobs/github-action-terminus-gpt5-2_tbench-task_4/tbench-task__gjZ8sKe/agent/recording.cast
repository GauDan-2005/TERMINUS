[196.034572, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\n\ndef load(path):\n    return json.loads(Path(path).read_text())['cases'][0]\n\nmatrix=json.loads(Path('/app/output/resume-audit.json').read_text())['cases']\nby={c['name']:c for c in matrix}\nfor name in ['rook','bishop','knight','lancer','sentinel','warden']:\n    sc=load(f'/app/output/single-{name}.json')\n    mc=by[name]\n    # compare all fields except records/log paths which differ\n    for k in ['ok','fresh','resume','moves','visibility','effects']:\n        if mc.get(k)!=sc.get(k):\n            raise SystemExit(f'DIFF {name} field {k}')\nprint('single-case outputs match matrix rows')\nPY\n"]
[196.037173, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> from pathlib import Path\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def load(path):\r\n\u001b[?2004l\r\u001b[?2004h>     return json.loads(Path(path).read_text())['cases'][0]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> matrix=json.loads(Path('/app/output/resume-audit.json').read_text())['cases']\r\n\u001b[?2004l\r\u001b[?2004h> by={c['name']:c for c in matrix}\r\n\u001b[?2004l\r\u001b[?2004h> for name in ['rook','bishop','knight','lancer','sentinel','warden']:\r\n\u001b[?2004l\r\u001b[?2004h>     sc=load(f'/app/output/single-{name}.json')\r\n\u001b[?2004l\r\u001b[?2004h>     mc=by[name]\r\n\u001b[?2004l\r\u001b[?2004h>     # compare all fields except records/log paths which differ\r\n\u001b[?2004l\r\u001b[?2004h>     for k in ['ok','fresh','resume','moves','visibility','effects']:\r\n\u001b[?2004l\r\u001b[?2004h>         if mc.get(k)!=sc.get(k):\r\n\u001b[?2004l\r\u001b[?2004h>             raise SystemExit(f'DIFF {name} field {k}')\r\n\u001b[?2004l\r\u001b[?2004h> "]
