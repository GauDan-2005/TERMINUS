[28.817319, "i", "python3 - <<'PY'\nimport json, pprint\np='/app/output/resume-audit.json'\nwith open(p) as f: data=json.load(f)\nfor name in ['rook','sentinel']:\n    c=next(x for x in data['cases'] if x['name']==name)\n    print('\\n===',name,'===')\n    for k in ['ok','fresh','resume','records','log']:\n        print(k, c.get(k))\n    print('moves:')\n    pprint.pp(c.get('moves'))\n    print('visibility:')\n    pprint.pp(c.get('visibility'))\n    print('effects:')\n    pprint.pp(c.get('effects'))\n    print('records_meta:')\n    pprint.pp(c.get('records_meta'))\n    print('log_meta:')\n    pprint.pp(c.get('log_meta'))\nPY\n"]
