[175.001382, "i", "python3 - <<'PY'\nimport json\nfrom pathlib import Path\n\naudit=Path('/app/output/resume-audit.json')\ndata=json.loads(audit.read_text())\n\ndef parse_jsonl(p):\n    rows=[]\n    for ln in Path(p).read_text().splitlines():\n        if not ln.strip():\n            continue\n        rows.append(json.loads(ln))\n    return rows\n\ndef parse_tsv(p):\n    rows=[]\n    for ln in Path(p).read_text().splitlines():\n        if not ln.strip():\n            continue\n        parts=ln.split('\\t')\n        # name, turn, actor, from_x, from_y, to_x, to_y, legal\n        rows.append({\n            'turn': int(parts[1]),\n            'actor': parts[2],\n            'from_x': int(parts[3]),\n            'from_y': int(parts[4]),\n            'to_x': int(parts[5]),\n            'to_y': int(parts[6]),\n            'legal': parts[7].strip().lower()=='true'\n        })\n    return rows\n\nfor c in data['cases']:\n    moves=c['moves']\n    rec=parse_jsonl(c['records'])\n    log=parse_tsv(c['log'])\n    ok_rec = (moves==rec)\n    # log doesn't include kind; compare subset\n    subset=[{k:m[k] for k in ['turn','actor','from_x','from_y','to_x','to_y','legal']} for m in moves]\n    ok_log = (subset==log)\n    if not (ok_rec and ok_log):\n        print('MISMATCH',c['name'],'records',ok_rec,'log',ok_log)\n        if not ok_rec:\n            print(' moves',moves)\n            print(' rec  ',rec)\n        if not ok_log:\n            print(' subset',subset)\n            print(' log   ',log)\n    else:\n        print(c['name'],'files ok')\nPY\n"]
[175.001686, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
