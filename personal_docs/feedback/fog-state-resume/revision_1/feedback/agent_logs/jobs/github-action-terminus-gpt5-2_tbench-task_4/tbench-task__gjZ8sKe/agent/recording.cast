[175.009276, "o", "> "]
[175.009415, "o", "    ok_rec = (moves==rec)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[175.009568, "o", "    # log doesn't include kind; compare subset\r\n\u001b[?2004l\r"]
[175.009635, "o", "\u001b[?2004h> "]
[175.009931, "o", "    subset=[{k:m[k] for k in ['turn','actor','from_x','from_y','to_x','to_y','legal']} for m in moves]\r\n\u001b[?2004l\r"]
[175.009962, "o", "\u001b[?2004h"]
[175.009982, "o", "> "]
[175.010125, "o", "    ok_log = (subset==log)\r\n\u001b[?2004l\r\u001b[?2004h"]
[175.010154, "o", "> "]
[175.010275, "o", "    if not (ok_rec and ok_log):\r\n\u001b[?2004l\r"]
[175.010342, "o", "\u001b[?2004h> "]
[175.010542, "o", "        print('MISMATCH',c['name'],'records',ok_rec,'log',ok_log)\r\n\u001b[?2004l\r"]
[175.010609, "o", "\u001b[?2004h> "]
[175.010735, "o", "        if not ok_rec:\r\n\u001b[?2004l\r\u001b[?2004h"]
[175.010763, "o", "> "]
