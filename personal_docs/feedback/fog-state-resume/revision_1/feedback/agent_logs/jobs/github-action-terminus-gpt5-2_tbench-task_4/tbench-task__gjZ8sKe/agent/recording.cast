[141.257836, "i", "python3 - <<'PY'\nimport re\nfrom pathlib import Path\np=Path('/app/internal/f5/run.go')\ns=p.read_text()\n\n# Replace sigFor function wholesale (non-greedy up to closing brace at column 0)\npat=re.compile(r\"func sigFor\\(moves \\[\\]MoveRow\\) string \\{.*?^\\}\", re.S|re.M)\nm=pat.search(s)\nif not m:\n    raise SystemExit('sigFor function not found')\nnewsig='''func sigFor(moves []MoveRow) string {\n\\tacc := int64(2166136261)\n\\t// Signature is meant to be stable across equivalent fresh vs resume\n\\t// execution paths. The internal Turn counter can legitimately differ\n\\t// across those paths due to save/load boundaries, so we do not include\n\\t// MoveRow.Turn in the signature material.\n\\tfor _, m := range moves {\n\\t\\tacc ^= int64(m.FromX*7 + m.FromY*11 + m.ToX*13 + m.ToY*17)\n\\t\\tfor _, ch := range m.Actor + m.Kind {\n\\t\\t\\tacc ^= int64(ch)\n\\t\\t\\tacc = (acc * 16777619) & 0x7fffffff\n\\t\\t}\n\\t}\n\\treturn fmt.Sprintf(\"%x\", acc)\n}'''\ns=s[:m.start()]+newsig+s[m.end():]\n\n# Insert ApplyLit after applyWorld in runLoaded\nif 'func runLoaded' not in s:\n    raise SystemExit('runLoaded not found')\n# only insert if runLoaded doesn't already have ApplyLit immediately after applyWorld\npat2=re.compile(r\"(func runLoaded\\(w \\*World, steps \\[\\]ScriptStep, blob a0\\.ItemY, stale map\\[string\\]bool, profile Profile, radius int\\) \\[\\]MoveRow \\{\\n\\tapplyWorld\\(w, blob\\)\\n)(?!\\te4\\.ApplyLit\\()\")\ns, n = pat2.subn(r\"\\1\\t// Fresh execution applies lighting/visibility whenever the player state\\n\\t// is set. After restoring a saved world we must also initialize the\\n\\t// lit/seen fields from the restored position, otherwise resume runs can\\n\\t// diverge in what is considered observable.\\n\\te4.ApplyLit(w, radius, blindActive(w))\\n\", s, count=1)\nif n==0:\n    print('note: ApplyLit insertion skipped (already present or pattern mismatch)')\n\np.write_text(s)\nprint('patched',p)\nPY\n"]
