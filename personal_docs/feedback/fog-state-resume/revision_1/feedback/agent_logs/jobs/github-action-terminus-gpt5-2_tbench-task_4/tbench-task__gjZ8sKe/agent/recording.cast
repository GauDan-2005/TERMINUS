[259.987563, "o", "     1\tpackage f5\r\n     2\t\r\n     3\timport (\r\n     4\t\t\"encoding/json\"\r\n     5\t\t\"fmt\"\r\n     6\t\t\"os\"\r\n     7\t\t\"path/filepath\"\r\n     8\t\t\"strconv\"\r\n     9\t\t\"strings\"\r\n"]
[259.987665, "o", "    10\t\r\n    11\t\t\"sort\"\r\n    12\t\r\n    13\t\t\"fog.local/resume/internal/a0\"\r\n    14\t\t\"fog.local/resume/internal/b1\"\r\n    15\t\t\"fog.local/resume/internal/c2\"\r\n    16\t\t\"fog.local/resume/internal/d3\"\r\n    17\t\t\"fog.local/resume/internal/e4\"\r\n    18\t)\r\n"]
[259.987852, "o", "    19\t\r\n    20\tfunc sigFor(moves []MoveRow) string {\r\n    21\t\tacc := int64(2166136261)\r\n    22\t\t// Signature is meant to be stable across equivalent fresh vs resume\r\n    23\t\t// execution paths. The internal Turn counter can legitimately differ\r\n    24\t\t// across those paths due to save/load boundaries, so we do not include\r\n    25\t\t// MoveRow.Turn in the signature material.\r\n    26\t\tfor _, m := range moves {\r\n    27\t\t\tacc ^= int64(m.FromX*7 + m.FromY*11 + m.ToX*13 + m.ToY*17)\r\n    28\t\t\tfor _, ch := range m.Actor + m.Kind {\r\n    29\t\t\t\tacc ^= int64(ch)\r\n    30\t\t\t\tacc = (acc * 16777619) & 0x7fffffff\r\n    31\t\t\t}\r\n    32\t\t}\r\n    33\t\treturn fmt.Sprintf(\"%x\", acc)\r\n    34\t}\r\n    35\t\r\n    36\tfunc cloneWorld(w *World) *World {\r\n    37\t\tsize := w.Width * w.Height\r\n    38\t\tseen := append([]bool(nil), w.Seen...)\r\n    39\t\tlit := append([]bool(nil), w.Lit...)\r\n    40\t\tif len(seen) != size {\r\n"]
[259.988323, "o", "\u001b[?2004hroot@f8bd583533f9:/app# "]
[260.105972, "i", "nl -ba /app/internal/f5/run.go | sed -n '250,330p'\n"]
[260.106496, "o", "nl -ba /app/internal/f5/run.go | sed -n '250,330p'\r\n"]
[260.106737, "o", "\u001b[?2004l\r"]
[260.108764, "o", "   250\t\tsteps, err := LoadScript(root, name)\r\n   251\t\tif err != nil {\r\n   252\t\t\treturn CaseResult{}, err\r\n   253\t\t}\r\n   254\t\r\n   255\t\twFresh := cloneWorld(base)\r\n   256\t\twFresh.Effects = snapFromC2(c2.Seed(profileToC2(profile), wFresh.Turn))\r\n   257\t\tblob, stale := playUntilSave(wFresh, steps, profile, radius)\r\n   258\t\tfreshMoves := runDirect(wFresh, steps, profile, radius)\r\n   259\t\r\n   260\t\twResume := cloneWorld(base)\r\n   261\t\twResume.Effects = snapFromC2(c2.Seed(profileToC2(profile), wResume.Turn))\r\n   262\t\tplayUntilSave(wResume, steps, profile, radius)\r\n   263\t\tresumeMoves := runLoaded(wResume, steps, blob, stale, profile, radius)\r\n   264\t\r\n   265\t\tfreshIllegal, resumeIllegal := 0, 0\r\n   266\t\tfor _, m := range freshMoves {\r\n   267\t\t\tif !m.Legal {\r\n   268\t\t\t\tfreshIllegal++\r\n   269\t\t\t}\r\n   270\t\t}\r\n   271\t\tfor _, m := range resumeMoves {\r\n   272\t\t\tif !m.Legal {\r\n   273\t\t\t\tresumeIllegal++\r\n   274\t\t\t}\r\n   275\t\t}\r\n   276\t\tallMoves := append(append([]MoveRow{}, freshMoves...), resumeMoves...)\r\n   277\t\tcaseDir := filepath.Join(root, \"workspace\", name)\r\n   278\t\t_ = os.MkdirAll(caseDir, 0o755)\r\n   279\t\trecPath := filepath.Join(caseDir, \"records.jsonl\")\r\n   280\t\tlogPath := filepath.Join(caseDir, \"trace.tsv\")\r\n   281\t\tflushRows(recPath, logPath, name, allMoves)\r\n   282\t\r\n   283\t\tfresh := PathSummary{Sig: sigFor(freshMoves), Illegal: freshIllegal, Steps: len(freshMoves)}\r\n   284\t\tresume := PathSummary{Sig: sigFor(resumeMoves), Illegal: resumeIllegal, Steps: len(resumeMoves)}\r\n   285\t\tok := freshIllegal == 0 && resumeIllegal == 0 && fresh.Sig == resume.Sig\r\n   286\t\r\n   287\t\treturn CaseResult{\r\n   288\t\t\tName:       name,\r\n   289\t\t\tOK:         ok,\r\n   290\t\t\tFresh:      fresh,\r\n   291\t\t\tResume:     resume,\r\n   292\t\t\tMoves:      allMoves,\r\n   293\t\t\tVisibility: VisPair{FreshSeen: e4.CountSeen(wFresh), ResumeSeen: e4.CountSeen(wResume)},\r\n   294\t\t\tEffects:    effects,\r\n   295\t\t\tRecords:    recPath,\r\n   296\t\t\tLog:        logPath,\r\n   297\t\t}, nil\r\n   298\t}\r\n   299\t\r\n   300\tfunc flushRows(recPath, logPath, name string, moves []MoveRow) {\r\n   301\t\trec, _ := os.Create(recPath)\r\n   302\t\tdefer rec.Close()\r\n   303\t\tfor _, m := range moves {\r\n   304\t\t\tb, _ := json.Marshal(m)\r\n   305\t\t\t_, _ = rec.Write(append(b, '\\n'))\r\n   306\t\t}\r\n   307\t\tlog, _ := os.Create(logPath)\r\n   308\t\tdefer log.Close()\r\n   309\t\tfor _, m := range moves {\r\n   310\t\t\tfmt.Fprintf(log, \"%s\\t%d\\t%s\\t%d\\t%d\\t%d\\t%d\\t%v\\n\",\r\n   311\t\t\t\tname, m.Turn, m.Actor, m.FromX, m.FromY, m.ToX, m.ToY, m.Legal)\r\n   312\t\t}\r\n   313\t}\r\n"]
