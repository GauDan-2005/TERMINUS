[77.826508, "i", "apply_patch <<'PATCH'\n*** Begin Patch\n*** Update File: internal/f5/run.go\n@@\n func runLoaded(w *World, steps []ScriptStep, blob a0.ItemY, stale map[string]bool, profile Profile, radius int) []MoveRow {\n         applyWorld(w, blob)\n+        // Fresh execution applies lighting/visibility whenever the player state\n+        // is set. After restoring a saved world we must also initialize the\n+        // lit/seen fields from the restored position, otherwise resume runs can\n+        // diverge in what is considered observable.\n+        e4.ApplyLit(w, radius, blindActive(w))\n         cache := &b1.CacheX{Obs: map[string]bool{}}\n         b1.Merge(cache, blob)\n         merged := b1.Snapshot(cache)\n*** End Patch\nPATCH\n"]
